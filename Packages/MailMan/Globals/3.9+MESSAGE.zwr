^XMB(3.9,145951,2,1943,0)="""RTN"",""SDES2CRTCLNAVAIL"",264,0)"
^XMB(3.9,145951,2,1944,0)=" I SI+SI+$L(X)>80 S CNT=0,LT=$G(STIME),SDEL=0 S POP=1 D ERRLOG^SDES2JSON(.ERRORS,52,""Pattern exceeds 80 characters for date: ""_$$FMTISO^SDAMUTDT(D0,DA)) Q"
