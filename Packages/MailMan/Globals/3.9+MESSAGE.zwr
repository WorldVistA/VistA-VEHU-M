^XMB(3.9,145951,2,1895,0)="""RTN"",""SDES2CRTCLNAVAIL"",240,0)"
^XMB(3.9,145951,2,1896,0)=" S:M2?1N M2=""0""_M2 S:H2?1N H2=""0""_H2"
^XMB(3.9,145951,2,1897,0)="""RTN"",""SDES2CRTCLNAVAIL"",241,0)"
^XMB(3.9,145951,2,1898,0)="G4 S CNT=CNT+1,PATTERNS(DA,""T"",D0,2,CNT,0)=H1_M1_""^""_NSL ;^SC(DA,""T"",D0,2,CNT,0)=H1_M1_""^""_NSL"
