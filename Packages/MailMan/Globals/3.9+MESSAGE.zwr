^XMB(3.9,145944,2,1797,0)="""RTN"",""IBJDF6"",124,0)"
^XMB(3.9,145944,2,1798,0)=" S DIR(""A"")=""Minimum age of most recent bill comment (optional): """
^XMB(3.9,145944,2,1799,0)="""RTN"",""IBJDF6"",125,0)"
