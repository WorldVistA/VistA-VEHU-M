^XMB(3.9,145989,2,690,0)=" ; Date Rx Written (ISSUE DATE) cannot be in the future or after Rx Fill Date (Use LOGIN DATE instead)"
^XMB(3.9,145989,2,691,0)="""RTN"",""PSOASAP0"",203,0)"
