^XMB(3.9,145989,2,663,0)="""RTN"",""PSOASAP0"",189,0)"
^XMB(3.9,145989,2,664,0)="PAT22() ;ASAP 3.0 : Primary Prescription Coverage Type (Not Used)"
^XMB(3.9,145989,2,665,0)="""RTN"",""PSOASAP0"",190,0)"
^XMB(3.9,145989,2,666,0)=" ;       ASAP 4.0+:Country of Non-U.S. Resident"
^XMB(3.9,145989,2,667,0)="""RTN"",""PSOASAP0"",191,0)"
^XMB(3.9,145989,2,668,0)=" I PSOASVER=""3.0"" Q """""
^XMB(3.9,145989,2,669,0)="""RTN"",""PSOASAP0"",192,0)"
^XMB(3.9,145989,2,670,0)=" N CNTRYIEN,FIPSCODE"
^XMB(3.9,145989,2,671,0)="""RTN"",""PSOASAP0"",193,0)"
^XMB(3.9,145989,2,672,0)=" S CNTRYIEN=+$G(VAPA(25)) I 'CNTRYIEN Q """""
^XMB(3.9,145989,2,673,0)="""RTN"",""PSOASAP0"",194,0)"
^XMB(3.9,145989,2,674,0)=" S FIPSCODE=$$GET1^DIQ(779.004,CNTRYIEN,1.2)"
^XMB(3.9,145989,2,675,0)="""RTN"",""PSOASAP0"",195,0)"
