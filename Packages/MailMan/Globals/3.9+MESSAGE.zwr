^XMB(3.9,145960,2,261,0)="""RTN"",""MAGGTU4T"",4,0)"
^XMB(3.9,145960,2,262,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145960,2,263,0)="""RTN"",""MAGGTU4T"",5,0)"
^XMB(3.9,145960,2,264,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145960,2,265,0)="""RTN"",""MAGGTU4T"",6,0)"
^XMB(3.9,145960,2,266,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145960,2,267,0)="""RTN"",""MAGGTU4T"",7,0)"
^XMB(3.9,145960,2,268,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145960,2,269,0)="""RTN"",""MAGGTU4T"",8,0)"
^XMB(3.9,145960,2,270,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145960,2,271,0)="""RTN"",""MAGGTU4T"",9,0)"
^XMB(3.9,145960,2,272,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145960,2,273,0)="""RTN"",""MAGGTU4T"",10,0)"
^XMB(3.9,145960,2,274,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145960,2,275,0)="""RTN"",""MAGGTU4T"",11,0)"
^XMB(3.9,145960,2,276,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145960,2,277,0)="""RTN"",""MAGGTU4T"",12,0)"
^XMB(3.9,145960,2,278,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145960,2,279,0)="""RTN"",""MAGGTU4T"",13,0)"
^XMB(3.9,145960,2,280,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145960,2,281,0)="""RTN"",""MAGGTU4T"",14,0)"
^XMB(3.9,145960,2,282,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145960,2,283,0)="""RTN"",""MAGGTU4T"",15,0)"
^XMB(3.9,145960,2,284,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145960,2,285,0)="""RTN"",""MAGGTU4T"",16,0)"
^XMB(3.9,145960,2,286,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145960,2,287,0)="""RTN"",""MAGGTU4T"",17,0)"
^XMB(3.9,145960,2,288,0)=" ;;"
^XMB(3.9,145960,2,289,0)="""RTN"",""MAGGTU4T"",18,0)"
^XMB(3.9,145960,2,290,0)=" ; This routine contains the version control code and data specific"
^XMB(3.9,145960,2,291,0)="""RTN"",""MAGGTU4T"",19,0)"
^XMB(3.9,145960,2,292,0)=" ; to the TeleReader application. DO NOT ADD ANYTHING ELSE!"
^XMB(3.9,145960,2,293,0)="""RTN"",""MAGGTU4T"",20,0)"
^XMB(3.9,145960,2,294,0)=" Q"
^XMB(3.9,145960,2,295,0)="""RTN"",""MAGGTU4T"",21,0)"
^XMB(3.9,145960,2,296,0)=" ;"
^XMB(3.9,145960,2,297,0)="""RTN"",""MAGGTU4T"",22,0)"
^XMB(3.9,145960,2,298,0)="CLVERCT ;***** VERSION CONTROL TABLE FOR THE TELEREADER CLIENTS"
^XMB(3.9,145960,2,299,0)="""RTN"",""MAGGTU4T"",23,0)"
^XMB(3.9,145960,2,300,0)=" ;;=================================================================="
^XMB(3.9,145960,2,301,0)="""RTN"",""MAGGTU4T"",24,0)"
^XMB(3.9,145960,2,302,0)=" ;;| Version |Build|Seq #|                Comment                   |"
^XMB(3.9,145960,2,303,0)="""RTN"",""MAGGTU4T"",25,0)"
^XMB(3.9,145960,2,304,0)=" ;;|---------+-----+------------------------------------------------|"
^XMB(3.9,145960,2,305,0)="""RTN"",""MAGGTU4T"",26,0)"
^XMB(3.9,145960,2,306,0)=" ;;| 3.0.370 |   2 |  79 | Aug 2024                                 |"
^XMB(3.9,145960,2,307,0)="""RTN"",""MAGGTU4T"",27,0)"
^XMB(3.9,145960,2,308,0)=" ;;| 3.0.352 |   1 |  78 | Mar 2023                                 |"
^XMB(3.9,145960,2,309,0)="""RTN"",""MAGGTU4T"",28,0)"
^XMB(3.9,145960,2,310,0)=" ;;| 3.0.320 |   2 |  76 | Aug 2022                                 |"
^XMB(3.9,145960,2,311,0)="""RTN"",""MAGGTU4T"",29,0)"
^XMB(3.9,145960,2,312,0)=" ;;| 3.0.292 |   3 |  65 | Feb 2022                                 |"
^XMB(3.9,145960,2,313,0)="""RTN"",""MAGGTU4T"",30,0)"
^XMB(3.9,145960,2,314,0)=" ;;=================================================================="
^XMB(3.9,145960,2,315,0)="""RTN"",""MAGGTU4T"",31,0)"
^XMB(3.9,145960,2,316,0)=" ;"
^XMB(3.9,145960,2,317,0)="""RTN"",""MAGGTU4T"",32,0)"
^XMB(3.9,145960,2,318,0)=" ; Each row of the version control table contains the version and"
^XMB(3.9,145960,2,319,0)="""RTN"",""MAGGTU4T"",33,0)"
^XMB(3.9,145960,2,320,0)=" ; build number of a supported client. Released patches must also"
^XMB(3.9,145960,2,321,0)="""RTN"",""MAGGTU4T"",34,0)"
^XMB(3.9,145960,2,322,0)=" ; indicate the sequential numbers."
^XMB(3.9,145960,2,323,0)="""RTN"",""MAGGTU4T"",35,0)"
^XMB(3.9,145960,2,324,0)=" ;"
^XMB(3.9,145960,2,325,0)="""RTN"",""MAGGTU4T"",36,0)"
^XMB(3.9,145960,2,326,0)=" ; Sort order of the rows does not matter. However, the reversed"
^XMB(3.9,145960,2,327,0)="""RTN"",""MAGGTU4T"",37,0)"
^XMB(3.9,145960,2,328,0)=" ; order of patch sequential numbers is recommended."
^XMB(3.9,145960,2,329,0)="""RTN"",""MAGGTU4T"",38,0)"
^XMB(3.9,145960,2,330,0)=" ;"
^XMB(3.9,145960,2,331,0)="""RTN"",""MAGGTU4T"",39,0)"
^XMB(3.9,145960,2,332,0)=" ; NOTE:"
^XMB(3.9,145960,2,333,0)="""RTN"",""MAGGTU4T"",40,0)"
^XMB(3.9,145960,2,334,0)=" ;  Patch 352 removed support for"
