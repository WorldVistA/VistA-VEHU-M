^XMB(3.9,145937,2,1134,0)="^^7^7^3170123^"
^XMB(3.9,145937,2,1135,0)="""^DIC"",601.95,601.95,""%D"",1,0)"
^XMB(3.9,145937,2,1136,0)="An Instrument Exchange entry contains the specification for one or more "
^XMB(3.9,145937,2,1137,0)="""^DIC"",601.95,601.95,""%D"",2,0)"
^XMB(3.9,145937,2,1138,0)="Mental Health instruments, formatted as JSON.  An entry can be created in "
^XMB(3.9,145937,2,1139,0)="""^DIC"",601.95,601.95,""%D"",3,0)"
^XMB(3.9,145937,2,1140,0)="a source account, then transmitted to destination accounts.  In the "
^XMB(3.9,145937,2,1141,0)="""^DIC"",601.95,601.95,""%D"",4,0)"
^XMB(3.9,145937,2,1142,0)="destination account, the JSON data may be used to update Mental Health"
^XMB(3.9,145937,2,1143,0)="""^DIC"",601.95,601.95,""%D"",5,0)"
^XMB(3.9,145937,2,1144,0)="instrument files.  This allows the specification for Mental Health"
^XMB(3.9,145937,2,1145,0)="""^DIC"",601.95,601.95,""%D"",6,0)"
^XMB(3.9,145937,2,1146,0)="instruments to be transmitted via a KIDS build or a host file.  It "
^XMB(3.9,145937,2,1147,0)="""^DIC"",601.95,601.95,""%D"",7,0)"
^XMB(3.9,145937,2,1148,0)="also allows instrument specifications to be backed up."
^XMB(3.9,145937,2,1149,0)="""^DIC"",601.95,""B"",""MH INSTRUMENT EXCHANGE"",601.95)"
