^XMB(3.9,145936,2,600,0)=" ...S:$G(PSBIDA)="""" PSBIDA=$P(^PSB(53.79,PSBIEN,.9,PSBXA1,0),""^"",2),PSBOT1=$P(^VA(200,PSBIDA,0),""^"",2),PSBNAME=$P(^VA(200,PSBIDA,0),""^"",1)"
