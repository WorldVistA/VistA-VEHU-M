^XMB(3.9,145957,2,660,0)=" ;  GMRCORC = ORC segment from incoming HL7 msg"
^XMB(3.9,145957,2,661,0)="""RTN"",""GMRCIMSG"",185,0)"
^XMB(3.9,145957,2,662,0)=" ;  GMRCCRNR = 1 if a converted site is involved"
^XMB(3.9,145957,2,663,0)="""RTN"",""GMRCIMSG"",186,0)"
^XMB(3.9,145957,2,664,0)=" ;  GMRCMSG = name of array where HL7 message is stored (P205 wtc 8/21/24)"
^XMB(3.9,145957,2,665,0)="""RTN"",""GMRCIMSG"",187,0)"
