^XMB(3.9,145946,2,1440,0)="0^5^B30988652"
^XMB(3.9,145946,2,1441,0)="""RTN"",""IBCMDT2"",1,0)"
^XMB(3.9,145946,2,1442,0)="IBCMDT2 ;ALB/VD - INSURANCE PLANS MISSING DATA REPORT (COMPILE) ; 10-APR-15"
^XMB(3.9,145946,2,1443,0)="""RTN"",""IBCMDT2"",2,0)"
^XMB(3.9,145946,2,1444,0)=" ;;2.0;INTEGRATED BILLING ;**549**; 10-APR-15;Build 0"
^XMB(3.9,145946,2,1445,0)="""RTN"",""IBCMDT2"",3,0)"
^XMB(3.9,145946,2,1446,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,1447,0)="""RTN"",""IBCMDT2"",4,0)"
^XMB(3.9,145946,2,1448,0)=" ;"
^XMB(3.9,145946,2,1449,0)="""RTN"",""IBCMDT2"",5,0)"
^XMB(3.9,145946,2,1450,0)="EN ; Queued Entry Point for Report."
^XMB(3.9,145946,2,1451,0)="""RTN"",""IBCMDT2"",6,0)"
^XMB(3.9,145946,2,1452,0)=" ;  Required variable input:  FLTRS,IBAI, IBAPL, IBGRN, IBPTY, IBTFT, IBEPT,"
^XMB(3.9,145946,2,1453,0)="""RTN"",""IBCMDT2"",7,0)"
^XMB(3.9,145946,2,1454,0)=" ;                            IBCLM, IBBIN, IBNMSPC,IBPCN"
^XMB(3.9,145946,2,1455,0)="""RTN"",""IBCMDT2"",8,0)"
^XMB(3.9,145946,2,1456,0)=" ;  ^TMP(""IBCMDT"",IBNMSPC) required if all companies and plans not selected"
^XMB(3.9,145946,2,1457,0)="""RTN"",""IBCMDT2"",9,0)"
^XMB(3.9,145946,2,1458,0)=" ;"
^XMB(3.9,145946,2,1459,0)="""RTN"",""IBCMDT2"",10,0)"
^XMB(3.9,145946,2,1460,0)=" ; - compile report data"
^XMB(3.9,145946,2,1461,0)="""RTN"",""IBCMDT2"",11,0)"
^XMB(3.9,145946,2,1462,0)=" N IBI,IBIC1,IBCNS"
^XMB(3.9,145946,2,1463,0)="""RTN"",""IBCMDT2"",12,0)"
^XMB(3.9,145946,2,1464,0)=" S IBI=0 K ^TMP($J,""PR"")"
^XMB(3.9,145946,2,1465,0)="""RTN"",""IBCMDT2"",13,0)"
^XMB(3.9,145946,2,1466,0)=" S IBIC1="""""
^XMB(3.9,145946,2,1467,0)="""RTN"",""IBCMDT2"",14,0)"
^XMB(3.9,145946,2,1468,0)=" F  S IBIC1=$O(^TMP(""IBCMDT"",IBNMSPC,IBIC1)) Q:IBIC1=""""  D"
^XMB(3.9,145946,2,1469,0)="""RTN"",""IBCMDT2"",15,0)"
^XMB(3.9,145946,2,1470,0)=" . S IBCNS=0"
^XMB(3.9,145946,2,1471,0)="""RTN"",""IBCMDT2"",16,0)"
^XMB(3.9,145946,2,1472,0)=" . F  S IBCNS=$O(^TMP(""IBCMDT"",IBNMSPC,IBIC1,IBCNS)) Q:'IBCNS  D"
^XMB(3.9,145946,2,1473,0)="""RTN"",""IBCMDT2"",17,0)"
^XMB(3.9,145946,2,1474,0)=" . . D GATH"
^XMB(3.9,145946,2,1475,0)="""RTN"",""IBCMDT2"",18,0)"
^XMB(3.9,145946,2,1476,0)=" Q"
^XMB(3.9,145946,2,1477,0)="""RTN"",""IBCMDT2"",19,0)"
^XMB(3.9,145946,2,1478,0)=" ;"
^XMB(3.9,145946,2,1479,0)="""RTN"",""IBCMDT2"",20,0)"
^XMB(3.9,145946,2,1480,0)="GATH ; Gather all data for a company."
^XMB(3.9,145946,2,1481,0)="""RTN"",""IBCMDT2"",21,0)"
^XMB(3.9,145946,2,1482,0)=" N IBCPS,IBCPT,IBCST"
^XMB(3.9,145946,2,1483,0)="""RTN"",""IBCMDT2"",22,0)"
^XMB(3.9,145946,2,1484,0)=" S IBI=IBI+1,(IBCPT,IBCPS,IBCST)=0 ; initialize counters"
^XMB(3.9,145946,2,1485,0)="""RTN"",""IBCMDT2"",23,0)"
^XMB(3.9,145946,2,1486,0)=" D PLAN ; gather plan info"
^XMB(3.9,145946,2,1487,0)="""RTN"",""IBCMDT2"",24,0)"
^XMB(3.9,145946,2,1488,0)=" ;"
^XMB(3.9,145946,2,1489,0)="""RTN"",""IBCMDT2"",25,0)"
^XMB(3.9,145946,2,1490,0)=" ; - set final company info"
^XMB(3.9,145946,2,1491,0)="""RTN"",""IBCMDT2"",26,0)"
^XMB(3.9,145946,2,1492,0)=" S ^TMP($J,""PR"",IBI)=$$COMPINF(IBCNS)_""^""_IBCPT_""^""_IBCPS"
^XMB(3.9,145946,2,1493,0)="""RTN"",""IBCMDT2"",27,0)"
^XMB(3.9,145946,2,1494,0)=" Q"
^XMB(3.9,145946,2,1495,0)="""RTN"",""IBCMDT2"",28,0)"
^XMB(3.9,145946,2,1496,0)=" ;"
^XMB(3.9,145946,2,1497,0)="""RTN"",""IBCMDT2"",29,0)"
^XMB(3.9,145946,2,1498,0)="PLAN ; Gather Insurance Plan information, if necessary"
^XMB(3.9,145946,2,1499,0)="""RTN"",""IBCMDT2"",30,0)"
^XMB(3.9,145946,2,1500,0)=" ;  Input:  IBCNS -- Pointer to the insurance company in file #36"
^XMB(3.9,145946,2,1501,0)="""RTN"",""IBCMDT2"",31,0)"
^XMB(3.9,145946,2,1502,0)=" ;         initialized counters, plus the 'Plan' array (^TMP(""IBINC"",$J))"
^XMB(3.9,145946,2,1503,0)="""RTN"",""IBCMDT2"",32,0)"
^XMB(3.9,145946,2,1504,0)=" ;"
^XMB(3.9,145946,2,1505,0)="""RTN"",""IBCMDT2"",33,0)"
^XMB(3.9,145946,2,1506,0)=" N FNDONE,IBPTR,PLNDATA,POSWT"
^XMB(3.9,145946,2,1507,0)="""RTN"",""IBCMDT2"",34,0)"
^XMB(3.9,145946,2,1508,0)=" S IBPTR=0"
^XMB(3.9,145946,2,1509,0)="""RTN"",""IBCMDT2"",35,0)"
^XMB(3.9,145946,2,1510,0)=" S POSWT=$S($$GET1^DIQ(36,IBCNS,.13)=""PRESCRIPTION ONLY"":1,1:0)"
^XMB(3.9,145946,2,1511,0)="""RTN"",""IBCMDT2"",36,0)"
^XMB(3.9,145946,2,1512,0)=" F  S IBPTR=$O(^IBA(355.3,""B"",IBCNS,IBPTR)) Q:'IBPTR  D"
^XMB(3.9,145946,2,1513,0)="""RTN"",""IBCMDT2"",37,0)"
^XMB(3.9,145946,2,1514,0)=" . S PLNDATA=$$PLANINF(IBPTR,POSWT)"
^XMB(3.9,145946,2,1515,0)="""RTN"",""IBCMDT2"",38,0)"
^XMB(3.9,145946,2,1516,0)=" . Q:(+PLNDATA=-2)                          ; Skip inactive plans."
^XMB(3.9,145946,2,1517,0)="""RTN"",""IBCMDT2"",39,0)"
^XMB(3.9,145946,2,1518,0)=" . ;"
^XMB(3.9,145946,2,1519,0)="""RTN"",""IBCMDT2"",40,0)"
^XMB(3.9,145946,2,1520,0)=" . ; If there's no Missing Plan Data & not looking for coverage limitations."
^XMB(3.9,145946,2,1521,0)="""RTN"",""IBCMDT2"",41,0)"
^XMB(3.9,145946,2,1522,0)=" . I (+PLNDATA=-1),'+$G(IBMDTSPC(""IBCLM"")) Q"
^XMB(3.9,145946,2,1523,0)="""RTN"",""IBCMDT2"",42,0)"
^XMB(3.9,145946,2,1524,0)=" . S ^TMP($J,""PR"",IBI,IBPTR)=PLNDATA"
^XMB(3.9,145946,2,1525,0)="""RTN"",""IBCMDT2"",43,0)"
^XMB(3.9,145946,2,1526,0)=" . I +$G(IBMDTSPC(""IBCLM"")) D"
^XMB(3.9,145946,2,1527,0)="""RTN"",""IBCMDT2"",44,0)"
^XMB(3.9,145946,2,1528,0)=" . . S FNDONE=+$$GCVLIMS(IBI,IBPTR,1)  ; This will create the cov. limit. nodes"
^XMB(3.9,145946,2,1529,0)="""RTN"",""IBCMDT2"",45,0)"
^XMB(3.9,145946,2,1530,0)=" . . ;"
^XMB(3.9,145946,2,1531,0)="""RTN"",""IBCMDT2"",46,0)"
^XMB(3.9,145946,2,1532,0)=" . . ; No missing coverage limitations AND no other missing data on requested"
^XMB(3.9,145946,2,1533,0)="""RTN"",""IBCMDT2"",47,0)"
^XMB(3.9,145946,2,1534,0)=" . . ; Filters found, kill reference to the plan."
^XMB(3.9,145946,2,1535,0)="""RTN"",""IBCMDT2"",48,0)"
^XMB(3.9,145946,2,1536,0)=" . . I '+FNDONE,+PLNDATA=-1 K ^TMP($J,""PR"",IBI,IBPTR)"
^XMB(3.9,145946,2,1537,0)="""RTN"",""IBCMDT2"",49,0)"
^XMB(3.9,145946,2,1538,0)=" Q"
^XMB(3.9,145946,2,1539,0)="""RTN"",""IBCMDT2"",50,0)"
^XMB(3.9,145946,2,1540,0)=" ;"
^XMB(3.9,145946,2,1541,0)="""RTN"",""IBCMDT2"",51,0)"
^XMB(3.9,145946,2,1542,0)="COMPINF(IBCNS) ; Return formatted Insurance Company information"
^XMB(3.9,145946,2,1543,0)="""RTN"",""IBCMDT2"",52,0)"
^XMB(3.9,145946,2,1544,0)=" ;  Input:  IBCNS  --  Pointer to the insurance company in file #36"
^XMB(3.9,145946,2,1545,0)="""RTN"",""IBCMDT2"",53,0)"
^XMB(3.9,145946,2,1546,0)=" ; Output:  company name ^ addr ^ city/st/zip"
^XMB(3.9,145946,2,1547,0)="""RTN"",""IBCMDT2"",54,0)"
^XMB(3.9,145946,2,1548,0)=" ;"
^XMB(3.9,145946,2,1549,0)="""RTN"",""IBCMDT2"",55,0)"
^XMB(3.9,145946,2,1550,0)=" N POSWT,ST,X"
^XMB(3.9,145946,2,1551,0)="""RTN"",""IBCMDT2"",56,0)"
^XMB(3.9,145946,2,1552,0)=" S POSWT=$S($$GET1^DIQ(36,IBCNS,.13)=""PRESCRIPTION ONLY"":1,1:0)"
^XMB(3.9,145946,2,1553,0)="""RTN"",""IBCMDT2"",57,0)"
^XMB(3.9,145946,2,1554,0)=" S ST=$P($G(^DIC(5,+$$GET1^DIQ(36,IBCNS,.115,""I""),0)),U,2)"
^XMB(3.9,145946,2,1555,0)="""RTN"",""IBCMDT2"",58,0)"
^XMB(3.9,145946,2,1556,0)=" S X=POSWT_U_$$GET1^DIQ(36,IBCNS,.01)_U_$$GET1^DIQ(36,IBCNS,.111)"
^XMB(3.9,145946,2,1557,0)="""RTN"",""IBCMDT2"",59,0)"
^XMB(3.9,145946,2,1558,0)=" S X=X_U_$$GET1^DIQ(36,IBCNS,.114)_"", ""_ST_"" ""_$$GET1^DIQ(36,IBCNS,.116)"
^XMB(3.9,145946,2,1559,0)="""RTN"",""IBCMDT2"",60,0)"
^XMB(3.9,145946,2,1560,0)=" Q X"
^XMB(3.9,145946,2,1561,0)="""RTN"",""IBCMDT2"",61,0)"
^XMB(3.9,145946,2,1562,0)=" ;"
^XMB(3.9,145946,2,1563,0)="""RTN"",""IBCMDT2"",62,0)"
^XMB(3.9,145946,2,1564,0)="PLANINF(PLAN,POSWT) ; Return formatted Insurance Plan information."
^XMB(3.9,145946,2,1565,0)="""RTN"",""IBCMDT2"",63,0)"
^XMB(3.9,145946,2,1566,0)=" ; Input:   PLAN    - Pointer to the plan in file #355.3"
^XMB(3.9,145946,2,1567,0)="""RTN"",""IBCMDT2"",64,0)"
^XMB(3.9,145946,2,1568,0)=" ;          POSWT   -  PRESCRIPTION ONLY indicator"
^XMB(3.9,145946,2,1569,0)="""RTN"",""IBCMDT2"",65,0)"
^XMB(3.9,145946,2,1570,0)=" ; Returns: A1^A2^A3^...^A8 Where"
^XMB(3.9,145946,2,1571,0)="""RTN"",""IBCMDT2"",66,0)"
^XMB(3.9,145946,2,1572,0)=" ;           A1 - -2 if inactive plan, -1 if no missing data found, else 0"
^XMB(3.9,145946,2,1573,0)="""RTN"",""IBCMDT2"",67,0)"
^XMB(3.9,145946,2,1574,0)=" ;           A2 - Plan Number"
^XMB(3.9,145946,2,1575,0)="""RTN"",""IBCMDT2"",68,0)"
^XMB(3.9,145946,2,1576,0)=" ;           A3 - Plan Name"
^XMB(3.9,145946,2,1577,0)="""RTN"",""IBCMDT2"",69,0)"
^XMB(3.9,145946,2,1578,0)=" ;           A4 - Type of Plan (Group or Individual"
^XMB(3.9,145946,2,1579,0)="""RTN"",""IBCMDT2"",70,0)"
^XMB(3.9,145946,2,1580,0)=" ;           A5 - Electronic Plan Type"
^XMB(3.9,145946,2,1581,0)="""RTN"",""IBCMDT2"",71,0)"
^XMB(3.9,145946,2,1582,0)=" ;           A6 - Timely filing Time Frame"
^XMB(3.9,145946,2,1583,0)="""RTN"",""IBCMDT2"",72,0)"
^XMB(3.9,145946,2,1584,0)=" ;           A7 - Banking Identification Number"
^XMB(3.9,145946,2,1585,0)="""RTN"",""IBCMDT2"",73,0)"
^XMB(3.9,145946,2,1586,0)=" ;           A8 - Process Control Number"
^XMB(3.9,145946,2,1587,0)="""RTN"",""IBCMDT2"",74,0)"
^XMB(3.9,145946,2,1588,0)=" ;"
^XMB(3.9,145946,2,1589,0)="""RTN"",""IBCMDT2"",75,0)"
^XMB(3.9,145946,2,1590,0)=" N BIN,EPT,NAME,NUM,PCN,TFTF,TYP,VAL"
^XMB(3.9,145946,2,1591,0)="""RTN"",""IBCMDT2"",76,0)"
^XMB(3.9,145946,2,1592,0)=" S VAL=-2"
^XMB(3.9,145946,2,1593,0)="""RTN"",""IBCMDT2"",77,0)"
^XMB(3.9,145946,2,1594,0)=" I +$$GET1^DIQ(355.3,+PLAN,.11,""I"") Q VAL       ; INACTIVE Plan, skip"
^XMB(3.9,145946,2,1595,0)="""RTN"",""IBCMDT2"",78,0)"
^XMB(3.9,145946,2,1596,0)=" S VAL=-1"
^XMB(3.9,145946,2,1597,0)="""RTN"",""IBCMDT2"",79,0)"
^XMB(3.9,145946,2,1598,0)=" S NAME=$E($$GET1^DIQ(355.3,+PLAN,.03),1,45)    ; 45 Chars max"
^XMB(3.9,145946,2,1599,0)="""RTN"",""IBCMDT2"",80,0)"
^XMB(3.9,145946,2,1600,0)=" S NUM=$$GET1^DIQ(355.3,+PLAN,.04)              ; 17 Chars max"
^XMB(3.9,145946,2,1601,0)="""RTN"",""IBCMDT2"",81,0)"
^XMB(3.9,145946,2,1602,0)=" S:'$L(NUM) NUM=""#######"""
^XMB(3.9,145946,2,1603,0)="""RTN"",""IBCMDT2"",82,0)"
^XMB(3.9,145946,2,1604,0)=" I +$G(IBMDTSPC(""IBGRN"")),NUM=""#######"" S VAL=0 ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1605,0)="""RTN"",""IBCMDT2"",83,0)"
^XMB(3.9,145946,2,1606,0)=" S TYP=$$GET1^DIQ(355.3,+PLAN,.09)              ; 40 Chars max"
^XMB(3.9,145946,2,1607,0)="""RTN"",""IBCMDT2"",84,0)"
^XMB(3.9,145946,2,1608,0)=" S:'$L(TYP) TYP=""#######"""
^XMB(3.9,145946,2,1609,0)="""RTN"",""IBCMDT2"",85,0)"
^XMB(3.9,145946,2,1610,0)=" I +$G(IBMDTSPC(""IBPTY"")),TYP=""#######"" S VAL=0 ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1611,0)="""RTN"",""IBCMDT2"",86,0)"
^XMB(3.9,145946,2,1612,0)=" S EPT=$$GET1^DIQ(355.3,+PLAN,.15)              ; 26 Chars max"
^XMB(3.9,145946,2,1613,0)="""RTN"",""IBCMDT2"",87,0)"
^XMB(3.9,145946,2,1614,0)=" S:'$L(EPT) EPT=""#######"""
^XMB(3.9,145946,2,1615,0)="""RTN"",""IBCMDT2"",88,0)"
^XMB(3.9,145946,2,1616,0)=" I +$G(IBMDTSPC(""IBEPT"")),EPT=""#######"" S VAL=0 ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1617,0)="""RTN"",""IBCMDT2"",89,0)"
^XMB(3.9,145946,2,1618,0)=" S TFTF=$$FTFGP^IBCNEUT7(PLAN,1)                ; Around 30 Chars max"
^XMB(3.9,145946,2,1619,0)="""RTN"",""IBCMDT2"",90,0)"
^XMB(3.9,145946,2,1620,0)=" I +$G(IBMDTSPC(""IBTFT"")),TFTF[""###"" S VAL=0    ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1621,0)="""RTN"",""IBCMDT2"",91,0)"
^XMB(3.9,145946,2,1622,0)=" S BIN=$$GET1^DIQ(355.3,+PLAN,6.02)             ; 10 Chars max"
^XMB(3.9,145946,2,1623,0)="""RTN"",""IBCMDT2"",92,0)"
^XMB(3.9,145946,2,1624,0)=" ;"
^XMB(3.9,145946,2,1625,0)="""RTN"",""IBCMDT2"",93,0)"
^XMB(3.9,145946,2,1626,0)=" ; If the plan is Prescription Only AND the Banking Identifier is blank, indicate it"
^XMB(3.9,145946,2,1627,0)="""RTN"",""IBCMDT2"",94,0)"
^XMB(3.9,145946,2,1628,0)=" I +POSWT,'$L(BIN) S BIN=""#######"""
^XMB(3.9,145946,2,1629,0)="""RTN"",""IBCMDT2"",95,0)"
^XMB(3.9,145946,2,1630,0)=" I +$G(IBMDTSPC(""IBBIN"")),+POSWT,BIN=""#######"" S VAL=0  ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1631,0)="""RTN"",""IBCMDT2"",96,0)"
^XMB(3.9,145946,2,1632,0)=" S PCN=$$GET1^DIQ(355.3,+PLAN,6.03)             ; 20 Chars max"
^XMB(3.9,145946,2,1633,0)="""RTN"",""IBCMDT2"",97,0)"
^XMB(3.9,145946,2,1634,0)=" ;"
^XMB(3.9,145946,2,1635,0)="""RTN"",""IBCMDT2"",98,0)"
^XMB(3.9,145946,2,1636,0)=" ; If the plan is Prescription Only AND the Process Control Number is blank, indicate it"
^XMB(3.9,145946,2,1637,0)="""RTN"",""IBCMDT2"",99,0)"
^XMB(3.9,145946,2,1638,0)=" I +POSWT,'$L(PCN) S PCN=""#######"""
^XMB(3.9,145946,2,1639,0)="""RTN"",""IBCMDT2"",100,0)"
^XMB(3.9,145946,2,1640,0)=" I +$G(IBMDTSPC(""IBPCN"")),+POSWT,PCN=""#######"" S VAL=0    ; Found Missing data for a Filter"
^XMB(3.9,145946,2,1641,0)="""RTN"",""IBCMDT2"",101,0)"
^XMB(3.9,145946,2,1642,0)=" Q VAL_U_NUM_U_$E(NAME,1,12)_U_$E(TYP,1,12)_U_$E(EPT,1,12)_U_TFTF_U_BIN_U_PCN"
^XMB(3.9,145946,2,1643,0)="""RTN"",""IBCMDT2"",102,0)"
^XMB(3.9,145946,2,1644,0)=" ;"
^XMB(3.9,145946,2,1645,0)="""RTN"",""IBCMDT2"",103,0)"
^XMB(3.9,145946,2,1646,0)="GCVLIMS(IBI,PLAN,RECIND) ; Obtain Plans that may have Coverage Limits missing."
^XMB(3.9,145946,2,1647,0)="""RTN"",""IBCMDT2"",104,0)"
^XMB(3.9,145946,2,1648,0)=" ;  Input:  IBI    --  Line counter"
^XMB(3.9,145946,2,1649,0)="""RTN"",""IBCMDT2"",105,0)"
^XMB(3.9,145946,2,1650,0)=" ;          IBCNS  --  Pointer to the insurance company in file #36"
^XMB(3.9,145946,2,1651,0)="""RTN"",""IBCMDT2"",106,0)"
^XMB(3.9,145946,2,1652,0)=" ;          RECIND --  Indicator to determine if header record for plan is already set"
^XMB(3.9,145946,2,1653,0)="""RTN"",""IBCMDT2"",107,0)"
^XMB(3.9,145946,2,1654,0)=" ;                     0 means ^TMP($J,""PR"",IBI,IBPTR) is already set."
^XMB(3.9,145946,2,1655,0)="""RTN"",""IBCMDT2"",108,0)"
^XMB(3.9,145946,2,1656,0)=" ;                     1 means ^TMP($J,""PR"",IBI,IBPTR) is not set yet."
^XMB(3.9,145946,2,1657,0)="""RTN"",""IBCMDT2"",109,0)"
^XMB(3.9,145946,2,1658,0)=" ;  Output: This will create the ^TMP($J,""PR"",IBI,IBPTR,IBCVLM) node"
^XMB(3.9,145946,2,1659,0)="""RTN"",""IBCMDT2"",110,0)"
^XMB(3.9,145946,2,1660,0)=" ;          FOUND  --  0 means a missing data coverage limitation was not found."
^XMB(3.9,145946,2,1661,0)="""RTN"",""IBCMDT2"",111,0)"
^XMB(3.9,145946,2,1662,0)=" ;                     1 means a missing data coverage limitation was found."
^XMB(3.9,145946,2,1663,0)="""RTN"",""IBCMDT2"",112,0)"
^XMB(3.9,145946,2,1664,0)=" ;"
^XMB(3.9,145946,2,1665,0)="""RTN"",""IBCMDT2"",113,0)"
^XMB(3.9,145946,2,1666,0)=" N FOUND,IBCAT,IBCOV,IBCPTR,IBCSTA,IBCVDAT,IBEFDT,IBRECDT,IBRECN,IBREC,VAL"
^XMB(3.9,145946,2,1667,0)="""RTN"",""IBCMDT2"",114,0)"
^XMB(3.9,145946,2,1668,0)=" S (FOUND,IBCPTR)=0"
^XMB(3.9,145946,2,1669,0)="""RTN"",""IBCMDT2"",115,0)"
^XMB(3.9,145946,2,1670,0)=" I '$D(^IBA(355.32,""APCD"",PLAN)) D  Q +FOUND"
^XMB(3.9,145946,2,1671,0)="""RTN"",""IBCMDT2"",116,0)"
^XMB(3.9,145946,2,1672,0)=" . I '+$G(IBMDTSPC(""IBCLM"")) Q"
^XMB(3.9,145946,2,1673,0)="""RTN"",""IBCMDT2"",117,0)"
^XMB(3.9,145946,2,1674,0)=" . S FOUND=1,IBCPTR=IBCPTR+1"
^XMB(3.9,145946,2,1675,0)="""RTN"",""IBCMDT2"",118,0)"
^XMB(3.9,145946,2,1676,0)=" . S ^TMP($J,""PR"",IBI,IBPTR,IBCPTR)=""This plan has no coverage limitations defined."""
^XMB(3.9,145946,2,1677,0)="""RTN"",""IBCMDT2"",119,0)"
^XMB(3.9,145946,2,1678,0)=" S IBCAT=0"
^XMB(3.9,145946,2,1679,0)="""RTN"",""IBCMDT2"",120,0)"
^XMB(3.9,145946,2,1680,0)=" F  S IBCAT=$O(^IBE(355.31,IBCAT)) Q:'+IBCAT  D"
^XMB(3.9,145946,2,1681,0)="""RTN"",""IBCMDT2"",121,0)"
^XMB(3.9,145946,2,1682,0)=" . I '$D(^IBA(355.32,""APCD"",PLAN,IBCAT)) D  Q"
^XMB(3.9,145946,2,1683,0)="""RTN"",""IBCMDT2"",122,0)"
^XMB(3.9,145946,2,1684,0)=" . . S IBCOV=$$GET1^DIQ(355.31,IBCAT,.01)"
^XMB(3.9,145946,2,1685,0)="""RTN"",""IBCMDT2"",123,0)"
^XMB(3.9,145946,2,1686,0)=" . . S IBEFDT=""#######"",IBCSTA=""#######"""
^XMB(3.9,145946,2,1687,0)="""RTN"",""IBCMDT2"",124,0)"
^XMB(3.9,145946,2,1688,0)=" . . S IBCVDAT=IBCOV_U_IBEFDT_U_IBCSTA,FOUND=1"
^XMB(3.9,145946,2,1689,0)="""RTN"",""IBCMDT2"",125,0)"
^XMB(3.9,145946,2,1690,0)=" . . S IBCPTR=IBCPTR+1"
^XMB(3.9,145946,2,1691,0)="""RTN"",""IBCMDT2"",126,0)"
^XMB(3.9,145946,2,1692,0)=" . . S ^TMP($J,""PR"",IBI,IBPTR,IBCPTR)=IBCVDAT"
^XMB(3.9,145946,2,1693,0)="""RTN"",""IBCMDT2"",127,0)"
^XMB(3.9,145946,2,1694,0)=" F  S IBCAT=$O(^IBA(355.32,""APCD"",PLAN,IBCAT)) Q:IBCAT=""""  D"
^XMB(3.9,145946,2,1695,0)="""RTN"",""IBCMDT2"",128,0)"
^XMB(3.9,145946,2,1696,0)=" . S IBRECDT="""""
^XMB(3.9,145946,2,1697,0)="""RTN"",""IBCMDT2"",129,0)"
^XMB(3.9,145946,2,1698,0)=" . F  S IBRECDT=$O(^IBA(355.32,""APCD"",PLAN,IBCAT,IBRECDT)) Q:IBRECDT=""""  D"
^XMB(3.9,145946,2,1699,0)="""RTN"",""IBCMDT2"",130,0)"
^XMB(3.9,145946,2,1700,0)=" . . S IBRECN="""""
^XMB(3.9,145946,2,1701,0)="""RTN"",""IBCMDT2"",131,0)"
^XMB(3.9,145946,2,1702,0)=" . . F  S IBRECN=$O(^IBA(355.32,""APCD"",PLAN,IBCAT,IBRECDT,IBRECN)) Q:IBRECN=""""  D"
^XMB(3.9,145946,2,1703,0)="""RTN"",""IBCMDT2"",132,0)"
^XMB(3.9,145946,2,1704,0)=" . . . S IBEFDT=$$DAT1^IBOUTL($$GET1^DIQ(355.32,IBRECN,.03,""I""))"
^XMB(3.9,145946,2,1705,0)="""RTN"",""IBCMDT2"",133,0)"
^XMB(3.9,145946,2,1706,0)=" . . . I +$G(IBMDTSPC(""IBCLM"")) S IBEFDT=$S(+$L(IBEFDT):IBEFDT,1:""#######"")   ; Effective Date"
^XMB(3.9,145946,2,1707,0)="""RTN"",""IBCMDT2"",134,0)"
^XMB(3.9,145946,2,1708,0)=" . . . S IBCOV=$$GET1^DIQ(355.32,IBRECN,.02)"
^XMB(3.9,145946,2,1709,0)="""RTN"",""IBCMDT2"",135,0)"
^XMB(3.9,145946,2,1710,0)=" . . . I +$G(IBMDTSPC(""IBCLM"")) S IBCOV=$S(+$L(IBCOV):IBCOV,1:""#######"")      ; Coverage Category"
^XMB(3.9,145946,2,1711,0)="""RTN"",""IBCMDT2"",136,0)"
^XMB(3.9,145946,2,1712,0)=" . . . S IBCSTA=$$GET1^DIQ(355.32,IBRECN,.04)"
^XMB(3.9,145946,2,1713,0)="""RTN"",""IBCMDT2"",137,0)"
^XMB(3.9,145946,2,1714,0)=" . . . I +$G(IBMDTSPC(""IBCLM"")) S IBCSTA=$S(+$L(IBCSTA):IBCSTA,1:""#######"")   ; Coverage Status"
^XMB(3.9,145946,2,1715,0)="""RTN"",""IBCMDT2"",138,0)"
^XMB(3.9,145946,2,1716,0)=" . . . S IBCVDAT=IBCOV_U_IBEFDT_U_IBCSTA"
^XMB(3.9,145946,2,1717,0)="""RTN"",""IBCMDT2"",139,0)"
^XMB(3.9,145946,2,1718,0)=" . . . I IBCVDAT[""#######"" S FOUND=1"
^XMB(3.9,145946,2,1719,0)="""RTN"",""IBCMDT2"",140,0)"
^XMB(3.9,145946,2,1720,0)=" . . . S IBCPTR=IBCPTR+1"
^XMB(3.9,145946,2,1721,0)="""RTN"",""IBCMDT2"",141,0)"
^XMB(3.9,145946,2,1722,0)=" . . . I +FOUND S ^TMP($J,""PR"",IBI,IBPTR,IBCPTR)=IBCVDAT"
^XMB(3.9,145946,2,1723,0)="""RTN"",""IBCMDT2"",142,0)"
^XMB(3.9,145946,2,1724,0)=" Q +FOUND"
^XMB(3.9,145946,2,1725,0)="""RTN"",""IBCMDT2"",143,0)"
^XMB(3.9,145946,2,1726,0)=" ;"
^XMB(3.9,145946,2,1727,0)="""RTN"",""IBCMDT3"")"
^XMB(3.9,145946,2,1728,0)="0^4^B9544257"
^XMB(3.9,145946,2,1729,0)="""RTN"",""IBCMDT3"",1,0)"
^XMB(3.9,145946,2,1730,0)="IBCMDT3 ;ALB/VD - INSURANCE PLANS MISSING DATA REPORT (PRINT) ; 10-APR-15"
^XMB(3.9,145946,2,1731,0)="""RTN"",""IBCMDT3"",2,0)"
^XMB(3.9,145946,2,1732,0)=" ;;2.0;INTEGRATED BILLING ;**549**; 10-APR-15;Build 0"
^XMB(3.9,145946,2,1733,0)="""RTN"",""IBCMDT3"",3,0)"
^XMB(3.9,145946,2,1734,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,1735,0)="""RTN"",""IBCMDT3"",4,0)"
^XMB(3.9,145946,2,1736,0)=" ;"
^XMB(3.9,145946,2,1737,0)="""RTN"",""IBCMDT3"",5,0)"
^XMB(3.9,145946,2,1738,0)=" ; Print the report."
^XMB(3.9,145946,2,1739,0)="""RTN"",""IBCMDT3"",6,0)"
^XMB(3.9,145946,2,1740,0)=" ;  Required Input:  Global print array ^TMP($J,""PR"""
^XMB(3.9,145946,2,1741,0)="""RTN"",""IBCMDT3"",7,0)"
^XMB(3.9,145946,2,1742,0)=" ;"
^XMB(3.9,145946,2,1743,0)="""RTN"",""IBCMDT3"",8,0)"
^XMB(3.9,145946,2,1744,0)=" ;"
^XMB(3.9,145946,2,1745,0)="""RTN"",""IBCMDT3"",9,0)"
^XMB(3.9,145946,2,1746,0)="EN ; - Entry point to print report"
^XMB(3.9,145946,2,1747,0)="""RTN"",""IBCMDT3"",10,0)"
^XMB(3.9,145946,2,1748,0)=" N EORMSG,IBHDT,NODATA"
^XMB(3.9,145946,2,1749,0)="""RTN"",""IBCMDT3"",11,0)"
^XMB(3.9,145946,2,1750,0)=" S EORMSG=""*** END OF REPORT ***"""
^XMB(3.9,145946,2,1751,0)="""RTN"",""IBCMDT3"",12,0)"
^XMB(3.9,145946,2,1752,0)=" D NOW^%DTC S IBHDT=$$DAT2^IBOUTL($E(%,1,12))"
^XMB(3.9,145946,2,1753,0)="""RTN"",""IBCMDT3"",13,0)"
^XMB(3.9,145946,2,1754,0)=" S NODATA=1"
^XMB(3.9,145946,2,1755,0)="""RTN"",""IBCMDT3"",14,0)"
^XMB(3.9,145946,2,1756,0)=" D PRINT"
^XMB(3.9,145946,2,1757,0)="""RTN"",""IBCMDT3"",15,0)"
^XMB(3.9,145946,2,1758,0)=" K ^TMP($J,""PR""),^TMP(""IBCMDT"",IBNMSPC)"
^XMB(3.9,145946,2,1759,0)="""RTN"",""IBCMDT3"",16,0)"
^XMB(3.9,145946,2,1760,0)=" I NODATA D"
^XMB(3.9,145946,2,1761,0)="""RTN"",""IBCMDT3"",17,0)"
^XMB(3.9,145946,2,1762,0)=" . N IBPAG"
^XMB(3.9,145946,2,1763,0)="""RTN"",""IBCMDT3"",18,0)"
^XMB(3.9,145946,2,1764,0)=" . S IBPAG=0"
^XMB(3.9,145946,2,1765,0)="""RTN"",""IBCMDT3"",19,0)"
^XMB(3.9,145946,2,1766,0)=" . D COMP"
^XMB(3.9,145946,2,1767,0)="""RTN"",""IBCMDT3"",20,0)"
^XMB(3.9,145946,2,1768,0)=" W !!!,EORMSG"
^XMB(3.9,145946,2,1769,0)="""RTN"",""IBCMDT3"",21,0)"
^XMB(3.9,145946,2,1770,0)=" D PAUSE"
^XMB(3.9,145946,2,1771,0)="""RTN"",""IBCMDT3"",22,0)"
^XMB(3.9,145946,2,1772,0)=" ;"
^XMB(3.9,145946,2,1773,0)="""RTN"",""IBCMDT3"",23,0)"
^XMB(3.9,145946,2,1774,0)=" I $D(ZTQUEUED) S ZTREQ=""@"" Q"
^XMB(3.9,145946,2,1775,0)="""RTN"",""IBCMDT3"",24,0)"
^XMB(3.9,145946,2,1776,0)=" ; Close Device"
^XMB(3.9,145946,2,1777,0)="""RTN"",""IBCMDT3"",25,0)"
^XMB(3.9,145946,2,1778,0)=" D ^%ZISC"
^XMB(3.9,145946,2,1779,0)="""RTN"",""IBCMDT3"",26,0)"
^XMB(3.9,145946,2,1780,0)=" Q"
^XMB(3.9,145946,2,1781,0)="""RTN"",""IBCMDT3"",27,0)"
^XMB(3.9,145946,2,1782,0)=" ;"
^XMB(3.9,145946,2,1783,0)="""RTN"",""IBCMDT3"",28,0)"
^XMB(3.9,145946,2,1784,0)="PRINT ; Print report"
^XMB(3.9,145946,2,1785,0)="""RTN"",""IBCMDT3"",29,0)"
^XMB(3.9,145946,2,1786,0)=" ; Input:   NODATA  - Set to 1 initially"
^XMB(3.9,145946,2,1787,0)="""RTN"",""IBCMDT3"",30,0)"
^XMB(3.9,145946,2,1788,0)=" ; Output:  NODATE  - Set to 1 if at least one Insurance Company"
^XMB(3.9,145946,2,1789,0)="""RTN"",""IBCMDT3"",31,0)"
^XMB(3.9,145946,2,1790,0)=" ;                    with data found"
^XMB(3.9,145946,2,1791,0)="""RTN"",""IBCMDT3"",32,0)"
^XMB(3.9,145946,2,1792,0)=" N CVLMRC,CVLPRT,CVSWT,IBC,IBCVLT,IBI,IBP,IBPAG,IBQUIT,NEWIC,POSWT,%"
^XMB(3.9,145946,2,1793,0)="""RTN"",""IBCMDT3"",33,0)"
^XMB(3.9,145946,2,1794,0)=" S (IBI,IBQUIT,IBPAG,CVLPRT,POSWT)=0,IBCVLT="""""
^XMB(3.9,145946,2,1795,0)="""RTN"",""IBCMDT3"",34,0)"
^XMB(3.9,145946,2,1796,0)=" F  S IBI=$O(^TMP($J,""PR"",IBI)) Q:('IBI!IBQUIT)  D"
^XMB(3.9,145946,2,1797,0)="""RTN"",""IBCMDT3"",35,0)"
^XMB(3.9,145946,2,1798,0)=" . S IBC=$G(^TMP($J,""PR"",IBI)),POSWT=+$P(IBC,U,1)"
^XMB(3.9,145946,2,1799,0)="""RTN"",""IBCMDT3"",36,0)"
^XMB(3.9,145946,2,1800,0)=" . I $D(^TMP($J,""PR"",IBI))=1 Q"
^XMB(3.9,145946,2,1801,0)="""RTN"",""IBCMDT3"",37,0)"
^XMB(3.9,145946,2,1802,0)=" . S NODATA=0"
^XMB(3.9,145946,2,1803,0)="""RTN"",""IBCMDT3"",38,0)"
^XMB(3.9,145946,2,1804,0)=" . D COMP D  Q:IBQUIT"
^XMB(3.9,145946,2,1805,0)="""RTN"",""IBCMDT3"",39,0)"
^XMB(3.9,145946,2,1806,0)=" . . S IBP=0"
^XMB(3.9,145946,2,1807,0)="""RTN"",""IBCMDT3"",40,0)"
^XMB(3.9,145946,2,1808,0)=" . . F  S IBP=$O(^TMP($J,""PR"",IBI,IBP)) Q:'IBP  D  Q:IBQUIT"
^XMB(3.9,145946,2,1809,0)="""RTN"",""IBCMDT3"",41,0)"
^XMB(3.9,145946,2,1810,0)=" . . . S IBPD=$G(^TMP($J,""PR"",IBI,IBP))"
^XMB(3.9,145946,2,1811,0)="""RTN"",""IBCMDT3"",42,0)"
^XMB(3.9,145946,2,1812,0)=" . . . I $Y>(IOSL-5) D PAUSE Q:IBQUIT  D COMP"
^XMB(3.9,145946,2,1813,0)="""RTN"",""IBCMDT3"",43,0)"
^XMB(3.9,145946,2,1814,0)=" . . . S CVSWT=1 D PLAN"
^XMB(3.9,145946,2,1815,0)="""RTN"",""IBCMDT3"",44,0)"
^XMB(3.9,145946,2,1816,0)=" . . . S IBCVLT="""""
^XMB(3.9,145946,2,1817,0)="""RTN"",""IBCMDT3"",45,0)"
^XMB(3.9,145946,2,1818,0)=" . . . F  S IBCVLT=$O(^TMP($J,""PR"",IBI,IBP,IBCVLT)) Q:IBCVLT=""""  D  Q:IBQUIT"
^XMB(3.9,145946,2,1819,0)="""RTN"",""IBCMDT3"",46,0)"
^XMB(3.9,145946,2,1820,0)=" . . . . S CVLMRC=$G(^TMP($J,""PR"",IBI,IBP,IBCVLT))"
^XMB(3.9,145946,2,1821,0)="""RTN"",""IBCMDT3"",47,0)"
^XMB(3.9,145946,2,1822,0)=" . . . . I +CVSWT D CVLMHD S CVSWT=0"
^XMB(3.9,145946,2,1823,0)="""RTN"",""IBCMDT3"",48,0)"
^XMB(3.9,145946,2,1824,0)=" . . . . W !?4,$P(CVLMRC,U,1),?30,$P(CVLMRC,U,2),?50,$P(CVLMRC,U,3)"
^XMB(3.9,145946,2,1825,0)="""RTN"",""IBCMDT3"",49,0)"
^XMB(3.9,145946,2,1826,0)=" . . . . S CVLPRT=1"
^XMB(3.9,145946,2,1827,0)="""RTN"",""IBCMDT3"",50,0)"
^XMB(3.9,145946,2,1828,0)=" ;"
^XMB(3.9,145946,2,1829,0)="""RTN"",""IBCMDT3"",51,0)"
^XMB(3.9,145946,2,1830,0)=" K IBC,IBCVLM,IBI,IBJJ,IBQUIT,IBP,IBPAG,IBPD,IBS,IBSD"
^XMB(3.9,145946,2,1831,0)="""RTN"",""IBCMDT3"",52,0)"
^XMB(3.9,145946,2,1832,0)=" Q"
^XMB(3.9,145946,2,1833,0)="""RTN"",""IBCMDT3"",53,0)"
^XMB(3.9,145946,2,1834,0)=" ;"
^XMB(3.9,145946,2,1835,0)="""RTN"",""IBCMDT3"",54,0)"
^XMB(3.9,145946,2,1836,0)="COMP ; Print Company header"
^XMB(3.9,145946,2,1837,0)="""RTN"",""IBCMDT3"",55,0)"
^XMB(3.9,145946,2,1838,0)=" ; Input:   NODATA - 1 if no data was found"
^XMB(3.9,145946,2,1839,0)="""RTN"",""IBCMDT3"",56,0)"
^XMB(3.9,145946,2,1840,0)=" I $E(IOST,1,2)=""C-""!(IBPAG) W @IOF"
^XMB(3.9,145946,2,1841,0)="""RTN"",""IBCMDT3"",57,0)"
^XMB(3.9,145946,2,1842,0)=" S IBPAG=IBPAG+1"
^XMB(3.9,145946,2,1843,0)="""RTN"",""IBCMDT3"",58,0)"
^XMB(3.9,145946,2,1844,0)=" W !,""INSURANCE PLANS MISSING DATA"""
^XMB(3.9,145946,2,1845,0)="""RTN"",""IBCMDT3"",59,0)"
^XMB(3.9,145946,2,1846,0)=" W ?80,IBHDT,?110,""Page: "",IBPAG"
^XMB(3.9,145946,2,1847,0)="""RTN"",""IBCMDT3"",60,0)"
^XMB(3.9,145946,2,1848,0)=" W !,$G(SUBHD),!"
^XMB(3.9,145946,2,1849,0)="""RTN"",""IBCMDT3"",61,0)"
^XMB(3.9,145946,2,1850,0)=" I +$G(NODATA) D  Q"
^XMB(3.9,145946,2,1851,0)="""RTN"",""IBCMDT3"",62,0)"
^XMB(3.9,145946,2,1852,0)=" . W !!!,""--- No Data To Report ---"",!"
^XMB(3.9,145946,2,1853,0)="""RTN"",""IBCMDT3"",63,0)"
^XMB(3.9,145946,2,1854,0)=" ;"
^XMB(3.9,145946,2,1855,0)="""RTN"",""IBCMDT3"",64,0)"
^XMB(3.9,145946,2,1856,0)=" ; - sub-header"
^XMB(3.9,145946,2,1857,0)="""RTN"",""IBCMDT3"",65,0)"
^XMB(3.9,145946,2,1858,0)=" W !?1,$P(IBC,U,2)_""  ""_$P(IBC,U,3)_""  ""_$P(IBC,U,4)"
^XMB(3.9,145946,2,1859,0)="""RTN"",""IBCMDT3"",66,0)"
^XMB(3.9,145946,2,1860,0)=" I +POSWT W ?90,""PRESCRIPTION ONLY"""
^XMB(3.9,145946,2,1861,0)="""RTN"",""IBCMDT3"",67,0)"
^XMB(3.9,145946,2,1862,0)=" S NEWIC=1"
^XMB(3.9,145946,2,1863,0)="""RTN"",""IBCMDT3"",68,0)"
^XMB(3.9,145946,2,1864,0)=" Q"
^XMB(3.9,145946,2,1865,0)="""RTN"",""IBCMDT3"",69,0)"
^XMB(3.9,145946,2,1866,0)=" ;"
^XMB(3.9,145946,2,1867,0)="""RTN"",""IBCMDT3"",70,0)"
^XMB(3.9,145946,2,1868,0)="PLAN ; Print plan information."
^XMB(3.9,145946,2,1869,0)="""RTN"",""IBCMDT3"",71,0)"
^XMB(3.9,145946,2,1870,0)=" I CVLPRT W ! S CVLPRT=0"
^XMB(3.9,145946,2,1871,0)="""RTN"",""IBCMDT3"",72,0)"
^XMB(3.9,145946,2,1872,0)=" I +NEWIC D"
^XMB(3.9,145946,2,1873,0)="""RTN"",""IBCMDT3"",73,0)"
^XMB(3.9,145946,2,1874,0)=" . W !!?2,""GROUP NUMBER"",?20,""GROUP NAME"",?46,""TYPE OF PLAN"",?62,""ELEC PLAN"",?78,""FTF"""
^XMB(3.9,145946,2,1875,0)="""RTN"",""IBCMDT3"",74,0)"
^XMB(3.9,145946,2,1876,0)=" . W:+$G(POSWT) ?98,""BIN"",?109,""PCN"""
^XMB(3.9,145946,2,1877,0)="""RTN"",""IBCMDT3"",75,0)"
^XMB(3.9,145946,2,1878,0)=" . W !?2,""------------"",?20,""----------"",?46,""------------"",?62,""---------"",?78,""---"""
^XMB(3.9,145946,2,1879,0)="""RTN"",""IBCMDT3"",76,0)"
^XMB(3.9,145946,2,1880,0)=" . W:+$G(POSWT) ?98,""---"",?109,""---"""
^XMB(3.9,145946,2,1881,0)="""RTN"",""IBCMDT3"",77,0)"
^XMB(3.9,145946,2,1882,0)=" W !?2,$P(IBPD,U,2),?20,$E($P(IBPD,U,3),1,25),?46,$E($P(IBPD,U,4),1,15)"
^XMB(3.9,145946,2,1883,0)="""RTN"",""IBCMDT3"",78,0)"
^XMB(3.9,145946,2,1884,0)=" W ?62,$E($P(IBPD,U,5),1,15),?78,$P(IBPD,U,6)"
^XMB(3.9,145946,2,1885,0)="""RTN"",""IBCMDT3"",79,0)"
^XMB(3.9,145946,2,1886,0)=" W:+$G(POSWT) ?98,$P(IBPD,U,7),?109,$P(IBPD,U,8)"
^XMB(3.9,145946,2,1887,0)="""RTN"",""IBCMDT3"",80,0)"
^XMB(3.9,145946,2,1888,0)=" S NEWIC=0"
^XMB(3.9,145946,2,1889,0)="""RTN"",""IBCMDT3"",81,0)"
^XMB(3.9,145946,2,1890,0)=" Q"
^XMB(3.9,145946,2,1891,0)="""RTN"",""IBCMDT3"",82,0)"
^XMB(3.9,145946,2,1892,0)=" ;"
^XMB(3.9,145946,2,1893,0)="""RTN"",""IBCMDT3"",83,0)"
^XMB(3.9,145946,2,1894,0)="CVLMHD ; Print Coverage Limit sub-header"
^XMB(3.9,145946,2,1895,0)="""RTN"",""IBCMDT3"",84,0)"
^XMB(3.9,145946,2,1896,0)=" W !!?4,""Coverage"",?30,""Effective Date"",?50,""Covered?"""
^XMB(3.9,145946,2,1897,0)="""RTN"",""IBCMDT3"",85,0)"
^XMB(3.9,145946,2,1898,0)=" W !?4,""--------"",?30,""--------------"",?50,""--------"""
^XMB(3.9,145946,2,1899,0)="""RTN"",""IBCMDT3"",86,0)"
^XMB(3.9,145946,2,1900,0)=" Q"
^XMB(3.9,145946,2,1901,0)="""RTN"",""IBCMDT3"",87,0)"
^XMB(3.9,145946,2,1902,0)=" ;"
^XMB(3.9,145946,2,1903,0)="""RTN"",""IBCMDT3"",88,0)"
^XMB(3.9,145946,2,1904,0)="PAUSE ; Pause for screen output."
^XMB(3.9,145946,2,1905,0)="""RTN"",""IBCMDT3"",89,0)"
^XMB(3.9,145946,2,1906,0)=" Q:$E(IOST,1,2)'[""C-"""
^XMB(3.9,145946,2,1907,0)="""RTN"",""IBCMDT3"",90,0)"
^XMB(3.9,145946,2,1908,0)=" F IBJJ=$Y:1:(IOSL-7) W !"
^XMB(3.9,145946,2,1909,0)="""RTN"",""IBCMDT3"",91,0)"
^XMB(3.9,145946,2,1910,0)=" S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,1911,0)="""RTN"",""IBCMDT3"",92,0)"
^XMB(3.9,145946,2,1912,0)=" I $D(DIRUT)!($D(DUOUT)) S IBQUIT=1 K DIRUT,DTOUT,DUOUT"
^XMB(3.9,145946,2,1913,0)="""RTN"",""IBCMDT3"",93,0)"
^XMB(3.9,145946,2,1914,0)=" Q"
^XMB(3.9,145946,2,1915,0)="""RTN"",""IBCNEDE2"")"
^XMB(3.9,145946,2,1916,0)="0^3^B136907122"
^XMB(3.9,145946,2,1917,0)="""RTN"",""IBCNEDE2"",1,0)"
^XMB(3.9,145946,2,1918,0)="IBCNEDE2 ;DAOU/DAC - eIV Appointment Extract ;23-SEP-2015"
^XMB(3.9,145946,2,1919,0)="""RTN"",""IBCNEDE2"",2,0)"
^XMB(3.9,145946,2,1920,0)=" ;;2.0;INTEGRATED BILLING;**184,271,249,345,416,438,506,549,593,595,621,659,743,778**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,1921,0)="""RTN"",""IBCNEDE2"",3,0)"
^XMB(3.9,145946,2,1922,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,1923,0)="""RTN"",""IBCNEDE2"",4,0)"
^XMB(3.9,145946,2,1924,0)=" ;"
^XMB(3.9,145946,2,1925,0)="""RTN"",""IBCNEDE2"",5,0)"
^XMB(3.9,145946,2,1926,0)=" ;IB*778/CKB - rewrote the eIV Appointment Extract from scratch, reusing the routine IBCNEDE2."
^XMB(3.9,145946,2,1927,0)="""RTN"",""IBCNEDE2"",6,0)"
^XMB(3.9,145946,2,1928,0)=" ;             Any modifications based on patches prior to 778 are no longer applicable for this"
^XMB(3.9,145946,2,1929,0)="""RTN"",""IBCNEDE2"",7,0)"
^XMB(3.9,145946,2,1930,0)=" ;             routine, due to the rewrite."
^XMB(3.9,145946,2,1931,0)="""RTN"",""IBCNEDE2"",8,0)"
^XMB(3.9,145946,2,1932,0)=" ;"
^XMB(3.9,145946,2,1933,0)="""RTN"",""IBCNEDE2"",9,0)"
^XMB(3.9,145946,2,1934,0)=" ;**Program Description**"
^XMB(3.9,145946,2,1935,0)="""RTN"",""IBCNEDE2"",10,0)"
^XMB(3.9,145946,2,1936,0)=" ;  This program finds patients who have upcoming appointments within a"
^XMB(3.9,145946,2,1937,0)="""RTN"",""IBCNEDE2"",11,0)"
^XMB(3.9,145946,2,1938,0)=" ;  specified date range. The date range is parameter driven."
^XMB(3.9,145946,2,1939,0)="""RTN"",""IBCNEDE2"",12,0)"
^XMB(3.9,145946,2,1940,0)=" ;  Periodically check for stop request as this is a background task."
^XMB(3.9,145946,2,1941,0)="""RTN"",""IBCNEDE2"",13,0)"
^XMB(3.9,145946,2,1942,0)=" ;"
^XMB(3.9,145946,2,1943,0)="""RTN"",""IBCNEDE2"",14,0)"
^XMB(3.9,145946,2,1944,0)=" Q   ; can't be called directly"
^XMB(3.9,145946,2,1945,0)="""RTN"",""IBCNEDE2"",15,0)"
^XMB(3.9,145946,2,1946,0)=" ;"
^XMB(3.9,145946,2,1947,0)="""RTN"",""IBCNEDE2"",16,0)"
^XMB(3.9,145946,2,1948,0)="EN ; Loop through designated cross-references for updates"
^XMB(3.9,145946,2,1949,0)="""RTN"",""IBCNEDE2"",17,0)"
^XMB(3.9,145946,2,1950,0)=" N APTDT,CLNC,CNT,DFN,DTRANGE,ENDDT,EXCLTOC,EXCLTOP,FRESHDAY,IBCNETOT,IBFNDTQ,IBPQ,IBSDA,INREC,INSIEN,INSNAME"
^XMB(3.9,145946,2,1951,0)="""RTN"",""IBCNEDE2"",18,0)"
^XMB(3.9,145946,2,1952,0)=" N MAXCNT,MFLG,MFRESHDAY,NUM,OK,PATID,PAYERSTR,PIEN,PTINS,PYRAPP,QURYFLAG,SETSTR,SRVICEDT"
^XMB(3.9,145946,2,1953,0)="""RTN"",""IBCNEDE2"",19,0)"
^XMB(3.9,145946,2,1954,0)=" N SYMBOL,TQIEN,VDATE,ZTQUEUED,ZTSTOP,ZZ"
^XMB(3.9,145946,2,1955,0)="""RTN"",""IBCNEDE2"",20,0)"
^XMB(3.9,145946,2,1956,0)=" ;"
^XMB(3.9,145946,2,1957,0)="""RTN"",""IBCNEDE2"",21,0)"
^XMB(3.9,145946,2,1958,0)=" S SETSTR=$$SETTINGS^IBCNEDE7(2)     ; Get setting for pre reg. extract "
^XMB(3.9,145946,2,1959,0)="""RTN"",""IBCNEDE2"",22,0)"
^XMB(3.9,145946,2,1960,0)=" I 'SETSTR Q                         ; Quit if extract is not active"
^XMB(3.9,145946,2,1961,0)="""RTN"",""IBCNEDE2"",23,0)"
^XMB(3.9,145946,2,1962,0)=" S DTRANGE=$P(SETSTR,U,2)            ; Selection Criteria #1 - how far in the future do I look for appts"
^XMB(3.9,145946,2,1963,0)="""RTN"",""IBCNEDE2"",24,0)"
^XMB(3.9,145946,2,1964,0)=" S MAXCNT=$P(SETSTR,U,4)             ; Max # of TQ entries to create & send to FSC"
^XMB(3.9,145946,2,1965,0)="""RTN"",""IBCNEDE2"",25,0)"
^XMB(3.9,145946,2,1966,0)=" S:MAXCNT="""" MAXCNT=9999999999"
^XMB(3.9,145946,2,1967,0)="""RTN"",""IBCNEDE2"",26,0)"
^XMB(3.9,145946,2,1968,0)=" S FRESHDAY=$P($G(^IBE(350.9,1,51)),U,1)     ; Freshness days span"
^XMB(3.9,145946,2,1969,0)="""RTN"",""IBCNEDE2"",27,0)"
^XMB(3.9,145946,2,1970,0)=" S MFRESHDAY=$$GET1^DIQ(350.9,""1,"",51.32)    ; Medicare Freshness days span"
^XMB(3.9,145946,2,1971,0)="""RTN"",""IBCNEDE2"",28,0)"
^XMB(3.9,145946,2,1972,0)=" S ENDDT=$$FMADD^XLFDT(DT,DTRANGE)           ; End of appt. date selection range"
^XMB(3.9,145946,2,1973,0)="""RTN"",""IBCNEDE2"",29,0)"
^XMB(3.9,145946,2,1974,0)=" S CNT=0                                     ; Init. entries created in TQ and send to FSC"
^XMB(3.9,145946,2,1975,0)="""RTN"",""IBCNEDE2"",30,0)"
^XMB(3.9,145946,2,1976,0)=" S IBCNETOT=0               ; Initialize count for periodic TaskMan check"
^XMB(3.9,145946,2,1977,0)="""RTN"",""IBCNEDE2"",31,0)"
^XMB(3.9,145946,2,1978,0)=" S EXCLTOC=$$GETELST(355.2) ; Initialize excluded TYPEs OF COVERAGE"
^XMB(3.9,145946,2,1979,0)="""RTN"",""IBCNEDE2"",32,0)"
^XMB(3.9,145946,2,1980,0)=" S EXCLTOP=$$GETELST(355.1) ; Initialize excluded TYPEs OF PLAN"
^XMB(3.9,145946,2,1981,0)="""RTN"",""IBCNEDE2"",33,0)"
^XMB(3.9,145946,2,1982,0)=" ; Clean TMP globals"
^XMB(3.9,145946,2,1983,0)="""RTN"",""IBCNEDE2"",34,0)"
^XMB(3.9,145946,2,1984,0)=" K ^TMP($J,""SDAMA301""),^TMP($J,""IBCNEDE2DFN"")"
^XMB(3.9,145946,2,1985,0)="""RTN"",""IBCNEDE2"",35,0)"
^XMB(3.9,145946,2,1986,0)=" ;"
^XMB(3.9,145946,2,1987,0)="""RTN"",""IBCNEDE2"",36,0)"
^XMB(3.9,145946,2,1988,0)=" ; Set up variables for scheduling call and call"
^XMB(3.9,145946,2,1989,0)="""RTN"",""IBCNEDE2"",37,0)"
^XMB(3.9,145946,2,1990,0)=" S IBSDA(""FLDS"")=8"
^XMB(3.9,145946,2,1991,0)="""RTN"",""IBCNEDE2"",38,0)"
^XMB(3.9,145946,2,1992,0)=" S IBSDA(1)=DT_"";""_ENDDT"
^XMB(3.9,145946,2,1993,0)="""RTN"",""IBCNEDE2"",39,0)"
^XMB(3.9,145946,2,1994,0)=" S IBSDA(3)=""R"""
^XMB(3.9,145946,2,1995,0)="""RTN"",""IBCNEDE2"",40,0)"
^XMB(3.9,145946,2,1996,0)=" S NUM=$$SDAPI^SDAMA301(.IBSDA) I NUM<1 D:NUM<0 ERRMSG G ENQ"
^XMB(3.9,145946,2,1997,0)="""RTN"",""IBCNEDE2"",41,0)"
^XMB(3.9,145946,2,1998,0)=" ;"
^XMB(3.9,145946,2,1999,0)="""RTN"",""IBCNEDE2"",42,0)"
^XMB(3.9,145946,2,2000,0)=" ;"
^XMB(3.9,145946,2,2001,0)="""RTN"",""IBCNEDE2"",43,0)"
^XMB(3.9,145946,2,2002,0)=" S CLNC=0 ; Init. clinic"
^XMB(3.9,145946,2,2003,0)="""RTN"",""IBCNEDE2"",44,0)"
^XMB(3.9,145946,2,2004,0)=" ; Loop through clinics returned"
^XMB(3.9,145946,2,2005,0)="""RTN"",""IBCNEDE2"",45,0)"
^XMB(3.9,145946,2,2006,0)=" F  S CLNC=$O(^TMP($J,""SDAMA301"",CLNC)) Q:'CLNC  D  Q:$G(ZTSTOP)"
^XMB(3.9,145946,2,2007,0)="""RTN"",""IBCNEDE2"",46,0)"
^XMB(3.9,145946,2,2008,0)=" . ;"
^XMB(3.9,145946,2,2009,0)="""RTN"",""IBCNEDE2"",47,0)"
^XMB(3.9,145946,2,2010,0)=" . ; Loop through patients returned"
^XMB(3.9,145946,2,2011,0)="""RTN"",""IBCNEDE2"",48,0)"
^XMB(3.9,145946,2,2012,0)=" . S DFN=0 F  S DFN=$O(^TMP($J,""SDAMA301"",CLNC,DFN)) Q:'DFN  D  Q:$G(ZTSTOP)"
^XMB(3.9,145946,2,2013,0)="""RTN"",""IBCNEDE2"",49,0)"
^XMB(3.9,145946,2,2014,0)=" .. ;"
^XMB(3.9,145946,2,2015,0)="""RTN"",""IBCNEDE2"",50,0)"
^XMB(3.9,145946,2,2016,0)=" .. S APTDT=DT           ; Check for appointment date"
^XMB(3.9,145946,2,2017,0)="""RTN"",""IBCNEDE2"",51,0)"
^XMB(3.9,145946,2,2018,0)=" .. ;"
^XMB(3.9,145946,2,2019,0)="""RTN"",""IBCNEDE2"",52,0)"
^XMB(3.9,145946,2,2020,0)=" .. ; Loop through dates in range at clinic"
^XMB(3.9,145946,2,2021,0)="""RTN"",""IBCNEDE2"",53,0)"
^XMB(3.9,145946,2,2022,0)=" .. F  S APTDT=$O(^TMP($J,""SDAMA301"",CLNC,DFN,APTDT)) Q:('APTDT)!((APTDT\1)>ENDDT)  D  Q:$G(ZTSTOP)"
^XMB(3.9,145946,2,2023,0)="""RTN"",""IBCNEDE2"",54,0)"
^XMB(3.9,145946,2,2024,0)=" ... ;"
^XMB(3.9,145946,2,2025,0)="""RTN"",""IBCNEDE2"",55,0)"
^XMB(3.9,145946,2,2026,0)=" ... S SRVICEDT=APTDT\1 ;Set service date equal to appointment date"
^XMB(3.9,145946,2,2027,0)="""RTN"",""IBCNEDE2"",56,0)"
^XMB(3.9,145946,2,2028,0)=" ... ;"
^XMB(3.9,145946,2,2029,0)="""RTN"",""IBCNEDE2"",57,0)"
^XMB(3.9,145946,2,2030,0)=" ... ; Update count for periodic check"
^XMB(3.9,145946,2,2031,0)="""RTN"",""IBCNEDE2"",58,0)"
^XMB(3.9,145946,2,2032,0)=" ... S IBCNETOT=IBCNETOT+1"
^XMB(3.9,145946,2,2033,0)="""RTN"",""IBCNEDE2"",59,0)"
^XMB(3.9,145946,2,2034,0)=" ... ; Check for request to stop background job, periodically"
^XMB(3.9,145946,2,2035,0)="""RTN"",""IBCNEDE2"",60,0)"
^XMB(3.9,145946,2,2036,0)=" ... I $D(ZTQUEUED),IBCNETOT#100=0,$$S^%ZTLOAD() S ZTSTOP=1 Q"
^XMB(3.9,145946,2,2037,0)="""RTN"",""IBCNEDE2"",61,0)"
^XMB(3.9,145946,2,2038,0)=" ... ;"
^XMB(3.9,145946,2,2039,0)="""RTN"",""IBCNEDE2"",62,0)"
^XMB(3.9,145946,2,2040,0)=" ... I $P($G(^DPT(DFN,0)),U,21) Q         ; Exclude if test patient"
^XMB(3.9,145946,2,2041,0)="""RTN"",""IBCNEDE2"",63,0)"
^XMB(3.9,145946,2,2042,0)=" ... ;"
^XMB(3.9,145946,2,2043,0)="""RTN"",""IBCNEDE2"",64,0)"
^XMB(3.9,145946,2,2044,0)=" ... ; Build temp array for allowed DFN's"
^XMB(3.9,145946,2,2045,0)="""RTN"",""IBCNEDE2"",65,0)"
^XMB(3.9,145946,2,2046,0)=" ... S ^TMP($J,""IBCNEDE2DFN"",DFN,(+$G(SRVICEDT)))="""""
^XMB(3.9,145946,2,2047,0)="""RTN"",""IBCNEDE2"",66,0)"
^XMB(3.9,145946,2,2048,0)=" ;"
^XMB(3.9,145946,2,2049,0)="""RTN"",""IBCNEDE2"",67,0)"
^XMB(3.9,145946,2,2050,0)="100 ;"
^XMB(3.9,145946,2,2051,0)="""RTN"",""IBCNEDE2"",68,0)"
^XMB(3.9,145946,2,2052,0)=" ; Check the insurance for the selected DFNs based on future appointments"
^XMB(3.9,145946,2,2053,0)="""RTN"",""IBCNEDE2"",69,0)"
^XMB(3.9,145946,2,2054,0)=" S DFN=0"
^XMB(3.9,145946,2,2055,0)="""RTN"",""IBCNEDE2"",70,0)"
^XMB(3.9,145946,2,2056,0)=" F  S DFN=$O(^TMP($J,""IBCNEDE2DFN"",DFN)) Q:'DFN  D"
^XMB(3.9,145946,2,2057,0)="""RTN"",""IBCNEDE2"",71,0)"
^XMB(3.9,145946,2,2058,0)=" . ;"
^XMB(3.9,145946,2,2059,0)="""RTN"",""IBCNEDE2"",72,0)"
^XMB(3.9,145946,2,2060,0)=" . K IBFNDTQ"
^XMB(3.9,145946,2,2061,0)="""RTN"",""IBCNEDE2"",73,0)"
^XMB(3.9,145946,2,2062,0)=" . K PTINS D ALL^IBCNEDE3(DFN,""PTINS"")"
^XMB(3.9,145946,2,2063,0)="""RTN"",""IBCNEDE2"",74,0)"
^XMB(3.9,145946,2,2064,0)=" . I '$D(PTINS(0)) Q  ; Patient has no insurance to be evaluated"
^XMB(3.9,145946,2,2065,0)="""RTN"",""IBCNEDE2"",75,0)"
^XMB(3.9,145946,2,2066,0)=" . ;"
^XMB(3.9,145946,2,2067,0)="""RTN"",""IBCNEDE2"",76,0)"
^XMB(3.9,145946,2,2068,0)=" . ; Find the service date that is closest to TODAY (DT), do not look for past dates."
^XMB(3.9,145946,2,2069,0)="""RTN"",""IBCNEDE2"",77,0)"
^XMB(3.9,145946,2,2070,0)=" . S SRVICEDT=$O(^TMP($J,""IBCNEDE2DFN"",DFN,(DT-1)))"
^XMB(3.9,145946,2,2071,0)="""RTN"",""IBCNEDE2"",78,0)"
^XMB(3.9,145946,2,2072,0)=" . I SRVICEDT="""" Q       ; No future appointments are found for the patient"
^XMB(3.9,145946,2,2073,0)="""RTN"",""IBCNEDE2"",79,0)"
^XMB(3.9,145946,2,2074,0)=" . ;"
^XMB(3.9,145946,2,2075,0)="""RTN"",""IBCNEDE2"",80,0)"
^XMB(3.9,145946,2,2076,0)=" . ;Loop through Patient policies and check MAXCNT"
^XMB(3.9,145946,2,2077,0)="""RTN"",""IBCNEDE2"",81,0)"
^XMB(3.9,145946,2,2078,0)=" . S INREC=0 F  S INREC=$O(PTINS(INREC)) Q:('INREC)!(CNT'<MAXCNT)  D"
^XMB(3.9,145946,2,2079,0)="""RTN"",""IBCNEDE2"",82,0)"
^XMB(3.9,145946,2,2080,0)=" .. N ADDTQ,FSCSEND,GIEN,GRPNAM,GRPNUM,PATID"
^XMB(3.9,145946,2,2081,0)="""RTN"",""IBCNEDE2"",83,0)"
^XMB(3.9,145946,2,2082,0)=" .. N SENDNOW,SUBID,TQENT,TQFOUND,XXGN"
^XMB(3.9,145946,2,2083,0)="""RTN"",""IBCNEDE2"",84,0)"
^XMB(3.9,145946,2,2084,0)=" .. S MFLG=0"
^XMB(3.9,145946,2,2085,0)="""RTN"",""IBCNEDE2"",85,0)"
^XMB(3.9,145946,2,2086,0)=" .. ; Repull Service Date for each Policy"
^XMB(3.9,145946,2,2087,0)="""RTN"",""IBCNEDE2"",86,0)"
^XMB(3.9,145946,2,2088,0)=" .. S SRVICEDT=$O(^TMP($J,""IBCNEDE2DFN"",DFN,(DT-1)))"
^XMB(3.9,145946,2,2089,0)="""RTN"",""IBCNEDE2"",87,0)"
^XMB(3.9,145946,2,2090,0)=" .. ; Get Payer, Insurance and Group Plan info"
^XMB(3.9,145946,2,2091,0)="""RTN"",""IBCNEDE2"",88,0)"
^XMB(3.9,145946,2,2092,0)=" .. S INSIEN=$P($G(PTINS(INREC,0)),U,1)"
^XMB(3.9,145946,2,2093,0)="""RTN"",""IBCNEDE2"",89,0)"
^XMB(3.9,145946,2,2094,0)=" .. S INSNAME=$$GET1^DIQ(36,INSIEN_"","",.01,""E"")"
^XMB(3.9,145946,2,2095,0)="""RTN"",""IBCNEDE2"",90,0)"
^XMB(3.9,145946,2,2096,0)=" .. S GIEN=$$GET1^DIQ(2.312,INREC_"",""_DFN_"","",.18,""I"")"
^XMB(3.9,145946,2,2097,0)="""RTN"",""IBCNEDE2"",91,0)"
^XMB(3.9,145946,2,2098,0)=" .. S GRPNAM=$$GET1^DIQ(355.3,GIEN_"","",2.01,""E"")"
^XMB(3.9,145946,2,2099,0)="""RTN"",""IBCNEDE2"",92,0)"
^XMB(3.9,145946,2,2100,0)=" .. S GRPNUM=$$GET1^DIQ(355.3,GIEN_"","",2.02,""E"")"
^XMB(3.9,145946,2,2101,0)="""RTN"",""IBCNEDE2"",93,0)"
^XMB(3.9,145946,2,2102,0)=" .. S SUBID=$$GET1^DIQ(2.312,INREC_"",""_DFN_"","",7.02,""E"")"
^XMB(3.9,145946,2,2103,0)="""RTN"",""IBCNEDE2"",94,0)"
^XMB(3.9,145946,2,2104,0)=" .. S PATID=$$GET1^DIQ(2.312,INREC_"",""_DFN_"","",5.01,""E"")"
^XMB(3.9,145946,2,2105,0)="""RTN"",""IBCNEDE2"",95,0)"
^XMB(3.9,145946,2,2106,0)=" .. ; Remove any non-alpha numeric characters"
^XMB(3.9,145946,2,2107,0)="""RTN"",""IBCNEDE2"",96,0)"
^XMB(3.9,145946,2,2108,0)=" .. I SUBID'="""" S SUBID=$$STRIP^IBCNEDE3(SUBID)"
^XMB(3.9,145946,2,2109,0)="""RTN"",""IBCNEDE2"",97,0)"
^XMB(3.9,145946,2,2110,0)=" .. I PATID'="""" S PATID=$$STRIP^IBCNEDE3(PATID)"
^XMB(3.9,145946,2,2111,0)="""RTN"",""IBCNEDE2"",98,0)"
^XMB(3.9,145946,2,2112,0)=" .. ;"
^XMB(3.9,145946,2,2113,0)="""RTN"",""IBCNEDE2"",99,0)"
^XMB(3.9,145946,2,2114,0)=" .. ; Type of Plan"
^XMB(3.9,145946,2,2115,0)="""RTN"",""IBCNEDE2"",100,0)"
^XMB(3.9,145946,2,2116,0)=" .. S ZZ=$$GET1^DIQ(355.3,GIEN_"","",.09,""I"")"
^XMB(3.9,145946,2,2117,0)="""RTN"",""IBCNEDE2"",101,0)"
^XMB(3.9,145946,2,2118,0)=" .. Q:EXCLTOP[(""^""_ZZ_""^"")                   ; Excluded Types of Plan"
^XMB(3.9,145946,2,2119,0)="""RTN"",""IBCNEDE2"",102,0)"
^XMB(3.9,145946,2,2120,0)=" .. ;"
^XMB(3.9,145946,2,2121,0)="""RTN"",""IBCNEDE2"",103,0)"
^XMB(3.9,145946,2,2122,0)=" .. ; Type of Coverage"
^XMB(3.9,145946,2,2123,0)="""RTN"",""IBCNEDE2"",104,0)"
^XMB(3.9,145946,2,2124,0)=" .. S ZZ=$$GET1^DIQ(36,INSIEN_"","",.13,""I"")"
^XMB(3.9,145946,2,2125,0)="""RTN"",""IBCNEDE2"",105,0)"
^XMB(3.9,145946,2,2126,0)=" .. Q:EXCLTOC[(""^""_ZZ_""^"")                   ; Excluded Type of Coverage "
^XMB(3.9,145946,2,2127,0)="""RTN"",""IBCNEDE2"",106,0)"
^XMB(3.9,145946,2,2128,0)=" .. ;"
^XMB(3.9,145946,2,2129,0)="""RTN"",""IBCNEDE2"",107,0)"
^XMB(3.9,145946,2,2130,0)=" .. ; OKFRESH properly identifies the policies to exclude when verified"
^XMB(3.9,145946,2,2131,0)="""RTN"",""IBCNEDE2"",108,0)"
^XMB(3.9,145946,2,2132,0)=" .. ; within the ""freshness days"" for Medicare and non-Medicare policies (MFLG)"
^XMB(3.9,145946,2,2133,0)="""RTN"",""IBCNEDE2"",109,0)"
^XMB(3.9,145946,2,2134,0)=" .. I '$$OKFRESH(INREC,FRESHDAY,MFRESHDAY,.MFLG) Q"
^XMB(3.9,145946,2,2135,0)="""RTN"",""IBCNEDE2"",110,0)"
^XMB(3.9,145946,2,2136,0)=" .. ;"
^XMB(3.9,145946,2,2137,0)="""RTN"",""IBCNEDE2"",111,0)"
^XMB(3.9,145946,2,2138,0)=" .. ; $$INSERROR, when passing in ""I"", gets Insurance company and Payer info and performs the following checks:"
^XMB(3.9,145946,2,2139,0)="""RTN"",""IBCNEDE2"",112,0)"
^XMB(3.9,145946,2,2140,0)=" .. ;  - Insurance company must be active, linked to a eIV payer AND not marked for deletion"
^XMB(3.9,145946,2,2141,0)="""RTN"",""IBCNEDE2"",113,0)"
^XMB(3.9,145946,2,2142,0)=" .. ;  - Insurance company name must not contain ""MEDICAID"""
^XMB(3.9,145946,2,2143,0)="""RTN"",""IBCNEDE2"",114,0)"
^XMB(3.9,145946,2,2144,0)=" .. ;  - Payer must be Nationally and Locally enabled for eIV AND not deactivated"
^XMB(3.9,145946,2,2145,0)="""RTN"",""IBCNEDE2"",115,0)"
^XMB(3.9,145946,2,2146,0)=" .. ;  - Payer must have a VA National ID "
^XMB(3.9,145946,2,2147,0)="""RTN"",""IBCNEDE2"",116,0)"
^XMB(3.9,145946,2,2148,0)=" .. S IBPQ=0"
^XMB(3.9,145946,2,2149,0)="""RTN"",""IBCNEDE2"",117,0)"
^XMB(3.9,145946,2,2150,0)=" .. S PAYERSTR=$$INSERROR^IBCNEUT3(""I"",INSIEN)"
^XMB(3.9,145946,2,2151,0)="""RTN"",""IBCNEDE2"",118,0)"
^XMB(3.9,145946,2,2152,0)=" .. S SYMBOL=+PAYERSTR                       ; error symbol"
^XMB(3.9,145946,2,2153,0)="""RTN"",""IBCNEDE2"",119,0)"
^XMB(3.9,145946,2,2154,0)=" .. S PIEN=$P(PAYERSTR,U,2)                  ; Payer IEN"
^XMB(3.9,145946,2,2155,0)="""RTN"",""IBCNEDE2"",120,0)"
^XMB(3.9,145946,2,2156,0)=" .. ;"
^XMB(3.9,145946,2,2157,0)="""RTN"",""IBCNEDE2"",121,0)"
^XMB(3.9,145946,2,2158,0)=" .. I +PIEN D"
^XMB(3.9,145946,2,2159,0)="""RTN"",""IBCNEDE2"",122,0)"
^XMB(3.9,145946,2,2160,0)=" ... ; Determine Payer App IEN"
^XMB(3.9,145946,2,2161,0)="""RTN"",""IBCNEDE2"",123,0)"
^XMB(3.9,145946,2,2162,0)=" ... S PYRAPP=$$PYRAPP^IBCNEUT5(""EIV"",PIEN)"
^XMB(3.9,145946,2,2163,0)="""RTN"",""IBCNEDE2"",124,0)"
^XMB(3.9,145946,2,2164,0)=" ... ; If Payer requires a Subscriber ID and the policy does not have one on file, drop to buffer"
^XMB(3.9,145946,2,2165,0)="""RTN"",""IBCNEDE2"",125,0)"
^XMB(3.9,145946,2,2166,0)=" ... I $$GET1^DIQ(365.121,PYRAPP_"",""_PIEN_"","",4.02,""I"") I SUBID="""" S IBPQ=1"
^XMB(3.9,145946,2,2167,0)="""RTN"",""IBCNEDE2"",126,0)"
^XMB(3.9,145946,2,2168,0)=" .. ;"
^XMB(3.9,145946,2,2169,0)="""RTN"",""IBCNEDE2"",127,0)"
^XMB(3.9,145946,2,2170,0)=" .. ; If Payer IEN is not defined or Payer is Nationally Inactive, drop to buffer"
^XMB(3.9,145946,2,2171,0)="""RTN"",""IBCNEDE2"",128,0)"
^XMB(3.9,145946,2,2172,0)=" .. I ('+PIEN)!('$$PYRACTV^IBCNEDE7(PIEN)) S IBPQ=1"
^XMB(3.9,145946,2,2173,0)="""RTN"",""IBCNEDE2"",129,0)"
^XMB(3.9,145946,2,2174,0)=" .. ;"
^XMB(3.9,145946,2,2175,0)="""RTN"",""IBCNEDE2"",130,0)"
^XMB(3.9,145946,2,2176,0)=" .. ; Drop to the Buffer and quit, had an issue with Insurance Co or Payer or Policy"
^XMB(3.9,145946,2,2177,0)="""RTN"",""IBCNEDE2"",131,0)"
^XMB(3.9,145946,2,2178,0)=" .. I (SYMBOL)!(IBPQ=1) D  Q"
^XMB(3.9,145946,2,2179,0)="""RTN"",""IBCNEDE2"",132,0)"
^XMB(3.9,145946,2,2180,0)=" ... I '$$BFEXIST^IBCNEDE3(DFN,INSNAME,SUBID,GRPNUM) D PT^IBCNEBF(DFN,INREC,SYMBOL,"""",1)"
^XMB(3.9,145946,2,2181,0)="""RTN"",""IBCNEDE2"",133,0)"
^XMB(3.9,145946,2,2182,0)=" .. ;"
^XMB(3.9,145946,2,2183,0)="""RTN"",""IBCNEDE2"",134,0)"
^XMB(3.9,145946,2,2184,0)=" .. ; If MEDICARE (MFLG) and GRPNUM=""PART A"" or ""PART B"", check for the existence in array IBFNDTQ"
^XMB(3.9,145946,2,2185,0)="""RTN"",""IBCNEDE2"",135,0)"
^XMB(3.9,145946,2,2186,0)=" .. ; Only allow ONE occurrence in the TQ for Medicare Part A and Medicare Part B, never both"
^XMB(3.9,145946,2,2187,0)="""RTN"",""IBCNEDE2"",136,0)"
^XMB(3.9,145946,2,2188,0)=" .. I MFLG&((GRPNUM=""PART A"")!(GRPNUM=""PART B"")) I $D(IBFNDTQ(PIEN,$S(SUBID="""":"" "",1:SUBID),""PART A""))!$D(IBFNDTQ(PIEN,$S(SUBID="""":"" "",1:SUBID),""PART B"")) Q"
^XMB(3.9,145946,2,2189,0)="""RTN"",""IBCNEDE2"",137,0)"
^XMB(3.9,145946,2,2190,0)=" .. ;"
^XMB(3.9,145946,2,2191,0)="""RTN"",""IBCNEDE2"",138,0)"
^XMB(3.9,145946,2,2192,0)=" .. ; Check for the existence in array IBFNDTQ, DO NOT continue"
^XMB(3.9,145946,2,2193,0)="""RTN"",""IBCNEDE2"",139,0)"
^XMB(3.9,145946,2,2194,0)=" .. I $D(IBFNDTQ(PIEN,$S(SUBID="""":"" "",1:SUBID),$S(GRPNUM="""":"" "",1:GRPNUM))) Q"
^XMB(3.9,145946,2,2195,0)="""RTN"",""IBCNEDE2"",140,0)"
^XMB(3.9,145946,2,2196,0)=" .. ; "
^XMB(3.9,145946,2,2197,0)="""RTN"",""IBCNEDE2"",141,0)"
^XMB(3.9,145946,2,2198,0)=" .. ; Update service date based on Payers allowed date range"
^XMB(3.9,145946,2,2199,0)="""RTN"",""IBCNEDE2"",142,0)"
^XMB(3.9,145946,2,2200,0)=" .. D UPDSD^IBCNEDE3(PIEN,PYRAPP,.SRVICEDT)"
^XMB(3.9,145946,2,2201,0)="""RTN"",""IBCNEDE2"",143,0)"
^XMB(3.9,145946,2,2202,0)=" .. ;"
^XMB(3.9,145946,2,2203,0)="""RTN"",""IBCNEDE2"",144,0)"
^XMB(3.9,145946,2,2204,0)=" .. ; Initialize variables for TQUPDSV and TQCHKS"
^XMB(3.9,145946,2,2205,0)="""RTN"",""IBCNEDE2"",145,0)"
^XMB(3.9,145946,2,2206,0)=" .. S ADDTQ=1,(FSCSEND,TQFOUND)=0,TQENT="""""
^XMB(3.9,145946,2,2207,0)="""RTN"",""IBCNEDE2"",146,0)"
^XMB(3.9,145946,2,2208,0)=" .. ;"
^XMB(3.9,145946,2,2209,0)="""RTN"",""IBCNEDE2"",147,0)"
^XMB(3.9,145946,2,2210,0)=" .. ; Update service dates for inquiry to be transmitted"
^XMB(3.9,145946,2,2211,0)="""RTN"",""IBCNEDE2"",148,0)"
^XMB(3.9,145946,2,2212,0)=" .. ;   sets TQFOUND, FSCSEND and TQENT"
^XMB(3.9,145946,2,2213,0)="""RTN"",""IBCNEDE2"",149,0)"
^XMB(3.9,145946,2,2214,0)=" .. D TQUPDSV^IBCNEDE3(DFN,PIEN,SRVICEDT,SUBID,GRPNUM)"
^XMB(3.9,145946,2,2215,0)="""RTN"",""IBCNEDE2"",150,0)"
^XMB(3.9,145946,2,2216,0)=" .. ; Check to see if a new entry can be added to the TQ file"
^XMB(3.9,145946,2,2217,0)="""RTN"",""IBCNEDE2"",151,0)"
^XMB(3.9,145946,2,2218,0)=" .. ;   sets ADDTQ"
^XMB(3.9,145946,2,2219,0)="""RTN"",""IBCNEDE2"",152,0)"
^XMB(3.9,145946,2,2220,0)=" .. D TQCHKS^IBCNEDE3(DFN,PIEN,SRVICEDT,SUBID,GRPNUM,$S(MFLG:MFRESHDAY,1:FRESHDAY))"
^XMB(3.9,145946,2,2221,0)="""RTN"",""IBCNEDE2"",153,0)"
^XMB(3.9,145946,2,2222,0)=" .. ;"
^XMB(3.9,145946,2,2223,0)="""RTN"",""IBCNEDE2"",154,0)"
^XMB(3.9,145946,2,2224,0)=" .. ; to handle Medicare Part A and Medicare Part B, only allow one occurrence "
^XMB(3.9,145946,2,2225,0)="""RTN"",""IBCNEDE2"",155,0)"
^XMB(3.9,145946,2,2226,0)=" .. I ADDTQ&'TQFOUND&MFLG&((GRPNUM=""PART A"")!(GRPNUM=""PART B"")) D"
^XMB(3.9,145946,2,2227,0)="""RTN"",""IBCNEDE2"",156,0)"
^XMB(3.9,145946,2,2228,0)=" ... S XXGN=$S(GRPNUM=""PART A"":""PART B"",1:""PART A"")"
^XMB(3.9,145946,2,2229,0)="""RTN"",""IBCNEDE2"",157,0)"
^XMB(3.9,145946,2,2230,0)=" ... D TQUPDSV^IBCNEDE3(DFN,PIEN,SRVICEDT,SUBID,XXGN)"
^XMB(3.9,145946,2,2231,0)="""RTN"",""IBCNEDE2"",158,0)"
^XMB(3.9,145946,2,2232,0)=" ... D TQCHKS^IBCNEDE3(DFN,PIEN,SRVICEDT,SUBID,XXGN,$S(MFLG:MFRESHDAY,1:FRESHDAY))"
^XMB(3.9,145946,2,2233,0)="""RTN"",""IBCNEDE2"",159,0)"
^XMB(3.9,145946,2,2234,0)=" .. ;"
^XMB(3.9,145946,2,2235,0)="""RTN"",""IBCNEDE2"",160,0)"
^XMB(3.9,145946,2,2236,0)=" .. ; If a valid entry was found in the TQ file (TQFOUND=1) AND the send to FSC now flag"
^XMB(3.9,145946,2,2237,0)="""RTN"",""IBCNEDE2"",161,0)"
^XMB(3.9,145946,2,2238,0)=" .. ;  (FSCSEND) is set to '1', transmit to FSC and increment counter"
^XMB(3.9,145946,2,2239,0)="""RTN"",""IBCNEDE2"",162,0)"
^XMB(3.9,145946,2,2240,0)=" .. ; DO NOT create a new entry if TQFOUND is true"
^XMB(3.9,145946,2,2241,0)="""RTN"",""IBCNEDE2"",163,0)"
^XMB(3.9,145946,2,2242,0)=" .. I TQFOUND  D  Q"
^XMB(3.9,145946,2,2243,0)="""RTN"",""IBCNEDE2"",164,0)"
^XMB(3.9,145946,2,2244,0)=" ... I FSCSEND,TQENT I CNT'>MAXCNT D XMIT1^IBCNEDEP(TQENT) S CNT=CNT+1      ; Increment counter of entries sent to FSC"
^XMB(3.9,145946,2,2245,0)="""RTN"",""IBCNEDE2"",165,0)"
^XMB(3.9,145946,2,2246,0)=" .. ; If ADDTQ is set to '0', DO NOT create a new entry (safety valve)"
^XMB(3.9,145946,2,2247,0)="""RTN"",""IBCNEDE2"",166,0)"
^XMB(3.9,145946,2,2248,0)=" .. I 'ADDTQ Q"
^XMB(3.9,145946,2,2249,0)="""RTN"",""IBCNEDE2"",167,0)"
^XMB(3.9,145946,2,2250,0)=" .. ;"
^XMB(3.9,145946,2,2251,0)="""RTN"",""IBCNEDE2"",168,0)"
^XMB(3.9,145946,2,2252,0)=" .. ;   Determine if the Subscriber ID should be included/saved to the TQ"
^XMB(3.9,145946,2,2253,0)="""RTN"",""IBCNEDE2"",169,0)"
^XMB(3.9,145946,2,2254,0)=" .. ; The policy has a subscriber ID on file - include subscriber ID"
^XMB(3.9,145946,2,2255,0)="""RTN"",""IBCNEDE2"",170,0)"
^XMB(3.9,145946,2,2256,0)=" .. S QURYFLAG=""V"""
^XMB(3.9,145946,2,2257,0)="""RTN"",""IBCNEDE2"",171,0)"
^XMB(3.9,145946,2,2258,0)=" .. I SUBID'="""" D SET(SUBID,INREC,PATID)"
^XMB(3.9,145946,2,2259,0)="""RTN"",""IBCNEDE2"",172,0)"
^XMB(3.9,145946,2,2260,0)=" .. ; If the policy does NOT have subscriber ID on file - don't include subscriber ID"
^XMB(3.9,145946,2,2261,0)="""RTN"",""IBCNEDE2"",173,0)"
^XMB(3.9,145946,2,2262,0)=" .. I SUBID="""" D SET("""",INREC,PATID)"
^XMB(3.9,145946,2,2263,0)="""RTN"",""IBCNEDE2"",174,0)"
^XMB(3.9,145946,2,2264,0)=" .. ; Set local array of patient's added to the TQ file"
^XMB(3.9,145946,2,2265,0)="""RTN"",""IBCNEDE2"",175,0)"
^XMB(3.9,145946,2,2266,0)=" .. S IBFNDTQ(PIEN,$S(SUBID="""":"" "",1:SUBID),$S(GRPNUM="""":"" "",1:GRPNUM))=1"
^XMB(3.9,145946,2,2267,0)="""RTN"",""IBCNEDE2"",176,0)"
^XMB(3.9,145946,2,2268,0)=" ;"
^XMB(3.9,145946,2,2269,0)="""RTN"",""IBCNEDE2"",177,0)"
^XMB(3.9,145946,2,2270,0)="ENQ ;"
^XMB(3.9,145946,2,2271,0)="""RTN"",""IBCNEDE2"",178,0)"
^XMB(3.9,145946,2,2272,0)=" K ^TMP($J,""SDAMA301"")"
^XMB(3.9,145946,2,2273,0)="""RTN"",""IBCNEDE2"",179,0)"
^XMB(3.9,145946,2,2274,0)=" K ^TMP($J,""IBCNEDE2DFN"")"
^XMB(3.9,145946,2,2275,0)="""RTN"",""IBCNEDE2"",180,0)"
^XMB(3.9,145946,2,2276,0)=" Q"
^XMB(3.9,145946,2,2277,0)="""RTN"",""IBCNEDE2"",181,0)"
^XMB(3.9,145946,2,2278,0)=" ;========================================================================"
^XMB(3.9,145946,2,2279,0)="""RTN"",""IBCNEDE2"",182,0)"
^XMB(3.9,145946,2,2280,0)="GETELST(FILE) ; Returns a '^' delimited list of IENs Type of Plans or Type of"
^XMB(3.9,145946,2,2281,0)="""RTN"",""IBCNEDE2"",183,0)"
^XMB(3.9,145946,2,2282,0)=" ; coverages to be excluded with leading and trailing '^'s"
^XMB(3.9,145946,2,2283,0)="""RTN"",""IBCNEDE2"",184,0)"
^XMB(3.9,145946,2,2284,0)=" ;Input:"
^XMB(3.9,145946,2,2285,0)="""RTN"",""IBCNEDE2"",185,0)"
^XMB(3.9,145946,2,2286,0)=" ; FILE = 355.1 - Type of Plans"
^XMB(3.9,145946,2,2287,0)="""RTN"",""IBCNEDE2"",186,0)"
^XMB(3.9,145946,2,2288,0)=" ;      = 355.2 - Type of Coverages"
^XMB(3.9,145946,2,2289,0)="""RTN"",""IBCNEDE2"",187,0)"
^XMB(3.9,145946,2,2290,0)=" ;Returns: "
^XMB(3.9,145946,2,2291,0)="""RTN"",""IBCNEDE2"",188,0)"
^XMB(3.9,145946,2,2292,0)=" ; EXCLIST - '^' delimited list of IENs for Type of Plans or Type of Coverages"
^XMB(3.9,145946,2,2293,0)="""RTN"",""IBCNEDE2"",189,0)"
^XMB(3.9,145946,2,2294,0)=" ;           to be excluded (ie., ^10^6^22^)"
^XMB(3.9,145946,2,2295,0)="""RTN"",""IBCNEDE2"",190,0)"
^XMB(3.9,145946,2,2296,0)=" ;"
^XMB(3.9,145946,2,2297,0)="""RTN"",""IBCNEDE2"",191,0)"
^XMB(3.9,145946,2,2298,0)=" N EXCLIST,IEN,LINE,TYPE"
^XMB(3.9,145946,2,2299,0)="""RTN"",""IBCNEDE2"",192,0)"
^XMB(3.9,145946,2,2300,0)=" S EXCLIST="""""
^XMB(3.9,145946,2,2301,0)="""RTN"",""IBCNEDE2"",193,0)"
^XMB(3.9,145946,2,2302,0)=" I FILE=""355.1"" F LINE=1:1 S TYPE=$P($T(TOP+LINE),"";;"",2) Q:TYPE=""""  D"
^XMB(3.9,145946,2,2303,0)="""RTN"",""IBCNEDE2"",194,0)"
^XMB(3.9,145946,2,2304,0)=" . I '$D(^IBE(FILE,""B"",TYPE)) Q"
^XMB(3.9,145946,2,2305,0)="""RTN"",""IBCNEDE2"",195,0)"
^XMB(3.9,145946,2,2306,0)=" . N IEN S IEN=$O(^IBE(FILE,""B"",TYPE,""""))"
^XMB(3.9,145946,2,2307,0)="""RTN"",""IBCNEDE2"",196,0)"
^XMB(3.9,145946,2,2308,0)=" . S EXCLIST=$S(EXCLIST="""":IEN,1:EXCLIST_""^""_IEN)"
^XMB(3.9,145946,2,2309,0)="""RTN"",""IBCNEDE2"",197,0)"
^XMB(3.9,145946,2,2310,0)=" ;"
^XMB(3.9,145946,2,2311,0)="""RTN"",""IBCNEDE2"",198,0)"
^XMB(3.9,145946,2,2312,0)=" I FILE=""355.2"" F LINE=1:1 S TYPE=$P($T(TOC+LINE),"";;"",2) Q:TYPE=""""  D"
^XMB(3.9,145946,2,2313,0)="""RTN"",""IBCNEDE2"",199,0)"
^XMB(3.9,145946,2,2314,0)=" . I '$D(^IBE(FILE,""B"",TYPE)) Q"
^XMB(3.9,145946,2,2315,0)="""RTN"",""IBCNEDE2"",200,0)"
^XMB(3.9,145946,2,2316,0)=" . N IEN S IEN=$O(^IBE(FILE,""B"",TYPE,""""))"
^XMB(3.9,145946,2,2317,0)="""RTN"",""IBCNEDE2"",201,0)"
^XMB(3.9,145946,2,2318,0)=" . S EXCLIST=$S(EXCLIST="""":IEN,1:EXCLIST_""^""_IEN)"
^XMB(3.9,145946,2,2319,0)="""RTN"",""IBCNEDE2"",202,0)"
^XMB(3.9,145946,2,2320,0)=" ;"
^XMB(3.9,145946,2,2321,0)="""RTN"",""IBCNEDE2"",203,0)"
^XMB(3.9,145946,2,2322,0)=" Q ""^""_EXCLIST_""^"""
^XMB(3.9,145946,2,2323,0)="""RTN"",""IBCNEDE2"",204,0)"
^XMB(3.9,145946,2,2324,0)=" ;----------------------------------"
^XMB(3.9,145946,2,2325,0)="""RTN"",""IBCNEDE2"",205,0)"
^XMB(3.9,145946,2,2326,0)="TOP ; Type of Plans (#355.1) to exclude"
^XMB(3.9,145946,2,2327,0)="""RTN"",""IBCNEDE2"",206,0)"
^XMB(3.9,145946,2,2328,0)=" ;;AUTOMOBILE"
^XMB(3.9,145946,2,2329,0)="""RTN"",""IBCNEDE2"",207,0)"
^XMB(3.9,145946,2,2330,0)=" ;;MEDICAID"
^XMB(3.9,145946,2,2331,0)="""RTN"",""IBCNEDE2"",208,0)"
^XMB(3.9,145946,2,2332,0)=" ;;MEDI-CAL"
^XMB(3.9,145946,2,2333,0)="""RTN"",""IBCNEDE2"",209,0)"
^XMB(3.9,145946,2,2334,0)=" ;;TORT FEASOR"
^XMB(3.9,145946,2,2335,0)="""RTN"",""IBCNEDE2"",210,0)"
^XMB(3.9,145946,2,2336,0)=" ;;WORKERS' COMPENSATION INSURANCE"
^XMB(3.9,145946,2,2337,0)="""RTN"",""IBCNEDE2"",211,0)"
^XMB(3.9,145946,2,2338,0)=" ;;VA SPECIAL CLASS"
^XMB(3.9,145946,2,2339,0)="""RTN"",""IBCNEDE2"",212,0)"
^XMB(3.9,145946,2,2340,0)=" ;;ACCIDENT AND HEALTH INSURANCE"
^XMB(3.9,145946,2,2341,0)="""RTN"",""IBCNEDE2"",213,0)"
^XMB(3.9,145946,2,2342,0)=" ;;AVIATION TRIP INSURANCE"
^XMB(3.9,145946,2,2343,0)="""RTN"",""IBCNEDE2"",214,0)"
^XMB(3.9,145946,2,2344,0)=" ;;CATASTROPHIC INSURANCE"
^XMB(3.9,145946,2,2345,0)="""RTN"",""IBCNEDE2"",215,0)"
^XMB(3.9,145946,2,2346,0)=" ;;COINSURANCE"
^XMB(3.9,145946,2,2347,0)="""RTN"",""IBCNEDE2"",216,0)"
^XMB(3.9,145946,2,2348,0)=" ;;INCOME PROTECTION (INDEMNITY)"
^XMB(3.9,145946,2,2349,0)="""RTN"",""IBCNEDE2"",217,0)"
^XMB(3.9,145946,2,2350,0)=" ;;MEDICARE/MEDICAID (MEDI-CAL)"
^XMB(3.9,145946,2,2351,0)="""RTN"",""IBCNEDE2"",218,0)"
^XMB(3.9,145946,2,2352,0)=" ;;QUALIFIED IMPAIRMENT INSURANCE"
^XMB(3.9,145946,2,2353,0)="""RTN"",""IBCNEDE2"",219,0)"
^XMB(3.9,145946,2,2354,0)=" ;;SPECIAL CLASS INSURANCE"
^XMB(3.9,145946,2,2355,0)="""RTN"",""IBCNEDE2"",220,0)"
^XMB(3.9,145946,2,2356,0)=" ;;SPECIAL RISK INSURANCE"
^XMB(3.9,145946,2,2357,0)="""RTN"",""IBCNEDE2"",221,0)"
^XMB(3.9,145946,2,2358,0)=" ;----------------------------------"
^XMB(3.9,145946,2,2359,0)="""RTN"",""IBCNEDE2"",222,0)"
^XMB(3.9,145946,2,2360,0)="TOC ; Type of Coverages (#355.2) to exclude "
^XMB(3.9,145946,2,2361,0)="""RTN"",""IBCNEDE2"",223,0)"
^XMB(3.9,145946,2,2362,0)=" ;;MEDICAID"
^XMB(3.9,145946,2,2363,0)="""RTN"",""IBCNEDE2"",224,0)"
^XMB(3.9,145946,2,2364,0)=" ;;MEDI-CAL"
^XMB(3.9,145946,2,2365,0)="""RTN"",""IBCNEDE2"",225,0)"
^XMB(3.9,145946,2,2366,0)=" ;;TORT/FEASOR "
^XMB(3.9,145946,2,2367,0)="""RTN"",""IBCNEDE2"",226,0)"
^XMB(3.9,145946,2,2368,0)=" ;;WORKERS' COMPENSATION"
^XMB(3.9,145946,2,2369,0)="""RTN"",""IBCNEDE2"",227,0)"
^XMB(3.9,145946,2,2370,0)=" ;;VA SPECIAL CLASS"
^XMB(3.9,145946,2,2371,0)="""RTN"",""IBCNEDE2"",228,0)"
^XMB(3.9,145946,2,2372,0)=" ;;DISABILITY INCOME INSURANCE"
^XMB(3.9,145946,2,2373,0)="""RTN"",""IBCNEDE2"",229,0)"
^XMB(3.9,145946,2,2374,0)=" ;;INDEMNITY"
^XMB(3.9,145946,2,2375,0)="""RTN"",""IBCNEDE2"",230,0)"
^XMB(3.9,145946,2,2376,0)=" ;;SUBSTANCE ABUSE ONLY"
^XMB(3.9,145946,2,2377,0)="""RTN"",""IBCNEDE2"",231,0)"
^XMB(3.9,145946,2,2378,0)=" ;----------------------------------"
^XMB(3.9,145946,2,2379,0)="""RTN"",""IBCNEDE2"",232,0)"
^XMB(3.9,145946,2,2380,0)="OKFRESH(INREC,FRESHDAY,MFRESHDAY,MFLG) ; Identify those policies to exclude when"
^XMB(3.9,145946,2,2381,0)="""RTN"",""IBCNEDE2"",233,0)"
^XMB(3.9,145946,2,2382,0)=" ;               verified within the ""freshness days"" for Medicare and non-Medicare policies."
^XMB(3.9,145946,2,2383,0)="""RTN"",""IBCNEDE2"",234,0)"
^XMB(3.9,145946,2,2384,0)=" ; INPUT:"
^XMB(3.9,145946,2,2385,0)="""RTN"",""IBCNEDE2"",235,0)"
^XMB(3.9,145946,2,2386,0)=" ;   INREC     - IEN to current Insurance Plan"
^XMB(3.9,145946,2,2387,0)="""RTN"",""IBCNEDE2"",236,0)"
^XMB(3.9,145946,2,2388,0)=" ;   FRESHDAY  - Freshness Days Span"
^XMB(3.9,145946,2,2389,0)="""RTN"",""IBCNEDE2"",237,0)"
^XMB(3.9,145946,2,2390,0)=" ;   MFRESHDAY - Medicare Freshness Days Span"
^XMB(3.9,145946,2,2391,0)="""RTN"",""IBCNEDE2"",238,0)"
^XMB(3.9,145946,2,2392,0)=" ;   MFLG      - Used to determine if the insurance plan is a Medicare Plan -  1=MEDICARE,  0=non-MEDICARE"
^XMB(3.9,145946,2,2393,0)="""RTN"",""IBCNEDE2"",239,0)"
^XMB(3.9,145946,2,2394,0)=" ; OUTPUT:"
^XMB(3.9,145946,2,2395,0)="""RTN"",""IBCNEDE2"",240,0)"
^XMB(3.9,145946,2,2396,0)=" ;   OK = 0 - Exclude Policy"
^XMB(3.9,145946,2,2397,0)="""RTN"",""IBCNEDE2"",241,0)"
^XMB(3.9,145946,2,2398,0)=" ;      = 1 - Include Policy"
^XMB(3.9,145946,2,2399,0)="""RTN"",""IBCNEDE2"",242,0)"
^XMB(3.9,145946,2,2400,0)=" N GIEN,IIEN,OK,VDATE"
^XMB(3.9,145946,2,2401,0)="""RTN"",""IBCNEDE2"",243,0)"
^XMB(3.9,145946,2,2402,0)=" S MFLG=0,OK=1,VDATE=$P($G(PTINS(INREC,1)),U,3)"
^XMB(3.9,145946,2,2403,0)="""RTN"",""IBCNEDE2"",244,0)"
^XMB(3.9,145946,2,2404,0)=" S IIEN=$P($G(PTINS(INREC,0)),U,1)       ; Insurance ien"
^XMB(3.9,145946,2,2405,0)="""RTN"",""IBCNEDE2"",245,0)"
^XMB(3.9,145946,2,2406,0)=" ; Is the Insurance company PAYER (#36,3.1) the same as MEDICARE PAYER (#350.9,51.25) "
^XMB(3.9,145946,2,2407,0)="""RTN"",""IBCNEDE2"",246,0)"
^XMB(3.9,145946,2,2408,0)=" I $$GET1^DIQ(36,IIEN_"","",3.1)=$$GET1^DIQ(350.9,""1,"",51.25) S MFLG=1   ;Medicare Part A and Part B Policies"
^XMB(3.9,145946,2,2409,0)="""RTN"",""IBCNEDE2"",247,0)"
^XMB(3.9,145946,2,2410,0)=" ; Determine if Type of Plan (#355.3,.09) for the Group Plan is MEDICARE ADVANTAGE"
^XMB(3.9,145946,2,2411,0)="""RTN"",""IBCNEDE2"",248,0)"
^XMB(3.9,145946,2,2412,0)=" I 'MFLG D"
^XMB(3.9,145946,2,2413,0)="""RTN"",""IBCNEDE2"",249,0)"
^XMB(3.9,145946,2,2414,0)=" . S GIEN=+$P($G(PTINS(INREC,0)),U,18)   ; Group Plan ien"
^XMB(3.9,145946,2,2415,0)="""RTN"",""IBCNEDE2"",250,0)"
^XMB(3.9,145946,2,2416,0)=" . I GIEN,$$GET1^DIQ(355.3,GIEN_"","",.09)=""MEDICARE ADVANTAGE"" S MFLG=1 ;Medicare Part C"
^XMB(3.9,145946,2,2417,0)="""RTN"",""IBCNEDE2"",251,0)"
^XMB(3.9,145946,2,2418,0)=" I $$GET1^DIQ(36,IIEN_"","",.01)=""MEDICARE PART D (WNR)"" S MFLG=1        ;Medicare Part D (WNR)"
^XMB(3.9,145946,2,2419,0)="""RTN"",""IBCNEDE2"",252,0)"
^XMB(3.9,145946,2,2420,0)=" ;"
^XMB(3.9,145946,2,2421,0)="""RTN"",""IBCNEDE2"",253,0)"
^XMB(3.9,145946,2,2422,0)=" I VDATE'="""",'MFLG,SRVICEDT'>$$FMADD^XLFDT(VDATE,FRESHDAY) S OK=0      ;Non-Medicare Policy outside of Freshness Day span"
^XMB(3.9,145946,2,2423,0)="""RTN"",""IBCNEDE2"",254,0)"
^XMB(3.9,145946,2,2424,0)=" I VDATE'="""",MFLG,SRVICEDT'>$$FMADD^XLFDT(VDATE,MFRESHDAY) S OK=0      ;Medicare Policy outside of Medicare Freshness Day span"
^XMB(3.9,145946,2,2425,0)="""RTN"",""IBCNEDE2"",255,0)"
^XMB(3.9,145946,2,2426,0)=" Q OK"
^XMB(3.9,145946,2,2427,0)="""RTN"",""IBCNEDE2"",256,0)"
^XMB(3.9,145946,2,2428,0)=" ;----------------------------------"
^XMB(3.9,145946,2,2429,0)="""RTN"",""IBCNEDE2"",257,0)"
^XMB(3.9,145946,2,2430,0)="SET(SID,INR,PATID) ; Set data in TQ and send to FSC"
^XMB(3.9,145946,2,2431,0)="""RTN"",""IBCNEDE2"",258,0)"
^XMB(3.9,145946,2,2432,0)=" ;"
^XMB(3.9,145946,2,2433,0)="""RTN"",""IBCNEDE2"",259,0)"
^XMB(3.9,145946,2,2434,0)=" N DATA1,DATA2,DATA5,ORIG"
^XMB(3.9,145946,2,2435,0)="""RTN"",""IBCNEDE2"",260,0)"
^XMB(3.9,145946,2,2436,0)=" ;"
^XMB(3.9,145946,2,2437,0)="""RTN"",""IBCNEDE2"",261,0)"
^XMB(3.9,145946,2,2438,0)=" ; The hard coded '1' in the 3rd piece of DATA1 sets the Transmission"
^XMB(3.9,145946,2,2439,0)="""RTN"",""IBCNEDE2"",262,0)"
^XMB(3.9,145946,2,2440,0)=" ; status of file 365.1 to ""Ready to Transmit"""
^XMB(3.9,145946,2,2441,0)="""RTN"",""IBCNEDE2"",263,0)"
^XMB(3.9,145946,2,2442,0)=" ;   10/2023: FRESHDT is no longer being included in DATA1"
^XMB(3.9,145946,2,2443,0)="""RTN"",""IBCNEDE2"",264,0)"
^XMB(3.9,145946,2,2444,0)=" S DATA1=DFN_U_PIEN_U_1_U_""""_U_SID                 ; SETTQ 1st parameter"
^XMB(3.9,145946,2,2445,0)="""RTN"",""IBCNEDE2"",265,0)"
^XMB(3.9,145946,2,2446,0)=" S $P(DATA1,U,8)=PATID"
^XMB(3.9,145946,2,2447,0)="""RTN"",""IBCNEDE2"",266,0)"
^XMB(3.9,145946,2,2448,0)=" ;"
^XMB(3.9,145946,2,2449,0)="""RTN"",""IBCNEDE2"",267,0)"
^XMB(3.9,145946,2,2450,0)=" ; The hardcoded '2' in the 1st piece of DATA2 is the value to tell"
^XMB(3.9,145946,2,2451,0)="""RTN"",""IBCNEDE2"",268,0)"
^XMB(3.9,145946,2,2452,0)=" ; the file 365.1 that it is the appointment extract."
^XMB(3.9,145946,2,2453,0)="""RTN"",""IBCNEDE2"",269,0)"
^XMB(3.9,145946,2,2454,0)=" S DATA2=2_U_QURYFLAG_U_SRVICEDT_U_INR             ; SETTQ 2nd parameter"
^XMB(3.9,145946,2,2455,0)="""RTN"",""IBCNEDE2"",270,0)"
^XMB(3.9,145946,2,2456,0)=" ;"
^XMB(3.9,145946,2,2457,0)="""RTN"",""IBCNEDE2"",271,0)"
^XMB(3.9,145946,2,2458,0)=" S ORIG=U_$S(GRPNUM="" "":"""",1:GRPNUM)_U_$S(GRPNAM="" "":"""",1:GRPNAM)"
^XMB(3.9,145946,2,2459,0)="""RTN"",""IBCNEDE2"",272,0)"
^XMB(3.9,145946,2,2460,0)=" ;"
^XMB(3.9,145946,2,2461,0)="""RTN"",""IBCNEDE2"",273,0)"
^XMB(3.9,145946,2,2462,0)=" S DATA5=$$FIND1^DIC(355.12,,,""eIV"",""C"")           ; Set to IEN of ""eIV"" Source of Information"
^XMB(3.9,145946,2,2463,0)="""RTN"",""IBCNEDE2"",274,0)"
^XMB(3.9,145946,2,2464,0)=" ;"
^XMB(3.9,145946,2,2465,0)="""RTN"",""IBCNEDE2"",275,0)"
^XMB(3.9,145946,2,2466,0)=" S TQIEN=$$SETTQ^IBCNEDE7(DATA1,DATA2,ORIG,,DATA5) ; Sets entry into the TQ"
^XMB(3.9,145946,2,2467,0)="""RTN"",""IBCNEDE2"",276,0)"
^XMB(3.9,145946,2,2468,0)=" ; Send entry to FSC"
^XMB(3.9,145946,2,2469,0)="""RTN"",""IBCNEDE2"",277,0)"
^XMB(3.9,145946,2,2470,0)=" I TQIEN I CNT'>MAXCNT D XMIT1^IBCNEDEP(TQIEN) S CNT=CNT+1      ; Increment the counter of entries sent to FSC"
^XMB(3.9,145946,2,2471,0)="""RTN"",""IBCNEDE2"",278,0)"
^XMB(3.9,145946,2,2472,0)=" Q"
^XMB(3.9,145946,2,2473,0)="""RTN"",""IBCNEDE2"",279,0)"
^XMB(3.9,145946,2,2474,0)=" ;----------------------------------"
^XMB(3.9,145946,2,2475,0)="""RTN"",""IBCNEDE2"",280,0)"
^XMB(3.9,145946,2,2476,0)="ERRMSG ; Send a message indicating an extract error has occurred"
^XMB(3.9,145946,2,2477,0)="""RTN"",""IBCNEDE2"",281,0)"
^XMB(3.9,145946,2,2478,0)=" N MGRP,XMSUB,MSG,IBX,IBM"
^XMB(3.9,145946,2,2479,0)="""RTN"",""IBCNEDE2"",282,0)"
^XMB(3.9,145946,2,2480,0)=" ;"
^XMB(3.9,145946,2,2481,0)="""RTN"",""IBCNEDE2"",283,0)"
^XMB(3.9,145946,2,2482,0)=" ; Set to IB site parameter MAILGROUP"
^XMB(3.9,145946,2,2483,0)="""RTN"",""IBCNEDE2"",284,0)"
^XMB(3.9,145946,2,2484,0)=" S MGRP=$$MGRP^IBCNEUT5()"
^XMB(3.9,145946,2,2485,0)="""RTN"",""IBCNEDE2"",285,0)"
^XMB(3.9,145946,2,2486,0)=" ;"
^XMB(3.9,145946,2,2487,0)="""RTN"",""IBCNEDE2"",286,0)"
^XMB(3.9,145946,2,2488,0)=" S XMSUB=""eIV Problem: Appointment Extract"""
^XMB(3.9,145946,2,2489,0)="""RTN"",""IBCNEDE2"",287,0)"
^XMB(3.9,145946,2,2490,0)=" S MSG(1)=""On ""_$$FMTE^XLFDT(DT)_"" the Appointment Extract for eIV encountered one or more"""
^XMB(3.9,145946,2,2491,0)="""RTN"",""IBCNEDE2"",288,0)"
^XMB(3.9,145946,2,2492,0)=" S MSG(2)=""errors while attempting to get Appointment data from the scheduling"""
^XMB(3.9,145946,2,2493,0)="""RTN"",""IBCNEDE2"",289,0)"
^XMB(3.9,145946,2,2494,0)=" S MSG(3)=""package."""
^XMB(3.9,145946,2,2495,0)="""RTN"",""IBCNEDE2"",290,0)"
^XMB(3.9,145946,2,2496,0)=" S MSG(4)="""""
^XMB(3.9,145946,2,2497,0)="""RTN"",""IBCNEDE2"",291,0)"
^XMB(3.9,145946,2,2498,0)=" S MSG(5)=""Error(s) encountered: """
^XMB(3.9,145946,2,2499,0)="""RTN"",""IBCNEDE2"",292,0)"
^XMB(3.9,145946,2,2500,0)=" S MSG(6)="""""
^XMB(3.9,145946,2,2501,0)="""RTN"",""IBCNEDE2"",293,0)"
^XMB(3.9,145946,2,2502,0)=" S MSG(7)=""  Error Code   Error Message"""
^XMB(3.9,145946,2,2503,0)="""RTN"",""IBCNEDE2"",294,0)"
^XMB(3.9,145946,2,2504,0)=" S MSG(8)=""  ----------   -------------"""
^XMB(3.9,145946,2,2505,0)="""RTN"",""IBCNEDE2"",295,0)"
^XMB(3.9,145946,2,2506,0)=" S IBM=8,IBX=0 F  S IBX=$O(^TMP($J,""SDAMA301"",IBX)) Q:IBX=""""  S IBM=IBM+1,MSG(IBM)=""  ""_$$LJ^XLFSTR(IBX,13)_$G(^TMP($J,""SDAMA301"",IBX))"
^XMB(3.9,145946,2,2507,0)="""RTN"",""IBCNEDE2"",296,0)"
^XMB(3.9,145946,2,2508,0)=" S IBM=IBM+1,MSG(IBM)="""""
^XMB(3.9,145946,2,2509,0)="""RTN"",""IBCNEDE2"",297,0)"
^XMB(3.9,145946,2,2510,0)=" S IBM=IBM+1,MSG(IBM)=""As a result of this error the extract was not done.  The extract"""
^XMB(3.9,145946,2,2511,0)="""RTN"",""IBCNEDE2"",298,0)"
^XMB(3.9,145946,2,2512,0)=" S IBM=IBM+1,MSG(IBM)=""will be attempted again the next night automatically.  If you"""
^XMB(3.9,145946,2,2513,0)="""RTN"",""IBCNEDE2"",299,0)"
^XMB(3.9,145946,2,2514,0)=" S IBM=IBM+1,MSG(IBM)=""continue to receive error messages you should contact your IRM"""
^XMB(3.9,145946,2,2515,0)="""RTN"",""IBCNEDE2"",300,0)"
^XMB(3.9,145946,2,2516,0)=" S IBM=IBM+1,MSG(IBM)=""and possibly call the Help Desk for assistance."""
^XMB(3.9,145946,2,2517,0)="""RTN"",""IBCNEDE2"",301,0)"
^XMB(3.9,145946,2,2518,0)=" ;"
^XMB(3.9,145946,2,2519,0)="""RTN"",""IBCNEDE2"",302,0)"
^XMB(3.9,145946,2,2520,0)=" D MSG^IBCNEUT5(MGRP,XMSUB,""MSG("")"
^XMB(3.9,145946,2,2521,0)="""RTN"",""IBCNEDE2"",303,0)"
^XMB(3.9,145946,2,2522,0)=" Q"
^XMB(3.9,145946,2,2523,0)="""RTN"",""IBCNEDE3"")"
^XMB(3.9,145946,2,2524,0)="0^2^B109033921"
^XMB(3.9,145946,2,2525,0)="""RTN"",""IBCNEDE3"",1,0)"
^XMB(3.9,145946,2,2526,0)="IBCNEDE3 ;AITC/CKB - eIV Appointment Extract ;23-OCT-2023"
^XMB(3.9,145946,2,2527,0)="""RTN"",""IBCNEDE3"",2,0)"
^XMB(3.9,145946,2,2528,0)=" ;;2.0;INTEGRATED BILLING;**778**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,2529,0)="""RTN"",""IBCNEDE3"",3,0)"
^XMB(3.9,145946,2,2530,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,2531,0)="""RTN"",""IBCNEDE3"",4,0)"
^XMB(3.9,145946,2,2532,0)=" ;"
^XMB(3.9,145946,2,2533,0)="""RTN"",""IBCNEDE3"",5,0)"
^XMB(3.9,145946,2,2534,0)=" ;IB*778/CKB - this routine is called by IBCNEDE2 which is used for the Appointment Extract"
^XMB(3.9,145946,2,2535,0)="""RTN"",""IBCNEDE3"",6,0)"
^XMB(3.9,145946,2,2536,0)=" ;"
^XMB(3.9,145946,2,2537,0)="""RTN"",""IBCNEDE3"",7,0)"
^XMB(3.9,145946,2,2538,0)=" Q  ; can't be called directly"
^XMB(3.9,145946,2,2539,0)="""RTN"",""IBCNEDE3"",8,0)"
^XMB(3.9,145946,2,2540,0)=" ;"
^XMB(3.9,145946,2,2541,0)="""RTN"",""IBCNEDE3"",9,0)"
^XMB(3.9,145946,2,2542,0)="STRIP(VALUE) ; check non-alpha numeric characters"
^XMB(3.9,145946,2,2543,0)="""RTN"",""IBCNEDE3"",10,0)"
^XMB(3.9,145946,2,2544,0)=" ;INPUT:"
^XMB(3.9,145946,2,2545,0)="""RTN"",""IBCNEDE3"",11,0)"
^XMB(3.9,145946,2,2546,0)=" ; VALUE  = the string/field to check"
^XMB(3.9,145946,2,2547,0)="""RTN"",""IBCNEDE3"",12,0)"
^XMB(3.9,145946,2,2548,0)=" ;"
^XMB(3.9,145946,2,2549,0)="""RTN"",""IBCNEDE3"",13,0)"
^XMB(3.9,145946,2,2550,0)=" ;RETURN:"
^XMB(3.9,145946,2,2551,0)="""RTN"",""IBCNEDE3"",14,0)"
^XMB(3.9,145946,2,2552,0)=" ; STRNG  = NO non-alpha numeric chars were found, STRNG equal VALUE"
^XMB(3.9,145946,2,2553,0)="""RTN"",""IBCNEDE3"",15,0)"
^XMB(3.9,145946,2,2554,0)=" ;        = if non-alpha numeric chars were found, STRNG will be returned without non-alpha numeric chars in VALUE"
^XMB(3.9,145946,2,2555,0)="""RTN"",""IBCNEDE3"",16,0)"
^XMB(3.9,145946,2,2556,0)=" ;"
^XMB(3.9,145946,2,2557,0)="""RTN"",""IBCNEDE3"",17,0)"
^XMB(3.9,145946,2,2558,0)=" ;  ASCII codes:  48-57: 0-9 / 65-90: A-Z / 97-122: a-z"
^XMB(3.9,145946,2,2559,0)="""RTN"",""IBCNEDE3"",18,0)"
^XMB(3.9,145946,2,2560,0)=" ;"
^XMB(3.9,145946,2,2561,0)="""RTN"",""IBCNEDE3"",19,0)"
^XMB(3.9,145946,2,2562,0)=" N IBI,IBY,LEN,STRNG,XX"
^XMB(3.9,145946,2,2563,0)="""RTN"",""IBCNEDE3"",20,0)"
^XMB(3.9,145946,2,2564,0)=" I $G(VALUE)="""" S STRNG=VALUE G STRIPX"
^XMB(3.9,145946,2,2565,0)="""RTN"",""IBCNEDE3"",21,0)"
^XMB(3.9,145946,2,2566,0)=" S LEN=$L(VALUE)"
^XMB(3.9,145946,2,2567,0)="""RTN"",""IBCNEDE3"",22,0)"
^XMB(3.9,145946,2,2568,0)=" S (IBY,STRNG)="""""
^XMB(3.9,145946,2,2569,0)="""RTN"",""IBCNEDE3"",23,0)"
^XMB(3.9,145946,2,2570,0)=" F IBI=1:1:LEN S IBY=$E(VALUE,IBI) Q:IBY=""""  D"
^XMB(3.9,145946,2,2571,0)="""RTN"",""IBCNEDE3"",24,0)"
^XMB(3.9,145946,2,2572,0)=" . ;Remove all non-alpha numeric characters"
^XMB(3.9,145946,2,2573,0)="""RTN"",""IBCNEDE3"",25,0)"
^XMB(3.9,145946,2,2574,0)=" . I ($A(IBY)<48) Q"
^XMB(3.9,145946,2,2575,0)="""RTN"",""IBCNEDE3"",26,0)"
^XMB(3.9,145946,2,2576,0)=" . I ($A(IBY)>57&($A(IBY)<65))!($A(IBY)>90&($A(IBY)<97))!($A(IBY)>122) Q"
^XMB(3.9,145946,2,2577,0)="""RTN"",""IBCNEDE3"",27,0)"
^XMB(3.9,145946,2,2578,0)=" . S STRNG=STRNG_IBY"
^XMB(3.9,145946,2,2579,0)="""RTN"",""IBCNEDE3"",28,0)"
^XMB(3.9,145946,2,2580,0)="STRIPX ; "
^XMB(3.9,145946,2,2581,0)="""RTN"",""IBCNEDE3"",29,0)"
^XMB(3.9,145946,2,2582,0)=" Q STRNG"
^XMB(3.9,145946,2,2583,0)="""RTN"",""IBCNEDE3"",30,0)"
^XMB(3.9,145946,2,2584,0)=" ;"
^XMB(3.9,145946,2,2585,0)="""RTN"",""IBCNEDE3"",31,0)"
^XMB(3.9,145946,2,2586,0)="UPDSD(PIEN,AIEN,SVDT) ;Update service date based on Payers allowed date range -  Appointment Extract"
^XMB(3.9,145946,2,2587,0)="""RTN"",""IBCNEDE3"",32,0)"
^XMB(3.9,145946,2,2588,0)=" ;from UPDDTS^IBCNEDE6, except past service dates and freshness days are no longer updated"
^XMB(3.9,145946,2,2589,0)="""RTN"",""IBCNEDE3"",33,0)"
^XMB(3.9,145946,2,2590,0)=" ;Input:"
^XMB(3.9,145946,2,2591,0)="""RTN"",""IBCNEDE3"",34,0)"
^XMB(3.9,145946,2,2592,0)=" ;  PIEN - Payer IEN"
^XMB(3.9,145946,2,2593,0)="""RTN"",""IBCNEDE3"",35,0)"
^XMB(3.9,145946,2,2594,0)=" ;  AIEN - Payer App IEN "
^XMB(3.9,145946,2,2595,0)="""RTN"",""IBCNEDE3"",36,0)"
^XMB(3.9,145946,2,2596,0)=" ;Output:"
^XMB(3.9,145946,2,2597,0)="""RTN"",""IBCNEDE3"",37,0)"
^XMB(3.9,145946,2,2598,0)=" ;  SVDT - passed by reference, updated service date"
^XMB(3.9,145946,2,2599,0)="""RTN"",""IBCNEDE3"",38,0)"
^XMB(3.9,145946,2,2600,0)=" ;"
^XMB(3.9,145946,2,2601,0)="""RTN"",""IBCNEDE3"",39,0)"
^XMB(3.9,145946,2,2602,0)=" N DATA,FDAYS"
^XMB(3.9,145946,2,2603,0)="""RTN"",""IBCNEDE3"",40,0)"
^XMB(3.9,145946,2,2604,0)=" ;"
^XMB(3.9,145946,2,2605,0)="""RTN"",""IBCNEDE3"",41,0)"
^XMB(3.9,145946,2,2606,0)=" I ($G(PIEN)="""")!($G(AIEN)="""") Q"
^XMB(3.9,145946,2,2607,0)="""RTN"",""IBCNEDE3"",42,0)"
^XMB(3.9,145946,2,2608,0)=" ;"
^XMB(3.9,145946,2,2609,0)="""RTN"",""IBCNEDE3"",43,0)"
^XMB(3.9,145946,2,2610,0)=" S FDAYS=0"
^XMB(3.9,145946,2,2611,0)="""RTN"",""IBCNEDE3"",44,0)"
^XMB(3.9,145946,2,2612,0)=" S DATA=$G(^IBE(365.12,PIEN,1,AIEN,0))"
^XMB(3.9,145946,2,2613,0)="""RTN"",""IBCNEDE3"",45,0)"
^XMB(3.9,145946,2,2614,0)=" ; Quit without changing if node is not defined"
^XMB(3.9,145946,2,2615,0)="""RTN"",""IBCNEDE3"",46,0)"
^XMB(3.9,145946,2,2616,0)=" I DATA="""" Q"
^XMB(3.9,145946,2,2617,0)="""RTN"",""IBCNEDE3"",47,0)"
^XMB(3.9,145946,2,2618,0)=" ; FUTURE SERVICE DAYS "
^XMB(3.9,145946,2,2619,0)="""RTN"",""IBCNEDE3"",48,0)"
^XMB(3.9,145946,2,2620,0)=" S FDAYS=$$GET1^DIQ(365.121,AIEN_"",""_PIEN_"","",4.03)"
^XMB(3.9,145946,2,2621,0)="""RTN"",""IBCNEDE3"",49,0)"
^XMB(3.9,145946,2,2622,0)=" ; Process future service days if not edited and if not null"
^XMB(3.9,145946,2,2623,0)="""RTN"",""IBCNEDE3"",50,0)"
^XMB(3.9,145946,2,2624,0)=" I FDAYS'="""" D"
^XMB(3.9,145946,2,2625,0)="""RTN"",""IBCNEDE3"",51,0)"
^XMB(3.9,145946,2,2626,0)=" . ; If zero and Service Date is greater than today, reset to TODAY"
^XMB(3.9,145946,2,2627,0)="""RTN"",""IBCNEDE3"",52,0)"
^XMB(3.9,145946,2,2628,0)=" . I FDAYS=0&(SVDT>DT) S SVDT=$$DT^XLFDT"
^XMB(3.9,145946,2,2629,0)="""RTN"",""IBCNEDE3"",53,0)"
^XMB(3.9,145946,2,2630,0)=" . ; If non-zero and Service Date is later than the allowed"
^XMB(3.9,145946,2,2631,0)="""RTN"",""IBCNEDE3"",54,0)"
^XMB(3.9,145946,2,2632,0)=" . ;  Payer Service Date range, reset the Service Date to latest"
^XMB(3.9,145946,2,2633,0)="""RTN"",""IBCNEDE3"",55,0)"
^XMB(3.9,145946,2,2634,0)=" . ;  allowable date for the Payer"
^XMB(3.9,145946,2,2635,0)="""RTN"",""IBCNEDE3"",56,0)"
^XMB(3.9,145946,2,2636,0)=" . I FDAYS,(SVDT>$$FMADD^XLFDT($$DT^XLFDT,FDAYS)) D"
^XMB(3.9,145946,2,2637,0)="""RTN"",""IBCNEDE3"",57,0)"
^XMB(3.9,145946,2,2638,0)=" .. S SVDT=$$FMADD^XLFDT($$DT^XLFDT,FDAYS)"
^XMB(3.9,145946,2,2639,0)="""RTN"",""IBCNEDE3"",58,0)"
^XMB(3.9,145946,2,2640,0)=" Q"
^XMB(3.9,145946,2,2641,0)="""RTN"",""IBCNEDE3"",59,0)"
^XMB(3.9,145946,2,2642,0)=" ;"
^XMB(3.9,145946,2,2643,0)="""RTN"",""IBCNEDE3"",60,0)"
^XMB(3.9,145946,2,2644,0)="ALL(DFN,VAR) ;Find all insurance data on a patient for the Appointment Extract"
^XMB(3.9,145946,2,2645,0)="""RTN"",""IBCNEDE3"",61,0)"
^XMB(3.9,145946,2,2646,0)=" ;Logic from ALL^IBCNS1"
^XMB(3.9,145946,2,2647,0)="""RTN"",""IBCNEDE3"",62,0)"
^XMB(3.9,145946,2,2648,0)=" ; Input:"
^XMB(3.9,145946,2,2649,0)="""RTN"",""IBCNEDE3"",63,0)"
^XMB(3.9,145946,2,2650,0)=" ;       DFN  = patient"
^XMB(3.9,145946,2,2651,0)="""RTN"",""IBCNEDE3"",64,0)"
^XMB(3.9,145946,2,2652,0)=" ;       VAR  = variable used to store output array"
^XMB(3.9,145946,2,2653,0)="""RTN"",""IBCNEDE3"",65,0)"
^XMB(3.9,145946,2,2654,0)=" ;"
^XMB(3.9,145946,2,2655,0)="""RTN"",""IBCNEDE3"",66,0)"
^XMB(3.9,145946,2,2656,0)=" ; Output:"
^XMB(3.9,145946,2,2657,0)="""RTN"",""IBCNEDE3"",67,0)"
^XMB(3.9,145946,2,2658,0)=" ;        var(0)   = number of entries insurance multiple"
^XMB(3.9,145946,2,2659,0)="""RTN"",""IBCNEDE3"",68,0)"
^XMB(3.9,145946,2,2660,0)=" ;        var(x,0) = ^DPT(DFN,.312,x,0)"
^XMB(3.9,145946,2,2661,0)="""RTN"",""IBCNEDE3"",69,0)"
^XMB(3.9,145946,2,2662,0)=" ;        var(x,1) = ^DPT(DFN,.312,x,1)"
^XMB(3.9,145946,2,2663,0)="""RTN"",""IBCNEDE3"",70,0)"
^XMB(3.9,145946,2,2664,0)=" ;        var(x,2) = ^DPT(DFN,.312,x,2)"
^XMB(3.9,145946,2,2665,0)="""RTN"",""IBCNEDE3"",71,0)"
^XMB(3.9,145946,2,2666,0)=" ;        var(x,3) = ^DPT(DFN,.312,x,3)"
^XMB(3.9,145946,2,2667,0)="""RTN"",""IBCNEDE3"",72,0)"
^XMB(3.9,145946,2,2668,0)=" ;        var(x,4) = ^DPT(DFN,.312,x,4)"
^XMB(3.9,145946,2,2669,0)="""RTN"",""IBCNEDE3"",73,0)"
^XMB(3.9,145946,2,2670,0)=" ;        var(x,5) = ^DPT(DFN,.312,x,5)"
^XMB(3.9,145946,2,2671,0)="""RTN"",""IBCNEDE3"",74,0)"
^XMB(3.9,145946,2,2672,0)=" ;        var(x,7) = ^DPT(DFN,.312,x,7)"
^XMB(3.9,145946,2,2673,0)="""RTN"",""IBCNEDE3"",75,0)"
^XMB(3.9,145946,2,2674,0)=" ;    var(x,355.3) = ^IBA(355.3,$p(var(x,0),""^"",18),0)"
^XMB(3.9,145946,2,2675,0)="""RTN"",""IBCNEDE3"",76,0)"
^XMB(3.9,145946,2,2676,0)=" ;"
^XMB(3.9,145946,2,2677,0)="""RTN"",""IBCNEDE3"",77,0)"
^XMB(3.9,145946,2,2678,0)=" N ADT,IBSP,IBIENS,X"
^XMB(3.9,145946,2,2679,0)="""RTN"",""IBCNEDE3"",78,0)"
^XMB(3.9,145946,2,2680,0)=" S ADT=DT"
^XMB(3.9,145946,2,2681,0)="""RTN"",""IBCNEDE3"",79,0)"
^XMB(3.9,145946,2,2682,0)=" S X=0 F  S X=$O(^DPT(DFN,.312,X)) Q:'X  I $D(^(X,0)) D"
^XMB(3.9,145946,2,2683,0)="""RTN"",""IBCNEDE3"",80,0)"
^XMB(3.9,145946,2,2684,0)=" . I '$$CHK(^DPT(DFN,.312,X,0),DFN,X,ADT) Q"
^XMB(3.9,145946,2,2685,0)="""RTN"",""IBCNEDE3"",81,0)"
^XMB(3.9,145946,2,2686,0)=" . S @VAR@(0)=$G(@VAR@(0))+1"
^XMB(3.9,145946,2,2687,0)="""RTN"",""IBCNEDE3"",82,0)"
^XMB(3.9,145946,2,2688,0)=" . S @VAR@(X,0)=$$ZND^IBCNS1(DFN,X)"
^XMB(3.9,145946,2,2689,0)="""RTN"",""IBCNEDE3"",83,0)"
^XMB(3.9,145946,2,2690,0)=" . S @VAR@(X,1)=$G(^DPT(DFN,.312,X,1))"
^XMB(3.9,145946,2,2691,0)="""RTN"",""IBCNEDE3"",84,0)"
^XMB(3.9,145946,2,2692,0)=" . S @VAR@(X,2)=$G(^DPT(DFN,.312,X,2))"
^XMB(3.9,145946,2,2693,0)="""RTN"",""IBCNEDE3"",85,0)"
^XMB(3.9,145946,2,2694,0)=" . S @VAR@(X,3)=$G(^DPT(DFN,.312,X,3))"
^XMB(3.9,145946,2,2695,0)="""RTN"",""IBCNEDE3"",86,0)"
^XMB(3.9,145946,2,2696,0)=" . S @VAR@(X,4)=$G(^DPT(DFN,.312,X,4))"
^XMB(3.9,145946,2,2697,0)="""RTN"",""IBCNEDE3"",87,0)"
^XMB(3.9,145946,2,2698,0)=" . S @VAR@(X,5)=$G(^DPT(DFN,.312,X,5))"
^XMB(3.9,145946,2,2699,0)="""RTN"",""IBCNEDE3"",88,0)"
^XMB(3.9,145946,2,2700,0)=" . S @VAR@(X,7)=$G(^DPT(DFN,.312,X,7))"
^XMB(3.9,145946,2,2701,0)="""RTN"",""IBCNEDE3"",89,0)"
^XMB(3.9,145946,2,2702,0)=" . S IBIENS=+$P($G(^DPT(DFN,.312,X,0)),""^"",18)"
^XMB(3.9,145946,2,2703,0)="""RTN"",""IBCNEDE3"",90,0)"
^XMB(3.9,145946,2,2704,0)=" . S @VAR@(X,355.3)=$G(^IBA(355.3,IBIENS,0))"
^XMB(3.9,145946,2,2705,0)="""RTN"",""IBCNEDE3"",91,0)"
^XMB(3.9,145946,2,2706,0)=" . S $P(@VAR@(X,355.3),U,3)=$$GET1^DIQ(355.3,IBIENS_"","",2.01)"
^XMB(3.9,145946,2,2707,0)="""RTN"",""IBCNEDE3"",92,0)"
^XMB(3.9,145946,2,2708,0)=" . S $P(@VAR@(X,355.3),U,4)=$$GET1^DIQ(355.3,IBIENS_"","",2.02)"
^XMB(3.9,145946,2,2709,0)="""RTN"",""IBCNEDE3"",93,0)"
^XMB(3.9,145946,2,2710,0)="INSCHKQ ;"
