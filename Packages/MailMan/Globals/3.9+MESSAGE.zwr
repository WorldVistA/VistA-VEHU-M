^XMB(3.9,145944,2,1353,0)="""RTN"",""IBJDF42"",160,0)"
^XMB(3.9,145944,2,1354,0)=" K ^UTILITY($J,""W"")"
^XMB(3.9,145944,2,1355,0)="""RTN"",""IBJDF42"",161,0)"
^XMB(3.9,145944,2,1356,0)=" Q"
^XMB(3.9,145944,2,1357,0)="""RTN"",""IBJDF42"",162,0)"
^XMB(3.9,145944,2,1358,0)=" ;"
^XMB(3.9,145944,2,1359,0)="""RTN"",""IBJDF42"",163,0)"
^XMB(3.9,145944,2,1360,0)="WCPB ; - Page Break in the middle of the Comments"
^XMB(3.9,145944,2,1361,0)="""RTN"",""IBJDF42"",164,0)"
^XMB(3.9,145944,2,1362,0)=" D PAUSE Q:IBQ  D HDR1,WPAT W !!"
^XMB(3.9,145944,2,1363,0)="""RTN"",""IBJDF42"",165,0)"
^XMB(3.9,145944,2,1364,0)=" Q"
^XMB(3.9,145944,2,1365,0)="""RTN"",""IBJDF42"",166,0)"
^XMB(3.9,145944,2,1366,0)=" ;"
^XMB(3.9,145944,2,1367,0)="""RTN"",""IBJDF42"",167,0)"
^XMB(3.9,145944,2,1368,0)="HDR1 ; - Write the report header."
^XMB(3.9,145944,2,1369,0)="""RTN"",""IBJDF42"",168,0)"
^XMB(3.9,145944,2,1370,0)=" N X,I"
^XMB(3.9,145944,2,1371,0)="""RTN"",""IBJDF42"",169,0)"
^XMB(3.9,145944,2,1372,0)=" W:'$G(IBPAG) ! I $E(IOST,1,2)=""C-""!$G(IBPAG) W @IOF,*13"
^XMB(3.9,145944,2,1373,0)="""RTN"",""IBJDF42"",170,0)"
^XMB(3.9,145944,2,1374,0)=" S IBPAG=$G(IBPAG)+1 W ""First Party Follow-Up Report"""
^XMB(3.9,145944,2,1375,0)="""RTN"",""IBJDF42"",171,0)"
^XMB(3.9,145944,2,1376,0)=" W ?34,""Run Date: "",IBRUN,?71,""Page: "",$J(IBPAG,3)"
^XMB(3.9,145944,2,1377,0)="""RTN"",""IBJDF42"",172,0)"
^XMB(3.9,145944,2,1378,0)=" S X=""ALL ""_$S(IBSTA'=""S"":""ACTIVE"",1:"""")_$S(IBSTA=""B"":"" AND "",1:"""")"
^XMB(3.9,145944,2,1379,0)="""RTN"",""IBJDF42"",173,0)"
^XMB(3.9,145944,2,1380,0)=" S X=X_$S(IBSTA'=""A"":""SUSPENDED"",1:"""")_"" RECEIVABLES"""
^XMB(3.9,145944,2,1381,0)="""RTN"",""IBJDF42"",174,0)"
^XMB(3.9,145944,2,1382,0)=" I IBSMN'=""A"" S X=X_"" OVER ""_IBSMN_"" AND UNDER ""_IBSMX_"" DAYS OLD"""
^XMB(3.9,145944,2,1383,0)="""RTN"",""IBJDF42"",175,0)"
^XMB(3.9,145944,2,1384,0)=" S X=X_"" / BY ""_$S(IBSN=""N"":""NAME"",1:""LAST 4 SSN"")"
^XMB(3.9,145944,2,1385,0)="""RTN"",""IBJDF42"",176,0)"
^XMB(3.9,145944,2,1386,0)=" S X=X_"" (""_$S($G(IBSNA)=""ALL"":""ALL"",1:""From ""_$S(IBSNF="""":""FIRST"",1:IBSNF)_"" to ""_$S(IBSNL=""zzzzz"":""LAST"",1:IBSNL))_"")"""
^XMB(3.9,145944,2,1387,0)="""RTN"",""IBJDF42"",177,0)"
^XMB(3.9,145944,2,1388,0)=" S X=X_"" / ""_$S('IBSAM:""NO "",1:"""")_""MINIMUM BALANCE"""
^XMB(3.9,145944,2,1389,0)="""RTN"",""IBJDF42"",178,0)"
^XMB(3.9,145944,2,1390,0)=" S X=X_$S(IBSAM:"": $""_$FN(IBSAM,"","",2),1:"""")"
^XMB(3.9,145944,2,1391,0)="""RTN"",""IBJDF42"",179,0)"
^XMB(3.9,145944,2,1392,0)=" S X=X_"" / ""_$S('IBSH:""NO "",IBSH1=""A"":""ALL "",1:""ONLY "")_""COMMENTS"""
^XMB(3.9,145944,2,1393,0)="""RTN"",""IBJDF42"",180,0)"
^XMB(3.9,145944,2,1394,0)=" S X=X_$S($G(IBSH2):"" LESS THAN ""_IBSH2_"" DAYS OLD"",1:"""")"
^XMB(3.9,145944,2,1395,0)="""RTN"",""IBJDF42"",181,0)"
^XMB(3.9,145944,2,1396,0)=" S X=X_"" / RECEIVABLES REFERRED TO RC ""_$S('IBSRC:""NOT "",1:"""")_""INCLUDED"""
^XMB(3.9,145944,2,1397,0)="""RTN"",""IBJDF42"",182,0)"
^XMB(3.9,145944,2,1398,0)=" F I=1:1 W !,$E(X,1,80) S X=$E(X,81,999) I X="""" Q"
^XMB(3.9,145944,2,1399,0)="""RTN"",""IBJDF42"",183,0)"
^XMB(3.9,145944,2,1400,0)=" ;"
^XMB(3.9,145944,2,1401,0)="""RTN"",""IBJDF42"",184,0)"
^XMB(3.9,145944,2,1402,0)=" S IBQ=$$STOP^IBOUTL(""First Party Follow-Up Report"")"
^XMB(3.9,145944,2,1403,0)="""RTN"",""IBJDF42"",185,0)"
^XMB(3.9,145944,2,1404,0)=" Q"
^XMB(3.9,145944,2,1405,0)="""RTN"",""IBJDF42"",186,0)"
^XMB(3.9,145944,2,1406,0)=" ;"
^XMB(3.9,145944,2,1407,0)="""RTN"",""IBJDF42"",187,0)"
^XMB(3.9,145944,2,1408,0)="TYPE(SEL) ; Returns a string with the type of receivables (description)"
^XMB(3.9,145944,2,1409,0)="""RTN"",""IBJDF42"",188,0)"
^XMB(3.9,145944,2,1410,0)=" ; selected or NULL if ALL receivable type have been selected."
^XMB(3.9,145944,2,1411,0)="""RTN"",""IBJDF42"",189,0)"
^XMB(3.9,145944,2,1412,0)=" ; SEL - User input for the parameter ""Type of Receivable"""
^XMB(3.9,145944,2,1413,0)="""RTN"",""IBJDF42"",190,0)"
^XMB(3.9,145944,2,1414,0)=" ;"
^XMB(3.9,145944,2,1415,0)="""RTN"",""IBJDF42"",191,0)"
^XMB(3.9,145944,2,1416,0)=" N TYPE,I,X"
^XMB(3.9,145944,2,1417,0)="""RTN"",""IBJDF42"",192,0)"
^XMB(3.9,145944,2,1418,0)=" I SEL=""1,2,3,"" Q """""
^XMB(3.9,145944,2,1419,0)="""RTN"",""IBJDF42"",193,0)"
