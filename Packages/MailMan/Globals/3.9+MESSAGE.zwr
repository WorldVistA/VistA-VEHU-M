^XMB(3.9,145946,2,653,0)="""RTN"",""IBCMDT"",5,0)"
^XMB(3.9,145946,2,654,0)=" ; IB - Insurance Plans Missing Data Report."
^XMB(3.9,145946,2,655,0)="""RTN"",""IBCMDT"",6,0)"
^XMB(3.9,145946,2,656,0)=" ;"
^XMB(3.9,145946,2,657,0)="""RTN"",""IBCMDT"",7,0)"
^XMB(3.9,145946,2,658,0)=" ;Input parameters: N/A"
