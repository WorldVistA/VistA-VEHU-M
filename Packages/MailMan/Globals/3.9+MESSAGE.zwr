^XMB(3.9,145983,2,1739,0)="""RTN"",""RCRPTLR"",83,0)"
^XMB(3.9,145983,2,1740,0)=" W !,""Repayment Plan Term Length Exceeded Report"",?50,EXTDT,?68,""Page: "",PAGE"
^XMB(3.9,145983,2,1741,0)="""RTN"",""RCRPTLR"",84,0)"
^XMB(3.9,145983,2,1742,0)=" W !!,""                                                               Term   Term Limit"""
^XMB(3.9,145983,2,1743,0)="""RTN"",""RCRPTLR"",85,0)"
^XMB(3.9,145983,2,1744,0)=" W !,""         Name                  SSN           RPP ID           Length   Exc. Date"""
^XMB(3.9,145983,2,1745,0)="""RTN"",""RCRPTLR"",86,0)"
^XMB(3.9,145983,2,1746,0)=" W ! D DASH^RCRPRPU(80)"
^XMB(3.9,145983,2,1747,0)="""RTN"",""RCRPTLR"",87,0)"
^XMB(3.9,145983,2,1748,0)=" Q"
^XMB(3.9,145983,2,1749,0)="""RTN"",""RCRPTLR"",88,0)"
^XMB(3.9,145983,2,1750,0)=" ;"
^XMB(3.9,145983,2,1751,0)="""RTN"",""RCRPTLR"",89,0)"
^XMB(3.9,145983,2,1752,0)="ASKSORT() ; display ""sort by"" prompt"
^XMB(3.9,145983,2,1753,0)="""RTN"",""RCRPTLR"",90,0)"
^XMB(3.9,145983,2,1754,0)=" ;"
^XMB(3.9,145983,2,1755,0)="""RTN"",""RCRPTLR"",91,0)"
^XMB(3.9,145983,2,1756,0)=" ; returns N for debtor name, S for status, A for account balance, -1 for user exit / timeout"
^XMB(3.9,145983,2,1757,0)="""RTN"",""RCRPTLR"",92,0)"
^XMB(3.9,145983,2,1758,0)=" ;"
^XMB(3.9,145983,2,1759,0)="""RTN"",""RCRPTLR"",93,0)"
^XMB(3.9,145983,2,1760,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,X,Y"
^XMB(3.9,145983,2,1761,0)="""RTN"",""RCRPTLR"",94,0)"
^XMB(3.9,145983,2,1762,0)=" S DIR(0)=""SA^N:Name;S:SSN;R:Repayment Plan ID"",DIR(""B"")=""N"""
^XMB(3.9,145983,2,1763,0)="""RTN"",""RCRPTLR"",95,0)"
^XMB(3.9,145983,2,1764,0)=" S DIR(""A"")=""Sort By (N)ame, (S)SN or (R)epayment Plan ID: """
^XMB(3.9,145983,2,1765,0)="""RTN"",""RCRPTLR"",96,0)"
^XMB(3.9,145983,2,1766,0)=" D ^DIR I $D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) Q -1"
^XMB(3.9,145983,2,1767,0)="""RTN"",""RCRPTLR"",97,0)"
^XMB(3.9,145983,2,1768,0)=" Q Y"
^XMB(3.9,145983,2,1769,0)="""RTN"",""RCRPU1"")"
^XMB(3.9,145983,2,1770,0)="0^5^B127787571"
^XMB(3.9,145983,2,1771,0)="""RTN"",""RCRPU1"",1,0)"
^XMB(3.9,145983,2,1772,0)="RCRPU1 ;EDE/SAB - REPAYMENT PLAN UTILITIES;12/11/2020  8:40 AM"
