^XMB(3.9,145956,2,2211,0)="""RTN"",""TIUTIUS"",163,0)"
^XMB(3.9,145956,2,2212,0)=" N AUMTJ,AUMTSKIP"
^XMB(3.9,145956,2,2213,0)="""RTN"",""TIUTIUS"",164,0)"
^XMB(3.9,145956,2,2214,0)=" S (AUMTJ,AUMTSKIP)=0"
^XMB(3.9,145956,2,2215,0)="""RTN"",""TIUTIUS"",165,0)"
^XMB(3.9,145956,2,2216,0)=" F  S AUMTJ=$O(AUMTSA(AUMTJ)) Q:'AUMTJ!(AUMTJ>AUMTI)  D"
^XMB(3.9,145956,2,2217,0)="""RTN"",""TIUTIUS"",166,0)"
^XMB(3.9,145956,2,2218,0)=" . I AUMTI'=AUMTJ,$D(AUMTSA(AUMTJ,AUMTEAM)) S AUMTSKIP=1 Q"
^XMB(3.9,145956,2,2219,0)="""RTN"",""TIUTIUS"",167,0)"
^XMB(3.9,145956,2,2220,0)=" Q AUMTSKIP"
^XMB(3.9,145956,2,2221,0)="""RTN"",""TIUTIUS"",168,0)"
^XMB(3.9,145956,2,2222,0)=" ;"
^XMB(3.9,145956,2,2223,0)="""RTN"",""TIUTIUS"",169,0)"
^XMB(3.9,145956,2,2224,0)=" ;"
^XMB(3.9,145956,2,2225,0)="""RTN"",""TIUTIUS"",170,0)"
^XMB(3.9,145956,2,2226,0)="ADDRECP ; Send to additional notification recipients."
^XMB(3.9,145956,2,2227,0)="""RTN"",""TIUTIUS"",171,0)"
^XMB(3.9,145956,2,2228,0)=" ; If no associate PC provider(3) then check and send to PC provider (1)."
^XMB(3.9,145956,2,2229,0)="""RTN"",""TIUTIUS"",172,0)"
^XMB(3.9,145956,2,2230,0)=" ; If team (6) then check if patient is member of team."
^XMB(3.9,145956,2,2231,0)="""RTN"",""TIUTIUS"",173,0)"
^XMB(3.9,145956,2,2232,0)=" ; If PCP (7-19) checks for associated PCP in PATIENT file (#2) , fields 695021-695033"
^XMB(3.9,145956,2,2233,0)="""RTN"",""TIUTIUS"",174,0)"
