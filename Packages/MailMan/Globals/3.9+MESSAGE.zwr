^XMB(3.9,145980,2,6552,0)=" I LENGTH>1 D"
^XMB(3.9,145980,2,6553,0)="""RTN"",""SDESRECALLREQ"",23,0)"
^XMB(3.9,145980,2,6554,0)=" .F I=1:1:LENGTH S $P(COMMENT,"" | "",I)=$P(SD409841COM,$C(13,10),I) I I=LENGTH S:$L(COMMENT)>80 COMMENT=$E(COMMENT,1,77)_""..."" S SD409841COM=COMMENT"
