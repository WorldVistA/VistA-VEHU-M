^XMB(3.9,145989,2,653,0)="""RTN"",""PSOASAP0"",184,0)"
^XMB(3.9,145989,2,654,0)="PAT20() ;ASAP 3.0 : Patient Gender Code"
^XMB(3.9,145989,2,655,0)="""RTN"",""PSOASAP0"",185,0)"
^XMB(3.9,145989,2,656,0)=" ;       ASAP 4.0+: Species Code (Always return ""01"" for 'Human')"
^XMB(3.9,145989,2,657,0)="""RTN"",""PSOASAP0"",186,0)"
^XMB(3.9,145989,2,658,0)=" I PSOASVER=""3.0"" Q $S($P($G(VADM(5)),""^"",1)'="""":$P($G(VADM(5)),""^"",1),1:""U"")"
^XMB(3.9,145989,2,659,0)="""RTN"",""PSOASAP0"",187,0)"
