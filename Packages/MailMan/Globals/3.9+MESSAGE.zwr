^XMB(3.9,145956,2,1150,0)="NUMIX Q ITEMSANS"
^XMB(3.9,145956,2,1151,0)="""RTN"",""TIUFLF4"",9,0)"
^XMB(3.9,145956,2,1152,0)=" ;"
^XMB(3.9,145956,2,1153,0)="""RTN"",""TIUFLF4"",10,0)"
^XMB(3.9,145956,2,1154,0)="MISSITEM(FILEDA) ; Function Checks FILEDA Items (doesn't check subitems etc.) for existence only. Returns IFN of first missing item it finds, else 0."
^XMB(3.9,145956,2,1155,0)="""RTN"",""TIUFLF4"",11,0)"
^XMB(3.9,145956,2,1156,0)=" ; Requires FILEDA."
^XMB(3.9,145956,2,1157,0)="""RTN"",""TIUFLF4"",12,0)"
^XMB(3.9,145956,2,1158,0)=" N TIUI,IFILEDA,MISSANS"
^XMB(3.9,145956,2,1159,0)="""RTN"",""TIUFLF4"",13,0)"
^XMB(3.9,145956,2,1160,0)=" S TIUI=0,MISSANS=0"
^XMB(3.9,145956,2,1161,0)="""RTN"",""TIUFLF4"",14,0)"
^XMB(3.9,145956,2,1162,0)=" F  S TIUI=$O(^TIU(8925.1,FILEDA,10,TIUI)) Q:'TIUI!MISSANS  D"
^XMB(3.9,145956,2,1163,0)="""RTN"",""TIUFLF4"",15,0)"
^XMB(3.9,145956,2,1164,0)=" . S IFILEDA=+^TIU(8925.1,FILEDA,10,TIUI,0)"
^XMB(3.9,145956,2,1165,0)="""RTN"",""TIUFLF4"",16,0)"
^XMB(3.9,145956,2,1166,0)=" . I '$D(^TIU(8925.1,IFILEDA,0)) S MISSANS=IFILEDA"
^XMB(3.9,145956,2,1167,0)="""RTN"",""TIUFLF4"",17,0)"
^XMB(3.9,145956,2,1168,0)=" Q MISSANS"
^XMB(3.9,145956,2,1169,0)="""RTN"",""TIUFLF4"",18,0)"
^XMB(3.9,145956,2,1170,0)=" ;"
^XMB(3.9,145956,2,1171,0)="""RTN"",""TIUFLF4"",19,0)"
^XMB(3.9,145956,2,1172,0)="ANCESTOR(FILEDA,NODE0,ANCESTOR,DOCFLAG) ; Module traces ancestors of FILEDA,"
^XMB(3.9,145956,2,1173,0)="""RTN"",""TIUFLF4"",20,0)"
^XMB(3.9,145956,2,1174,0)=" ;creates array ANCESTOR,"
^XMB(3.9,145956,2,1175,0)="""RTN"",""TIUFLF4"",21,0)"
^XMB(3.9,145956,2,1176,0)=" ; where ANCESTOR(0)=FILEDA,"
^XMB(3.9,145956,2,1177,0)="""RTN"",""TIUFLF4"",22,0)"
^XMB(3.9,145956,2,1178,0)=" ; where ANCESTOR(1)=Parent IFN of FILEDA,"
^XMB(3.9,145956,2,1179,0)="""RTN"",""TIUFLF4"",23,0)"
^XMB(3.9,145956,2,1180,0)=" ;       ANCESTOR(2)=Parent IFN of ANCESTOR(1)"
^XMB(3.9,145956,2,1181,0)="""RTN"",""TIUFLF4"",24,0)"
^XMB(3.9,145956,2,1182,0)=" ;       ..."
^XMB(3.9,145956,2,1183,0)="""RTN"",""TIUFLF4"",25,0)"
^XMB(3.9,145956,2,1184,0)=" ;       ANCESTOR(last subscript)=IFN of oldest ancestor of FILEDA if"
^XMB(3.9,145956,2,1185,0)="""RTN"",""TIUFLF4"",26,0)"
^XMB(3.9,145956,2,1186,0)=" ;                                '$G(DOCFLAG)"
^XMB(3.9,145956,2,1187,0)="""RTN"",""TIUFLF4"",27,0)"
^XMB(3.9,145956,2,1188,0)=" ;                                           OR"
^XMB(3.9,145956,2,1189,0)="""RTN"",""TIUFLF4"",28,0)"
^XMB(3.9,145956,2,1190,0)=" ;                                IFN of oldest ancestor of FILEDA NOT"
^XMB(3.9,145956,2,1191,0)="""RTN"",""TIUFLF4"",29,0)"
^XMB(3.9,145956,2,1192,0)=" ;                                OF TYPE DC OR CL if $G(DOCFLAG)"
^XMB(3.9,145956,2,1193,0)="""RTN"",""TIUFLF4"",30,0)"
^XMB(3.9,145956,2,1194,0)=" ; Don't stop the array for problems like bad type, no type, type object."
^XMB(3.9,145956,2,1195,0)="""RTN"",""TIUFLF4"",31,0)"
^XMB(3.9,145956,2,1196,0)=" ; If DOCFLAG, DON'T GET DC or CL; don't want array to mistakenly"
^XMB(3.9,145956,2,1197,0)="""RTN"",""TIUFLF4"",32,0)"
^XMB(3.9,145956,2,1198,0)=" ;go all  the way to CLinical Documents."
^XMB(3.9,145956,2,1199,0)="""RTN"",""TIUFLF4"",33,0)"
^XMB(3.9,145956,2,1200,0)=" ; Array may not EXIST if DOCFLAG"
^XMB(3.9,145956,2,1201,0)="""RTN"",""TIUFLF4"",34,0)"
^XMB(3.9,145956,2,1202,0)=" ; Requires FILEDA, NODE0= 0 Node;"
^XMB(3.9,145956,2,1203,0)="""RTN"",""TIUFLF4"",35,0)"
^XMB(3.9,145956,2,1204,0)=" ; DOCFLAG optional, 0 or 1"
^XMB(3.9,145956,2,1205,0)="""RTN"",""TIUFLF4"",36,0)"
^XMB(3.9,145956,2,1206,0)=" N TIUI,QUIT,ANODE0"
^XMB(3.9,145956,2,1207,0)="""RTN"",""TIUFLF4"",37,0)"
^XMB(3.9,145956,2,1208,0)=" S DOCFLAG=+$G(DOCFLAG)"
^XMB(3.9,145956,2,1209,0)="""RTN"",""TIUFLF4"",38,0)"
^XMB(3.9,145956,2,1210,0)=" I DOCFLAG,($P(NODE0,U,4)=""DC"")!($P(NODE0,U,4)=""CL"") G ANCEX"
^XMB(3.9,145956,2,1211,0)="""RTN"",""TIUFLF4"",39,0)"
^XMB(3.9,145956,2,1212,0)=" S TIUI=0,ANCESTOR(0)=FILEDA"
^XMB(3.9,145956,2,1213,0)="""RTN"",""TIUFLF4"",40,0)"
^XMB(3.9,145956,2,1214,0)=" F  D  Q:$G(QUIT)"
^XMB(3.9,145956,2,1215,0)="""RTN"",""TIUFLF4"",41,0)"
^XMB(3.9,145956,2,1216,0)=" . S ANCESTOR(TIUI+1)=$O(^TIU(8925.1,""AD"",ANCESTOR(TIUI),0))"
^XMB(3.9,145956,2,1217,0)="""RTN"",""TIUFLF4"",42,0)"
^XMB(3.9,145956,2,1218,0)=" . I 'ANCESTOR(TIUI+1) K ANCESTOR(TIUI+1) S QUIT=1 Q"
^XMB(3.9,145956,2,1219,0)="""RTN"",""TIUFLF4"",43,0)"
^XMB(3.9,145956,2,1220,0)=" . I DOCFLAG S ANODE0=^TIU(8925.1,ANCESTOR(TIUI+1),0) I ($P(ANODE0,U,4)=""DC"")!($P(ANODE0,U,4)=""CL"") K ANCESTOR(TIUI+1) S QUIT=1 Q"
^XMB(3.9,145956,2,1221,0)="""RTN"",""TIUFLF4"",44,0)"
^XMB(3.9,145956,2,1222,0)=" . S TIUI=TIUI+1"
^XMB(3.9,145956,2,1223,0)="""RTN"",""TIUFLF4"",45,0)"
^XMB(3.9,145956,2,1224,0)="ANCEX Q"
^XMB(3.9,145956,2,1225,0)="""RTN"",""TIUFLF4"",46,0)"
^XMB(3.9,145956,2,1226,0)=" ;"
^XMB(3.9,145956,2,1227,0)="""RTN"",""TIUFLF4"",47,0)"
^XMB(3.9,145956,2,1228,0)="ORPHAN(FILEDA,NODE0,ANCESTOR) ; Function traces ancestors of FILEDA,"
^XMB(3.9,145956,2,1229,0)="""RTN"",""TIUFLF4"",48,0)"
^XMB(3.9,145956,2,1230,0)=" ; Returns NA if FILEDA is Object or Shared Component,"
^XMB(3.9,145956,2,1231,0)="""RTN"",""TIUFLF4"",49,0)"
^XMB(3.9,145956,2,1232,0)=" ;         NO if NOT NA AND FILEDA belongs to Clinical Docmts Hierarchy,"
^XMB(3.9,145956,2,1233,0)="""RTN"",""TIUFLF4"",50,0)"
^XMB(3.9,145956,2,1234,0)=" ;         YES if NOT NA, AND doesn't belong."
^XMB(3.9,145956,2,1235,0)="""RTN"",""TIUFLF4"",51,0)"
^XMB(3.9,145956,2,1236,0)=" ; Requires FILEDA, NODE0= 0 Node;"
^XMB(3.9,145956,2,1237,0)="""RTN"",""TIUFLF4"",52,0)"
^XMB(3.9,145956,2,1238,0)=" N ORPHAN,LAST"
^XMB(3.9,145956,2,1239,0)="""RTN"",""TIUFLF4"",53,0)"
^XMB(3.9,145956,2,1240,0)=" I $P(NODE0,U,4)=""O"" S ORPHAN=""NA"" G ORPHX"
^XMB(3.9,145956,2,1241,0)="""RTN"",""TIUFLF4"",54,0)"
^XMB(3.9,145956,2,1242,0)=" I '$D(ANCESTOR) D ANCESTOR(FILEDA,NODE0,.ANCESTOR)"
^XMB(3.9,145956,2,1243,0)="""RTN"",""TIUFLF4"",55,0)"
^XMB(3.9,145956,2,1244,0)=" I '$D(^TMP(""TIUF"",$J,""CLINDOC"")) D  G:Y=-1 ORPHX"
^XMB(3.9,145956,2,1245,0)="""RTN"",""TIUFLF4"",56,0)"
^XMB(3.9,145956,2,1246,0)=" . N DIC,X,Y"
^XMB(3.9,145956,2,1247,0)="""RTN"",""TIUFLF4"",57,0)"
^XMB(3.9,145956,2,1248,0)=" . S DIC=8925.1,DIC(0)=""X"",X=""CLINICAL DOCUMENTS"" D ^DIC"
^XMB(3.9,145956,2,1249,0)="""RTN"",""TIUFLF4"",58,0)"
^XMB(3.9,145956,2,1250,0)=" . I Y=-1 S ORPHAN=""UNKNOWN"" Q"
^XMB(3.9,145956,2,1251,0)="""RTN"",""TIUFLF4"",59,0)"
^XMB(3.9,145956,2,1252,0)=" . S ^TMP(""TIUF"",$J,""CLINDOC"")=+Y"
^XMB(3.9,145956,2,1253,0)="""RTN"",""TIUFLF4"",60,0)"
^XMB(3.9,145956,2,1254,0)=" S LAST=$O(ANCESTOR(100),-1) I ANCESTOR(LAST)=^TMP(""TIUF"",$J,""CLINDOC"") S ORPHAN=""NO"" G ORPHX"
^XMB(3.9,145956,2,1255,0)="""RTN"",""TIUFLF4"",61,0)"
^XMB(3.9,145956,2,1256,0)=" S ORPHAN=""YES"""
^XMB(3.9,145956,2,1257,0)="""RTN"",""TIUFLF4"",62,0)"
^XMB(3.9,145956,2,1258,0)="ORPHX Q ORPHAN"
^XMB(3.9,145956,2,1259,0)="""RTN"",""TIUFLF4"",63,0)"
^XMB(3.9,145956,2,1260,0)=" ;"
^XMB(3.9,145956,2,1261,0)="""RTN"",""TIUFLF4"",64,0)"
^XMB(3.9,145956,2,1262,0)="STUFFLDS(FILEDA,PFILEDA) ; Stuff fields .03, .04 (tries), .07, [.1]"
^XMB(3.9,145956,2,1263,0)="""RTN"",""TIUFLF4"",65,0)"
^XMB(3.9,145956,2,1264,0)=" ;for 8925.1 entry FILEDA."
^XMB(3.9,145956,2,1265,0)="""RTN"",""TIUFLF4"",66,0)"
^XMB(3.9,145956,2,1266,0)=" ; Requires FILEDA."
^XMB(3.9,145956,2,1267,0)="""RTN"",""TIUFLF4"",67,0)"
^XMB(3.9,145956,2,1268,0)=" ; Requires TIUFTLST as set in TYPELIST^TIUFLF7"
^XMB(3.9,145956,2,1269,0)="""RTN"",""TIUFLF4"",68,0)"
^XMB(3.9,145956,2,1270,0)=" ; Requires PFILEDA if entry has prospective (as in Create and Add Item)"
^XMB(3.9,145956,2,1271,0)="""RTN"",""TIUFLF4"",69,0)"
^XMB(3.9,145956,2,1272,0)=" ;or actual parent in order to try to stuff Type."
^XMB(3.9,145956,2,1273,0)="""RTN"",""TIUFLF4"",70,0)"
^XMB(3.9,145956,2,1274,0)=" ; Stuffs .03 Print Name = First 60 chars of .01 Name if not from copy"
^XMB(3.9,145956,2,1275,0)="""RTN"",""TIUFLF4"",71,0)"
^XMB(3.9,145956,2,1276,0)=" ;action."
^XMB(3.9,145956,2,1277,0)="""RTN"",""TIUFLF4"",72,0)"
^XMB(3.9,145956,2,1278,0)=" ; Stuffs .04 Type if only 1 possible type in TIUFTLST (because of parent"
^XMB(3.9,145956,2,1279,0)="""RTN"",""TIUFLF4"",73,0)"
^XMB(3.9,145956,2,1280,0)=" ;or duplicates or option e.g. create objects)."
^XMB(3.9,145956,2,1281,0)="""RTN"",""TIUFLF4"",74,0)"
^XMB(3.9,145956,2,1282,0)=" ; Stuffs .07 Status = Inactive."
^XMB(3.9,145956,2,1283,0)="""RTN"",""TIUFLF4"",75,0)"
^XMB(3.9,145956,2,1284,0)=" ; If receives parent PFILEDA, parent is Shared, then"
^XMB(3.9,145956,2,1285,0)="""RTN"",""TIUFLF4"",76,0)"
^XMB(3.9,145956,2,1286,0)=" ;stuffs .1 Shared = 1"
^XMB(3.9,145956,2,1287,0)="""RTN"",""TIUFLF4"",77,0)"
^XMB(3.9,145956,2,1288,0)=" ; Should Lock FILEDA before calling STUFFLDS."
^XMB(3.9,145956,2,1289,0)="""RTN"",""TIUFLF4"",78,0)"
^XMB(3.9,145956,2,1290,0)=" N DIE,DA,DR,Y,NAME,PRINTDR,TYPEDR,STATUSDR,SHAREDR"
^XMB(3.9,145956,2,1291,0)="""RTN"",""TIUFLF4"",79,0)"
^XMB(3.9,145956,2,1292,0)=" N NATL,NATLDR,NODE0,TYPE"
^XMB(3.9,145956,2,1293,0)="""RTN"",""TIUFLF4"",80,0)"
^XMB(3.9,145956,2,1294,0)=" I '$G(PFILEDA) S PFILEDA=0"
^XMB(3.9,145956,2,1295,0)="""RTN"",""TIUFLF4"",81,0)"
^XMB(3.9,145956,2,1296,0)=" S DIE=8925.1,DA=FILEDA"
^XMB(3.9,145956,2,1297,0)="""RTN"",""TIUFLF4"",82,0)"
^XMB(3.9,145956,2,1298,0)=" S NODE0=^TIU(8925.1,FILEDA,0),NAME=$P(NODE0,U),PRINTDR="".03///^S X=NAME"""
^XMB(3.9,145956,2,1299,0)="""RTN"",""TIUFLF4"",83,0)"
^XMB(3.9,145956,2,1300,0)=" I $L(TIUFTLST,U)=3 S TYPE=$P(TIUFTLST,U,2),TYPEDR="".04////^S X=TYPE"""
^XMB(3.9,145956,2,1301,0)="""RTN"",""TIUFLF4"",84,0)"
^XMB(3.9,145956,2,1302,0)=" S STATUSDR="".07///INACTIVE"""
^XMB(3.9,145956,2,1303,0)="""RTN"",""TIUFLF4"",85,0)"
^XMB(3.9,145956,2,1304,0)=" S SHAREDR="".1////1"""
^XMB(3.9,145956,2,1305,0)="""RTN"",""TIUFLF4"",86,0)"
^XMB(3.9,145956,2,1306,0)=" I $G(XQORNOD(0))'[""Copy"" S DR=PRINTDR"
^XMB(3.9,145956,2,1307,0)="""RTN"",""TIUFLF4"",87,0)"
^XMB(3.9,145956,2,1308,0)=" ;VMP/ELR P232. On a copy set print name equal title if not an object menu."
^XMB(3.9,145956,2,1309,0)="""RTN"",""TIUFLF4"",88,0)"
^XMB(3.9,145956,2,1310,0)=" I $G(TIUFXNOD)[""Copy"",$G(ACTION)=""C"",$P($G(NODE0),U,4)'=""O"" S DR=PRINTDR"
^XMB(3.9,145956,2,1311,0)="""RTN"",""TIUFLF4"",89,0)"
^XMB(3.9,145956,2,1312,0)=" I $G(TYPEDR) S DR=$S($D(DR):DR_"";""_TYPEDR,1:TYPEDR)"
^XMB(3.9,145956,2,1313,0)="""RTN"",""TIUFLF4"",90,0)"
^XMB(3.9,145956,2,1314,0)=" S DR=$S($D(DR):DR_"";""_STATUSDR,1:STATUSDR)"
^XMB(3.9,145956,2,1315,0)="""RTN"",""TIUFLF4"",91,0)"
^XMB(3.9,145956,2,1316,0)=" I $P($G(^TIU(8925.1,PFILEDA,0)),U,10) S DR=DR_"";""_SHAREDR"
^XMB(3.9,145956,2,1317,0)="""RTN"",""TIUFLF4"",92,0)"
^XMB(3.9,145956,2,1318,0)=" D ^DIE"
^XMB(3.9,145956,2,1319,0)="""RTN"",""TIUFLF4"",93,0)"
^XMB(3.9,145956,2,1320,0)="STUFFX Q"
^XMB(3.9,145956,2,1321,0)="""RTN"",""TIUFLF4"",94,0)"
^XMB(3.9,145956,2,1322,0)=" ;"
^XMB(3.9,145956,2,1323,0)="""RTN"",""TIUFLF4"",95,0)"
^XMB(3.9,145956,2,1324,0)="ADDTEN(PFILEDA,FILEDA,NODE0,TENDA) ; Add item FILEDA to 10 NODE of"
^XMB(3.9,145956,2,1325,0)="""RTN"",""TIUFLF4"",96,0)"
^XMB(3.9,145956,2,1326,0)=" ;File 8925.1 entry PFILEDA. Stuff item Menu Text"
^XMB(3.9,145956,2,1327,0)="""RTN"",""TIUFLF4"",97,0)"
^XMB(3.9,145956,2,1328,0)=" ; Requires PFILEDA = 8925.1 IFN of parent of FILEDA."
^XMB(3.9,145956,2,1329,0)="""RTN"",""TIUFLF4"",98,0)"
^XMB(3.9,145956,2,1330,0)=" ; Requires FILEDA, Requires NODE0 = ^TIU(8925.1,FILEDA,0)"
^XMB(3.9,145956,2,1331,0)="""RTN"",""TIUFLF4"",99,0)"
^XMB(3.9,145956,2,1332,0)=" ; Returns TENDA = 10 node DA of new item."
^XMB(3.9,145956,2,1333,0)="""RTN"",""TIUFLF4"",100,0)"
^XMB(3.9,145956,2,1334,0)=" ; Returns TENDA="""" if fails lookup.  Screen on fld 10, subfld .01"
^XMB(3.9,145956,2,1335,0)="""RTN"",""TIUFLF4"",101,0)"
^XMB(3.9,145956,2,1336,0)=" ;prevents lookup failure due to duplicate names by allowing only"
^XMB(3.9,145956,2,1337,0)="""RTN"",""TIUFLF4"",102,0)"
^XMB(3.9,145956,2,1338,0)=" ;FILEDA to pass screen."
^XMB(3.9,145956,2,1339,0)="""RTN"",""TIUFLF4"",103,0)"
^XMB(3.9,145956,2,1340,0)=" ;Should Lock PFILEDA before calling ADDTEN."
^XMB(3.9,145956,2,1341,0)="""RTN"",""TIUFLF4"",104,0)"
^XMB(3.9,145956,2,1342,0)=" N X,Y,DIE,DR,NAME,DA,DIC,DLAYGO,TIUFISCR,MSG,DUPITEM"
^XMB(3.9,145956,2,1343,0)="""RTN"",""TIUFLF4"",105,0)"
^XMB(3.9,145956,2,1344,0)=" S TENDA="""""
^XMB(3.9,145956,2,1345,0)="""RTN"",""TIUFLF4"",106,0)"
^XMB(3.9,145956,2,1346,0)=" I ('$G(PFILEDA))!('$G(FILEDA)) G ADDTX"
^XMB(3.9,145956,2,1347,0)="""RTN"",""TIUFLF4"",107,0)"
^XMB(3.9,145956,2,1348,0)=" S NAME=$P(NODE0,U)"
^XMB(3.9,145956,2,1349,0)="""RTN"",""TIUFLF4"",108,0)"
^XMB(3.9,145956,2,1350,0)=" I '$D(TIUFTLST) S DUPITEM=0,DUPITEM=$$DUPITEM^TIUFLF7(NAME,PFILEDA) I DUPITEM S MSG="" Can't add Item; Parent already has Item with the same Name"" W !!,MSG,! G ADDTX ; possibly needed when called from TIU rather than from TIUF."
^XMB(3.9,145956,2,1351,0)="""RTN"",""TIUFLF4"",109,0)"
^XMB(3.9,145956,2,1352,0)=" S X=""""""""_NAME_"""""""""
^XMB(3.9,145956,2,1353,0)="""RTN"",""TIUFLF4"",110,0)"
^XMB(3.9,145956,2,1354,0)=" S DA(1)=PFILEDA,DLAYGO=8925.1"
^XMB(3.9,145956,2,1355,0)="""RTN"",""TIUFLF4"",111,0)"
^XMB(3.9,145956,2,1356,0)=" S TIUFISCR=FILEDA ; activates screen on fld 10, Subfld .01 in DD"
^XMB(3.9,145956,2,1357,0)="""RTN"",""TIUFLF4"",112,0)"
^XMB(3.9,145956,2,1358,0)=" S DIC=""^TIU(8925.1,DA(1),10,"",DIC(0)=""L"",DIC(""P"")=$P(^DD(8925.1,10,0),U,2)"
^XMB(3.9,145956,2,1359,0)="""RTN"",""TIUFLF4"",113,0)"
^XMB(3.9,145956,2,1360,0)=" D ^DIC S TENDA=+Y I Y=-1 S TENDA="""" G ADDTX"
^XMB(3.9,145956,2,1361,0)="""RTN"",""TIUFLF4"",114,0)"
^XMB(3.9,145956,2,1362,0)=" K DIC"
^XMB(3.9,145956,2,1363,0)="""RTN"",""TIUFLF4"",115,0)"
^XMB(3.9,145956,2,1364,0)=" S DA=TENDA,DA(1)=PFILEDA D MTXTCHEC^TIUFT1(.DA,FILEDA,1)"
^XMB(3.9,145956,2,1365,0)="""RTN"",""TIUFLF4"",116,0)"
^XMB(3.9,145956,2,1366,0)="ADDTX Q"
^XMB(3.9,145956,2,1367,0)="""RTN"",""TIUFLF4"",117,0)"
^XMB(3.9,145956,2,1368,0)=" ;"
^XMB(3.9,145956,2,1369,0)="""RTN"",""TIUSRVT3"")"
^XMB(3.9,145956,2,1370,0)="0^7^B17514400"
^XMB(3.9,145956,2,1371,0)="""RTN"",""TIUSRVT3"",1,0)"
^XMB(3.9,145956,2,1372,0)="TIUSRVT3 ; SLC/PKS Remove a user's non-shared Templates. ; [6/26/01 9:17am]"
^XMB(3.9,145956,2,1373,0)="""RTN"",""TIUSRVT3"",2,0)"
^XMB(3.9,145956,2,1374,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**110**;Jun 20, 1997;Build 0"
^XMB(3.9,145956,2,1375,0)="""RTN"",""TIUSRVT3"",3,0)"
^XMB(3.9,145956,2,1376,0)=" ;"
^XMB(3.9,145956,2,1377,0)="""RTN"",""TIUSRVT3"",4,0)"
^XMB(3.9,145956,2,1378,0)=" ; Variables used herein:"
^XMB(3.9,145956,2,1379,0)="""RTN"",""TIUSRVT3"",5,0)"
^XMB(3.9,145956,2,1380,0)=" ;"
^XMB(3.9,145956,2,1381,0)="""RTN"",""TIUSRVT3"",6,0)"
^XMB(3.9,145956,2,1382,0)=" ;    DIR     = FM call varible."
^XMB(3.9,145956,2,1383,0)="""RTN"",""TIUSRVT3"",7,0)"
^XMB(3.9,145956,2,1384,0)=" ;    TIUARY  = Array holder."
^XMB(3.9,145956,2,1385,0)="""RTN"",""TIUSRVT3"",8,0)"
^XMB(3.9,145956,2,1386,0)=" ;    TIUCNT  = Returned array counter."
^XMB(3.9,145956,2,1387,0)="""RTN"",""TIUSRVT3"",9,0)"
^XMB(3.9,145956,2,1388,0)=" ;    TIUGET  = Holder for returned array $O command."
^XMB(3.9,145956,2,1389,0)="""RTN"",""TIUSRVT3"",10,0)"
^XMB(3.9,145956,2,1390,0)=" ;    TIUIDX  = X-ref holder."
^XMB(3.9,145956,2,1391,0)="""RTN"",""TIUSRVT3"",11,0)"
^XMB(3.9,145956,2,1392,0)=" ;    TIUIEN  = Template IEN holder."
^XMB(3.9,145956,2,1393,0)="""RTN"",""TIUSRVT3"",12,0)"
^XMB(3.9,145956,2,1394,0)=" ;    TIUNM   = Holder variable for name of user."
^XMB(3.9,145956,2,1395,0)="""RTN"",""TIUSRVT3"",13,0)"
^XMB(3.9,145956,2,1396,0)=" ;    TIUNUM  = Loop counter from this routine."
^XMB(3.9,145956,2,1397,0)="""RTN"",""TIUSRVT3"",14,0)"
^XMB(3.9,145956,2,1398,0)=" ;    TIUPAR  = Current setting of auto-cleanup parameter.  "
^XMB(3.9,145956,2,1399,0)="""RTN"",""TIUSRVT3"",15,0)"
^XMB(3.9,145956,2,1400,0)=" ;    TIURARY = Returned array; zero node will contain user's DUZ and"
^XMB(3.9,145956,2,1401,0)="""RTN"",""TIUSRVT3"",16,0)"
^XMB(3.9,145956,2,1402,0)=" ;              AROOT IEN (if any) or error message (RPC use only)."
^XMB(3.9,145956,2,1403,0)="""RTN"",""TIUSRVT3"",17,0)"
^XMB(3.9,145956,2,1404,0)=" ;    TIUSR   = DUZ of user to process."
^XMB(3.9,145956,2,1405,0)="""RTN"",""TIUSRVT3"",18,0)"
^XMB(3.9,145956,2,1406,0)=" ;    TIUTMP  = Call return array values holder."
^XMB(3.9,145956,2,1407,0)="""RTN"",""TIUSRVT3"",19,0)"
^XMB(3.9,145956,2,1408,0)=" ;    TIUTPLT = Template IEN."
^XMB(3.9,145956,2,1409,0)="""RTN"",""TIUSRVT3"",20,0)"
^XMB(3.9,145956,2,1410,0)=" ;    X,Y     = Variables for FM call."
^XMB(3.9,145956,2,1411,0)="""RTN"",""TIUSRVT3"",21,0)"
^XMB(3.9,145956,2,1412,0)=" ;            "
^XMB(3.9,145956,2,1413,0)="""RTN"",""TIUSRVT3"",22,0)"
^XMB(3.9,145956,2,1414,0)=" Q"
^XMB(3.9,145956,2,1415,0)="""RTN"",""TIUSRVT3"",23,0)"
^XMB(3.9,145956,2,1416,0)=" ;"
^XMB(3.9,145956,2,1417,0)="""RTN"",""TIUSRVT3"",24,0)"
^XMB(3.9,145956,2,1418,0)="SELUSR ; Call here for manual selection of TIUSR from NEW PERSON file."
^XMB(3.9,145956,2,1419,0)="""RTN"",""TIUSRVT3"",25,0)"
^XMB(3.9,145956,2,1420,0)=" ;"
^XMB(3.9,145956,2,1421,0)="""RTN"",""TIUSRVT3"",26,0)"
^XMB(3.9,145956,2,1422,0)=" N DIR,TIUCNT,TIUGET,TIUIDX,TIUNM,TIUNUM,TIUTPLT,TIURARY,TIUSR,X,Y"
^XMB(3.9,145956,2,1423,0)="""RTN"",""TIUSRVT3"",27,0)"
^XMB(3.9,145956,2,1424,0)=" ;"
^XMB(3.9,145956,2,1425,0)="""RTN"",""TIUSRVT3"",28,0)"
^XMB(3.9,145956,2,1426,0)=" ; Get input for user:"
^XMB(3.9,145956,2,1427,0)="""RTN"",""TIUSRVT3"",29,0)"
^XMB(3.9,145956,2,1428,0)=" S TIUSR=""""          ; Default."
^XMB(3.9,145956,2,1429,0)="""RTN"",""TIUSRVT3"",30,0)"
^XMB(3.9,145956,2,1430,0)=" S DIR(0)=""PAO^200,:AEMNQ"""
^XMB(3.9,145956,2,1431,0)="""RTN"",""TIUSRVT3"",31,0)"
^XMB(3.9,145956,2,1432,0)=" S DIR(""A"")=""  Enter/select user for whom templates will be deleted: """
^XMB(3.9,145956,2,1433,0)="""RTN"",""TIUSRVT3"",32,0)"
^XMB(3.9,145956,2,1434,0)=" S DIR(""?"")=""Specify user for template cleanup."""
^XMB(3.9,145956,2,1435,0)="""RTN"",""TIUSRVT3"",33,0)"
^XMB(3.9,145956,2,1436,0)=" D ^DIR"
^XMB(3.9,145956,2,1437,0)="""RTN"",""TIUSRVT3"",34,0)"
^XMB(3.9,145956,2,1438,0)=" S TIUSR=Y"
^XMB(3.9,145956,2,1439,0)="""RTN"",""TIUSRVT3"",35,0)"
^XMB(3.9,145956,2,1440,0)=" K DIR,X,Y                             ; Clean up from FM call."
^XMB(3.9,145956,2,1441,0)="""RTN"",""TIUSRVT3"",36,0)"
^XMB(3.9,145956,2,1442,0)=" I TIUSR<1 S TIUSR="""" Q                ; No acceptable entry."
^XMB(3.9,145956,2,1443,0)="""RTN"",""TIUSRVT3"",37,0)"
^XMB(3.9,145956,2,1444,0)=" S TIUSR=+TIUSR                        ; Selected user's DUZ."
^XMB(3.9,145956,2,1445,0)="""RTN"",""TIUSRVT3"",38,0)"
^XMB(3.9,145956,2,1446,0)=" I TIUSR="""" Q        ; Punt here if there's a problem."
^XMB(3.9,145956,2,1447,0)="""RTN"",""TIUSRVT3"",39,0)"
^XMB(3.9,145956,2,1448,0)=" ;"
^XMB(3.9,145956,2,1449,0)="""RTN"",""TIUSRVT3"",40,0)"
^XMB(3.9,145956,2,1450,0)=" ; Confirm before deletion:"
^XMB(3.9,145956,2,1451,0)="""RTN"",""TIUSRVT3"",41,0)"
^XMB(3.9,145956,2,1452,0)=" S TIUNM=$P($G(^VA(200,TIUSR,0)),U,1)"
^XMB(3.9,145956,2,1453,0)="""RTN"",""TIUSRVT3"",42,0)"
^XMB(3.9,145956,2,1454,0)=" S DIR(""T"")=120  ; Two minute maximum timeout for response."
^XMB(3.9,145956,2,1455,0)="""RTN"",""TIUSRVT3"",43,0)"
^XMB(3.9,145956,2,1456,0)=" S DIR(""A"")=""   Delete all non-shared templates for user ""_TIUNM_"" (Y/N)"""
^XMB(3.9,145956,2,1457,0)="""RTN"",""TIUSRVT3"",44,0)"
^XMB(3.9,145956,2,1458,0)=" S DIR(""?"")=""   Non-shared templates for this user will be permanently lost..."""
^XMB(3.9,145956,2,1459,0)="""RTN"",""TIUSRVT3"",45,0)"
^XMB(3.9,145956,2,1460,0)=" S DIR(""B"")=""NO"" ; Default. "
^XMB(3.9,145956,2,1461,0)="""RTN"",""TIUSRVT3"",46,0)"
^XMB(3.9,145956,2,1462,0)=" ;"
^XMB(3.9,145956,2,1463,0)="""RTN"",""TIUSRVT3"",47,0)"
^XMB(3.9,145956,2,1464,0)=" ; Define DIR input requirements:"
^XMB(3.9,145956,2,1465,0)="""RTN"",""TIUSRVT3"",48,0)"
^XMB(3.9,145956,2,1466,0)=" S DIR(0)=""YO^1:2:0"""
^XMB(3.9,145956,2,1467,0)="""RTN"",""TIUSRVT3"",49,0)"
^XMB(3.9,145956,2,1468,0)=" ;"
^XMB(3.9,145956,2,1469,0)="""RTN"",""TIUSRVT3"",50,0)"
^XMB(3.9,145956,2,1470,0)=" ; Call DIR for user choice:"
^XMB(3.9,145956,2,1471,0)="""RTN"",""TIUSRVT3"",51,0)"
^XMB(3.9,145956,2,1472,0)=" W !! ; Spacing for screen display."
^XMB(3.9,145956,2,1473,0)="""RTN"",""TIUSRVT3"",52,0)"
^XMB(3.9,145956,2,1474,0)=" D ^DIR"
^XMB(3.9,145956,2,1475,0)="""RTN"",""TIUSRVT3"",53,0)"
^XMB(3.9,145956,2,1476,0)=" ;"
^XMB(3.9,145956,2,1477,0)="""RTN"",""TIUSRVT3"",54,0)"
^XMB(3.9,145956,2,1478,0)=" ; Check user response:"
^XMB(3.9,145956,2,1479,0)="""RTN"",""TIUSRVT3"",55,0)"
^XMB(3.9,145956,2,1480,0)=" I '$L($G(Y)) Q                        ; Skip if Y isn't assigned."
^XMB(3.9,145956,2,1481,0)="""RTN"",""TIUSRVT3"",56,0)"
^XMB(3.9,145956,2,1482,0)=" I Y="""" Q                              ; Skip if Y is null."
^XMB(3.9,145956,2,1483,0)="""RTN"",""TIUSRVT3"",57,0)"
^XMB(3.9,145956,2,1484,0)=" I Y=""^"" Q                             ; Skip if Y is ""^"" character."
^XMB(3.9,145956,2,1485,0)="""RTN"",""TIUSRVT3"",58,0)"
^XMB(3.9,145956,2,1486,0)=" I Y<1 Q                               ; Skip if Y is less than one."
^XMB(3.9,145956,2,1487,0)="""RTN"",""TIUSRVT3"",59,0)"
^XMB(3.9,145956,2,1488,0)=" I Y>2 Q                               ; ""No"" choice."
^XMB(3.9,145956,2,1489,0)="""RTN"",""TIUSRVT3"",60,0)"
^XMB(3.9,145956,2,1490,0)=" K DIR,X,Y                             ; Clean up from FM call."
^XMB(3.9,145956,2,1491,0)="""RTN"",""TIUSRVT3"",61,0)"
^XMB(3.9,145956,2,1492,0)=" ;"
^XMB(3.9,145956,2,1493,0)="""RTN"",""TIUSRVT3"",62,0)"
^XMB(3.9,145956,2,1494,0)=" ; Proceed with clean up:"
^XMB(3.9,145956,2,1495,0)="""RTN"",""TIUSRVT3"",63,0)"
^XMB(3.9,145956,2,1496,0)=" D CTRL"
^XMB(3.9,145956,2,1497,0)="""RTN"",""TIUSRVT3"",64,0)"
^XMB(3.9,145956,2,1498,0)=" K TIURARY           ; Array not returned under manual functionality."
^XMB(3.9,145956,2,1499,0)="""RTN"",""TIUSRVT3"",65,0)"
^XMB(3.9,145956,2,1500,0)=" ;"
^XMB(3.9,145956,2,1501,0)="""RTN"",""TIUSRVT3"",66,0)"
^XMB(3.9,145956,2,1502,0)=" Q"
^XMB(3.9,145956,2,1503,0)="""RTN"",""TIUSRVT3"",67,0)"
^XMB(3.9,145956,2,1504,0)=" ;"
^XMB(3.9,145956,2,1505,0)="""RTN"",""TIUSRVT3"",68,0)"
^XMB(3.9,145956,2,1506,0)="KUSER ; Get USER from Kernel - called by option: TIU TEMPLATE USER DELETE."
^XMB(3.9,145956,2,1507,0)="""RTN"",""TIUSRVT3"",69,0)"
^XMB(3.9,145956,2,1508,0)=" ;"
^XMB(3.9,145956,2,1509,0)="""RTN"",""TIUSRVT3"",70,0)"
^XMB(3.9,145956,2,1510,0)=" ; See if this function is ""active"" by checking Parameter:"
^XMB(3.9,145956,2,1511,0)="""RTN"",""TIUSRVT3"",71,0)"
^XMB(3.9,145956,2,1512,0)=" ;"
^XMB(3.9,145956,2,1513,0)="""RTN"",""TIUSRVT3"",72,0)"
^XMB(3.9,145956,2,1514,0)=" N TIUCNT,TIUGET,TIUIDX,TIUNUM,TIUTPLT,TIUPAR,TIURARY,TIUSR"
^XMB(3.9,145956,2,1515,0)="""RTN"",""TIUSRVT3"",73,0)"
^XMB(3.9,145956,2,1516,0)=" S TIUPAR=$$GET^XPAR(""DIV^SYS^PKG"",""TIU TEMPLATE USER AUTO DELETE"",1,""E"")"
^XMB(3.9,145956,2,1517,0)="""RTN"",""TIUSRVT3"",74,0)"
^XMB(3.9,145956,2,1518,0)=" I TIUPAR'=""YES"" Q"
^XMB(3.9,145956,2,1519,0)="""RTN"",""TIUSRVT3"",75,0)"
^XMB(3.9,145956,2,1520,0)=" I TIUPAR="""" Q"
^XMB(3.9,145956,2,1521,0)="""RTN"",""TIUSRVT3"",76,0)"
^XMB(3.9,145956,2,1522,0)=" ;"
^XMB(3.9,145956,2,1523,0)="""RTN"",""TIUSRVT3"",77,0)"
^XMB(3.9,145956,2,1524,0)=" ; Parameter set to activate auto-cleanup - proceed:"
^XMB(3.9,145956,2,1525,0)="""RTN"",""TIUSRVT3"",78,0)"
^XMB(3.9,145956,2,1526,0)=" S TIUSR=$GET(XUIFN) ; Assign TIUSR variable."
^XMB(3.9,145956,2,1527,0)="""RTN"",""TIUSRVT3"",79,0)"
^XMB(3.9,145956,2,1528,0)=" I TIUSR="""" Q        ; Punt here if there's a problem."
^XMB(3.9,145956,2,1529,0)="""RTN"",""TIUSRVT3"",80,0)"
^XMB(3.9,145956,2,1530,0)=" D CTRL"
^XMB(3.9,145956,2,1531,0)="""RTN"",""TIUSRVT3"",81,0)"
^XMB(3.9,145956,2,1532,0)=" K TIURARY           ; Array not returned when triggered by Kernel."
^XMB(3.9,145956,2,1533,0)="""RTN"",""TIUSRVT3"",82,0)"
^XMB(3.9,145956,2,1534,0)=" ;"
^XMB(3.9,145956,2,1535,0)="""RTN"",""TIUSRVT3"",83,0)"
^XMB(3.9,145956,2,1536,0)=" Q"
^XMB(3.9,145956,2,1537,0)="""RTN"",""TIUSRVT3"",84,0)"
^XMB(3.9,145956,2,1538,0)=" ;"
^XMB(3.9,145956,2,1539,0)="""RTN"",""TIUSRVT3"",85,0)"
^XMB(3.9,145956,2,1540,0)="CLEAN(TIUSR,TIURARY) ; Call here as an RPC: Dump templates for one user."
^XMB(3.9,145956,2,1541,0)="""RTN"",""TIUSRVT3"",86,0)"
^XMB(3.9,145956,2,1542,0)=" ;"
^XMB(3.9,145956,2,1543,0)="""RTN"",""TIUSRVT3"",87,0)"
^XMB(3.9,145956,2,1544,0)=" N TIUCNT,TIUGET,TIUIDX,TIUNUM,TIUTPLT"
^XMB(3.9,145956,2,1545,0)="""RTN"",""TIUSRVT3"",88,0)"
^XMB(3.9,145956,2,1546,0)=" I 'TIUSR>0 S TIURARY(0)=""No user DUZ passed."" Q"
^XMB(3.9,145956,2,1547,0)="""RTN"",""TIUSRVT3"",89,0)"
^XMB(3.9,145956,2,1548,0)=" ;"
^XMB(3.9,145956,2,1549,0)="""RTN"",""TIUSRVT3"",90,0)"
^XMB(3.9,145956,2,1550,0)="CTRL ; Main control code for actual cleanup process."
^XMB(3.9,145956,2,1551,0)="""RTN"",""TIUSRVT3"",91,0)"
^XMB(3.9,145956,2,1552,0)=" ;"
^XMB(3.9,145956,2,1553,0)="""RTN"",""TIUSRVT3"",92,0)"
^XMB(3.9,145956,2,1554,0)=" S TIUCNT=0"
^XMB(3.9,145956,2,1555,0)="""RTN"",""TIUSRVT3"",93,0)"
^XMB(3.9,145956,2,1556,0)=" ;"
^XMB(3.9,145956,2,1557,0)="""RTN"",""TIUSRVT3"",94,0)"
^XMB(3.9,145956,2,1558,0)=" ; See if there is an AROOT x-ref entry for this user:"
^XMB(3.9,145956,2,1559,0)="""RTN"",""TIUSRVT3"",95,0)"
^XMB(3.9,145956,2,1560,0)=" I '$D(^TIU(8927,""AROOT"",TIUSR)) S TIURARY(0)=""No AROOT record."" Q"
^XMB(3.9,145956,2,1561,0)="""RTN"",""TIUSRVT3"",96,0)"
^XMB(3.9,145956,2,1562,0)=" ;"
^XMB(3.9,145956,2,1563,0)="""RTN"",""TIUSRVT3"",97,0)"
^XMB(3.9,145956,2,1564,0)=" ; Get parent record for user's templates:"
^XMB(3.9,145956,2,1565,0)="""RTN"",""TIUSRVT3"",98,0)"
^XMB(3.9,145956,2,1566,0)=" S TIUTPLT=0"
^XMB(3.9,145956,2,1567,0)="""RTN"",""TIUSRVT3"",99,0)"
^XMB(3.9,145956,2,1568,0)=" F  D  Q:'TIUTPLT"
^XMB(3.9,145956,2,1569,0)="""RTN"",""TIUSRVT3"",100,0)"
^XMB(3.9,145956,2,1570,0)=" .S TIUTPLT=$O(^TIU(8927,""AROOT"",TIUSR,TIUTPLT))"
^XMB(3.9,145956,2,1571,0)="""RTN"",""TIUSRVT3"",101,0)"
^XMB(3.9,145956,2,1572,0)=" .I 'TIUTPLT Q"
^XMB(3.9,145956,2,1573,0)="""RTN"",""TIUSRVT3"",102,0)"
^XMB(3.9,145956,2,1574,0)=" .;"
^XMB(3.9,145956,2,1575,0)="""RTN"",""TIUSRVT3"",103,0)"
^XMB(3.9,145956,2,1576,0)=" .; Compile an array of applicable templates:"
^XMB(3.9,145956,2,1577,0)="""RTN"",""TIUSRVT3"",104,0)"
^XMB(3.9,145956,2,1578,0)=" .D DEL(TIUTPLT)"
^XMB(3.9,145956,2,1579,0)="""RTN"",""TIUSRVT3"",105,0)"
^XMB(3.9,145956,2,1580,0)=" ;"
^XMB(3.9,145956,2,1581,0)="""RTN"",""TIUSRVT3"",106,0)"
^XMB(3.9,145956,2,1582,0)=" Q"
^XMB(3.9,145956,2,1583,0)="""RTN"",""TIUSRVT3"",107,0)"
^XMB(3.9,145956,2,1584,0)=" ;"
^XMB(3.9,145956,2,1585,0)="""RTN"",""TIUSRVT3"",108,0)"
^XMB(3.9,145956,2,1586,0)="DEL(TIUIEN) ; Pass root node of AROOT x-ref of <^TIU(8927,> file."
^XMB(3.9,145956,2,1587,0)="""RTN"",""TIUSRVT3"",109,0)"
^XMB(3.9,145956,2,1588,0)=" ;"
^XMB(3.9,145956,2,1589,0)="""RTN"",""TIUSRVT3"",110,0)"
^XMB(3.9,145956,2,1590,0)=" N TIUARY,TIUTMP"
^XMB(3.9,145956,2,1591,0)="""RTN"",""TIUSRVT3"",111,0)"
^XMB(3.9,145956,2,1592,0)=" ;"
^XMB(3.9,145956,2,1593,0)="""RTN"",""TIUSRVT3"",112,0)"
^XMB(3.9,145956,2,1594,0)=" S TIURARY(TIUCNT)=TIUSR_U_TIUIEN ; 0-node: ""UserDUZ^ARootIEN"" format."
^XMB(3.9,145956,2,1595,0)="""RTN"",""TIUSRVT3"",113,0)"
^XMB(3.9,145956,2,1596,0)=" D BLD(TIUIEN,.TIUARY)            ; Recursive array builder."
^XMB(3.9,145956,2,1597,0)="""RTN"",""TIUSRVT3"",114,0)"
^XMB(3.9,145956,2,1598,0)=" ;"
^XMB(3.9,145956,2,1599,0)="""RTN"",""TIUSRVT3"",115,0)"
^XMB(3.9,145956,2,1600,0)=" ; Create or add to return array:"
^XMB(3.9,145956,2,1601,0)="""RTN"",""TIUSRVT3"",116,0)"
^XMB(3.9,145956,2,1602,0)=" S (TIUGET,TIUNUM)=0"
^XMB(3.9,145956,2,1603,0)="""RTN"",""TIUSRVT3"",117,0)"
^XMB(3.9,145956,2,1604,0)=" F  D  Q:'TIUGET"
^XMB(3.9,145956,2,1605,0)="""RTN"",""TIUSRVT3"",118,0)"
^XMB(3.9,145956,2,1606,0)=" .S TIUNUM=TIUNUM+1"
^XMB(3.9,145956,2,1607,0)="""RTN"",""TIUSRVT3"",119,0)"
^XMB(3.9,145956,2,1608,0)=" .S TIUGET=$G(TIUARY(TIUNUM))"
^XMB(3.9,145956,2,1609,0)="""RTN"",""TIUSRVT3"",120,0)"
^XMB(3.9,145956,2,1610,0)=" .I 'TIUGET Q"
^XMB(3.9,145956,2,1611,0)="""RTN"",""TIUSRVT3"",121,0)"
^XMB(3.9,145956,2,1612,0)=" .S TIUCNT=TIUCNT+1"
^XMB(3.9,145956,2,1613,0)="""RTN"",""TIUSRVT3"",122,0)"
^XMB(3.9,145956,2,1614,0)=" .S TIURARY(TIUCNT)=TIUGET"
^XMB(3.9,145956,2,1615,0)="""RTN"",""TIUSRVT3"",123,0)"
^XMB(3.9,145956,2,1616,0)=" ;"
^XMB(3.9,145956,2,1617,0)="""RTN"",""TIUSRVT3"",124,0)"
^XMB(3.9,145956,2,1618,0)=" ; Using the array of templates, make call that kills only orphans:"
^XMB(3.9,145956,2,1619,0)="""RTN"",""TIUSRVT3"",125,0)"
^XMB(3.9,145956,2,1620,0)=" D DELETE^TIUSRVT(.TIUTMP,.TIUARY)"
^XMB(3.9,145956,2,1621,0)="""RTN"",""TIUSRVT3"",126,0)"
^XMB(3.9,145956,2,1622,0)=" ;"
^XMB(3.9,145956,2,1623,0)="""RTN"",""TIUSRVT3"",127,0)"
^XMB(3.9,145956,2,1624,0)=" Q"
^XMB(3.9,145956,2,1625,0)="""RTN"",""TIUSRVT3"",128,0)"
^XMB(3.9,145956,2,1626,0)=" ;"
^XMB(3.9,145956,2,1627,0)="""RTN"",""TIUSRVT3"",129,0)"
^XMB(3.9,145956,2,1628,0)="BLD(TIUIEN,TIUARY) ; Recursively build an array of templates."
^XMB(3.9,145956,2,1629,0)="""RTN"",""TIUSRVT3"",130,0)"
^XMB(3.9,145956,2,1630,0)=" ;"
^XMB(3.9,145956,2,1631,0)="""RTN"",""TIUSRVT3"",131,0)"
^XMB(3.9,145956,2,1632,0)=" N TIUIDX"
^XMB(3.9,145956,2,1633,0)="""RTN"",""TIUSRVT3"",132,0)"
^XMB(3.9,145956,2,1634,0)=" ;"
^XMB(3.9,145956,2,1635,0)="""RTN"",""TIUSRVT3"",133,0)"
^XMB(3.9,145956,2,1636,0)=" S TIUIDX=$O(TIUARY("" ""),-1)+1"
^XMB(3.9,145956,2,1637,0)="""RTN"",""TIUSRVT3"",134,0)"
^XMB(3.9,145956,2,1638,0)=" S TIUARY(TIUIDX)=TIUIEN"
^XMB(3.9,145956,2,1639,0)="""RTN"",""TIUSRVT3"",135,0)"
^XMB(3.9,145956,2,1640,0)=" S TIUIDX=0"
^XMB(3.9,145956,2,1641,0)="""RTN"",""TIUSRVT3"",136,0)"
^XMB(3.9,145956,2,1642,0)=" F  S TIUIDX=$O(^TIU(8927,TIUIEN,10,TIUIDX))  Q:'TIUIDX  D"
^XMB(3.9,145956,2,1643,0)="""RTN"",""TIUSRVT3"",137,0)"
^XMB(3.9,145956,2,1644,0)=" .D BLD($P(^TIU(8927,TIUIEN,10,TIUIDX,0),U,2),.TIUARY)"
^XMB(3.9,145956,2,1645,0)="""RTN"",""TIUSRVT3"",138,0)"
^XMB(3.9,145956,2,1646,0)=" ;"
^XMB(3.9,145956,2,1647,0)="""RTN"",""TIUSRVT3"",139,0)"
^XMB(3.9,145956,2,1648,0)=" Q"
^XMB(3.9,145956,2,1649,0)="""RTN"",""TIUSRVT3"",140,0)"
^XMB(3.9,145956,2,1650,0)=" ;"
^XMB(3.9,145956,2,1651,0)="""RTN"",""TIUSRVT4"")"
^XMB(3.9,145956,2,1652,0)="0^8^B14271945"
^XMB(3.9,145956,2,1653,0)="""RTN"",""TIUSRVT4"",1,0)"
^XMB(3.9,145956,2,1654,0)="TIUSRVT4 ; SLC/PKS Remove all terminated user Templates. ; [3/15/01 12:15pm]"
^XMB(3.9,145956,2,1655,0)="""RTN"",""TIUSRVT4"",2,0)"
^XMB(3.9,145956,2,1656,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**110**;Jun 20, 1997;Build 0"
^XMB(3.9,145956,2,1657,0)="""RTN"",""TIUSRVT4"",3,0)"
^XMB(3.9,145956,2,1658,0)=" ;"
^XMB(3.9,145956,2,1659,0)="""RTN"",""TIUSRVT4"",4,0)"
^XMB(3.9,145956,2,1660,0)=" ; Variables used herein:"
^XMB(3.9,145956,2,1661,0)="""RTN"",""TIUSRVT4"",5,0)"
^XMB(3.9,145956,2,1662,0)=" ;"
^XMB(3.9,145956,2,1663,0)="""RTN"",""TIUSRVT4"",6,0)"
^XMB(3.9,145956,2,1664,0)=" ;     TIUANS  = Result of call to $$VERIF."
^XMB(3.9,145956,2,1665,0)="""RTN"",""TIUSRVT4"",7,0)"
^XMB(3.9,145956,2,1666,0)=" ;     TIUARY  = Array holder."
^XMB(3.9,145956,2,1667,0)="""RTN"",""TIUSRVT4"",8,0)"
^XMB(3.9,145956,2,1668,0)=" ;     TIUCNT  = Counter Variable."
^XMB(3.9,145956,2,1669,0)="""RTN"",""TIUSRVT4"",9,0)"
^XMB(3.9,145956,2,1670,0)=" ;     TIUERR  = Error array for call return."
^XMB(3.9,145956,2,1671,0)="""RTN"",""TIUSRVT4"",10,0)"
^XMB(3.9,145956,2,1672,0)=" ;     TIUIDX  = X-ref holder."
^XMB(3.9,145956,2,1673,0)="""RTN"",""TIUSRVT4"",11,0)"
^XMB(3.9,145956,2,1674,0)=" ;     TIUIEN  = Template IEN holder."
^XMB(3.9,145956,2,1675,0)="""RTN"",""TIUSRVT4"",12,0)"
^XMB(3.9,145956,2,1676,0)=" ;     TIUNOW  = Current date."
^XMB(3.9,145956,2,1677,0)="""RTN"",""TIUSRVT4"",13,0)"
^XMB(3.9,145956,2,1678,0)=" ;     TIUNUM  = Loop counter."
^XMB(3.9,145956,2,1679,0)="""RTN"",""TIUSRVT4"",14,0)"
^XMB(3.9,145956,2,1680,0)=" ;     TIUSR   = Terminated user (DUZ)."
^XMB(3.9,145956,2,1681,0)="""RTN"",""TIUSRVT4"",15,0)"
^XMB(3.9,145956,2,1682,0)=" ;     TIUSTAT = Status of user."
^XMB(3.9,145956,2,1683,0)="""RTN"",""TIUSRVT4"",16,0)"
^XMB(3.9,145956,2,1684,0)=" ;     TIUTMP  = Call return array value holder."
^XMB(3.9,145956,2,1685,0)="""RTN"",""TIUSRVT4"",17,0)"
^XMB(3.9,145956,2,1686,0)=" ;     TIUTPLT = Template IEN."
^XMB(3.9,145956,2,1687,0)="""RTN"",""TIUSRVT4"",18,0)"
^XMB(3.9,145956,2,1688,0)=" ;            "
^XMB(3.9,145956,2,1689,0)="""RTN"",""TIUSRVT4"",19,0)"
^XMB(3.9,145956,2,1690,0)=" Q"
^XMB(3.9,145956,2,1691,0)="""RTN"",""TIUSRVT4"",20,0)"
^XMB(3.9,145956,2,1692,0)=" ;"
^XMB(3.9,145956,2,1693,0)="""RTN"",""TIUSRVT4"",21,0)"
^XMB(3.9,145956,2,1694,0)="CTRL ; Main control section."
^XMB(3.9,145956,2,1695,0)="""RTN"",""TIUSRVT4"",22,0)"
^XMB(3.9,145956,2,1696,0)=" ;"
^XMB(3.9,145956,2,1697,0)="""RTN"",""TIUSRVT4"",23,0)"
^XMB(3.9,145956,2,1698,0)=" N TIUANS,TIUCNT,TIUERR,TIUIDX,TIUNOW,TIUSR,TIUSTAT,TIUTPLT"
^XMB(3.9,145956,2,1699,0)="""RTN"",""TIUSRVT4"",24,0)"
^XMB(3.9,145956,2,1700,0)=" ;"
^XMB(3.9,145956,2,1701,0)="""RTN"",""TIUSRVT4"",25,0)"
^XMB(3.9,145956,2,1702,0)=" S TIUANS=$$VERIF ; Confirm before deleting."
^XMB(3.9,145956,2,1703,0)="""RTN"",""TIUSRVT4"",26,0)"
^XMB(3.9,145956,2,1704,0)=" I 'TIUANS Q      ; User failed to confirm - quit."
^XMB(3.9,145956,2,1705,0)="""RTN"",""TIUSRVT4"",27,0)"
^XMB(3.9,145956,2,1706,0)=" ;"
^XMB(3.9,145956,2,1707,0)="""RTN"",""TIUSRVT4"",28,0)"
^XMB(3.9,145956,2,1708,0)=" D EACH ; Call to process template cleanup."
^XMB(3.9,145956,2,1709,0)="""RTN"",""TIUSRVT4"",29,0)"
^XMB(3.9,145956,2,1710,0)=" ;"
^XMB(3.9,145956,2,1711,0)="""RTN"",""TIUSRVT4"",30,0)"
^XMB(3.9,145956,2,1712,0)=" Q"
^XMB(3.9,145956,2,1713,0)="""RTN"",""TIUSRVT4"",31,0)"
^XMB(3.9,145956,2,1714,0)=" ;"
^XMB(3.9,145956,2,1715,0)="""RTN"",""TIUSRVT4"",32,0)"
^XMB(3.9,145956,2,1716,0)="EACH ; Process template deletion for each user found who has any."
^XMB(3.9,145956,2,1717,0)="""RTN"",""TIUSRVT4"",33,0)"
^XMB(3.9,145956,2,1718,0)=" ;"
^XMB(3.9,145956,2,1719,0)="""RTN"",""TIUSRVT4"",34,0)"
^XMB(3.9,145956,2,1720,0)=" ; Get current date information:"
^XMB(3.9,145956,2,1721,0)="""RTN"",""TIUSRVT4"",35,0)"
^XMB(3.9,145956,2,1722,0)=" D NOW^%DTC"
^XMB(3.9,145956,2,1723,0)="""RTN"",""TIUSRVT4"",36,0)"
^XMB(3.9,145956,2,1724,0)=" S TIUNOW=X"
^XMB(3.9,145956,2,1725,0)="""RTN"",""TIUSRVT4"",37,0)"
^XMB(3.9,145956,2,1726,0)=" K X"
^XMB(3.9,145956,2,1727,0)="""RTN"",""TIUSRVT4"",38,0)"
^XMB(3.9,145956,2,1728,0)=" ;"
^XMB(3.9,145956,2,1729,0)="""RTN"",""TIUSRVT4"",39,0)"
^XMB(3.9,145956,2,1730,0)=" ; Retrieve each user in ^TIU(8927 file:"
^XMB(3.9,145956,2,1731,0)="""RTN"",""TIUSRVT4"",40,0)"
^XMB(3.9,145956,2,1732,0)=" S TIUSR=0"
^XMB(3.9,145956,2,1733,0)="""RTN"",""TIUSRVT4"",41,0)"
^XMB(3.9,145956,2,1734,0)=" F  D  Q:'TIUSR"
^XMB(3.9,145956,2,1735,0)="""RTN"",""TIUSRVT4"",42,0)"
^XMB(3.9,145956,2,1736,0)=" .S TIUSR=$O(^TIU(8927,""AROOT"",TIUSR))"
^XMB(3.9,145956,2,1737,0)="""RTN"",""TIUSRVT4"",43,0)"
^XMB(3.9,145956,2,1738,0)=" .I 'TIUSR Q"
^XMB(3.9,145956,2,1739,0)="""RTN"",""TIUSRVT4"",44,0)"
^XMB(3.9,145956,2,1740,0)=" .;"
^XMB(3.9,145956,2,1741,0)="""RTN"",""TIUSRVT4"",45,0)"
^XMB(3.9,145956,2,1742,0)=" .; Check user's status - look for terminated users:"
^XMB(3.9,145956,2,1743,0)="""RTN"",""TIUSRVT4"",46,0)"
^XMB(3.9,145956,2,1744,0)=" .I '$D(^VA(200,TIUSR,0)) Q        ; No user record."
^XMB(3.9,145956,2,1745,0)="""RTN"",""TIUSRVT4"",47,0)"
^XMB(3.9,145956,2,1746,0)=" .I '$L($P($G(^VA(200,TIUSR,0)),""^"",1)) Q  ; Invalid user data."
^XMB(3.9,145956,2,1747,0)="""RTN"",""TIUSRVT4"",48,0)"
^XMB(3.9,145956,2,1748,0)=" .S TIUSTAT=$$GET1^DIQ(200,TIUSR,9.2,""I"",,.TIUERR) ; Termination date?"
^XMB(3.9,145956,2,1749,0)="""RTN"",""TIUSRVT4"",49,0)"
^XMB(3.9,145956,2,1750,0)=" .I 'TIUSTAT Q                     ; Active user."
^XMB(3.9,145956,2,1751,0)="""RTN"",""TIUSRVT4"",50,0)"
^XMB(3.9,145956,2,1752,0)=" .I TIUSTAT>TIUNOW Q               ; User terminated on a future date."
^XMB(3.9,145956,2,1753,0)="""RTN"",""TIUSRVT4"",51,0)"
^XMB(3.9,145956,2,1754,0)=" .;"
^XMB(3.9,145956,2,1755,0)="""RTN"",""TIUSRVT4"",52,0)"
^XMB(3.9,145956,2,1756,0)=" .; User terminated, effective today or earlier, so proceed:"
^XMB(3.9,145956,2,1757,0)="""RTN"",""TIUSRVT4"",53,0)"
^XMB(3.9,145956,2,1758,0)=" .; Find AROOT x-ref record, if any:"
^XMB(3.9,145956,2,1759,0)="""RTN"",""TIUSRVT4"",54,0)"
^XMB(3.9,145956,2,1760,0)=" .S TIUTPLT=0"
^XMB(3.9,145956,2,1761,0)="""RTN"",""TIUSRVT4"",55,0)"
^XMB(3.9,145956,2,1762,0)=" .F  D  Q:'TIUTPLT"
^XMB(3.9,145956,2,1763,0)="""RTN"",""TIUSRVT4"",56,0)"
^XMB(3.9,145956,2,1764,0)=" ..S TIUTPLT=$O(^TIU(8927,""AROOT"",TIUSR,TIUTPLT))"
^XMB(3.9,145956,2,1765,0)="""RTN"",""TIUSRVT4"",57,0)"
^XMB(3.9,145956,2,1766,0)=" ..I 'TIUTPLT Q"
^XMB(3.9,145956,2,1767,0)="""RTN"",""TIUSRVT4"",58,0)"
^XMB(3.9,145956,2,1768,0)=" ..;"
^XMB(3.9,145956,2,1769,0)="""RTN"",""TIUSRVT4"",59,0)"
^XMB(3.9,145956,2,1770,0)=" ..; Get any existing templates, delete them:"
^XMB(3.9,145956,2,1771,0)="""RTN"",""TIUSRVT4"",60,0)"
^XMB(3.9,145956,2,1772,0)=" ..D DEL(TIUTPLT)"
^XMB(3.9,145956,2,1773,0)="""RTN"",""TIUSRVT4"",61,0)"
^XMB(3.9,145956,2,1774,0)=" ;"
^XMB(3.9,145956,2,1775,0)="""RTN"",""TIUSRVT4"",62,0)"
^XMB(3.9,145956,2,1776,0)=" Q"
^XMB(3.9,145956,2,1777,0)="""RTN"",""TIUSRVT4"",63,0)"
^XMB(3.9,145956,2,1778,0)=" ;"
^XMB(3.9,145956,2,1779,0)="""RTN"",""TIUSRVT4"",64,0)"
^XMB(3.9,145956,2,1780,0)="DEL(TIUIEN) ; Pass root node of AROOT x-ref."
^XMB(3.9,145956,2,1781,0)="""RTN"",""TIUSRVT4"",65,0)"
^XMB(3.9,145956,2,1782,0)=" ;"
^XMB(3.9,145956,2,1783,0)="""RTN"",""TIUSRVT4"",66,0)"
^XMB(3.9,145956,2,1784,0)=" N TIUARY,TIUNUM,TIUTMP"
^XMB(3.9,145956,2,1785,0)="""RTN"",""TIUSRVT4"",67,0)"
^XMB(3.9,145956,2,1786,0)=" ;"
^XMB(3.9,145956,2,1787,0)="""RTN"",""TIUSRVT4"",68,0)"
^XMB(3.9,145956,2,1788,0)=" D BLD(TIUIEN,.TIUARY)             ; Recursive call."
^XMB(3.9,145956,2,1789,0)="""RTN"",""TIUSRVT4"",69,0)"
^XMB(3.9,145956,2,1790,0)=" ;"
^XMB(3.9,145956,2,1791,0)="""RTN"",""TIUSRVT4"",70,0)"
^XMB(3.9,145956,2,1792,0)=" D DELETE^TIUSRVT(.TIUTMP,.TIUARY) ; Kill record(s)."
^XMB(3.9,145956,2,1793,0)="""RTN"",""TIUSRVT4"",71,0)"
^XMB(3.9,145956,2,1794,0)=" ;"
^XMB(3.9,145956,2,1795,0)="""RTN"",""TIUSRVT4"",72,0)"
^XMB(3.9,145956,2,1796,0)=" Q"
^XMB(3.9,145956,2,1797,0)="""RTN"",""TIUSRVT4"",73,0)"
^XMB(3.9,145956,2,1798,0)=" ;"
^XMB(3.9,145956,2,1799,0)="""RTN"",""TIUSRVT4"",74,0)"
^XMB(3.9,145956,2,1800,0)="BLD(TIUIEN,TIUARY) ; Build array of templates for user."
^XMB(3.9,145956,2,1801,0)="""RTN"",""TIUSRVT4"",75,0)"
^XMB(3.9,145956,2,1802,0)=" ;"
^XMB(3.9,145956,2,1803,0)="""RTN"",""TIUSRVT4"",76,0)"
^XMB(3.9,145956,2,1804,0)=" N TIUIDX"
^XMB(3.9,145956,2,1805,0)="""RTN"",""TIUSRVT4"",77,0)"
^XMB(3.9,145956,2,1806,0)=" ;"
^XMB(3.9,145956,2,1807,0)="""RTN"",""TIUSRVT4"",78,0)"
^XMB(3.9,145956,2,1808,0)=" S TIUIDX=$O(TIUARY("" ""),-1)+1"
^XMB(3.9,145956,2,1809,0)="""RTN"",""TIUSRVT4"",79,0)"
^XMB(3.9,145956,2,1810,0)=" S TIUARY(TIUIDX)=TIUIEN"
^XMB(3.9,145956,2,1811,0)="""RTN"",""TIUSRVT4"",80,0)"
^XMB(3.9,145956,2,1812,0)=" S TIUIDX=0"
^XMB(3.9,145956,2,1813,0)="""RTN"",""TIUSRVT4"",81,0)"
^XMB(3.9,145956,2,1814,0)=" F  S TIUIDX=$O(^TIU(8927,TIUIEN,10,TIUIDX))  Q:'TIUIDX  D"
^XMB(3.9,145956,2,1815,0)="""RTN"",""TIUSRVT4"",82,0)"
^XMB(3.9,145956,2,1816,0)=" .D BLD($P(^TIU(8927,TIUIEN,10,TIUIDX,0),U,2),.TIUARY)"
^XMB(3.9,145956,2,1817,0)="""RTN"",""TIUSRVT4"",83,0)"
^XMB(3.9,145956,2,1818,0)=" ;"
^XMB(3.9,145956,2,1819,0)="""RTN"",""TIUSRVT4"",84,0)"
^XMB(3.9,145956,2,1820,0)=" Q"
^XMB(3.9,145956,2,1821,0)="""RTN"",""TIUSRVT4"",85,0)"
^XMB(3.9,145956,2,1822,0)=" ;"
^XMB(3.9,145956,2,1823,0)="""RTN"",""TIUSRVT4"",86,0)"
^XMB(3.9,145956,2,1824,0)="PARSET ; Edit parameter for auto-cleanup of templates upon termination."
^XMB(3.9,145956,2,1825,0)="""RTN"",""TIUSRVT4"",87,0)"
^XMB(3.9,145956,2,1826,0)=" ;"
^XMB(3.9,145956,2,1827,0)="""RTN"",""TIUSRVT4"",88,0)"
^XMB(3.9,145956,2,1828,0)=" D EDITPAR^XPAREDIT(""TIU TEMPLATE USER AUTO DELETE"")"
^XMB(3.9,145956,2,1829,0)="""RTN"",""TIUSRVT4"",89,0)"
^XMB(3.9,145956,2,1830,0)=" ;"
^XMB(3.9,145956,2,1831,0)="""RTN"",""TIUSRVT4"",90,0)"
^XMB(3.9,145956,2,1832,0)=" Q"
^XMB(3.9,145956,2,1833,0)="""RTN"",""TIUSRVT4"",91,0)"
^XMB(3.9,145956,2,1834,0)=" ;"
^XMB(3.9,145956,2,1835,0)="""RTN"",""TIUSRVT4"",92,0)"
^XMB(3.9,145956,2,1836,0)="VERIF() ; Verify that user really wants to execute this option:"
^XMB(3.9,145956,2,1837,0)="""RTN"",""TIUSRVT4"",93,0)"
^XMB(3.9,145956,2,1838,0)=" ;"
^XMB(3.9,145956,2,1839,0)="""RTN"",""TIUSRVT4"",94,0)"
^XMB(3.9,145956,2,1840,0)=" N DIR,X,Y       ; DIR variables."
^XMB(3.9,145956,2,1841,0)="""RTN"",""TIUSRVT4"",95,0)"
^XMB(3.9,145956,2,1842,0)=" S DIR(""T"")=120  ; Two minute maximum timeout for response."
^XMB(3.9,145956,2,1843,0)="""RTN"",""TIUSRVT4"",96,0)"
^XMB(3.9,145956,2,1844,0)=" S DIR(""A"")=""   Delete all non-shared templates for all terminated users (Y/N)"""
^XMB(3.9,145956,2,1845,0)="""RTN"",""TIUSRVT4"",97,0)"
^XMB(3.9,145956,2,1846,0)=" S DIR(""?"")=""   Templates for terminated users will be permanently lost..."""
^XMB(3.9,145956,2,1847,0)="""RTN"",""TIUSRVT4"",98,0)"
^XMB(3.9,145956,2,1848,0)=" S DIR(""B"")=""NO"" ; Default. "
^XMB(3.9,145956,2,1849,0)="""RTN"",""TIUSRVT4"",99,0)"
^XMB(3.9,145956,2,1850,0)=" ;"
^XMB(3.9,145956,2,1851,0)="""RTN"",""TIUSRVT4"",100,0)"
^XMB(3.9,145956,2,1852,0)=" ; Define DIR input requirements:"
^XMB(3.9,145956,2,1853,0)="""RTN"",""TIUSRVT4"",101,0)"
^XMB(3.9,145956,2,1854,0)=" S DIR(0)=""YO^1:2:0"""
^XMB(3.9,145956,2,1855,0)="""RTN"",""TIUSRVT4"",102,0)"
^XMB(3.9,145956,2,1856,0)=" ;"
^XMB(3.9,145956,2,1857,0)="""RTN"",""TIUSRVT4"",103,0)"
^XMB(3.9,145956,2,1858,0)=" ; Call DIR for user choice:"
^XMB(3.9,145956,2,1859,0)="""RTN"",""TIUSRVT4"",104,0)"
^XMB(3.9,145956,2,1860,0)=" W !! ; Spacing for screen display."
^XMB(3.9,145956,2,1861,0)="""RTN"",""TIUSRVT4"",105,0)"
^XMB(3.9,145956,2,1862,0)=" D ^DIR"
^XMB(3.9,145956,2,1863,0)="""RTN"",""TIUSRVT4"",106,0)"
^XMB(3.9,145956,2,1864,0)=" ;"
^XMB(3.9,145956,2,1865,0)="""RTN"",""TIUSRVT4"",107,0)"
^XMB(3.9,145956,2,1866,0)=" ; Check user response:"
^XMB(3.9,145956,2,1867,0)="""RTN"",""TIUSRVT4"",108,0)"
^XMB(3.9,145956,2,1868,0)=" I '$L($G(Y)) Q 0                      ; Skip if Y isn't assigned."
^XMB(3.9,145956,2,1869,0)="""RTN"",""TIUSRVT4"",109,0)"
^XMB(3.9,145956,2,1870,0)=" I Y="""" Q 0                            ; Skip if Y is null."
^XMB(3.9,145956,2,1871,0)="""RTN"",""TIUSRVT4"",110,0)"
^XMB(3.9,145956,2,1872,0)=" I Y=""^"" Q 0                           ; Skip if Y is ""^"" character."
^XMB(3.9,145956,2,1873,0)="""RTN"",""TIUSRVT4"",111,0)"
^XMB(3.9,145956,2,1874,0)=" I Y<1 Q 0                             ; Skip if Y is less than one."
^XMB(3.9,145956,2,1875,0)="""RTN"",""TIUSRVT4"",112,0)"
^XMB(3.9,145956,2,1876,0)=" I Y>2 Q 0                             ; ""No"" choice."
^XMB(3.9,145956,2,1877,0)="""RTN"",""TIUSRVT4"",113,0)"
^XMB(3.9,145956,2,1878,0)=" I Y=1 Q 1                             ; ""Yes"" choice."
^XMB(3.9,145956,2,1879,0)="""RTN"",""TIUSRVT4"",114,0)"
^XMB(3.9,145956,2,1880,0)=" ;"
^XMB(3.9,145956,2,1881,0)="""RTN"",""TIUSRVT4"",115,0)"
^XMB(3.9,145956,2,1882,0)=" Q 0                                   ; Default return of ""No."""
^XMB(3.9,145956,2,1883,0)="""RTN"",""TIUSRVT4"",116,0)"
^XMB(3.9,145956,2,1884,0)=" ;"
^XMB(3.9,145956,2,1885,0)="""RTN"",""TIUTIUS"")"
^XMB(3.9,145956,2,1886,0)="0^3^B38618925"
^XMB(3.9,145956,2,1887,0)="""RTN"",""TIUTIUS"",1,0)"
^XMB(3.9,145956,2,1888,0)="TIUTIUS ; MILW/JMC - Functions to search TIU documents; May 24, 2006 ; 2/16/16 1:49pm"
^XMB(3.9,145956,2,1889,0)="""RTN"",""TIUTIUS"",2,0)"
^XMB(3.9,145956,2,1890,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**296,324,346**;JUN 20, 1997;Build 0;Build 13"
^XMB(3.9,145956,2,1891,0)="""RTN"",""TIUTIUS"",3,0)"
^XMB(3.9,145956,2,1892,0)=" ;"
^XMB(3.9,145956,2,1893,0)="""RTN"",""TIUTIUS"",4,0)"
^XMB(3.9,145956,2,1894,0)=" ;"
^XMB(3.9,145956,2,1895,0)="""RTN"",""TIUTIUS"",5,0)"
^XMB(3.9,145956,2,1896,0)="TASK(AUMTDA) ; Task searching of document for specified text"
^XMB(3.9,145956,2,1897,0)="""RTN"",""TIUTIUS"",6,0)"
^XMB(3.9,145956,2,1898,0)=" N AUMTADD,I,ZTDESC,ZTDTH,ZTRTN,ZTIO,ZTSAVE,X,ZTSK"
^XMB(3.9,145956,2,1899,0)="""RTN"",""TIUTIUS"",7,0)"
^XMB(3.9,145956,2,1900,0)=" I $G(AUMTDA)<1 Q"
^XMB(3.9,145956,2,1901,0)="""RTN"",""TIUTIUS"",8,0)"
^XMB(3.9,145956,2,1902,0)=" ;"
^XMB(3.9,145956,2,1903,0)="""RTN"",""TIUTIUS"",9,0)"
^XMB(3.9,145956,2,1904,0)=" ; Check if document is an addendum"
^XMB(3.9,145956,2,1905,0)="""RTN"",""TIUTIUS"",10,0)"
^XMB(3.9,145956,2,1906,0)=" S AUMTADD=+$$ISADDNDM^TIULC1(AUMTDA)"
^XMB(3.9,145956,2,1907,0)="""RTN"",""TIUTIUS"",11,0)"
^XMB(3.9,145956,2,1908,0)=" ;"
^XMB(3.9,145956,2,1909,0)="""RTN"",""TIUTIUS"",12,0)"
^XMB(3.9,145956,2,1910,0)=" ; If original don't check if cosigned and signer different than cosigner - was checked when signed."
^XMB(3.9,145956,2,1911,0)="""RTN"",""TIUTIUS"",13,0)"
^XMB(3.9,145956,2,1912,0)=" F I=0,15 S X(I)=$G(^TIU(8925,AUMTDA,I))"
^XMB(3.9,145956,2,1913,0)="""RTN"",""TIUTIUS"",14,0)"
^XMB(3.9,145956,2,1914,0)=" ;TIU*1*346 Remove this line that prevents alerts from being sent when completed by cosigner"
^XMB(3.9,145956,2,1915,0)="""RTN"",""TIUTIUS"",15,0)"
^XMB(3.9,145956,2,1916,0)=" ;I 'AUMTADD,$P(X(15),""^"",8),$P(X(15),""^"",2),$P(X(15),""^"",8)'=$P(X(15),""^"",2) Q"
^XMB(3.9,145956,2,1917,0)="""RTN"",""TIUTIUS"",16,0)"
^XMB(3.9,145956,2,1918,0)=" ; If addendum and not complete then don't check."
^XMB(3.9,145956,2,1919,0)="""RTN"",""TIUTIUS"",17,0)"
^XMB(3.9,145956,2,1920,0)=" I AUMTADD,$P(X(0),""^"",5)'=7 Q"
^XMB(3.9,145956,2,1921,0)="""RTN"",""TIUTIUS"",18,0)"
^XMB(3.9,145956,2,1922,0)=" ;"
^XMB(3.9,145956,2,1923,0)="""RTN"",""TIUTIUS"",19,0)"
^XMB(3.9,145956,2,1924,0)=" ; TIU*1.0*324 Pass AUMTADD"
^XMB(3.9,145956,2,1925,0)="""RTN"",""TIUTIUS"",20,0)"
^XMB(3.9,145956,2,1926,0)=" S ZTDTH=$H,ZTIO="""",ZTSAVE(""AUMTDA"")="""",ZTSAVE(""AUMTADD"")="""""
^XMB(3.9,145956,2,1927,0)="""RTN"",""TIUTIUS"",21,0)"
^XMB(3.9,145956,2,1928,0)=" S ZTRTN=""DQ^TIUTIUS"",ZTDESC=""Search TIU document for specified text"""
^XMB(3.9,145956,2,1929,0)="""RTN"",""TIUTIUS"",22,0)"
^XMB(3.9,145956,2,1930,0)=" ; TIU 324 TESTING"
^XMB(3.9,145956,2,1931,0)="""RTN"",""TIUTIUS"",23,0)"
^XMB(3.9,145956,2,1932,0)=" D ^%ZTLOAD"
^XMB(3.9,145956,2,1933,0)="""RTN"",""TIUTIUS"",24,0)"
^XMB(3.9,145956,2,1934,0)=" ; TIU*1.0*324 Call in foreground of it failed to queue"
^XMB(3.9,145956,2,1935,0)="""RTN"",""TIUTIUS"",25,0)"
^XMB(3.9,145956,2,1936,0)=" I '$D(ZTSK) D DQ^TIUTIUS"
^XMB(3.9,145956,2,1937,0)="""RTN"",""TIUTIUS"",26,0)"
^XMB(3.9,145956,2,1938,0)=" Q"
^XMB(3.9,145956,2,1939,0)="""RTN"",""TIUTIUS"",27,0)"
^XMB(3.9,145956,2,1940,0)=" ;"
^XMB(3.9,145956,2,1941,0)="""RTN"",""TIUTIUS"",28,0)"
^XMB(3.9,145956,2,1942,0)=" ;"
^XMB(3.9,145956,2,1943,0)="""RTN"",""TIUTIUS"",29,0)"
^XMB(3.9,145956,2,1944,0)="DQ ; Tasked entry point to search TIU document for specified text "
^XMB(3.9,145956,2,1945,0)="""RTN"",""TIUTIUS"",30,0)"
^XMB(3.9,145956,2,1946,0)=" ; that should generate an alert to appropriate CPRS team."
^XMB(3.9,145956,2,1947,0)="""RTN"",""TIUTIUS"",31,0)"
^XMB(3.9,145956,2,1948,0)=" ;"
^XMB(3.9,145956,2,1949,0)="""RTN"",""TIUTIUS"",32,0)"
^XMB(3.9,145956,2,1950,0)=" N AUMTI,AUMTJ,AUMTK,AUMTMSPT,AUMTXT,AUMTVL,AUMTVLS,AUMTXQA,X,X0,X1,Y,AUMTZ,AUMPRT"
^XMB(3.9,145956,2,1951,0)="""RTN"",""TIUTIUS"",33,0)"
^XMB(3.9,145956,2,1952,0)=" ;"
^XMB(3.9,145956,2,1953,0)="""RTN"",""TIUTIUS"",34,0)"
^XMB(3.9,145956,2,1954,0)=" I '$D(^TIU(8925,AUMTDA,0)) Q"
^XMB(3.9,145956,2,1955,0)="""RTN"",""TIUTIUS"",35,0)"
^XMB(3.9,145956,2,1956,0)=" ;"
^XMB(3.9,145956,2,1957,0)="""RTN"",""TIUTIUS"",36,0)"
^XMB(3.9,145956,2,1958,0)=" ; Get visit location"
^XMB(3.9,145956,2,1959,0)="""RTN"",""TIUTIUS"",37,0)"
^XMB(3.9,145956,2,1960,0)=" ; TIU*1.0*324 Get location from parent if an addendum"
^XMB(3.9,145956,2,1961,0)="""RTN"",""TIUTIUS"",38,0)"
^XMB(3.9,145956,2,1962,0)=" I AUMTADD D"
^XMB(3.9,145956,2,1963,0)="""RTN"",""TIUTIUS"",39,0)"
^XMB(3.9,145956,2,1964,0)=" . S AUMTVL=+$P($G(^TIU(8925,AUMTDA,12)),""^"",11)"
^XMB(3.9,145956,2,1965,0)="""RTN"",""TIUTIUS"",40,0)"
^XMB(3.9,145956,2,1966,0)=" . I 'AUMTVL D"
^XMB(3.9,145956,2,1967,0)="""RTN"",""TIUTIUS"",41,0)"
^XMB(3.9,145956,2,1968,0)=" . . S AUMPRT=$P(^TIU(8925,AUMTDA,0),U,6)"
^XMB(3.9,145956,2,1969,0)="""RTN"",""TIUTIUS"",42,0)"
^XMB(3.9,145956,2,1970,0)=" . . S AUMTVL=+$P($G(^TIU(8925,AUMPRT,12)),""^"",11)"
^XMB(3.9,145956,2,1971,0)="""RTN"",""TIUTIUS"",43,0)"
^XMB(3.9,145956,2,1972,0)=" E  S AUMTVL=+$P($G(^TIU(8925,AUMTDA,12)),""^"",11)"
^XMB(3.9,145956,2,1973,0)="""RTN"",""TIUTIUS"",44,0)"
^XMB(3.9,145956,2,1974,0)=" S AUMTVL(0)=$$GET1^DIQ(44,AUMTVL_"","",.01)"
^XMB(3.9,145956,2,1975,0)="""RTN"",""TIUTIUS"",45,0)"
^XMB(3.9,145956,2,1976,0)=" ;"
^XMB(3.9,145956,2,1977,0)="""RTN"",""TIUTIUS"",46,0)"
^XMB(3.9,145956,2,1978,0)=" ; Setup array of text events to search in the document."
^XMB(3.9,145956,2,1979,0)="""RTN"",""TIUTIUS"",47,0)"
^XMB(3.9,145956,2,1980,0)=" S AUMTI=0"
^XMB(3.9,145956,2,1981,0)="""RTN"",""TIUTIUS"",48,0)"
^XMB(3.9,145956,2,1982,0)=" F  S AUMTI=$O(^TIU(8925.71,AUMTI)) Q:'AUMTI  D"
^XMB(3.9,145956,2,1983,0)="""RTN"",""TIUTIUS"",49,0)"
^XMB(3.9,145956,2,1984,0)=" . I '$P(^TIU(8925.71,AUMTI,0),""^"",2) Q"
^XMB(3.9,145956,2,1985,0)="""RTN"",""TIUTIUS"",50,0)"
^XMB(3.9,145956,2,1986,0)=" . S X=$G(^TIU(8925.71,AUMTI,3))"
^XMB(3.9,145956,2,1987,0)="""RTN"",""TIUTIUS"",51,0)"
^XMB(3.9,145956,2,1988,0)=" . I X="""" Q"
^XMB(3.9,145956,2,1989,0)="""RTN"",""TIUTIUS"",52,0)"
^XMB(3.9,145956,2,1990,0)=" . ; TIU*1.0*324 these parameters no longer used"
^XMB(3.9,145956,2,1991,0)="""RTN"",""TIUTIUS"",53,0)"
^XMB(3.9,145956,2,1992,0)=" . ;S AUMTXT(AUMTI)=$P(^TIU(8925.71,AUMTI,0),""^"",3,4)"
^XMB(3.9,145956,2,1993,0)="""RTN"",""TIUTIUS"",54,0)"
^XMB(3.9,145956,2,1994,0)=" . ; TIU*1.0*324 Compare Visit Search String in upper case only"
^XMB(3.9,145956,2,1995,0)="""RTN"",""TIUTIUS"",55,0)"
^XMB(3.9,145956,2,1996,0)=" . S AUMTVLS=$$UPPER^TIULS($P(^TIU(8925.71,AUMTI,0),""^"",5))"
^XMB(3.9,145956,2,1997,0)="""RTN"",""TIUTIUS"",56,0)"
^XMB(3.9,145956,2,1998,0)=" . ; TIU*1.0*324 not case sensitive and remove spaces"
^XMB(3.9,145956,2,1999,0)="""RTN"",""TIUTIUS"",57,0)"
^XMB(3.9,145956,2,2000,0)=" . S X=$$LOW^XLFSTR(X),X=$TR(X,"" "","""") S AUMTXT(AUMTI,""T"")=X"
^XMB(3.9,145956,2,2001,0)="""RTN"",""TIUTIUS"",58,0)"
^XMB(3.9,145956,2,2002,0)=" . ; visit location or visit location string defined"
^XMB(3.9,145956,2,2003,0)="""RTN"",""TIUTIUS"",59,0)"
^XMB(3.9,145956,2,2004,0)=" . I $O(^TIU(8925.71,AUMTI,5,0))!(AUMTVLS'="""") D"
^XMB(3.9,145956,2,2005,0)="""RTN"",""TIUTIUS"",60,0)"
^XMB(3.9,145956,2,2006,0)=" . . I $D(^TIU(8925.71,AUMTI,5,""B"",AUMTVL)) S AUMTXT(AUMTI,""VL"")="""" Q"
^XMB(3.9,145956,2,2007,0)="""RTN"",""TIUTIUS"",61,0)"
^XMB(3.9,145956,2,2008,0)=" . . I AUMTVLS'="""",AUMTVL(0)[AUMTVLS S AUMTXT(AUMTI,""VL"")="""" Q"
^XMB(3.9,145956,2,2009,0)="""RTN"",""TIUTIUS"",62,0)"
^XMB(3.9,145956,2,2010,0)=" . . K AUMTXT(AUMTI)"
^XMB(3.9,145956,2,2011,0)="""RTN"",""TIUTIUS"",63,0)"
^XMB(3.9,145956,2,2012,0)=" ;"
^XMB(3.9,145956,2,2013,0)="""RTN"",""TIUTIUS"",64,0)"
^XMB(3.9,145956,2,2014,0)=" ; TIU*1.0*324 - Removing this logic so all alerts setup are sent even "
^XMB(3.9,145956,2,2015,0)="""RTN"",""TIUTIUS"",65,0)"
^XMB(3.9,145956,2,2016,0)=" ; for the same search text"
^XMB(3.9,145956,2,2017,0)="""RTN"",""TIUTIUS"",66,0)"
^XMB(3.9,145956,2,2018,0)=" ; Check if same alert text is for two or more events and one of the"
^XMB(3.9,145956,2,2019,0)="""RTN"",""TIUTIUS"",67,0)"
^XMB(3.9,145956,2,2020,0)=" ; events is for this document's visit location then check for specific"
^XMB(3.9,145956,2,2021,0)="""RTN"",""TIUTIUS"",68,0)"
^XMB(3.9,145956,2,2022,0)=" ; location event text and suppress the general event."
^XMB(3.9,145956,2,2023,0)="""RTN"",""TIUTIUS"",69,0)"
^XMB(3.9,145956,2,2024,0)=" ;S AUMTI=0"
^XMB(3.9,145956,2,2025,0)="""RTN"",""TIUTIUS"",70,0)"
^XMB(3.9,145956,2,2026,0)=" ;F  S AUMTI=$O(AUMTXT(AUMTI)) Q:'AUMTI  D"
^XMB(3.9,145956,2,2027,0)="""RTN"",""TIUTIUS"",71,0)"
^XMB(3.9,145956,2,2028,0)=" ;. I '$D(AUMTXT(AUMTI,""VL"")) Q"
^XMB(3.9,145956,2,2029,0)="""RTN"",""TIUTIUS"",72,0)"
^XMB(3.9,145956,2,2030,0)=" ;. S AUMTK=0"
^XMB(3.9,145956,2,2031,0)="""RTN"",""TIUTIUS"",73,0)"
^XMB(3.9,145956,2,2032,0)=" ;. F  S AUMTK=$O(AUMTXT(AUMTK)) Q:'AUMTK  D"
^XMB(3.9,145956,2,2033,0)="""RTN"",""TIUTIUS"",74,0)"
^XMB(3.9,145956,2,2034,0)=" ;. . I AUMTK=AUMTI!($D(AUMTXT(AUMTK,""VL""))) Q"
^XMB(3.9,145956,2,2035,0)="""RTN"",""TIUTIUS"",75,0)"
^XMB(3.9,145956,2,2036,0)=" ;. . I AUMTXT(AUMTK,""T"")=AUMTXT(AUMTI,""T"") K AUMTXT(AUMTK)"
^XMB(3.9,145956,2,2037,0)="""RTN"",""TIUTIUS"",76,0)"
^XMB(3.9,145956,2,2038,0)=" ;"
^XMB(3.9,145956,2,2039,0)="""RTN"",""TIUTIUS"",77,0)"
^XMB(3.9,145956,2,2040,0)=" ; If no active text events then quit"
^XMB(3.9,145956,2,2041,0)="""RTN"",""TIUTIUS"",78,0)"
^XMB(3.9,145956,2,2042,0)=" I '$D(AUMTXT) Q"
^XMB(3.9,145956,2,2043,0)="""RTN"",""TIUTIUS"",79,0)"
^XMB(3.9,145956,2,2044,0)=" ;"
^XMB(3.9,145956,2,2045,0)="""RTN"",""TIUTIUS"",80,0)"
^XMB(3.9,145956,2,2046,0)=" ; Search the current and preceeding line for matching text, deal with"
^XMB(3.9,145956,2,2047,0)="""RTN"",""TIUTIUS"",81,0)"
^XMB(3.9,145956,2,2048,0)=" ; text that spans two lines."
^XMB(3.9,145956,2,2049,0)="""RTN"",""TIUTIUS"",82,0)"
^XMB(3.9,145956,2,2050,0)=" ; Skip the event if we've already found a match on a given text event."
^XMB(3.9,145956,2,2051,0)="""RTN"",""TIUTIUS"",83,0)"
^XMB(3.9,145956,2,2052,0)=" ; TIU*1.0*324 - REWRITE THIS CODE"
^XMB(3.9,145956,2,2053,0)="""RTN"",""TIUTIUS"",84,0)"
^XMB(3.9,145956,2,2054,0)=" ;S AUMTI=0,X1="""""
^XMB(3.9,145956,2,2055,0)="""RTN"",""TIUTIUS"",85,0)"
^XMB(3.9,145956,2,2056,0)=" ;F  S AUMTI=$O(^TIU(8925,AUMTDA,""TEXT"",AUMTI)) Q:'AUMTI  D"
^XMB(3.9,145956,2,2057,0)="""RTN"",""TIUTIUS"",86,0)"
^XMB(3.9,145956,2,2058,0)=" ;. S X0=X1,X1=^TIU(8925,AUMTDA,""TEXT"",AUMTI,0)"
^XMB(3.9,145956,2,2059,0)="""RTN"",""TIUTIUS"",87,0)"
^XMB(3.9,145956,2,2060,0)=" ;. S X=X0_X1"
^XMB(3.9,145956,2,2061,0)="""RTN"",""TIUTIUS"",88,0)"
^XMB(3.9,145956,2,2062,0)=" ;. S AUMTJ=0"
^XMB(3.9,145956,2,2063,0)="""RTN"",""TIUTIUS"",89,0)"
^XMB(3.9,145956,2,2064,0)=" ;. F  S AUMTJ=$O(AUMTXT(AUMTJ)) Q:AUMTJ=""""  I '$D(AUMTXQA(AUMTJ)) D"
^XMB(3.9,145956,2,2065,0)="""RTN"",""TIUTIUS"",90,0)"
^XMB(3.9,145956,2,2066,0)=" ;. . S Y=X"
^XMB(3.9,145956,2,2067,0)="""RTN"",""TIUTIUS"",91,0)"
^XMB(3.9,145956,2,2068,0)=" ;. . S Y=$$LOW^XLFSTR(Y)"
^XMB(3.9,145956,2,2069,0)="""RTN"",""TIUTIUS"",92,0)"
^XMB(3.9,145956,2,2070,0)=" ;. . I '$P(AUMTXT(AUMTJ),""^"",2) S Y=$TR(Y,"" "","""")"
^XMB(3.9,145956,2,2071,0)="""RTN"",""TIUTIUS"",93,0)"
^XMB(3.9,145956,2,2072,0)=" ;. . S AUMTZ=0 F  S AUMTZ=$O(AUMTXT(AUMTZ)) Q:AUMTZ=""""  S AUMTJ=AUMTZ D"
^XMB(3.9,145956,2,2073,0)="""RTN"",""TIUTIUS"",94,0)"
^XMB(3.9,145956,2,2074,0)=" ;...I $G(Y)'="""" S:Y[AUMTXT(AUMTJ,""T"") AUMTXQA(AUMTJ)=AUMTJ"
^XMB(3.9,145956,2,2075,0)="""RTN"",""TIUTIUS"",95,0)"
^XMB(3.9,145956,2,2076,0)=" ;"
^XMB(3.9,145956,2,2077,0)="""RTN"",""TIUTIUS"",96,0)"
^XMB(3.9,145956,2,2078,0)=" ; TIU*1.0*324 REPLACEMENT CODE"
^XMB(3.9,145956,2,2079,0)="""RTN"",""TIUTIUS"",97,0)"
^XMB(3.9,145956,2,2080,0)=" S AUMTI=0,X1="""""
^XMB(3.9,145956,2,2081,0)="""RTN"",""TIUTIUS"",98,0)"
^XMB(3.9,145956,2,2082,0)=" F  S AUMTI=$O(^TIU(8925,AUMTDA,""TEXT"",AUMTI)) Q:'AUMTI  D"
^XMB(3.9,145956,2,2083,0)="""RTN"",""TIUTIUS"",99,0)"
^XMB(3.9,145956,2,2084,0)=" . S X1=X1_^TIU(8925,AUMTDA,""TEXT"",AUMTI,0)"
^XMB(3.9,145956,2,2085,0)="""RTN"",""TIUTIUS"",100,0)"
^XMB(3.9,145956,2,2086,0)=" S X1=$$LOW^XLFSTR(X1)"
^XMB(3.9,145956,2,2087,0)="""RTN"",""TIUTIUS"",101,0)"
^XMB(3.9,145956,2,2088,0)=" ;strip out spaces (should all punctuation be stripped?"
^XMB(3.9,145956,2,2089,0)="""RTN"",""TIUTIUS"",102,0)"
^XMB(3.9,145956,2,2090,0)=" S X1=$TR(X1,"" "",""""),AUMTJ=0"
^XMB(3.9,145956,2,2091,0)="""RTN"",""TIUTIUS"",103,0)"
^XMB(3.9,145956,2,2092,0)=" F  S AUMTJ=$O(AUMTXT(AUMTJ)) Q:AUMTJ=""""  D"
^XMB(3.9,145956,2,2093,0)="""RTN"",""TIUTIUS"",104,0)"
^XMB(3.9,145956,2,2094,0)=" . S:X1[AUMTXT(AUMTJ,""T"") AUMTXQA(AUMTJ)=AUMTJ"
^XMB(3.9,145956,2,2095,0)="""RTN"",""TIUTIUS"",105,0)"
^XMB(3.9,145956,2,2096,0)=" ; Send any alerts"
^XMB(3.9,145956,2,2097,0)="""RTN"",""TIUTIUS"",106,0)"
^XMB(3.9,145956,2,2098,0)=" S AUMTZ=0 S AUMTZ=$O(AUMTXQA(AUMTZ)) D:AUMTZ'="""" SENDXQA"
^XMB(3.9,145956,2,2099,0)="""RTN"",""TIUTIUS"",107,0)"
^XMB(3.9,145956,2,2100,0)=" ;"
^XMB(3.9,145956,2,2101,0)="""RTN"",""TIUTIUS"",108,0)"
^XMB(3.9,145956,2,2102,0)=" K AUMTDA"
^XMB(3.9,145956,2,2103,0)="""RTN"",""TIUTIUS"",109,0)"
^XMB(3.9,145956,2,2104,0)=" Q"
^XMB(3.9,145956,2,2105,0)="""RTN"",""TIUTIUS"",110,0)"
^XMB(3.9,145956,2,2106,0)=" ;"
^XMB(3.9,145956,2,2107,0)="""RTN"",""TIUTIUS"",111,0)"
^XMB(3.9,145956,2,2108,0)=" ;"
^XMB(3.9,145956,2,2109,0)="""RTN"",""TIUTIUS"",112,0)"
^XMB(3.9,145956,2,2110,0)="SENDXQA ; Send Kernel alert to appropriate team or team device "
^XMB(3.9,145956,2,2111,0)="""RTN"",""TIUTIUS"",113,0)"
^XMB(3.9,145956,2,2112,0)=" ;"
^XMB(3.9,145956,2,2113,0)="""RTN"",""TIUTIUS"",114,0)"
^XMB(3.9,145956,2,2114,0)=" N AUMTHL,AUMTSKIP,AUMTEAM,AUMTI,AUMTJ,AUMTK,AUMTSA"
^XMB(3.9,145956,2,2115,0)="""RTN"",""TIUTIUS"",115,0)"
^XMB(3.9,145956,2,2116,0)=" N DFN,TIU0,TIUPNM,TIUSSN,VA,XQA,XQADATA,XQAID,XQAMSG,XQAROU,XQATEXT"
^XMB(3.9,145956,2,2117,0)="""RTN"",""TIUTIUS"",116,0)"
^XMB(3.9,145956,2,2118,0)=" ;"
^XMB(3.9,145956,2,2119,0)="""RTN"",""TIUTIUS"",117,0)"
^XMB(3.9,145956,2,2120,0)=" S TIU0=$G(^TIU(8925,AUMTDA,0)),DFN=+$P(TIU0,U,2)"
^XMB(3.9,145956,2,2121,0)="""RTN"",""TIUTIUS"",118,0)"
^XMB(3.9,145956,2,2122,0)=" S TIUPNM=$E($$PTNAME^TIULC1(DFN),1,9)"
^XMB(3.9,145956,2,2123,0)="""RTN"",""TIUTIUS"",119,0)"
^XMB(3.9,145956,2,2124,0)=" D PID^VADPT6"
^XMB(3.9,145956,2,2125,0)="""RTN"",""TIUTIUS"",120,0)"
^XMB(3.9,145956,2,2126,0)=" S TIUSSN=$E(TIUPNM,1)_VA(""BID"")"
^XMB(3.9,145956,2,2127,0)="""RTN"",""TIUTIUS"",121,0)"
^XMB(3.9,145956,2,2128,0)=" ;"
^XMB(3.9,145956,2,2129,0)="""RTN"",""TIUTIUS"",122,0)"
^XMB(3.9,145956,2,2130,0)=" ; Get hospital location for alert message text"
^XMB(3.9,145956,2,2131,0)="""RTN"",""TIUTIUS"",123,0)"
^XMB(3.9,145956,2,2132,0)=" S AUMTHL=+$P($G(^TIU(8925,AUMTDA,12)),""^"",5)"
^XMB(3.9,145956,2,2133,0)="""RTN"",""TIUTIUS"",124,0)"
^XMB(3.9,145956,2,2134,0)=" S AUMTHL(0)=$$GET1^DIQ(44,AUMTHL_"","",1)"
^XMB(3.9,145956,2,2135,0)="""RTN"",""TIUTIUS"",125,0)"
^XMB(3.9,145956,2,2136,0)=" ;"
^XMB(3.9,145956,2,2137,0)="""RTN"",""TIUTIUS"",126,0)"
^XMB(3.9,145956,2,2138,0)=" ; Send alert to each team's members and other additional recipients."
^XMB(3.9,145956,2,2139,0)="""RTN"",""TIUTIUS"",127,0)"
^XMB(3.9,145956,2,2140,0)=" S AUMTI=0"
^XMB(3.9,145956,2,2141,0)="""RTN"",""TIUTIUS"",128,0)"
^XMB(3.9,145956,2,2142,0)=" F  S AUMTI=$O(AUMTXQA(AUMTI)) Q:AUMTI=""""  D"
^XMB(3.9,145956,2,2143,0)="""RTN"",""TIUTIUS"",129,0)"
^XMB(3.9,145956,2,2144,0)=" . K XQA,XQADATA,XQADFN,XQAID,XQAMSG,XQAROU,XQATEXT"
^XMB(3.9,145956,2,2145,0)="""RTN"",""TIUTIUS"",130,0)"
^XMB(3.9,145956,2,2146,0)=" . S XQAID=""TIUADD""_AUMTDA,XQADATA=AUMTDA_""^"",XQAROU=""ACTADD^TIUALRT"""
^XMB(3.9,145956,2,2147,0)="""RTN"",""TIUTIUS"",131,0)"
^XMB(3.9,145956,2,2148,0)=" . S XQAMSG=TIUPNM_"" (""_TIUSSN_""): (""_AUMTHL(0)_"") ""_$P($G(^TIU(8925.71,AUMTI,2)),""^"")"
^XMB(3.9,145956,2,2149,0)="""RTN"",""TIUTIUS"",132,0)"
^XMB(3.9,145956,2,2150,0)=" . S AUMTK=0"
^XMB(3.9,145956,2,2151,0)="""RTN"",""TIUTIUS"",133,0)"
^XMB(3.9,145956,2,2152,0)=" . F  S AUMTK=$O(^TIU(8925.71,AUMTI,4,AUMTK)) Q:'AUMTK  D"
^XMB(3.9,145956,2,2153,0)="""RTN"",""TIUTIUS"",134,0)"
^XMB(3.9,145956,2,2154,0)=" . . K AUMTEAM"
^XMB(3.9,145956,2,2155,0)="""RTN"",""TIUTIUS"",135,0)"
^XMB(3.9,145956,2,2156,0)=" . . S AUMTEAM=+^TIU(8925.71,AUMTI,4,AUMTK,0)"
^XMB(3.9,145956,2,2157,0)="""RTN"",""TIUTIUS"",136,0)"
^XMB(3.9,145956,2,2158,0)=" . . I AUMTEAM>0 D ADDTEAM(AUMTEAM)"
^XMB(3.9,145956,2,2159,0)="""RTN"",""TIUTIUS"",137,0)"
^XMB(3.9,145956,2,2160,0)=" . D ADDRECP"
^XMB(3.9,145956,2,2161,0)="""RTN"",""TIUTIUS"",138,0)"
^XMB(3.9,145956,2,2162,0)=" . I $D(XQA) D SETUP^XQALERT"
^XMB(3.9,145956,2,2163,0)="""RTN"",""TIUTIUS"",139,0)"
^XMB(3.9,145956,2,2164,0)=" ;"
^XMB(3.9,145956,2,2165,0)="""RTN"",""TIUTIUS"",140,0)"
^XMB(3.9,145956,2,2166,0)=" ; Send alert to signer that teams have been notified."
^XMB(3.9,145956,2,2167,0)="""RTN"",""TIUTIUS"",141,0)"
^XMB(3.9,145956,2,2168,0)=" I $D(AUMTSA) D SENDSA"
^XMB(3.9,145956,2,2169,0)="""RTN"",""TIUTIUS"",142,0)"
^XMB(3.9,145956,2,2170,0)=" Q"
^XMB(3.9,145956,2,2171,0)="""RTN"",""TIUTIUS"",143,0)"
^XMB(3.9,145956,2,2172,0)=" ;"
^XMB(3.9,145956,2,2173,0)="""RTN"",""TIUTIUS"",144,0)"
^XMB(3.9,145956,2,2174,0)=" ;"
^XMB(3.9,145956,2,2175,0)="""RTN"",""TIUTIUS"",145,0)"
^XMB(3.9,145956,2,2176,0)="SENDSA ; Build and sent alerts to signer"
^XMB(3.9,145956,2,2177,0)="""RTN"",""TIUTIUS"",146,0)"
^XMB(3.9,145956,2,2178,0)=" ;"
^XMB(3.9,145956,2,2179,0)="""RTN"",""TIUTIUS"",147,0)"
^XMB(3.9,145956,2,2180,0)=" N AUMTCNT,AUMTDUZ,AUMTI,AUMTMSG"
^XMB(3.9,145956,2,2181,0)="""RTN"",""TIUTIUS"",148,0)"
^XMB(3.9,145956,2,2182,0)=" N XQA,XQADATA,XQADFN,XQAID,XQAMSG,XQAROU,XQATEXT"
^XMB(3.9,145956,2,2183,0)="""RTN"",""TIUTIUS"",149,0)"
^XMB(3.9,145956,2,2184,0)=" ;"
^XMB(3.9,145956,2,2185,0)="""RTN"",""TIUTIUS"",150,0)"
^XMB(3.9,145956,2,2186,0)=" S AUMTDUZ=+$P($G(^TIU(8925,AUMTDA,15)),""^"",2)"
^XMB(3.9,145956,2,2187,0)="""RTN"",""TIUTIUS"",151,0)"
^XMB(3.9,145956,2,2188,0)=" I 'AUMTDUZ Q"
^XMB(3.9,145956,2,2189,0)="""RTN"",""TIUTIUS"",152,0)"
^XMB(3.9,145956,2,2190,0)=" S AUMTI=0,AUMTMSG=""Alert(s) Sent: """
^XMB(3.9,145956,2,2191,0)="""RTN"",""TIUTIUS"",153,0)"
^XMB(3.9,145956,2,2192,0)=" F  S AUMTI=$O(AUMTSA(AUMTI)) Q:'AUMTI  S AUMTMSG=AUMTMSG_$P($G(^TIU(8925.71,AUMTI,2)),""^"",2)_"","" D"
^XMB(3.9,145956,2,2193,0)="""RTN"",""TIUTIUS"",154,0)"
^XMB(3.9,145956,2,2194,0)=" . S XQAID=""AUMTIU,""_AUMTDA"
^XMB(3.9,145956,2,2195,0)="""RTN"",""TIUTIUS"",155,0)"
^XMB(3.9,145956,2,2196,0)=" . S XQAMSG=TIUPNM_"" (""_TIUSSN_""): ""_AUMTMSG"
^XMB(3.9,145956,2,2197,0)="""RTN"",""TIUTIUS"",156,0)"
^XMB(3.9,145956,2,2198,0)=" . S XQA(AUMTDUZ)="""""
^XMB(3.9,145956,2,2199,0)="""RTN"",""TIUTIUS"",157,0)"
^XMB(3.9,145956,2,2200,0)=" . D SETUP^XQALERT"
^XMB(3.9,145956,2,2201,0)="""RTN"",""TIUTIUS"",158,0)"
^XMB(3.9,145956,2,2202,0)=" Q"
^XMB(3.9,145956,2,2203,0)="""RTN"",""TIUTIUS"",159,0)"
^XMB(3.9,145956,2,2204,0)=" ;"
^XMB(3.9,145956,2,2205,0)="""RTN"",""TIUTIUS"",160,0)"
^XMB(3.9,145956,2,2206,0)=" ;"
^XMB(3.9,145956,2,2207,0)="""RTN"",""TIUTIUS"",161,0)"
^XMB(3.9,145956,2,2208,0)="SKIP() ; Check if we should skip alerting this team if they already have been sent an alert."
^XMB(3.9,145956,2,2209,0)="""RTN"",""TIUTIUS"",162,0)"
