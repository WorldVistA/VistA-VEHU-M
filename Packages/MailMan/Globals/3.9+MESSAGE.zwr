^XMB(3.9,145986,2,3973,0)="""RTN"",""FBPCR"",237,0)"
^XMB(3.9,145986,2,3974,0)=" D CL^SDCO21(DFN,FBADT,"""",.FBARR)"
^XMB(3.9,145986,2,3975,0)="""RTN"",""FBPCR"",238,0)"
^XMB(3.9,145986,2,3976,0)=" I $D(FBARR(3)) W ""SC TREATMENT"",!"
^XMB(3.9,145986,2,3977,0)="""RTN"",""FBPCR"",239,0)"
