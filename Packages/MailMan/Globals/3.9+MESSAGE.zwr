^XMB(3.9,145984,2,1134,0)=" ;"
^XMB(3.9,145984,2,1135,0)="""RTN"",""PSOERX1D"",69,0)"
^XMB(3.9,145984,2,1136,0)="SETMRC(PSOIEN,CHGMESRI,CHGMESRQ,RESPVAL,RULE,LINE) ; Set values for MRC variables"
^XMB(3.9,145984,2,1137,0)="""RTN"",""PSOERX1D"",70,0)"
^XMB(3.9,145984,2,1138,0)=" N CHGMESRE,CHMSSUB,I,IENS,NO311,NOTEARY,X,REATXT"
^XMB(3.9,145984,2,1139,0)="""RTN"",""PSOERX1D"",71,0)"
^XMB(3.9,145984,2,1140,0)=" S CHGMESRE=$$GET1^DIQ(52.45,CHGMESRQ,.02,""I"")"
^XMB(3.9,145984,2,1141,0)="""RTN"",""PSOERX1D"",72,0)"
^XMB(3.9,145984,2,1142,0)=" I RULE?1(1""1058"",1""1059"",1""1060"",1""1043"",1""1056"",1""0"") D SET(.LINE,""Change Request Type: "",CHGMESRE),CNTRL^VALM10(LINE,22,$L(CHGMESRE),IOINHI,IOINORM)"
