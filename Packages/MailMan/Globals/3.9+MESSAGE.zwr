^XMB(3.9,145956,2,2298,0)=" ;"
^XMB(3.9,145956,2,2299,0)="""RTN"",""TIUTIUS"",207,0)"
^XMB(3.9,145956,2,2300,0)=" ; Call with AUMTEAM = ien of team in file 100.21"
^XMB(3.9,145956,2,2301,0)="""RTN"",""TIUTIUS"",208,0)"
^XMB(3.9,145956,2,2302,0)=" ;"
^XMB(3.9,145956,2,2303,0)="""RTN"",""TIUTIUS"",209,0)"
^XMB(3.9,145956,2,2304,0)=" N AUMTD,AUMTDEV,AUMTJ"
^XMB(3.9,145956,2,2305,0)="""RTN"",""TIUTIUS"",210,0)"
^XMB(3.9,145956,2,2306,0)=" ;I $$SKIP Q"
