^XMB(3.9,145980,2,3895,0)="""RTN"",""SDES2CANCELAPPT2"",104,0)"
^XMB(3.9,145980,2,3896,0)=" ; cancel appointments"
^XMB(3.9,145980,2,3897,0)="""RTN"",""SDES2CANCELAPPT2"",105,0)"
^XMB(3.9,145980,2,3898,0)=" D CANCEL40984^SDES2CANCELAPPT1(.SDERRORS,APPTIEN,CANCELREASONIEN,CANBYCLINORPAT,WALKIN,$G(EAS),.ROLLBACK)"
^XMB(3.9,145980,2,3899,0)="""RTN"",""SDES2CANCELAPPT2"",106,0)"
^XMB(3.9,145980,2,3900,0)=" Q:$D(SDERRORS)"
^XMB(3.9,145980,2,3901,0)="""RTN"",""SDES2CANCELAPPT2"",107,0)"
^XMB(3.9,145980,2,3902,0)=" D CANCEL44(.SDERRORS,CLINICIEN,APPTSTARTTIME,DFN,APPTIEN,WALKIN,IENS44,.ROLLBACK)"
^XMB(3.9,145980,2,3903,0)="""RTN"",""SDES2CANCELAPPT2"",108,0)"
