^XMB(3.9,145944,2,1158,0)=" . . I IBSTA=""A"",IB'=16 Q"
^XMB(3.9,145944,2,1159,0)="""RTN"",""IBJDF42"",63,0)"
^XMB(3.9,145944,2,1160,0)=" . . I IBSTA=""S"",IB=16 Q"
^XMB(3.9,145944,2,1161,0)="""RTN"",""IBJDF42"",64,0)"
^XMB(3.9,145944,2,1162,0)=" . . I '$D(^TMP(""IBJDF4"",$J,IBPT,IB)) D  Q"
^XMB(3.9,145944,2,1163,0)="""RTN"",""IBJDF42"",65,0)"
