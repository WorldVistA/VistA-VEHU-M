^XMB(3.9,145946,2,5451,0)="""RTN"",""IBCNSU21"",85,0)"
^XMB(3.9,145946,2,5452,0)=" S VALMHDR(4)=$$SETSTR^VALM1(""Pre-  Pre-  Ben"",X,64,17)"
^XMB(3.9,145946,2,5453,0)="""RTN"",""IBCNSU21"",86,0)"
^XMB(3.9,145946,2,5454,0)=" Q"
^XMB(3.9,145946,2,5455,0)="""RTN"",""IBCNSU21"",87,0)"
^XMB(3.9,145946,2,5456,0)=" ;"
^XMB(3.9,145946,2,5457,0)="""RTN"",""IBCNSU21"",88,0)"
^XMB(3.9,145946,2,5458,0)="EXIT ; Exit action."
^XMB(3.9,145946,2,5459,0)="""RTN"",""IBCNSU21"",89,0)"
^XMB(3.9,145946,2,5460,0)=" N IDX"
^XMB(3.9,145946,2,5461,0)="""RTN"",""IBCNSU21"",90,0)"
^XMB(3.9,145946,2,5462,0)=" K VALMBCK"
^XMB(3.9,145946,2,5463,0)="""RTN"",""IBCNSU21"",91,0)"
^XMB(3.9,145946,2,5464,0)=" M ^TMP($J,""IBSEL"")=^TMP(""IBCNSU21A"",$J) S ^TMP($J,""IBSEL"",0)=NUMSEL"
^XMB(3.9,145946,2,5465,0)="""RTN"",""IBCNSU21"",92,0)"
^XMB(3.9,145946,2,5466,0)=" F IDX=""IBCNSU21"",""IBCNSU21A"",""IBCNSU21IX"" K ^TMP(IDX,$J)"
^XMB(3.9,145946,2,5467,0)="""RTN"",""IBCNSU21"",93,0)"
^XMB(3.9,145946,2,5468,0)=" D CLEAN^VALM10,CLEAR^VALM1"
^XMB(3.9,145946,2,5469,0)="""RTN"",""IBCNSU21"",94,0)"
^XMB(3.9,145946,2,5470,0)=" Q"
^XMB(3.9,145946,2,5471,0)="""RTN"",""IBCNSU21"",95,0)"
^XMB(3.9,145946,2,5472,0)=" ;"
^XMB(3.9,145946,2,5473,0)="""RTN"",""IBCNSU21"",96,0)"
^XMB(3.9,145946,2,5474,0)="BLD ;"
^XMB(3.9,145946,2,5475,0)="""RTN"",""IBCNSU21"",97,0)"
^XMB(3.9,145946,2,5476,0)=" ;Source Data from ^TMP($J,""IBCNSU21"")"
^XMB(3.9,145946,2,5477,0)="""RTN"",""IBCNSU21"",98,0)"
^XMB(3.9,145946,2,5478,0)=" N IIEN,LINE"
^XMB(3.9,145946,2,5479,0)="""RTN"",""IBCNSU21"",99,0)"
^XMB(3.9,145946,2,5480,0)=" S (IIEN,VALMCNT)=0"
^XMB(3.9,145946,2,5481,0)="""RTN"",""IBCNSU21"",100,0)"
^XMB(3.9,145946,2,5482,0)=" F  S IIEN=$O(^TMP($J,""IBCNSU21"",IIEN)) Q:'IIEN  D"
^XMB(3.9,145946,2,5483,0)="""RTN"",""IBCNSU21"",101,0)"
^XMB(3.9,145946,2,5484,0)=" . S VALMCNT=VALMCNT+1"
^XMB(3.9,145946,2,5485,0)="""RTN"",""IBCNSU21"",102,0)"
^XMB(3.9,145946,2,5486,0)=" . S LINE=$$BLDLN(VALMCNT,IIEN)"
^XMB(3.9,145946,2,5487,0)="""RTN"",""IBCNSU21"",103,0)"
^XMB(3.9,145946,2,5488,0)=" . D SET^VALM10(VALMCNT,LINE,LINE)"
^XMB(3.9,145946,2,5489,0)="""RTN"",""IBCNSU21"",104,0)"
^XMB(3.9,145946,2,5490,0)=" . S ^TMP(""IBCNSU21IX"",$J,VALMCNT)=IIEN"
^XMB(3.9,145946,2,5491,0)="""RTN"",""IBCNSU21"",105,0)"
^XMB(3.9,145946,2,5492,0)=" Q"
^XMB(3.9,145946,2,5493,0)="""RTN"",""IBCNSU21"",106,0)"
^XMB(3.9,145946,2,5494,0)=" ;"
^XMB(3.9,145946,2,5495,0)="""RTN"",""IBCNSU21"",107,0)"
^XMB(3.9,145946,2,5496,0)="BLDLN(ICTR,IIEN,DATA) ;EP"
^XMB(3.9,145946,2,5497,0)="""RTN"",""IBCNSU21"",108,0)"
^XMB(3.9,145946,2,5498,0)=" ; Builds a line to display one insurance company"
^XMB(3.9,145946,2,5499,0)="""RTN"",""IBCNSU21"",109,0)"
^XMB(3.9,145946,2,5500,0)=" ; Input:   ICTR                        - Selection Number"
^XMB(3.9,145946,2,5501,0)="""RTN"",""IBCNSU21"",110,0)"
^XMB(3.9,145946,2,5502,0)=" ;          IIEN                        - IEN of the Policy to be displayed"
^XMB(3.9,145946,2,5503,0)="""RTN"",""IBCNSU21"",111,0)"
^XMB(3.9,145946,2,5504,0)=" ;          ^TMP(""IBCNSU21A"",$J,IIEN)    - Array of currently selected policies"
^XMB(3.9,145946,2,5505,0)="""RTN"",""IBCNSU21"",112,0)"
^XMB(3.9,145946,2,5506,0)=" ;"
^XMB(3.9,145946,2,5507,0)="""RTN"",""IBCNSU21"",113,0)"
^XMB(3.9,145946,2,5508,0)=" ; Output:  LINE    - Formatted for setting into the list display"
^XMB(3.9,145946,2,5509,0)="""RTN"",""IBCNSU21"",114,0)"
^XMB(3.9,145946,2,5510,0)=" N DATA,LINEVAR"
^XMB(3.9,145946,2,5511,0)="""RTN"",""IBCNSU21"",115,0)"
^XMB(3.9,145946,2,5512,0)=" D GETS^DIQ(355.3,+IIEN_"","","".02;.05;.06;.07;.08;.09;.11;2.01;2.02"",""EI"",""DATA"")"
^XMB(3.9,145946,2,5513,0)="""RTN"",""IBCNSU21"",116,0)"
^XMB(3.9,145946,2,5514,0)=" S LINEVAR="""""
^XMB(3.9,145946,2,5515,0)="""RTN"",""IBCNSU21"",117,0)"
^XMB(3.9,145946,2,5516,0)=" I $D(^TMP(""IBCNSU21A"",$J,IIEN)) S ICTR=ICTR_"">"""
^XMB(3.9,145946,2,5517,0)="""RTN"",""IBCNSU21"",118,0)"
^XMB(3.9,145946,2,5518,0)=" S LINEVAR=$$SETFLD^VALM1(ICTR,"""",""CTR"")"
^XMB(3.9,145946,2,5519,0)="""RTN"",""IBCNSU21"",119,0)"
^XMB(3.9,145946,2,5520,0)=" I '$G(DATA(355.3,IIEN_"","",.02,""I"")) S $E(LINEVAR,4)=""+"""
^XMB(3.9,145946,2,5521,0)="""RTN"",""IBCNSU21"",120,0)"
^XMB(3.9,145946,2,5522,0)=" S LINEVAR=$$SETFLD^VALM1($G(DATA(355.3,IIEN_"","",2.01,""E"")),LINEVAR,""GNAME"")"
^XMB(3.9,145946,2,5523,0)="""RTN"",""IBCNSU21"",121,0)"
^XMB(3.9,145946,2,5524,0)=" I $G(DATA(355.3,IIEN_"","",.11,""I"")) S $E(LINEVAR,24)=""*"""
^XMB(3.9,145946,2,5525,0)="""RTN"",""IBCNSU21"",122,0)"
^XMB(3.9,145946,2,5526,0)=" S LINEVAR=$$SETFLD^VALM1($G(DATA(355.3,IIEN_"","",2.02,""E"")),LINEVAR,""GNUM"")"
^XMB(3.9,145946,2,5527,0)="""RTN"",""IBCNSU21"",123,0)"
^XMB(3.9,145946,2,5528,0)=" S LINEVAR=$$SETFLD^VALM1($G(DATA(355.3,IIEN_"","",.09,""E"")),LINEVAR,""TYPE"")"
^XMB(3.9,145946,2,5529,0)="""RTN"",""IBCNSU21"",124,0)"
^XMB(3.9,145946,2,5530,0)=" S LINEVAR=$$SETFLD^VALM1($$YN^IBCNSM($G(DATA(355.3,IIEN_"","",.05,""I""))),LINEVAR,""UR"")"
^XMB(3.9,145946,2,5531,0)="""RTN"",""IBCNSU21"",125,0)"
^XMB(3.9,145946,2,5532,0)=" S LINEVAR=$$SETFLD^VALM1($$YN^IBCNSM($G(DATA(355.3,IIEN_"","",.06,""I""))),LINEVAR,""PREC"")"
^XMB(3.9,145946,2,5533,0)="""RTN"",""IBCNSU21"",126,0)"
^XMB(3.9,145946,2,5534,0)=" S LINEVAR=$$SETFLD^VALM1($$YN^IBCNSM($G(DATA(355.3,IIEN_"","",.07,""I""))),LINEVAR,""PREEX"")"
^XMB(3.9,145946,2,5535,0)="""RTN"",""IBCNSU21"",127,0)"
^XMB(3.9,145946,2,5536,0)=" S LINEVAR=$$SETFLD^VALM1($$YN^IBCNSM($G(DATA(355.3,IIEN_"","",.08,""I""))),LINEVAR,""BENAS"")"
^XMB(3.9,145946,2,5537,0)="""RTN"",""IBCNSU21"",128,0)"
^XMB(3.9,145946,2,5538,0)=" Q LINEVAR"
^XMB(3.9,145946,2,5539,0)="""RTN"",""IBCNSU21"",129,0)"
^XMB(3.9,145946,2,5540,0)=" ;"
^XMB(3.9,145946,2,5541,0)="""RTN"",""IBCNSU21"",130,0)"
^XMB(3.9,145946,2,5542,0)="SEL ;EP"
^XMB(3.9,145946,2,5543,0)="""RTN"",""IBCNSU21"",131,0)"
^XMB(3.9,145946,2,5544,0)=" ; Protocol Action to select an unselected policy"
^XMB(3.9,145946,2,5545,0)="""RTN"",""IBCNSU21"",132,0)"
^XMB(3.9,145946,2,5546,0)=" ; Input:   NUMSEL                  - Current number of selected policies"
^XMB(3.9,145946,2,5547,0)="""RTN"",""IBCNSU21"",133,0)"
