^XMB(3.9,145984,2,2053,0)="""RTN"",""PSOERXI1"",178,0)"
^XMB(3.9,145984,2,2054,0)=" I $G(PACHK(""success""))=""false"" D"
^XMB(3.9,145984,2,2055,0)="""RTN"",""PSOERXI1"",179,0)"
^XMB(3.9,145984,2,2056,0)=" .; file e&e error"
^XMB(3.9,145984,2,2057,0)="""RTN"",""PSOERXI1"",180,0)"
