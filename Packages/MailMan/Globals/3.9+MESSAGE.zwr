^XMB(3.9,145958,2,1177,0)="""RTN"",""ORWDXA"",83,0)"
^XMB(3.9,145958,2,1178,0)=" S ACTDA=$$ACTION^ORCSAVE(""RL"",+ORID,ORNP)"
^XMB(3.9,145958,2,1179,0)="""RTN"",""ORWDXA"",84,0)"
