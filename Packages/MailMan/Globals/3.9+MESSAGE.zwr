^XMB(3.9,145987,2,465,0)="""RTN"",""SDECRECREQ"")"
^XMB(3.9,145987,2,466,0)="0^4^B11117880"
^XMB(3.9,145987,2,467,0)="""RTN"",""SDECRECREQ"",1,0)"
^XMB(3.9,145987,2,468,0)="SDECRECREQ   ;ALB/SAT/JSM,WTC,LAB,LEG,KML - VISTA SCHEDULING RPCS (SOURCE FROM SDEC08) ;April 20, 2022"
^XMB(3.9,145987,2,469,0)="""RTN"",""SDECRECREQ"",2,0)"
^XMB(3.9,145987,2,470,0)=" ;;5.3;Scheduling;**790,792,805,815**;Aug 13, 1993;Build 0"
^XMB(3.9,145987,2,471,0)="""RTN"",""SDECRECREQ"",3,0)"
^XMB(3.9,145987,2,472,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified"
^XMB(3.9,145987,2,473,0)="""RTN"",""SDECRECREQ"",4,0)"
^XMB(3.9,145987,2,474,0)=" ;"
^XMB(3.9,145987,2,475,0)="""RTN"",""SDECRECREQ"",5,0)"
^XMB(3.9,145987,2,476,0)=" ; Reference to ^DPT (Patient File) is supported by IA #7030"
^XMB(3.9,145987,2,477,0)="""RTN"",""SDECRECREQ"",6,0)"
^XMB(3.9,145987,2,478,0)=" Q"
^XMB(3.9,145987,2,479,0)="""RTN"",""SDECRECREQ"",7,0)"
^XMB(3.9,145987,2,480,0)=" ;"
^XMB(3.9,145987,2,481,0)="""RTN"",""SDECRECREQ"",8,0)"
^XMB(3.9,145987,2,482,0)="RECREQ(SDECY,SDECAPTID,SDAPTYP,NEWPID,SDECTYP) ;for Recall Requests"
^XMB(3.9,145987,2,483,0)="""RTN"",""SDECRECREQ"",9,0)"
^XMB(3.9,145987,2,484,0)=" ; VSE-863; 6/6/2021 ; create new ""APPT"" Request if A ""RECALL"" Appt is Cancelled"
^XMB(3.9,145987,2,485,0)="""RTN"",""SDECRECREQ"",10,0)"
^XMB(3.9,145987,2,486,0)=" ;I $P(SDAPTYP,"";"",2)=""SD(403.5,"" D  ; RECALL"
^XMB(3.9,145987,2,487,0)="""RTN"",""SDECRECREQ"",11,0)"
^XMB(3.9,145987,2,488,0)=" N PTR,SD40350PRV,SD40350REC,SD40354PRV,SD4035IEN,SD409840REC,SD409842REC,SDCLN,SDCLNR,SDPROVNAM,IEN40985,SD409841COM"
^XMB(3.9,145987,2,489,0)="""RTN"",""SDECRECREQ"",12,0)"
^XMB(3.9,145987,2,490,0)=" N CANCHANGEPID,PIDH,RECOPENYN"
^XMB(3.9,145987,2,491,0)="""RTN"",""SDECRECREQ"",13,0)"
^XMB(3.9,145987,2,492,0)=" S SD409840REC=^SDEC(409.84,SDECAPTID,0) ; APPT"
^XMB(3.9,145987,2,493,0)="""RTN"",""SDECRECREQ"",14,0)"
^XMB(3.9,145987,2,494,0)=" ; Only re-open Appt Request for approved Cancellation Reasons VSE-1112"
^XMB(3.9,145987,2,495,0)="""RTN"",""SDECRECREQ"",15,0)"
^XMB(3.9,145987,2,496,0)=" S RECOPENYN=$$GET1^DIQ(409.2,$P(SD409840REC,U,22),5,""I"")"
^XMB(3.9,145987,2,497,0)="""RTN"",""SDECRECREQ"",16,0)"
^XMB(3.9,145987,2,498,0)=" Q:RECOPENYN=0"
^XMB(3.9,145987,2,499,0)="""RTN"",""SDECRECREQ"",17,0)"
^XMB(3.9,145987,2,500,0)=" S SD409842REC=$G(^SDEC(409.84,SDECAPTID,2)) ; REQ record"
^XMB(3.9,145987,2,501,0)="""RTN"",""SDECRECREQ"",18,0)"
^XMB(3.9,145987,2,502,0)=" ; start COMMENTS multiple process ;VSE-1218;**792"
^XMB(3.9,145987,2,503,0)="""RTN"",""SDECRECREQ"",19,0)"
^XMB(3.9,145987,2,504,0)=" S SD409841COM=$G(^SDEC(409.84,SDECAPTID,1,1,0))"
^XMB(3.9,145987,2,505,0)="""RTN"",""SDECRECREQ"",20,0)"
^XMB(3.9,145987,2,506,0)=" N I,L,ZZ"
^XMB(3.9,145987,2,507,0)="""RTN"",""SDECRECREQ"",21,0)"
^XMB(3.9,145987,2,508,0)=" S L=$L(SD409841COM,$C(13,10))"
^XMB(3.9,145987,2,509,0)="""RTN"",""SDECRECREQ"",22,0)"
^XMB(3.9,145987,2,510,0)=" I L>1 F I=1:1:L S $P(ZZ,"" | "",I)=$P(SD409841COM,$C(13,10),I) I I=L S:$L(ZZ)>80 ZZ=$E(ZZ,1,77)_""..."" S SD409841COM=ZZ"
^XMB(3.9,145987,2,511,0)="""RTN"",""SDECRECREQ"",23,0)"
^XMB(3.9,145987,2,512,0)=" ; end COMMENTS multiple process"
^XMB(3.9,145987,2,513,0)="""RTN"",""SDECRECREQ"",24,0)"
^XMB(3.9,145987,2,514,0)=" S PTR=$P(SD409842REC,"";"",1)"
^XMB(3.9,145987,2,515,0)="""RTN"",""SDECRECREQ"",25,0)"
^XMB(3.9,145987,2,516,0)=" S SDCLNR=$P(SD409840REC,U,7)"
^XMB(3.9,145987,2,517,0)="""RTN"",""SDECRECREQ"",26,0)"
^XMB(3.9,145987,2,518,0)=" S SDCLN=$$GET1^DIQ(409.831,SDCLNR,.04,""I"")"
^XMB(3.9,145987,2,519,0)="""RTN"",""SDECRECREQ"",27,0)"
^XMB(3.9,145987,2,520,0)=" S SDECFDA(409.85,""+1,"",.01)=$P(SD409840REC,U,5) ;     DFN"
^XMB(3.9,145987,2,521,0)="""RTN"",""SDECRECREQ"",28,0)"
^XMB(3.9,145987,2,522,0)=" S SDECFDA(409.85,""+1,"",1)=$P($$NOW^XLFDT,""."",1)"
^XMB(3.9,145987,2,523,0)="""RTN"",""SDECRECREQ"",29,0)"
^XMB(3.9,145987,2,524,0)=" S SDECFDA(409.85,""+1,"",2)=$$GET1^DIQ(44,SDCLN,3,""I"") ;INSTIT"
^XMB(3.9,145987,2,525,0)="""RTN"",""SDECRECREQ"",30,0)"
^XMB(3.9,145987,2,526,0)=" S SDECFDA(409.85,""+1,"",4)=""APPT"""
^XMB(3.9,145987,2,527,0)="""RTN"",""SDECRECREQ"",31,0)"
^XMB(3.9,145987,2,528,0)=" S SDECFDA(409.85,""+1,"",8.7)=$P(SD409840REC,U,6) ;     REQ APPT TIME"
^XMB(3.9,145987,2,529,0)="""RTN"",""SDECRECREQ"",32,0)"
^XMB(3.9,145987,2,530,0)=" S SDECFDA(409.85,""+1,"",.02)=$P(SD409842REC,U,2) ;     PAT STATUS"
^XMB(3.9,145987,2,531,0)="""RTN"",""SDECRECREQ"",33,0)"
^XMB(3.9,145987,2,532,0)=" S SDECFDA(409.85,""+1,"",8)=SDCLN ;                     REQ SPECIFIC CLINIC"
^XMB(3.9,145987,2,533,0)="""RTN"",""SDECRECREQ"",34,0)"
^XMB(3.9,145987,2,534,0)=" S SDECFDA(409.85,""+1,"",9)=DUZ ;                       ORIG USER"
^XMB(3.9,145987,2,535,0)="""RTN"",""SDECRECREQ"",35,0)"
^XMB(3.9,145987,2,536,0)=" S SDECFDA(409.85,""+1,"",10)=""F"" ;                      PRIORITY"
^XMB(3.9,145987,2,537,0)="""RTN"",""SDECRECREQ"",36,0)"
^XMB(3.9,145987,2,538,0)=" S SDECFDA(409.85,""+1,"",11)=1 ;                        REQ BY"
^XMB(3.9,145987,2,539,0)="""RTN"",""SDECRECREQ"",37,0)"
^XMB(3.9,145987,2,540,0)=" S SDECFDA(409.85,""+1,"",12)=$P(SD409840REC,""^"",16) ;   PROV"
^XMB(3.9,145987,2,541,0)="""RTN"",""SDECRECREQ"",38,0)"
^XMB(3.9,145987,2,542,0)=" I $G(NEWPID)="""" D"
^XMB(3.9,145987,2,543,0)="""RTN"",""SDECRECREQ"",39,0)"
^XMB(3.9,145987,2,544,0)=" .S SDECFDA(409.85,""+1,"",22)=$P(SD409840REC,U,20) ;    PID"
^XMB(3.9,145987,2,545,0)="""RTN"",""SDECRECREQ"",40,0)"
^XMB(3.9,145987,2,546,0)=" I $G(NEWPID)'="""" D"
^XMB(3.9,145987,2,547,0)="""RTN"",""SDECRECREQ"",41,0)"
^XMB(3.9,145987,2,548,0)=" .S SDECFDA(409.85,""+1,"",22)=NEWPID"
^XMB(3.9,145987,2,549,0)="""RTN"",""SDECRECREQ"",42,0)"
^XMB(3.9,145987,2,550,0)=" S SDECFDA(409.85,""+1,"",23)=""O"" ;                      STATUS"
^XMB(3.9,145987,2,551,0)="""RTN"",""SDECRECREQ"",43,0)"
^XMB(3.9,145987,2,552,0)=" S SDECFDA(409.85,""+1,"",25)=SD409841COM ;VSE-1218;**792"
^XMB(3.9,145987,2,553,0)="""RTN"",""SDECRECREQ"",44,0)"
^XMB(3.9,145987,2,554,0)=" ;**790 corrected REQUEST ptr and added Contact Attempts"
^XMB(3.9,145987,2,555,0)="""RTN"",""SDECRECREQ"",45,0)"
^XMB(3.9,145987,2,556,0)=" S CANCHANGEPID=$S($G(SDECTYP)=""PC"":1,$G(SDECTYP)=""C"":0,1:"""")"
^XMB(3.9,145987,2,557,0)="""RTN"",""SDECRECREQ"",46,0)"
^XMB(3.9,145987,2,558,0)=" S SDECFDA(409.85,""+1,"",49)=CANCHANGEPID"
^XMB(3.9,145987,2,559,0)="""RTN"",""SDECRECREQ"",47,0)"
^XMB(3.9,145987,2,560,0)=" D UPDATE^DIE("""",""SDECFDA"",""IEN40985"")"
^XMB(3.9,145987,2,561,0)="""RTN"",""SDECRECREQ"",48,0)"
^XMB(3.9,145987,2,562,0)=" ;I $G(NEWPID)'="""" D"
^XMB(3.9,145987,2,563,0)="""RTN"",""SDECRECREQ"",49,0)"
^XMB(3.9,145987,2,564,0)=" I $G(NEWPID)="""" S PIDH=$P(SD409840REC,U,20)"
^XMB(3.9,145987,2,565,0)="""RTN"",""SDECRECREQ"",50,0)"
^XMB(3.9,145987,2,566,0)=" I $G(NEWPID)'="""" S PIDH=$G(NEWPID)"
^XMB(3.9,145987,2,567,0)="""RTN"",""SDECRECREQ"",51,0)"
^XMB(3.9,145987,2,568,0)=" S FDA(409.854,""+1,""_IEN40985(1)_"","",.01)=$$NOW^XLFDT"
^XMB(3.9,145987,2,569,0)="""RTN"",""SDECRECREQ"",52,0)"
^XMB(3.9,145987,2,570,0)=" S FDA(409.854,""+1,""_IEN40985(1)_"","",1)=$G(PIDH)"
^XMB(3.9,145987,2,571,0)="""RTN"",""SDECRECREQ"",53,0)"
^XMB(3.9,145987,2,572,0)=" S FDA(409.854,""+1,""_IEN40985(1)_"","",2)=$$GET1^DIQ(200,DUZ,.01,""E"")"
^XMB(3.9,145987,2,573,0)="""RTN"",""SDECRECREQ"",54,0)"
^XMB(3.9,145987,2,574,0)=" D UPDATE^DIE(,""FDA"",""PIDHIEN"",""ERR"") K FDA"
^XMB(3.9,145987,2,575,0)="""RTN"",""SDECRECREQ"",55,0)"
^XMB(3.9,145987,2,576,0)=" S IEN40985=IEN40985(1)"
^XMB(3.9,145987,2,577,0)="""RTN"",""SDECRECREQ"",56,0)"
^XMB(3.9,145987,2,578,0)=" N REQLINK,DFN40985"
^XMB(3.9,145987,2,579,0)="""RTN"",""SDECRECREQ"",57,0)"
^XMB(3.9,145987,2,580,0)=" D APPREQLINK"
^XMB(3.9,145987,2,581,0)="""RTN"",""SDECRECREQ"",58,0)"
^XMB(3.9,145987,2,582,0)=" D CONTACTLINK"
^XMB(3.9,145987,2,583,0)="""RTN"",""SDECRECREQ"",59,0)"
^XMB(3.9,145987,2,584,0)=" Q"
^XMB(3.9,145987,2,585,0)="""RTN"",""SDECRECREQ"",60,0)"
^XMB(3.9,145987,2,586,0)="APPREQLINK ; Associate new APPT Req vs. old RECALL Req"
^XMB(3.9,145987,2,587,0)="""RTN"",""SDECRECREQ"",61,0)"
^XMB(3.9,145987,2,588,0)=" S DFN40985=$P(SD409840REC,U,5)"
^XMB(3.9,145987,2,589,0)="""RTN"",""SDECRECREQ"",62,0)"
^XMB(3.9,145987,2,590,0)=" S REQLINK=IEN40985_"";SDEC(409.85,"""
^XMB(3.9,145987,2,591,0)="""RTN"",""SDECRECREQ"",63,0)"
^XMB(3.9,145987,2,592,0)=" S $P(^SDEC(409.84,SDECAPTID,2),""^"",1)=REQLINK"
^XMB(3.9,145987,2,593,0)="""RTN"",""SDECRECREQ"",64,0)"
^XMB(3.9,145987,2,594,0)=" Q"
^XMB(3.9,145987,2,595,0)="""RTN"",""SDECRECREQ"",65,0)"
^XMB(3.9,145987,2,596,0)="CONTACTLINK ; update contact attempts"
