^XMB(3.9,145956,2,295,0)="""RTN"")"
^XMB(3.9,145956,2,296,0)=6
^XMB(3.9,145956,2,297,0)="""RTN"",""TIUALRT"")"
^XMB(3.9,145956,2,298,0)="0^4^B72816199"
^XMB(3.9,145956,2,299,0)="""RTN"",""TIUALRT"",1,0)"
^XMB(3.9,145956,2,300,0)="TIUALRT ; SLC/JER,AJB - SEND ALERTS ;11/08/23  10:36"
^XMB(3.9,145956,2,301,0)="""RTN"",""TIUALRT"",2,0)"
^XMB(3.9,145956,2,302,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**21,84,79,88,58,61,151,158,175,221,227,259,355,358,353,357**;Jun 20, 1997;Build 0"
^XMB(3.9,145956,2,303,0)="""RTN"",""TIUALRT"",3,0)"
^XMB(3.9,145956,2,304,0)=" ;"
^XMB(3.9,145956,2,305,0)="""RTN"",""TIUALRT"",4,0)"
^XMB(3.9,145956,2,306,0)=" ; Reference to ^DPT( supported by ICR #10035"
^XMB(3.9,145956,2,307,0)="""RTN"",""TIUALRT"",5,0)"
^XMB(3.9,145956,2,308,0)=" ; Reference to ^VA(200 supported by ICR #4329"
^XMB(3.9,145956,2,309,0)="""RTN"",""TIUALRT"",6,0)"
^XMB(3.9,145956,2,310,0)=" ; Reference to ONEHR^ORACCESS supported by ICR #7356"
^XMB(3.9,145956,2,311,0)="""RTN"",""TIUALRT"",7,0)"
^XMB(3.9,145956,2,312,0)=" ;"
^XMB(3.9,145956,2,313,0)="""RTN"",""TIUALRT"",8,0)"
^XMB(3.9,145956,2,314,0)=" Q"
^XMB(3.9,145956,2,315,0)="""RTN"",""TIUALRT"",9,0)"
^XMB(3.9,145956,2,316,0)="SEND(DA,OVERDUE,TIUXQA) ;"
^XMB(3.9,145956,2,317,0)="""RTN"",""TIUALRT"",10,0)"
^XMB(3.9,145956,2,318,0)=" ; DA         document IEN"
^XMB(3.9,145956,2,319,0)="""RTN"",""TIUALRT"",11,0)"
^XMB(3.9,145956,2,320,0)=" ; [OVERDUE]  send alert as overdue"
^XMB(3.9,145956,2,321,0)="""RTN"",""TIUALRT"",12,0)"
^XMB(3.9,145956,2,322,0)=" ; [TIUXQA]   third party alerts, passed by reference, TIUXQA(<IEN>)=""""  recipients"
^XMB(3.9,145956,2,323,0)="""RTN"",""TIUALRT"",13,0)"
^XMB(3.9,145956,2,324,0)=" ;            TIUXQA=0 delete current alerts, TIUXQA=1 keep current alerts"
^XMB(3.9,145956,2,325,0)="""RTN"",""TIUALRT"",14,0)"
^XMB(3.9,145956,2,326,0)=" N ADDENDUM,FDA,NODE,TIUAAALRT,TIUDPRM,TIUPRM0,TIUPRM1,XQA,XQAARCH,XQADATA,XQADFN,XQAID,XQAMSG,XQAROU"
^XMB(3.9,145956,2,327,0)="""RTN"",""TIUALRT"",15,0)"
^XMB(3.9,145956,2,328,0)=" S NODE(0)=$G(^TIU(8925,+DA,0)) Q:'NODE(0)  S NODE(12)=$G(^(12)),NODE(13)=$G(^(13))"
^XMB(3.9,145956,2,329,0)="""RTN"",""TIUALRT"",16,0)"
^XMB(3.9,145956,2,330,0)=" S NODE(14)=$G(^TIU(8925,+DA,14)),NODE(15)=$G(^(15)),OVERDUE=+$G(OVERDUE,0),ZTREQ=""@"""
^XMB(3.9,145956,2,331,0)="""RTN"",""TIUALRT"",17,0)"
^XMB(3.9,145956,2,332,0)=" S ADDENDUM=$S($P($G(^TIU(8925.1,+NODE(0),0)),U)[""ADDENDUM""&$P(NODE(0),U,6):1,1:0) ;    is document an addendum?"
^XMB(3.9,145956,2,333,0)="""RTN"",""TIUALRT"",18,0)"
^XMB(3.9,145956,2,334,0)=" I '$G(TIUXQA) D ALERTDEL(DA) ;                                                         delete alerts for a document"
^XMB(3.9,145956,2,335,0)="""RTN"",""TIUALRT"",19,0)"
^XMB(3.9,145956,2,336,0)=" D SETPARM^TIULE S (TIUDPRM(0),TIUDPRM(5))="""" D DOCPRM^TIULC1(+NODE(0),.TIUDPRM,DA)  ;  get basic & document parameters"
^XMB(3.9,145956,2,337,0)="""RTN"",""TIUALRT"",20,0)"
^XMB(3.9,145956,2,338,0)=" S TIUAAALRT=$G(TIUADDL,0) ;                                                            from nightly task, if additional signer overdue, TIUADDL=1"
^XMB(3.9,145956,2,339,0)="""RTN"",""TIUALRT"",21,0)"
^XMB(3.9,145956,2,340,0)=" Q:'$D(TIUDPRM(0))  ;                                                                   quit if no document parameters (? - original code)"
^XMB(3.9,145956,2,341,0)="""RTN"",""TIUALRT"",22,0)"
^XMB(3.9,145956,2,342,0)=" Q:'+$P(TIUPRM1,U,7)  ;                                                                 quit if notification enable date not set"
^XMB(3.9,145956,2,343,0)="""RTN"",""TIUALRT"",23,0)"
^XMB(3.9,145956,2,344,0)=" Q:+$P(TIUPRM1,U,7)>+$P(NODE(12),U)  ;                                                  quit if entry date/time earlier than notification date"
^XMB(3.9,145956,2,345,0)="""RTN"",""TIUALRT"",24,0)"
^XMB(3.9,145956,2,346,0)=" Q:$P(NODE(0),U,5)=15  ;                                                                quit, document status is retracted"
^XMB(3.9,145956,2,347,0)="""RTN"",""TIUALRT"",25,0)"
^XMB(3.9,145956,2,348,0)=" N TIU S TIU(""Status"")=$P(NODE(0),U,5),TIU(""Author/Dictator"")=$P(NODE(12),U,2) ;        set field data"
^XMB(3.9,145956,2,349,0)="""RTN"",""TIUALRT"",26,0)"
^XMB(3.9,145956,2,350,0)=" S TIU(""Expected Signer"")=$P(NODE(12),U,4),TIU(""Signature Date/Time"")=$P(NODE(15),U)"
^XMB(3.9,145956,2,351,0)="""RTN"",""TIUALRT"",27,0)"
^XMB(3.9,145956,2,352,0)=" S TIU(""Expected Co-signer"")=$P(NODE(12),U,8),TIU(""Attending Physician"")=$P(NODE(12),U,9)"
^XMB(3.9,145956,2,353,0)="""RTN"",""TIUALRT"",28,0)"
^XMB(3.9,145956,2,354,0)=" S TIU(""Co-signature Date/Time"")=$P(NODE(15),U,7)"
^XMB(3.9,145956,2,355,0)="""RTN"",""TIUALRT"",29,0)"
^XMB(3.9,145956,2,356,0)=" I +$G(TIUXQA)!(TIU(""Status"")>6) G TPA ;                                                send only third party or additional signer alerts"
^XMB(3.9,145956,2,357,0)="""RTN"",""TIUALRT"",30,0)"
^XMB(3.9,145956,2,358,0)=" I +$P(TIUDPRM(0),U,2),TIU(""Status"")=3,'+$P(NODE(13),U,4) Q  ;                          requires release, unreleased, no release date/time"
^XMB(3.9,145956,2,359,0)="""RTN"",""TIUALRT"",31,0)"
^XMB(3.9,145956,2,360,0)=" I +$P(TIUDPRM(0),U,3),TIU(""Status"")=4,'+$P(NODE(13),U,5) Q  ;                          requires verification, unverified, no verification date/time"
^XMB(3.9,145956,2,361,0)="""RTN"",""TIUALRT"",32,0)"
^XMB(3.9,145956,2,362,0)=" I 'TIU(""Expected Signer""),TIU(""Author/Dictator"") D  ;                                  no expected signer, set expected signer to author/dictator"
^XMB(3.9,145956,2,363,0)="""RTN"",""TIUALRT"",33,0)"
^XMB(3.9,145956,2,364,0)=" . S TIU(""Expected Signer"")=TIU(""Author/Dictator"")"
^XMB(3.9,145956,2,365,0)="""RTN"",""TIUALRT"",34,0)"
^XMB(3.9,145956,2,366,0)=" . S FDA(8925,DA_"","",1204)=TIU(""Expected Signer"") D FILE^DIE(,""FDA"")"
^XMB(3.9,145956,2,367,0)="""RTN"",""TIUALRT"",35,0)"
^XMB(3.9,145956,2,368,0)=" I 'TIU(""Expected Co-signer""),TIU(""Attending Physician"") D  ;                           no co-signer, set expected co-signer to attending physician"
^XMB(3.9,145956,2,369,0)="""RTN"",""TIUALRT"",36,0)"
^XMB(3.9,145956,2,370,0)=" . S TIU(""Expected Co-signer"")=TIU(""Attending Physician"")"
^XMB(3.9,145956,2,371,0)="""RTN"",""TIUALRT"",37,0)"
^XMB(3.9,145956,2,372,0)=" . S FDA(8925,DA_"","",1208)=$P(NODE(12),U,9) D FILE^DIE(,""FDA"")"
^XMB(3.9,145956,2,373,0)="""RTN"",""TIUALRT"",38,0)"
^XMB(3.9,145956,2,374,0)=" ; signer as recipient"
^XMB(3.9,145956,2,375,0)="""RTN"",""TIUALRT"",39,0)"
^XMB(3.9,145956,2,376,0)=" I $P(TIUDPRM(0),U,4),'TIU(""Signature Date/Time""),TIU(""Expected Signer"") D  ;           require author to sign, no signature"
^XMB(3.9,145956,2,377,0)="""RTN"",""TIUALRT"",40,0)"
^XMB(3.9,145956,2,378,0)=" . Q:TIU(""Status"")>5  S XQA(TIU(""Expected Signer""))="""" ;                                verify status, add as recipient"
^XMB(3.9,145956,2,379,0)="""RTN"",""TIUALRT"",41,0)"
^XMB(3.9,145956,2,380,0)=" ; co-signer as recipient"
^XMB(3.9,145956,2,381,0)="""RTN"",""TIUALRT"",42,0)"
^XMB(3.9,145956,2,382,0)=" I TIU(""Expected Co-signer""),'TIU(""Co-signature Date/Time""),TIU(""Status"")<7 D"
^XMB(3.9,145956,2,383,0)="""RTN"",""TIUALRT"",43,0)"
^XMB(3.9,145956,2,384,0)=" . I '$P(TIUDPRM(0),U,20),$P(TIUDPRM(0),U,4),'TIU(""Signature Date/Time"") Q  ;           send co-signer alert, require author to sign, unsigned"
^XMB(3.9,145956,2,385,0)="""RTN"",""TIUALRT"",44,0)"
^XMB(3.9,145956,2,386,0)=" . S XQA(TIU(""Expected Co-signer""))="""""
^XMB(3.9,145956,2,387,0)="""RTN"",""TIUALRT"",45,0)"
^XMB(3.9,145956,2,388,0)="TPA S TIUXQA=0 F  S TIUXQA=$O(TIUXQA(TIUXQA)) Q:'TIUXQA  S XQA(TIUXQA)="""" ;                set third party alert recipients"
^XMB(3.9,145956,2,389,0)="""RTN"",""TIUALRT"",46,0)"
^XMB(3.9,145956,2,390,0)=" I ADDENDUM,'TIUAAALRT D SENDADD(DA) ;                                                  if from nightly task, do not send addendum added alert"
^XMB(3.9,145956,2,391,0)="""RTN"",""TIUALRT"",47,0)"
^XMB(3.9,145956,2,392,0)=" Q:'$D(XQA)&'$O(^TIU(8925.7,""B"",DA,0))  ;                                               quit, no recipients or additional signers"
^XMB(3.9,145956,2,393,0)="""RTN"",""TIUALRT"",48,0)"
^XMB(3.9,145956,2,394,0)=" N D0,PT,XQALERR D PATVADPT^TIULV(.PT,$P(NODE(0),U,2)) ;                                get patient demographics"
^XMB(3.9,145956,2,395,0)="""RTN"",""TIUALRT"",49,0)"
^XMB(3.9,145956,2,396,0)=" ; if recipients, setup alert data and send alert"
^XMB(3.9,145956,2,397,0)="""RTN"",""TIUALRT"",50,0)"
^XMB(3.9,145956,2,398,0)=" I $D(XQA) D XQADATA(DA,.PT),SETUP^XQALERT Q:+$G(TIUXQA)  K XQA ;                       send , if third party alert quit"
^XMB(3.9,145956,2,399,0)="""RTN"",""TIUALRT"",51,0)"
^XMB(3.9,145956,2,400,0)=" I $P(NODE(0),U,5)>5,$O(^TIU(8925.7,""B"",DA,0)) D  ;                                     for a signed document, check for additional signers"
^XMB(3.9,145956,2,401,0)="""RTN"",""TIUALRT"",52,0)"
^XMB(3.9,145956,2,402,0)=" . N I S I=0 F  S I=$O(^TIU(8925.7,""AC"",+NODE(12),DA,I)) Q:'I  D  ;                     traverse ""AC"" for outstanding additional signers"
^XMB(3.9,145956,2,403,0)="""RTN"",""TIUALRT"",53,0)"
^XMB(3.9,145956,2,404,0)=" . . I '$D(^TIU(8925.7,I,0)) K ^TIU(8925.7,""AC"",+NODE(12),DA,I) Q  ;                    remove ""AC"" if no entry"
^XMB(3.9,145956,2,405,0)="""RTN"",""TIUALRT"",54,0)"
^XMB(3.9,145956,2,406,0)=" . . I +$P($G(^TIU(8925.7,I,0)),U,4) K ^TIU(8925.7,""AC"",+NODE(12),DA,I) Q  ;            remove ""AC"" if signed"
^XMB(3.9,145956,2,407,0)="""RTN"",""TIUALRT"",55,0)"
^XMB(3.9,145956,2,408,0)=" . . N USR S USR=$P($G(^TIU(8925.7,I,0)),U,3) S:+USR XQA(USR)="""" ;                      set additional signer"
^XMB(3.9,145956,2,409,0)="""RTN"",""TIUALRT"",56,0)"
^XMB(3.9,145956,2,410,0)=" Q:'$D(XQA)  ;                                                                          quit, no outstanding additional signers"
^XMB(3.9,145956,2,411,0)="""RTN"",""TIUALRT"",57,0)"
^XMB(3.9,145956,2,412,0)=" D XQADATA(DA,.PT,1),SETUP^XQALERT ;                                                    send additional signer alert(s)"
^XMB(3.9,145956,2,413,0)="""RTN"",""TIUALRT"",58,0)"
^XMB(3.9,145956,2,414,0)=" Q"
^XMB(3.9,145956,2,415,0)="""RTN"",""TIUALRT"",59,0)"
^XMB(3.9,145956,2,416,0)="XQADATA(DA,PT,AS) ; setup message text"
^XMB(3.9,145956,2,417,0)="""RTN"",""TIUALRT"",60,0)"
^XMB(3.9,145956,2,418,0)=" ; DA  document IEN      PT  patient demographics [passed by reference]"
^XMB(3.9,145956,2,419,0)="""RTN"",""TIUALRT"",61,0)"
^XMB(3.9,145956,2,420,0)=" ; AS  additional signer [default 0]"
^XMB(3.9,145956,2,421,0)="""RTN"",""TIUALRT"",62,0)"
^XMB(3.9,145956,2,422,0)=" S XQAARCH=24000,XQADATA=+DA_U,XQADFN=$P(NODE(0),U,2),XQAID=""TIU""_DA,XQAROU=""ACT^TIUALRT"""
^XMB(3.9,145956,2,423,0)="""RTN"",""TIUALRT"",63,0)"
^XMB(3.9,145956,2,424,0)=" S XQAMSG=PT(""PNM"")_"" (""_$E(PT(""PNM""),1)_$P(PT(""SSN""),""-"",3)_""): """
^XMB(3.9,145956,2,425,0)="""RTN"",""TIUALRT"",64,0)"
^XMB(3.9,145956,2,426,0)=" S XQAMSG=XQAMSG_$S(TIU(""Status"")=5&TIU(""Expected Co-signer"")&$P(TIUDPRM(0),U,20):""UNSIGNED/UNCOSIGNED"",1:$$UP^XLFSTR($$GET1^DIQ(8925,DA,.05)))"
^XMB(3.9,145956,2,427,0)="""RTN"",""TIUALRT"",65,0)"
^XMB(3.9,145956,2,428,0)=" S XQAMSG=XQAMSG_$S($P(NODE(0),U,9)=""P"":"" STAT "",1:"" "")_$$PNAME^TIULC1(+NODE(0))"
^XMB(3.9,145956,2,429,0)="""RTN"",""TIUALRT"",66,0)"
^XMB(3.9,145956,2,430,0)=" S XQAMSG=XQAMSG_$S(OVERDUE:"" Dated ""_$$DATE^TIULS(+NODE(13))_"" OVERDUE for "",1:"" available for "")"
^XMB(3.9,145956,2,431,0)="""RTN"",""TIUALRT"",67,0)"
^XMB(3.9,145956,2,432,0)=" S XQAMSG=XQAMSG_$S(TIU(""Status"")'>5:""SIGNATURE"",TIU(""Status"")=6&('$G(AS)):""COSIGNATURE"",1:""ADDITIONAL SIGNATURE"")"
^XMB(3.9,145956,2,433,0)="""RTN"",""TIUALRT"",68,0)"
^XMB(3.9,145956,2,434,0)=" Q"
^XMB(3.9,145956,2,435,0)="""RTN"",""TIUALRT"",69,0)"
^XMB(3.9,145956,2,436,0)="ACT ; Act on alerts"
^XMB(3.9,145956,2,437,0)="""RTN"",""TIUALRT"",70,0)"
^XMB(3.9,145956,2,438,0)=" N TIUQUIK,TIUDA,TIUPRM0,TIUPRM1,TIUPRM3,RSTOK S TIUQUIK=1 K XQAKILL"
^XMB(3.9,145956,2,439,0)="""RTN"",""TIUALRT"",71,0)"
^XMB(3.9,145956,2,440,0)=" I $$ONEHR^ORACCESS D  Q  ; *353 agp"
^XMB(3.9,145956,2,441,0)="""RTN"",""TIUALRT"",72,0)"
^XMB(3.9,145956,2,442,0)=" . W !,""Site has migrated to Electronic Health Record."""
^XMB(3.9,145956,2,443,0)="""RTN"",""TIUALRT"",73,0)"
^XMB(3.9,145956,2,444,0)=" . W !,""TIU List Manager access not allowed."""
^XMB(3.9,145956,2,445,0)="""RTN"",""TIUALRT"",74,0)"
^XMB(3.9,145956,2,446,0)=" . I $$READ^TIUU(""EA"",""RETURN to continue..."")"
^XMB(3.9,145956,2,447,0)="""RTN"",""TIUALRT"",75,0)"
^XMB(3.9,145956,2,448,0)=" S TIUDA=$P(XQADATA,U)"
^XMB(3.9,145956,2,449,0)="""RTN"",""TIUALRT"",76,0)"
^XMB(3.9,145956,2,450,0)=" I '$D(^TIU(8925,+TIUDA,0)) D ALERTDEL(TIUDA) Q"
^XMB(3.9,145956,2,451,0)="""RTN"",""TIUALRT"",77,0)"
^XMB(3.9,145956,2,452,0)=" S RSTOK=$$DOCCHK^TIULRR(TIUDA)"
^XMB(3.9,145956,2,453,0)="""RTN"",""TIUALRT"",78,0)"
^XMB(3.9,145956,2,454,0)=" I RSTOK'>0 D  Q"
^XMB(3.9,145956,2,455,0)="""RTN"",""TIUALRT"",79,0)"
^XMB(3.9,145956,2,456,0)=" . W !!,$C(7),""Ok, no harm done..."",! ; Echo denial message"
^XMB(3.9,145956,2,457,0)="""RTN"",""TIUALRT"",80,0)"
^XMB(3.9,145956,2,458,0)=" . I $$READ^TIUU(""EA"",""RETURN to continue..."") ; pause"
^XMB(3.9,145956,2,459,0)="""RTN"",""TIUALRT"",81,0)"
^XMB(3.9,145956,2,460,0)=" I $P(^TIU(8925,+TIUDA,0),U,5)>6,'+$$ISSIGNR(TIUDA,DUZ) S XQAKILL=1 ; *357"
^XMB(3.9,145956,2,461,0)="""RTN"",""TIUALRT"",82,0)"
^XMB(3.9,145956,2,462,0)=" D:'$D(TIUPRM0)!'$D(TIUPRM1) SETPARM^TIULE"
^XMB(3.9,145956,2,463,0)="""RTN"",""TIUALRT"",83,0)"
^XMB(3.9,145956,2,464,0)=" D EN^VALM(""TIU BROWSE FOR CLINICIAN"")"
^XMB(3.9,145956,2,465,0)="""RTN"",""TIUALRT"",84,0)"
^XMB(3.9,145956,2,466,0)=" Q"
^XMB(3.9,145956,2,467,0)="""RTN"",""TIUALRT"",85,0)"
^XMB(3.9,145956,2,468,0)="ISSIGNR(DA,USER) ; *357, is user an additional signer (or surrogate for) and is signature outstanding?"
^XMB(3.9,145956,2,469,0)="""RTN"",""TIUALRT"",86,0)"
^XMB(3.9,145956,2,470,0)=" N TIUAS,TIUY S (TIUAS,TIUY)=0"
^XMB(3.9,145956,2,471,0)="""RTN"",""TIUALRT"",87,0)"
^XMB(3.9,145956,2,472,0)=" F  S TIUAS=$O(^TIU(8925.7,""AE"",DA,TIUAS)) Q:'TIUAS!(+TIUY)  I USER=TIUAS!(USER=$$ACTVSURO^XQALSURO(TIUAS)) D"
^XMB(3.9,145956,2,473,0)="""RTN"",""TIUALRT"",88,0)"
^XMB(3.9,145956,2,474,0)=" . N NODE0 S NODE0=$G(^TIU(8925.7,+$O(^TIU(8925.7,""AE"",DA,TIUAS,0)),0))"
^XMB(3.9,145956,2,475,0)="""RTN"",""TIUALRT"",89,0)"
^XMB(3.9,145956,2,476,0)=" . I +$L(NODE0),+$P(NODE0,U,4)'>0 S TIUY=1"
^XMB(3.9,145956,2,477,0)="""RTN"",""TIUALRT"",90,0)"
^XMB(3.9,145956,2,478,0)=" I 'TIUY D TASKALRT(DA) ; resend alert(s) for a document"
^XMB(3.9,145956,2,479,0)="""RTN"",""TIUALRT"",91,0)"
^XMB(3.9,145956,2,480,0)=" Q TIUY"
^XMB(3.9,145956,2,481,0)="""RTN"",""TIUALRT"",92,0)"
^XMB(3.9,145956,2,482,0)="TASKALRT(DA) ; resend alert(s) for a document via a delayed task *357"
^XMB(3.9,145956,2,483,0)="""RTN"",""TIUALRT"",93,0)"
^XMB(3.9,145956,2,484,0)=" N TIUADDL,ZTDESC,ZTDTH,ZTIO,ZTRTN,ZTSAVE,ZTSK S TIUADDL=1,ZTDESC=""SEND^TIUALRT(""_DA_"")"",ZTDTH=+$H_"",""_($P($H,"","",2)+10)"
^XMB(3.9,145956,2,485,0)="""RTN"",""TIUALRT"",94,0)"
^XMB(3.9,145956,2,486,0)=" S ZTIO="""",ZTSAVE(""TIUADDL"")="""",ZTSAVE(""DA"")="""",ZTRTN=""SEND^TIUALRT(DA)"" D ^%ZTLOAD"
^XMB(3.9,145956,2,487,0)="""RTN"",""TIUALRT"",95,0)"
^XMB(3.9,145956,2,488,0)=" Q"
^XMB(3.9,145956,2,489,0)="""RTN"",""TIUALRT"",96,0)"
^XMB(3.9,145956,2,490,0)="SENDTRAN(DA) ; Generate ""Send back to transcription"" alert"
^XMB(3.9,145956,2,491,0)="""RTN"",""TIUALRT"",97,0)"
^XMB(3.9,145956,2,492,0)=" N TIUEDT,TIU0,TIUPNM,TIUSSN,TIUTRAN,TIU,XQA,XQAMSG,TIUMSG"
^XMB(3.9,145956,2,493,0)="""RTN"",""TIUALRT"",98,0)"
^XMB(3.9,145956,2,494,0)=" N TIUESNR,TIU12,TIU13,TIU14,TIU15,TIUTYP"
^XMB(3.9,145956,2,495,0)="""RTN"",""TIUALRT"",99,0)"
^XMB(3.9,145956,2,496,0)=" N XQAID ;259"
^XMB(3.9,145956,2,497,0)="""RTN"",""TIUALRT"",100,0)"
^XMB(3.9,145956,2,498,0)=" I '$D(TIUPRM0)!'$D(TIUPRM1) D SETPARM^TIULE"
^XMB(3.9,145956,2,499,0)="""RTN"",""TIUALRT"",101,0)"
^XMB(3.9,145956,2,500,0)=" D ALERTDEL(DA)"
^XMB(3.9,145956,2,501,0)="""RTN"",""TIUALRT"",102,0)"
^XMB(3.9,145956,2,502,0)=" ; Don't send if notifications not enabled"
^XMB(3.9,145956,2,503,0)="""RTN"",""TIUALRT"",103,0)"
^XMB(3.9,145956,2,504,0)=" I '+$P(TIUPRM1,U,7) Q"
^XMB(3.9,145956,2,505,0)="""RTN"",""TIUALRT"",104,0)"
^XMB(3.9,145956,2,506,0)=" S TIU0=$G(^TIU(8925,+DA,0)),TIU12=$G(^(12)),TIU13=$G(^(13))"
^XMB(3.9,145956,2,507,0)="""RTN"",""TIUALRT"",105,0)"
^XMB(3.9,145956,2,508,0)=" S TIU14=$G(^TIU(8925,+DA,14)),TIU15=$G(^(15))"
^XMB(3.9,145956,2,509,0)="""RTN"",""TIUALRT"",106,0)"
^XMB(3.9,145956,2,510,0)=" S TIUPNM=$E($P($G(^DPT(+$P(TIU0,U,2),0)),U),1,9)"
^XMB(3.9,145956,2,511,0)="""RTN"",""TIUALRT"",107,0)"
^XMB(3.9,145956,2,512,0)=" S TIUEDT=$$DATE^TIULS($P(TIU0,U,7))"
^XMB(3.9,145956,2,513,0)="""RTN"",""TIUALRT"",108,0)"
^XMB(3.9,145956,2,514,0)=" S TIUTYP=$$PNAME^TIULC1(+$G(TIU0))"
^XMB(3.9,145956,2,515,0)="""RTN"",""TIUALRT"",109,0)"
^XMB(3.9,145956,2,516,0)=" S TIUTRAN=$P(TIU13,U,2),TIUESNR=$P(TIU12,U,2) ; **175**"
^XMB(3.9,145956,2,517,0)="""RTN"",""TIUALRT"",110,0)"
^XMB(3.9,145956,2,518,0)=" D PATVADPT^TIULV(.TIU,+$P(TIU0,U,2)) ;Used to get SSN. Date not important."
^XMB(3.9,145956,2,519,0)="""RTN"",""TIUALRT"",111,0)"
^XMB(3.9,145956,2,520,0)=" S TIUSSN=$E(TIUPNM,1)_$P($G(TIU(""SSN"")),""-"",3)"
^XMB(3.9,145956,2,521,0)="""RTN"",""TIUALRT"",112,0)"
^XMB(3.9,145956,2,522,0)=" ;I $D(^VA(200,+TIUTRAN,0)) S XQA(TIUTRAN)="""""
^XMB(3.9,145956,2,523,0)="""RTN"",""TIUALRT"",113,0)"
^XMB(3.9,145956,2,524,0)=" I $$PROVIDER^XUSER(TIUTRAN) S XQA(TIUTRAN)="""" ;ICR #2343 In file 200 & not terminated"
^XMB(3.9,145956,2,525,0)="""RTN"",""TIUALRT"",114,0)"
^XMB(3.9,145956,2,526,0)=" Q:$D(XQA)'>9"
^XMB(3.9,145956,2,527,0)="""RTN"",""TIUALRT"",115,0)"
^XMB(3.9,145956,2,528,0)=" S TIUMSG=$S(TIUTRAN=TIUESNR:"" needs editing"",1:"" needs retranscription."")"
^XMB(3.9,145956,2,529,0)="""RTN"",""TIUALRT"",116,0)"
^XMB(3.9,145956,2,530,0)=" S XQAID=""TIU""_+DA"
^XMB(3.9,145956,2,531,0)="""RTN"",""TIUALRT"",117,0)"
^XMB(3.9,145956,2,532,0)=" S XQAMSG=TIUPNM_"" (""_TIUSSN_""): ""_TIUTYP_TIUMSG"
^XMB(3.9,145956,2,533,0)="""RTN"",""TIUALRT"",118,0)"
^XMB(3.9,145956,2,534,0)=" D SETUP^XQALERT"
^XMB(3.9,145956,2,535,0)="""RTN"",""TIUALRT"",119,0)"
^XMB(3.9,145956,2,536,0)=" Q"
^XMB(3.9,145956,2,537,0)="""RTN"",""TIUALRT"",120,0)"
^XMB(3.9,145956,2,538,0)="SENDADD(DA) ; Generates ""Addendum added"" alert"
^XMB(3.9,145956,2,539,0)="""RTN"",""TIUALRT"",121,0)"
^XMB(3.9,145956,2,540,0)=" N TIU12,TIU13,TIU14,TIU15,TIU0,TIUPNM,TIUSSN,TIUTRAN,TIU,TIUTITLE,TIUDPRM"
^XMB(3.9,145956,2,541,0)="""RTN"",""TIUALRT"",122,0)"
^XMB(3.9,145956,2,542,0)=" N XQA,XQAMSG,XQAFLG,XQADATA,XQAROU,TIUESNR,TIUDATE,TIUESNM,TIUO0,TIUO12,TIUO13"
^XMB(3.9,145956,2,543,0)="""RTN"",""TIUALRT"",123,0)"
^XMB(3.9,145956,2,544,0)=" N XQAID,TIUECSNR ;P259"
^XMB(3.9,145956,2,545,0)="""RTN"",""TIUALRT"",124,0)"
^XMB(3.9,145956,2,546,0)=" I '$D(TIUPRM0)!'$D(TIUPRM1) D SETPARM^TIULE"
^XMB(3.9,145956,2,547,0)="""RTN"",""TIUALRT"",125,0)"
^XMB(3.9,145956,2,548,0)=" D ADDENDEL(DA)"
^XMB(3.9,145956,2,549,0)="""RTN"",""TIUALRT"",126,0)"
^XMB(3.9,145956,2,550,0)=" ; Don't send if notifications not enabled"
^XMB(3.9,145956,2,551,0)="""RTN"",""TIUALRT"",127,0)"
^XMB(3.9,145956,2,552,0)=" I '+$P(TIUPRM1,U,7) Q"
^XMB(3.9,145956,2,553,0)="""RTN"",""TIUALRT"",128,0)"
^XMB(3.9,145956,2,554,0)=" S TIU0=$G(^TIU(8925,+DA,0))"
^XMB(3.9,145956,2,555,0)="""RTN"",""TIUALRT"",129,0)"
^XMB(3.9,145956,2,556,0)=" ; Only send upon completion"
^XMB(3.9,145956,2,557,0)="""RTN"",""TIUALRT"",130,0)"
^XMB(3.9,145956,2,558,0)=" Q:+$P(TIU0,U,5)'>6"
^XMB(3.9,145956,2,559,0)="""RTN"",""TIUALRT"",131,0)"
^XMB(3.9,145956,2,560,0)=" D DOCPRM^TIULC1(+TIU0,.TIUDPRM,DA) Q:'+$P(TIUDPRM(0),U,17)"
^XMB(3.9,145956,2,561,0)="""RTN"",""TIUALRT"",132,0)"
^XMB(3.9,145956,2,562,0)=" S TIU12=$G(^TIU(8925,+DA,12)),TIU13=$G(^(13)),TIU14=$G(^(14)),TIU15=$G(^(15))"
^XMB(3.9,145956,2,563,0)="""RTN"",""TIUALRT"",133,0)"
^XMB(3.9,145956,2,564,0)=" S TIUO0=$G(^TIU(8925,$P(TIU0,U,6),0)),TIUO12=$G(^(12)),TIUO13=$G(^(13))"
^XMB(3.9,145956,2,565,0)="""RTN"",""TIUALRT"",134,0)"
^XMB(3.9,145956,2,566,0)=" S TIUPNM=$E($$PTNAME^TIULC1(+$P(TIU0,U,2)),1,9)"
^XMB(3.9,145956,2,567,0)="""RTN"",""TIUALRT"",135,0)"
^XMB(3.9,145956,2,568,0)=" S TIUESNM=$$NAME^TIULS($$PERSNAME^TIULC1(+$P(TIU12,U,2)),""LAST,FI MI"")"
^XMB(3.9,145956,2,569,0)="""RTN"",""TIUALRT"",136,0)"
^XMB(3.9,145956,2,570,0)=" S TIUTITLE=$E($$PNAME^TIULC1(+TIUO0),1,20)"
^XMB(3.9,145956,2,571,0)="""RTN"",""TIUALRT"",137,0)"
^XMB(3.9,145956,2,572,0)=" S TIUDATE=$S(+$P(TIUO13,U):$P(TIUO13,U),1:$G(DT))"
^XMB(3.9,145956,2,573,0)="""RTN"",""TIUALRT"",138,0)"
^XMB(3.9,145956,2,574,0)=" S TIUDATE=$$DATE^TIULS(TIUDATE)"
^XMB(3.9,145956,2,575,0)="""RTN"",""TIUALRT"",139,0)"
^XMB(3.9,145956,2,576,0)=" D PATVADPT^TIULV(.TIU,+$P(TIU0,U,2)) ;Used to get SSN. Date not important."
^XMB(3.9,145956,2,577,0)="""RTN"",""TIUALRT"",140,0)"
^XMB(3.9,145956,2,578,0)=" S TIUSSN=$E(TIUPNM,1)_$P($G(TIU(""SSN"")),""-"",3)"
^XMB(3.9,145956,2,579,0)="""RTN"",""TIUALRT"",141,0)"
^XMB(3.9,145956,2,580,0)=" S TIUTRAN=$P(TIU13,U,2)"
^XMB(3.9,145956,2,581,0)="""RTN"",""TIUALRT"",142,0)"
^XMB(3.9,145956,2,582,0)=" ;Expected Cosigner and Author of original document"
^XMB(3.9,145956,2,583,0)="""RTN"",""TIUALRT"",143,0)"
^XMB(3.9,145956,2,584,0)=" S TIUECSNR=$P($G(^TIU(8925,$P(TIU0,U,6),12)),U,8),TIUESNR=$P($G(^(12)),U,4)"
^XMB(3.9,145956,2,585,0)="""RTN"",""TIUALRT"",144,0)"
^XMB(3.9,145956,2,586,0)=" ; Not entered by Expected Signer: SET Expected Signer as recipient"
^XMB(3.9,145956,2,587,0)="""RTN"",""TIUALRT"",145,0)"
^XMB(3.9,145956,2,588,0)=" I TIUESNR'=TIUTRAN,$D(^VA(200,+TIUESNR,0)) S XQA(TIUESNR)="""""
^XMB(3.9,145956,2,589,0)="""RTN"",""TIUALRT"",146,0)"
^XMB(3.9,145956,2,590,0)=" ; Not entered by Expected Cosigner: SET Expected Cosigner as recipient"
^XMB(3.9,145956,2,591,0)="""RTN"",""TIUALRT"",147,0)"
^XMB(3.9,145956,2,592,0)=" ; VMP/RJT - *227 - If user is the expected cosigner, do not send alert"
^XMB(3.9,145956,2,593,0)="""RTN"",""TIUALRT"",148,0)"
^XMB(3.9,145956,2,594,0)=" I +TIUECSNR>0,(TIUECSNR'=DUZ),(TIUECSNR'=TIUTRAN),$D(^VA(200,+TIUECSNR,0)) S XQA(TIUECSNR)="""""
^XMB(3.9,145956,2,595,0)="""RTN"",""TIUALRT"",149,0)"
^XMB(3.9,145956,2,596,0)=" Q:$D(XQA)'>9"
^XMB(3.9,145956,2,597,0)="""RTN"",""TIUALRT"",150,0)"
^XMB(3.9,145956,2,598,0)=" S XQAID=""TIUADD""_+DA,XQADATA=+DA_U,XQAROU=""ACTADD^TIUALRT"""
^XMB(3.9,145956,2,599,0)="""RTN"",""TIUALRT"",151,0)"
^XMB(3.9,145956,2,600,0)=" S XQAMSG=TIUPNM_"" (""_TIUSSN_""): ADDENDUM to ""_TIUTITLE_"" of ""_TIUDATE_"" by ""_TIUESNM"
^XMB(3.9,145956,2,601,0)="""RTN"",""TIUALRT"",152,0)"
^XMB(3.9,145956,2,602,0)=" D SETUP^XQALERT"
^XMB(3.9,145956,2,603,0)="""RTN"",""TIUALRT"",153,0)"
^XMB(3.9,145956,2,604,0)=" Q"
