^XMB(3.9,145946,2,1152,0)=" S DIR(""?"",1)=""Enter a code from the list:  1 or 2.  Only insurance"""
^XMB(3.9,145946,2,1153,0)="""RTN"",""IBCMDT1"",20,0)"
^XMB(3.9,145946,2,1154,0)=" S DIR(""?"")=""companies with one or more plans can be selected."""
