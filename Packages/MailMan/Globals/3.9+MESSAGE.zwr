^XMB(3.9,145976,2,322,0)=" ; order of patch sequential numbers is recommended."
^XMB(3.9,145976,2,323,0)="""RTN"",""MAGGTU4D"",37,0)"
^XMB(3.9,145976,2,324,0)=" ; NOTE:"
