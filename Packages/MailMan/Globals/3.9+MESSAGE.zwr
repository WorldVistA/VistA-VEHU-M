^XMB(3.9,145953,2,826,0)="0^2^B1475907"
^XMB(3.9,145953,2,827,0)="""RTN"",""SDES2CANCELAPPT1"",1,0)"
^XMB(3.9,145953,2,828,0)="SDES2CANCELAPPT1 ;ALB/MGD - SDES2 CANCEL APPOINTMENT CONT. ; AUG 05 2024"
^XMB(3.9,145953,2,829,0)="""RTN"",""SDES2CANCELAPPT1"",2,0)"
^XMB(3.9,145953,2,830,0)=" ;;5.3;Scheduling;**886**;Aug 13, 1993;Build 0"
^XMB(3.9,145953,2,831,0)="""RTN"",""SDES2CANCELAPPT1"",3,0)"
^XMB(3.9,145953,2,832,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145953,2,833,0)="""RTN"",""SDES2CANCELAPPT1"",4,0)"
^XMB(3.9,145953,2,834,0)=" ;"
^XMB(3.9,145953,2,835,0)="""RTN"",""SDES2CANCELAPPT1"",5,0)"
^XMB(3.9,145953,2,836,0)="BEFOREEVENT(DFN,APPTSTARTTIME,CLINICIEN,SDATA) ;"
^XMB(3.9,145953,2,837,0)="""RTN"",""SDES2CANCELAPPT1"",6,0)"
^XMB(3.9,145953,2,838,0)=" N SDDA,SDCPHDL"
^XMB(3.9,145953,2,839,0)="""RTN"",""SDES2CANCELAPPT1"",7,0)"
^XMB(3.9,145953,2,840,0)=" S SDDA=$$SCIEN^SDECU2(DFN,CLINICIEN,APPTSTARTTIME)"
^XMB(3.9,145953,2,841,0)="""RTN"",""SDES2CANCELAPPT1"",8,0)"
^XMB(3.9,145953,2,842,0)=" S SDCPHDL=$$HANDLE^SDAMEVT(1),SDATA=SDDA_U_DFN_U_APPTSTARTTIME_U_CLINICIEN"
^XMB(3.9,145953,2,843,0)="""RTN"",""SDES2CANCELAPPT1"",9,0)"
^XMB(3.9,145953,2,844,0)=" D BEFORE^SDAMEVT(.SDATA,DFN,APPTSTARTTIME,CLINICIEN,SDDA,SDCPHDL)"
^XMB(3.9,145953,2,845,0)="""RTN"",""SDES2CANCELAPPT1"",10,0)"
^XMB(3.9,145953,2,846,0)=" Q $G(SDDA)"
^XMB(3.9,145953,2,847,0)="""RTN"",""SDES2CANCELAPPT1"",11,0)"
^XMB(3.9,145953,2,848,0)=" ;"
