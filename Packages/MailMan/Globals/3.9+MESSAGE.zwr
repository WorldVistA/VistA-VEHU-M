^XMB(3.9,145958,2,1634,0)=" K ^TMP($J,""WP"")"
^XMB(3.9,145958,2,1635,0)="""RTN"",""ORWDXA"",312,0)"
^XMB(3.9,145958,2,1636,0)=" D WP^DIE(100.845,ORFNM(1)_"",""_$P(ORIFN,"";"",2)_"",""_+ORIFN_"","",1,,""ORFH"")"
^XMB(3.9,145958,2,1637,0)="""RTN"",""ORWDXA"",313,0)"
