^XMB(3.9,145952,2,847,0)="""RTN"",""SDES2BLDAPPT2"",1,0)"
^XMB(3.9,145952,2,848,0)="SDES2BLDAPPT2 ;ALB/LAB,JAS,LAB,TAW,RN- VISTA SCHEDULING BUILDING APPT OBJECT FROM PATIENT ;JAN 29,2026"
^XMB(3.9,145952,2,849,0)="""RTN"",""SDES2BLDAPPT2"",2,0)"
^XMB(3.9,145952,2,850,0)=" ;;5.3;Scheduling;**871,877,880,916,909,929**;Aug 13, 1993;Build 0"
^XMB(3.9,145952,2,851,0)="""RTN"",""SDES2BLDAPPT2"",3,0)"
^XMB(3.9,145952,2,852,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145952,2,853,0)="""RTN"",""SDES2BLDAPPT2"",4,0)"
^XMB(3.9,145952,2,854,0)=" ;"
^XMB(3.9,145952,2,855,0)="""RTN"",""SDES2BLDAPPT2"",5,0)"
^XMB(3.9,145952,2,856,0)=" Q"
^XMB(3.9,145952,2,857,0)="""RTN"",""SDES2BLDAPPT2"",6,0)"
^XMB(3.9,145952,2,858,0)=" ;"
^XMB(3.9,145952,2,859,0)="""RTN"",""SDES2BLDAPPT2"",7,0)"
^XMB(3.9,145952,2,860,0)="GET2INFO(APPTOBJ,APPTIEN,SDDFN,RECCNT) ;"
^XMB(3.9,145952,2,861,0)="""RTN"",""SDES2BLDAPPT2"",8,0)"
^XMB(3.9,145952,2,862,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""DFN"")=SDDFN"
^XMB(3.9,145952,2,863,0)="""RTN"",""SDES2BLDAPPT2"",9,0)"
^XMB(3.9,145952,2,864,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""ICN"")=$$GETPATICN^SDESINPUTVALUTL(SDDFN)"
^XMB(3.9,145952,2,865,0)="""RTN"",""SDES2BLDAPPT2"",10,0)"
^XMB(3.9,145952,2,866,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""SSN"")=$$LAST4SSN^SDESINPUTVALUTL(SDDFN)"
^XMB(3.9,145952,2,867,0)="""RTN"",""SDES2BLDAPPT2"",11,0)"
^XMB(3.9,145952,2,868,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""DateOfBirth"")=$$FMTISO^SDAMUTDT($$GET1^DIQ(2,SDDFN_"","",.03,""I""))"
^XMB(3.9,145952,2,869,0)="""RTN"",""SDES2BLDAPPT2"",12,0)"
^XMB(3.9,145952,2,870,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""DateOfBirthInternal"")=$$GET1^DIQ(2,SDDFN_"","",.03,""I"")"
^XMB(3.9,145952,2,871,0)="""RTN"",""SDES2BLDAPPT2"",13,0)"
^XMB(3.9,145952,2,872,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""DateOfDeath"")=$$FMTISO^SDAMUTDT($$GET1^DIQ(2,SDDFN_"","",.351,""I""))"
^XMB(3.9,145952,2,873,0)="""RTN"",""SDES2BLDAPPT2"",14,0)"
^XMB(3.9,145952,2,874,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""EligibilityIEN"")=$$GET1^DIQ(2,SDDFN_"","",.361,""I"")"
^XMB(3.9,145952,2,875,0)="""RTN"",""SDES2BLDAPPT2"",15,0)"
^XMB(3.9,145952,2,876,0)=" S APPTOBJ(""Appointment"",RECCNT,""Patient"",""Eligibility"")=$$GET1^DIQ(2,SDDFN_"","",.361,""E"")"
^XMB(3.9,145952,2,877,0)="""RTN"",""SDES2BLDAPPT2"",16,0)"
