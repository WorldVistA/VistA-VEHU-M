^XMB(3.9,145949,2,462,0)=" Q"
^XMB(3.9,145949,2,463,0)="""RTN"",""PSXMISC1"",112,0)"
^XMB(3.9,145949,2,464,0)="TSTCHAR ; test each character of SIG for certain characters"
