^XMB(3.9,145946,2,4841,0)="""RTN"",""IBCNILK"",252,0)"
^XMB(3.9,145946,2,4842,0)=" ; Help code"
^XMB(3.9,145946,2,4843,0)="""RTN"",""IBCNILK"",253,0)"
^XMB(3.9,145946,2,4844,0)=" ; Input: None"
^XMB(3.9,145946,2,4845,0)="""RTN"",""IBCNILK"",254,0)"
^XMB(3.9,145946,2,4846,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,4847,0)="""RTN"",""IBCNILK"",255,0)"
^XMB(3.9,145946,2,4848,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,4849,0)="""RTN"",""IBCNILK"",256,0)"
