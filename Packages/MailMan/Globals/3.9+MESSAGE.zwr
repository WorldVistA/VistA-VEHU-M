^XMB(3.9,145944,2,1322,0)=" ;        D - Print the Date  "" - MM/DD/YY"""
^XMB(3.9,145944,2,1323,0)="""RTN"",""IBJDF42"",145,0)"
^XMB(3.9,145944,2,1324,0)=" ;        C - Print the Cont. ""(Continued)"""
