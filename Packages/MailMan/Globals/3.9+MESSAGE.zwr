^XMB(3.9,145949,2,495,0)="""RTN"",""PSXMISC1"",128,0)"
^XMB(3.9,145949,2,496,0)=" ;BHW;PSX*2*64;Changed Quit below from Q:+(^TMP... to Q +(^TMP..."
^XMB(3.9,145949,2,497,0)="""RTN"",""PSXMISC1"",129,0)"
