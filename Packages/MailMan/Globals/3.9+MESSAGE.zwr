^XMB(3.9,145935,2,241,0)="""RTN"",""PSOERXU7"")"
^XMB(3.9,145935,2,242,0)="0^1^B129576560"
^XMB(3.9,145935,2,243,0)="""RTN"",""PSOERXU7"",1,0)"
^XMB(3.9,145935,2,244,0)="PSOERXU7 ;ALB/BLB,RM - eRx Utilities/RPC's ; 11/27/2019 11:02am"
^XMB(3.9,145935,2,245,0)="""RTN"",""PSOERXU7"",2,0)"
^XMB(3.9,145935,2,246,0)=" ;;7.0;OUTPATIENT PHARMACY;**581,617,700,746,769,770**;DEC 1997;Build 0"
^XMB(3.9,145935,2,247,0)="""RTN"",""PSOERXU7"",3,0)"
^XMB(3.9,145935,2,248,0)=" ;"
^XMB(3.9,145935,2,249,0)="""RTN"",""PSOERXU7"",4,0)"
^XMB(3.9,145935,2,250,0)=" Q"
^XMB(3.9,145935,2,251,0)="""RTN"",""PSOERXU7"",5,0)"
^XMB(3.9,145935,2,252,0)="MEDDIS(ERXIEN,LINE) ;"
^XMB(3.9,145935,2,253,0)="""RTN"",""PSOERXU7"",6,0)"
^XMB(3.9,145935,2,254,0)=" N DRUG,DIEN,QTY,DAYS,WDATE,EFDATE,REFILL,EXDATE,LFDATE,DIRECT,CLQ,USC,PUC,F,IENS,I,LTXT"
^XMB(3.9,145935,2,255,0)="""RTN"",""PSOERXU7"",7,0)"
^XMB(3.9,145935,2,256,0)=" N RXIEN,RXNUM,INS,DDAT,PARIEN,OREFILL,DLOOP,DIARY,MIEN,MTYPE,DATAIEN,QUOM,SIG1TXT,SIG1ARY,II"
^XMB(3.9,145935,2,257,0)="""RTN"",""PSOERXU7"",8,0)"
^XMB(3.9,145935,2,258,0)=" S F=52.49311"
^XMB(3.9,145935,2,259,0)="""RTN"",""PSOERXU7"",9,0)"
^XMB(3.9,145935,2,260,0)=" I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,261,0)="""RTN"",""PSOERXU7"",10,0)"
^XMB(3.9,145935,2,262,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""****************************MEDICATION DISPENSED****************************"")"
^XMB(3.9,145935,2,263,0)="""RTN"",""PSOERXU7"",11,0)"
^XMB(3.9,145935,2,264,0)=" I $G(SDERXFLG) D SET^VALM10(LINE,""                              MEDICATION DISPENSED                            ""),CNTRL^VALM10(LINE,1,80,$G(IOUON)_$G(IOINHI),$G(IOUOFF)_$G(IOINORM))"
^XMB(3.9,145935,2,265,0)="""RTN"",""PSOERXU7"",12,0)"
^XMB(3.9,145935,2,266,0)=" S PARIEN=$$RESOLV^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,267,0)="""RTN"",""PSOERXU7"",13,0)"
^XMB(3.9,145935,2,268,0)=" I PARIEN S RXIEN=$$GET1^DIQ(52.49,PARIEN,.13,""I"")"
^XMB(3.9,145935,2,269,0)="""RTN"",""PSOERXU7"",14,0)"
^XMB(3.9,145935,2,270,0)=" I $G(RXIEN) S OREFILL=$$GET1^DIQ(52,RXIEN,9,""E"")"
^XMB(3.9,145935,2,271,0)="""RTN"",""PSOERXU7"",15,0)"
^XMB(3.9,145935,2,272,0)=" S MTYPE=$$GET1^DIQ(52.49,ERXIEN,.08,""I"")"
^XMB(3.9,145935,2,273,0)="""RTN"",""PSOERXU7"",16,0)"
^XMB(3.9,145935,2,274,0)=" I MTYPE=""RE"" S DATAIEN=$$GETREQ^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,275,0)="""RTN"",""PSOERXU7"",17,0)"
^XMB(3.9,145935,2,276,0)=" I MTYPE=""RR"" S DATAIEN=ERXIEN"
^XMB(3.9,145935,2,277,0)="""RTN"",""PSOERXU7"",18,0)"
^XMB(3.9,145935,2,278,0)=" S MIEN=0 F  S MIEN=$O(^PS(52.49,DATAIEN,311,""C"",""D"",MIEN)) Q:'MIEN  D"
^XMB(3.9,145935,2,279,0)="""RTN"",""PSOERXU7"",19,0)"
^XMB(3.9,145935,2,280,0)=" .S IENS=MIEN_"",""_DATAIEN_"","""
^XMB(3.9,145935,2,281,0)="""RTN"",""PSOERXU7"",20,0)"
^XMB(3.9,145935,2,282,0)=" .D GETS^DIQ(F,IENS,"".03;2.1;2.3;2.4;2.5;2.8"",""IE"",""DDAT"")"
^XMB(3.9,145935,2,283,0)="""RTN"",""PSOERXU7"",21,0)"
^XMB(3.9,145935,2,284,0)=" .S DRUG=$G(DDAT(F,IENS,.03,""E""))"
^XMB(3.9,145935,2,285,0)="""RTN"",""PSOERXU7"",22,0)"
^XMB(3.9,145935,2,286,0)=" .S:DRUG'="""" DIEN=$O(^PSDRUG(""B"",DRUG,0))"
^XMB(3.9,145935,2,287,0)="""RTN"",""PSOERXU7"",23,0)"
^XMB(3.9,145935,2,288,0)=" .S QTY=$G(DDAT(F,IENS,2.1,""E""))"
^XMB(3.9,145935,2,289,0)="""RTN"",""PSOERXU7"",24,0)"
^XMB(3.9,145935,2,290,0)=" .S DAYS=$G(DDAT(F,IENS,2.4,""E""))"
^XMB(3.9,145935,2,291,0)="""RTN"",""PSOERXU7"",25,0)"
^XMB(3.9,145935,2,292,0)=" .S REFILL=$G(DDAT(F,IENS,2.8,""E""))"
