^XMB(3.9,145957,2,722,0)=" N GMRCI"
^XMB(3.9,145957,2,723,0)="""RTN"",""GMRCIMSG"",216,0)"
^XMB(3.9,145957,2,724,0)=" F GMRCI=1:1:4 S TCH($P(""\E\-\R\-\S\-\T\"",""-"",GMRCI))=$E(""\~^&"",GMRCI)"
^XMB(3.9,145957,2,725,0)="""RTN"",""GMRCIMSG"",217,0)"
^XMB(3.9,145957,2,726,0)=" Q"
^XMB(3.9,145957,2,727,0)="""RTN"",""GMRCIMSG"",218,0)"
^XMB(3.9,145957,2,728,0)=" ;"
^XMB(3.9,145957,2,729,0)="""RTN"",""GMRCIMSG"",219,0)"
^XMB(3.9,145957,2,730,0)="SETTCH2()  ;Set up TCH array with encoding characters"
^XMB(3.9,145957,2,731,0)="""RTN"",""GMRCIMSG"",220,0)"
^XMB(3.9,145957,2,732,0)=" N GMRCI"
^XMB(3.9,145957,2,733,0)="""RTN"",""GMRCIMSG"",221,0)"
^XMB(3.9,145957,2,734,0)=" F GMRCI=1:1:4 S TCH($E(""\~^&"",GMRCI))=$P(""\E\-\R\-\S\-\T\"",""-"",GMRCI)"
^XMB(3.9,145957,2,735,0)="""RTN"",""GMRCIMSG"",222,0)"
^XMB(3.9,145957,2,736,0)=" Q"
^XMB(3.9,145957,2,737,0)="""RTN"",""GMRCIMSG"",223,0)"
^XMB(3.9,145957,2,738,0)=" ;"
^XMB(3.9,145957,2,739,0)="""RTN"",""GMRCIUT1"")"
^XMB(3.9,145957,2,740,0)="0^3^B54016189"
^XMB(3.9,145957,2,741,0)="""RTN"",""GMRCIUT1"",1,0)"
^XMB(3.9,145957,2,742,0)="GMRCIUT1 ;SLC/JFR - UTILITIES FOR INTER-FACILITY CONSULTS ; Jan 27, 2025@06:04:10"
^XMB(3.9,145957,2,743,0)="""RTN"",""GMRCIUT1"",2,0)"
^XMB(3.9,145957,2,744,0)=" ;;3.0;CONSULT/REQUEST TRACKING;**189,205**;DEC 27, 1997;Build 0"
^XMB(3.9,145957,2,745,0)="""RTN"",""GMRCIUT1"",3,0)"
^XMB(3.9,145957,2,746,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145957,2,747,0)="""RTN"",""GMRCIUT1"",4,0)"
^XMB(3.9,145957,2,748,0)=" ;"
^XMB(3.9,145957,2,749,0)="""RTN"",""GMRCIUT1"",5,0)"
^XMB(3.9,145957,2,750,0)=" Q  ;don't start at the top"
^XMB(3.9,145957,2,751,0)="""RTN"",""GMRCIUT1"",6,0)"
^XMB(3.9,145957,2,752,0)=" ;"
^XMB(3.9,145957,2,753,0)="""RTN"",""GMRCIUT1"",7,0)"
^XMB(3.9,145957,2,754,0)="CHKPROXY(GMRCDA,GMRCDFN,STA,DONOTLOG) ;"
^XMB(3.9,145957,2,755,0)="""RTN"",""GMRCIUT1"",8,0)"
^XMB(3.9,145957,2,756,0)=" ;"
^XMB(3.9,145957,2,757,0)="""RTN"",""GMRCIUT1"",9,0)"
^XMB(3.9,145957,2,758,0)=" ;  GMRCDA   = Consult, pointer to #123"
^XMB(3.9,145957,2,759,0)="""RTN"",""GMRCIUT1"",10,0)"
^XMB(3.9,145957,2,760,0)=" ;  GMRCDFN  = Patient, pointer to #2"
^XMB(3.9,145957,2,761,0)="""RTN"",""GMRCIUT1"",11,0)"
^XMB(3.9,145957,2,762,0)=" ;  STA      = Routing station number"
^XMB(3.9,145957,2,763,0)="""RTN"",""GMRCIUT1"",12,0)"
^XMB(3.9,145957,2,764,0)=" ;  DONOTLOG = Flag to prevent logging in IFC Message Log (#123.6).  1=DO NOT LOG. [OPTIONAL]"
^XMB(3.9,145957,2,765,0)="""RTN"",""GMRCIUT1"",13,0)"
^XMB(3.9,145957,2,766,0)=" ;"
^XMB(3.9,145957,2,767,0)="""RTN"",""GMRCIUT1"",14,0)"
^XMB(3.9,145957,2,768,0)=" ;  Checks success/failure of proxy add.  Returns 1 if all is OK and IFC can be sent, 0^REASON if not."
^XMB(3.9,145957,2,769,0)="""RTN"",""GMRCIUT1"",15,0)"
^XMB(3.9,145957,2,770,0)=" ;"
^XMB(3.9,145957,2,771,0)="""RTN"",""GMRCIUT1"",16,0)"
^XMB(3.9,145957,2,772,0)=" ;pull patient Correlation list"
^XMB(3.9,145957,2,773,0)="""RTN"",""GMRCIUT1"",17,0)"
^XMB(3.9,145957,2,774,0)=" ;"
^XMB(3.9,145957,2,775,0)="""RTN"",""GMRCIUT1"",18,0)"
^XMB(3.9,145957,2,776,0)=" N DGKEY,DGOUT,CNT,IDS,CERNERID,CONSULTDFN,RTNCODE,EDIPI ;"
^XMB(3.9,145957,2,777,0)="""RTN"",""GMRCIUT1"",19,0)"
^XMB(3.9,145957,2,778,0)=" ;"
^XMB(3.9,145957,2,779,0)="""RTN"",""GMRCIUT1"",20,0)"
^XMB(3.9,145957,2,780,0)=" S DGKEY=GMRCDFN_U_""PI""_U_""USVHA""_U_$P($$SITE^VASITE,""^"",3)"
^XMB(3.9,145957,2,781,0)="""RTN"",""GMRCIUT1"",21,0)"
^XMB(3.9,145957,2,782,0)=" D TFL^VAFCTFU2(.DGOUT,DGKEY)"
^XMB(3.9,145957,2,783,0)="""RTN"",""GMRCIUT1"",22,0)"
^XMB(3.9,145957,2,784,0)=" ; "
^XMB(3.9,145957,2,785,0)="""RTN"",""GMRCIUT1"",23,0)"
^XMB(3.9,145957,2,786,0)=" S CONSULTDFN="""",CERNERID="""" ;"
^XMB(3.9,145957,2,787,0)="""RTN"",""GMRCIUT1"",24,0)"
^XMB(3.9,145957,2,788,0)=" S CNT=0 F  S CNT=$O(DGOUT(CNT)) Q:'CNT  S IDS=$G(DGOUT(CNT)) D  ;"
^XMB(3.9,145957,2,789,0)="""RTN"",""GMRCIUT1"",25,0)"
^XMB(3.9,145957,2,790,0)=" .I $P(IDS,""^"",4)=""200CRNR"" I $P(IDS,""^"",2)=""PI"" S CERNERID=IDS ;"
^XMB(3.9,145957,2,791,0)="""RTN"",""GMRCIUT1"",26,0)"
^XMB(3.9,145957,2,792,0)=" .I $P(IDS,""^"",4)=STA I $P(IDS,""^"",2)=""PI"" I $P(IDS,""^"",5)=""A""!($P(IDS,""^"",5)=""C"") S CONSULTDFN=IDS ;"
^XMB(3.9,145957,2,793,0)="""RTN"",""GMRCIUT1"",27,0)"
^XMB(3.9,145957,2,794,0)=" ;"
^XMB(3.9,145957,2,795,0)="""RTN"",""GMRCIUT1"",28,0)"
^XMB(3.9,145957,2,796,0)=" ;  Destination site is converted."
^XMB(3.9,145957,2,797,0)="""RTN"",""GMRCIUT1"",29,0)"
^XMB(3.9,145957,2,798,0)=" ;"
^XMB(3.9,145957,2,799,0)="""RTN"",""GMRCIUT1"",30,0)"
^XMB(3.9,145957,2,800,0)=" I $$CRNRSITE^VAFCCRNR(STA)=1 D  Q RTNCODE ;"
^XMB(3.9,145957,2,801,0)="""RTN"",""GMRCIUT1"",31,0)"
^XMB(3.9,145957,2,802,0)=" . I CERNERID'="""",CONSULTDFN'="""" S RTNCODE=1 Q  ;"
^XMB(3.9,145957,2,803,0)="""RTN"",""GMRCIUT1"",32,0)"
^XMB(3.9,145957,2,804,0)=" . ;"
^XMB(3.9,145957,2,805,0)="""RTN"",""GMRCIUT1"",33,0)"
^XMB(3.9,145957,2,806,0)=" . I CERNERID="""" S RTNCODE=""0^CERNER INCOMPLETE"" Q  ;"
^XMB(3.9,145957,2,807,0)="""RTN"",""GMRCIUT1"",34,0)"
^XMB(3.9,145957,2,808,0)=" . ;"
^XMB(3.9,145957,2,809,0)="""RTN"",""GMRCIUT1"",35,0)"
^XMB(3.9,145957,2,810,0)=" . I CONSULTDFN="""" D  Q  ;"
^XMB(3.9,145957,2,811,0)="""RTN"",""GMRCIUT1"",36,0)"
^XMB(3.9,145957,2,812,0)=" .. ;"
^XMB(3.9,145957,2,813,0)="""RTN"",""GMRCIUT1"",37,0)"
^XMB(3.9,145957,2,814,0)=" .. ;  Call proxy add for converted VistA."
^XMB(3.9,145957,2,815,0)="""RTN"",""GMRCIUT1"",38,0)"
^XMB(3.9,145957,2,816,0)=" .. ;"
^XMB(3.9,145957,2,817,0)="""RTN"",""GMRCIUT1"",39,0)"
^XMB(3.9,145957,2,818,0)=" .. S EDIPI=$$EDIPI^GMRCIUTL(GMRCDFN) ;"
^XMB(3.9,145957,2,819,0)="""RTN"",""GMRCIUT1"",40,0)"
^XMB(3.9,145957,2,820,0)=" .. S RTNCODE=$$ADD^DGPROSAD(EDIPI_""~USDOD~NI~200DOD"",STA) ;  ICR 7421"
^XMB(3.9,145957,2,821,0)="""RTN"",""GMRCIUT1"",41,0)"
^XMB(3.9,145957,2,822,0)=" .. I RTNCODE<0 D  ;  Proxy add failed."
^XMB(3.9,145957,2,823,0)="""RTN"",""GMRCIUT1"",42,0)"
^XMB(3.9,145957,2,824,0)=" ... I '$G(DONOTLOG) D LOGMSG^GMRCIUTL(GMRCDA,1,"""",205) ;"
^XMB(3.9,145957,2,825,0)="""RTN"",""GMRCIUT1"",43,0)"
^XMB(3.9,145957,2,826,0)=" ... D FAILPRXY("""",EDIPI,GMRCDA,"""","""","""",STA,$P(RTNCODE,U,2)) ; P189 WTC 6/24/24"
^XMB(3.9,145957,2,827,0)="""RTN"",""GMRCIUT1"",44,0)"
^XMB(3.9,145957,2,828,0)=" ... S RTNCODE=""0^CONVERTED VISTA INCOMPLETE"" ;"
^XMB(3.9,145957,2,829,0)="""RTN"",""GMRCIUT1"",45,0)"
^XMB(3.9,145957,2,830,0)=" .. Q:$G(DONOTLOG)  ;"
^XMB(3.9,145957,2,831,0)="""RTN"",""GMRCIUT1"",46,0)"
^XMB(3.9,145957,2,832,0)=" .. ;"
^XMB(3.9,145957,2,833,0)="""RTN"",""GMRCIUT1"",47,0)"
^XMB(3.9,145957,2,834,0)=" .. ;  Suppress 201 error if IFC already has a 203 error in the message log.  wtc 11.22.23 p189"
^XMB(3.9,145957,2,835,0)="""RTN"",""GMRCIUT1"",48,0)"
^XMB(3.9,145957,2,836,0)=" .. ;"
^XMB(3.9,145957,2,837,0)="""RTN"",""GMRCIUT1"",49,0)"
^XMB(3.9,145957,2,838,0)=" .. N ACTIEN,SUPPRESS,LOGIEN S SUPPRESS=0,ACTIEN=0 F  S ACTIEN=$O(^GMR(123.6,""AC"",GMRCDA,ACTIEN)) Q:'ACTIEN  D  Q:SUPPRESS  ;"
^XMB(3.9,145957,2,839,0)="""RTN"",""GMRCIUT1"",50,0)"
^XMB(3.9,145957,2,840,0)=" ... S LOGIEN=0 F  S LOGIEN=$O(^GMR(123.6,""AC"",GMRCDA,ACTIEN,1,LOGIEN)) Q:'LOGIEN  I $P($G(^GMR(123.6,LOGIEN,0)),U,8)=203 S SUPPRESS=1 Q  ;"
^XMB(3.9,145957,2,841,0)="""RTN"",""GMRCIUT1"",51,0)"
^XMB(3.9,145957,2,842,0)=" .. ;"
^XMB(3.9,145957,2,843,0)="""RTN"",""GMRCIUT1"",52,0)"
^XMB(3.9,145957,2,844,0)=" .. I 'SUPPRESS D LOGMSG^GMRCIUTL(GMRCDA,1,"""",201) ;"
^XMB(3.9,145957,2,845,0)="""RTN"",""GMRCIUT1"",53,0)"
^XMB(3.9,145957,2,846,0)=" ;"
^XMB(3.9,145957,2,847,0)="""RTN"",""GMRCIUT1"",54,0)"
^XMB(3.9,145957,2,848,0)=" ;  Destination site is non-converted."
^XMB(3.9,145957,2,849,0)="""RTN"",""GMRCIUT1"",55,0)"
^XMB(3.9,145957,2,850,0)=" ;"
^XMB(3.9,145957,2,851,0)="""RTN"",""GMRCIUT1"",56,0)"
^XMB(3.9,145957,2,852,0)=" I $$CRNRSITE^VAFCCRNR(STA)'=1 D  Q RTNCODE ;"
^XMB(3.9,145957,2,853,0)="""RTN"",""GMRCIUT1"",57,0)"
^XMB(3.9,145957,2,854,0)=" . I CONSULTDFN'="""" S RTNCODE=1 Q  ;"
^XMB(3.9,145957,2,855,0)="""RTN"",""GMRCIUT1"",58,0)"
^XMB(3.9,145957,2,856,0)=" . ;"
^XMB(3.9,145957,2,857,0)="""RTN"",""GMRCIUT1"",59,0)"
^XMB(3.9,145957,2,858,0)=" . S RTNCODE=""0^NON-CONVERTED VISTA INCOMPLETE"" ;"
^XMB(3.9,145957,2,859,0)="""RTN"",""GMRCIUT1"",60,0)"
^XMB(3.9,145957,2,860,0)=" . D LOGMSG^GMRCIUTL(GMRCDA,1,"""",201) ;"
^XMB(3.9,145957,2,861,0)="""RTN"",""GMRCIUT1"",61,0)"
^XMB(3.9,145957,2,862,0)=" ;"
^XMB(3.9,145957,2,863,0)="""RTN"",""GMRCIUT1"",62,0)"
^XMB(3.9,145957,2,864,0)=" Q ""0^UNKNOWN"" ;"
^XMB(3.9,145957,2,865,0)="""RTN"",""GMRCIUT1"",63,0)"
^XMB(3.9,145957,2,866,0)=" ;"
^XMB(3.9,145957,2,867,0)="""RTN"",""GMRCIUT1"",64,0)"
^XMB(3.9,145957,2,868,0)="FAILPRXY(MSGID,EDIPI,GMRCDA,CRNRORDR,ORDRDESC,ORDRDATE,STA,REASON) ;"
^XMB(3.9,145957,2,869,0)="""RTN"",""GMRCIUT1"",65,0)"
^XMB(3.9,145957,2,870,0)=" ;"
^XMB(3.9,145957,2,871,0)="""RTN"",""GMRCIUT1"",66,0)"
^XMB(3.9,145957,2,872,0)=" ;  Send MailMan message when proxy add fails."
^XMB(3.9,145957,2,873,0)="""RTN"",""GMRCIUT1"",67,0)"
^XMB(3.9,145957,2,874,0)=" ;"
^XMB(3.9,145957,2,875,0)="""RTN"",""GMRCIUT1"",68,0)"
^XMB(3.9,145957,2,876,0)=" ;  MSGID    = HL7 Message ID (MSH-10) [OPTIONAL]"
^XMB(3.9,145957,2,877,0)="""RTN"",""GMRCIUT1"",69,0)"
^XMB(3.9,145957,2,878,0)=" ;  EDIPI    = Patient's EDIPI [OPTIONAL]"
^XMB(3.9,145957,2,879,0)="""RTN"",""GMRCIUT1"",70,0)"
^XMB(3.9,145957,2,880,0)=" ;  GMRCDA   = Consult IEN (pointer to #123) [OPTIONAL]"
^XMB(3.9,145957,2,881,0)="""RTN"",""GMRCIUT1"",71,0)"
^XMB(3.9,145957,2,882,0)=" ;  CRNRORDR = Cerner order number [OPTIONAL]"
^XMB(3.9,145957,2,883,0)="""RTN"",""GMRCIUT1"",72,0)"
^XMB(3.9,145957,2,884,0)=" ;  ORDRDESC = Ordering description [OPTIONAL]"
^XMB(3.9,145957,2,885,0)="""RTN"",""GMRCIUT1"",73,0)"
^XMB(3.9,145957,2,886,0)=" ;  ORDRDATE = Ordering date in HL7 format [OPTIONAL]"
^XMB(3.9,145957,2,887,0)="""RTN"",""GMRCIUT1"",74,0)"
^XMB(3.9,145957,2,888,0)=" ;  STA      = Station where proxy add attempted [OPTIONAL]"
^XMB(3.9,145957,2,889,0)="""RTN"",""GMRCIUT1"",75,0)"
^XMB(3.9,145957,2,890,0)=" ;  REASON   = Proxy add failure reason [REQUIRED]"
^XMB(3.9,145957,2,891,0)="""RTN"",""GMRCIUT1"",76,0)"
^XMB(3.9,145957,2,892,0)=" ;"
^XMB(3.9,145957,2,893,0)="""RTN"",""GMRCIUT1"",77,0)"
^XMB(3.9,145957,2,894,0)=" Q:$G(REASON)=""""  ;"
^XMB(3.9,145957,2,895,0)="""RTN"",""GMRCIUT1"",78,0)"
^XMB(3.9,145957,2,896,0)=" ;"
^XMB(3.9,145957,2,897,0)="""RTN"",""GMRCIUT1"",79,0)"
^XMB(3.9,145957,2,898,0)=" N XMSUB,XMDUZ,XMTEXT,XMY,GRPIEN,MEM,GRP,N ;"
^XMB(3.9,145957,2,899,0)="""RTN"",""GMRCIUT1"",80,0)"
^XMB(3.9,145957,2,900,0)=" S GRP=""IFC PATIENT ERROR MESSAGES"" ;"
^XMB(3.9,145957,2,901,0)="""RTN"",""GMRCIUT1"",81,0)"
^XMB(3.9,145957,2,902,0)=" S XMSUB=""Failed IFC transaction: Proxy Add Failed"",XMTEXT=""XMTEXT("" ;"
^XMB(3.9,145957,2,903,0)="""RTN"",""GMRCIUT1"",82,0)"
^XMB(3.9,145957,2,904,0)=" S N=0 ;"
^XMB(3.9,145957,2,905,0)="""RTN"",""GMRCIUT1"",83,0)"
^XMB(3.9,145957,2,906,0)=" I $G(MSGID)'="""" S N=N+1,XMTEXT(N)=""Message ID: ""_MSGID ;"
^XMB(3.9,145957,2,907,0)="""RTN"",""GMRCIUT1"",84,0)"
^XMB(3.9,145957,2,908,0)=" I $G(EDIPI)'="""" S N=N+1,XMTEXT(N)=""EDIPI: ""_EDIPI ;"
^XMB(3.9,145957,2,909,0)="""RTN"",""GMRCIUT1"",85,0)"
^XMB(3.9,145957,2,910,0)=" I $G(GMRCDA)'="""" S N=N+1,XMTEXT(N)=""Consult Number: ""_GMRCDA ;"
^XMB(3.9,145957,2,911,0)="""RTN"",""GMRCIUT1"",86,0)"
^XMB(3.9,145957,2,912,0)=" I $G(CRNRORDR)'="""" S N=N+1,XMTEXT(N)=""Cerner Order Number: ""_CRNRORDR ;"
^XMB(3.9,145957,2,913,0)="""RTN"",""GMRCIUT1"",87,0)"
^XMB(3.9,145957,2,914,0)=" I $G(ORDRDESC)'="""" S N=N+1,XMTEXT(N)=""Order Description: ""_ORDRDESC ;"
^XMB(3.9,145957,2,915,0)="""RTN"",""GMRCIUT1"",88,0)"
^XMB(3.9,145957,2,916,0)=" I $G(ORDRDATE)'="""" S N=N+1,XMTEXT(N)=""Order Date: ""_$$FMTE^XLFDT($$HL7TFM^XLFDT(ORDRDATE)) ;"
^XMB(3.9,145957,2,917,0)="""RTN"",""GMRCIUT1"",89,0)"
^XMB(3.9,145957,2,918,0)=" I $G(STA)'="""" S N=N+1,XMTEXT(N)=""Station where proxy add attempted: ""_STA ;"
^XMB(3.9,145957,2,919,0)="""RTN"",""GMRCIUT1"",90,0)"
^XMB(3.9,145957,2,920,0)=" S N=N+1,XMTEXT(N)=""Failure Reason: ""_REASON ;"
^XMB(3.9,145957,2,921,0)="""RTN"",""GMRCIUT1"",91,0)"
^XMB(3.9,145957,2,922,0)=" S GRPIEN=$O(^XMB(3.8,""B"",GRP,"""")) Q:'GRPIEN"
^XMB(3.9,145957,2,923,0)="""RTN"",""GMRCIUT1"",92,0)"
^XMB(3.9,145957,2,924,0)=" ;Set up XMY for MEMBERS"
^XMB(3.9,145957,2,925,0)="""RTN"",""GMRCIUT1"",93,0)"
^XMB(3.9,145957,2,926,0)=" S MEM=0 F  S MEM=$O(^XMB(3.8,GRPIEN,1,MEM)) Q:'MEM  S XMY($P(^XMB(3.8,GRPIEN,1,MEM,0),U))="""""
^XMB(3.9,145957,2,927,0)="""RTN"",""GMRCIUT1"",94,0)"
^XMB(3.9,145957,2,928,0)=" ;Set up XMY for MEMBERS REMOTE"
^XMB(3.9,145957,2,929,0)="""RTN"",""GMRCIUT1"",95,0)"
^XMB(3.9,145957,2,930,0)=" S MEM=0 F  S MEM=$O(^XMB(3.8,GRPIEN,6,MEM)) Q:'MEM  S XMY($P(^XMB(3.8,GRPIEN,6,MEM,0),U))="""""
^XMB(3.9,145957,2,931,0)="""RTN"",""GMRCIUT1"",96,0)"
^XMB(3.9,145957,2,932,0)=" Q:'$D(XMY)"
^XMB(3.9,145957,2,933,0)="""RTN"",""GMRCIUT1"",97,0)"
^XMB(3.9,145957,2,934,0)=" S XMDUZ=GRP"
^XMB(3.9,145957,2,935,0)="""RTN"",""GMRCIUT1"",98,0)"
^XMB(3.9,145957,2,936,0)=" D XMZ^XMA2 ; call Create Message Module"
^XMB(3.9,145957,2,937,0)="""RTN"",""GMRCIUT1"",99,0)"
^XMB(3.9,145957,2,938,0)=" D EN1^XMD"
^XMB(3.9,145957,2,939,0)="""RTN"",""GMRCIUT1"",100,0)"
^XMB(3.9,145957,2,940,0)=" Q  ;"
^XMB(3.9,145957,2,941,0)="""RTN"",""GMRCIUT1"",101,0)"
^XMB(3.9,145957,2,942,0)=" ;"
^XMB(3.9,145957,2,943,0)="""RTN"",""GMRCIUT1"",102,0)"
^XMB(3.9,145957,2,944,0)="RESP(GMRCAC,GMRCMID,GMRCOC,GMRCDA,GMRCERR,GMRCMSG) ;"
^XMB(3.9,145957,2,945,0)="""RTN"",""GMRCIUT1"",103,0)"
^XMB(3.9,145957,2,946,0)=" ;"
^XMB(3.9,145957,2,947,0)="""RTN"",""GMRCIUT1"",104,0)"
^XMB(3.9,145957,2,948,0)=" ;  Send ACK or NAK to Cerner followed by rejection comment. P205 wtc 8/15/24"
^XMB(3.9,145957,2,949,0)="""RTN"",""GMRCIUT1"",105,0)"
^XMB(3.9,145957,2,950,0)=" ;"
^XMB(3.9,145957,2,951,0)="""RTN"",""GMRCIUT1"",106,0)"
^XMB(3.9,145957,2,952,0)=" ; Input:"
^XMB(3.9,145957,2,953,0)="""RTN"",""GMRCIUT1"",107,0)"
^XMB(3.9,145957,2,954,0)=" ;   GMRCAC  = acknowledgement code (AA or AR)"
^XMB(3.9,145957,2,955,0)="""RTN"",""GMRCIUT1"",108,0)"
^XMB(3.9,145957,2,956,0)=" ;   GMRCMID = message id from original msg"
^XMB(3.9,145957,2,957,0)="""RTN"",""GMRCIUT1"",109,0)"
^XMB(3.9,145957,2,958,0)=" ;   GMRCOC  = order control from original msg ORC"
^XMB(3.9,145957,2,959,0)="""RTN"",""GMRCIUT1"",110,0)"
^XMB(3.9,145957,2,960,0)=" ;   GMRCDA  = ien of consult being worked on"
^XMB(3.9,145957,2,961,0)="""RTN"",""GMRCIUT1"",111,0)"
^XMB(3.9,145957,2,962,0)=" ;   GMRCERR = only defined if an error is found"
^XMB(3.9,145957,2,963,0)="""RTN"",""GMRCIUT1"",112,0)"
^XMB(3.9,145957,2,964,0)=" ;   GMRCMSG = name of array where incoming HL7 stored"
^XMB(3.9,145957,2,965,0)="""RTN"",""GMRCIUT1"",113,0)"
^XMB(3.9,145957,2,966,0)=" ;"
^XMB(3.9,145957,2,967,0)="""RTN"",""GMRCIUT1"",114,0)"
^XMB(3.9,145957,2,968,0)=" N HLA S HLA(""HLA"",1)=$$MSA^GMRCISEG(GMRCAC,GMRCMID,$G(GMRCERR))"
^XMB(3.9,145957,2,969,0)="""RTN"",""GMRCIUT1"",115,0)"
^XMB(3.9,145957,2,970,0)=" ;"
^XMB(3.9,145957,2,971,0)="""RTN"",""GMRCIUT1"",116,0)"
^XMB(3.9,145957,2,972,0)=" ;  Generate PID segment for Cerner orders.  Insert EDIPI and patient account number.  p184"
^XMB(3.9,145957,2,973,0)="""RTN"",""GMRCIUT1"",117,0)"
^XMB(3.9,145957,2,974,0)=" ;"
^XMB(3.9,145957,2,975,0)="""RTN"",""GMRCIUT1"",118,0)"
^XMB(3.9,145957,2,976,0)=" N DFN,PID,EDIPI,ICN,PTACCTNO,FS,CS,REPTTN,SEGNUM,PTACCTNO,GMRCRSLT ;"
^XMB(3.9,145957,2,977,0)="""RTN"",""GMRCIUT1"",119,0)"
^XMB(3.9,145957,2,978,0)=" S SEGNUM=1 ;"
^XMB(3.9,145957,2,979,0)="""RTN"",""GMRCIUT1"",120,0)"
^XMB(3.9,145957,2,980,0)=" I $G(GMRCDA) D  ;"
^XMB(3.9,145957,2,981,0)="""RTN"",""GMRCIUT1"",121,0)"
^XMB(3.9,145957,2,982,0)=" . S DFN=$P(^GMR(123,GMRCDA,0),U,2),PTACCTNO=$P($G(^GMR(123,GMRCDA,""CERNER"")),U,3) ;"
^XMB(3.9,145957,2,983,0)="""RTN"",""GMRCIUT1"",122,0)"
^XMB(3.9,145957,2,984,0)=" . I PTACCTNO'="""" D  ;"
^XMB(3.9,145957,2,985,0)="""RTN"",""GMRCIUT1"",123,0)"
^XMB(3.9,145957,2,986,0)=" .. S HLECH=HL(""ECH""),PID=$$EN^VAFCPID(DFN,""1,2,3,7,8,19""),PID=$$ADD2PID^GMRCIUTL(PID,DFN,PTACCTNO) ;"
^XMB(3.9,145957,2,987,0)="""RTN"",""GMRCIUT1"",124,0)"
^XMB(3.9,145957,2,988,0)=" .. S SEGNUM=SEGNUM+1,HLA(""HLA"",SEGNUM)=PID ;"
^XMB(3.9,145957,2,989,0)="""RTN"",""GMRCIUT1"",125,0)"
^XMB(3.9,145957,2,990,0)=" ;"
^XMB(3.9,145957,2,991,0)="""RTN"",""GMRCIUT1"",126,0)"
^XMB(3.9,145957,2,992,0)=" I $D(GMRCOC) D"
^XMB(3.9,145957,2,993,0)="""RTN"",""GMRCIUT1"",127,0)"
^XMB(3.9,145957,2,994,0)=" . I GMRCOC=""NW"" S SEGNUM=SEGNUM+1,HLA(""HLA"",SEGNUM)=$$ORCRESP^GMRCISG1(GMRCDA,""OK"",""IP"")"
^XMB(3.9,145957,2,995,0)="""RTN"",""GMRCIUT1"",128,0)"
^XMB(3.9,145957,2,996,0)=" ;"
^XMB(3.9,145957,2,997,0)="""RTN"",""GMRCIUT1"",129,0)"
^XMB(3.9,145957,2,998,0)=" ;  Generate OBR segment for Cerner orders.  p184"
^XMB(3.9,145957,2,999,0)="""RTN"",""GMRCIUT1"",130,0)"
^XMB(3.9,145957,2,1000,0)=" ;"
^XMB(3.9,145957,2,1001,0)="""RTN"",""GMRCIUT1"",131,0)"
^XMB(3.9,145957,2,1002,0)=" I $G(GMRCDA) S SEGNUM=SEGNUM+1,HLA(""HLA"",SEGNUM)=$$OBR^GMRCISG1(GMRCDA),HLA(""HLA"",SEGNUM)=$$ADD2OBR^GMRCIUTL(HLA(""HLA"",SEGNUM),GMRCDA) ;"
^XMB(3.9,145957,2,1003,0)="""RTN"",""GMRCIUT1"",132,0)"
^XMB(3.9,145957,2,1004,0)=" ;"
^XMB(3.9,145957,2,1005,0)="""RTN"",""GMRCIUT1"",133,0)"
^XMB(3.9,145957,2,1006,0)=" ;  Send ACK/NAK to Cerner."
^XMB(3.9,145957,2,1007,0)="""RTN"",""GMRCIUT1"",134,0)"
^XMB(3.9,145957,2,1008,0)=" ;"
^XMB(3.9,145957,2,1009,0)="""RTN"",""GMRCIUT1"",135,0)"
^XMB(3.9,145957,2,1010,0)=" D GENACK^HLMA1(HL(""EID""),HLMTIENS,HL(""EIDS""),""LM"",1,.GMRCRSLT) ;-("
^XMB(3.9,145957,2,1011,0)="""RTN"",""GMRCIUT1"",136,0)"
^XMB(3.9,145957,2,1012,0)=" ;"
^XMB(3.9,145957,2,1013,0)="""RTN"",""GMRCIUT1"",137,0)"
^XMB(3.9,145957,2,1014,0)=" Q:GMRCAC=""AA""  ;"
^XMB(3.9,145957,2,1015,0)="""RTN"",""GMRCIUT1"",138,0)"
^XMB(3.9,145957,2,1016,0)=" ;"
^XMB(3.9,145957,2,1017,0)="""RTN"",""GMRCIUT1"",139,0)"
^XMB(3.9,145957,2,1018,0)=" ;  Send rejection comment along with original order message."
^XMB(3.9,145957,2,1019,0)="""RTN"",""GMRCIUT1"",140,0)"
^XMB(3.9,145957,2,1020,0)=" ;"
^XMB(3.9,145957,2,1021,0)="""RTN"",""GMRCIUT1"",141,0)"
^XMB(3.9,145957,2,1022,0)=" N HL,HLL,HLP,ERRTEXT,OBR,IDX,STA,I ;"
^XMB(3.9,145957,2,1023,0)="""RTN"",""GMRCIUT1"",142,0)"
^XMB(3.9,145957,2,1024,0)=" ;"
^XMB(3.9,145957,2,1025,0)="""RTN"",""GMRCIUT1"",143,0)"
^XMB(3.9,145957,2,1026,0)=" D INIT^HLFNC2(""GMRC IFC ORM EVENT"",.HL)"
^XMB(3.9,145957,2,1027,0)="""RTN"",""GMRCIUT1"",144,0)"
^XMB(3.9,145957,2,1028,0)=" ;"
^XMB(3.9,145957,2,1029,0)="""RTN"",""GMRCIUT1"",145,0)"
^XMB(3.9,145957,2,1030,0)=" K ^TMP(""GMRCIUT1"",$J) M ^TMP(""GMRCIUT1"",$J)=@GMRCMSG ;"
^XMB(3.9,145957,2,1031,0)="""RTN"",""GMRCIUT1"",146,0)"
^XMB(3.9,145957,2,1032,0)=" ;"
^XMB(3.9,145957,2,1033,0)="""RTN"",""GMRCIUT1"",147,0)"
^XMB(3.9,145957,2,1034,0)=" K ^TMP(""HLS"",$J) S SEGNUM=1,^TMP(""HLS"",$J,SEGNUM)=""PID|""_^TMP(""GMRCIUT1"",$J,""PID"") ;"
^XMB(3.9,145957,2,1035,0)="""RTN"",""GMRCIUT1"",148,0)"
^XMB(3.9,145957,2,1036,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""ORC|""_^TMP(""GMRCIUT1"",$J,""ORC"") ;"
^XMB(3.9,145957,2,1037,0)="""RTN"",""GMRCIUT1"",149,0)"
^XMB(3.9,145957,2,1038,0)=" ;"
^XMB(3.9,145957,2,1039,0)="""RTN"",""GMRCIUT1"",150,0)"
^XMB(3.9,145957,2,1040,0)=" ;  Change order control and status to ""add comment"" (IP/IP).  WTC 10/21/24"
^XMB(3.9,145957,2,1041,0)="""RTN"",""GMRCIUT1"",151,0)"
^XMB(3.9,145957,2,1042,0)=" ;"
^XMB(3.9,145957,2,1043,0)="""RTN"",""GMRCIUT1"",152,0)"
^XMB(3.9,145957,2,1044,0)=" S $P(^TMP(""HLS"",$J,SEGNUM),""|"",2)=""IP"",$P(^TMP(""HLS"",$J,SEGNUM),""|"",6)=""IP"" ;"
^XMB(3.9,145957,2,1045,0)="""RTN"",""GMRCIUT1"",153,0)"
^XMB(3.9,145957,2,1046,0)=" ;"
^XMB(3.9,145957,2,1047,0)="""RTN"",""GMRCIUT1"",154,0)"
^XMB(3.9,145957,2,1048,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBR|""_^TMP(""GMRCIUT1"",$J,""OBR""),OBR=""OBR|""_^TMP(""GMRCIUT1"",$J,""OBR"") ;"
^XMB(3.9,145957,2,1049,0)="""RTN"",""GMRCIUT1"",155,0)"
^XMB(3.9,145957,2,1050,0)=" ;"
^XMB(3.9,145957,2,1051,0)="""RTN"",""GMRCIUT1"",156,0)"
^XMB(3.9,145957,2,1052,0)=" S IDX=0 F  S IDX=$O(^TMP(""GMRCIUT1"",$J,""OBX"",1,IDX)) Q:'IDX  S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|""_^TMP(""GMRCIUT1"",$J,""OBX"",1,IDX) ;"
^XMB(3.9,145957,2,1053,0)="""RTN"",""GMRCIUT1"",157,0)"
^XMB(3.9,145957,2,1054,0)=" ;"
^XMB(3.9,145957,2,1055,0)="""RTN"",""GMRCIUT1"",158,0)"
^XMB(3.9,145957,2,1056,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|1| ||||||P"" ;"
^XMB(3.9,145957,2,1057,0)="""RTN"",""GMRCIUT1"",159,0)"
^XMB(3.9,145957,2,1058,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|2|Activity Type: Order Rejected||||||P"" ;"
^XMB(3.9,145957,2,1059,0)="""RTN"",""GMRCIUT1"",160,0)"
^XMB(3.9,145957,2,1060,0)=" S ERRTEXT=""ERR""_GMRCERR_""^GMRCIUTL"" ;"
^XMB(3.9,145957,2,1061,0)="""RTN"",""GMRCIUT1"",161,0)"
^XMB(3.9,145957,2,1062,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|3|Rejection Reason: ""_GMRCERR_"" - ""_$P($T(@ERRTEXT),"";"",2)_""||||||P"" ;"
^XMB(3.9,145957,2,1063,0)="""RTN"",""GMRCIUT1"",162,0)"
^XMB(3.9,145957,2,1064,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|4|Entered At Location: ""_$P($$SITE^VASITE(),U,2)_""||||||P"" ;"
^XMB(3.9,145957,2,1065,0)="""RTN"",""GMRCIUT1"",163,0)"
^XMB(3.9,145957,2,1066,0)=" S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|5|""_$$FMTE^XLFDT($$NOW^XLFDT())_""||||||P"" ;"
^XMB(3.9,145957,2,1067,0)="""RTN"",""GMRCIUT1"",164,0)"
^XMB(3.9,145957,2,1068,0)=" ;"
^XMB(3.9,145957,2,1069,0)="""RTN"",""GMRCIUT1"",165,0)"
^XMB(3.9,145957,2,1070,0)=" S IDX=0 F I=6:1 S IDX=$O(^TMP(""GMRCIUT1"",$J,""OBX"",3,IDX)) Q:'IDX  S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|3|TX|^COMMENTS^|""_I_""|""_^TMP(""GMRCIUT1"",$J,""OBX"",3,IDX) ;"
^XMB(3.9,145957,2,1071,0)="""RTN"",""GMRCIUT1"",166,0)"
^XMB(3.9,145957,2,1072,0)=" ;"
^XMB(3.9,145957,2,1073,0)="""RTN"",""GMRCIUT1"",167,0)"
^XMB(3.9,145957,2,1074,0)=" S IDX=0 F  S IDX=$O(^TMP(""GMRCIUT1"",$J,""OBX"",5,IDX)) Q:'IDX  S SEGNUM=SEGNUM+1,^TMP(""HLS"",$J,SEGNUM)=""OBX|""_^TMP(""GMRCIUT1"",$J,""OBX"",5,IDX) ;"
^XMB(3.9,145957,2,1075,0)="""RTN"",""GMRCIUT1"",168,0)"
^XMB(3.9,145957,2,1076,0)=" ;"
^XMB(3.9,145957,2,1077,0)="""RTN"",""GMRCIUT1"",169,0)"
^XMB(3.9,145957,2,1078,0)=" S STA=$P($P(OBR,""|"",3),""^"",2) ;"
^XMB(3.9,145957,2,1079,0)="""RTN"",""GMRCIUT1"",170,0)"
^XMB(3.9,145957,2,1080,0)=" S HLL(""LINKS"",1)=""GMRC IFC SUBSC^""_$$GET^XPAR(""SYS"",""GMRC IFC REGIONAL ROUTER"",1)_U_STA ;"
^XMB(3.9,145957,2,1081,0)="""RTN"",""GMRCIUT1"",171,0)"
^XMB(3.9,145957,2,1082,0)=" S HLP(""SUBSCRIBER"")=""^^^^""_$P(HLL(""LINKS"",1),U,3) ;"
^XMB(3.9,145957,2,1083,0)="""RTN"",""GMRCIUT1"",172,0)"
^XMB(3.9,145957,2,1084,0)=" D GENERATE^HLMA(""GMRC IFC ORM EVENT"",""GM"",1,,,.HLP) ;"
^XMB(3.9,145957,2,1085,0)="""RTN"",""GMRCIUT1"",173,0)"
^XMB(3.9,145957,2,1086,0)=" ;"
^XMB(3.9,145957,2,1087,0)="""RTN"",""GMRCIUT1"",174,0)"
^XMB(3.9,145957,2,1088,0)=" ;  Save message in HL7 repository."
