^XMB(3.9,145986,2,2082,0)=" Q FBOUT"
^XMB(3.9,145986,2,2083,0)="""RTN"",""FBCHVH"",96,0)"
^XMB(3.9,145986,2,2084,0)="WRTDX ;write dianosis code and present on admission code"
^XMB(3.9,145986,2,2085,0)="""RTN"",""FBCHVH"",97,0)"
