^XMB(3.9,145984,2,780,0)=" I $D(DUEINFO) D"
^XMB(3.9,145984,2,781,0)="""RTN"",""PSOERX1C"",239,0)"
^XMB(3.9,145984,2,782,0)=" . S $P(DDOT,""."",81)="""""
^XMB(3.9,145984,2,783,0)="""RTN"",""PSOERX1C"",240,0)"
^XMB(3.9,145984,2,784,0)=" . W !,$$TITLELN(""PRESCRIBER DRUG USE EVALUATION"")"
^XMB(3.9,145984,2,785,0)="""RTN"",""PSOERX1C"",241,0)"
^XMB(3.9,145984,2,786,0)=" . S DUECNT=0 F  S DUECNT=$O(DUEINFO(DUECNT)) Q:'DUECNT  D"
^XMB(3.9,145984,2,787,0)="""RTN"",""PSOERX1C"",242,0)"
^XMB(3.9,145984,2,788,0)=" . . W !,""Co-Agent: ""_$P(DUEINFO(DUECNT),""^"",8)"
^XMB(3.9,145984,2,789,0)="""RTN"",""PSOERX1C"",243,0)"
^XMB(3.9,145984,2,790,0)=" . . S REASON=$P(DUEINFO(DUECNT),""^"",2) I $$PRESOLV^PSOERXA1(REASON,""REA"") S REASON=$$GET1^DIQ(52.45,$$PRESOLV^PSOERXA1(REASON,""REA""),.02)"
^XMB(3.9,145984,2,791,0)="""RTN"",""PSOERX1C"",244,0)"
^XMB(3.9,145984,2,792,0)=" . . W !,""Reason: ""_REASON"
^XMB(3.9,145984,2,793,0)="""RTN"",""PSOERX1C"",245,0)"
^XMB(3.9,145984,2,794,0)=" . . S RESULT=$P(DUEINFO(DUECNT),""^"",4) I $$PRESOLV^PSOERXA1(RESULT,""RES"") S RESULT=$$GET1^DIQ(52.45,$$PRESOLV^PSOERXA1(RESULT,""RES""),.02)"
^XMB(3.9,145984,2,795,0)="""RTN"",""PSOERX1C"",246,0)"
^XMB(3.9,145984,2,796,0)=" . . W !,""Result: ""_RESULT"
^XMB(3.9,145984,2,797,0)="""RTN"",""PSOERX1C"",247,0)"
^XMB(3.9,145984,2,798,0)=" . . W !,""Override: ""_$P(DUEINFO(DUECNT),""^"",9)"
^XMB(3.9,145984,2,799,0)="""RTN"",""PSOERX1C"",248,0)"
^XMB(3.9,145984,2,800,0)=" . . I $O(DUEINFO(DUECNT)) W !,DDOT"
^XMB(3.9,145984,2,801,0)="""RTN"",""PSOERX1C"",249,0)"
^XMB(3.9,145984,2,802,0)=" . . I '$D(ZTQUEUED),$Y>(IOSL-7) D PAUSE(.PSOQ) Q:$G(PSOQ)"
^XMB(3.9,145984,2,803,0)="""RTN"",""PSOERX1C"",250,0)"
^XMB(3.9,145984,2,804,0)=" ;Diagnosis Code"
