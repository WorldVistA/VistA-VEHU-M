^XMB(3.9,145986,2,3811,0)="""RTN"",""FBPCR"",156,0)"
^XMB(3.9,145986,2,3812,0)=" Q"
^XMB(3.9,145986,2,3813,0)="""RTN"",""FBPCR"",157,0)"
^XMB(3.9,145986,2,3814,0)=" ;"
^XMB(3.9,145986,2,3815,0)="""RTN"",""FBPCR"",158,0)"
^XMB(3.9,145986,2,3816,0)="PAGE ;form feed when new station/patient"
