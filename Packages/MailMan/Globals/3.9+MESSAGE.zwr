^XMB(3.9,145944,2,233,0)="""QUES"",""XPZ1"",0)"
^XMB(3.9,145944,2,234,0)="Y"
^XMB(3.9,145944,2,235,0)="""QUES"",""XPZ1"",""??"")"
^XMB(3.9,145944,2,236,0)="^D OPT^XPDH"
^XMB(3.9,145944,2,237,0)="""QUES"",""XPZ1"",""A"")"
^XMB(3.9,145944,2,238,0)="Want to DISABLE Scheduled Options, Menu Options, and Protocols"
^XMB(3.9,145944,2,239,0)="""QUES"",""XPZ1"",""B"")"
^XMB(3.9,145944,2,240,0)="NO"
^XMB(3.9,145944,2,241,0)="""QUES"",""XPZ1"",""M"")"
