^XMB(3.9,145946,2,6227,0)="""RTN"",""IBCOPP"",86,0)"
^XMB(3.9,145946,2,6228,0)=" I '$D(^TMP(""IBINC"",$J)) D  Q"
^XMB(3.9,145946,2,6229,0)="""RTN"",""IBCOPP"",87,0)"
^XMB(3.9,145946,2,6230,0)=" . W !!,*7,""No plans selected!"""
^XMB(3.9,145946,2,6231,0)="""RTN"",""IBCOPP"",88,0)"
^XMB(3.9,145946,2,6232,0)=" . D ENQ"
^XMB(3.9,145946,2,6233,0)="""RTN"",""IBCOPP"",89,0)"
^XMB(3.9,145946,2,6234,0)=" ;"
^XMB(3.9,145946,2,6235,0)="""RTN"",""IBCOPP"",90,0)"
^XMB(3.9,145946,2,6236,0)=" S IBAO=$$OUT^IBCOPP1                       ; Report or CSV output"
^XMB(3.9,145946,2,6237,0)="""RTN"",""IBCOPP"",91,0)"
^XMB(3.9,145946,2,6238,0)=" D DEVICE"
^XMB(3.9,145946,2,6239,0)="""RTN"",""IBCOPP"",92,0)"
^XMB(3.9,145946,2,6240,0)=" Q"
^XMB(3.9,145946,2,6241,0)="""RTN"",""IBCOPP"",93,0)"
^XMB(3.9,145946,2,6242,0)=" ;"
^XMB(3.9,145946,2,6243,0)="""RTN"",""IBCOPP"",94,0)"
^XMB(3.9,145946,2,6244,0)="DEVICE ; Ask user to select device"
^XMB(3.9,145946,2,6245,0)="""RTN"",""IBCOPP"",95,0)"
^XMB(3.9,145946,2,6246,0)=" ;"
^XMB(3.9,145946,2,6247,0)="""RTN"",""IBCOPP"",96,0)"
^XMB(3.9,145946,2,6248,0)=" N I,POP"
^XMB(3.9,145946,2,6249,0)="""RTN"",""IBCOPP"",97,0)"
^XMB(3.9,145946,2,6250,0)=" I IBAO'=""E"" D"
^XMB(3.9,145946,2,6251,0)="""RTN"",""IBCOPP"",98,0)"
^XMB(3.9,145946,2,6252,0)=" . W !!,""*** You will need a 132 column printer for this report. ***"",!"
^XMB(3.9,145946,2,6253,0)="""RTN"",""IBCOPP"",99,0)"
^XMB(3.9,145946,2,6254,0)=" E  D"
^XMB(3.9,145946,2,6255,0)="""RTN"",""IBCOPP"",100,0)"
^XMB(3.9,145946,2,6256,0)=" . W !!,""For CSV output, turn logging or capture on now. To avoid undesired wrapping"""
^XMB(3.9,145946,2,6257,0)="""RTN"",""IBCOPP"",101,0)"
^XMB(3.9,145946,2,6258,0)=" . W !,""of the data saved to the file, please enter """"0;256;99999"""" at the """"DEVICE:"""""""
^XMB(3.9,145946,2,6259,0)="""RTN"",""IBCOPP"",102,0)"
^XMB(3.9,145946,2,6260,0)=" . W !,""prompt."",!"
^XMB(3.9,145946,2,6261,0)="""RTN"",""IBCOPP"",103,0)"
^XMB(3.9,145946,2,6262,0)=" S %ZIS=""QM"""
^XMB(3.9,145946,2,6263,0)="""RTN"",""IBCOPP"",104,0)"
^XMB(3.9,145946,2,6264,0)=" D ^%ZIS"
^XMB(3.9,145946,2,6265,0)="""RTN"",""IBCOPP"",105,0)"
^XMB(3.9,145946,2,6266,0)=" I POP D ENQ Q"
^XMB(3.9,145946,2,6267,0)="""RTN"",""IBCOPP"",106,0)"
^XMB(3.9,145946,2,6268,0)=" I $D(IO(""Q"")) D  Q"
^XMB(3.9,145946,2,6269,0)="""RTN"",""IBCOPP"",107,0)"
^XMB(3.9,145946,2,6270,0)=" . S ZTRTN=""^IBCOPP2"",ZTDESC=""IB - LIST OF PLANS BY INSURANCE COMPANY"""
^XMB(3.9,145946,2,6271,0)="""RTN"",""IBCOPP"",108,0)"
^XMB(3.9,145946,2,6272,0)=" . F I=""^TMP(""""IBINC"""",$J,"",""IBAPA"",""IBAI"",""IBAPL"",""IBAO"" S ZTSAVE(I)="""""
^XMB(3.9,145946,2,6273,0)="""RTN"",""IBCOPP"",109,0)"
^XMB(3.9,145946,2,6274,0)=" . D ^%ZTLOAD"
^XMB(3.9,145946,2,6275,0)="""RTN"",""IBCOPP"",110,0)"
^XMB(3.9,145946,2,6276,0)=" . K IO(""Q"")"
^XMB(3.9,145946,2,6277,0)="""RTN"",""IBCOPP"",111,0)"
^XMB(3.9,145946,2,6278,0)=" . D HOME^%ZIS"
^XMB(3.9,145946,2,6279,0)="""RTN"",""IBCOPP"",112,0)"
^XMB(3.9,145946,2,6280,0)=" . W !!,$S($D(ZTSK):""This job has been queued as task #""_ZTSK_""."",1:""Unable to queue this job."")"
^XMB(3.9,145946,2,6281,0)="""RTN"",""IBCOPP"",113,0)"
^XMB(3.9,145946,2,6282,0)=" . K ZTSK,IO(""Q"")"
^XMB(3.9,145946,2,6283,0)="""RTN"",""IBCOPP"",114,0)"
^XMB(3.9,145946,2,6284,0)=" . D ENQ"
^XMB(3.9,145946,2,6285,0)="""RTN"",""IBCOPP"",115,0)"
^XMB(3.9,145946,2,6286,0)=" ;"
^XMB(3.9,145946,2,6287,0)="""RTN"",""IBCOPP"",116,0)"
^XMB(3.9,145946,2,6288,0)=" ; Compile and print report"
^XMB(3.9,145946,2,6289,0)="""RTN"",""IBCOPP"",117,0)"
^XMB(3.9,145946,2,6290,0)=" U IO"
^XMB(3.9,145946,2,6291,0)="""RTN"",""IBCOPP"",118,0)"
^XMB(3.9,145946,2,6292,0)=" D ^IBCOPP2"
^XMB(3.9,145946,2,6293,0)="""RTN"",""IBCOPP"",119,0)"
^XMB(3.9,145946,2,6294,0)=" ;"
^XMB(3.9,145946,2,6295,0)="""RTN"",""IBCOPP"",120,0)"
^XMB(3.9,145946,2,6296,0)="ENQ ;"
^XMB(3.9,145946,2,6297,0)="""RTN"",""IBCOPP"",121,0)"
^XMB(3.9,145946,2,6298,0)=" K A,DIRUT,DIROUT,DUOUT,DTOUT,IBAO,IBAI,IBAIA,IBAIPA,IBAPA,IBAPL,IBQUIT,X,Y"
^XMB(3.9,145946,2,6299,0)="""RTN"",""IBCOPP"",122,0)"
^XMB(3.9,145946,2,6300,0)=" K ^TMP(""IBCNILKA"",$J),^TMP(""IBINC"",$J)"
^XMB(3.9,145946,2,6301,0)="""RTN"",""IBCOPP"",123,0)"
