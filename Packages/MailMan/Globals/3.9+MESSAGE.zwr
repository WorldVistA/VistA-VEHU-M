^XMB(3.9,145946,2,4914,0)=" . S LINE=$P(DLINE,"","",IX)"
^XMB(3.9,145946,2,4915,0)="""RTN"",""IBCNILK"",289,0)"
^XMB(3.9,145946,2,4916,0)=" . ;"
^XMB(3.9,145946,2,4917,0)="""RTN"",""IBCNILK"",290,0)"
^XMB(3.9,145946,2,4918,0)=" . ; If currently selected, display an error message"
^XMB(3.9,145946,2,4919,0)="""RTN"",""IBCNILK"",291,0)"
^XMB(3.9,145946,2,4920,0)=" . I $D(^TMP(""IBCNILKA"",$J,IIEN)) D  Q"
^XMB(3.9,145946,2,4921,0)="""RTN"",""IBCNILK"",292,0)"
^XMB(3.9,145946,2,4922,0)=" . . W !,*7,"">>>> # "",LINE,"" is currently selected."""
^XMB(3.9,145946,2,4923,0)="""RTN"",""IBCNILK"",293,0)"
