^XMB(3.9,145951,2,2967,0)="""RTN"",""SDESCLINICAVAIL"",4,0)"
^XMB(3.9,145951,2,2968,0)=" ;"
^XMB(3.9,145951,2,2969,0)="""RTN"",""SDESCLINICAVAIL"",5,0)"
^XMB(3.9,145951,2,2970,0)=" ; External References"
^XMB(3.9,145951,2,2971,0)="""RTN"",""SDESCLINICAVAIL"",6,0)"
^XMB(3.9,145951,2,2972,0)=" ; -------------------"
^XMB(3.9,145951,2,2973,0)="""RTN"",""SDESCLINICAVAIL"",7,0)"
^XMB(3.9,145951,2,2974,0)=" ; Reference to ^%DT        in ICR #10003"
^XMB(3.9,145951,2,2975,0)="""RTN"",""SDESCLINICAVAIL"",8,0)"
^XMB(3.9,145951,2,2976,0)=" ; Reference to $$FIND1^DIC in ICR #2051"
^XMB(3.9,145951,2,2977,0)="""RTN"",""SDESCLINICAVAIL"",9,0)"
^XMB(3.9,145951,2,2978,0)=" ; Reference to $$GET1^DIQ  in ICR #2056"
^XMB(3.9,145951,2,2979,0)="""RTN"",""SDESCLINICAVAIL"",10,0)"
^XMB(3.9,145951,2,2980,0)=" ;"
^XMB(3.9,145951,2,2981,0)="""RTN"",""SDESCLINICAVAIL"",11,0)"
^XMB(3.9,145951,2,2982,0)=" Q  ;No Direct Call"
^XMB(3.9,145951,2,2983,0)="""RTN"",""SDESCLINICAVAIL"",12,0)"
^XMB(3.9,145951,2,2984,0)=" ;"
^XMB(3.9,145951,2,2985,0)="""RTN"",""SDESCLINICAVAIL"",13,0)"
^XMB(3.9,145951,2,2986,0)="GETCLAVAILABLTY(RETURN,CLINICIEN,SDESSTART,SDESENDDATE,SDEAS) ;Called from RPC: SDES GET CLINIC AVAILABILITY"
^XMB(3.9,145951,2,2987,0)="""RTN"",""SDESCLINICAVAIL"",14,0)"
^XMB(3.9,145951,2,2988,0)=" ; This RPC returns available appointment slots within a given timeframe for a given clinic in JSON format."
^XMB(3.9,145951,2,2989,0)="""RTN"",""SDESCLINICAVAIL"",15,0)"
^XMB(3.9,145951,2,2990,0)=" ; Input:"
^XMB(3.9,145951,2,2991,0)="""RTN"",""SDESCLINICAVAIL"",16,0)"
^XMB(3.9,145951,2,2992,0)=" ; RETURN      [required] - This is where the retrieve data  is stored in JSON format"
^XMB(3.9,145951,2,2993,0)="""RTN"",""SDESCLINICAVAIL"",17,0)"
^XMB(3.9,145951,2,2994,0)=" ; CLINICIEN   [required] - The Internal Entry Number (IEN) from the HOSPITAL LOCATION File #44"
^XMB(3.9,145951,2,2995,0)="""RTN"",""SDESCLINICAVAIL"",18,0)"
^XMB(3.9,145951,2,2996,0)=" ; SDESSTART   [required] - The Start Date of search in ISO8601 format CCYY-MM-DDTHH:MM-OFFSET or external format CCYY-MM-DD"
^XMB(3.9,145951,2,2997,0)="""RTN"",""SDESCLINICAVAIL"",19,0)"
^XMB(3.9,145951,2,2998,0)=" ; SDESENDDATE [required] - The End Date of search in ISO8601 format CCYY-MM-DDTHH:MM-OFFSET or external format CCYY-MM-DD"
^XMB(3.9,145951,2,2999,0)="""RTN"",""SDESCLINICAVAIL"",20,0)"
^XMB(3.9,145951,2,3000,0)=" ; SDEAS [optional] - Enterprise Appointment Scheduling (EAS) Tracking Number associated to an appointment."
^XMB(3.9,145951,2,3001,0)="""RTN"",""SDESCLINICAVAIL"",21,0)"
^XMB(3.9,145951,2,3002,0)=" ;"
^XMB(3.9,145951,2,3003,0)="""RTN"",""SDESCLINICAVAIL"",22,0)"
^XMB(3.9,145951,2,3004,0)=" N SDGETCLAVL,SDCLNAME,ERROR,SDCLRESIEN,SDTMPARY,SDESSTARTDTTM,SDESENDDTTM"
^XMB(3.9,145951,2,3005,0)="""RTN"",""SDESCLINICAVAIL"",23,0)"
^XMB(3.9,145951,2,3006,0)=" S ERROR=0"
^XMB(3.9,145951,2,3007,0)="""RTN"",""SDESCLINICAVAIL"",24,0)"
^XMB(3.9,145951,2,3008,0)=" K RETURN,SDGETCLAVL ;always clear returned data array to ensure a new array of data are returned"
^XMB(3.9,145951,2,3009,0)="""RTN"",""SDESCLINICAVAIL"",25,0)"
^XMB(3.9,145951,2,3010,0)=" D VALIDATEINPUT ;validate input parameters"
^XMB(3.9,145951,2,3011,0)="""RTN"",""SDESCLINICAVAIL"",26,0)"
^XMB(3.9,145951,2,3012,0)=" I 'ERROR D"
^XMB(3.9,145951,2,3013,0)="""RTN"",""SDESCLINICAVAIL"",27,0)"
^XMB(3.9,145951,2,3014,0)=" . K SDTMPARY"
^XMB(3.9,145951,2,3015,0)="""RTN"",""SDESCLINICAVAIL"",28,0)"
^XMB(3.9,145951,2,3016,0)=" . S SDTMPARY=$NA(^TMP($J,""CLNCAVAIL""))"
^XMB(3.9,145951,2,3017,0)="""RTN"",""SDESCLINICAVAIL"",29,0)"
^XMB(3.9,145951,2,3018,0)=" . K @SDTMPARY"
^XMB(3.9,145951,2,3019,0)="""RTN"",""SDESCLINICAVAIL"",30,0)"
^XMB(3.9,145951,2,3020,0)=" . D GETSLOTS^SDEC57(SDTMPARY,SDCLRESIEN,SDESSTART,SDESENDDATE)"
^XMB(3.9,145951,2,3021,0)="""RTN"",""SDESCLINICAVAIL"",31,0)"
^XMB(3.9,145951,2,3022,0)=" . D BUILDDATA(CLINICIEN)"
^XMB(3.9,145951,2,3023,0)="""RTN"",""SDESCLINICAVAIL"",32,0)"
^XMB(3.9,145951,2,3024,0)=" . K @SDTMPARY"
^XMB(3.9,145951,2,3025,0)="""RTN"",""SDESCLINICAVAIL"",33,0)"
^XMB(3.9,145951,2,3026,0)=" I ERROR!('$D(SDGETCLAVL(""ClinAvail""))) S SDGETCLAVL(""ClinAvail"",1)="""""
^XMB(3.9,145951,2,3027,0)="""RTN"",""SDESCLINICAVAIL"",34,0)"
^XMB(3.9,145951,2,3028,0)=" D BUILDJSON"
^XMB(3.9,145951,2,3029,0)="""RTN"",""SDESCLINICAVAIL"",35,0)"
^XMB(3.9,145951,2,3030,0)=" K SDGETCLAVL"
^XMB(3.9,145951,2,3031,0)="""RTN"",""SDESCLINICAVAIL"",36,0)"
^XMB(3.9,145951,2,3032,0)=" Q"
^XMB(3.9,145951,2,3033,0)="""RTN"",""SDESCLINICAVAIL"",37,0)"
^XMB(3.9,145951,2,3034,0)=" ;"
^XMB(3.9,145951,2,3035,0)="""RTN"",""SDESCLINICAVAIL"",38,0)"
^XMB(3.9,145951,2,3036,0)="VALIDATEINPUT   ;validate input parameters"
^XMB(3.9,145951,2,3037,0)="""RTN"",""SDESCLINICAVAIL"",39,0)"
^XMB(3.9,145951,2,3038,0)=" N SDERR,EFLAG,SFLAG"
^XMB(3.9,145951,2,3039,0)="""RTN"",""SDESCLINICAVAIL"",40,0)"
^XMB(3.9,145951,2,3040,0)=" S (SFLAG,EFLAG)=0"
^XMB(3.9,145951,2,3041,0)="""RTN"",""SDESCLINICAVAIL"",41,0)"
^XMB(3.9,145951,2,3042,0)=" ;validate CLINIC IEN"
^XMB(3.9,145951,2,3043,0)="""RTN"",""SDESCLINICAVAIL"",42,0)"
^XMB(3.9,145951,2,3044,0)=" S CLINICIEN=$G(CLINICIEN)"
^XMB(3.9,145951,2,3045,0)="""RTN"",""SDESCLINICAVAIL"",43,0)"
^XMB(3.9,145951,2,3046,0)=" I CLINICIEN="""" D ERRLOG^SDESJSON(.SDGETCLAVL,67) S ERROR=1 Q  ;clinic cannot be blank"
^XMB(3.9,145951,2,3047,0)="""RTN"",""SDESCLINICAVAIL"",44,0)"
^XMB(3.9,145951,2,3048,0)=" I +CLINICIEN,'$D(^SC(CLINICIEN)) D ERRLOG^SDESJSON(.SDGETCLAVL,19) S ERROR=1 Q  ; clinic not found"
^XMB(3.9,145951,2,3049,0)="""RTN"",""SDESCLINICAVAIL"",45,0)"
^XMB(3.9,145951,2,3050,0)=" I +CLINICIEN'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,19) S ERROR=1 Q  ; invalid clinic"
^XMB(3.9,145951,2,3051,0)="""RTN"",""SDESCLINICAVAIL"",46,0)"
^XMB(3.9,145951,2,3052,0)=" I +CLINICIEN>0 D"
^XMB(3.9,145951,2,3053,0)="""RTN"",""SDESCLINICAVAIL"",47,0)"
^XMB(3.9,145951,2,3054,0)=" . S SDCLRESIEN=$$GETRES^SDES2UTIL1(CLINICIEN,1)"
^XMB(3.9,145951,2,3055,0)="""RTN"",""SDESCLINICAVAIL"",48,0)"
^XMB(3.9,145951,2,3056,0)=" . I 'SDCLRESIEN D ERRLOG^SDESJSON(.SDGETCLAVL,70) S ERROR=1  ;invalid clinic resource id"
^XMB(3.9,145951,2,3057,0)="""RTN"",""SDESCLINICAVAIL"",49,0)"
^XMB(3.9,145951,2,3058,0)=" ;validate start date"
^XMB(3.9,145951,2,3059,0)="""RTN"",""SDESCLINICAVAIL"",50,0)"
^XMB(3.9,145951,2,3060,0)=" S SDESSTART=$G(SDESSTART)"
^XMB(3.9,145951,2,3061,0)="""RTN"",""SDESCLINICAVAIL"",51,0)"
^XMB(3.9,145951,2,3062,0)=" I SDESSTART="""" D ERRLOG^SDESJSON(.SDGETCLAVL,25) S ERROR=1  ;missing begin date/time"
^XMB(3.9,145951,2,3063,0)="""RTN"",""SDESCLINICAVAIL"",52,0)"
^XMB(3.9,145951,2,3064,0)=" I SDESSTART'="""",+$G(SDESSTART)'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,27) S ERROR=1  ;invalid begin date"
^XMB(3.9,145951,2,3065,0)="""RTN"",""SDESCLINICAVAIL"",53,0)"
^XMB(3.9,145951,2,3066,0)=" ; If start date is external format, convert to ISO"
^XMB(3.9,145951,2,3067,0)="""RTN"",""SDESCLINICAVAIL"",54,0)"
^XMB(3.9,145951,2,3068,0)=" I $E(SDESSTART,11)'=""T"" D"
^XMB(3.9,145951,2,3069,0)="""RTN"",""SDESCLINICAVAIL"",55,0)"
^XMB(3.9,145951,2,3070,0)=" . S SDESSTART=$$ISOTFM^SDAMUTDT(SDESSTART,CLINICIEN)"
^XMB(3.9,145951,2,3071,0)="""RTN"",""SDESCLINICAVAIL"",56,0)"
^XMB(3.9,145951,2,3072,0)=" . I SDESSTART'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,27) S ERROR=1 Q"
^XMB(3.9,145951,2,3073,0)="""RTN"",""SDESCLINICAVAIL"",57,0)"
^XMB(3.9,145951,2,3074,0)=" . S SDESSTART=SDESSTART_"".000001"""
^XMB(3.9,145951,2,3075,0)="""RTN"",""SDESCLINICAVAIL"",58,0)"
^XMB(3.9,145951,2,3076,0)=" . S SDESSTART=$$FMTISO^SDAMUTDT(SDESSTART,CLINICIEN)"
^XMB(3.9,145951,2,3077,0)="""RTN"",""SDESCLINICAVAIL"",59,0)"
^XMB(3.9,145951,2,3078,0)=" . I SDESSTART'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,27) S ERROR=1 Q"
^XMB(3.9,145951,2,3079,0)="""RTN"",""SDESCLINICAVAIL"",60,0)"
^XMB(3.9,145951,2,3080,0)=" I +SDESSTART>0 D"
^XMB(3.9,145951,2,3081,0)="""RTN"",""SDESCLINICAVAIL"",61,0)"
^XMB(3.9,145951,2,3082,0)=" . S SDESSTART=$$ISOTFM^SDAMUTDT(SDESSTART,CLINICIEN)  ;convert ISO format to internal format"
^XMB(3.9,145951,2,3083,0)="""RTN"",""SDESCLINICAVAIL"",62,0)"
^XMB(3.9,145951,2,3084,0)=" . S SDESSTARTDTTM=SDESSTART"
^XMB(3.9,145951,2,3085,0)="""RTN"",""SDESCLINICAVAIL"",63,0)"
^XMB(3.9,145951,2,3086,0)=" . S SDESSTART=$P(SDESSTART,""."")"
^XMB(3.9,145951,2,3087,0)="""RTN"",""SDESCLINICAVAIL"",64,0)"
^XMB(3.9,145951,2,3088,0)=" . S SFLAG=1"
^XMB(3.9,145951,2,3089,0)="""RTN"",""SDESCLINICAVAIL"",65,0)"
^XMB(3.9,145951,2,3090,0)=" . I +SDESSTART<1 D ERRLOG^SDESJSON(.SDGETCLAVL,27) S ERROR=1 Q  ;invalid begin date/time"
^XMB(3.9,145951,2,3091,0)="""RTN"",""SDESCLINICAVAIL"",66,0)"
^XMB(3.9,145951,2,3092,0)=" . I '$P(SDESSTARTDTTM,""."",2) D ERRLOG^SDESJSON(.SDGETCLAVL,27) S ERROR=1 Q  ; invalid begin date/time (missing time)"
^XMB(3.9,145951,2,3093,0)="""RTN"",""SDESCLINICAVAIL"",67,0)"
^XMB(3.9,145951,2,3094,0)=" ;validate end date"
^XMB(3.9,145951,2,3095,0)="""RTN"",""SDESCLINICAVAIL"",68,0)"
^XMB(3.9,145951,2,3096,0)=" S SDESENDDATE=$G(SDESENDDATE)"
^XMB(3.9,145951,2,3097,0)="""RTN"",""SDESCLINICAVAIL"",69,0)"
^XMB(3.9,145951,2,3098,0)=" I SDESENDDATE="""" D ERRLOG^SDESJSON(.SDGETCLAVL,26) S ERROR=1  ;missing end date/time"
^XMB(3.9,145951,2,3099,0)="""RTN"",""SDESCLINICAVAIL"",70,0)"
^XMB(3.9,145951,2,3100,0)=" I SDESENDDATE'="""",+$G(SDESENDDATE)'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,28) S ERROR=1  ;invalid end date"
^XMB(3.9,145951,2,3101,0)="""RTN"",""SDESCLINICAVAIL"",71,0)"
^XMB(3.9,145951,2,3102,0)=" I $E(SDESENDDATE,11)'=""T"" D"
^XMB(3.9,145951,2,3103,0)="""RTN"",""SDESCLINICAVAIL"",72,0)"
^XMB(3.9,145951,2,3104,0)=" . S SDESENDDATE=$$ISOTFM^SDAMUTDT(SDESENDDATE,CLINICIEN)"
^XMB(3.9,145951,2,3105,0)="""RTN"",""SDESCLINICAVAIL"",73,0)"
^XMB(3.9,145951,2,3106,0)=" . I SDESENDDATE'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,28) S ERROR=1 Q"
^XMB(3.9,145951,2,3107,0)="""RTN"",""SDESCLINICAVAIL"",74,0)"
^XMB(3.9,145951,2,3108,0)=" . S SDESENDDATE=SDESENDDATE_"".235959"""
^XMB(3.9,145951,2,3109,0)="""RTN"",""SDESCLINICAVAIL"",75,0)"
^XMB(3.9,145951,2,3110,0)=" . S SDESENDDATE=$$FMTISO^SDAMUTDT(SDESENDDATE,CLINICIEN)"
^XMB(3.9,145951,2,3111,0)="""RTN"",""SDESCLINICAVAIL"",76,0)"
^XMB(3.9,145951,2,3112,0)=" . I SDESENDDATE'>0 D ERRLOG^SDESJSON(.SDGETCLAVL,28) S ERROR=1 Q"
^XMB(3.9,145951,2,3113,0)="""RTN"",""SDESCLINICAVAIL"",77,0)"
^XMB(3.9,145951,2,3114,0)=" I +SDESENDDATE>0 D"
^XMB(3.9,145951,2,3115,0)="""RTN"",""SDESCLINICAVAIL"",78,0)"
^XMB(3.9,145951,2,3116,0)=" . S SDESENDDATE=$$ISOTFM^SDAMUTDT(SDESENDDATE,CLINICIEN)  ;convert ISO format to internal format"
^XMB(3.9,145951,2,3117,0)="""RTN"",""SDESCLINICAVAIL"",79,0)"
^XMB(3.9,145951,2,3118,0)=" . S SDESENDDTTM=SDESENDDATE"
^XMB(3.9,145951,2,3119,0)="""RTN"",""SDESCLINICAVAIL"",80,0)"
^XMB(3.9,145951,2,3120,0)=" . S SDESENDDATE=$P(SDESENDDATE,""."")"
^XMB(3.9,145951,2,3121,0)="""RTN"",""SDESCLINICAVAIL"",81,0)"
^XMB(3.9,145951,2,3122,0)=" . S EFLAG=1"
^XMB(3.9,145951,2,3123,0)="""RTN"",""SDESCLINICAVAIL"",82,0)"
^XMB(3.9,145951,2,3124,0)=" . I +SDESENDDATE<1 D ERRLOG^SDESJSON(.SDGETCLAVL,28) S ERROR=1 Q  ;invalid end date/time"
^XMB(3.9,145951,2,3125,0)="""RTN"",""SDESCLINICAVAIL"",83,0)"
^XMB(3.9,145951,2,3126,0)=" . I '$P(SDESENDDTTM,""."",2) D ERRLOG^SDESJSON(.SDGETCLAVL,28) S ERROR=1 Q  ; invalid end date/time (missing time)"
^XMB(3.9,145951,2,3127,0)="""RTN"",""SDESCLINICAVAIL"",84,0)"
^XMB(3.9,145951,2,3128,0)=" . I $G(SDESENDDTTM)<$G(SDESSTARTDTTM) D ERRLOG^SDESJSON(.SDGETCLAVL,242) S ERROR=1 Q"
^XMB(3.9,145951,2,3129,0)="""RTN"",""SDESCLINICAVAIL"",85,0)"
^XMB(3.9,145951,2,3130,0)=" ; validate EAS"
^XMB(3.9,145951,2,3131,0)="""RTN"",""SDESCLINICAVAIL"",86,0)"
^XMB(3.9,145951,2,3132,0)=" S SDEAS=$G(SDEAS,"""")"
^XMB(3.9,145951,2,3133,0)="""RTN"",""SDESCLINICAVAIL"",87,0)"
^XMB(3.9,145951,2,3134,0)=" I $L(SDEAS) S SDEAS=$$EASVALIDATE^SDESUTIL(SDEAS)"
^XMB(3.9,145951,2,3135,0)="""RTN"",""SDESCLINICAVAIL"",88,0)"
^XMB(3.9,145951,2,3136,0)=" I SDEAS=-1 D ERRLOG^SDESJSON(.SDGETCLAVL,142) S ERROR=1"
^XMB(3.9,145951,2,3137,0)="""RTN"",""SDESCLINICAVAIL"",89,0)"
^XMB(3.9,145951,2,3138,0)=" Q"
^XMB(3.9,145951,2,3139,0)="""RTN"",""SDESCLINICAVAIL"",90,0)"
^XMB(3.9,145951,2,3140,0)=" ;"
^XMB(3.9,145951,2,3141,0)="""RTN"",""SDESCLINICAVAIL"",91,0)"
^XMB(3.9,145951,2,3142,0)="BUILDDATA(CLINICIEN) ;retrieve clinic availability data"
^XMB(3.9,145951,2,3143,0)="""RTN"",""SDESCLINICAVAIL"",92,0)"
^XMB(3.9,145951,2,3144,0)=" N SDP1,SDP2,SDP3,SDP4,SDSTRTDT,SDENDDT,SDSLOTS,SDSTOPTM,SDSTRTTM,SDTOTAL,II,SDDIV,SDINST"
^XMB(3.9,145951,2,3145,0)="""RTN"",""SDESCLINICAVAIL"",93,0)"
^XMB(3.9,145951,2,3146,0)=" I $O(@SDTMPARY@(""""))="""" Q"
^XMB(3.9,145951,2,3147,0)="""RTN"",""SDESCLINICAVAIL"",94,0)"
^XMB(3.9,145951,2,3148,0)=" S SDTOTAL=@SDTMPARY@(""CNT"")"
^XMB(3.9,145951,2,3149,0)="""RTN"",""SDESCLINICAVAIL"",95,0)"
^XMB(3.9,145951,2,3150,0)=" I $P(SDESSTARTDTTM,""."",2)=""000001"" S SDESSTARTDTTM=$P(SDESSTARTDTTM,""."")_"".000000"""
^XMB(3.9,145951,2,3151,0)="""RTN"",""SDESCLINICAVAIL"",96,0)"
^XMB(3.9,145951,2,3152,0)=" F II=1:1:SDTOTAL D"
^XMB(3.9,145951,2,3153,0)="""RTN"",""SDESCLINICAVAIL"",97,0)"
^XMB(3.9,145951,2,3154,0)=" . S SDP1=$P(@SDTMPARY@(II),U,2) ;start date"
^XMB(3.9,145951,2,3155,0)="""RTN"",""SDESCLINICAVAIL"",98,0)"
^XMB(3.9,145951,2,3156,0)=" . S SDP2=$P(@SDTMPARY@(II),U,3) ;end date"
^XMB(3.9,145951,2,3157,0)="""RTN"",""SDESCLINICAVAIL"",99,0)"
^XMB(3.9,145951,2,3158,0)=" . I (SDP1<SDESSTARTDTTM)!(SDP1>SDESENDDTTM) Q"
^XMB(3.9,145951,2,3159,0)="""RTN"",""SDESCLINICAVAIL"",100,0)"
^XMB(3.9,145951,2,3160,0)=" . S SDP3=+$P(@SDTMPARY@(II),U,4) ;open slots available"
^XMB(3.9,145951,2,3161,0)="""RTN"",""SDESCLINICAVAIL"",101,0)"
^XMB(3.9,145951,2,3162,0)=" . S SDP4=$P(@SDTMPARY@(II),U,5) ;access type  (1=available, 2=not available, 3=cancelled)"
^XMB(3.9,145951,2,3163,0)="""RTN"",""SDESCLINICAVAIL"",102,0)"
