^XMB(3.9,145946,2,5363,0)="""RTN"",""IBCNSU21"",41,0)"
^XMB(3.9,145946,2,5364,0)=" S IBP=0"
^XMB(3.9,145946,2,5365,0)="""RTN"",""IBCNSU21"",42,0)"
^XMB(3.9,145946,2,5366,0)=" F  S IBP=$O(^IBA(355.3,""B"",+IBCNS,IBP)) Q:'IBP  D"
^XMB(3.9,145946,2,5367,0)="""RTN"",""IBCNSU21"",43,0)"
^XMB(3.9,145946,2,5368,0)=" . N PLANDATA,PLANOK"
^XMB(3.9,145946,2,5369,0)="""RTN"",""IBCNSU21"",44,0)"
