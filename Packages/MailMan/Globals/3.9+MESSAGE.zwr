^XMB(3.9,145988,2,336,0)="^^1^1^3061113^"
^XMB(3.9,145988,2,337,0)="""^DD"",73.2,73.2,4,21,1,0)"
^XMB(3.9,145988,2,338,0)="This is type of imaging that will be used in RVU reports."
^XMB(3.9,145988,2,339,0)="""^DD"",73.2,73.2,4,""DT"")"
^XMB(3.9,145988,2,340,0)=3061113
^XMB(3.9,145988,2,341,0)="""^DD"",73.2,73.2,5,0)"
^XMB(3.9,145988,2,342,0)="DESCRIPTOR^FI^^1;1^K:$L(X)>150!($L(X)<3) X"
^XMB(3.9,145988,2,343,0)="""^DD"",73.2,73.2,5,3)"
^XMB(3.9,145988,2,344,0)="Answer must be 3-150 characters in length."
^XMB(3.9,145988,2,345,0)="""^DD"",73.2,73.2,5,21,0)"
^XMB(3.9,145988,2,346,0)="^^3^3^3061113^"
^XMB(3.9,145988,2,347,0)="""^DD"",73.2,73.2,5,21,1,0)"
^XMB(3.9,145988,2,348,0)="This is the long description of the CPT Code, which may be slightly "
^XMB(3.9,145988,2,349,0)="""^DD"",73.2,73.2,5,21,2,0)"
^XMB(3.9,145988,2,350,0)="different from the description for the same CPT Code in the CPT file "
^XMB(3.9,145988,2,351,0)="""^DD"",73.2,73.2,5,21,3,0)"
^XMB(3.9,145988,2,352,0)="(#81)."
^XMB(3.9,145988,2,353,0)="""^DD"",73.2,73.2,5,""DT"")"
^XMB(3.9,145988,2,354,0)=3061113
^XMB(3.9,145988,2,355,0)="""^DD"",73.2,73.2,6,0)"
^XMB(3.9,145988,2,356,0)="CMS WORK RVU^NJ6,2I^^0;6^K:+X'=X!(X>100)!(X<0)!(X?.E1"".""3N.N) X"
^XMB(3.9,145988,2,357,0)="""^DD"",73.2,73.2,6,3)"
^XMB(3.9,145988,2,358,0)="Type a Number between 0 and 100, 2 Decimal Digits"
^XMB(3.9,145988,2,359,0)="""^DD"",73.2,73.2,6,21,0)"
^XMB(3.9,145988,2,360,0)="^.001^2^2^3061113^^"
^XMB(3.9,145988,2,361,0)="""^DD"",73.2,73.2,6,21,1,0)"
^XMB(3.9,145988,2,362,0)="This is the Centers for Medicare and Medicaid Services' published values "
^XMB(3.9,145988,2,363,0)="""^DD"",73.2,73.2,6,21,2,0)"
^XMB(3.9,145988,2,364,0)="for Work Relative Value Unit for the procedure with this CPT Code."
^XMB(3.9,145988,2,365,0)="""^DD"",73.2,73.2,6,""DT"")"
^XMB(3.9,145988,2,366,0)=3061113
^XMB(3.9,145988,2,367,0)="""^DD"",73.2,73.2,7,0)"
^XMB(3.9,145988,2,368,0)="VA GAP WRVU^NJ6,2I^^0;7^K:+X'=X!(X>100)!(X<0)!(X?.E1"".""3N.N) X"
^XMB(3.9,145988,2,369,0)="""^DD"",73.2,73.2,7,3)"
^XMB(3.9,145988,2,370,0)="Type a Number between 0 and 100, 2 Decimal Digits"
^XMB(3.9,145988,2,371,0)="""^DD"",73.2,73.2,7,21,0)"
^XMB(3.9,145988,2,372,0)="^^2^2^3061113^"
^XMB(3.9,145988,2,373,0)="""^DD"",73.2,73.2,7,21,1,0)"
^XMB(3.9,145988,2,374,0)="RVU value created for VA use for codes that have no RVU value because "
^XMB(3.9,145988,2,375,0)="""^DD"",73.2,73.2,7,21,2,0)"
^XMB(3.9,145988,2,376,0)="they are designed as carrier defined by Medicare."
^XMB(3.9,145988,2,377,0)="""^DD"",73.2,73.2,7,""DT"")"
^XMB(3.9,145988,2,378,0)=3061113
^XMB(3.9,145988,2,379,0)="""^DD"",73.2,73.2,8,0)"
^XMB(3.9,145988,2,380,0)="BI-RADS PROCEDURE^SI^Y:Yes;^0;8^Q"
^XMB(3.9,145988,2,381,0)="""^DD"",73.2,73.2,8,3)"
^XMB(3.9,145988,2,382,0)="Enter a 'Y' for 'Yes' if this CPT is for a BI-RADS code."
^XMB(3.9,145988,2,383,0)="""^DD"",73.2,73.2,8,21,0)"
^XMB(3.9,145988,2,384,0)="^^2^2^3061113^"
^XMB(3.9,145988,2,385,0)="""^DD"",73.2,73.2,8,21,1,0)"
^XMB(3.9,145988,2,386,0)="This conttains a ""Yes"" if this CPT Code is a BI-RADS procedure; otherwise "
^XMB(3.9,145988,2,387,0)="""^DD"",73.2,73.2,8,21,2,0)"
^XMB(3.9,145988,2,388,0)="nothing (null)."
^XMB(3.9,145988,2,389,0)="""^DD"",73.2,73.2,8,""DT"")"
^XMB(3.9,145988,2,390,0)=3061113
^XMB(3.9,145988,2,391,0)="""^DIC"",73.2,73.2,0)"
^XMB(3.9,145988,2,392,0)="RADIOLOGY CPT BY PROCEDURE TYPE^73.2"
^XMB(3.9,145988,2,393,0)="""^DIC"",73.2,73.2,0,""GL"")"
^XMB(3.9,145988,2,394,0)="^RA(73.2,"
^XMB(3.9,145988,2,395,0)="""^DIC"",73.2,73.2,""%D"",0)"
^XMB(3.9,145988,2,396,0)="^^14^14^3060929^"
^XMB(3.9,145988,2,397,0)="""^DIC"",73.2,73.2,""%D"",1,0)"
^XMB(3.9,145988,2,398,0)="WARNING:  ENTRIES SHOULD NOT BE ADDED/DELETED/CHANGED FROM THIS FILE."
^XMB(3.9,145988,2,399,0)="""^DIC"",73.2,73.2,""%D"",2,0)"
^XMB(3.9,145988,2,400,0)=" "
^XMB(3.9,145988,2,401,0)="""^DIC"",73.2,73.2,""%D"",3,0)"
^XMB(3.9,145988,2,402,0)="This file contains only data supplied by the Office of Patient Care "
^XMB(3.9,145988,2,403,0)="""^DIC"",73.2,73.2,""%D"",4,0)"
^XMB(3.9,145988,2,404,0)="Services.  The data are sent to the Radiology development and maintenance "
^XMB(3.9,145988,2,405,0)="""^DIC"",73.2,73.2,""%D"",5,0)"
^XMB(3.9,145988,2,406,0)="teams as an Excel spreadsheet.  Updates to the data are sent as a "
^XMB(3.9,145988,2,407,0)="""^DIC"",73.2,73.2,""%D"",6,0)"
^XMB(3.9,145988,2,408,0)="comprehensive spreadsheet, so all entries in this file must be deleted "
^XMB(3.9,145988,2,409,0)="""^DIC"",73.2,73.2,""%D"",7,0)"
^XMB(3.9,145988,2,410,0)="before loading the new comprehensive spreadsheet into this file."
^XMB(3.9,145988,2,411,0)="""^DIC"",73.2,73.2,""%D"",8,0)"
^XMB(3.9,145988,2,412,0)=" "
^XMB(3.9,145988,2,413,0)="""^DIC"",73.2,73.2,""%D"",9,0)"
^XMB(3.9,145988,2,414,0)="This file provides data for certain CPT Codes.  One of the data items is "
^XMB(3.9,145988,2,415,0)="""^DIC"",73.2,73.2,""%D"",10,0)"
^XMB(3.9,145988,2,416,0)="PROCEDURE TYPE.  The PROCEDURE TYPE is similar to the Type of Imaging in "
^XMB(3.9,145988,2,417,0)="""^DIC"",73.2,73.2,""%D"",11,0)"
^XMB(3.9,145988,2,418,0)="the IMAGING TYPE file (#79.2), and is needed from this file to compare"
^XMB(3.9,145988,2,419,0)="""^DIC"",73.2,73.2,""%D"",12,0)"
^XMB(3.9,145988,2,420,0)="PROCEDURE TYPES nationally for performance monitors and performance"
^XMB(3.9,145988,2,421,0)="""^DIC"",73.2,73.2,""%D"",13,0)"
^XMB(3.9,145988,2,422,0)="measures, because not all sites are assigning the same Type of Imaging to"
^XMB(3.9,145988,2,423,0)="""^DIC"",73.2,73.2,""%D"",14,0)"
^XMB(3.9,145988,2,424,0)="the same CPT Code via the RAD/NUC MED PROCEDURES file (#71)."
^XMB(3.9,145988,2,425,0)="""^DIC"",73.2,""B"",""RADIOLOGY CPT BY PROCEDURE TYP"",73.2)"
^XMB(3.9,145988,2,426,0)=""
