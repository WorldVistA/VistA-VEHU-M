^XMB(3.9,145956,2,2308,0)=" S AUMTD=$P($$TMDEV^ORB31(AUMTEAM),""^"",2)"
^XMB(3.9,145956,2,2309,0)="""RTN"",""TIUTIUS"",212,0)"
^XMB(3.9,145956,2,2310,0)=" I AUMTD'="""" S AUMTDEV(AUMTD)="""" D REGDEV^ORB31(.AUMTDEV)"
^XMB(3.9,145956,2,2311,0)="""RTN"",""TIUTIUS"",213,0)"
^XMB(3.9,145956,2,2312,0)=" D TEAMPROV^ORQPTQ1(.AUMTEAM,AUMTEAM)"
^XMB(3.9,145956,2,2313,0)="""RTN"",""TIUTIUS"",214,0)"
^XMB(3.9,145956,2,2314,0)=" I '$G(AUMTEAM(1)) Q"
^XMB(3.9,145956,2,2315,0)="""RTN"",""TIUTIUS"",215,0)"
^XMB(3.9,145956,2,2316,0)=" S AUMTSA(AUMTI,AUMTEAM)="""""
^XMB(3.9,145956,2,2317,0)="""RTN"",""TIUTIUS"",216,0)"
^XMB(3.9,145956,2,2318,0)=" S AUMTJ=0"
^XMB(3.9,145956,2,2319,0)="""RTN"",""TIUTIUS"",217,0)"
^XMB(3.9,145956,2,2320,0)=" F  S AUMTJ=$O(AUMTEAM(AUMTJ)) Q:'AUMTJ  S XQA(+AUMTEAM(AUMTJ))="""""
^XMB(3.9,145956,2,2321,0)="""RTN"",""TIUTIUS"",218,0)"
^XMB(3.9,145956,2,2322,0)=" Q"
^XMB(3.9,145956,2,2323,0)="""VER"")"
^XMB(3.9,145956,2,2324,0)="8.0^22.2"
^XMB(3.9,145956,2,2325,0)="""^DD"",8925.99,8925.99,3.1,0)"
^XMB(3.9,145956,2,2326,0)="START OF ADD SGNR ALERT PERIOD^FJ5^^3;1^K:$L(X)>5!($L(X)<1)!'((X?1.4N1""D"")!(X?1.4N1""W"")!(X?1.4N1""M"")) X"
^XMB(3.9,145956,2,2327,0)="""^DD"",8925.99,8925.99,3.1,3)"
^XMB(3.9,145956,2,2328,0)="Equivalent to LENGTH OF SIGNER ALERT PERIOD but for ADDITIONAL SIGNATURES. Must be 1-4 NUMBERS followed by ""D"", ""W"" or ""M"". Default is 7D."
^XMB(3.9,145956,2,2329,0)="""^DD"",8925.99,8925.99,3.1,21,0)"
^XMB(3.9,145956,2,2330,0)="^^17^17^3230113^^"
^XMB(3.9,145956,2,2331,0)="""^DD"",8925.99,8925.99,3.1,21,1,0)"
^XMB(3.9,145956,2,2332,0)="This parameter determines how far back the nightly task will look "
^XMB(3.9,145956,2,2333,0)="""^DD"",8925.99,8925.99,3.1,21,2,0)"
^XMB(3.9,145956,2,2334,0)="for overdue additional signatures."
^XMB(3.9,145956,2,2335,0)="""^DD"",8925.99,8925.99,3.1,21,3,0)"
^XMB(3.9,145956,2,2336,0)=" "
^XMB(3.9,145956,2,2337,0)="""^DD"",8925.99,8925.99,3.1,21,4,0)"
^XMB(3.9,145956,2,2338,0)="If blank, defaults to 12M."
^XMB(3.9,145956,2,2339,0)="""^DD"",8925.99,8925.99,3.1,21,5,0)"
^XMB(3.9,145956,2,2340,0)=" "
^XMB(3.9,145956,2,2341,0)="""^DD"",8925.99,8925.99,3.1,21,6,0)"
^XMB(3.9,145956,2,2342,0)="This parameter should be set to the same value as the LENGTH OF SIGNER"
^XMB(3.9,145956,2,2343,0)="""^DD"",8925.99,8925.99,3.1,21,7,0)"
^XMB(3.9,145956,2,2344,0)="ALERT PERIOD to avoid any potential gaps in resending alerts."
^XMB(3.9,145956,2,2345,0)="""^DD"",8925.99,8925.99,3.1,21,8,0)"
^XMB(3.9,145956,2,2346,0)=" "
^XMB(3.9,145956,2,2347,0)="""^DD"",8925.99,8925.99,3.1,21,9,0)"
^XMB(3.9,145956,2,2348,0)="If this parameter is less than the LENGTH OF SIGNER ALERT PERIOD, "
^XMB(3.9,145956,2,2349,0)="""^DD"",8925.99,8925.99,3.1,21,10,0)"
^XMB(3.9,145956,2,2350,0)="documents that fall between the date ranges will NOT have alerts sent as "
^XMB(3.9,145956,2,2351,0)="""^DD"",8925.99,8925.99,3.1,21,11,0)"
^XMB(3.9,145956,2,2352,0)="OVERDUE."
^XMB(3.9,145956,2,2353,0)="""^DD"",8925.99,8925.99,3.1,21,12,0)"
^XMB(3.9,145956,2,2354,0)=" "
^XMB(3.9,145956,2,2355,0)="""^DD"",8925.99,8925.99,3.1,21,13,0)"
^XMB(3.9,145956,2,2356,0)="Example:  LENGTH OF SIGNER ALERT PERIOD=12M"
^XMB(3.9,145956,2,2357,0)="""^DD"",8925.99,8925.99,3.1,21,14,0)"
^XMB(3.9,145956,2,2358,0)="          START OF ADD SGNR ALERT PERIOD=6M"
^XMB(3.9,145956,2,2359,0)="""^DD"",8925.99,8925.99,3.1,21,15,0)"
^XMB(3.9,145956,2,2360,0)=" "
^XMB(3.9,145956,2,2361,0)="""^DD"",8925.99,8925.99,3.1,21,16,0)"
^XMB(3.9,145956,2,2362,0)="Documents that have outstanding additional signatures between 6M+1-12M"
^XMB(3.9,145956,2,2363,0)="""^DD"",8925.99,8925.99,3.1,21,17,0)"
^XMB(3.9,145956,2,2364,0)="will be excluded."
^XMB(3.9,145956,2,2365,0)="""^DD"",8925.99,8925.99,3.1,""AUDIT"")"
^XMB(3.9,145956,2,2366,0)="n"
^XMB(3.9,145956,2,2367,0)="""^DD"",8925.99,8925.99,3.1,""DT"")"
