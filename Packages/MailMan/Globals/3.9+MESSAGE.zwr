^XMB(3.9,145944,2,215,0)="""QUES"",""XPM1"",""??"")"
^XMB(3.9,145944,2,216,0)="^D MG^XPDH"
^XMB(3.9,145944,2,217,0)="""QUES"",""XPM1"",""A"")"
^XMB(3.9,145944,2,218,0)="Enter the Coordinator for Mail Group '|FLAG|'"
^XMB(3.9,145944,2,219,0)="""QUES"",""XPM1"",""B"")"
