^XMB(3.9,145980,2,5484,0)="CREATE(JSON,SDCONTEXT,AVAILABILITY) ;"
^XMB(3.9,145980,2,5485,0)="""RTN"",""SDES2CRTCLNAVAL2"",9,0)"
^XMB(3.9,145980,2,5486,0)=" N ERRORS,RETURNAVAIL,CLINICIEN,CLINICSTARTHOUR,NUMBEROFENTRIES,INPUTS,INDEFINITEUNTIL,SDDISPPERHR,SDCLINSTARTHR,SLOTSTOCANCEL,%,%DT"
^XMB(3.9,145980,2,5487,0)="""RTN"",""SDES2CRTCLNAVAL2"",10,0)"
^XMB(3.9,145980,2,5488,0)=" ;"
^XMB(3.9,145980,2,5489,0)="""RTN"",""SDES2CRTCLNAVAL2"",11,0)"
^XMB(3.9,145980,2,5490,0)=" M INPUTS=AVAILABILITY"
^XMB(3.9,145980,2,5491,0)="""RTN"",""SDES2CRTCLNAVAL2"",12,0)"
^XMB(3.9,145980,2,5492,0)=" D VALCONTEXT^SDES2VALCONTEXT(.ERRORS,.SDCONTEXT)"
^XMB(3.9,145980,2,5493,0)="""RTN"",""SDES2CRTCLNAVAL2"",13,0)"
^XMB(3.9,145980,2,5494,0)=" I $D(ERRORS) S ERRORS(""clinicAvailability"")="""" K CNT,I D BUILDJSON^SDES2JSON(.JSON,.ERRORS) Q"
^XMB(3.9,145980,2,5495,0)="""RTN"",""SDES2CRTCLNAVAL2"",14,0)"
^XMB(3.9,145980,2,5496,0)=" I $G(SDCONTEXT(""USER DUZ""))'="""" N DUZ D DUZ^XUP(SDCONTEXT(""USER DUZ""))"
^XMB(3.9,145980,2,5497,0)="""RTN"",""SDES2CRTCLNAVAL2"",15,0)"
^XMB(3.9,145980,2,5498,0)=" D VALIDATE(.ERRORS,.AVAILABILITY,.CLINICIEN,.CLINICSTARTHOUR,.NUMBEROFENTRIES,.INPUTS)"
^XMB(3.9,145980,2,5499,0)="""RTN"",""SDES2CRTCLNAVAL2"",16,0)"
^XMB(3.9,145980,2,5500,0)=" I $D(ERRORS) S ERRORS(""clinicAvailability"")="""" K CNT,I D BUILDJSON^SDES2JSON(.JSON,.ERRORS) Q"
^XMB(3.9,145980,2,5501,0)="""RTN"",""SDES2CRTCLNAVAL2"",17,0)"
^XMB(3.9,145980,2,5502,0)=" ;"
^XMB(3.9,145980,2,5503,0)="""RTN"",""SDES2CRTCLNAVAL2"",18,0)"
^XMB(3.9,145980,2,5504,0)=" D CREATEAVAIL(.AVAILABILITY,.SDCONTEXT,.SLOTSTOCANCEL,CLINICIEN,CLINICSTARTHOUR,$$GET1^DIQ(44,CLINICIEN,1917,""I""),$$GET1^DIQ(44,CLINICIEN,1914,""I""),NUMBEROFENTRIES,.INPUTS,.INDEFINITEUNTIL,.RETURNAVAIL,.ERRORS)"
^XMB(3.9,145980,2,5505,0)="""RTN"",""SDES2CRTCLNAVAL2"",19,0)"
^XMB(3.9,145980,2,5506,0)=" ;"
^XMB(3.9,145980,2,5507,0)="""RTN"",""SDES2CRTCLNAVAL2"",20,0)"
^XMB(3.9,145980,2,5508,0)=" I $L($G(SLOTSTOCANCEL(""CancelledSlots"",1,""BeginTime""))),$G(AVAILABILITY(""KEEP CANCELLED SLOTS""))=1 D"
^XMB(3.9,145980,2,5509,0)="""RTN"",""SDES2CRTCLNAVAL2"",21,0)"
