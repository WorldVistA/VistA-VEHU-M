^XMB(3.9,145944,2,1789,0)="""RTN"",""IBJDF6"",120,0)"
^XMB(3.9,145944,2,1790,0)=" D ^DIR K DIR G:$D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1791,0)="""RTN"",""IBJDF6"",121,0)"
