^XMB(3.9,145952,2,2854,0)="BUILDER ;"
^XMB(3.9,145952,2,2855,0)="""RTN"",""SDESGETCLINAPPT"",53,0)"
^XMB(3.9,145952,2,2856,0)=" D ENCODE^XLFJSON(""APPTREC"",""SDECY"",""ERR"")"
