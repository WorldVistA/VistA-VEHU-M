^XMB(3.9,145935,2,486,0)=" ; MbM Only - Change to allow users to validate Patient, Provider and Drug for records on Hold, as well as Accept Validation"
^XMB(3.9,145935,2,487,0)="""RTN"",""PSOERXU7"",123,0)"
^XMB(3.9,145935,2,488,0)=" S MBMALLOW=0"
^XMB(3.9,145935,2,489,0)="""RTN"",""PSOERXU7"",124,0)"
^XMB(3.9,145935,2,490,0)=" I $$GET1^DIQ(59.7,1,102,""I"")=""MBM"",$E(MSTAT)=""H"",'$D(^XUSEC(""PSO ERX VIEW"",DUZ)) D  I $G(MBMALLOW) Q 1"
^XMB(3.9,145935,2,491,0)="""RTN"",""PSOERXU7"",125,0)"
^XMB(3.9,145935,2,492,0)=" . I OPTION=""PSO ERX VALIDATE PATIENT"" S MBMALLOW=1"
^XMB(3.9,145935,2,493,0)="""RTN"",""PSOERXU7"",126,0)"
^XMB(3.9,145935,2,494,0)=" . I OPTION=""PSO ERX VALIDATE PROVIDER"" S MBMALLOW=1"
^XMB(3.9,145935,2,495,0)="""RTN"",""PSOERXU7"",127,0)"
^XMB(3.9,145935,2,496,0)=" . I OPTION=""PSO ERX VALIDATE DRUG"" S MBMALLOW=1"
^XMB(3.9,145935,2,497,0)="""RTN"",""PSOERXU7"",128,0)"
^XMB(3.9,145935,2,498,0)=" . I OPTION=""PSO ERX ACCEPT VALIDATION"" S MBMALLOW=1"
^XMB(3.9,145935,2,499,0)="""RTN"",""PSOERXU7"",129,0)"
^XMB(3.9,145935,2,500,0)=" I $E(MSTAT)=""H"",OPTION'[""HOLD"",OPTION'[""UNHOLD"",OPTION'[""PRINT"",OPTION'[""HISTORY"",OPTION'[""REMOVE"" Q 0"
^XMB(3.9,145935,2,501,0)="""RTN"",""PSOERXU7"",130,0)"
^XMB(3.9,145935,2,502,0)=" I OPTION=""PSO ERX ACCEPT ERX"",(RESVAL=""AWC""!(RESVAL=""R"")),MTYPE=""RE"",(MSTAT=""RXN""!(MSTAT=""RXW"")) D  Q RET"
^XMB(3.9,145935,2,503,0)="""RTN"",""PSOERXU7"",131,0)"
^XMB(3.9,145935,2,504,0)=" .S RET=0 I ('$D(^XUSEC(""PSDRPH"",DUZ))),('$D(^XUSEC(""PSO ERX ADV TECH"",DUZ))) Q"
^XMB(3.9,145935,2,505,0)="""RTN"",""PSOERXU7"",132,0)"
^XMB(3.9,145935,2,506,0)=" .I MSTAT=""RXW"" S RET=1 Q"
^XMB(3.9,145935,2,507,0)="""RTN"",""PSOERXU7"",133,0)"
^XMB(3.9,145935,2,508,0)=" .S RESIEN=PSOIEN,REQIEN=$$GETREQ^PSOERXU2(PSOIEN)"
^XMB(3.9,145935,2,509,0)="""RTN"",""PSOERXU7"",134,0)"
^XMB(3.9,145935,2,510,0)=" .D RRDELTA^PSOERXU2(.DELTA,REQIEN,RESIEN)"
^XMB(3.9,145935,2,511,0)="""RTN"",""PSOERXU7"",135,0)"
^XMB(3.9,145935,2,512,0)=" .I $D(DELTA(52.49,""EXTERNAL PROVIDER"")) S RET=1"
^XMB(3.9,145935,2,513,0)="""RTN"",""PSOERXU7"",136,0)"
^XMB(3.9,145935,2,514,0)=" ; block all but accept erx on eRx's in RXW status"
^XMB(3.9,145935,2,515,0)="""RTN"",""PSOERXU7"",137,0)"
^XMB(3.9,145935,2,516,0)=" I OPTION'=""PSO ERX ACCEPT ERX"",MSTAT=""RXW"",RESVAL'=""R"" Q 0"
^XMB(3.9,145935,2,517,0)="""RTN"",""PSOERXU7"",138,0)"
^XMB(3.9,145935,2,518,0)=" ;"
^XMB(3.9,145935,2,519,0)="""RTN"",""PSOERXU7"",139,0)"
^XMB(3.9,145935,2,520,0)=" I OPTION=""PSO ERX UNHOLD"",($D(^XUSEC(""PSO ERX VIEW"",DUZ))) Q 0"
^XMB(3.9,145935,2,521,0)="""RTN"",""PSOERXU7"",140,0)"
^XMB(3.9,145935,2,522,0)=" I OPTION=""PSO ERX REJECT""!(OPTION=""PSO ERX REMOVE""),MSTAT=""RXE"" Q 0"
^XMB(3.9,145935,2,523,0)="""RTN"",""PSOERXU7"",141,0)"
^XMB(3.9,145935,2,524,0)=" I OPTION=""PSO ERX REJECT""!(OPTION=""PSO ERX REMOVE"")!(OPTION=""PSO ERX HOLD"")!(OPTION=""PSO ERX UNHOLD""),MSTAT=""RXN"" Q 0"
^XMB(3.9,145935,2,525,0)="""RTN"",""PSOERXU7"",142,0)"
^XMB(3.9,145935,2,526,0)=" I OPTION=""PSO ERX ACCEPT ERX"",('$D(^XUSEC(""PSDRPH"",DUZ))),('$D(^XUSEC(""PSO ERX ADV TECH"",DUZ))) Q 0"
^XMB(3.9,145935,2,527,0)="""RTN"",""PSOERXU7"",143,0)"
^XMB(3.9,145935,2,528,0)=" I OPTION=""PSO ERX ACCEPT VALIDATION"",$D(^XUSEC(""PSO ERX VIEW"",DUZ)) Q 0"
^XMB(3.9,145935,2,529,0)="""RTN"",""PSOERXU7"",144,0)"
^XMB(3.9,145935,2,530,0)=" I OPTION=""PSO ERX REJECT"",($D(^XUSEC(""PSO ERX VIEW"",DUZ))) Q 0"
^XMB(3.9,145935,2,531,0)="""RTN"",""PSOERXU7"",145,0)"
^XMB(3.9,145935,2,532,0)=" I OPTION=""PSO ERX REMOVE"",($D(^XUSEC(""PSO ERX VIEW"",DUZ))) Q 0"
^XMB(3.9,145935,2,533,0)="""RTN"",""PSOERXU7"",146,0)"
^XMB(3.9,145935,2,534,0)=" I OPTION=""PSO ERX VALIDATE PATIENT"",$D(^XUSEC(""PSO ERX VIEW"",DUZ)) Q 0"
^XMB(3.9,145935,2,535,0)="""RTN"",""PSOERXU7"",147,0)"
^XMB(3.9,145935,2,536,0)=" I OPTION=""PSO ERX VALIDATE PROVIDER"",$D(^XUSEC(""PSO ERX VIEW"",DUZ)) Q 0"
^XMB(3.9,145935,2,537,0)="""RTN"",""PSOERXU7"",148,0)"
^XMB(3.9,145935,2,538,0)=" I OPTION=""PSO ERX VALIDATE DRUG"",$D(^XUSEC(""PSO ERX VIEW"",DUZ)) Q 0"
^XMB(3.9,145935,2,539,0)="""RTN"",""PSOERXU7"",149,0)"
^XMB(3.9,145935,2,540,0)=" I OPTION=""PSO ERX HOLD"",$D(^XUSEC(""PSO ERX VIEW"",DUZ)) Q 0"
^XMB(3.9,145935,2,541,0)="""RTN"",""PSOERXU7"",150,0)"
^XMB(3.9,145935,2,542,0)=" Q 1"
^XMB(3.9,145935,2,543,0)="""RTN"",""PSOERXU7"",151,0)"
^XMB(3.9,145935,2,544,0)="ERRDISP(ERXIEN,LINE) ;"
^XMB(3.9,145935,2,545,0)="""RTN"",""PSOERXU7"",152,0)"
^XMB(3.9,145935,2,546,0)=" N ECODE,ETEXT,EDECODE,EDICODE,I,ERRDTTM"
^XMB(3.9,145935,2,547,0)="""RTN"",""PSOERXU7"",153,0)"
^XMB(3.9,145935,2,548,0)=" S ECODE=$$GET1^DIQ(52.49,ERXIEN,60.1,""E"")"
^XMB(3.9,145935,2,549,0)="""RTN"",""PSOERXU7"",154,0)"
^XMB(3.9,145935,2,550,0)=" S ETEXT=$$GET1^DIQ(52.49,ERXIEN,60,""E"")"
^XMB(3.9,145935,2,551,0)="""RTN"",""PSOERXU7"",155,0)"
^XMB(3.9,145935,2,552,0)=" S ERRDTTM=$$GET1^DIQ(52.49,ERXIEN,.03,""E"")"
^XMB(3.9,145935,2,553,0)="""RTN"",""PSOERXU7"",156,0)"
^XMB(3.9,145935,2,554,0)=" S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,555,0)="""RTN"",""PSOERXU7"",157,0)"
^XMB(3.9,145935,2,556,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""*****************************ERROR DETAILS********************************"")"
^XMB(3.9,145935,2,557,0)="""RTN"",""PSOERXU7"",158,0)"
^XMB(3.9,145935,2,558,0)=" I $G(SDERXFLG) D SET^VALM10(LINE,""                                ERROR DETAILS                                ""),CNTRL^VALM10(LINE,1,80,$G(IOUON)_$G(IOINHI),$G(IOUOFF)_$G(IOINORM))"
^XMB(3.9,145935,2,559,0)="""RTN"",""PSOERXU7"",159,0)"
^XMB(3.9,145935,2,560,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Error Date/Time: ""_ERRDTTM),CNTRL^VALM10(LINE,18,$L(ERRDTTM),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,561,0)="""RTN"",""PSOERXU7"",160,0)"
^XMB(3.9,145935,2,562,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Code: ""_ECODE),CNTRL^VALM10(LINE,7,$L(ECODE),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,563,0)="""RTN"",""PSOERXU7"",161,0)"
^XMB(3.9,145935,2,564,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Details: ""_ETEXT),CNTRL^VALM10(LINE,10,$L(ETEXT),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,565,0)="""RTN"",""PSOERXU7"",162,0)"
^XMB(3.9,145935,2,566,0)=" I $D(^PS(52.49,ERXIEN,61)) D"
^XMB(3.9,145935,2,567,0)="""RTN"",""PSOERXU7"",163,0)"
^XMB(3.9,145935,2,568,0)=" .I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,569,0)="""RTN"",""PSOERXU7"",164,0)"
^XMB(3.9,145935,2,570,0)=" .S LINE=LINE+1 D SET^VALM10(LINE,""Description Codes"")"
^XMB(3.9,145935,2,571,0)="""RTN"",""PSOERXU7"",165,0)"
^XMB(3.9,145935,2,572,0)=" .S LINE=LINE+1 D SET^VALM10(LINE,""================="")"
^XMB(3.9,145935,2,573,0)="""RTN"",""PSOERXU7"",166,0)"
^XMB(3.9,145935,2,574,0)=" .I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,575,0)="""RTN"",""PSOERXU7"",167,0)"
^XMB(3.9,145935,2,576,0)=" S I=0 F  S I=$O(^PS(52.49,ERXIEN,61,I)) Q:'I  D"
^XMB(3.9,145935,2,577,0)="""RTN"",""PSOERXU7"",168,0)"
^XMB(3.9,145935,2,578,0)=" .S EDECODE=$$GET1^DIQ(52.4961,I_"",""_ERXIEN_"","",.01,""E"")"
^XMB(3.9,145935,2,579,0)="""RTN"",""PSOERXU7"",169,0)"
^XMB(3.9,145935,2,580,0)=" .S EDICODE=$$GET1^DIQ(52.4961,I_"",""_ERXIEN_"","",.01,""I"")"
^XMB(3.9,145935,2,581,0)="""RTN"",""PSOERXU7"",170,0)"
^XMB(3.9,145935,2,582,0)=" .S LINE=LINE+1 D SET^VALM10(LINE,EDICODE_"" - ""_EDECODE),CNTRL^VALM10(LINE,1,$L(EDICODE_"" - ""_EDECODE),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,583,0)="""RTN"",""PSOERXU7"",171,0)"
^XMB(3.9,145935,2,584,0)=" Q"
^XMB(3.9,145935,2,585,0)="""RTN"",""PSOERXU7"",172,0)"
^XMB(3.9,145935,2,586,0)=" ;"
^XMB(3.9,145935,2,587,0)="""RTN"",""PSOERXU7"",173,0)"
^XMB(3.9,145935,2,588,0)=" ; refill request information"
^XMB(3.9,145935,2,589,0)="""RTN"",""PSOERXU7"",174,0)"
^XMB(3.9,145935,2,590,0)="RRREQ(ERXIEN,LINE) ;"
^XMB(3.9,145935,2,591,0)="""RTN"",""PSOERXU7"",175,0)"
^XMB(3.9,145935,2,592,0)=" N REQBY,REQDTTM,REFREQ,COMM,COMMARY,I,COMMBY,COMMDTTM,CTXT,REQIEN,S2017"
^XMB(3.9,145935,2,593,0)="""RTN"",""PSOERXU7"",176,0)"
^XMB(3.9,145935,2,594,0)=" S REQIEN=ERXIEN"
^XMB(3.9,145935,2,595,0)="""RTN"",""PSOERXU7"",177,0)"
^XMB(3.9,145935,2,596,0)=" I $$GET1^DIQ(52.49,ERXIEN,.08,""I"")=""RE"" S REQIEN=$$RESOLV^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,597,0)="""RTN"",""PSOERXU7"",178,0)"
^XMB(3.9,145935,2,598,0)=" S REQBY=$$GET1^DIQ(52.49,REQIEN,51.1,""E"")"
^XMB(3.9,145935,2,599,0)="""RTN"",""PSOERXU7"",179,0)"
^XMB(3.9,145935,2,600,0)=" S REFREQ=$$GET1^DIQ(52.49,REQIEN,51.2,""E"")"
^XMB(3.9,145935,2,601,0)="""RTN"",""PSOERXU7"",180,0)"
^XMB(3.9,145935,2,602,0)=" S REQDTTM=$$GET1^DIQ(52.49,REQIEN,.03,""E"")"
^XMB(3.9,145935,2,603,0)="""RTN"",""PSOERXU7"",181,0)"
^XMB(3.9,145935,2,604,0)=" S COMM=$$GET1^DIQ(52.49,REQIEN,50,""E"")"
^XMB(3.9,145935,2,605,0)="""RTN"",""PSOERXU7"",182,0)"
^XMB(3.9,145935,2,606,0)=" S S2017=$$GET1^DIQ(52.49,ERXIEN,312.1)"
^XMB(3.9,145935,2,607,0)="""RTN"",""PSOERXU7"",183,0)"
^XMB(3.9,145935,2,608,0)=" I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,609,0)="""RTN"",""PSOERXU7"",184,0)"
^XMB(3.9,145935,2,610,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""************************RXRENEWAL REQUEST INFORMATION**************************"")"
^XMB(3.9,145935,2,611,0)="""RTN"",""PSOERXU7"",185,0)"
^XMB(3.9,145935,2,612,0)=" I $G(SDERXFLG) D SET^VALM10(LINE,""                        RXRENEWAL REQUEST INFORMATION                          ""),CNTRL^VALM10(LINE,1,80,$G(IOUON)_$G(IOINHI),$G(IOUOFF)_$G(IOINORM))"
^XMB(3.9,145935,2,613,0)="""RTN"",""PSOERXU7"",186,0)"
^XMB(3.9,145935,2,614,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Requested By: ""_REQBY),CNTRL^VALM10(LINE,15,$L(REQBY),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,615,0)="""RTN"",""PSOERXU7"",187,0)"
^XMB(3.9,145935,2,616,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Request Date/Time: ""_REQDTTM),CNTRL^VALM10(LINE,20,$L(REQDTTM),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,617,0)="""RTN"",""PSOERXU7"",188,0)"
^XMB(3.9,145935,2,618,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""# of Refills Requested: ""_REFREQ),CNTRL^VALM10(LINE,25,$L(REFREQ),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,619,0)="""RTN"",""PSOERXU7"",189,0)"
^XMB(3.9,145935,2,620,0)=" I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,621,0)="""RTN"",""PSOERXU7"",190,0)"
^XMB(3.9,145935,2,622,0)=" S COMM=""RxRenewal Request Comments: ""_COMM"
^XMB(3.9,145935,2,623,0)="""RTN"",""PSOERXU7"",191,0)"
^XMB(3.9,145935,2,624,0)=" D TXT2ARY^PSOERXD1(.COMMARY,COMM,"" "",80)"
^XMB(3.9,145935,2,625,0)="""RTN"",""PSOERXU7"",192,0)"
^XMB(3.9,145935,2,626,0)=" S I=0 F  S I=$O(COMMARY(I)) Q:'I  D"
^XMB(3.9,145935,2,627,0)="""RTN"",""PSOERXU7"",193,0)"
^XMB(3.9,145935,2,628,0)=" .S CTXT=$G(COMMARY(I))"
^XMB(3.9,145935,2,629,0)="""RTN"",""PSOERXU7"",194,0)"
^XMB(3.9,145935,2,630,0)=" .S LINE=LINE+1 D SET^VALM10(LINE,CTXT)"
^XMB(3.9,145935,2,631,0)="""RTN"",""PSOERXU7"",195,0)"
^XMB(3.9,145935,2,632,0)=" .I I=1 D CNTRL^VALM10(LINE,29,$L($P(CTXT,"":"",2)),$G(IOINHI),$G(IOINORM)) Q"
^XMB(3.9,145935,2,633,0)="""RTN"",""PSOERXU7"",196,0)"
^XMB(3.9,145935,2,634,0)=" .D CNTRL^VALM10(LINE,1,$L(CTXT),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,635,0)="""RTN"",""PSOERXU7"",197,0)"
^XMB(3.9,145935,2,636,0)=" S COMMBY=$$GET1^DIQ(52.49,REQIEN,50.1,""E"")"
^XMB(3.9,145935,2,637,0)="""RTN"",""PSOERXU7"",198,0)"
^XMB(3.9,145935,2,638,0)=" S COMMDTTM=$$GET1^DIQ(52.49,REQIEN,50.2,""E"")"
^XMB(3.9,145935,2,639,0)="""RTN"",""PSOERXU7"",199,0)"
^XMB(3.9,145935,2,640,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Comments By: ""_COMMBY),CNTRL^VALM10(LINE,14,$L(COMMBY),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,641,0)="""RTN"",""PSOERXU7"",200,0)"
^XMB(3.9,145935,2,642,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Comments Date/Time: ""_COMMDTTM),CNTRL^VALM10(LINE,21,$L(COMMDTTM),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,643,0)="""RTN"",""PSOERXU7"",201,0)"
^XMB(3.9,145935,2,644,0)=" Q"
^XMB(3.9,145935,2,645,0)="""RTN"",""PSOERXU7"",202,0)"
^XMB(3.9,145935,2,646,0)=" ;"
^XMB(3.9,145935,2,647,0)="""RTN"",""PSOERXU7"",203,0)"
^XMB(3.9,145935,2,648,0)="MSGHIS(ERXIEN,LINE) ;"
^XMB(3.9,145935,2,649,0)="""RTN"",""PSOERXU7"",204,0)"
^XMB(3.9,145935,2,650,0)=" N FLAG"
^XMB(3.9,145935,2,651,0)="""RTN"",""PSOERXU7"",205,0)"
^XMB(3.9,145935,2,652,0)=" S FLAG=+$G(FLAG)"
^XMB(3.9,145935,2,653,0)="""RTN"",""PSOERXU7"",206,0)"
^XMB(3.9,145935,2,654,0)=" N ERXREF,RELERX,ERXRES,I,ERXHID,FOUND,REQID,RESID,MTYPE"
^XMB(3.9,145935,2,655,0)="""RTN"",""PSOERXU7"",207,0)"
^XMB(3.9,145935,2,656,0)=" S MTYPE=$$GET1^DIQ(52.49,ERXIEN,.08,""I"")"
^XMB(3.9,145935,2,657,0)="""RTN"",""PSOERXU7"",208,0)"
^XMB(3.9,145935,2,658,0)=" I "",RR,CA,CR,""[("",""_MTYPE_"","") S REQIEN=ERXIEN,RESIEN=$$GETRESP^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,659,0)="""RTN"",""PSOERXU7"",209,0)"
^XMB(3.9,145935,2,660,0)=" I "",RE,CN,CX,""[("",""_MTYPE_"","") S RESIEN=ERXIEN,REQIEN=$$RESOLV^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,661,0)="""RTN"",""PSOERXU7"",210,0)"
^XMB(3.9,145935,2,662,0)=" I MTYPE=""IE"" S RESIEN=ERXIEN,REQIEN=$$RESOLV^PSOERXU2(ERXIEN)"
^XMB(3.9,145935,2,663,0)="""RTN"",""PSOERXU7"",211,0)"
^XMB(3.9,145935,2,664,0)=" S RESID=$$GET1^DIQ(52.49,RESIEN,.01,""E"")"
^XMB(3.9,145935,2,665,0)="""RTN"",""PSOERXU7"",212,0)"
^XMB(3.9,145935,2,666,0)=" S REQID=$$GET1^DIQ(52.49,REQIEN,.01,""E"")"
^XMB(3.9,145935,2,667,0)="""RTN"",""PSOERXU7"",213,0)"
^XMB(3.9,145935,2,668,0)=" S RELERX=$$GET1^DIQ(52.49,REQIEN,.14)"
^XMB(3.9,145935,2,669,0)="""RTN"",""PSOERXU7"",214,0)"
^XMB(3.9,145935,2,670,0)=" S FOUND=0"
^XMB(3.9,145935,2,671,0)="""RTN"",""PSOERXU7"",215,0)"
^XMB(3.9,145935,2,672,0)=" S I=ERXIEN F  S I=$O(^PS(52.49,ERXIEN,201,""B"",I)) Q:'I!(FOUND)  D"
^XMB(3.9,145935,2,673,0)="""RTN"",""PSOERXU7"",216,0)"
^XMB(3.9,145935,2,674,0)=" .I $$GET1^DIQ(52.49,I,.08,""E"")=""RE"",$$GET1^DIQ(52.49,I,.14,""E"")=$$GET1^DIQ(52.49,ERXIEN,.01,""E"") S ERXRES=$$GET1^DIQ(52.49,I,.14,""E""),FOUND=1"
^XMB(3.9,145935,2,675,0)="""RTN"",""PSOERXU7"",217,0)"
^XMB(3.9,145935,2,676,0)=" I '$G(SDERXFLG) S LINE=LINE+1 D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,677,0)="""RTN"",""PSOERXU7"",218,0)"
^XMB(3.9,145935,2,678,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""*****************************MESSAGE HISTORY********************************"")"
^XMB(3.9,145935,2,679,0)="""RTN"",""PSOERXU7"",219,0)"
^XMB(3.9,145935,2,680,0)=" I $G(SDERXFLG) D SET^VALM10(LINE,""                                MESSAGE HISTORY                                 ""),CNTRL^VALM10(LINE,1,80,$G(IOUON)_$G(IOINHI),$G(IOUOFF)_$G(IOINORM))"
^XMB(3.9,145935,2,681,0)="""RTN"",""PSOERXU7"",220,0)"
^XMB(3.9,145935,2,682,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Request Reference #: ""_$G(REQID)),CNTRL^VALM10(LINE,22,$L(REQID),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,683,0)="""RTN"",""PSOERXU7"",221,0)"
^XMB(3.9,145935,2,684,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""New eRx Reference #: ""_RELERX),CNTRL^VALM10(LINE,22,$L(RELERX),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,685,0)="""RTN"",""PSOERXU7"",222,0)"
^XMB(3.9,145935,2,686,0)=" S LINE=LINE+1 D SET^VALM10(LINE,""Response eRx Reference #: ""_$G(RESID)),CNTRL^VALM10(LINE,27,$L(RESID),$G(IOINHI),$G(IOINORM))"
^XMB(3.9,145935,2,687,0)="""RTN"",""PSOERXU7"",223,0)"
^XMB(3.9,145935,2,688,0)=" Q"
^XMB(3.9,145935,2,689,0)="""RTN"",""PSOERXU7"",224,0)"
^XMB(3.9,145935,2,690,0)=" ; displays processing errors"
^XMB(3.9,145935,2,691,0)="""RTN"",""PSOERXU7"",225,0)"
^XMB(3.9,145935,2,692,0)="PROCERR(ERXIEN,LINE) ;"
^XMB(3.9,145935,2,693,0)="""RTN"",""PSOERXU7"",226,0)"
^XMB(3.9,145935,2,694,0)=" N ERRIEN,ERRIENS,ERRTXT,ERRTARY"
^XMB(3.9,145935,2,695,0)="""RTN"",""PSOERXU7"",227,0)"
^XMB(3.9,145935,2,696,0)=" ; quit if there are no processing errors"
^XMB(3.9,145935,2,697,0)="""RTN"",""PSOERXU7"",228,0)"
^XMB(3.9,145935,2,698,0)=" Q:'$D(^PS(52.49,ERXIEN,100,""C"",""PX""))"
^XMB(3.9,145935,2,699,0)="""RTN"",""PSOERXU7"",229,0)"
^XMB(3.9,145935,2,700,0)=" S LINE=LINE+1"
^XMB(3.9,145935,2,701,0)="""RTN"",""PSOERXU7"",230,0)"
^XMB(3.9,145935,2,702,0)=" I $G(SDERXFLG) D SET^VALM10(LINE,""                            PROCESSING ERRORS                               ""),CNTRL^VALM10(LINE,1,80,$G(IOUON)_$G(IOINHI),$G(IOUOFF)_$G(IOINORM))"
^XMB(3.9,145935,2,703,0)="""RTN"",""PSOERXU7"",231,0)"
^XMB(3.9,145935,2,704,0)=" E  D"
^XMB(3.9,145935,2,705,0)="""RTN"",""PSOERXU7"",232,0)"
^XMB(3.9,145935,2,706,0)=" .D SET^VALM10(LINE,"""")"
^XMB(3.9,145935,2,707,0)="""RTN"",""PSOERXU7"",233,0)"
^XMB(3.9,145935,2,708,0)=" .S LINE=LINE+1 D SET^VALM10(LINE,""****************************PROCESSING ERRORS*******************************"")"
^XMB(3.9,145935,2,709,0)="""RTN"",""PSOERXU7"",234,0)"
^XMB(3.9,145935,2,710,0)=" S ERRIEN=0 F  S ERRIEN=$O(^PS(52.49,ERXIEN,100,ERRIEN)) Q:'ERRIEN  D"
^XMB(3.9,145935,2,711,0)="""RTN"",""PSOERXU7"",235,0)"
^XMB(3.9,145935,2,712,0)=" .S ERRIENS=ERRIEN_"",""_ERXIEN_"","""
^XMB(3.9,145935,2,713,0)="""RTN"",""PSOERXU7"",236,0)"
^XMB(3.9,145935,2,714,0)=" .S ERRTXT=$$GET1^DIQ(52.49101,ERRIENS,1,""E"")"
^XMB(3.9,145935,2,715,0)="""RTN"",""PSOERXU7"",237,0)"
^XMB(3.9,145935,2,716,0)=" .S ERRTXT=""Error Details: ""_ERRTXT"
^XMB(3.9,145935,2,717,0)="""RTN"",""PSOERXU7"",238,0)"
^XMB(3.9,145935,2,718,0)=" .D TXT2ARY^PSOERXD1(.ERRTARY,ERRTXT,"" "",78)"
^XMB(3.9,145935,2,719,0)="""RTN"",""PSOERXU7"",239,0)"
^XMB(3.9,145935,2,720,0)=" .S I=0 F  S I=$O(ERRTARY(I)) Q:'I  D"
^XMB(3.9,145935,2,721,0)="""RTN"",""PSOERXU7"",240,0)"
^XMB(3.9,145935,2,722,0)=" ..S LINE=LINE+1 D SET^VALM10(LINE,$G(ERRTARY(I))),CNTRL^VALM10(LINE,15,$L($G(ERRTARY(I))),$G(IORVON),$G(IORVOFF))"
^XMB(3.9,145935,2,723,0)="""RTN"",""PSOERXU7"",241,0)"
^XMB(3.9,145935,2,724,0)=" .K ERRTXT,ERRTARY"
^XMB(3.9,145935,2,725,0)="""RTN"",""PSOERXU7"",242,0)"
^XMB(3.9,145935,2,726,0)=" Q"
^XMB(3.9,145935,2,727,0)="""RTN"",""PSOERXU7"",243,0)"
^XMB(3.9,145935,2,728,0)=" ;"
^XMB(3.9,145935,2,729,0)="""VER"")"
