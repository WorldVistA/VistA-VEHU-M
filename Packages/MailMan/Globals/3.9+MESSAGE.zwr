^XMB(3.9,145951,2,1926,0)=" .F D=1:1:DH S Y(Y#100*SI\60+(Y\100*SI)-(STARTDAY*SI)+D)=$S($P(Y,U,2):$E(""123456789jklmnopqrstuvwxyz"",$P(Y,U,2)),1:0)"
