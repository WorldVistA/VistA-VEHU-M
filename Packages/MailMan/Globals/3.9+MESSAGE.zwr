^XMB(3.9,145950,2,357,0)="""RTN"",""PSAVERA"",61,0)"
^XMB(3.9,145950,2,358,0)=" I 'PSACSLOC,$P($G(^PSDRUG(PSADRG,2)),""^"",3)[""N"" D MSTVAULT I $G(PSAOUT)!'PSACSLOC G NOCHNG"
^XMB(3.9,145950,2,359,0)="""RTN"",""PSAVERA"",62,0)"
