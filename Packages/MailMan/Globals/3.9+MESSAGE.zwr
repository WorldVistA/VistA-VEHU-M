^XMB(3.9,145944,2,1759,0)="""RTN"",""IBJDF6"",105,0)"
^XMB(3.9,145944,2,1760,0)=" ;"
^XMB(3.9,145944,2,1761,0)="""RTN"",""IBJDF6"",106,0)"
^XMB(3.9,145944,2,1762,0)="EXCEL ; - Determine whether to gather data for Excel report."
^XMB(3.9,145944,2,1763,0)="""RTN"",""IBJDF6"",107,0)"
^XMB(3.9,145944,2,1764,0)=" S IBEXCEL=$$EXCEL^IBJD() G ENQ:IBEXCEL=""^"""
^XMB(3.9,145944,2,1765,0)="""RTN"",""IBJDF6"",108,0)"
^XMB(3.9,145944,2,1766,0)=" I IBEXCEL S IBSH=1,IBSH1=""M"" G DEV"
^XMB(3.9,145944,2,1767,0)="""RTN"",""IBJDF6"",109,0)"
^XMB(3.9,145944,2,1768,0)=" ;"
^XMB(3.9,145944,2,1769,0)="""RTN"",""IBJDF6"",110,0)"
^XMB(3.9,145944,2,1770,0)="BCH ; - Determine whether to include the bill comment history."
^XMB(3.9,145944,2,1771,0)="""RTN"",""IBJDF6"",111,0)"
^XMB(3.9,145944,2,1772,0)=" S DIR(0)=""Y"",DIR(""B"")=""NO"" W !"
^XMB(3.9,145944,2,1773,0)="""RTN"",""IBJDF6"",112,0)"
^XMB(3.9,145944,2,1774,0)=" S DIR(""A"")=""Include the bill comment history with each receivable"""
^XMB(3.9,145944,2,1775,0)="""RTN"",""IBJDF6"",113,0)"
