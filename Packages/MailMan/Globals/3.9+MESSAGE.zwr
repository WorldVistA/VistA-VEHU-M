^XMB(3.9,145958,2,1617,0)="""RTN"",""ORWDXA"",303,0)"
^XMB(3.9,145958,2,1618,0)="SAVFLG(ORIFN,ORFH) ;File flag history ;p539"
^XMB(3.9,145958,2,1619,0)="""RTN"",""ORWDXA"",304,0)"
^XMB(3.9,145958,2,1620,0)=" N ORNOW,ORFDA,ORFNM,ORFIENS"
^XMB(3.9,145958,2,1621,0)="""RTN"",""ORWDXA"",305,0)"
^XMB(3.9,145958,2,1622,0)=" S ORNOW=$$NOW^XLFDT"
^XMB(3.9,145958,2,1623,0)="""RTN"",""ORWDXA"",306,0)"
^XMB(3.9,145958,2,1624,0)=" S ORFIENS=""?+1""_"",""_$P(ORIFN,"";"",2)_"",""_+ORIFN_"","""
