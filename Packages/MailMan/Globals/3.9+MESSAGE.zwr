^XMB(3.9,145976,2,254,0)=" ;;3.0;IMAGING;**93,94,106,117,122,131,149,138,156,161,167,181,191,188,216,234,225,256,258,316,290,315,351,334,379**;Mar 19, 2002;Build 0"
^XMB(3.9,145976,2,255,0)="""RTN"",""MAGGTU4D"",3,0)"
^XMB(3.9,145976,2,256,0)=" ;; Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145976,2,257,0)="""RTN"",""MAGGTU4D"",4,0)"
^XMB(3.9,145976,2,258,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145976,2,259,0)="""RTN"",""MAGGTU4D"",5,0)"
^XMB(3.9,145976,2,260,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145976,2,261,0)="""RTN"",""MAGGTU4D"",6,0)"
^XMB(3.9,145976,2,262,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145976,2,263,0)="""RTN"",""MAGGTU4D"",7,0)"
^XMB(3.9,145976,2,264,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145976,2,265,0)="""RTN"",""MAGGTU4D"",8,0)"
^XMB(3.9,145976,2,266,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145976,2,267,0)="""RTN"",""MAGGTU4D"",9,0)"
^XMB(3.9,145976,2,268,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145976,2,269,0)="""RTN"",""MAGGTU4D"",10,0)"
^XMB(3.9,145976,2,270,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145976,2,271,0)="""RTN"",""MAGGTU4D"",11,0)"
^XMB(3.9,145976,2,272,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145976,2,273,0)="""RTN"",""MAGGTU4D"",12,0)"
^XMB(3.9,145976,2,274,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145976,2,275,0)="""RTN"",""MAGGTU4D"",13,0)"
^XMB(3.9,145976,2,276,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145976,2,277,0)="""RTN"",""MAGGTU4D"",14,0)"
^XMB(3.9,145976,2,278,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145976,2,279,0)="""RTN"",""MAGGTU4D"",15,0)"
^XMB(3.9,145976,2,280,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145976,2,281,0)="""RTN"",""MAGGTU4D"",16,0)"
^XMB(3.9,145976,2,282,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145976,2,283,0)="""RTN"",""MAGGTU4D"",17,0)"
^XMB(3.9,145976,2,284,0)=" ;;"
^XMB(3.9,145976,2,285,0)="""RTN"",""MAGGTU4D"",18,0)"
^XMB(3.9,145976,2,286,0)=" ; This routine contains the version control code and data specific"
^XMB(3.9,145976,2,287,0)="""RTN"",""MAGGTU4D"",19,0)"
^XMB(3.9,145976,2,288,0)=" ; to the Clinical Display application. DO NOT ADD ANYTHING ELSE!"
^XMB(3.9,145976,2,289,0)="""RTN"",""MAGGTU4D"",20,0)"
^XMB(3.9,145976,2,290,0)=" Q"
^XMB(3.9,145976,2,291,0)="""RTN"",""MAGGTU4D"",21,0)"
^XMB(3.9,145976,2,292,0)=" ;"
^XMB(3.9,145976,2,293,0)="""RTN"",""MAGGTU4D"",22,0)"
^XMB(3.9,145976,2,294,0)="CLVERCT ;***** VERSION CONTROL TABLE FOR THE CLINICAL DISPLAY CLIENTS"
^XMB(3.9,145976,2,295,0)="""RTN"",""MAGGTU4D"",23,0)"
