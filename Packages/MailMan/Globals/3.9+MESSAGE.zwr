^XMB(3.9,145946,2,1130,0)=" ; 0 -- user selects insurance companies"
^XMB(3.9,145946,2,1131,0)="""RTN"",""IBCMDT1"",9,0)"
^XMB(3.9,145946,2,1132,0)=" ; 1 -- run report for all insurance companies with plans"
^XMB(3.9,145946,2,1133,0)="""RTN"",""IBCMDT1"",10,0)"
^XMB(3.9,145946,2,1134,0)=" ;"
^XMB(3.9,145946,2,1135,0)="""RTN"",""IBCMDT1"",11,0)"
^XMB(3.9,145946,2,1136,0)=" N A,B"
^XMB(3.9,145946,2,1137,0)="""RTN"",""IBCMDT1"",12,0)"
^XMB(3.9,145946,2,1138,0)=" S (A,B)=0"
^XMB(3.9,145946,2,1139,0)="""RTN"",""IBCMDT1"",13,0)"
^XMB(3.9,145946,2,1140,0)=" F  S A=$O(^IBA(355.3,""B"",A)) Q:'A  S B=B+1"
^XMB(3.9,145946,2,1141,0)="""RTN"",""IBCMDT1"",14,0)"
^XMB(3.9,145946,2,1142,0)=" S DIR(0)=""SA^1:List All ""_B_"" Ins. Companies;2:List Only Ins. Companies That You Select"""
^XMB(3.9,145946,2,1143,0)="""RTN"",""IBCMDT1"",15,0)"
^XMB(3.9,145946,2,1144,0)=" W !!,""     There are ""_B_"" insurance companies associated with plans."",!"
^XMB(3.9,145946,2,1145,0)="""RTN"",""IBCMDT1"",16,0)"
^XMB(3.9,145946,2,1146,0)=" S DIR(""A"",1)=""1. List All ""_B_"" Active Ins. Companies"""
