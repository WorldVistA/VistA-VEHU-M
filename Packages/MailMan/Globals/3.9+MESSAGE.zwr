^XMB(3.9,145981,2,691,0)="""RTN"",""IBECECX1"",226,0)"
^XMB(3.9,145981,2,692,0)=" . S IB3513D=0"
^XMB(3.9,145981,2,693,0)="""RTN"",""IBECECX1"",227,0)"
^XMB(3.9,145981,2,694,0)=" . F  S IB3513D=$O(IB3513(IB3513D)) Q:'IB3513D  S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=$P(IB3513D,""^"",2)_""                ""_$P(IB3513D,""^"",3)"
^XMB(3.9,145981,2,695,0)="""RTN"",""IBECECX1"",228,0)"
^XMB(3.9,145981,2,696,0)=" . S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,697,0)="""RTN"",""IBECECX1"",229,0)"
^XMB(3.9,145981,2,698,0)=" . S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""For full Query Response details, review the logs from the MEANS TEST"""
^XMB(3.9,145981,2,699,0)="""RTN"",""IBECECX1"",230,0)"
^XMB(3.9,145981,2,700,0)=" . S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""BILLING CLOCK VERIFY (351.3) file."""
^XMB(3.9,145981,2,701,0)="""RTN"",""IBECECX1"",231,0)"
^XMB(3.9,145981,2,702,0)=" S XMDUZ=DUZ,XMTEXT=""^TMP($J,""""IBCPYAC"""","""
^XMB(3.9,145981,2,703,0)="""RTN"",""IBECECX1"",232,0)"
^XMB(3.9,145981,2,704,0)=" D ^XMD"
^XMB(3.9,145981,2,705,0)="""RTN"",""IBECECX1"",233,0)"
^XMB(3.9,145981,2,706,0)=" Q"
^XMB(3.9,145981,2,707,0)="""RTN"",""IBECECX1"",234,0)"
^XMB(3.9,145981,2,708,0)=" ;"
^XMB(3.9,145981,2,709,0)="""RTN"",""IBECECX1"",235,0)"
^XMB(3.9,145981,2,710,0)="UDCL ;Update original billing clock so nightly querys are not sent for patients without TFL's"
^XMB(3.9,145981,2,711,0)="""RTN"",""IBECECX1"",236,0)"
^XMB(3.9,145981,2,712,0)=" Q:'$G(IB351IEN)"
^XMB(3.9,145981,2,713,0)="""RTN"",""IBECECX1"",237,0)"
^XMB(3.9,145981,2,714,0)=" S $P(^IBE(351,IB351IEN,1),""^"",5)=1  ;Update QUERY SENT"
^XMB(3.9,145981,2,715,0)="""RTN"",""IBECECX1"",238,0)"
^XMB(3.9,145981,2,716,0)=" Q"
^XMB(3.9,145981,2,717,0)="""RTN"",""IBECECX1"",239,0)"
^XMB(3.9,145981,2,718,0)=" ;"
^XMB(3.9,145981,2,719,0)="""RTN"",""IBECECX1"",240,0)"
^XMB(3.9,145981,2,720,0)="EDTCLCK(DFN,IBADMIT,IBCURIEN) ;Called from Billing Clock Maintenance option"
^XMB(3.9,145981,2,721,0)="""RTN"",""IBECECX1"",241,0)"
^XMB(3.9,145981,2,722,0)=" N IBTRYTIL,IBECDT,IBECLDT,IBECIEN,IBECSTDT,IBECENDT,IBECDT1,ICN,IBECADM,IBSADMIT,IBSDISCH,IBQRYDT,IBREFNUM,IBMES,HDR,IBINST,IBSTATION"
^XMB(3.9,145981,2,723,0)="""RTN"",""IBECECX1"",242,0)"
^XMB(3.9,145981,2,724,0)=" I '$$ICN^IBARXMU(DFN) S IBFLAG1=1 Q  ;Do not run query if patient does not have an ICN"
^XMB(3.9,145981,2,725,0)="""RTN"",""IBECECX1"",243,0)"
^XMB(3.9,145981,2,726,0)=" S IBTFL=$$TFL^IBARXMU(DFN,.IBTFL,2) I 'IBTFL S IBFLAG1=1 Q  ;Quit if patient has no other TFL's"
^XMB(3.9,145981,2,727,0)="""RTN"",""IBECECX1"",244,0)"
^XMB(3.9,145981,2,728,0)=" ;send clock start date ad admit date when editing billing clock"
^XMB(3.9,145981,2,729,0)="""RTN"",""IBECECX1"",245,0)"
^XMB(3.9,145981,2,730,0)=" ;D CCINPT(DFN,IBADMIT)"
^XMB(3.9,145981,2,731,0)="""RTN"",""IBECECX1"",246,0)"
^XMB(3.9,145981,2,732,0)=" S IBDISCH="""",IBSTATION=$P($$SITE^VASITE,U,3),IBADM1=IBADMIT"
^XMB(3.9,145981,2,733,0)="""RTN"",""IBECECX1"",247,0)"
^XMB(3.9,145981,2,734,0)=" D MTEQRY^IBECECQ1(DFN,IBADM1)  ;Run Query"
^XMB(3.9,145981,2,735,0)="""RTN"",""IBECECX1"",248,0)"
^XMB(3.9,145981,2,736,0)=" N IBMSG,HDR,SEG,XXX,DFN,IBVARRY,IBECERR,IBECNIEN,IBID,IBICLDTS,IBDISCH"
^XMB(3.9,145981,2,737,0)="""RTN"",""IBECECX1"",249,0)"
^XMB(3.9,145981,2,738,0)=" W !,""Running Billing Clock Query, please wait."""
^XMB(3.9,145981,2,739,0)="""RTN"",""IBECECX1"",250,0)"
^XMB(3.9,145981,2,740,0)=" ;Wait clock for up to 2 minutes until DSR returned from billing clock query"
^XMB(3.9,145981,2,741,0)="""RTN"",""IBECECX1"",251,0)"
^XMB(3.9,145981,2,742,0)=" S IBFLAG1=0 S IBTRYTIL=$$FMADD^XLFDT($$NOW^XLFDT,,,2) F  Q:$$NOW^XLFDT>IBTRYTIL  Q:IBFLAG1  D"
^XMB(3.9,145981,2,743,0)="""RTN"",""IBECECX1"",252,0)"
^XMB(3.9,145981,2,744,0)=" .H 2 W ""."" Q:IBFLAG1  S HLMSGIEN=MSG(""IEN""),IBMES=$$STARTMSG^HLOPRS(.IBMSG,HLMSGIEN,.HDR) S HLMSGIEN=$G(IBMSG(""ACK BY IEN"")) I HLMSGIEN D"
^XMB(3.9,145981,2,745,0)="""RTN"",""IBECECX1"",253,0)"
^XMB(3.9,145981,2,746,0)=" ..S IBERR=0,IBERRMSG="""""
^XMB(3.9,145981,2,747,0)="""RTN"",""IBECECX1"",254,0)"
^XMB(3.9,145981,2,748,0)=" ..S XXX=$$STARTMSG^HLOPRS(.IBMSG,HLMSGIEN,.HDR)"
^XMB(3.9,145981,2,749,0)="""RTN"",""IBECECX1"",255,0)"
^XMB(3.9,145981,2,750,0)=" ..F  Q:'$$NEXTSEG^HLOPRS(.IBMSG,.SEG)  S IBSEGT=$G(SEG(""SEGMENT TYPE"")) Q:IBSEGT=""""  D"
^XMB(3.9,145981,2,751,0)="""RTN"",""IBECECX1"",256,0)"
^XMB(3.9,145981,2,752,0)=" ...I IBSEGT=""MSA"" D MSA1^IBECECQ1"
^XMB(3.9,145981,2,753,0)="""RTN"",""IBECECX1"",257,0)"
^XMB(3.9,145981,2,754,0)=" ...I IBSEGT=""QRD"" D QRDDI^IBECECQ1"
^XMB(3.9,145981,2,755,0)="""RTN"",""IBECECX1"",258,0)"
^XMB(3.9,145981,2,756,0)=" ...I IBSEGT=""DSP"" S:$$GET^HLOPRS(.SEG,5,1)[""Billing Clock found at site #"" IBERRMSG=$$GET^HLOPRS(.SEG,5,1) S IBCNT=$$GET^HLOPRS(.SEG,1,1) I IBCNT>1 D"
^XMB(3.9,145981,2,757,0)="""RTN"",""IBECECX1"",259,0)"
^XMB(3.9,145981,2,758,0)=" ....S IBSTATION=$$GET^HLOPRS(.SEG,9,1) ;Station Number"
^XMB(3.9,145981,2,759,0)="""RTN"",""IBECECX1"",260,0)"
^XMB(3.9,145981,2,760,0)=" ....I IBSTATION'="""" D FIND^DIC(4,,.01,""MX"",IBSTATION,,""D"",,,""IBLIST"",""IBERR"") D"
^XMB(3.9,145981,2,761,0)="""RTN"",""IBECECX1"",261,0)"
^XMB(3.9,145981,2,762,0)=" .....S IBINST=IBLIST(""DILIST"",1,1),IBECARY(IBINST)="""" ;Institution array for error messaging"
^XMB(3.9,145981,2,763,0)="""RTN"",""IBECECX1"",262,0)"
^XMB(3.9,145981,2,764,0)=" ..;I IBERRMSG[""MVI returned no treating facilities for this patient"" S IBERRMSG="""""
^XMB(3.9,145981,2,765,0)="""RTN"",""IBECECX1"",263,0)"
^XMB(3.9,145981,2,766,0)=" ..;I IBERRMSG[""NO MEANS TEST BILLING CLOCK FOUND"" S IBERRMSG="""""
^XMB(3.9,145981,2,767,0)="""RTN"",""IBECECX1"",264,0)"
^XMB(3.9,145981,2,768,0)=" ..;I IBERRMSG[""No Member found"" S IBERRMSG=""""  ;IB*2.0*769 Clear error message for HBM no Member response"
^XMB(3.9,145981,2,769,0)="""RTN"",""IBECECX1"",265,0)"
^XMB(3.9,145981,2,770,0)=" ..H 4 I IBERRMSG'="""" S IBFLAG1=1 Q"
^XMB(3.9,145981,2,771,0)="""RTN"",""IBECECX1"",266,0)"
^XMB(3.9,145981,2,772,0)=" ..S IBECERR=0 ;IBECERR - FLAG TO DETERMINE IF VERSIONING OUT OF SYNC"
^XMB(3.9,145981,2,773,0)="""RTN"",""IBECECX1"",267,0)"
^XMB(3.9,145981,2,774,0)=" ..I IBERRMSG="""" S IBECDA=$S(+IB351IEN:IB351IEN,1:$G(IBECNIEN)) I IBECDA S IBECERR=$$GET1^DIQ(351,IBECDA,18) I IBECERR=""YES"" D  ;DSR returned with query results - now validate the results based on clock version"
^XMB(3.9,145981,2,775,0)="""RTN"",""IBECECX1"",268,0)"
^XMB(3.9,145981,2,776,0)=" ...S IBERRMSG=""Query results contain inconsistent versioning - indicating MEANS TEST BILLING CLOCKs may be out of sync."""
^XMB(3.9,145981,2,777,0)="""RTN"",""IBECECX1"",269,0)"
^XMB(3.9,145981,2,778,0)=" ..S IBFLAG1=1"
