^XMB(3.9,145976,2,309,0)="""RTN"",""MAGGTU4D"",30,0)"
^XMB(3.9,145976,2,310,0)=" ;"
^XMB(3.9,145976,2,311,0)="""RTN"",""MAGGTU4D"",31,0)"
^XMB(3.9,145976,2,312,0)=" ; Each row of the version control table contains the version and"
^XMB(3.9,145976,2,313,0)="""RTN"",""MAGGTU4D"",32,0)"
^XMB(3.9,145976,2,314,0)=" ; build number of a supported client. Released patches must also"
^XMB(3.9,145976,2,315,0)="""RTN"",""MAGGTU4D"",33,0)"
^XMB(3.9,145976,2,316,0)=" ; indicate the sequential numbers."
^XMB(3.9,145976,2,317,0)="""RTN"",""MAGGTU4D"",34,0)"
^XMB(3.9,145976,2,318,0)=" ;"
^XMB(3.9,145976,2,319,0)="""RTN"",""MAGGTU4D"",35,0)"
^XMB(3.9,145976,2,320,0)=" ; Sort order of the rows does not matter. However, the reversed"
