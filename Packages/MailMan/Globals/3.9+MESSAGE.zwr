^XMB(3.9,145989,2,705,0)="""RTN"",""PSOASAP0"",210,0)"
^XMB(3.9,145989,2,706,0)=" I 'RX14 S RX14=$$NUMERIC($$GET1^DIQ(50,DRUGIEN,31))"
^XMB(3.9,145989,2,707,0)="""RTN"",""PSOASAP0"",211,0)"
