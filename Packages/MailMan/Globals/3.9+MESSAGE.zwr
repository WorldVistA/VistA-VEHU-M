^XMB(3.9,145980,2,3845,0)="""RTN"",""SDES2CANCELAPPT2"",79,0)"
^XMB(3.9,145980,2,3846,0)=" ;"
^XMB(3.9,145980,2,3847,0)="""RTN"",""SDES2CANCELAPPT2"",80,0)"
^XMB(3.9,145980,2,3848,0)="DUPPIDCHK(REQUESTIEN,NEWPID) ;"
^XMB(3.9,145980,2,3849,0)="""RTN"",""SDES2CANCELAPPT2"",81,0)"
^XMB(3.9,145980,2,3850,0)=" N CHILDIEN,DUPPID,PARENTIEN S (CHILDIEN,DUPPID)=0"
^XMB(3.9,145980,2,3851,0)="""RTN"",""SDES2CANCELAPPT2"",82,0)"
