^XMB(3.9,145944,2,1427,0)="""RTN"",""IBJDF42"",197,0)"
^XMB(3.9,145944,2,1428,0)=" S $E(TYPE,1)="""""
^XMB(3.9,145944,2,1429,0)="""RTN"",""IBJDF42"",198,0)"
