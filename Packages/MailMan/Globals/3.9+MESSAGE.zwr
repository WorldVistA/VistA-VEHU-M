^XMB(3.9,145958,2,2050,0)="LISTALL(Y,FROM,DIR) ; Return a bolus of patient names.  From is either Name or IEN^Name."
^XMB(3.9,145958,2,2051,0)="""RTN"",""ORWPT"",205,0)"
