^XMB(3.9,145946,2,851,0)="""RTN"",""IBCMDT"",104,0)"
^XMB(3.9,145946,2,852,0)=" I +IBMDTSPC(""IBBIN"") D"
^XMB(3.9,145946,2,853,0)="""RTN"",""IBCMDT"",105,0)"
^XMB(3.9,145946,2,854,0)=" . S IBMDTSPC(""SUBHD"")=$G(IBMDTSPC(""SUBHD""))_$S(+IBMDTSPC(""FLTRS""):"", "",1:"""")_""BIN"""
^XMB(3.9,145946,2,855,0)="""RTN"",""IBCMDT"",106,0)"
^XMB(3.9,145946,2,856,0)=" . S IBMDTSPC(""FLTRS"")=IBMDTSPC(""FLTRS"")+1"
^XMB(3.9,145946,2,857,0)="""RTN"",""IBCMDT"",107,0)"
^XMB(3.9,145946,2,858,0)=" ;"
^XMB(3.9,145946,2,859,0)="""RTN"",""IBCMDT"",108,0)"
^XMB(3.9,145946,2,860,0)=" ; Filter on Missing PCN (Processor Control Number)"
^XMB(3.9,145946,2,861,0)="""RTN"",""IBCMDT"",109,0)"
^XMB(3.9,145946,2,862,0)="F70 D SLPCN^IBCMDT1"
^XMB(3.9,145946,2,863,0)="""RTN"",""IBCMDT"",110,0)"
^XMB(3.9,145946,2,864,0)=" I STOP G:$$STOP EXIT G F60"
^XMB(3.9,145946,2,865,0)="""RTN"",""IBCMDT"",111,0)"
^XMB(3.9,145946,2,866,0)=" I +IBMDTSPC(""IBPCN"") D"
^XMB(3.9,145946,2,867,0)="""RTN"",""IBCMDT"",112,0)"
^XMB(3.9,145946,2,868,0)=" . S IBMDTSPC(""SUBHD"")=$G(IBMDTSPC(""SUBHD""))_$S(+IBMDTSPC(""FLTRS""):"", "",1:"""")_""PCN"""
^XMB(3.9,145946,2,869,0)="""RTN"",""IBCMDT"",113,0)"
^XMB(3.9,145946,2,870,0)=" . S IBMDTSPC(""FLTRS"")=IBMDTSPC(""FLTRS"")+1"
^XMB(3.9,145946,2,871,0)="""RTN"",""IBCMDT"",114,0)"
^XMB(3.9,145946,2,872,0)=" ;"
^XMB(3.9,145946,2,873,0)="""RTN"",""IBCMDT"",115,0)"
^XMB(3.9,145946,2,874,0)=" I '+IBMDTSPC(""FLTRS"") D  G:$D(DUOUT) EXIT G FILTERS"
^XMB(3.9,145946,2,875,0)="""RTN"",""IBCMDT"",116,0)"
^XMB(3.9,145946,2,876,0)=" . W !!,""** No Filters were selected **""   ; No Filters were selected so quit."
^XMB(3.9,145946,2,877,0)="""RTN"",""IBCMDT"",117,0)"
^XMB(3.9,145946,2,878,0)=" . D PAUSE^VALM1"
^XMB(3.9,145946,2,879,0)="""RTN"",""IBCMDT"",118,0)"
^XMB(3.9,145946,2,880,0)=" I +IBMDTSPC(""IBCLM"") D"
^XMB(3.9,145946,2,881,0)="""RTN"",""IBCMDT"",119,0)"
^XMB(3.9,145946,2,882,0)=" . S IBMDTSPC(""SUBHD"")=$G(IBMDTSPC(""SUBHD""))_$S((+IBMDTSPC(""FLTRS"")>1):"", "",1:"""")"
^XMB(3.9,145946,2,883,0)="""RTN"",""IBCMDT"",120,0)"
^XMB(3.9,145946,2,884,0)=" . S IBMDTSPC(""SUBHD"")=IBMDTSPC(""SUBHD"")_""Coverage Limitations"""
^XMB(3.9,145946,2,885,0)="""RTN"",""IBCMDT"",121,0)"
^XMB(3.9,145946,2,886,0)=" ;"
^XMB(3.9,145946,2,887,0)="""RTN"",""IBCMDT"",122,0)"
^XMB(3.9,145946,2,888,0)="F100 D DEVICE(.IBMDTSPC)"
^XMB(3.9,145946,2,889,0)="""RTN"",""IBCMDT"",123,0)"
^XMB(3.9,145946,2,890,0)=" I STOP G EXIT ;IB*763/CKB - exit the report if user enters '^'"
^XMB(3.9,145946,2,891,0)="""RTN"",""IBCMDT"",124,0)"
^XMB(3.9,145946,2,892,0)=" ;"
^XMB(3.9,145946,2,893,0)="""RTN"",""IBCMDT"",125,0)"
^XMB(3.9,145946,2,894,0)="EXIT ; Exit point"
^XMB(3.9,145946,2,895,0)="""RTN"",""IBCMDT"",126,0)"
^XMB(3.9,145946,2,896,0)=" Q"
^XMB(3.9,145946,2,897,0)="""RTN"",""IBCMDT"",127,0)"
^XMB(3.9,145946,2,898,0)=" ;"
^XMB(3.9,145946,2,899,0)="""RTN"",""IBCMDT"",128,0)"
^XMB(3.9,145946,2,900,0)="STOP() ; Determine if user wants to exit out of the whole option"
^XMB(3.9,145946,2,901,0)="""RTN"",""IBCMDT"",129,0)"
^XMB(3.9,145946,2,902,0)=" ; Initialize Variables"
^XMB(3.9,145946,2,903,0)="""RTN"",""IBCMDT"",130,0)"
^XMB(3.9,145946,2,904,0)=" N DIR,DIRUT,X,Y"
^XMB(3.9,145946,2,905,0)="""RTN"",""IBCMDT"",131,0)"
^XMB(3.9,145946,2,906,0)=" ;"
^XMB(3.9,145946,2,907,0)="""RTN"",""IBCMDT"",132,0)"
^XMB(3.9,145946,2,908,0)=" W !"
^XMB(3.9,145946,2,909,0)="""RTN"",""IBCMDT"",133,0)"
^XMB(3.9,145946,2,910,0)=" S DIR(0)=""Y"""
^XMB(3.9,145946,2,911,0)="""RTN"",""IBCMDT"",134,0)"
^XMB(3.9,145946,2,912,0)=" S DIR(""A"")=""Do you want to exit out of this option entirely"""
^XMB(3.9,145946,2,913,0)="""RTN"",""IBCMDT"",135,0)"
^XMB(3.9,145946,2,914,0)=" S DIR(""B"")=""YES"""
^XMB(3.9,145946,2,915,0)="""RTN"",""IBCMDT"",136,0)"
^XMB(3.9,145946,2,916,0)=" S DIR(""?"",1)="" Enter YES to immediately exit out of this option."""
^XMB(3.9,145946,2,917,0)="""RTN"",""IBCMDT"",137,0)"
^XMB(3.9,145946,2,918,0)=" S DIR(""?"")="" Enter NO to return to the previous question."""
^XMB(3.9,145946,2,919,0)="""RTN"",""IBCMDT"",138,0)"
^XMB(3.9,145946,2,920,0)=" D ^DIR K DIR"
^XMB(3.9,145946,2,921,0)="""RTN"",""IBCMDT"",139,0)"
^XMB(3.9,145946,2,922,0)=" I $D(DIRUT) S (STOP,Y)=1 G STOPX"
^XMB(3.9,145946,2,923,0)="""RTN"",""IBCMDT"",140,0)"
^XMB(3.9,145946,2,924,0)=" I 'Y S STOP=0"
^XMB(3.9,145946,2,925,0)="""RTN"",""IBCMDT"",141,0)"
^XMB(3.9,145946,2,926,0)="STOPX ; STOP Exit Point"
^XMB(3.9,145946,2,927,0)="""RTN"",""IBCMDT"",142,0)"
^XMB(3.9,145946,2,928,0)=" Q Y"
^XMB(3.9,145946,2,929,0)="""RTN"",""IBCMDT"",143,0)"
^XMB(3.9,145946,2,930,0)=" ;"
^XMB(3.9,145946,2,931,0)="""RTN"",""IBCMDT"",144,0)"
^XMB(3.9,145946,2,932,0)="START ; Gather the Insurance Companies and respective Plans"
^XMB(3.9,145946,2,933,0)="""RTN"",""IBCMDT"",145,0)"
^XMB(3.9,145946,2,934,0)=" I 'IBAI D GTSEL,GTPLNS G STARTQ"
^XMB(3.9,145946,2,935,0)="""RTN"",""IBCMDT"",146,0)"
^XMB(3.9,145946,2,936,0)=" D GTALL,GTPLNS"
^XMB(3.9,145946,2,937,0)="""RTN"",""IBCMDT"",147,0)"
^XMB(3.9,145946,2,938,0)=" G STARTQ"
^XMB(3.9,145946,2,939,0)="""RTN"",""IBCMDT"",148,0)"
^XMB(3.9,145946,2,940,0)=" ;"
^XMB(3.9,145946,2,941,0)="""RTN"",""IBCMDT"",149,0)"
^XMB(3.9,145946,2,942,0)="GTSEL ; Gather plans for all selected companies."
^XMB(3.9,145946,2,943,0)="""RTN"",""IBCMDT"",150,0)"
^XMB(3.9,145946,2,944,0)=" N IBCNS,IBIC"
^XMB(3.9,145946,2,945,0)="""RTN"",""IBCMDT"",151,0)"
^XMB(3.9,145946,2,946,0)=" S (IBCT,IBQUIT)=0"
^XMB(3.9,145946,2,947,0)="""RTN"",""IBCMDT"",152,0)"
^XMB(3.9,145946,2,948,0)=" K ^TMP(""IBCMDT"",$J),^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,949,0)="""RTN"",""IBCMDT"",153,0)"
^XMB(3.9,145946,2,950,0)=" ;"
^XMB(3.9,145946,2,951,0)="""RTN"",""IBCMDT"",154,0)"
^XMB(3.9,145946,2,952,0)=" ; Allow user selection of Insurance Companies, if required"
^XMB(3.9,145946,2,953,0)="""RTN"",""IBCMDT"",155,0)"
^XMB(3.9,145946,2,954,0)=" D EN^IBCNILK(1)  ; Only want Active Insurance Companies"
^XMB(3.9,145946,2,955,0)="""RTN"",""IBCMDT"",156,0)"
^XMB(3.9,145946,2,956,0)=" I '$D(^TMP(""IBCNILKA"",$J)) S IBQUIT=1 Q  ; No Insurance Companies selected"
^XMB(3.9,145946,2,957,0)="""RTN"",""IBCMDT"",157,0)"
^XMB(3.9,145946,2,958,0)=" S IBCNS="""""
^XMB(3.9,145946,2,959,0)="""RTN"",""IBCMDT"",158,0)"
^XMB(3.9,145946,2,960,0)=" F  S IBCNS=$O(^TMP(""IBCNILKA"",$J,IBCNS)) Q:IBCNS=""""  D"
^XMB(3.9,145946,2,961,0)="""RTN"",""IBCMDT"",159,0)"
^XMB(3.9,145946,2,962,0)=" . ; Insurance Company Name"
^XMB(3.9,145946,2,963,0)="""RTN"",""IBCMDT"",160,0)"
^XMB(3.9,145946,2,964,0)=" . S IBIC=$E($$GET1^DIQ(36,IBCNS_"","",.01),1,25)"
^XMB(3.9,145946,2,965,0)="""RTN"",""IBCMDT"",161,0)"
^XMB(3.9,145946,2,966,0)=" . S ^TMP(""IBCMDT"",$J,IBIC,IBCNS)="""""
^XMB(3.9,145946,2,967,0)="""RTN"",""IBCMDT"",162,0)"
^XMB(3.9,145946,2,968,0)=" K ^TMP(""IBCNILKA"",$J)"
^XMB(3.9,145946,2,969,0)="""RTN"",""IBCMDT"",163,0)"
^XMB(3.9,145946,2,970,0)=" Q"
^XMB(3.9,145946,2,971,0)="""RTN"",""IBCMDT"",164,0)"
^XMB(3.9,145946,2,972,0)=" ;"
^XMB(3.9,145946,2,973,0)="""RTN"",""IBCMDT"",165,0)"
^XMB(3.9,145946,2,974,0)="GTALL ; - gather all companies if required"
^XMB(3.9,145946,2,975,0)="""RTN"",""IBCMDT"",166,0)"
^XMB(3.9,145946,2,976,0)=" N IBCNS,IBIC1"
^XMB(3.9,145946,2,977,0)="""RTN"",""IBCMDT"",167,0)"
^XMB(3.9,145946,2,978,0)=" K ^TMP(""IBCMDT"",$J),^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,979,0)="""RTN"",""IBCMDT"",168,0)"
^XMB(3.9,145946,2,980,0)=" S IBIC1="""""
^XMB(3.9,145946,2,981,0)="""RTN"",""IBCMDT"",169,0)"
^XMB(3.9,145946,2,982,0)=" F  S IBIC1=$O(^DIC(36,""B"",IBIC1)) Q:IBIC1=""""  D"
^XMB(3.9,145946,2,983,0)="""RTN"",""IBCMDT"",170,0)"
^XMB(3.9,145946,2,984,0)=" . S IBCNS=0"
^XMB(3.9,145946,2,985,0)="""RTN"",""IBCMDT"",171,0)"
^XMB(3.9,145946,2,986,0)=" . F  S IBCNS=$O(^DIC(36,""B"",IBIC1,IBCNS)) Q:'IBCNS  D"
^XMB(3.9,145946,2,987,0)="""RTN"",""IBCMDT"",172,0)"
^XMB(3.9,145946,2,988,0)=" . . I +$$GET1^DIQ(36,IBCNS_"","",.05,""I"") Q  ; Inactive"
^XMB(3.9,145946,2,989,0)="""RTN"",""IBCMDT"",173,0)"
^XMB(3.9,145946,2,990,0)=" . . S ^TMP(""IBCMDT"",$J,$E(IBIC1,1,25),IBCNS)="""""
^XMB(3.9,145946,2,991,0)="""RTN"",""IBCMDT"",174,0)"
^XMB(3.9,145946,2,992,0)=" Q"
^XMB(3.9,145946,2,993,0)="""RTN"",""IBCMDT"",175,0)"
^XMB(3.9,145946,2,994,0)=" ;"
^XMB(3.9,145946,2,995,0)="""RTN"",""IBCMDT"",176,0)"
^XMB(3.9,145946,2,996,0)="GTPLNS ; - gather plans for selected companies"
^XMB(3.9,145946,2,997,0)="""RTN"",""IBCMDT"",177,0)"
^XMB(3.9,145946,2,998,0)=" N IBCNS,IBIC,IBP"
^XMB(3.9,145946,2,999,0)="""RTN"",""IBCMDT"",178,0)"
^XMB(3.9,145946,2,1000,0)=" S IBIC="""""
^XMB(3.9,145946,2,1001,0)="""RTN"",""IBCMDT"",179,0)"
^XMB(3.9,145946,2,1002,0)=" F  S IBIC=$O(^TMP(""IBCMDT"",$J,IBIC)) Q:IBIC=""""!IBQUIT  D"
^XMB(3.9,145946,2,1003,0)="""RTN"",""IBCMDT"",180,0)"
^XMB(3.9,145946,2,1004,0)=" . S IBCNS="""""
^XMB(3.9,145946,2,1005,0)="""RTN"",""IBCMDT"",181,0)"
^XMB(3.9,145946,2,1006,0)=" . F  S IBCNS=$O(^TMP(""IBCMDT"",$J,IBIC,IBCNS)) Q:IBCNS=""""!(IBQUIT)  D"
^XMB(3.9,145946,2,1007,0)="""RTN"",""IBCMDT"",182,0)"
^XMB(3.9,145946,2,1008,0)=" . . S IBP=0"
^XMB(3.9,145946,2,1009,0)="""RTN"",""IBCMDT"",183,0)"
^XMB(3.9,145946,2,1010,0)=" . . F  S IBP=$O(^IBA(355.3,""B"",+IBCNS,IBP)) Q:'IBP  D"
^XMB(3.9,145946,2,1011,0)="""RTN"",""IBCMDT"",184,0)"
^XMB(3.9,145946,2,1012,0)=" . . . S ^TMP(""IBCMDT"",$J,IBIC,IBCNS,IBP)=""""   ; Set plans into the array."
^XMB(3.9,145946,2,1013,0)="""RTN"",""IBCMDT"",185,0)"
^XMB(3.9,145946,2,1014,0)=" Q"
^XMB(3.9,145946,2,1015,0)="""RTN"",""IBCMDT"",186,0)"
^XMB(3.9,145946,2,1016,0)=" ;"
^XMB(3.9,145946,2,1017,0)="""RTN"",""IBCMDT"",187,0)"
^XMB(3.9,145946,2,1018,0)="STARTQ ;"
^XMB(3.9,145946,2,1019,0)="""RTN"",""IBCMDT"",188,0)"
^XMB(3.9,145946,2,1020,0)=" K IBCNS,IBIC,IBCT,IBP,IBSEL,^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,1021,0)="""RTN"",""IBCMDT"",189,0)"
^XMB(3.9,145946,2,1022,0)=" Q"
^XMB(3.9,145946,2,1023,0)="""RTN"",""IBCMDT"",190,0)"
^XMB(3.9,145946,2,1024,0)=" ;"
^XMB(3.9,145946,2,1025,0)="""RTN"",""IBCMDT"",191,0)"
^XMB(3.9,145946,2,1026,0)="DEVICE(IBMDTSPC) ; Device Handler and possible TaskManager calls"
^XMB(3.9,145946,2,1027,0)="""RTN"",""IBCMDT"",192,0)"
^XMB(3.9,145946,2,1028,0)=" ; Input:   IBMDTSPC    - Array passed by reference of the report parameters"
^XMB(3.9,145946,2,1029,0)="""RTN"",""IBCMDT"",193,0)"
