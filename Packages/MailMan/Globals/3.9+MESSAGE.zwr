^XMB(3.9,145983,2,707,0)="""RTN"",""RCRPENTR"",59,0)"
^XMB(3.9,145983,2,708,0)=" ;Clear working array when exiting."
^XMB(3.9,145983,2,709,0)="""RTN"",""RCRPENTR"",60,0)"
^XMB(3.9,145983,2,710,0)=" K ^TMP(""RCRPP"",$J)"
^XMB(3.9,145983,2,711,0)="""RTN"",""RCRPENTR"",61,0)"
^XMB(3.9,145983,2,712,0)=" ;"
^XMB(3.9,145983,2,713,0)="""RTN"",""RCRPENTR"",62,0)"
^XMB(3.9,145983,2,714,0)=" Q"
^XMB(3.9,145983,2,715,0)="""RTN"",""RCRPENTR"",63,0)"
^XMB(3.9,145983,2,716,0)=" ;"
^XMB(3.9,145983,2,717,0)="""RTN"",""RCRPENTR"",64,0)"
^XMB(3.9,145983,2,718,0)="EDIT ;Edit A Repayment Plan"
