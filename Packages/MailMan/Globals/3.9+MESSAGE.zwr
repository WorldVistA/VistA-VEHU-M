^XMB(3.9,145986,2,4017,0)="""RTN"",""FBPCR"",259,0)"
^XMB(3.9,145986,2,4018,0)=" M FBINS=FBRTN(""IBBAPI"",""INSUR"")"
^XMB(3.9,145986,2,4019,0)="""RTN"",""FBPCR"",260,0)"
^XMB(3.9,145986,2,4020,0)=" S FBX=0"
^XMB(3.9,145986,2,4021,0)="""RTN"",""FBPCR"",261,0)"
^XMB(3.9,145986,2,4022,0)=" F  S FBX=$O(FBINS(FBX)) Q:'FBX  D INSDSP(FBX)"
^XMB(3.9,145986,2,4023,0)="""RTN"",""FBPCR"",262,0)"
^XMB(3.9,145986,2,4024,0)=" ;"
^XMB(3.9,145986,2,4025,0)="""RTN"",""FBPCR"",263,0)"
^XMB(3.9,145986,2,4026,0)="INSQ  ;Check Insurance Buffer and verify no coverage then quit FB*3.5*163"
^XMB(3.9,145986,2,4027,0)="""RTN"",""FBPCR"",264,0)"
^XMB(3.9,145986,2,4028,0)=" N FBNC"
^XMB(3.9,145986,2,4029,0)="""RTN"",""FBPCR"",265,0)"
^XMB(3.9,145986,2,4030,0)=" W ! I $D(FBRTN(""BUFFER"")) D"
^XMB(3.9,145986,2,4031,0)="""RTN"",""FBPCR"",266,0)"
^XMB(3.9,145986,2,4032,0)=" . I FBRTN(""BUFFER"")>0 W !?17,""*** Patient has Insurance Buffer entries ***"""
^XMB(3.9,145986,2,4033,0)="""RTN"",""FBPCR"",267,0)"
^XMB(3.9,145986,2,4034,0)=" S FBNC=+$G(^IBA(354,DFN,60)) I +FBNC D"
^XMB(3.9,145986,2,4035,0)="""RTN"",""FBPCR"",268,0)"
^XMB(3.9,145986,2,4036,0)=" . W !?17,""*** Verification of No Coverage ""_$$FMTE^XLFDT(FBNC)_"" ***"""
^XMB(3.9,145986,2,4037,0)="""RTN"",""FBPCR"",269,0)"
^XMB(3.9,145986,2,4038,0)=" Q"
^XMB(3.9,145986,2,4039,0)="""RTN"",""FBPCR"",270,0)"
^XMB(3.9,145986,2,4040,0)=" ;"
^XMB(3.9,145986,2,4041,0)="""RTN"",""FBPCR"",271,0)"
^XMB(3.9,145986,2,4042,0)="INSHDR ;Print insurance header FB*3.5*163"
^XMB(3.9,145986,2,4043,0)="""RTN"",""FBPCR"",272,0)"
^XMB(3.9,145986,2,4044,0)=" N FBEQL"
^XMB(3.9,145986,2,4045,0)="""RTN"",""FBPCR"",273,0)"
^XMB(3.9,145986,2,4046,0)=" W !,""Insurance"",?13,""COB"",?17,""Subscriber ID"",?35,""Group"",?47,""Holder"",?54,""Eff Dt"",?63,""Exp Dt"",?72,""Verified"""
^XMB(3.9,145986,2,4047,0)="""RTN"",""FBPCR"",274,0)"
^XMB(3.9,145986,2,4048,0)=" S FBEQL="""",$P(FBEQL,""="",80)=""="" W !,FBEQL"
^XMB(3.9,145986,2,4049,0)="""RTN"",""FBPCR"",275,0)"
^XMB(3.9,145986,2,4050,0)=" Q"
^XMB(3.9,145986,2,4051,0)="""RTN"",""FBPCR"",276,0)"
^XMB(3.9,145986,2,4052,0)=" ;"
^XMB(3.9,145986,2,4053,0)="""RTN"",""FBPCR"",277,0)"
^XMB(3.9,145986,2,4054,0)="INSDSP(FBVAL) ;Print insurance display line FB*3.5*163 "
^XMB(3.9,145986,2,4055,0)="""RTN"",""FBPCR"",278,0)"
^XMB(3.9,145986,2,4056,0)=" N FBY,FBZ"
^XMB(3.9,145986,2,4057,0)="""RTN"",""FBPCR"",279,0)"
^XMB(3.9,145986,2,4058,0)=" Q:'$D(FBINS)"
^XMB(3.9,145986,2,4059,0)="""RTN"",""FBPCR"",280,0)"
^XMB(3.9,145986,2,4060,0)=" W !,$S($D(FBINS(FBVAL,1)):$E($P(FBINS(FBVAL,1),U,2),1,10),1:""UNKNOWN"")  ;Insurance Company"
^XMB(3.9,145986,2,4061,0)="""RTN"",""FBPCR"",281,0)"
^XMB(3.9,145986,2,4062,0)=" S FBY=+FBINS(FBVAL,7) I FBY'="""" S FBY=$S(FBY=1:""p"",FBY=2:""s"",FBY=3:""t"",1:"""")"
^XMB(3.9,145986,2,4063,0)="""RTN"",""FBPCR"",282,0)"
^XMB(3.9,145986,2,4064,0)=" W ?13,FBY  ;COB"
^XMB(3.9,145986,2,4065,0)="""RTN"",""FBPCR"",283,0)"
^XMB(3.9,145986,2,4066,0)=" W ?17,$E(FBINS(FBVAL,14),1,16)  ;Subscriber ID"
^XMB(3.9,145986,2,4067,0)="""RTN"",""FBPCR"",284,0)"
^XMB(3.9,145986,2,4068,0)=" W ?35,$E(FBINS(FBVAL,18),1,10)  ;Group"
^XMB(3.9,145986,2,4069,0)="""RTN"",""FBPCR"",285,0)"
^XMB(3.9,145986,2,4070,0)=" S FBZ=$P(FBINS(FBVAL,12),U,1)"
^XMB(3.9,145986,2,4071,0)="""RTN"",""FBPCR"",286,0)"
^XMB(3.9,145986,2,4072,0)=" W ?47,$S(FBZ=""P"":""SELF"",FBZ=""S"":""SPOUSE"",1:""OTHER"")  ;Policy Holder"
^XMB(3.9,145986,2,4073,0)="""RTN"",""FBPCR"",287,0)"
^XMB(3.9,145986,2,4074,0)=" W ?54,$TR($$FMTE^XLFDT(FBINS(FBVAL,10),""2DF""),"" "",""0"")  ;Effective Date"
^XMB(3.9,145986,2,4075,0)="""RTN"",""FBPCR"",288,0)"
^XMB(3.9,145986,2,4076,0)=" W ?63,$TR($$FMTE^XLFDT(FBINS(FBVAL,11),""2DF""),"" "",""0"")  ;Expiration Date"
^XMB(3.9,145986,2,4077,0)="""RTN"",""FBPCR"",289,0)"
^XMB(3.9,145986,2,4078,0)=" W ?72,$TR($$FMTE^XLFDT(FBINS(FBVAL,25),""2DF""),"" "",""0"")  ;Date Last Verified"
^XMB(3.9,145986,2,4079,0)="""RTN"",""FBPCR"",290,0)"
^XMB(3.9,145986,2,4080,0)=" Q"
^XMB(3.9,145986,2,4081,0)="""VER"")"
^XMB(3.9,145986,2,4082,0)="8.0^22.2"
^XMB(3.9,145986,2,4083,0)="$END KID FB*3.5*194b"
