^XMB(3.9,145980,2,5519,0)="""RTN"",""SDES2CRTCLNAVAL2"",26,0)"
^XMB(3.9,145980,2,5520,0)=" Q"
^XMB(3.9,145980,2,5521,0)="""RTN"",""SDES2CRTCLNAVAL2"",27,0)"
^XMB(3.9,145980,2,5522,0)=" ;"
