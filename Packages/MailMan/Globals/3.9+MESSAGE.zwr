^XMB(3.9,145949,2,240,0)="0^1^B48508352"
^XMB(3.9,145949,2,241,0)="""RTN"",""PSXMISC1"",1,0)"
^XMB(3.9,145949,2,242,0)="PSXMISC1 ;BIR/WPB,BAB-Transmission Data Validation ;MAR 1,2002@13:13:34"
^XMB(3.9,145949,2,243,0)="""RTN"",""PSXMISC1"",2,0)"
^XMB(3.9,145949,2,244,0)=" ;;2.0;CMOP;**3,18,23,28,30,42,41,52,54,58,64,76,78,98**;11 Apr 97;Build 0"
^XMB(3.9,145949,2,245,0)="""RTN"",""PSXMISC1"",3,0)"
^XMB(3.9,145949,2,246,0)=" ;Reference to ^PSDRUG(  supported by DBIA #1983"
^XMB(3.9,145949,2,247,0)="""RTN"",""PSXMISC1"",4,0)"
^XMB(3.9,145949,2,248,0)=" ;Reference to ^PS(52.5, supported by DBIA #1978"
^XMB(3.9,145949,2,249,0)="""RTN"",""PSXMISC1"",5,0)"
^XMB(3.9,145949,2,250,0)=" ;Reference to ^PSRX(    supported by DBIA #1977"
^XMB(3.9,145949,2,251,0)="""RTN"",""PSXMISC1"",6,0)"
^XMB(3.9,145949,2,252,0)=" ;Reference to ^PS(55,   supported by DBIA #2228"
^XMB(3.9,145949,2,253,0)="""RTN"",""PSXMISC1"",7,0)"
^XMB(3.9,145949,2,254,0)=" ;Reference to ^PSRX(    supported by DBIA #1977"
^XMB(3.9,145949,2,255,0)="""RTN"",""PSXMISC1"",8,0)"
^XMB(3.9,145949,2,256,0)=" ;Reference to PROD2^PSNAPIS supported by DBIA #2531"
^XMB(3.9,145949,2,257,0)="""RTN"",""PSXMISC1"",9,0)"
^XMB(3.9,145949,2,258,0)=" ;Reference to ^PSSLOCK supported by DBIA #2789"
^XMB(3.9,145949,2,259,0)="""RTN"",""PSXMISC1"",10,0)"
^XMB(3.9,145949,2,260,0)=" ;Reference to CHKRX^PSOBAI supported by DBIA #4910"
^XMB(3.9,145949,2,261,0)="""RTN"",""PSXMISC1"",11,0)"
^XMB(3.9,145949,2,262,0)="CHKDATA ;checks the data elements in PSRX before putting the rx in 550.2"
^XMB(3.9,145949,2,263,0)="""RTN"",""PSXMISC1"",12,0)"
^XMB(3.9,145949,2,264,0)=" Q:'$D(^PS(52.5,REC,0))"
^XMB(3.9,145949,2,265,0)="""RTN"",""PSXMISC1"",13,0)"
^XMB(3.9,145949,2,266,0)=" K DRUGCHK,PSXRXERR,PSXDGST,WARNS"
^XMB(3.9,145949,2,267,0)="""RTN"",""PSXMISC1"",14,0)"
^XMB(3.9,145949,2,268,0)=" S (RXN,PSXPTR)=$P($G(^PS(52.5,REC,0)),""^"",1) I PSXPTR="""" S PSXOK=8 Q"
^XMB(3.9,145949,2,269,0)="""RTN"",""PSXMISC1"",15,0)"
^XMB(3.9,145949,2,270,0)=" D PSOL^PSSLOCK(RXN) S PSOMSG=+PSOMSG ; sets PSOMSG"
^XMB(3.9,145949,2,271,0)="""RTN"",""PSXMISC1"",16,0)"
^XMB(3.9,145949,2,272,0)=" I ($P(^PS(52.5,REC,0),U,3)'=XDFN)!($P(^PSRX(PSXPTR,0),U,2)'=XDFN) S PSXOK=8 Q"
^XMB(3.9,145949,2,273,0)="""RTN"",""PSXMISC1"",17,0)"
^XMB(3.9,145949,2,274,0)=" I '$D(^PSRX(PSXPTR,0)) S PSXOK=8 Q"
^XMB(3.9,145949,2,275,0)="""RTN"",""PSXMISC1"",18,0)"
^XMB(3.9,145949,2,276,0)=" S RXNUM=$P($G(^PSRX(PSXPTR,0)),""^"",6),RXEX=$P($G(^PSRX(PSXPTR,0)),""^"",1)"
^XMB(3.9,145949,2,277,0)="""RTN"",""PSXMISC1"",19,0)"
^XMB(3.9,145949,2,278,0)=" I $G(^PSDRUG(RXNUM,""ND""))'="""" D"
^XMB(3.9,145949,2,279,0)="""RTN"",""PSXMISC1"",20,0)"
^XMB(3.9,145949,2,280,0)=" .S PTRA=$P($G(^PSDRUG(RXNUM,""ND"")),U,1),PTRB=$P($G(^PSDRUG(RXNUM,""ND"")),U,3)"
^XMB(3.9,145949,2,281,0)="""RTN"",""PSXMISC1"",21,0)"
^XMB(3.9,145949,2,282,0)=" .I $G(PTRA)'="""" S ZX=$$PROD2^PSNAPIS(PTRA,PTRB),DRUGCHK=$P($G(ZX),""^"",3)"
^XMB(3.9,145949,2,283,0)="""RTN"",""PSXMISC1"",22,0)"
^XMB(3.9,145949,2,284,0)=" S:$G(DRUGCHK)'="""" PSXDGST=$P(ZX,""^"",2)_""^""_$P(ZX,""^"")"
^XMB(3.9,145949,2,285,0)="""RTN"",""PSXMISC1"",23,0)"
^XMB(3.9,145949,2,286,0)=" I '$D(DRUGCHK) S DRUGCHK=0"
^XMB(3.9,145949,2,287,0)="""RTN"",""PSXMISC1"",24,0)"
^XMB(3.9,145949,2,288,0)=" S:'$D(^PSDRUG(""AQ"",RXNUM)) PSXOK=1"
^XMB(3.9,145949,2,289,0)="""RTN"",""PSXMISC1"",25,0)"
^XMB(3.9,145949,2,290,0)=" S:$G(DRUGCHK)'=1 PSXOK=1"
^XMB(3.9,145949,2,291,0)="""RTN"",""PSXMISC1"",26,0)"
^XMB(3.9,145949,2,292,0)=" I $P(^PSDRUG(RXNUM,2),""^"",3)'[""O"" S PSXOK=1,PSXCK=RXNUM D UNMARK^PSXUTL"
^XMB(3.9,145949,2,293,0)="""RTN"",""PSXMISC1"",27,0)"
^XMB(3.9,145949,2,294,0)=" S:$P($G(^PSRX(PSXPTR,""STA"")),U,1)'=5 PSXOK=5"
^XMB(3.9,145949,2,295,0)="""RTN"",""PSXMISC1"",28,0)"
^XMB(3.9,145949,2,296,0)=" ;gets the fill number by ordering thru the refill node for the last"
^XMB(3.9,145949,2,297,0)="""RTN"",""PSXMISC1"",29,0)"
^XMB(3.9,145949,2,298,0)=" ;refill number"
^XMB(3.9,145949,2,299,0)="""RTN"",""PSXMISC1"",30,0)"
^XMB(3.9,145949,2,300,0)=" S FILNUM=0 F REF=0:0 S REF=$O(^PSRX(PSXPTR,1,REF)) Q:REF'>0  S:REF>0 FILNUM=REF S:REF="""" FILNUM=0"
^XMB(3.9,145949,2,301,0)="""RTN"",""PSXMISC1"",31,0)"
^XMB(3.9,145949,2,302,0)=" ;I $G(PSXFLAG)=2 S PSXOK=0 Q"
^XMB(3.9,145949,2,303,0)="""RTN"",""PSXMISC1"",32,0)"
^XMB(3.9,145949,2,304,0)=" S RXF=FILNUM"
^XMB(3.9,145949,2,305,0)="""RTN"",""PSXMISC1"",33,0)"
^XMB(3.9,145949,2,306,0)=" S REL=$S(RXF>0:$P($G(^PSRX(RXN,1,RXF,0)),U,18),RXF=0:$P($G(^PSRX(RXN,2)),U,13),1:"""") I $G(REL)'="""" S PSXOK=6"
^XMB(3.9,145949,2,307,0)="""RTN"",""PSXMISC1"",34,0)"
^XMB(3.9,145949,2,308,0)=" S:((PSXOK=0)&(FILNUM>0)&($P($G(^PSRX(PSXPTR,1,FILNUM,0)),""^"",2)'=""M"")) PSXOK=3"
^XMB(3.9,145949,2,309,0)="""RTN"",""PSXMISC1"",35,0)"
^XMB(3.9,145949,2,310,0)=" S:((PSXOK=0)&(FILNUM'>0)&($P($G(^PSRX(PSXPTR,0)),""^"",11)'=""M"")) PSXOK=3"
^XMB(3.9,145949,2,311,0)="""RTN"",""PSXMISC1"",36,0)"
^XMB(3.9,145949,2,312,0)=" I $G(^PS(52.5,REC,""P""))=""1"" S PSXOK=4"
^XMB(3.9,145949,2,313,0)="""RTN"",""PSXMISC1"",37,0)"
^XMB(3.9,145949,2,314,0)=" S PSXDIV=$S(FILNUM=0:$P($G(^PSRX(PSXPTR,2)),U,9),FILNUM>0:$P($G(^PSRX(PSXPTR,1,FILNUM,0)),""^"",9),1:"""")"
^XMB(3.9,145949,2,315,0)="""RTN"",""PSXMISC1"",38,0)"
^XMB(3.9,145949,2,316,0)=" ;If trans div does not match Rx div eliminate"
^XMB(3.9,145949,2,317,0)="""RTN"",""PSXMISC1"",39,0)"
^XMB(3.9,145949,2,318,0)=" I PSXDIV'=PSOSITE S PSXOK=7 Q"
^XMB(3.9,145949,2,319,0)="""RTN"",""PSXMISC1"",40,0)"
^XMB(3.9,145949,2,320,0)=" ; Changes for Controlled subs "
^XMB(3.9,145949,2,321,0)="""RTN"",""PSXMISC1"",41,0)"
^XMB(3.9,145949,2,322,0)=" N PSXCSC,PSXCSD S PSXCSRX="""""
^XMB(3.9,145949,2,323,0)="""RTN"",""PSXMISC1"",42,0)"
^XMB(3.9,145949,2,324,0)=" S PSXCSC=$P($G(^PSDRUG(RXNUM,0)),""^"",3)"
^XMB(3.9,145949,2,325,0)="""RTN"",""PSXMISC1"",43,0)"
^XMB(3.9,145949,2,326,0)=" ;Can't trans DEA schedule 1 or 2"
^XMB(3.9,145949,2,327,0)="""RTN"",""PSXMISC1"",44,0)"
^XMB(3.9,145949,2,328,0)=" I $G(PSXCSC)[1!($G(PSXCSC)[2) S PSXOK=10 Q"
^XMB(3.9,145949,2,329,0)="""RTN"",""PSXMISC1"",45,0)"
^XMB(3.9,145949,2,330,0)=" ;If CS must be DEA 3-5 to qualify"
^XMB(3.9,145949,2,331,0)="""RTN"",""PSXMISC1"",46,0)"
^XMB(3.9,145949,2,332,0)=" F PSXCSD=3:1:5 I PSXCSC[PSXCSD S PSXCSRX=1"
^XMB(3.9,145949,2,333,0)="""RTN"",""PSXMISC1"",47,0)"
^XMB(3.9,145949,2,334,0)=" ;If not CS drug and CS trans eliminate"
^XMB(3.9,145949,2,335,0)="""RTN"",""PSXMISC1"",48,0)"
^XMB(3.9,145949,2,336,0)=" I ($G(PSXCSRX)<1)&($G(PSXCS)=1) S PSXOK=9 Q"
^XMB(3.9,145949,2,337,0)="""RTN"",""PSXMISC1"",49,0)"
^XMB(3.9,145949,2,338,0)=" ;If CS drug and not CS trans eliminate"
^XMB(3.9,145949,2,339,0)="""RTN"",""PSXMISC1"",50,0)"
^XMB(3.9,145949,2,340,0)=" I ($G(PSXCSRX)=1)&($G(PSXCS)<1) S PSXOK=9 Q"
^XMB(3.9,145949,2,341,0)="""RTN"",""PSXMISC1"",51,0)"
^XMB(3.9,145949,2,342,0)=" ; Checks for do not mail and expiration date thereof"
^XMB(3.9,145949,2,343,0)="""RTN"",""PSXMISC1"",52,0)"
^XMB(3.9,145949,2,344,0)=" ; moved to under NOGO"
^XMB(3.9,145949,2,345,0)="""RTN"",""PSXMISC1"",53,0)"
^XMB(3.9,145949,2,346,0)=" ;"
^XMB(3.9,145949,2,347,0)="""RTN"",""PSXMISC1"",54,0)"
^XMB(3.9,145949,2,348,0)=" G:PSXOK'=0 STOP"
^XMB(3.9,145949,2,349,0)="""RTN"",""PSXMISC1"",55,0)"
^XMB(3.9,145949,2,350,0)="NOGO ;any rx that does not pass the following checks will not be transmitted"
^XMB(3.9,145949,2,351,0)="""RTN"",""PSXMISC1"",56,0)"
^XMB(3.9,145949,2,352,0)=" ;and an error message will be generated and sent to the user who"
^XMB(3.9,145949,2,353,0)="""RTN"",""PSXMISC1"",57,0)"
^XMB(3.9,145949,2,354,0)=" ;initiated the transmission.  All that pass the checks will be sent."
^XMB(3.9,145949,2,355,0)="""RTN"",""PSXMISC1"",58,0)"
^XMB(3.9,145949,2,356,0)=" S RXERR=0,PSXRXERR=RXEX_""^""_RXF"
^XMB(3.9,145949,2,357,0)="""RTN"",""PSXMISC1"",59,0)"
^XMB(3.9,145949,2,358,0)=" I RXEX["" "" S RXERR=13,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,359,0)="""RTN"",""PSXMISC1"",60,0)"
^XMB(3.9,145949,2,360,0)=" S QTY=$S(RXF>0:$P($G(^PSRX(RXN,1,RXF,0)),U,4),RXF=0:$P($G(^PSRX(RXN,0)),U,7),1:"""") G:$G(QTY)'=""""&($G(QTY)>0)&(QTY?.N)!(QTY?.N1""."".N) NG1 S RXERR=2,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,361,0)="""RTN"",""PSXMISC1"",61,0)"
^XMB(3.9,145949,2,362,0)="NG1 S PHY=$S(RXF>0:$P($G(^PSRX(RXN,1,RXF,0)),U,17),RXF=0:$P($G(^PSRX(RXN,0)),U,4),1:"""") I PHY="""" S RXERR=3,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,363,0)="""RTN"",""PSXMISC1"",62,0)"
^XMB(3.9,145949,2,364,0)=" S DAYS=$S(RXF>0:$P($G(^PSRX(RXN,1,RXF,0)),U,10),RXF=0:$P($G(^PSRX(RXN,0)),U,8),1:"""") I (DAYS'>0)!(DAYS="""") S RXERR=4,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,365,0)="""RTN"",""PSXMISC1"",63,0)"
^XMB(3.9,145949,2,366,0)=" S PHARCLK=$S(RXF>0:$P($G(^PSRX(RXN,1,RXF,0)),U,7),RXF=0:$P($G(^PSRX(RXN,0)),U,16),1:"""") I PHARCLK="""" S RXERR=9,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,367,0)="""RTN"",""PSXMISC1"",64,0)"
^XMB(3.9,145949,2,368,0)=" S DRUG=$P($G(^PSRX(RXN,0)),U,6),PSTAT=$P($G(^(0)),U,3),FDATE=$P($G(^PSRX(RXN,2)),U,2)"
^XMB(3.9,145949,2,369,0)="""RTN"",""PSXMISC1"",65,0)"
^XMB(3.9,145949,2,370,0)=" D TSTSIG"
^XMB(3.9,145949,2,371,0)="""RTN"",""PSXMISC1"",66,0)"
^XMB(3.9,145949,2,372,0)=" S DFN=$P($G(^PSRX(RXN,0)),U,2) D ADD^VADPT I (($G(VAPA(1))="""")!($G(VAPA(4))="""")!($P($G(VAPA(5)),""^"",2)="""")!($G(VAPA(6))'>0)!($P($G(VAPA(11)),""^"",2)'>0)),(($$BADADR^DGUTL3(DFN))'>0) S RXERR=10,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,373,0)="""RTN"",""PSXMISC1"",67,0)"
^XMB(3.9,145949,2,374,0)=" D DEM^VADPT"
^XMB(3.9,145949,2,375,0)="""RTN"",""PSXMISC1"",68,0)"
^XMB(3.9,145949,2,376,0)=" I VADM(1)[""MERGING"" S RXERR=17,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,377,0)="""RTN"",""PSXMISC1"",69,0)"
^XMB(3.9,145949,2,378,0)=" ;MVP OIFO BAY PINES;ELR;PSX*2*52  CHANGED RXERR FROM 10 TO 19. ADDED NEW ERROR IN PSXERR"
^XMB(3.9,145949,2,379,0)="""RTN"",""PSXMISC1"",70,0)"
^XMB(3.9,145949,2,380,0)=" I $G(VA(""PID""))[""000-00"" S RXERR=19,PSXRXERR=PSXRXERR_""^""_RXERR ; SSN [""000-00"" indicates test patient"
^XMB(3.9,145949,2,381,0)="""RTN"",""PSXMISC1"",71,0)"
^XMB(3.9,145949,2,382,0)=" S (CNTR,XC,DUPFLG)=0,DUPRX="""" F  S XC=$O(^PSRX(""B"",RXEX,XC)) Q:XC'>0  S CNTR=CNTR+1,DUPRX=DUPRX_""^""_XC"
^XMB(3.9,145949,2,383,0)="""RTN"",""PSXMISC1"",72,0)"
^XMB(3.9,145949,2,384,0)=" I CNTR>1 D"
^XMB(3.9,145949,2,385,0)="""RTN"",""PSXMISC1"",73,0)"
^XMB(3.9,145949,2,386,0)=" .Q:$P(DUPRX,""^"",3)="""""
^XMB(3.9,145949,2,387,0)="""RTN"",""PSXMISC1"",74,0)"
^XMB(3.9,145949,2,388,0)=" .F I2=2:1 S I1=$P(DUPRX,""^"",I2) Q:I1=""""  S PSREC=$O(^PS(52.5,""B"",I1,"""")) Q:$G(PSREC)'>0  S:($P(^PS(52.5,PSREC,0),""^"",2)<PSXDTRG&($P(^PS(52.5,PSREC,0),""^"",7)=""Q"")) DUPFLG=1"
^XMB(3.9,145949,2,389,0)="""RTN"",""PSXMISC1"",75,0)"
^XMB(3.9,145949,2,390,0)=" S:$G(DUPFLG)>0 PSXRXERR=PSXRXERR_""^""_""14"""
^XMB(3.9,145949,2,391,0)="""RTN"",""PSXMISC1"",76,0)"
^XMB(3.9,145949,2,392,0)=" K CNTR,XC,DUPRX,I2,I1,PSREC,DUPFLG"
^XMB(3.9,145949,2,393,0)="""RTN"",""PSXMISC1"",77,0)"
^XMB(3.9,145949,2,394,0)=" I $D(^PSRX(PSXPTR,4,0)) D"
^XMB(3.9,145949,2,395,0)="""RTN"",""PSXMISC1"",78,0)"
^XMB(3.9,145949,2,396,0)=" .S RXERR="""""
^XMB(3.9,145949,2,397,0)="""RTN"",""PSXMISC1"",79,0)"
^XMB(3.9,145949,2,398,0)=" .S ZX=0 F  S ZX=$O(^PSRX(PSXPTR,4,ZX)) Q:ZX'>0  D"
^XMB(3.9,145949,2,399,0)="""RTN"",""PSXMISC1"",80,0)"
^XMB(3.9,145949,2,400,0)=" ..I $P(^PSRX(PSXPTR,4,ZX,0),""^"",3)=RXF&($P(^PSRX(PSXPTR,4,ZX,0),""^"",4)'=3) S RXERR=12"
^XMB(3.9,145949,2,401,0)="""RTN"",""PSXMISC1"",81,0)"
^XMB(3.9,145949,2,402,0)=" ..I $P(^PSRX(PSXPTR,4,ZX,0),""^"",3)=RXF&($P(^PSRX(PSXPTR,4,ZX,0),""^"",4)=3) S RXERR="""""
^XMB(3.9,145949,2,403,0)="""RTN"",""PSXMISC1"",82,0)"
^XMB(3.9,145949,2,404,0)=" .I RXERR'="""" S PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,405,0)="""RTN"",""PSXMISC1"",83,0)"
^XMB(3.9,145949,2,406,0)=" I DRUG="""" S RXERR=5,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,407,0)="""RTN"",""PSXMISC1"",84,0)"
^XMB(3.9,145949,2,408,0)=" I DRUG S WARNS=$P(^PSDRUG(DRUG,0),""^"",8) D"
^XMB(3.9,145949,2,409,0)="""RTN"",""PSXMISC1"",85,0)"
^XMB(3.9,145949,2,410,0)=" .;IF USING NEW WARNING SOURCE, LENGTH OF OLD WARNINGS DOESN'T MATTER"
^XMB(3.9,145949,2,411,0)="""RTN"",""PSXMISC1"",86,0)"
^XMB(3.9,145949,2,412,0)=" .I '$D(PSSWSITE) S PSSWSITE=+$O(^PS(59.7,0))"
^XMB(3.9,145949,2,413,0)="""RTN"",""PSXMISC1"",87,0)"
^XMB(3.9,145949,2,414,0)=" .I $P($G(^PS(59.7,PSSWSITE,10)),""^"",10)=""N"" Q"
^XMB(3.9,145949,2,415,0)="""RTN"",""PSXMISC1"",88,0)"
^XMB(3.9,145949,2,416,0)=" .I $G(WARNS) S:$L(WARNS)>11 RXERR=16,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,417,0)="""RTN"",""PSXMISC1"",89,0)"
^XMB(3.9,145949,2,418,0)=" I SIG="""" S RXERR=6,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,419,0)="""RTN"",""PSXMISC1"",90,0)"
^XMB(3.9,145949,2,420,0)=" I PSTAT="""" S RXERR=7,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,421,0)="""RTN"",""PSXMISC1"",91,0)"
^XMB(3.9,145949,2,422,0)=" I FDATE'?7N S RXERR=8,PSXRXERR=PSXRXERR_""^""_RXERR"
^XMB(3.9,145949,2,423,0)="""RTN"",""PSXMISC1"",92,0)"
^XMB(3.9,145949,2,424,0)=" I '$$MAILOK(RXN) D"
^XMB(3.9,145949,2,425,0)="""RTN"",""PSXMISC1"",93,0)"
^XMB(3.9,145949,2,426,0)=" . S COM=""Removed from CMOP Suspense - Mail Status Change"" D NOW^%DTC S DTTM=% K % D ACTLOG^PSXRPPL"
^XMB(3.9,145949,2,427,0)="""RTN"",""PSXMISC1"",94,0)"
^XMB(3.9,145949,2,428,0)=" . D DELETE^PSXRPPL S PSXOK=1"
^XMB(3.9,145949,2,429,0)="""RTN"",""PSXMISC1"",95,0)"
^XMB(3.9,145949,2,430,0)=" . ;MVP OIFO BAY PINES;ELR;PSX*2*5 DELETE MM MSG FOR DO NOT MAIL"
^XMB(3.9,145949,2,431,0)="""RTN"",""PSXMISC1"",96,0)"
^XMB(3.9,145949,2,432,0)=" . ;S RXERR=15,PSXRXERR=PSXRXERR_""^""_RXERR ;mail message to users"
^XMB(3.9,145949,2,433,0)="""RTN"",""PSXMISC1"",97,0)"
^XMB(3.9,145949,2,434,0)=" I $D(^TMP($J,""PSXBAI"",DFN)),'$G(^TMP($J,""PSXBAI"",DFN)) D"
^XMB(3.9,145949,2,435,0)="""RTN"",""PSXMISC1"",98,0)"
^XMB(3.9,145949,2,436,0)=" . S PSXOK=8"
^XMB(3.9,145949,2,437,0)="""RTN"",""PSXMISC1"",99,0)"
^XMB(3.9,145949,2,438,0)=" . D CHKACT(PSXPTR)"
^XMB(3.9,145949,2,439,0)="""RTN"",""PSXMISC1"",100,0)"
^XMB(3.9,145949,2,440,0)=" . I '$G(PSXFIRST) K PSXRXERR Q"
^XMB(3.9,145949,2,441,0)="""RTN"",""PSXMISC1"",101,0)"
^XMB(3.9,145949,2,442,0)=" . S COM=""Bad Address Indicator or Foreign Address. Not removed from CMOP Suspense"" D NOW^%DTC S DTTM=% K % D ACTLOG^PSXRPPL"
^XMB(3.9,145949,2,443,0)="""RTN"",""PSXMISC1"",102,0)"
^XMB(3.9,145949,2,444,0)=" . S RXERR=20,PSXRXERR=PSXRXERR_""^""_RXERR ;mail message to users"
^XMB(3.9,145949,2,445,0)="""RTN"",""PSXMISC1"",103,0)"
^XMB(3.9,145949,2,446,0)="PSOMSG I +PSOMSG=0 S RXERR=18,PSXRXERR=PSXRXERR_""^""_RXERR ; from PSSLOCK"
^XMB(3.9,145949,2,447,0)="""RTN"",""PSXMISC1"",104,0)"
^XMB(3.9,145949,2,448,0)=" I $P($G(PSXRXERR),""^"",3)'="""" S PSXOK=8 D ER7^PSXERR"
^XMB(3.9,145949,2,449,0)="""RTN"",""PSXMISC1"",105,0)"
^XMB(3.9,145949,2,450,0)="STOP K DAYS,DRUG,FDATE,PHARCLK,PHY,PSTAT,QTY,RXERR,RXEX,SIG,VAPA(1),DRUGCHK,PTRA,PTRB,REL,RXNUM,PHARCLK1,ZX,VAPA(4),VAPA(5),VAPA(6)"
^XMB(3.9,145949,2,451,0)="""RTN"",""PSXMISC1"",106,0)"
^XMB(3.9,145949,2,452,0)=" Q"
^XMB(3.9,145949,2,453,0)="""RTN"",""PSXMISC1"",107,0)"
^XMB(3.9,145949,2,454,0)=" ;"
