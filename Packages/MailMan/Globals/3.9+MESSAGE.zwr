^XMB(3.9,145980,2,5511,0)="""RTN"",""SDES2CRTCLNAVAL2"",22,0)"
^XMB(3.9,145980,2,5512,0)=" ;"
^XMB(3.9,145980,2,5513,0)="""RTN"",""SDES2CRTCLNAVAL2"",23,0)"
^XMB(3.9,145980,2,5514,0)=" I '$D(RETURNAVAIL) S RETURNAVAIL(""clinicAvailability"")="""""
^XMB(3.9,145980,2,5515,0)="""RTN"",""SDES2CRTCLNAVAL2"",24,0)"
^XMB(3.9,145980,2,5516,0)=" D BUILDJSON^SDES2JSON(.JSON,.RETURNAVAIL)"
^XMB(3.9,145980,2,5517,0)="""RTN"",""SDES2CRTCLNAVAL2"",25,0)"
