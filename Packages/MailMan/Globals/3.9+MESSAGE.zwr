^XMB(3.9,145946,2,5611,0)="""RTN"",""IBCNSU21"",165,0)"
^XMB(3.9,145946,2,5612,0)=" ;          ^TMP(""IBCNSU21"",$J)     - Current Array of displayed policies"
^XMB(3.9,145946,2,5613,0)="""RTN"",""IBCNSU21"",166,0)"
