^XMB(3.9,145958,2,2066,0)=" . . ; S X1=$G(^DPT(IEN,.1))_"" ""_$G(^DPT(IEN,.101))"
^XMB(3.9,145958,2,2067,0)="""RTN"",""ORWPT"",213,0)"
