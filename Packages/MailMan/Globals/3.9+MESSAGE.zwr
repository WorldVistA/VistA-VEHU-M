^XMB(3.9,145936,2,523,0)="""RTN"",""PSBOMH1"",142,0)"
^XMB(3.9,145936,2,524,0)=" .....I $L(PSBLINE2)'>169 S ^TMP(""PSB"",$J,PSBWEEK,PSBORD,""AT"",X+4)=""     ""_PSBRTXTW"
^XMB(3.9,145936,2,525,0)="""RTN"",""PSBOMH1"",143,0)"
^XMB(3.9,145936,2,526,0)=" .....I $L(PSBLINE2)>169 S ^TMP(""PSB"",$J,PSBWEEK,PSBORD,""AT"",X+4)=""           ""_$E(PSBLINE2,170,245),^TMP(""PSB"",$J,PSBWEEK,PSBORD,""AT"",X+5)=""     ""_PSBRTXTW"
^XMB(3.9,145936,2,527,0)="""RTN"",""PSBOMH1"",144,0)"
^XMB(3.9,145936,2,528,0)=" D RELINE^PSBOMH3(PSBWEEK) ;Line up administrations with their admin times - PSB*3*67"
^XMB(3.9,145936,2,529,0)="""RTN"",""PSBOMH1"",145,0)"
^XMB(3.9,145936,2,530,0)=" Q"
^XMB(3.9,145936,2,531,0)="""RTN"",""PSBOMH1"",146,0)"
^XMB(3.9,145936,2,532,0)=" ;"
^XMB(3.9,145936,2,533,0)="""RTN"",""PSBOMH1"",147,0)"
^XMB(3.9,145936,2,534,0)="DDAUD ;  audits for dispen drugs"
^XMB(3.9,145936,2,535,0)="""RTN"",""PSBOMH1"",148,0)"
^XMB(3.9,145936,2,536,0)=" ;"
^XMB(3.9,145936,2,537,0)="""RTN"",""PSBOMH1"",149,0)"
^XMB(3.9,145936,2,538,0)=" N PSBMLA,PSBDATE,PSBGA,PSBTMP"
^XMB(3.9,145936,2,539,0)="""RTN"",""PSBOMH1"",150,0)"
^XMB(3.9,145936,2,540,0)=" M PSBMLA=^PSB(53.79,PSBIEN)"
^XMB(3.9,145936,2,541,0)="""RTN"",""PSBOMH1"",151,0)"
^XMB(3.9,145936,2,542,0)=" S PSBGA="""" I $D(PSBMLA(.9,0)) D"
^XMB(3.9,145936,2,543,0)="""RTN"",""PSBOMH1"",152,0)"
^XMB(3.9,145936,2,544,0)=" .F PSBX=1:1 Q:'$D(PSBMLA(.9,PSBX))  I ((PSBMLA(.9,PSBX,0)[""ACTION STATUS"")!(PSBMLA(.9,PSBX,0)[""ADMINISTRATION STATUS"")) D  Q"
^XMB(3.9,145936,2,545,0)="""RTN"",""PSBOMH1"",153,0)"
^XMB(3.9,145936,2,546,0)=" ..I $D(PSBMLA(.9,PSBX-2,0)) D DT^DILF(""ENPST"",$P(PSBMLA(.9,PSBX-2,0),""'"",2),.PSBDATE)"
^XMB(3.9,145936,2,547,0)="""RTN"",""PSBOMH1"",154,0)"
^XMB(3.9,145936,2,548,0)=" ..I '$D(PSBMLA(.9,PSBX-2,0)) S PSBDATE=$P(^PSB(53.79,PSBIEN,0),U,6)"
^XMB(3.9,145936,2,549,0)="""RTN"",""PSBOMH1"",155,0)"
^XMB(3.9,145936,2,550,0)=" ..S PSBTMP(10000000-PSBDATE,""B"")=PSBDATE_U_$$INITIAL^PSBRPC2($P(PSBMLA(0),U,5))_U_$P(PSBMLA(.9,PSBX,0),""'"",2)"
^XMB(3.9,145936,2,551,0)="""RTN"",""PSBOMH1"",156,0)"
^XMB(3.9,145936,2,552,0)=" ..S PSBGA=1"
^XMB(3.9,145936,2,553,0)="""RTN"",""PSBOMH1"",157,0)"
^XMB(3.9,145936,2,554,0)=" .F PSBX=1:1 Q:'$D(PSBMLA(.9,PSBX))  I ((PSBMLA(.9,PSBX,0)[""ACTION STATUS"")!(PSBMLA(.9,PSBX,0)[""ADMINISTRATION STATUS"")) D"
^XMB(3.9,145936,2,555,0)="""RTN"",""PSBOMH1"",158,0)"
^XMB(3.9,145936,2,556,0)=" ..S PSBTMP(10000000-$P(PSBMLA(.9,PSBX,0),U,1),""B"")=$P(PSBMLA(.9,PSBX,0),U,1)_U_$$INITIAL^PSBRPC2($P(PSBMLA(.9,PSBX,0),U,2))_U_$P($P(PSBMLA(.9,PSBX,0),U,3),""'"",2)"
^XMB(3.9,145936,2,557,0)="""RTN"",""PSBOMH1"",159,0)"
^XMB(3.9,145936,2,558,0)=" ..S PSBGA=1"
^XMB(3.9,145936,2,559,0)="""RTN"",""PSBOMH1"",160,0)"
^XMB(3.9,145936,2,560,0)=" ;PSB*3*45 Remove Use of $Q(<>,-1)"
^XMB(3.9,145936,2,561,0)="""RTN"",""PSBOMH1"",161,0)"
^XMB(3.9,145936,2,562,0)=" N PSBTMQ,PSBPQRY,PSBQRY"
^XMB(3.9,145936,2,563,0)="""RTN"",""PSBOMH1"",162,0)"
^XMB(3.9,145936,2,564,0)=" I PSBGA'=1 S PSBTMP(10000000-$P(PSBMLA(0),U,6),""A"")=$P(PSBMLA(0),U,6)_U_$$INITIAL^PSBRPC2($P(PSBMLA(0),U,7))"
^XMB(3.9,145936,2,565,0)="""RTN"",""PSBOMH1"",163,0)"
^XMB(3.9,145936,2,566,0)=" S PSBQRY=""PSBTMP"",PSBCNT=1 F  S PSBTMQ=PSBQRY,PSBQRY=$Q(@PSBQRY) Q:PSBQRY=""""  D  ; does comment go with action"
^XMB(3.9,145936,2,567,0)="""RTN"",""PSBOMH1"",164,0)"
^XMB(3.9,145936,2,568,0)=" .S PSBPQRY=$G(PSBTMQ)"
^XMB(3.9,145936,2,569,0)="""RTN"",""PSBOMH1"",165,0)"
^XMB(3.9,145936,2,570,0)=" .I PSBPQRY="""" S PSBTAR(PSBCNT)=@PSBQRY,PSBCNT=PSBCNT+1 Q  ; no prev action"
^XMB(3.9,145936,2,571,0)="""RTN"",""PSBOMH1"",166,0)"
^XMB(3.9,145936,2,572,0)=" .I $QS(PSBPQRY,2)=""C""  S PSBTAR(PSBCNT)=@PSBQRY,PSBCNT=PSBCNT+1 Q  ; prev line = comment"
^XMB(3.9,145936,2,573,0)="""RTN"",""PSBOMH1"",167,0)"
^XMB(3.9,145936,2,574,0)=" .I $QS(PSBQRY,2)=""C"",$E($P(@PSBTMQ,U,1),1,12)=$E($P(@PSBQRY,U,1),1,12),$P(@PSBTMQ,U,2)=$P(@PSBQRY,U,2) D  Q"
^XMB(3.9,145936,2,575,0)="""RTN"",""PSBOMH1"",168,0)"
^XMB(3.9,145936,2,576,0)=" ..S X=$P(@PSBQRY,U,4) S:X["":"" X=$P(X,"":"",2) S $P(PSBTAR(PSBCNT-1),U,4)=X Q"
^XMB(3.9,145936,2,577,0)="""RTN"",""PSBOMH1"",169,0)"
^XMB(3.9,145936,2,578,0)=" .S PSBTAR(PSBCNT)=@PSBQRY,PSBCNT=PSBCNT+1"
