^XMB(3.9,145986,2,1990,0)=" S FBADMTDX=$P(FBY5,""^"",9) I FBADMTDX]"""" W !?2,""Admit Dx: "",$$ICD9^FBCSV1((FBADMTDX),$P($G(FBIN),""^"",6))"
^XMB(3.9,145986,2,1991,0)="""RTN"",""FBCHVH"",50,0)"
^XMB(3.9,145986,2,1992,0)=" ;write contract number"
^XMB(3.9,145986,2,1993,0)="""RTN"",""FBCHVH"",51,0)"
^XMB(3.9,145986,2,1994,0)=" S FBCNTRN=$S($P(FBY5,U,8):$P($G(^FBAA(161.43,$P(FBY5,U,8),0)),U),1:"""")"
^XMB(3.9,145986,2,1995,0)="""RTN"",""FBCHVH"",52,0)"
^XMB(3.9,145986,2,1996,0)=" I FBCNTRN]"""" W ?25,""Contract Number: "",FBCNTRN"
^XMB(3.9,145986,2,1997,0)="""RTN"",""FBCHVH"",53,0)"
^XMB(3.9,145986,2,1998,0)=" ;set diagnosis code and present on admission code"
^XMB(3.9,145986,2,1999,0)="""RTN"",""FBCHVH"",54,0)"
^XMB(3.9,145986,2,2000,0)=" N P1,P2"
^XMB(3.9,145986,2,2001,0)="""RTN"",""FBCHVH"",55,0)"
^XMB(3.9,145986,2,2002,0)=" S P1=$G(^FBAAI(FBI,""DX""))"
^XMB(3.9,145986,2,2003,0)="""RTN"",""FBCHVH"",56,0)"
^XMB(3.9,145986,2,2004,0)=" S P2=$G(^FBAAI(FBI,""POA""))"
^XMB(3.9,145986,2,2005,0)="""RTN"",""FBCHVH"",57,0)"
^XMB(3.9,145986,2,2006,0)=" F K=1:1:25 D WRTDX"
^XMB(3.9,145986,2,2007,0)="""RTN"",""FBCHVH"",58,0)"
^XMB(3.9,145986,2,2008,0)=" ;display procedure code with line item prov data - FB*3.5*135"
^XMB(3.9,145986,2,2009,0)="""RTN"",""FBCHVH"",59,0)"
^XMB(3.9,145986,2,2010,0)=" N DIR,DUOUT,DTOUT,FBOUT,F135,L,P3,P5,RPROV,STRLEN,WRTPC"
^XMB(3.9,145986,2,2011,0)="""RTN"",""FBCHVH"",60,0)"
^XMB(3.9,145986,2,2012,0)=" S P5=$G(^FBAAI(FBI,""PROC""))   ; Procedure codes"
^XMB(3.9,145986,2,2013,0)="""RTN"",""FBCHVH"",61,0)"
^XMB(3.9,145986,2,2014,0)=" M RPROV=^FBAAI(FBI,""RPROV"")   ; LI Provider array"
^XMB(3.9,145986,2,2015,0)="""RTN"",""FBCHVH"",62,0)"
^XMB(3.9,145986,2,2016,0)=" S F135=24,FBOUT=0,STRLEN=66"
^XMB(3.9,145986,2,2017,0)="""RTN"",""FBCHVH"",63,0)"
^XMB(3.9,145986,2,2018,0)=" F L=1:1:25 S WRTPC=$$WRTPC I WRTPC]"""" D  Q:FBOUT"
^XMB(3.9,145986,2,2019,0)="""RTN"",""FBCHVH"",64,0)"
^XMB(3.9,145986,2,2020,0)=" . S P3=$O(RPROV(""B"",L,0))"
^XMB(3.9,145986,2,2021,0)="""RTN"",""FBCHVH"",65,0)"
^XMB(3.9,145986,2,2022,0)=" . I P3 D    ; display LI Provider and NPI/TAXONOMY data if present"
^XMB(3.9,145986,2,2023,0)="""RTN"",""FBCHVH"",66,0)"
^XMB(3.9,145986,2,2024,0)=" .. W !,?4,""PROC: ""_WRTPC,?17,""RENDERING PROV NAME (LI): ""_$P(RPROV(P3,0),U,2) S F135=1+F135,STRLEN=66"
^XMB(3.9,145986,2,2025,0)="""RTN"",""FBCHVH"",67,0)"
^XMB(3.9,145986,2,2026,0)=" .. I '$L($P(RPROV(P3,0),U,3)),'$L($P(RPROV(P3,0),U,4)) Q"
^XMB(3.9,145986,2,2027,0)="""RTN"",""FBCHVH"",68,0)"
^XMB(3.9,145986,2,2028,0)=" .. W !,?22,""NPI: ""_$P(RPROV(P3,0),U,3),?43,""TAXONOMY CODE: ""_$P(RPROV(P3,0),U,4) S F135=1+F135"
^XMB(3.9,145986,2,2029,0)="""RTN"",""FBCHVH"",69,0)"
^XMB(3.9,145986,2,2030,0)=" . E  D  Q   ; only display procedure code"
^XMB(3.9,145986,2,2031,0)="""RTN"",""FBCHVH"",70,0)"
^XMB(3.9,145986,2,2032,0)=" .. I STRLEN>65 W !,?4,""PROC: "" S STRLEN=0    ; start new line"
^XMB(3.9,145986,2,2033,0)="""RTN"",""FBCHVH"",71,0)"
^XMB(3.9,145986,2,2034,0)=" .. W WRTPC_"" "" S STRLEN=1+STRLEN+$L(WRTPC)"
^XMB(3.9,145986,2,2035,0)="""RTN"",""FBCHVH"",72,0)"
^XMB(3.9,145986,2,2036,0)=" . I F135>22 S F135=0,STRLEN=66,DIR(0)=""E"" W ! D ^DIR K DIR S:$D(DUOUT)!($D(DTOUT)) FBOUT=1   ; pagination"
^XMB(3.9,145986,2,2037,0)="""RTN"",""FBCHVH"",73,0)"
^XMB(3.9,145986,2,2038,0)=" I $D(^FBAAI(FBI,10)) D  Q:FBOUT"
^XMB(3.9,145986,2,2039,0)="""RTN"",""FBCHVH"",74,0)"
^XMB(3.9,145986,2,2040,0)=" . N AI,AID,AITI S AI=0 S WRTPC=""Attachment ID:"""
^XMB(3.9,145986,2,2041,0)="""RTN"",""FBCHVH"",75,0)"
^XMB(3.9,145986,2,2042,0)=" . F  S AI=$O(^FBAAI(FBI,10,AI)) Q:'AI  D  Q:FBOUT"
^XMB(3.9,145986,2,2043,0)="""RTN"",""FBCHVH"",76,0)"
^XMB(3.9,145986,2,2044,0)=" . . S AID=$P($G(^FBAAI(FBI,10,AI,0)),""^"") I $L(WRTPC)>20 S WRTPC=WRTPC_"","""
^XMB(3.9,145986,2,2045,0)="""RTN"",""FBCHVH"",77,0)"
^XMB(3.9,145986,2,2046,0)=" . . S WRTPC=WRTPC_"" ""_AID"
^XMB(3.9,145986,2,2047,0)="""RTN"",""FBCHVH"",78,0)"
^XMB(3.9,145986,2,2048,0)=" . . S AITI=$P($G(^FBAAI(FBI,10,AI,0)),""^"",2) I AITI D"
^XMB(3.9,145986,2,2049,0)="""RTN"",""FBCHVH"",79,0)"
^XMB(3.9,145986,2,2050,0)=" . . . S WRTPC=WRTPC_"" (""_$P($G(^IBE(353.3,AITI,0)),""^"")"
^XMB(3.9,145986,2,2051,0)="""RTN"",""FBCHVH"",80,0)"
^XMB(3.9,145986,2,2052,0)=" . . . S WRTPC=WRTPC_"" - """
^XMB(3.9,145986,2,2053,0)="""RTN"",""FBCHVH"",81,0)"
^XMB(3.9,145986,2,2054,0)=" . . . S WRTPC=WRTPC_$P($G(^IBE(353.3,AITI,0)),""^"",2)_"")"""
^XMB(3.9,145986,2,2055,0)="""RTN"",""FBCHVH"",82,0)"
^XMB(3.9,145986,2,2056,0)=" . . I $L(WRTPC)>65 S FBOUT=$$WRTSTR(.WRTPC,65)"
^XMB(3.9,145986,2,2057,0)="""RTN"",""FBCHVH"",83,0)"
^XMB(3.9,145986,2,2058,0)=" . I $L(WRTPC)>0 S FBOUT=$$WRTSTR(.WRTPC,65)"
^XMB(3.9,145986,2,2059,0)="""RTN"",""FBCHVH"",84,0)"
^XMB(3.9,145986,2,2060,0)=" N A2 S A2=FBIN(9) W ! D PMNT^FBAACCB2"
^XMB(3.9,145986,2,2061,0)="""RTN"",""FBCHVH"",85,0)"
^XMB(3.9,145986,2,2062,0)=" Q"
^XMB(3.9,145986,2,2063,0)="""RTN"",""FBCHVH"",86,0)"
^XMB(3.9,145986,2,2064,0)="WRTSTR(STR,MX) ; Wordwrap string"
^XMB(3.9,145986,2,2065,0)="""RTN"",""FBCHVH"",87,0)"
^XMB(3.9,145986,2,2066,0)=" N RM,I S FBOUT=0"
^XMB(3.9,145986,2,2067,0)="""RTN"",""FBCHVH"",88,0)"
^XMB(3.9,145986,2,2068,0)="WRTSTR1 S RM=$S(STR?1""Attachment ID:"".E:MX-4,1:MX-7)"
^XMB(3.9,145986,2,2069,0)="""RTN"",""FBCHVH"",89,0)"
^XMB(3.9,145986,2,2070,0)=" F I=1:1:$L(STR,"" "") Q:$L($P(STR,"" "",1,I))>RM"
^XMB(3.9,145986,2,2071,0)="""RTN"",""FBCHVH"",90,0)"
