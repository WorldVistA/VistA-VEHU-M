^XMB(3.9,145986,2,3429,0)="""RTN"",""FBPAY671"",99,0)"
^XMB(3.9,145986,2,3430,0)=" I ($Y+5)>IOSL D:FBCRT CR Q:FBOUT  D HDR,SH,SHA"
