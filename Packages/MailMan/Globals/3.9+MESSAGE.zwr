^XMB(3.9,145946,2,700,0)=" ; IBMDTSPC(""IBEPT"") 0 = ignore Missing Electronic Plan Type filter."
^XMB(3.9,145946,2,701,0)="""RTN"",""IBCMDT"",29,0)"
^XMB(3.9,145946,2,702,0)=" ;                   1 = include Missing Electronic Plan Type filter."
^XMB(3.9,145946,2,703,0)="""RTN"",""IBCMDT"",30,0)"
