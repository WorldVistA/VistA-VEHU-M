^XMB(3.9,145984,2,2038,0)=" I $G(MBMSITE),DFN D"
^XMB(3.9,145984,2,2039,0)="""RTN"",""PSOERXI1"",171,0)"
^XMB(3.9,145984,2,2040,0)=" . I "",N,I,W,RXI,RXN,RXW,RXR,CXI,CXN,CXW,""'[("",""_$$GET1^DIQ(52.49,CURREC,1,""I"")_"","") Q"
^XMB(3.9,145984,2,2041,0)="""RTN"",""PSOERXI1"",172,0)"
^XMB(3.9,145984,2,2042,0)=" . I '$$CHVAELIG^PSOERXU9(DFN) D  Q"
^XMB(3.9,145984,2,2043,0)="""RTN"",""PSOERXI1"",173,0)"
^XMB(3.9,145984,2,2044,0)=" . . D UPDSTAT^PSOERXU1(CURREC,""HEL"",""Hold due to Eligibility Issue"")"
^XMB(3.9,145984,2,2045,0)="""RTN"",""PSOERXI1"",174,0)"
^XMB(3.9,145984,2,2046,0)=" . N GMRA,GMRAL"
^XMB(3.9,145984,2,2047,0)="""RTN"",""PSOERXI1"",175,0)"
