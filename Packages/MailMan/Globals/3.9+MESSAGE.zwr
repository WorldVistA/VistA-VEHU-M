^XMB(3.9,145984,2,1972,0)=" I $G(PACHK(""MVIerror""))']"""" D"
^XMB(3.9,145984,2,1973,0)="""RTN"",""PSOERXI1"",138,0)"
^XMB(3.9,145984,2,1974,0)=" . S PAICN=+$P($G(PACHK(""ICN"")),""V"")"
^XMB(3.9,145984,2,1975,0)="""RTN"",""PSOERXI1"",139,0)"
^XMB(3.9,145984,2,1976,0)=" . I PAICN D"
