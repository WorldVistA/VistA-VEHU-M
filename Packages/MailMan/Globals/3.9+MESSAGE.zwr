^XMB(3.9,145986,2,2169,0)="""RTN"",""FBCHVH"",139,0)"
^XMB(3.9,145986,2,2170,0)=" S DIR(0)=""E"" D ^DIR"
^XMB(3.9,145986,2,2171,0)="""RTN"",""FBCHVH"",140,0)"
^XMB(3.9,145986,2,2172,0)=" Q"
^XMB(3.9,145986,2,2173,0)="""RTN"",""FBCNHCEN"")"
^XMB(3.9,145986,2,2174,0)="0^17^B16649136"
^XMB(3.9,145986,2,2175,0)="""RTN"",""FBCNHCEN"",1,0)"
^XMB(3.9,145986,2,2176,0)="FBCNHCEN ;AISC/CMR-CNH/CH CENSUS DATA ;1/13/98"
^XMB(3.9,145986,2,2177,0)="""RTN"",""FBCNHCEN"",2,0)"
^XMB(3.9,145986,2,2178,0)=" ;;3.5;FEE BASIS;**12**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2179,0)="""RTN"",""FBCNHCEN"",3,0)"
^XMB(3.9,145986,2,2180,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,2181,0)="""RTN"",""FBCNHCEN"",4,0)"
^XMB(3.9,145986,2,2182,0)=" ;FBI is set in option entry action, 6=CH, 7=CNH"
^XMB(3.9,145986,2,2183,0)="""RTN"",""FBCNHCEN"",5,0)"
^XMB(3.9,145986,2,2184,0)=" I $G(FBI)'=6&($G(FBI)'=7) W ""Inpatient type is not identified."" Q"
^XMB(3.9,145986,2,2185,0)="""RTN"",""FBCNHCEN"",6,0)"
^XMB(3.9,145986,2,2186,0)=" W !!,""****CENSUS DATE SELECTION****"""
^XMB(3.9,145986,2,2187,0)="""RTN"",""FBCNHCEN"",7,0)"
^XMB(3.9,145986,2,2188,0)=" W ! S %DT=""APEX"",%DT(""A"")=""   Census DATE:  "" D ^%DT G END:Y<0  S FBDT=Y K %DT"
^XMB(3.9,145986,2,2189,0)="""RTN"",""FBCNHCEN"",8,0)"
^XMB(3.9,145986,2,2190,0)=" W ! S DIR(0)=""Y"",DIR(""A"")=""Display Address for Vendors"",DIR(""B"")=""No"" D ^DIR K DIR Q:$D(DIRUT)  S FBADDCK=Y"
^XMB(3.9,145986,2,2191,0)="""RTN"",""FBCNHCEN"",9,0)"
^XMB(3.9,145986,2,2192,0)=" S VAR=""FBDT^FBI^FBADDCK"",VAL=FBDT_""^""_FBI_""^""_FBADDCK,PGM=""START^FBCNHCEN"" D ZIS^FBAAUTL G END:FBPOP"
^XMB(3.9,145986,2,2193,0)="""RTN"",""FBCNHCEN"",10,0)"
^XMB(3.9,145986,2,2194,0)="START S Q=""="",$P(Q,""="",80)=""="",QQ=""-"",$P(QQ,""-"",38)=""-"",FBAAOUT=0 K ^TMP($J) U IO W:$E(IOST,1,2)[""C-"" @IOF D HED"
^XMB(3.9,145986,2,2195,0)="""RTN"",""FBCNHCEN"",11,0)"
^XMB(3.9,145986,2,2196,0)=" S FBK=0,FBJ=(FBDT-.1) F  S FBJ=$O(^FB7078(""AD"",FBI,FBJ)) Q:FBJ'>0  F  S FBK=$O(^FB7078(""AD"",FBI,FBJ,FBK)) Q:FBK'>0  D"
^XMB(3.9,145986,2,2197,0)="""RTN"",""FBCNHCEN"",12,0)"
^XMB(3.9,145986,2,2198,0)=" .S FBAFDT=$P(^FB7078(FBK,0),""^"",4) I FBAFDT'>FBDT S FB7078=^(0) Q:$P(FB7078,U,9)=""DC""  D GOT"
^XMB(3.9,145986,2,2199,0)="""RTN"",""FBCNHCEN"",13,0)"
^XMB(3.9,145986,2,2200,0)=" S (FBL,FBK)=0 F  S FBL=$O(^FB7078(""AC"",""I"",FBL)) Q:FBL'>0  F  S FBK=$O(^FB7078(""AC"",""I"",FBL,FBK)) Q:FBK'>0  D"
^XMB(3.9,145986,2,2201,0)="""RTN"",""FBCNHCEN"",14,0)"
^XMB(3.9,145986,2,2202,0)=" .S FBAFDT=$P(^FB7078(FBK,0),""^"",4),FBJ=$P(^FB7078(FBK,0),""^"",5) I FBAFDT'>FBDT,(FBJ'<FBDT),($P(^(0),""^"",11)=FBI) S FB7078=^(0) Q:$P(FB7078,U,9)=""DC""  D GOT"
^XMB(3.9,145986,2,2203,0)="""RTN"",""FBCNHCEN"",15,0)"
^XMB(3.9,145986,2,2204,0)=" S FBVNAME="""",FBVIEN=0"
^XMB(3.9,145986,2,2205,0)="""RTN"",""FBCNHCEN"",16,0)"
^XMB(3.9,145986,2,2206,0)=" F  S FBVNAME=$O(^TMP($J,""FBCEN"",FBVNAME)) Q:FBVNAME=""""!(FBAAOUT)  F  S FBVIEN=$O(^TMP($J,""FBCEN"",FBVNAME,FBVIEN)) Q:'FBVIEN  S FBNAME=0 D HED1 Q:FBAAOUT  F  S FBNAME=$O(^TMP($J,""FBCEN"",FBVNAME,FBVIEN,FBNAME)) Q:FBNAME=""""!(FBAAOUT)  D"
^XMB(3.9,145986,2,2207,0)="""RTN"",""FBCNHCEN"",17,0)"
^XMB(3.9,145986,2,2208,0)=" .S DFN=0 F  S DFN=$O(^TMP($J,""FBCEN"",FBVNAME,FBVIEN,FBNAME,DFN)) Q:'DFN  S FB7078=^TMP($J,""FBCEN"",FBVNAME,FBVIEN,FBNAME,DFN),FBDOB=+FB7078,FBAFD=$P(FB7078,""^"",2),FBPSA=$P(FB7078,""^"",3) D PRINT"
^XMB(3.9,145986,2,2209,0)="""RTN"",""FBCNHCEN"",18,0)"
^XMB(3.9,145986,2,2210,0)="END K FBDT,Q,QQ,FBAAOUT,FBI,FBJ,FBK,FBVNAME,FBNAME,FB7078,DFN,FBDOB,FBAFD,FBZ,^TMP($J,""FBCEN""),FBPSA,JJ,X,Y,FBOUT,FBL,FBAFDT,FBACT,FBCKDT,FBIEN,FBREC,FBTRAN,FBTRDT,FBTRTYP,FBOUT,FBADDCK"
^XMB(3.9,145986,2,2211,0)="""RTN"",""FBCNHCEN"",19,0)"
^XMB(3.9,145986,2,2212,0)=" D CLOSE^FBAAUTL Q"
^XMB(3.9,145986,2,2213,0)="""RTN"",""FBCNHCEN"",20,0)"
^XMB(3.9,145986,2,2214,0)="GOT S DFN=$P(FB7078,""^"",3),FBZ=$P(FB7078,""^"",2) Q:$P(FBZ,"";"",2)'=""FBAAV("""
^XMB(3.9,145986,2,2215,0)="""RTN"",""FBCNHCEN"",21,0)"
^XMB(3.9,145986,2,2216,0)=" I FBI=7 K FBOUT S FBCKDT=FBAFDT D ASIH Q:$G(FBOUT)"
^XMB(3.9,145986,2,2217,0)="""RTN"",""FBCNHCEN"",22,0)"
^XMB(3.9,145986,2,2218,0)=" S FBNAME=$$NAME^FBCHREQ2(DFN),FBDOB=$P(^DPT(DFN,0),""^"",3),FBAFD=$P(FB7078,""^"",4)"
^XMB(3.9,145986,2,2219,0)="""RTN"",""FBCNHCEN"",23,0)"
^XMB(3.9,145986,2,2220,0)=" S FBVNAME=$P($G(^FBAAV(+FBZ,0)),""^"") Q:FBVNAME=""""  S FBVNAME=$E(FBVNAME,1,23)"
^XMB(3.9,145986,2,2221,0)="""RTN"",""FBCNHCEN"",24,0)"
^XMB(3.9,145986,2,2222,0)=" S JJ=0,FBPSA="""",JJ=$O(^FBAAA(""AG"",FBK_"";FB7078("",DFN,JJ)) I JJ S FBPSA=$P($G(^FBAAA(DFN,1,JJ,0)),""^"",5)"
^XMB(3.9,145986,2,2223,0)="""RTN"",""FBCNHCEN"",25,0)"
^XMB(3.9,145986,2,2224,0)=" S ^TMP($J,""FBCEN"",FBVNAME,+FBZ)="""",^TMP($J,""FBCEN"",FBVNAME,+FBZ,FBNAME,DFN)=FBDOB_""^""_FBAFD_""^""_FBPSA_""^""_FBK"
^XMB(3.9,145986,2,2225,0)="""RTN"",""FBCNHCEN"",26,0)"
^XMB(3.9,145986,2,2226,0)=" Q"
^XMB(3.9,145986,2,2227,0)="""RTN"",""FBCNHCEN"",27,0)"
^XMB(3.9,145986,2,2228,0)="PRINT I $Y+3>IOSL,($E(IOST,1,2)[""C-"") S DIR(0)=""E"" D ^DIR K DIR I 'Y S FBAAOUT=1 Q"
^XMB(3.9,145986,2,2229,0)="""RTN"",""FBCNHCEN"",28,0)"
^XMB(3.9,145986,2,2230,0)=" I $Y+3>IOSL W @IOF D HED,HED1"
^XMB(3.9,145986,2,2231,0)="""RTN"",""FBCNHCEN"",29,0)"
^XMB(3.9,145986,2,2232,0)=" W !?4,FBNAME,?32,$$FMTE^XLFDT(FBDOB),?46,$$SSN^FBAAUTL(DFN),?60,$$PSA^FBAAUTL5(FBPSA),?67,$$FMTE^XLFDT(FBAFD)"
^XMB(3.9,145986,2,2233,0)="""RTN"",""FBCNHCEN"",30,0)"
^XMB(3.9,145986,2,2234,0)=" Q"
^XMB(3.9,145986,2,2235,0)="""RTN"",""FBCNHCEN"",31,0)"
^XMB(3.9,145986,2,2236,0)="HED W !?20,""FEE BASIS "",$S(FBI=6:""CIVIL HOSPITAL"",FBI=7:""CONTRACT NURSING HOME"",1:""UNKNOWN""),"" CENSUS"",!?31,$$FMTE^XLFDT(FBDT),!?20,$S(FBI=6:$E(QQ,1,31),1:QQ)"
^XMB(3.9,145986,2,2237,0)="""RTN"",""FBCNHCEN"",32,0)"
^XMB(3.9,145986,2,2238,0)=" W !!,""VENDOR NAME"",?40,""VENDOR ID"",!?4,""VETERAN NAME"",?36,""DOB"",?46,""VETERAN ID"",?60,""PSA"",?67,""AUTH FROM"",!,Q"
^XMB(3.9,145986,2,2239,0)="""RTN"",""FBCNHCEN"",33,0)"
^XMB(3.9,145986,2,2240,0)=" Q"
^XMB(3.9,145986,2,2241,0)="""RTN"",""FBCNHCEN"",34,0)"
^XMB(3.9,145986,2,2242,0)="HED1 I $Y+8>IOSL,($E(IOST,1,2)[""C-"") S DIR(0)=""E"" D ^DIR I 'Y S FBAAOUT=1 Q"
^XMB(3.9,145986,2,2243,0)="""RTN"",""FBCNHCEN"",35,0)"
^XMB(3.9,145986,2,2244,0)=" I $Y+8>IOSL W @IOF D HED"
^XMB(3.9,145986,2,2245,0)="""RTN"",""FBCNHCEN"",36,0)"
^XMB(3.9,145986,2,2246,0)=" W !!!,FBVNAME I FBADDCK S Y=FBVIEN D ^FBVDISP Q"
^XMB(3.9,145986,2,2247,0)="""RTN"",""FBCNHCEN"",37,0)"
^XMB(3.9,145986,2,2248,0)=" W ?40,$$VID^FBNHEXP(FBVIEN) Q"
^XMB(3.9,145986,2,2249,0)="""RTN"",""FBCNHCEN"",38,0)"
^XMB(3.9,145986,2,2250,0)="ASIH ;Checks to see if vet has been transferred ASIH on specified date."
^XMB(3.9,145986,2,2251,0)="""RTN"",""FBCNHCEN"",39,0)"
^XMB(3.9,145986,2,2252,0)=" S FBACT=$O(^FBAACNH(""AG"",DFN,+FBZ,FBCKDT)) I 'FBACT!(FBACT>FBJ) S FBOUT=1 Q"
^XMB(3.9,145986,2,2253,0)="""RTN"",""FBCNHCEN"",40,0)"
^XMB(3.9,145986,2,2254,0)=" S FBIEN=$O(^FBAACNH(""AG"",DFN,+FBZ,FBACT,0)) I 'FBIEN S FBOUT=1 Q"
^XMB(3.9,145986,2,2255,0)="""RTN"",""FBCNHCEN"",41,0)"
^XMB(3.9,145986,2,2256,0)=" I $P(^FBAACNH(FBIEN,0),""^"",3)'=""A"" S FBCKDT=FBACT G ASIH"
^XMB(3.9,145986,2,2257,0)="""RTN"",""FBCNHCEN"",42,0)"
^XMB(3.9,145986,2,2258,0)=" S FBTRAN=FBIEN F  S FBTRAN=$O(^FBAACNH(""AC"",FBIEN,FBTRAN)) Q:FBTRAN=""""  Q:($P(^FBAACNH(FBTRAN,0),""^"",3)=""D"")  D"
^XMB(3.9,145986,2,2259,0)="""RTN"",""FBCNHCEN"",43,0)"
^XMB(3.9,145986,2,2260,0)=" .S FBREC=$G(^FBAACNH(FBTRAN,0)),FBTRTYP=$P(FBREC,""^"",7) Q:'FBTRTYP  S FBTRDT=+FBREC"
^XMB(3.9,145986,2,2261,0)="""RTN"",""FBCNHCEN"",44,0)"
^XMB(3.9,145986,2,2262,0)=" .I FBTRTYP<4,($P(FBTRDT,""."")=FBDT) S FBOUT=1"
^XMB(3.9,145986,2,2263,0)="""RTN"",""FBCNHCEN"",45,0)"
^XMB(3.9,145986,2,2264,0)=" .I FBTRTYP<4 I FBTRDT'>FBDT S FBOUT=1"
^XMB(3.9,145986,2,2265,0)="""RTN"",""FBCNHCEN"",46,0)"
^XMB(3.9,145986,2,2266,0)=" .I FBTRTYP>3 I FBTRDT'>(FBDT+.99) K FBOUT"
^XMB(3.9,145986,2,2267,0)="""RTN"",""FBLTCAR2"")"
^XMB(3.9,145986,2,2268,0)="0^19^B56991072"
^XMB(3.9,145986,2,2269,0)="""RTN"",""FBLTCAR2"",1,0)"
^XMB(3.9,145986,2,2270,0)="FBLTCAR2 ;WOIFO/SS-LTC AUTHORIZATIONS REPORTS ;11/20/02"
^XMB(3.9,145986,2,2271,0)="""RTN"",""FBLTCAR2"",2,0)"
^XMB(3.9,145986,2,2272,0)=" ;;3.5;FEE BASIS;**49**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2273,0)="""RTN"",""FBLTCAR2"",3,0)"
^XMB(3.9,145986,2,2274,0)=" ;"
^XMB(3.9,145986,2,2275,0)="""RTN"",""FBLTCAR2"",4,0)"
^XMB(3.9,145986,2,2276,0)="EN ;ask program"
^XMB(3.9,145986,2,2277,0)="""RTN"",""FBLTCAR2"",5,0)"
^XMB(3.9,145986,2,2278,0)=" N FBLTCAR"
^XMB(3.9,145986,2,2279,0)="""RTN"",""FBLTCAR2"",6,0)"
^XMB(3.9,145986,2,2280,0)=" S DIC(""B"")=$S(FBLTCPR=""CONTRACT NURSING HOME"":FBLTCPR,1:""OUTPATIENT"")"
^XMB(3.9,145986,2,2281,0)="""RTN"",""FBLTCAR2"",7,0)"
^XMB(3.9,145986,2,2282,0)=" S DIC=""^FBAA(161.8,"",DIC(0)=""AQEM"",DIC(""S"")=""S FBLTCAR=$P(^(0),U,1) I FBLTCAR=""""OUTPATIENT""""!(FBLTCAR=""""CONTRACT NURSING HOME"""")"""
^XMB(3.9,145986,2,2283,0)="""RTN"",""FBLTCAR2"",8,0)"
^XMB(3.9,145986,2,2284,0)=" D ^DIC K DIC I Y'>0 G EXIT"
^XMB(3.9,145986,2,2285,0)="""RTN"",""FBLTCAR2"",9,0)"
^XMB(3.9,145986,2,2286,0)=" S FBPROG=+Y"
^XMB(3.9,145986,2,2287,0)="""RTN"",""FBLTCAR2"",10,0)"
^XMB(3.9,145986,2,2288,0)=" ;"
^XMB(3.9,145986,2,2289,0)="""RTN"",""FBLTCAR2"",11,0)"
^XMB(3.9,145986,2,2290,0)=" ; ask purpose of visit(s)"
^XMB(3.9,145986,2,2291,0)="""RTN"",""FBLTCAR2"",12,0)"
^XMB(3.9,145986,2,2292,0)=" S DIR(0)=""Y"",DIR(""A"")=""For ALL LTC Purpose of Visits? Y/N"",DIR(""B"")=""YES"""
^XMB(3.9,145986,2,2293,0)="""RTN"",""FBLTCAR2"",13,0)"
^XMB(3.9,145986,2,2294,0)=" D ^DIR K DIR G:$D(DIRUT) EXIT"
^XMB(3.9,145986,2,2295,0)="""RTN"",""FBLTCAR2"",14,0)"
^XMB(3.9,145986,2,2296,0)=" S FBPOV=Y"
^XMB(3.9,145986,2,2297,0)="""RTN"",""FBLTCAR2"",15,0)"
^XMB(3.9,145986,2,2298,0)=" I 'FBPOV D  G:'$D(FBPOV) EXIT S FBPOV=0"
^XMB(3.9,145986,2,2299,0)="""RTN"",""FBLTCAR2"",16,0)"
^XMB(3.9,145986,2,2300,0)=" . K FBPOV"
^XMB(3.9,145986,2,2301,0)="""RTN"",""FBLTCAR2"",17,0)"
^XMB(3.9,145986,2,2302,0)=" . W !,""Select one or more LTC Purpose of Visits"""
^XMB(3.9,145986,2,2303,0)="""RTN"",""FBLTCAR2"",18,0)"
^XMB(3.9,145986,2,2304,0)=" . S DIC=""^FBAA(161.82,"",DIC(0)=""AQEM"",DIC(""S"")=""I $P(^(0),U,2)=FBPROG&(+$P(^(0),U,4)>0)"""
^XMB(3.9,145986,2,2305,0)="""RTN"",""FBLTCAR2"",19,0)"
^XMB(3.9,145986,2,2306,0)=" . F  D  Q:Y'>0"
^XMB(3.9,145986,2,2307,0)="""RTN"",""FBLTCAR2"",20,0)"
^XMB(3.9,145986,2,2308,0)=" . . D ^DIC I Y>0 S FBPOV(+Y)=$P(Y,U,2)"
^XMB(3.9,145986,2,2309,0)="""RTN"",""FBLTCAR2"",21,0)"
^XMB(3.9,145986,2,2310,0)=" . K DIC"
^XMB(3.9,145986,2,2311,0)="""RTN"",""FBLTCAR2"",22,0)"
^XMB(3.9,145986,2,2312,0)=" ;"
^XMB(3.9,145986,2,2313,0)="""RTN"",""FBLTCAR2"",23,0)"
^XMB(3.9,145986,2,2314,0)=" ; ask dates"
^XMB(3.9,145986,2,2315,0)="""RTN"",""FBLTCAR2"",24,0)"
^XMB(3.9,145986,2,2316,0)=" S DIR(0)=""D^::EX"",DIR(""A"")=""From Date"""
^XMB(3.9,145986,2,2317,0)="""RTN"",""FBLTCAR2"",25,0)"
^XMB(3.9,145986,2,2318,0)=" ;   default from date is first day of previous month"
^XMB(3.9,145986,2,2319,0)="""RTN"",""FBLTCAR2"",26,0)"
^XMB(3.9,145986,2,2320,0)=" S DIR(""B"")=$$FMTE^XLFDT($E($$FMADD^XLFDT($E(DT,1,5)_""01"",-1),1,5)_""01"")"
^XMB(3.9,145986,2,2321,0)="""RTN"",""FBLTCAR2"",27,0)"
^XMB(3.9,145986,2,2322,0)=" D ^DIR K DIR G:$D(DIRUT) EXIT"
^XMB(3.9,145986,2,2323,0)="""RTN"",""FBLTCAR2"",28,0)"
^XMB(3.9,145986,2,2324,0)=" S FBDT1=Y"
^XMB(3.9,145986,2,2325,0)="""RTN"",""FBLTCAR2"",29,0)"
^XMB(3.9,145986,2,2326,0)=" S DIR(0)=""DA^""_FBDT1_""::EX"",DIR(""A"")=""To Date: """
^XMB(3.9,145986,2,2327,0)="""RTN"",""FBLTCAR2"",30,0)"
^XMB(3.9,145986,2,2328,0)=" ;   default to date is last day of specified month"
^XMB(3.9,145986,2,2329,0)="""RTN"",""FBLTCAR2"",31,0)"
^XMB(3.9,145986,2,2330,0)=" S X=FBDT1 D DAYS^FBAAUTL1"
^XMB(3.9,145986,2,2331,0)="""RTN"",""FBLTCAR2"",32,0)"
^XMB(3.9,145986,2,2332,0)=" S DIR(""B"")=$$FMTE^XLFDT($E(FBDT1,1,5)_X)"
^XMB(3.9,145986,2,2333,0)="""RTN"",""FBLTCAR2"",33,0)"
^XMB(3.9,145986,2,2334,0)=" D ^DIR K DIR G:$D(DIRUT) EXIT"
^XMB(3.9,145986,2,2335,0)="""RTN"",""FBLTCAR2"",34,0)"
^XMB(3.9,145986,2,2336,0)=" S FBDT2=Y"
^XMB(3.9,145986,2,2337,0)="""RTN"",""FBLTCAR2"",35,0)"
^XMB(3.9,145986,2,2338,0)=" ;"
^XMB(3.9,145986,2,2339,0)="""RTN"",""FBLTCAR2"",36,0)"
^XMB(3.9,145986,2,2340,0)=" ; ask if remarks should be printed"
^XMB(3.9,145986,2,2341,0)="""RTN"",""FBLTCAR2"",37,0)"
^XMB(3.9,145986,2,2342,0)=" S DIR(0)=""Y"",DIR(""A"")=""Print authorization remarks"",DIR(""B"")=""NO"""
^XMB(3.9,145986,2,2343,0)="""RTN"",""FBLTCAR2"",38,0)"
^XMB(3.9,145986,2,2344,0)=" D ^DIR K DIR G:$D(DIRUT) EXIT"
^XMB(3.9,145986,2,2345,0)="""RTN"",""FBLTCAR2"",39,0)"
^XMB(3.9,145986,2,2346,0)=" S FBAR=Y"
^XMB(3.9,145986,2,2347,0)="""RTN"",""FBLTCAR2"",40,0)"
^XMB(3.9,145986,2,2348,0)=" ;"
^XMB(3.9,145986,2,2349,0)="""RTN"",""FBLTCAR2"",41,0)"
^XMB(3.9,145986,2,2350,0)=" ; ask device"
^XMB(3.9,145986,2,2351,0)="""RTN"",""FBLTCAR2"",42,0)"
^XMB(3.9,145986,2,2352,0)=" S %ZIS=""QM"" D ^%ZIS G:POP EXIT"
^XMB(3.9,145986,2,2353,0)="""RTN"",""FBLTCAR2"",43,0)"
^XMB(3.9,145986,2,2354,0)=" I $D(IO(""Q"")) D  G EXIT"
^XMB(3.9,145986,2,2355,0)="""RTN"",""FBLTCAR2"",44,0)"
^XMB(3.9,145986,2,2356,0)=" . S ZTRTN=""QEN^FBLTCAR2"",ZTDESC=""LTC Authorizations Report"""
^XMB(3.9,145986,2,2357,0)="""RTN"",""FBLTCAR2"",45,0)"
^XMB(3.9,145986,2,2358,0)=" . F FBX=""FBLTCRT"",""FBPROG"",""FBPOV*"",""FBDT*"",""FBAR"" S ZTSAVE(FBX)="""""
^XMB(3.9,145986,2,2359,0)="""RTN"",""FBLTCAR2"",46,0)"
^XMB(3.9,145986,2,2360,0)=" . D ^%ZTLOAD,HOME^%ZIS K ZTSK,ZTDESC,ZTREQ,ZTRTN,ZTSAVE,ZTSTOP,ZTQUEUED"
^XMB(3.9,145986,2,2361,0)="""RTN"",""FBLTCAR2"",47,0)"
^XMB(3.9,145986,2,2362,0)=" ;"
^XMB(3.9,145986,2,2363,0)="""RTN"",""FBLTCAR2"",48,0)"
^XMB(3.9,145986,2,2364,0)="QEN ; queued entry"
^XMB(3.9,145986,2,2365,0)="""RTN"",""FBLTCAR2"",49,0)"
^XMB(3.9,145986,2,2366,0)=" U IO"
^XMB(3.9,145986,2,2367,0)="""RTN"",""FBLTCAR2"",50,0)"
^XMB(3.9,145986,2,2368,0)=" ;"
^XMB(3.9,145986,2,2369,0)="""RTN"",""FBLTCAR2"",51,0)"
^XMB(3.9,145986,2,2370,0)="GATHER ; collect and sort data"
^XMB(3.9,145986,2,2371,0)="""RTN"",""FBLTCAR2"",52,0)"
^XMB(3.9,145986,2,2372,0)=" N FBVN"
^XMB(3.9,145986,2,2373,0)="""RTN"",""FBLTCAR2"",53,0)"
^XMB(3.9,145986,2,2374,0)=" K ^TMP($J)"
^XMB(3.9,145986,2,2375,0)="""RTN"",""FBLTCAR2"",54,0)"
^XMB(3.9,145986,2,2376,0)=" ; loop thru Fee Basis Patients"
^XMB(3.9,145986,2,2377,0)="""RTN"",""FBLTCAR2"",55,0)"
^XMB(3.9,145986,2,2378,0)=" S FBDFN=0 F  S FBDFN=$O(^FBAAA(FBDFN)) Q:'FBDFN  D"
^XMB(3.9,145986,2,2379,0)="""RTN"",""FBLTCAR2"",56,0)"
^XMB(3.9,145986,2,2380,0)=" . S FBPNAME=$$GET1^DIQ(161,FBDFN,.01)"
^XMB(3.9,145986,2,2381,0)="""RTN"",""FBLTCAR2"",57,0)"
^XMB(3.9,145986,2,2382,0)=" . S:FBPNAME="""" FBPNAME=""UNKNOWN"""
^XMB(3.9,145986,2,2383,0)="""RTN"",""FBLTCAR2"",58,0)"
^XMB(3.9,145986,2,2384,0)=" . ; loop thru authorizations"
^XMB(3.9,145986,2,2385,0)="""RTN"",""FBLTCAR2"",59,0)"
^XMB(3.9,145986,2,2386,0)=" . S FBAU=0 F  S FBAU=$O(^FBAAA(FBDFN,1,FBAU)) Q:'FBAU  D"
^XMB(3.9,145986,2,2387,0)="""RTN"",""FBLTCAR2"",60,0)"
^XMB(3.9,145986,2,2388,0)=" . . S FBA=$G(^FBAAA(FBDFN,1,FBAU,0))"
^XMB(3.9,145986,2,2389,0)="""RTN"",""FBLTCAR2"",61,0)"
^XMB(3.9,145986,2,2390,0)=" . . Q:$P(FBA,U,3)'=FBPROG  ; not program"
^XMB(3.9,145986,2,2391,0)="""RTN"",""FBLTCAR2"",62,0)"
^XMB(3.9,145986,2,2392,0)=" . . Q:$P($G(^FBAAA(FBDFN,1,FBAU,""ADEL"")),U)  ; austin deleted"
^XMB(3.9,145986,2,2393,0)="""RTN"",""FBLTCAR2"",63,0)"
^XMB(3.9,145986,2,2394,0)=" . . Q:$P(FBA,U,7)=""""  ; blank purpose of visit"
^XMB(3.9,145986,2,2395,0)="""RTN"",""FBLTCAR2"",64,0)"
^XMB(3.9,145986,2,2396,0)=" . . I 'FBPOV Q:'$D(FBPOV($P(FBA,U,7)))  ; not selected POV"
^XMB(3.9,145986,2,2397,0)="""RTN"",""FBLTCAR2"",65,0)"
^XMB(3.9,145986,2,2398,0)=" . . Q:+$P($G(^FBAA(161.82,+$P(FBA,U,7),0)),U,4)=0  ;non-LTC"
^XMB(3.9,145986,2,2399,0)="""RTN"",""FBLTCAR2"",66,0)"
^XMB(3.9,145986,2,2400,0)=" . . ; ensure authorization is not outside the period of interest"
^XMB(3.9,145986,2,2401,0)="""RTN"",""FBLTCAR2"",67,0)"
^XMB(3.9,145986,2,2402,0)=" . . I +$G(FBLTCRT)=0 Q  ;FBLTCRT should be defined"
^XMB(3.9,145986,2,2403,0)="""RTN"",""FBLTCAR2"",68,0)"
^XMB(3.9,145986,2,2404,0)=" . . I +$G(FBLTCRT)>0 Q:$$LTCRPT^FBLTCAR($P(FBA,U),$P(FBA,U,2),FBDT1,FBDT2,+$G(FBLTCRT))  ;for LTC reports FBLTCRT is difined in ^FBLTCAR"
^XMB(3.9,145986,2,2405,0)="""RTN"",""FBLTCAR2"",69,0)"
^XMB(3.9,145986,2,2406,0)=" . . ; passed all criteria"
^XMB(3.9,145986,2,2407,0)="""RTN"",""FBLTCAR2"",70,0)"
^XMB(3.9,145986,2,2408,0)=" . . S FBVN=$S($P(FBA,U,4):$P($G(^FBAAV($P(FBA,U,4),0)),U),1:"""")"
^XMB(3.9,145986,2,2409,0)="""RTN"",""FBLTCAR2"",71,0)"
^XMB(3.9,145986,2,2410,0)=" . . I FBVN="""" S FBVN=""not specified"""
^XMB(3.9,145986,2,2411,0)="""RTN"",""FBLTCAR2"",72,0)"
^XMB(3.9,145986,2,2412,0)=" . . ; sort by purpose of visit,vendor,name^dfn,auth from date^auth ien"
^XMB(3.9,145986,2,2413,0)="""RTN"",""FBLTCAR2"",73,0)"
^XMB(3.9,145986,2,2414,0)=" . . S ^TMP($J,$P(FBA,U,7),FBVN,FBPNAME_U_FBDFN,$P(FBA,U)_U_FBAU)=FBA"
^XMB(3.9,145986,2,2415,0)="""RTN"",""FBLTCAR2"",74,0)"
^XMB(3.9,145986,2,2416,0)=" ;"
^XMB(3.9,145986,2,2417,0)="""RTN"",""FBLTCAR2"",75,0)"
^XMB(3.9,145986,2,2418,0)="PRINT ; report data"
^XMB(3.9,145986,2,2419,0)="""RTN"",""FBLTCAR2"",76,0)"
^XMB(3.9,145986,2,2420,0)=" N FBVN,FBD"
^XMB(3.9,145986,2,2421,0)="""RTN"",""FBLTCAR2"",77,0)"
^XMB(3.9,145986,2,2422,0)=" S (FBQUIT,FBPG)=0 D NOW^%DTC S Y=% D DD^%DT S FBDTR=Y"
^XMB(3.9,145986,2,2423,0)="""RTN"",""FBLTCAR2"",78,0)"
^XMB(3.9,145986,2,2424,0)=" K FBDL S FBDL="""",$P(FBDL,""-"",IOM)="""""
^XMB(3.9,145986,2,2425,0)="""RTN"",""FBLTCAR2"",79,0)"
^XMB(3.9,145986,2,2426,0)=" ;"
^XMB(3.9,145986,2,2427,0)="""RTN"",""FBLTCAR2"",80,0)"
^XMB(3.9,145986,2,2428,0)=" ; build page header text for selection criteria"
^XMB(3.9,145986,2,2429,0)="""RTN"",""FBLTCAR2"",81,0)"
^XMB(3.9,145986,2,2430,0)=" K FBHDT"
^XMB(3.9,145986,2,2431,0)="""RTN"",""FBLTCAR2"",82,0)"
^XMB(3.9,145986,2,2432,0)=" S FBHDT(1)=""  FROM ""_$$FMTE^XLFDT(FBDT1)_"" TO ""_$$FMTE^XLFDT(FBDT2)"
^XMB(3.9,145986,2,2433,0)="""RTN"",""FBLTCAR2"",83,0)"
^XMB(3.9,145986,2,2434,0)=" S FBHDT(1)=FBHDT(1)_""  FOR THE ""_$$GET1^DIQ(161.8,FBPROG,.01)_"" PROGRAM"""
^XMB(3.9,145986,2,2435,0)="""RTN"",""FBLTCAR2"",84,0)"
^XMB(3.9,145986,2,2436,0)=" S FBHDT(2)=""  FOR ""_$S(FBPOV:""ALL "",1:"""")_""PURPOSE OF VISIT(S)"""
^XMB(3.9,145986,2,2437,0)="""RTN"",""FBLTCAR2"",85,0)"
^XMB(3.9,145986,2,2438,0)=" I 'FBPOV D"
^XMB(3.9,145986,2,2439,0)="""RTN"",""FBLTCAR2"",86,0)"
^XMB(3.9,145986,2,2440,0)=" . S FBL=2,FBHDT(FBL)=FBHDT(FBL)_"": """
^XMB(3.9,145986,2,2441,0)="""RTN"",""FBLTCAR2"",87,0)"
^XMB(3.9,145986,2,2442,0)=" . S (FBC,FBI)=0 F  S FBI=$O(FBPOV(FBI)) Q:'FBI  D"
^XMB(3.9,145986,2,2443,0)="""RTN"",""FBLTCAR2"",88,0)"
^XMB(3.9,145986,2,2444,0)=" . . I $L(FBHDT(FBL))+2+$L(FBPOV(FBI))>75 D"
^XMB(3.9,145986,2,2445,0)="""RTN"",""FBLTCAR2"",89,0)"
^XMB(3.9,145986,2,2446,0)=" . . . I FBC S FBHDT(FBL)=FBHDT(FBL)_"","""
^XMB(3.9,145986,2,2447,0)="""RTN"",""FBLTCAR2"",90,0)"
^XMB(3.9,145986,2,2448,0)=" . . . S FBL=FBL+1"
^XMB(3.9,145986,2,2449,0)="""RTN"",""FBLTCAR2"",91,0)"
^XMB(3.9,145986,2,2450,0)=" . . . S FBC=0,FBHDT(FBL)=""    """
^XMB(3.9,145986,2,2451,0)="""RTN"",""FBLTCAR2"",92,0)"
^XMB(3.9,145986,2,2452,0)=" . . S FBHDT(FBL)=FBHDT(FBL)_$S(FBC:"", "",1:"""")_FBPOV(FBI)"
^XMB(3.9,145986,2,2453,0)="""RTN"",""FBLTCAR2"",93,0)"
^XMB(3.9,145986,2,2454,0)=" . . S FBC=FBC+1 ; count of POVs on current line (FBL)"
^XMB(3.9,145986,2,2455,0)="""RTN"",""FBLTCAR2"",94,0)"
^XMB(3.9,145986,2,2456,0)=" ;"
^XMB(3.9,145986,2,2457,0)="""RTN"",""FBLTCAR2"",95,0)"
^XMB(3.9,145986,2,2458,0)=" ; determine if DAYS column should be displayed (true/false)"
^XMB(3.9,145986,2,2459,0)="""RTN"",""FBLTCAR2"",96,0)"
^XMB(3.9,145986,2,2460,0)=" S FBDD=$$GET1^DIQ(161.8,FBPROG,.01)=""STATE HOME"""
^XMB(3.9,145986,2,2461,0)="""RTN"",""FBLTCAR2"",97,0)"
^XMB(3.9,145986,2,2462,0)=" ;"
^XMB(3.9,145986,2,2463,0)="""RTN"",""FBLTCAR2"",98,0)"
^XMB(3.9,145986,2,2464,0)=" D HD"
^XMB(3.9,145986,2,2465,0)="""RTN"",""FBLTCAR2"",99,0)"
^XMB(3.9,145986,2,2466,0)=" I '$D(^TMP($J)) W !,""No authorizations found during period."""
^XMB(3.9,145986,2,2467,0)="""RTN"",""FBLTCAR2"",100,0)"
^XMB(3.9,145986,2,2468,0)=" S FBC(""TOT"")=0 ; initialize count of authorizations on report"
^XMB(3.9,145986,2,2469,0)="""RTN"",""FBLTCAR2"",101,0)"
^XMB(3.9,145986,2,2470,0)=" ; loop thru purpose of visit"
^XMB(3.9,145986,2,2471,0)="""RTN"",""FBLTCAR2"",102,0)"
^XMB(3.9,145986,2,2472,0)=" S FBPOV=0 F  S FBPOV=$O(^TMP($J,FBPOV)) Q:'FBPOV  D  Q:FBQUIT"
^XMB(3.9,145986,2,2473,0)="""RTN"",""FBLTCAR2"",103,0)"
^XMB(3.9,145986,2,2474,0)=" . S FBPOV(""E"")=$$GET1^DIQ(161.82,FBPOV,.01)"
^XMB(3.9,145986,2,2475,0)="""RTN"",""FBLTCAR2"",104,0)"
^XMB(3.9,145986,2,2476,0)=" . I $Y+9>IOSL D HD Q:FBQUIT"
^XMB(3.9,145986,2,2477,0)="""RTN"",""FBLTCAR2"",105,0)"
^XMB(3.9,145986,2,2478,0)=" . W !!,""POV: "",FBPOV(""E"")"
^XMB(3.9,145986,2,2479,0)="""RTN"",""FBLTCAR2"",106,0)"
^XMB(3.9,145986,2,2480,0)=" . S FBC(""POV"")=0 ; initialize count of authorizations for POV"
^XMB(3.9,145986,2,2481,0)="""RTN"",""FBLTCAR2"",107,0)"
^XMB(3.9,145986,2,2482,0)=" . S:FBDD FBD(""POV"")=0 ; initialize count of days for POV"
^XMB(3.9,145986,2,2483,0)="""RTN"",""FBLTCAR2"",108,0)"
^XMB(3.9,145986,2,2484,0)=" . ; loop thru vendors"
^XMB(3.9,145986,2,2485,0)="""RTN"",""FBLTCAR2"",109,0)"
^XMB(3.9,145986,2,2486,0)=" . S FBVN="""" F  S FBVN=$O(^TMP($J,FBPOV,FBVN)) Q:FBVN=""""  D  Q:FBQUIT"
^XMB(3.9,145986,2,2487,0)="""RTN"",""FBLTCAR2"",110,0)"
^XMB(3.9,145986,2,2488,0)=" . . I $Y+7>IOSL D HD Q:FBQUIT  D HDPOV"
^XMB(3.9,145986,2,2489,0)="""RTN"",""FBLTCAR2"",111,0)"
^XMB(3.9,145986,2,2490,0)=" . . W !!,""  Vendor: "",FBVN,!"
^XMB(3.9,145986,2,2491,0)="""RTN"",""FBLTCAR2"",112,0)"
^XMB(3.9,145986,2,2492,0)=" . . S FBC(""VEN"")=0 ; initialize count of auth for vendor (in POV)"
^XMB(3.9,145986,2,2493,0)="""RTN"",""FBLTCAR2"",113,0)"
^XMB(3.9,145986,2,2494,0)=" . . S:FBDD FBD(""VEN"")=0 ; initialize count of days for vendor (in POV)"
^XMB(3.9,145986,2,2495,0)="""RTN"",""FBLTCAR2"",114,0)"
^XMB(3.9,145986,2,2496,0)=" . . ; loop thru veterans"
^XMB(3.9,145986,2,2497,0)="""RTN"",""FBLTCAR2"",115,0)"
^XMB(3.9,145986,2,2498,0)=" . . S FBPAT="""""
^XMB(3.9,145986,2,2499,0)="""RTN"",""FBLTCAR2"",116,0)"
^XMB(3.9,145986,2,2500,0)=" . . F  S FBPAT=$O(^TMP($J,FBPOV,FBVN,FBPAT)) Q:FBPAT=""""  D  Q:FBQUIT"
^XMB(3.9,145986,2,2501,0)="""RTN"",""FBLTCAR2"",117,0)"
^XMB(3.9,145986,2,2502,0)=" . . . S FBPNAME=$P(FBPAT,U)"
^XMB(3.9,145986,2,2503,0)="""RTN"",""FBLTCAR2"",118,0)"
^XMB(3.9,145986,2,2504,0)=" . . . S FBDFN=$P(FBPAT,U,2)"
^XMB(3.9,145986,2,2505,0)="""RTN"",""FBLTCAR2"",119,0)"
^XMB(3.9,145986,2,2506,0)=" . . . D"
^XMB(3.9,145986,2,2507,0)="""RTN"",""FBLTCAR2"",120,0)"
^XMB(3.9,145986,2,2508,0)=" . . . . N DFN S DFN=FBDFN D DEM^VADPT ; obtain patient demographics"
^XMB(3.9,145986,2,2509,0)="""RTN"",""FBLTCAR2"",121,0)"
^XMB(3.9,145986,2,2510,0)=" . . . ; loop thru authorizations"
^XMB(3.9,145986,2,2511,0)="""RTN"",""FBLTCAR2"",122,0)"
^XMB(3.9,145986,2,2512,0)=" . . . S FBAUT="""""
^XMB(3.9,145986,2,2513,0)="""RTN"",""FBLTCAR2"",123,0)"
^XMB(3.9,145986,2,2514,0)=" . . . F  S FBAUT=$O(^TMP($J,FBPOV,FBVN,FBPAT,FBAUT)) Q:FBAUT=""""  D  Q:FBQUIT"
^XMB(3.9,145986,2,2515,0)="""RTN"",""FBLTCAR2"",124,0)"
^XMB(3.9,145986,2,2516,0)=" . . . . S FBDTF=$P(FBAUT,U)"
^XMB(3.9,145986,2,2517,0)="""RTN"",""FBLTCAR2"",125,0)"
^XMB(3.9,145986,2,2518,0)=" . . . . S FBAU=$P(FBAUT,U,2)"
^XMB(3.9,145986,2,2519,0)="""RTN"",""FBLTCAR2"",126,0)"
^XMB(3.9,145986,2,2520,0)=" . . . . S FBA=^TMP($J,FBPOV,FBVN,FBPAT,FBAUT)"
^XMB(3.9,145986,2,2521,0)="""RTN"",""FBLTCAR2"",127,0)"
^XMB(3.9,145986,2,2522,0)=" . . . . S:FBDD FBDAYS=$$DOC^FBSHUTL($P(FBA,U),$P(FBA,U,2),FBDT1,FBDT2)"
^XMB(3.9,145986,2,2523,0)="""RTN"",""FBLTCAR2"",128,0)"
^XMB(3.9,145986,2,2524,0)=" . . . . S FBC(""VEN"")=FBC(""VEN"")+1"
^XMB(3.9,145986,2,2525,0)="""RTN"",""FBLTCAR2"",129,0)"
^XMB(3.9,145986,2,2526,0)=" . . . . S:FBDD FBD(""VEN"")=FBD(""VEN"")+FBDAYS"
^XMB(3.9,145986,2,2527,0)="""RTN"",""FBLTCAR2"",130,0)"
^XMB(3.9,145986,2,2528,0)=" . . . . I $Y+6>IOSL D HD Q:FBQUIT  D HDPOV,HDVEN"
^XMB(3.9,145986,2,2529,0)="""RTN"",""FBLTCAR2"",131,0)"
^XMB(3.9,145986,2,2530,0)=" . . . . W !,?4,FBPNAME,?35,$P(VADM(2),U,2)"
^XMB(3.9,145986,2,2531,0)="""RTN"",""FBLTCAR2"",132,0)"
^XMB(3.9,145986,2,2532,0)=" . . . . W:FBDD ?48,$J(FBDAYS,3)"
^XMB(3.9,145986,2,2533,0)="""RTN"",""FBLTCAR2"",133,0)"
^XMB(3.9,145986,2,2534,0)=" . . . . W ?53,$$FMTE^XLFDT($P(FBA,U)),?67,$$FMTE^XLFDT($P(FBA,U,2))"
^XMB(3.9,145986,2,2535,0)="""RTN"",""FBLTCAR2"",134,0)"
^XMB(3.9,145986,2,2536,0)=" . . . . W !,?6,""DOB: "",$P(VADM(3),U,2)"
^XMB(3.9,145986,2,2537,0)="""RTN"",""FBLTCAR2"",135,0)"
^XMB(3.9,145986,2,2538,0)=" . . . . I +VADM(6) W ?25,""*** Patient Died on "",$P(VADM(6),U,2)"
^XMB(3.9,145986,2,2539,0)="""RTN"",""FBLTCAR2"",136,0)"
^XMB(3.9,145986,2,2540,0)=" . . . . ; print remarks (optional)"
^XMB(3.9,145986,2,2541,0)="""RTN"",""FBLTCAR2"",137,0)"
^XMB(3.9,145986,2,2542,0)=" . . . . I $G(FBAR),$O(^FBAAA(FBDFN,1,FBAU,2,0)) D"
^XMB(3.9,145986,2,2543,0)="""RTN"",""FBLTCAR2"",138,0)"
^XMB(3.9,145986,2,2544,0)=" . . . . . N DIWL,DIWR,DIWF,FBRR"
^XMB(3.9,145986,2,2545,0)="""RTN"",""FBLTCAR2"",139,0)"
^XMB(3.9,145986,2,2546,0)=" . . . . . K ^UTILITY($J,""W"") S DIWL=7,DIWR=(IOM-5),DIWF=""W"""
^XMB(3.9,145986,2,2547,0)="""RTN"",""FBLTCAR2"",140,0)"
^XMB(3.9,145986,2,2548,0)=" . . . . . S X=""REMARKS: "",FBRR=0"
^XMB(3.9,145986,2,2549,0)="""RTN"",""FBLTCAR2"",141,0)"
^XMB(3.9,145986,2,2550,0)=" . . . . . F  S FBRR=$O(^FBAAA(FBDFN,1,FBAU,2,FBRR)) Q:'FBRR  S X=X_^(FBRR,0) D ^DIWP S X="""" I $Y+6>IOSL D HD Q:FBQUIT  D HDPOV,HDVEN,HDPAT"
^XMB(3.9,145986,2,2551,0)="""RTN"",""FBLTCAR2"",142,0)"
^XMB(3.9,145986,2,2552,0)=" . . . . . D:'FBQUIT ^DIWW"
^XMB(3.9,145986,2,2553,0)="""RTN"",""FBLTCAR2"",143,0)"
^XMB(3.9,145986,2,2554,0)=" . . . . ; print additional information for LTC reports"
^XMB(3.9,145986,2,2555,0)="""RTN"",""FBLTCAR2"",144,0)"
^XMB(3.9,145986,2,2556,0)=" . . . . I +$G(FBLTCRT)>0 D PRNVIS^FBLTCAR(+FBDFN,+FBAU,FBVN,+FBDT1,+FBDT2,+$P(FBA,U),+$P(FBA,U,2))"
^XMB(3.9,145986,2,2557,0)="""RTN"",""FBLTCAR2"",145,0)"
^XMB(3.9,145986,2,2558,0)=" . . . D KVA^VADPT ; clean up patient demographics"
^XMB(3.9,145986,2,2559,0)="""RTN"",""FBLTCAR2"",146,0)"
^XMB(3.9,145986,2,2560,0)=" . . Q:FBQUIT"
^XMB(3.9,145986,2,2561,0)="""RTN"",""FBLTCAR2"",147,0)"
^XMB(3.9,145986,2,2562,0)=" . . S FBC(""POV"")=FBC(""POV"")+FBC(""VEN"")"
^XMB(3.9,145986,2,2563,0)="""RTN"",""FBLTCAR2"",148,0)"
^XMB(3.9,145986,2,2564,0)=" . . S:FBDD FBD(""POV"")=FBD(""POV"")+FBD(""VEN"")"
^XMB(3.9,145986,2,2565,0)="""RTN"",""FBLTCAR2"",149,0)"
^XMB(3.9,145986,2,2566,0)=" . . I $Y+5>IOSL D HD Q:FBQUIT  D HDPOV,HDVEN"
^XMB(3.9,145986,2,2567,0)="""RTN"",""FBLTCAR2"",150,0)"
^XMB(3.9,145986,2,2568,0)=" . . W !,?32,""----"""
^XMB(3.9,145986,2,2569,0)="""RTN"",""FBLTCAR2"",151,0)"
^XMB(3.9,145986,2,2570,0)=" . . W:FBDD ?47,""----"""
^XMB(3.9,145986,2,2571,0)="""RTN"",""FBLTCAR2"",152,0)"
^XMB(3.9,145986,2,2572,0)=" . . W !,""  Vendor Subtotal:"",?25,""Count: "",$J(FBC(""VEN""),4)"
^XMB(3.9,145986,2,2573,0)="""RTN"",""FBLTCAR2"",153,0)"
^XMB(3.9,145986,2,2574,0)=" . . W:FBDD ?41,""Days: "",$J(FBD(""VEN""),4)"
^XMB(3.9,145986,2,2575,0)="""RTN"",""FBLTCAR2"",154,0)"
^XMB(3.9,145986,2,2576,0)=" . Q:FBQUIT"
^XMB(3.9,145986,2,2577,0)="""RTN"",""FBLTCAR2"",155,0)"
^XMB(3.9,145986,2,2578,0)=" . S FBC(""TOT"")=FBC(""TOT"")+FBC(""POV"")"
^XMB(3.9,145986,2,2579,0)="""RTN"",""FBLTCAR2"",156,0)"
^XMB(3.9,145986,2,2580,0)=" . I $Y+5>IOSL D HD Q:FBQUIT  D HDPOV"
^XMB(3.9,145986,2,2581,0)="""RTN"",""FBLTCAR2"",157,0)"
^XMB(3.9,145986,2,2582,0)=" . W !,?32,""===="""
^XMB(3.9,145986,2,2583,0)="""RTN"",""FBLTCAR2"",158,0)"
^XMB(3.9,145986,2,2584,0)=" . W:FBDD ?47,""===="""
^XMB(3.9,145986,2,2585,0)="""RTN"",""FBLTCAR2"",159,0)"
^XMB(3.9,145986,2,2586,0)=" . W !,""POV Subtotal: "",?25,""Count: "",$J(FBC(""POV""),4)"
^XMB(3.9,145986,2,2587,0)="""RTN"",""FBLTCAR2"",160,0)"
^XMB(3.9,145986,2,2588,0)=" . W:FBDD ?41,""Days: "",$J(FBD(""POV""),4)"
^XMB(3.9,145986,2,2589,0)="""RTN"",""FBLTCAR2"",161,0)"
^XMB(3.9,145986,2,2590,0)=" ;"
^XMB(3.9,145986,2,2591,0)="""RTN"",""FBLTCAR2"",162,0)"
^XMB(3.9,145986,2,2592,0)=" I FBQUIT W !!,""REPORT STOPPED AT USER REQUEST"""
^XMB(3.9,145986,2,2593,0)="""RTN"",""FBLTCAR2"",163,0)"
^XMB(3.9,145986,2,2594,0)=" E  W !!,FBC(""TOT""),"" Authorization"",$S(FBC(""TOT"")=1:"""",1:""s""),"" on report"""
^XMB(3.9,145986,2,2595,0)="""RTN"",""FBLTCAR2"",164,0)"
^XMB(3.9,145986,2,2596,0)=" I 'FBQUIT,$E(IOST,1,2)=""C-"" S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145986,2,2597,0)="""RTN"",""FBLTCAR2"",165,0)"
^XMB(3.9,145986,2,2598,0)=" D ^%ZISC"
^XMB(3.9,145986,2,2599,0)="""RTN"",""FBLTCAR2"",166,0)"
^XMB(3.9,145986,2,2600,0)=" ;"
^XMB(3.9,145986,2,2601,0)="""RTN"",""FBLTCAR2"",167,0)"
^XMB(3.9,145986,2,2602,0)="EXIT ;"
^XMB(3.9,145986,2,2603,0)="""RTN"",""FBLTCAR2"",168,0)"
^XMB(3.9,145986,2,2604,0)=" I $D(ZTQUEUED) S ZTREQ=""@"""
^XMB(3.9,145986,2,2605,0)="""RTN"",""FBLTCAR2"",169,0)"
^XMB(3.9,145986,2,2606,0)=" K ^TMP($J)"
^XMB(3.9,145986,2,2607,0)="""RTN"",""FBLTCAR2"",170,0)"
^XMB(3.9,145986,2,2608,0)=" K FBA,FBAR,FBAU,FBAUT,FBC,FBDAYS,FBDD,FBDFN,FBDL,FBDT1,FBDT2,FBDTF"
^XMB(3.9,145986,2,2609,0)="""RTN"",""FBLTCAR2"",171,0)"
^XMB(3.9,145986,2,2610,0)=" K FBDTR,FBHDT,FBI,FBL,FBPAT,FBPG,FBPNAME,FBPOV,FBPROG,FBSSN,FBQUIT,FBX"
^XMB(3.9,145986,2,2611,0)="""RTN"",""FBLTCAR2"",172,0)"
^XMB(3.9,145986,2,2612,0)=" K DIC,DIR,DIROUT,DIRUT,DTOUT,DUOUT,X,Y,POP,VADM"
^XMB(3.9,145986,2,2613,0)="""RTN"",""FBLTCAR2"",173,0)"
^XMB(3.9,145986,2,2614,0)=" Q"
^XMB(3.9,145986,2,2615,0)="""RTN"",""FBLTCAR2"",174,0)"
^XMB(3.9,145986,2,2616,0)="HD ; page header"
^XMB(3.9,145986,2,2617,0)="""RTN"",""FBLTCAR2"",175,0)"
^XMB(3.9,145986,2,2618,0)=" I $D(ZTQUEUED),$$S^%ZTLOAD S ZTSTOP=1,FBQUIT=1 Q"
^XMB(3.9,145986,2,2619,0)="""RTN"",""FBLTCAR2"",176,0)"
^XMB(3.9,145986,2,2620,0)=" I $E(IOST,1,2)=""C-"",FBPG S DIR(0)=""E"" D ^DIR K DIR I 'Y S FBQUIT=1 Q"
^XMB(3.9,145986,2,2621,0)="""RTN"",""FBLTCAR2"",177,0)"
^XMB(3.9,145986,2,2622,0)=" I $E(IOST,1,2)=""C-""!FBPG W @IOF"
^XMB(3.9,145986,2,2623,0)="""RTN"",""FBLTCAR2"",178,0)"
^XMB(3.9,145986,2,2624,0)=" S FBPG=FBPG+1"
^XMB(3.9,145986,2,2625,0)="""RTN"",""FBLTCAR2"",179,0)"
^XMB(3.9,145986,2,2626,0)=" W !,$S(FBLTCRT=1:""ENDING "",1:""ACTIVE ""),""AUTHORIZATIONS by POV, Vendor, Patient"""
^XMB(3.9,145986,2,2627,0)="""RTN"",""FBLTCAR2"",180,0)"
^XMB(3.9,145986,2,2628,0)=" W ?49,FBDTR,?72,""page "",FBPG"
^XMB(3.9,145986,2,2629,0)="""RTN"",""FBLTCAR2"",181,0)"
^XMB(3.9,145986,2,2630,0)=" S FBI=0 F  S FBI=$O(FBHDT(FBI)) Q:'FBI  W !,FBHDT(FBI)"
^XMB(3.9,145986,2,2631,0)="""RTN"",""FBLTCAR2"",182,0)"
^XMB(3.9,145986,2,2632,0)=" W !!,?4,""VETERAN"",?35,""Pt. ID"""
^XMB(3.9,145986,2,2633,0)="""RTN"",""FBLTCAR2"",183,0)"
^XMB(3.9,145986,2,2634,0)=" W:FBDD ?47,""DAYS"""
^XMB(3.9,145986,2,2635,0)="""RTN"",""FBLTCAR2"",184,0)"
^XMB(3.9,145986,2,2636,0)=" W ?56,""AUTHORIZATION"""
^XMB(3.9,145986,2,2637,0)="""RTN"",""FBLTCAR2"",185,0)"
^XMB(3.9,145986,2,2638,0)=" W !,?53,""FROM DATE"",?67,""TO DATE"""
^XMB(3.9,145986,2,2639,0)="""RTN"",""FBLTCAR2"",186,0)"
^XMB(3.9,145986,2,2640,0)=" W !,FBDL"
^XMB(3.9,145986,2,2641,0)="""RTN"",""FBLTCAR2"",187,0)"
^XMB(3.9,145986,2,2642,0)=" Q"
^XMB(3.9,145986,2,2643,0)="""RTN"",""FBLTCAR2"",188,0)"
^XMB(3.9,145986,2,2644,0)="HDPOV ; page header for continued POV"
^XMB(3.9,145986,2,2645,0)="""RTN"",""FBLTCAR2"",189,0)"
^XMB(3.9,145986,2,2646,0)=" W !,""POV:"",FBPOV(""E""),"" (continued)"""
^XMB(3.9,145986,2,2647,0)="""RTN"",""FBLTCAR2"",190,0)"
^XMB(3.9,145986,2,2648,0)=" Q"
^XMB(3.9,145986,2,2649,0)="""RTN"",""FBLTCAR2"",191,0)"
^XMB(3.9,145986,2,2650,0)="HDVEN ; page header for continued Vendor"
^XMB(3.9,145986,2,2651,0)="""RTN"",""FBLTCAR2"",192,0)"
^XMB(3.9,145986,2,2652,0)=" W !,""  Vendor: "",FBVN,"" (continued)"""
^XMB(3.9,145986,2,2653,0)="""RTN"",""FBLTCAR2"",193,0)"
^XMB(3.9,145986,2,2654,0)=" Q"
^XMB(3.9,145986,2,2655,0)="""RTN"",""FBLTCAR2"",194,0)"
^XMB(3.9,145986,2,2656,0)="HDPAT ; page header for continued Patient"
^XMB(3.9,145986,2,2657,0)="""RTN"",""FBLTCAR2"",195,0)"
^XMB(3.9,145986,2,2658,0)=" W !,""    Patient: "",FBPNAME,"" (continued)"""
^XMB(3.9,145986,2,2659,0)="""RTN"",""FBLTCAR2"",196,0)"
^XMB(3.9,145986,2,2660,0)=" Q"
^XMB(3.9,145986,2,2661,0)="""RTN"",""FBLTCAR2"",197,0)"
^XMB(3.9,145986,2,2662,0)=" ;"
^XMB(3.9,145986,2,2663,0)="""RTN"",""FBLTCAR2"",198,0)"
^XMB(3.9,145986,2,2664,0)=" ;FBLTCAR2"
^XMB(3.9,145986,2,2665,0)="""RTN"",""FBNHAMI2"")"
^XMB(3.9,145986,2,2666,0)="0^6^B9348107"
^XMB(3.9,145986,2,2667,0)="""RTN"",""FBNHAMI2"",1,0)"
^XMB(3.9,145986,2,2668,0)="FBNHAMI2 ;AISC/CMR-CNH STAYS IN EXCESS OF 90 DAYS ;1DEC00"
^XMB(3.9,145986,2,2669,0)="""RTN"",""FBNHAMI2"",2,0)"
^XMB(3.9,145986,2,2670,0)=" ;;3.5;FEE BASIS;**25**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2671,0)="""RTN"",""FBNHAMI2"",3,0)"
^XMB(3.9,145986,2,2672,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,2673,0)="""RTN"",""FBNHAMI2"",4,0)"
^XMB(3.9,145986,2,2674,0)=" W !!,""Use of this option will provide you with all 'ACTIVE' stays that are in excess"",!,""of 90 days.  The active stays are as of the date you choose."",!"
^XMB(3.9,145986,2,2675,0)="""RTN"",""FBNHAMI2"",5,0)"
^XMB(3.9,145986,2,2676,0)=" S %DT=""APEX"",%DT(""A"")=""Enter Effective Date : "" D ^%DT G END:Y<0 S FBDT=Y"
^XMB(3.9,145986,2,2677,0)="""RTN"",""FBNHAMI2"",6,0)"
^XMB(3.9,145986,2,2678,0)=" S VAR=""FBDT"",VAL=FBDT,PGM=""START^FBNHAMI2"" D ZIS^FBAAUTL G END:FBPOP"
^XMB(3.9,145986,2,2679,0)="""RTN"",""FBNHAMI2"",7,0)"
^XMB(3.9,145986,2,2680,0)="START K ^TMP($J,""FBSTAY"") S FBHD=""="",$P(FBHD,""="",80)=""="",FBUL=""-"",$P(FBUL,""-"",37)=""-"" U IO W:$E(IOST,1,2)[""C-"" @IOF D HED"
^XMB(3.9,145986,2,2681,0)="""RTN"",""FBNHAMI2"",8,0)"
^XMB(3.9,145986,2,2682,0)=" S (FBADM,FBASSOC)=0"
^XMB(3.9,145986,2,2683,0)="""RTN"",""FBNHAMI2"",9,0)"
^XMB(3.9,145986,2,2684,0)=" F  S FBADM=$O(^FBAACNH(""AC"",FBADM)) Q:'FBADM  S FBCHK=0 D  I FBCHK=0 D SET"
^XMB(3.9,145986,2,2685,0)="""RTN"",""FBNHAMI2"",10,0)"
^XMB(3.9,145986,2,2686,0)=" .F  S FBASSOC=$O(^FBAACNH(""AC"",FBADM,FBASSOC)) Q:'FBASSOC  D"
^XMB(3.9,145986,2,2687,0)="""RTN"",""FBNHAMI2"",11,0)"
^XMB(3.9,145986,2,2688,0)=" ..Q:FBADM=FBASSOC"
^XMB(3.9,145986,2,2689,0)="""RTN"",""FBNHAMI2"",12,0)"
^XMB(3.9,145986,2,2690,0)=" ..S FBI=$G(^FBAACNH(FBASSOC,0)),FBTYPE=$P(FBI,""^"",3) Q:FBTYPE'=""D""  S FBDDT=$P(FBI,""^"") I FBDDT'>FBDT S FBCHK=1"
^XMB(3.9,145986,2,2691,0)="""RTN"",""FBNHAMI2"",13,0)"
^XMB(3.9,145986,2,2692,0)=" S FBNAME="""""
^XMB(3.9,145986,2,2693,0)="""RTN"",""FBNHAMI2"",14,0)"
^XMB(3.9,145986,2,2694,0)=" F  S FBNAME=$O(^TMP($J,""FBSTAY"",FBNAME)) Q:FBNAME']""""!($G(FBAAOUT))  S DFN=0 F  S DFN=$O(^TMP($J,""FBSTAY"",FBNAME,DFN)) Q:'DFN!($G(FBAAOUT))  D"
^XMB(3.9,145986,2,2695,0)="""RTN"",""FBNHAMI2"",15,0)"
^XMB(3.9,145986,2,2696,0)=" .S FBI=^TMP($J,""FBSTAY"",FBNAME,DFN),FBID=$P(FBI,""^""),FBADT=$P(FBI,""^"",2),FBVNAME=$P(FBI,""^"",3),FBLOS=$P(FBI,""^"",4) D PRINT"
^XMB(3.9,145986,2,2697,0)="""RTN"",""FBNHAMI2"",16,0)"
^XMB(3.9,145986,2,2698,0)=" G END:$G(FBAAOUT)"
^XMB(3.9,145986,2,2699,0)="""RTN"",""FBNHAMI2"",17,0)"
^XMB(3.9,145986,2,2700,0)=" W !!?5,""***LOS = Length of Stay as of "",$$DATX^FBAAUTL(FBDT)"
^XMB(3.9,145986,2,2701,0)="""RTN"",""FBNHAMI2"",18,0)"
^XMB(3.9,145986,2,2702,0)=" I $E(IOST,1,2)=""C-"" S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145986,2,2703,0)="""RTN"",""FBNHAMI2"",19,0)"
^XMB(3.9,145986,2,2704,0)="END ;"
^XMB(3.9,145986,2,2705,0)="""RTN"",""FBNHAMI2"",20,0)"
^XMB(3.9,145986,2,2706,0)=" K %DT,FBDT,FBAAOUT,DFN,FBNAME,FBID,FBVNAME,FBHD,FBTYPE,FBUL,VAR,VAL,PGM,FBPOP,FBADM,FBASSOC,FBCHK,FBI,FBDDT,FBADT,FBLOS,^TMP($J,""FBSTAY""),FBMS,VA,VADM"
^XMB(3.9,145986,2,2707,0)="""RTN"",""FBNHAMI2"",21,0)"
^XMB(3.9,145986,2,2708,0)=" D CLOSE^FBAAUTL"
^XMB(3.9,145986,2,2709,0)="""RTN"",""FBNHAMI2"",22,0)"
^XMB(3.9,145986,2,2710,0)=" Q"
^XMB(3.9,145986,2,2711,0)="""RTN"",""FBNHAMI2"",23,0)"
^XMB(3.9,145986,2,2712,0)="SET ;SETS UP TMP GLOBAL"
^XMB(3.9,145986,2,2713,0)="""RTN"",""FBNHAMI2"",24,0)"
^XMB(3.9,145986,2,2714,0)=" S FBADT=+^FBAACNH(FBADM,0)"
^XMB(3.9,145986,2,2715,0)="""RTN"",""FBNHAMI2"",25,0)"
^XMB(3.9,145986,2,2716,0)=" S FBLOS=$$DTC^FBUCUTL(FBDT,FBADT)"
^XMB(3.9,145986,2,2717,0)="""RTN"",""FBNHAMI2"",26,0)"
^XMB(3.9,145986,2,2718,0)=" Q:FBLOS<90"
^XMB(3.9,145986,2,2719,0)="""RTN"",""FBNHAMI2"",27,0)"
^XMB(3.9,145986,2,2720,0)=" S FBI=$G(^FBAACNH(FBADM,0)),DFN=$P(FBI,""^"",2) Q:'$G(DFN)  S FBNAME=$$NAME^FBCHREQ2(DFN),FBID=$$SSN^FBAAUTL(DFN),FBVNAME=$P($G(^FBAAV($P(FBI,""^"",9),0)),""^"")"
^XMB(3.9,145986,2,2721,0)="""RTN"",""FBNHAMI2"",28,0)"
^XMB(3.9,145986,2,2722,0)=" S ^TMP($J,""FBSTAY"",FBNAME,DFN)=FBID_""^""_FBADT_""^""_FBVNAME_""^""_FBLOS_""^""_DFN"
^XMB(3.9,145986,2,2723,0)="""RTN"",""FBNHAMI2"",29,0)"
^XMB(3.9,145986,2,2724,0)=" K FBNAME,FBID,FBVNAME,FBLOS,DFN Q"
^XMB(3.9,145986,2,2725,0)="""RTN"",""FBNHAMI2"",30,0)"
^XMB(3.9,145986,2,2726,0)="PRINT ;"
^XMB(3.9,145986,2,2727,0)="""RTN"",""FBNHAMI2"",31,0)"
^XMB(3.9,145986,2,2728,0)=" I $E(IOST,1,2)[""C-"",$Y+2>IOSL S DIR(0)=""E"" D ^DIR K DIR I 'Y S FBAAOUT=1 Q"
^XMB(3.9,145986,2,2729,0)="""RTN"",""FBNHAMI2"",32,0)"
^XMB(3.9,145986,2,2730,0)=" I $Y+2>IOSL W @IOF D HED"
^XMB(3.9,145986,2,2731,0)="""RTN"",""FBNHAMI2"",33,0)"
^XMB(3.9,145986,2,2732,0)=" W !,$E(FBNAME,1,15),?18,FBID"
^XMB(3.9,145986,2,2733,0)="""RTN"",""FBNHAMI2"",34,0)"
^XMB(3.9,145986,2,2734,0)=" D DEM^VADPT S FBMS=$E($P(VADM(10),""^"",2),1) K VA,VADM"
^XMB(3.9,145986,2,2735,0)="""RTN"",""FBNHAMI2"",35,0)"
^XMB(3.9,145986,2,2736,0)=" W ?32,FBMS,?35,$$DATX^FBAAUTL($E(FBADT,1,7)),?45,$J(FBLOS,6),?53,$E(FBVNAME,1,27)"
^XMB(3.9,145986,2,2737,0)="""RTN"",""FBNHAMI2"",36,0)"
^XMB(3.9,145986,2,2738,0)=" Q"
^XMB(3.9,145986,2,2739,0)="""RTN"",""FBNHAMI2"",37,0)"
^XMB(3.9,145986,2,2740,0)="HED ;"
^XMB(3.9,145986,2,2741,0)="""RTN"",""FBNHAMI2"",38,0)"
^XMB(3.9,145986,2,2742,0)=" W !?22,""ACTIVE CNH STAYS IN EXCESS OF 90 DAYS"",!?33,""AS OF "",$$DATX^FBAAUTL(FBDT),!?22,FBUL,!!"
^XMB(3.9,145986,2,2743,0)="""RTN"",""FBNHAMI2"",39,0)"
^XMB(3.9,145986,2,2744,0)=" W ?28,""MARITAL"",!,""VETERAN"",?20,""Pt. ID"",?30,""ST."",?35,""ADM. DATE"",?48,""LOS"",?60,""VENDOR"",!,FBHD"
^XMB(3.9,145986,2,2745,0)="""RTN"",""FBNHAMI2"",40,0)"
^XMB(3.9,145986,2,2746,0)=" Q"
^XMB(3.9,145986,2,2747,0)="""RTN"",""FBNHAMIS"")"
^XMB(3.9,145986,2,2748,0)="0^5^B26677841"
^XMB(3.9,145986,2,2749,0)="""RTN"",""FBNHAMIS"",1,0)"
^XMB(3.9,145986,2,2750,0)="FBNHAMIS ;AISC/GRR-CALCULATE AMIS 349 ;18DEC00"
^XMB(3.9,145986,2,2751,0)="""RTN"",""FBNHAMIS"",2,0)"
^XMB(3.9,145986,2,2752,0)=" ;;3.5;FEE BASIS;**12,25**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2753,0)="""RTN"",""FBNHAMIS"",3,0)"
^XMB(3.9,145986,2,2754,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,2755,0)="""RTN"",""FBNHAMIS"",4,0)"
^XMB(3.9,145986,2,2756,0)=" D DT^DICRW S %DT=""AEPMX"",%DT(0)=-$E(DT,1,5)_31,%DT(""A"")=""Calculate AMIS for which Month/Year: "" D ^%DT G:X=""""!(X=""^"") END S FBPAYDT=$E(+Y,1,5)_""00"",FBMM=$E(+Y,4,5),FBYY=$E(+Y,2,3),X=+Y D DAYS^FBAAUTL1"
^XMB(3.9,145986,2,2757,0)="""RTN"",""FBNHAMIS"",5,0)"
^XMB(3.9,145986,2,2758,0)=" W ! S FBDAYS=X,FBENDDT=$E(+Y,1,5)_FBDAYS+.9"
^XMB(3.9,145986,2,2759,0)="""RTN"",""FBNHAMIS"",6,0)"
^XMB(3.9,145986,2,2760,0)=" S DIR(0)=""Y"",DIR(""A"")=""Do you want data validation with this output"",DIR(""B"")=""No"",DIR(""?"")=""Answering 'Yes' will print who is found for each AMIS segment."" D ^DIR K DIR G:$D(DIRUT) END I Y S FBVAL=1"
^XMB(3.9,145986,2,2761,0)="""RTN"",""FBNHAMIS"",7,0)"
^XMB(3.9,145986,2,2762,0)=" S VAR=""FBPAYDT^FBENDDT^FBDAYS^FBYY^FBVAL"",VAL=FBPAYDT_""^""_FBENDDT_""^""_FBDAYS_""^""_FBYY_""^""_$G(FBVAL),PGM=""START^FBNHAMIS"",IOP=""Q"" D ZIS^FBAAUTL G:FBPOP END W !"
^XMB(3.9,145986,2,2763,0)="""RTN"",""FBNHAMIS"",8,0)"
^XMB(3.9,145986,2,2764,0)="START K FBOUT U IO D PRIOR"
^XMB(3.9,145986,2,2765,0)="""RTN"",""FBNHAMIS"",9,0)"
^XMB(3.9,145986,2,2766,0)=" K ^TMP($J,""FBAMIS"") S FBCUR=1 ;current month flag"
^XMB(3.9,145986,2,2767,0)="""RTN"",""FBNHAMIS"",10,0)"
^XMB(3.9,145986,2,2768,0)=" F I=1:1:4 S FBG(I)=0"
^XMB(3.9,145986,2,2769,0)="""RTN"",""FBNHAMIS"",11,0)"
^XMB(3.9,145986,2,2770,0)=" F I=1:1:4 S FBL(I)=0"
^XMB(3.9,145986,2,2771,0)="""RTN"",""FBNHAMIS"",12,0)"
^XMB(3.9,145986,2,2772,0)=" F I=1,2,3 S FBR(I)=0"
^XMB(3.9,145986,2,2773,0)="""RTN"",""FBNHAMIS"",13,0)"
^XMB(3.9,145986,2,2774,0)=" S (FBASDIS,FBASDEAD,FBTRDYS,FBSC,FBFEM,TOTDAYS)=0,FBMONTH=$E(FBPAYDT,1,5)_""01^""_$E(FBENDDT,1,7)"
^XMB(3.9,145986,2,2775,0)="""RTN"",""FBNHAMIS"",14,0)"
^XMB(3.9,145986,2,2776,0)=" F FBJ=FBPAYDT:0 S FBJ=$O(^FBAACNH(""B"",FBJ)) Q:FBJ'>0!(FBJ>FBENDDT)  F FBIFN=0:0 S FBIFN=$O(^FBAACNH(""B"",FBJ,FBIFN)) Q:'FBIFN  I $D(^FBAACNH(FBIFN,0)) S Y(0)=^(0),FBTYPE=$P(Y(0),""^"",3) D ADD:FBTYPE=""A"",TRAN:FBTYPE=""T"",DIS:FBTYPE=""D"""
^XMB(3.9,145986,2,2777,0)="""RTN"",""FBNHAMIS"",15,0)"
^XMB(3.9,145986,2,2778,0)=" G ^FBNHAMI1"
^XMB(3.9,145986,2,2779,0)="""RTN"",""FBNHAMIS"",16,0)"
^XMB(3.9,145986,2,2780,0)="END K %DT,FB,FBSW,FBG,FBL,FBR,IFN,DFN,FBLTT,FBNAC,FBPNAC,FBZ,FBPRTR,FBDD,FBENDDT,FBPAYDT,FBDAYS,TOTDAYS,FBRIFN,FBPIFN,FBTRDYS,FBFEM,FBSC,FBASIH,Z,Y,FBJ,FBTYPE,ATYPE,DTYPE,TTYPE,VAR,VAL,PGM,FBCUR,FBCHK,FBPRIOR,FBMOV,FBPG"
^XMB(3.9,145986,2,2781,0)="""RTN"",""FBNHAMIS"",17,0)"
^XMB(3.9,145986,2,2782,0)=" K FBABD,FBASDEAD,FBASDIS,FBDEFP,FBEDT,FBERR,FBHIFN,FBIFN,FBIRAT,FBMM,FBMONTH,FBMULT,FBNHCC,FBONE,FBPREV,FBSRAT,FBSUB,FBTDT,FBTOTAL,FBTWO,FBUL,FBVCAR,FBYY,I,X,X1,Z1,Z2,FBTOT,FBCOUNT,FBPSW,FBER,FBZZ,FBVAL,FBDV,FBOUT,^TMP($J,""FBAMIS"")"
^XMB(3.9,145986,2,2783,0)="""RTN"",""FBNHAMIS"",18,0)"
^XMB(3.9,145986,2,2784,0)=" D CLOSE^FBAAUTL"
^XMB(3.9,145986,2,2785,0)="""RTN"",""FBNHAMIS"",19,0)"
^XMB(3.9,145986,2,2786,0)=" Q"
^XMB(3.9,145986,2,2787,0)="""RTN"",""FBNHAMIS"",20,0)"
^XMB(3.9,145986,2,2788,0)="PRIOR ;calculate bed occupants remaining from previous month's amis"
^XMB(3.9,145986,2,2789,0)="""RTN"",""FBNHAMIS"",21,0)"
^XMB(3.9,145986,2,2790,0)=" S FBPAYHDT=FBPAYDT"
^XMB(3.9,145986,2,2791,0)="""RTN"",""FBNHAMIS"",22,0)"
^XMB(3.9,145986,2,2792,0)=" N FBR,FBPAYDT,FBENDDT,FBDAYS,FBMM,FBYY,FBYYY,FBFEM,FBTRDYS"
^XMB(3.9,145986,2,2793,0)="""RTN"",""FBNHAMIS"",23,0)"
^XMB(3.9,145986,2,2794,0)=" F I=1,2,3 S FBR(I)=0"
^XMB(3.9,145986,2,2795,0)="""RTN"",""FBNHAMIS"",24,0)"
^XMB(3.9,145986,2,2796,0)=" S (FBFEM,FBTRDYS)=0"
^XMB(3.9,145986,2,2797,0)="""RTN"",""FBNHAMIS"",25,0)"
^XMB(3.9,145986,2,2798,0)=" S FBMM=$E(FBPAYHDT,4,5),FBYYY=$E(FBPAYHDT,1,3)"
^XMB(3.9,145986,2,2799,0)="""RTN"",""FBNHAMIS"",26,0)"
^XMB(3.9,145986,2,2800,0)=" S FBMM=FBMM-1"
^XMB(3.9,145986,2,2801,0)="""RTN"",""FBNHAMIS"",27,0)"
^XMB(3.9,145986,2,2802,0)=" I FBMM<1 S FBMM=12,FBYYY=FBYYY-1"
^XMB(3.9,145986,2,2803,0)="""RTN"",""FBNHAMIS"",28,0)"
^XMB(3.9,145986,2,2804,0)=" I $L(FBMM)=1 S FBMM=""0""_FBMM"
^XMB(3.9,145986,2,2805,0)="""RTN"",""FBNHAMIS"",29,0)"
^XMB(3.9,145986,2,2806,0)=" I $L(FBYYY)<3 S FBYYY=$E(""000"",0,3-$L(FBYYY))_FBYYY"
^XMB(3.9,145986,2,2807,0)="""RTN"",""FBNHAMIS"",30,0)"
^XMB(3.9,145986,2,2808,0)=" S FBYY=$E(FBYYY,2,3)"
^XMB(3.9,145986,2,2809,0)="""RTN"",""FBNHAMIS"",31,0)"
^XMB(3.9,145986,2,2810,0)=" S FBPAYDT=FBYYY_FBMM_""00"",X=+FBPAYDT D DAYS^FBAAUTL1 S FBDAYS=X"
^XMB(3.9,145986,2,2811,0)="""RTN"",""FBNHAMIS"",32,0)"
^XMB(3.9,145986,2,2812,0)=" S FBENDDT=$E(+FBPAYDT,1,5)_FBDAYS+.9"
^XMB(3.9,145986,2,2813,0)="""RTN"",""FBNHAMIS"",33,0)"
^XMB(3.9,145986,2,2814,0)=" D NEXT^FBNHAMI1"
^XMB(3.9,145986,2,2815,0)="""RTN"",""FBNHAMIS"",34,0)"
^XMB(3.9,145986,2,2816,0)=" S FBPRIOR=FBR(1)+FBR(2) K FBPAYHDT"
^XMB(3.9,145986,2,2817,0)="""RTN"",""FBNHAMIS"",35,0)"
^XMB(3.9,145986,2,2818,0)=" Q"
^XMB(3.9,145986,2,2819,0)="""RTN"",""FBNHAMIS"",36,0)"
^XMB(3.9,145986,2,2820,0)="ADD S ATYPE=$P(Y(0),""^"",6) Q:ATYPE="""""
^XMB(3.9,145986,2,2821,0)="""RTN"",""FBNHAMIS"",37,0)"
^XMB(3.9,145986,2,2822,0)=" S FBSUB=$S(ATYPE=1:1,ATYPE=2:3,1:2),FBG(FBSUB)=FBG(FBSUB)+1 D TMP^FBNHAMI1(FBSUB)"
^XMB(3.9,145986,2,2823,0)="""RTN"",""FBNHAMIS"",38,0)"
^XMB(3.9,145986,2,2824,0)=" S DFN=$P(Y(0),""^"",2) I $$EXTPV^FBAAUTL5($P($G(^FBAAA(DFN,1,+$P(Y(0),""^"",10),0)),""^"",7))=40 S FBSC=FBSC+1 D TMP^FBNHAMI1(16)"
^XMB(3.9,145986,2,2825,0)="""RTN"",""FBNHAMIS"",39,0)"
^XMB(3.9,145986,2,2826,0)=" Q"
^XMB(3.9,145986,2,2827,0)="""RTN"",""FBNHAMIS"",40,0)"
^XMB(3.9,145986,2,2828,0)="DIS S DTYPE=$P(Y(0),""^"",8) Q:DTYPE="""""
^XMB(3.9,145986,2,2829,0)="""RTN"",""FBNHAMIS"",41,0)"
^XMB(3.9,145986,2,2830,0)=" I DTYPE<4!(DTYPE=6) S FBSUB=$S(DTYPE=1:1,DTYPE=6:1,1:DTYPE),FBL(FBSUB)=FBL(FBSUB)+1 D TMP^FBNHAMI1(FBSUB+4) Q"
^XMB(3.9,145986,2,2831,0)="""RTN"",""FBNHAMIS"",42,0)"
^XMB(3.9,145986,2,2832,0)=" I DTYPE=4 S FBASDIS=FBASDIS+1 D TMP^FBNHAMI1(13) Q"
^XMB(3.9,145986,2,2833,0)="""RTN"",""FBNHAMIS"",43,0)"
^XMB(3.9,145986,2,2834,0)=" S FBASDEAD=FBASDEAD+1 D TMP^FBNHAMI1(14)"
^XMB(3.9,145986,2,2835,0)="""RTN"",""FBNHAMIS"",44,0)"
^XMB(3.9,145986,2,2836,0)=" Q"
^XMB(3.9,145986,2,2837,0)="""RTN"",""FBNHAMIS"",45,0)"
^XMB(3.9,145986,2,2838,0)="TRAN S TTYPE=$P(Y(0),""^"",7) Q:TTYPE="""""
^XMB(3.9,145986,2,2839,0)="""RTN"",""FBNHAMIS"",46,0)"
^XMB(3.9,145986,2,2840,0)=" I TTYPE=6 S FBG(4)=FBG(4)+1 D TMP^FBNHAMI1(4) Q"
^XMB(3.9,145986,2,2841,0)="""RTN"",""FBNHAMIS"",47,0)"
^XMB(3.9,145986,2,2842,0)=" I TTYPE=3 S FBL(4)=FBL(4)+1 D TMP^FBNHAMI1(8) Q"
^XMB(3.9,145986,2,2843,0)="""RTN"",""FBNHAMIS"",48,0)"
^XMB(3.9,145986,2,2844,0)=" Q"
^XMB(3.9,145986,2,2845,0)="""RTN"",""FBNHAMIS"",49,0)"
^XMB(3.9,145986,2,2846,0)="DISCR ;print out pts whose authorization dates have been exceeded"
^XMB(3.9,145986,2,2847,0)="""RTN"",""FBNHAMIS"",50,0)"
^XMB(3.9,145986,2,2848,0)=" Q:'$D(FBER)"
^XMB(3.9,145986,2,2849,0)="""RTN"",""FBNHAMIS"",51,0)"
^XMB(3.9,145986,2,2850,0)=" W @IOF D HDR^FBNHPAMS"
^XMB(3.9,145986,2,2851,0)="""RTN"",""FBNHAMIS"",52,0)"
^XMB(3.9,145986,2,2852,0)=" W !?5,"">>>NOTICE OF INCOMPLETE PATIENT MOVEMENTS AFFECTING AMIS TOTALS<<<"",!!!,""The following patient(s) have met or exceeded their authorizations, and have"",!,""not been discharged.  This will result in inaccurate AMIS 349 calculations"""
^XMB(3.9,145986,2,2853,0)="""RTN"",""FBNHAMIS"",53,0)"
^XMB(3.9,145986,2,2854,0)=" W !,""for the current month's amis, and will affect the balancing segment for"",!,""subsequent months!!"",!!,""To obtain an accurate AMIS, you must either discharge the patient,"""
^XMB(3.9,145986,2,2855,0)="""RTN"",""FBNHAMIS"",54,0)"
^XMB(3.9,145986,2,2856,0)=" W !,""or extend their Authorization To Date.  Once the data has been corrected,"",!,""you may run the AMIS 349 again to obtain accurate figures."""
^XMB(3.9,145986,2,2857,0)="""RTN"",""FBNHAMIS"",55,0)"
^XMB(3.9,145986,2,2858,0)=" W !!?10,""PATIENT"",?44,""PT. ID"",?55,""AUTHORIZATION TO DATE"",!"
^XMB(3.9,145986,2,2859,0)="""RTN"",""FBNHAMIS"",56,0)"
^XMB(3.9,145986,2,2860,0)=" S FBZ=0 F  S FBZ=$O(FBER(FBZ)) Q:'FBZ!($G(FBOUT))  S FBDD=0 F  S FBDD=$O(FBER(FBZ,FBDD)) Q:'FBDD!($G(FBOUT))  D PGCK^FBNHPAMS(3) Q:$G(FBOUT)  D"
^XMB(3.9,145986,2,2861,0)="""RTN"",""FBNHAMIS"",57,0)"
^XMB(3.9,145986,2,2862,0)=" .W !,$S(FBER(FBZ,FBDD)=1:"""",1:""**""),?5,$$NAME^FBCHREQ2(FBZ),?40,$$SSN^FBAAUTL(FBZ),?60,$$DATX^FBAAUTL(FBDD) I FBER(FBZ,FBDD)="""" S FBMOV=1"
^XMB(3.9,145986,2,2863,0)="""RTN"",""FBNHAMIS"",58,0)"
^XMB(3.9,145986,2,2864,0)=" I $G(FBMOV) D PGCK^FBNHPAMS(4) Q:$G(FBOUT)  W !!,""** indicates movement problem from the prior month that is affecting"",!,""the balancing segment."""
^XMB(3.9,145986,2,2865,0)="""RTN"",""FBNHAMIS"",59,0)"
^XMB(3.9,145986,2,2866,0)=" Q"
^XMB(3.9,145986,2,2867,0)="""RTN"",""FBNHPC"")"
^XMB(3.9,145986,2,2868,0)="0^18^B14845789"
^XMB(3.9,145986,2,2869,0)="""RTN"",""FBNHPC"",1,0)"
^XMB(3.9,145986,2,2870,0)="FBNHPC ;AISC/GRR-POST COMMITMENTS TO 1358 ;1DEC00"
^XMB(3.9,145986,2,2871,0)="""RTN"",""FBNHPC"",2,0)"
^XMB(3.9,145986,2,2872,0)=" ;;3.5;FEE BASIS;**25,153,162**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2873,0)="""RTN"",""FBNHPC"",3,0)"
^XMB(3.9,145986,2,2874,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,2875,0)="""RTN"",""FBNHPC"",4,0)"
^XMB(3.9,145986,2,2876,0)=" ;"
^XMB(3.9,145986,2,2877,0)="""RTN"",""FBNHPC"",5,0)"
^XMB(3.9,145986,2,2878,0)=" ;FB*3.5*153 Save requested site internal to insure obligation found in file"
^XMB(3.9,145986,2,2879,0)="""RTN"",""FBNHPC"",6,0)"
^XMB(3.9,145986,2,2880,0)=" ;           FB7078 for time period selected is from the same station selected"
^XMB(3.9,145986,2,2881,0)="""RTN"",""FBNHPC"",7,0)"
^XMB(3.9,145986,2,2882,0)=" ;           during option process.  This is true for both monthly activity"
^XMB(3.9,145986,2,2883,0)="""RTN"",""FBNHPC"",8,0)"
^XMB(3.9,145986,2,2884,0)=" ;           as well as carry over activity and Insufficient Authorization "
^XMB(3.9,145986,2,2885,0)="""RTN"",""FBNHPC"",9,0)"
^XMB(3.9,145986,2,2886,0)=" ;           Rate data on file"
^XMB(3.9,145986,2,2887,0)="""RTN"",""FBNHPC"",10,0)"
^XMB(3.9,145986,2,2888,0)=" ;"
^XMB(3.9,145986,2,2889,0)="""RTN"",""FBNHPC"",11,0)"
^XMB(3.9,145986,2,2890,0)=" ;FB*3.5*162 Modify task process to include PRC(""site"")"
^XMB(3.9,145986,2,2891,0)="""RTN"",""FBNHPC"",12,0)"
^XMB(3.9,145986,2,2892,0)=" ;"
^XMB(3.9,145986,2,2893,0)="""RTN"",""FBNHPC"",13,0)"
^XMB(3.9,145986,2,2894,0)=" S PRCS(""TYPE"")=""FB"",(FBNHCC,FBTOT)=0,PRCS(""A"")=""Select Obligation Number: "" K PRCS(""X"") D EN1^PRCS58 G:Y<0 Q S FBOBN=$P(Y,""^"",2),FBSTA=PRC(""SST"")   ;FB*3.5*153"
^XMB(3.9,145986,2,2895,0)="""RTN"",""FBNHPC"",14,0)"
^XMB(3.9,145986,2,2896,0)=" ;entry point for estimate report FBNHCC=1,(FBSEQ,FBOBN)="""""
^XMB(3.9,145986,2,2897,0)="""RTN"",""FBNHPC"",15,0)"
^XMB(3.9,145986,2,2898,0)="EN1 I FBNHCC D STA^PRCSUT Q:'$D(PRC(""SITE""))  S FBSTA=PRC(""SST"")     ;FB*3.5*153"
^XMB(3.9,145986,2,2899,0)="""RTN"",""FBNHPC"",16,0)"
^XMB(3.9,145986,2,2900,0)=" S FBTOT=0,%DT=$S(FBNHCC:""AEPMX"",1:""AEPMX""),%DT(""A"")=$S(FBNHCC:""Calculate "",1:""Post "")_""Commitments for which Month/Year: "" D ^%DT G:X=""^""!(X="""") Q S FBPAYDT=$E(+Y,1,5)_""00"",FBMM=$E(+Y,4,5),FBYY=$E(+Y,2,3),X=+Y D DAYS^FBAAUTL1 S FBDAYS=X"
^XMB(3.9,145986,2,2901,0)="""RTN"",""FBNHPC"",17,0)"
^XMB(3.9,145986,2,2902,0)=" S VAR=""FBOBN^FBPAYDT^FBMM^FBYY^FBDAYS^FBNHCC^FBSTA^PRC(""""SITE"""")"",VAL=FBOBN_""^""_FBPAYDT_""^""_FBMM_""^""_FBYY_""^""_FBDAYS_""^""_FBNHCC,PGM=""START^FBNHPC"" D ZIS^FBAAUTL G:FBPOP END   ;FB*3.5*162"
^XMB(3.9,145986,2,2903,0)="""RTN"",""FBNHPC"",18,0)"
^XMB(3.9,145986,2,2904,0)=" ;"
^XMB(3.9,145986,2,2905,0)="""RTN"",""FBNHPC"",19,0)"
^XMB(3.9,145986,2,2906,0)="START K ^TMP($J,""FBNHPC"") S (FBPAYEDT,FBENDDT)=$E(FBPAYDT,1,5)_FBDAYS,Q="""",$P(Q,""="",80)=""="",(FBTOT,FBTOTAL,FBOUT)=0 U IO W:$E(IOST,1,2)[""C-"" @IOF D HED^FBNHPC1"
^XMB(3.9,145986,2,2907,0)="""RTN"",""FBNHPC"",20,0)"
^XMB(3.9,145986,2,2908,0)=" N FBCNT S FBCNT=0"
^XMB(3.9,145986,2,2909,0)="""RTN"",""FBNHPC"",21,0)"
^XMB(3.9,145986,2,2910,0)=" S FBIFN=0,^XTMP(""FBPOST"",0)=$$CDTC^FBUCUTL(DT,1)_""^""_DT"
^XMB(3.9,145986,2,2911,0)="""RTN"",""FBNHPC"",22,0)"
^XMB(3.9,145986,2,2912,0)=" F FBDD=FBPAYDT:0 S FBDD=$O(^FB7078(""AD"",7,FBDD)) Q:FBDD'>0!(FBOUT)  D"
^XMB(3.9,145986,2,2913,0)="""RTN"",""FBNHPC"",23,0)"
^XMB(3.9,145986,2,2914,0)=" .F  S FBIFN=$O(^FB7078(""AD"",7,FBDD,FBIFN)) Q:'FBIFN!(FBOUT)  I $D(^FB7078(FBIFN,0)) S FBZ=^(0) I $P(FBZ,U,9)'=""DC"" S (FBHIFN,FB7078)=FBIFN,FBABD=$P(FBZ,""^"",4),IFN=+$P(FBZ,""^"",2),DFN=+$P(FBZ,""^"",3) D"
^XMB(3.9,145986,2,2915,0)="""RTN"",""FBNHPC"",24,0)"
^XMB(3.9,145986,2,2916,0)=" ..D L(FBIFN,1) I $G(FBLERR) S FBNAME=$$NAME^FBCHREQ2(DFN),FBSSN=$$SSN^FBAAUTL(DFN),Y=""Another user is editing 7078."" D ERR K FBLERR,Y W ! Q"
^XMB(3.9,145986,2,2917,0)="""RTN"",""FBNHPC"",25,0)"
^XMB(3.9,145986,2,2918,0)=" ..I '$D(^XTMP(""FBPOST"",FBIFN)) D CHECK^FBNHPC1,L(FBIFN,2)"
^XMB(3.9,145986,2,2919,0)="""RTN"",""FBNHPC"",26,0)"
^XMB(3.9,145986,2,2920,0)=" G END:FBOUT"
^XMB(3.9,145986,2,2921,0)="""RTN"",""FBNHPC"",27,0)"
^XMB(3.9,145986,2,2922,0)=" D PRT^FBNHPC1"
^XMB(3.9,145986,2,2923,0)="""RTN"",""FBNHPC"",28,0)"
^XMB(3.9,145986,2,2924,0)=" I $$WRT() W !!?10,""No funds currently need to be posted."",! G END"
^XMB(3.9,145986,2,2925,0)="""RTN"",""FBNHPC"",29,0)"
^XMB(3.9,145986,2,2926,0)="Q W !!,?10,""Total "",$S(FBNHCC:""Estimated: "",1:""Posted: ""),$J(FBTOT,10,2),?50,""Total Days: "",$S($D(FBTOTAL):FBTOTAL,1:0),!"
^XMB(3.9,145986,2,2927,0)="""RTN"",""FBNHPC"",30,0)"
^XMB(3.9,145986,2,2928,0)=" ;"
^XMB(3.9,145986,2,2929,0)="""RTN"",""FBNHPC"",31,0)"
^XMB(3.9,145986,2,2930,0)="END K FBMM,FBYY,FBDEFP,FBABD,FBPAYDT,FBDAYS,FBIFN,Z1,Z2,FBVCAR,FBCD,FBSEQ,FBOBN,FBNAME,FBSSN,FBPOSDT,FBNHCC,FBTOTAL,FBPAYEDT,FB7078,FBAABDT,FBX1,FBOUT,DFN,FBVEN,FBENDFLG,FBLERR"
^XMB(3.9,145986,2,2931,0)="""RTN"",""FBNHPC"",32,0)"
^XMB(3.9,145986,2,2932,0)=" K %,%DT,DIC,FBDD,FBERR,FBTOT,IFN,PGM,Q,VAL,VAR,Z,FBEDT,FBENDDT,FBHIFN,FBRIFN,FBTDT,FBTRDYS,FBZ,FB,I,PRCS,Y,PRC,PRCSCPAN,X,X1,^TMP($J,""FBNHPC"")"
^XMB(3.9,145986,2,2933,0)="""RTN"",""FBNHPC"",33,0)"
^XMB(3.9,145986,2,2934,0)=" K FBSTA,FBOBIEN,FBOBNO,PRC23,FBPOP,FBCNT,FBHIN,FBMM"
^XMB(3.9,145986,2,2935,0)="""RTN"",""FBNHPC"",34,0)"
^XMB(3.9,145986,2,2936,0)=" K ^XTMP(""FBPOST"") D CLOSE^FBAAUTL Q"
^XMB(3.9,145986,2,2937,0)="""RTN"",""FBNHPC"",35,0)"
^XMB(3.9,145986,2,2938,0)=" ;"
^XMB(3.9,145986,2,2939,0)="""RTN"",""FBNHPC"",36,0)"
^XMB(3.9,145986,2,2940,0)="WRT() ;determine if write to output"
^XMB(3.9,145986,2,2941,0)="""RTN"",""FBNHPC"",37,0)"
^XMB(3.9,145986,2,2942,0)=" ;return 1 if nothing to post"
^XMB(3.9,145986,2,2943,0)="""RTN"",""FBNHPC"",38,0)"
^XMB(3.9,145986,2,2944,0)=" Q $S('$G(FBTOT):1,'$G(FBTOTAL):1,1:0)"
^XMB(3.9,145986,2,2945,0)="""RTN"",""FBNHPC"",39,0)"
^XMB(3.9,145986,2,2946,0)=" ;"
^XMB(3.9,145986,2,2947,0)="""RTN"",""FBNHPC"",40,0)"
^XMB(3.9,145986,2,2948,0)="ERR W !!,*7,""Unable to Post the following transaction because of the following:"",!,Y,!?7,FBNAME,?40,FBSSN I '$G(FBLERR) W ?60,""$""_$FN(FBDEFP,"","",2)"
^XMB(3.9,145986,2,2949,0)="""RTN"",""FBNHPC"",41,0)"
^XMB(3.9,145986,2,2950,0)=" Q"
^XMB(3.9,145986,2,2951,0)="""RTN"",""FBNHPC"",42,0)"
^XMB(3.9,145986,2,2952,0)=" ;"
^XMB(3.9,145986,2,2953,0)="""RTN"",""FBNHPC"",43,0)"
^XMB(3.9,145986,2,2954,0)="L(FBDA,FBL) ;lock/unlock 7078"
^XMB(3.9,145986,2,2955,0)="""RTN"",""FBNHPC"",44,0)"
^XMB(3.9,145986,2,2956,0)=" ;INPUT:  FBDA = ien (fbifn) of 7078 file"
^XMB(3.9,145986,2,2957,0)="""RTN"",""FBNHPC"",45,0)"
^XMB(3.9,145986,2,2958,0)=" ;        FBL = lock code:  1 to lock, 2 to unlock"
^XMB(3.9,145986,2,2959,0)="""RTN"",""FBNHPC"",46,0)"
^XMB(3.9,145986,2,2960,0)=" ;OUTPUT:  no output variables; fb7078 entry will be locked or unlocked"
^XMB(3.9,145986,2,2961,0)="""RTN"",""FBNHPC"",47,0)"
^XMB(3.9,145986,2,2962,0)=" N FBLCTR S FBLCTR=0"
^XMB(3.9,145986,2,2963,0)="""RTN"",""FBNHPC"",48,0)"
^XMB(3.9,145986,2,2964,0)="L1 I $S('+$G(FBDA):1,'+$G(FBL):1,1:0) Q"
^XMB(3.9,145986,2,2965,0)="""RTN"",""FBNHPC"",49,0)"
^XMB(3.9,145986,2,2966,0)=" I FBL=1 L +^FB7078(FBDA):2 I '$T S FBLCTR=FBLCTR+1 G:FBLCTR<5 L1 S FBLERR=1 Q"
^XMB(3.9,145986,2,2967,0)="""RTN"",""FBNHPC"",50,0)"
^XMB(3.9,145986,2,2968,0)=" I FBL=2 K ^XTMP(""FBPOST"",FBDA) L -^FB7078(FBDA)"
^XMB(3.9,145986,2,2969,0)="""RTN"",""FBNHPC"",51,0)"
^XMB(3.9,145986,2,2970,0)=" Q"
^XMB(3.9,145986,2,2971,0)="""RTN"",""FBNHPC1"")"
^XMB(3.9,145986,2,2972,0)="0^20^B13879946"
^XMB(3.9,145986,2,2973,0)="""RTN"",""FBNHPC1"",1,0)"
^XMB(3.9,145986,2,2974,0)="FBNHPC1 ;AISC/CMR-POST COMMITMENTS TO 1358 cont. ;9/20/94"
^XMB(3.9,145986,2,2975,0)="""RTN"",""FBNHPC1"",2,0)"
^XMB(3.9,145986,2,2976,0)=" ;;3.5;FEE BASIS;**153**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,2977,0)="""RTN"",""FBNHPC1"",3,0)"
^XMB(3.9,145986,2,2978,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,2979,0)="""RTN"",""FBNHPC1"",4,0)"
^XMB(3.9,145986,2,2980,0)=" ;"
^XMB(3.9,145986,2,2981,0)="""RTN"",""FBNHPC1"",5,0)"
^XMB(3.9,145986,2,2982,0)=" ;FB*3.5*153 Added calls to tag 'CHKSITOB' to insure obligation found in file"
^XMB(3.9,145986,2,2983,0)="""RTN"",""FBNHPC1"",6,0)"
^XMB(3.9,145986,2,2984,0)=" ;           FB7078 for time period selected is from the same station selected"
^XMB(3.9,145986,2,2985,0)="""RTN"",""FBNHPC1"",7,0)"
^XMB(3.9,145986,2,2986,0)=" ;           during option process.  This is true for both monthly activity"
^XMB(3.9,145986,2,2987,0)="""RTN"",""FBNHPC1"",8,0)"
^XMB(3.9,145986,2,2988,0)=" ;           as well as carry over activity and Insufficient Authorization "
^XMB(3.9,145986,2,2989,0)="""RTN"",""FBNHPC1"",9,0)"
^XMB(3.9,145986,2,2990,0)=" ;           Rate data on file"
^XMB(3.9,145986,2,2991,0)="""RTN"",""FBNHPC1"",10,0)"
^XMB(3.9,145986,2,2992,0)=" ;"
^XMB(3.9,145986,2,2993,0)="""RTN"",""FBNHPC1"",11,0)"
^XMB(3.9,145986,2,2994,0)="CHECK S ^XTMP(""FBPOST"",FBIFN)="""""
^XMB(3.9,145986,2,2995,0)="""RTN"",""FBNHPC1"",12,0)"
^XMB(3.9,145986,2,2996,0)=" Q:$E(FBPAYDT,1,5)<$E(FBABD,1,5)"
^XMB(3.9,145986,2,2997,0)="""RTN"",""FBNHPC1"",13,0)"
^XMB(3.9,145986,2,2998,0)=" S FBTRDYS=0 K FBELSE"
^XMB(3.9,145986,2,2999,0)="""RTN"",""FBNHPC1"",14,0)"
^XMB(3.9,145986,2,3000,0)=" S FBERR=""""  D CHKSITOB Q:$G(FBELSE)=1  D GETRAT^FBNHEP2 Q:FBERR  D CHECK^FBNHEP2 Q:FBERR  ;FB*3.5*153"
^XMB(3.9,145986,2,3001,0)="""RTN"",""FBNHPC1"",15,0)"
^XMB(3.9,145986,2,3002,0)=" S FBIFN=FBHIFN"
^XMB(3.9,145986,2,3003,0)="""RTN"",""FBNHPC1"",16,0)"
^XMB(3.9,145986,2,3004,0)=" D"
^XMB(3.9,145986,2,3005,0)="""RTN"",""FBNHPC1"",17,0)"
^XMB(3.9,145986,2,3006,0)=" .I $E(FBABD,1,5)<$E(FBPAYDT,1,5)&($E(FBDD,1,5)>$E(FBPAYDT,1,5)) S FBTRDYS=FBDAYS D CALC Q"
^XMB(3.9,145986,2,3007,0)="""RTN"",""FBNHPC1"",18,0)"
^XMB(3.9,145986,2,3008,0)=" .I $E(FBABD,1,5)<$E(FBPAYDT,1,5)&($E(FBDD,1,5)'>$E(FBPAYDT,1,5)) S FBTRDYS=$E(FBDD,6,7)-1,FBTRDYS=$S(FBTRDYS>0:FBTRDYS,1:0) S:FBTRDYS'>0 FBELSE=1 D CALC Q"
^XMB(3.9,145986,2,3009,0)="""RTN"",""FBNHPC1"",19,0)"
^XMB(3.9,145986,2,3010,0)=" .I $E(FBABD,1,5)=$E(FBPAYDT,1,5)&($E(FBDD,1,5)>$E(FBPAYDT,1,5)) S FBTRDYS=(FBDAYS-$E(FBABD,6,7))+1 D CALC Q"
^XMB(3.9,145986,2,3011,0)="""RTN"",""FBNHPC1"",20,0)"
^XMB(3.9,145986,2,3012,0)=" .I FBABD=FBDD S FBTRDYS=1 D CALC Q"
^XMB(3.9,145986,2,3013,0)="""RTN"",""FBNHPC1"",21,0)"
^XMB(3.9,145986,2,3014,0)=" .I $E(FBABD,1,5)=$E(FBPAYDT,1,5)&($E(FBDD,1,5)'>$E(FBPAYDT,1,5)) S FBTRDYS=FBDD-FBABD,FBTRDYS=$S(FBTRDYS>0:FBTRDYS,1:0) S:FBTRDYS'>0 FBELSE=1 D CALC Q"
^XMB(3.9,145986,2,3015,0)="""RTN"",""FBNHPC1"",22,0)"
^XMB(3.9,145986,2,3016,0)=" Q:$D(FBELSE)"
^XMB(3.9,145986,2,3017,0)="""RTN"",""FBNHPC1"",23,0)"
^XMB(3.9,145986,2,3018,0)=" ;ifcap calls for posting"
^XMB(3.9,145986,2,3019,0)="""RTN"",""FBNHPC1"",24,0)"
^XMB(3.9,145986,2,3020,0)=" I 'FBNHCC,$D(^PRC(424,""E"",+$P(FBZ,""^"",3)_"";""_+FBIFN_"";""_$P(FBOBN,""-"",2)_"";""_FBMM)) Q"
^XMB(3.9,145986,2,3021,0)="""RTN"",""FBNHPC1"",25,0)"
^XMB(3.9,145986,2,3022,0)=" S FBSEQ="""" I 'FBNHCC S X=FBOBN,PRCS(""TYPE"")=""FB"" D EN1^PRCSUT31 Q:Y=""""  S FBSEQ=Y"
^XMB(3.9,145986,2,3023,0)="""RTN"",""FBNHPC1"",26,0)"
^XMB(3.9,145986,2,3024,0)=" S DFN=$P(FBZ,""^"",3),FBNAME=$$NAME^FBCHREQ2(DFN),FBSSN=$$SSN^FBAAUTL(DFN),FBVEN=$P(FBZ,""^"",2)"
^XMB(3.9,145986,2,3025,0)="""RTN"",""FBNHPC1"",27,0)"
^XMB(3.9,145986,2,3026,0)=" S PRCS(""TYPE"")=""FB"" I 'FBNHCC D NOW^%DTC S FBPOSDT=%,X=FBOBN_""^""_FBPOSDT_""^""_FBDEFP_""^^""_FBSEQ_""^""_FBNAME_""  (""_FBSSN_"")""_""^""_+DFN_"";""_+FBIFN_"";""_$P(FBOBN,""-"",2)_"";""_FBMM D EN2^PRCS58"
^XMB(3.9,145986,2,3027,0)="""RTN"",""FBNHPC1"",28,0)"
^XMB(3.9,145986,2,3028,0)=" I 'FBNHCC G:+Y=0 ERR^FBNHPC"
^XMB(3.9,145986,2,3029,0)="""RTN"",""FBNHPC1"",29,0)"
^XMB(3.9,145986,2,3030,0)=" S FBTOTAL=FBTOTAL+FBTRDYS,FBTOT=FBTOT+FBDEFP,FBCNT=FBCNT+1"
^XMB(3.9,145986,2,3031,0)="""RTN"",""FBNHPC1"",30,0)"
^XMB(3.9,145986,2,3032,0)=" S ^TMP($J,""FBNHPC"",FBNAME,FBCNT)=FBSSN_""^""_FBTRDYS_""^""_FBDEFP_""^""_$G(FBSEQ)_""^""_+FBVEN"
^XMB(3.9,145986,2,3033,0)="""RTN"",""FBNHPC1"",31,0)"
^XMB(3.9,145986,2,3034,0)=" Q"
^XMB(3.9,145986,2,3035,0)="""RTN"",""FBNHPC1"",32,0)"
^XMB(3.9,145986,2,3036,0)=" ;"
^XMB(3.9,145986,2,3037,0)="""RTN"",""FBNHPC1"",33,0)"
^XMB(3.9,145986,2,3038,0)="PRT S FBNAME="""" F  S FBNAME=$O(^TMP($J,""FBNHPC"",FBNAME)) Q:FBNAME']""""!($G(FBOUT))  F FBCNT=0:0 S FBCNT=$O(^TMP($J,""FBNHPC"",FBNAME,FBCNT)) Q:'FBCNT!($G(FBOUT))  D"
^XMB(3.9,145986,2,3039,0)="""RTN"",""FBNHPC1"",34,0)"
^XMB(3.9,145986,2,3040,0)=" .S Y(0)=$G(^TMP($J,""FBNHPC"",FBNAME,FBCNT)),FBSSN=$P(Y(0),""^""),FBTRDYS=$P(Y(0),""^"",2),FBDEFP=$P(Y(0),""^"",3),FBSEQ=$P(Y(0),""^"",4),FBVEN=$P(Y(0),""^"",5)"
^XMB(3.9,145986,2,3041,0)="""RTN"",""FBNHPC1"",35,0)"
^XMB(3.9,145986,2,3042,0)=" .I $Y+3>IOSL,$E(IOST,1,2)[""C-"" S DIR(0)=""E"" D ^DIR K DIR S:'Y FBOUT=1 Q:FBOUT"
^XMB(3.9,145986,2,3043,0)="""RTN"",""FBNHPC1"",36,0)"
^XMB(3.9,145986,2,3044,0)=" .I ($Y+3)>IOSL W @IOF D HED"
^XMB(3.9,145986,2,3045,0)="""RTN"",""FBNHPC1"",37,0)"
^XMB(3.9,145986,2,3046,0)=" .W !,FBSEQ,?7,$E(FBNAME,1,20),?30,FBSSN,?44,$E($$VNAME^FBNHEXP(FBVEN),1,20),?66,FBTRDYS,?70,$J($FN(FBDEFP,"","",2),10)"
^XMB(3.9,145986,2,3047,0)="""RTN"",""FBNHPC1"",38,0)"
^XMB(3.9,145986,2,3048,0)=" Q"
^XMB(3.9,145986,2,3049,0)="""RTN"",""FBNHPC1"",39,0)"
^XMB(3.9,145986,2,3050,0)=" ;"
^XMB(3.9,145986,2,3051,0)="""RTN"",""FBNHPC1"",40,0)"
^XMB(3.9,145986,2,3052,0)="HED W !?11,""C O M M U N I T Y   N U R S I N G   H O M E   R E P O R T"",!"
^XMB(3.9,145986,2,3053,0)="""RTN"",""FBNHPC1"",41,0)"
^XMB(3.9,145986,2,3054,0)=" S I="""",$P(I,""-"",59)=""-"" W ?10,I K I W !"
^XMB(3.9,145986,2,3055,0)="""RTN"",""FBNHPC1"",42,0)"
^XMB(3.9,145986,2,3056,0)=" I FBNHCC W ?5,""Estimated Funds for: "",$P(""Jan^Feb^Mar^Apr^May^Jun^Jul^Aug^Sep^Oct^Nov^Dec"",""^"",+FBMM),"" "",FBYY,!!"
^XMB(3.9,145986,2,3057,0)="""RTN"",""FBNHPC1"",43,0)"
^XMB(3.9,145986,2,3058,0)=" I 'FBNHCC W ?5,""Postings for Obligation Number: "",$P(FBOBN,""-"",2),!!,""Ref #"""
^XMB(3.9,145986,2,3059,0)="""RTN"",""FBNHPC1"",44,0)"
^XMB(3.9,145986,2,3060,0)=" W ?7,""Veteran"",?30,""SSN"",?44,""Vendor"",?65,""Days"",?74,""Total"",!,Q,!"
^XMB(3.9,145986,2,3061,0)="""RTN"",""FBNHPC1"",45,0)"
^XMB(3.9,145986,2,3062,0)=" Q"
^XMB(3.9,145986,2,3063,0)="""RTN"",""FBNHPC1"",46,0)"
^XMB(3.9,145986,2,3064,0)=" ;"
^XMB(3.9,145986,2,3065,0)="""RTN"",""FBNHPC1"",47,0)"
^XMB(3.9,145986,2,3066,0)="CALC S FBENDFLG=$S(FBDD'>FBENDDT:1,1:""""),FBENDDT=$S(FBDD>FBENDDT:FBENDDT,1:FBDD),FBAABDT=FBABD D CALC^FBNHEP2"
^XMB(3.9,145986,2,3067,0)="""RTN"",""FBNHPC1"",48,0)"
^XMB(3.9,145986,2,3068,0)=" S FBENDDT=FBPAYEDT K FB"
^XMB(3.9,145986,2,3069,0)="""RTN"",""FBNHPC1"",49,0)"
^XMB(3.9,145986,2,3070,0)=" Q"
^XMB(3.9,145986,2,3071,0)="""RTN"",""FBNHPC1"",50,0)"
^XMB(3.9,145986,2,3072,0)=" ;FB*3.5*153"
^XMB(3.9,145986,2,3073,0)="""RTN"",""FBNHPC1"",51,0)"
^XMB(3.9,145986,2,3074,0)="CHKSITOB ;INSURE ENTRY IS FOR CORRECT SITE/OBLIGATION"
^XMB(3.9,145986,2,3075,0)="""RTN"",""FBNHPC1"",52,0)"
^XMB(3.9,145986,2,3076,0)=" S FBOBNO=$E($P(FBZ,U),1,6)"
^XMB(3.9,145986,2,3077,0)="""RTN"",""FBNHPC1"",53,0)"
^XMB(3.9,145986,2,3078,0)=" S FBOBIEN=$O(^PRC(442,""B"",PRC(""SITE"")_""-""_FBOBNO,0)) I FBOBIEN="""" S FBELSE=1 Q"
^XMB(3.9,145986,2,3079,0)="""RTN"",""FBNHPC1"",54,0)"
^XMB(3.9,145986,2,3080,0)=" S PRC23=$G(^PRC(442,FBOBIEN,23)) I PRC23="""" S FBELSE=1 Q"
^XMB(3.9,145986,2,3081,0)="""RTN"",""FBNHPC1"",55,0)"
^XMB(3.9,145986,2,3082,0)=" I $P(PRC23,U,7)'=FBSTA S FBELSE=1 Q"
^XMB(3.9,145986,2,3083,0)="""RTN"",""FBNHPC1"",56,0)"
^XMB(3.9,145986,2,3084,0)=" Q"
^XMB(3.9,145986,2,3085,0)="""RTN"",""FBNHPLT"")"
^XMB(3.9,145986,2,3086,0)="0^9^B9333666"
^XMB(3.9,145986,2,3087,0)="""RTN"",""FBNHPLT"",1,0)"
^XMB(3.9,145986,2,3088,0)="FBNHPLT ;AISC/GRR-PRINT CNH PAYMENTS AND TOTALS FOR A MONTH ;1DEC00"
^XMB(3.9,145986,2,3089,0)="""RTN"",""FBNHPLT"",2,0)"
^XMB(3.9,145986,2,3090,0)=" ;;3.5;FEE BASIS;**25**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,3091,0)="""RTN"",""FBNHPLT"",3,0)"
^XMB(3.9,145986,2,3092,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,3093,0)="""RTN"",""FBNHPLT"",4,0)"
^XMB(3.9,145986,2,3094,0)="ASK S %DT(0)=-DT,%DT=""AEPMX"",%DT(""A"")=""Community Nursing Home Payment List for which Month/Year: "" D ^%DT K %DT G END:X=""^""!(X=""""),ASK:Y<0"
^XMB(3.9,145986,2,3095,0)="""RTN"",""FBNHPLT"",5,0)"
^XMB(3.9,145986,2,3096,0)=" S FBPAYDT=$E(+Y,1,5)_""00"",VAR=""FBPAYDT"",VAL=FBPAYDT,PGM=""START^FBNHPLT"" D ZIS^FBAAUTL G:FBPOP END W !"
^XMB(3.9,145986,2,3097,0)="""RTN"",""FBNHPLT"",6,0)"
^XMB(3.9,145986,2,3098,0)="START K ^TMP($J) S Q="""",$P(Q,""="",80)=""="",(FBGTOT,FBVTOT)=0,FBENDDT=$E(FBPAYDT,1,5)_31 U IO W:$E(IOST,1,2)[""C-"" @IOF D HED"
^XMB(3.9,145986,2,3099,0)="""RTN"",""FBNHPLT"",7,0)"
^XMB(3.9,145986,2,3100,0)="BEG F FBJ=FBPAYDT:0 S FBJ=$O(^FBAAI(""AD"",FBJ)) Q:FBJ'>0!(FBJ>FBENDDT)  F IFN=0:0 S IFN=$O(^FBAAI(""AD"",FBJ,IFN)) Q:IFN'>0  I $D(^FBAAI(IFN,0)) S FBZ=^(0) D SETUP"
^XMB(3.9,145986,2,3101,0)="""RTN"",""FBNHPLT"",8,0)"
^XMB(3.9,145986,2,3102,0)=" S FBSW=1 F FBVEN=0:0 S FBVEN=$O(^TMP($J,FBVEN)) Q:FBVEN'>0  D:'FBSW TOT S FBSW=0 D GETVEN F DFN=0:0 S DFN=$O(^TMP($J,FBVEN,DFN)) Q:DFN'>0  S IFN=$O(^TMP($J,FBVEN,DFN,0)) Q:IFN'>0  I $D(^FBAAI(IFN,0)) S FBZ=^(0) D MORE"
^XMB(3.9,145986,2,3103,0)="""RTN"",""FBNHPLT"",9,0)"
^XMB(3.9,145986,2,3104,0)=" S FBGTOT=FBGTOT+FBVTOT D TOT W !!,""Grand Total Dollars: "",$J(FBGTOT,7,2)"
^XMB(3.9,145986,2,3105,0)="""RTN"",""FBNHPLT"",10,0)"
^XMB(3.9,145986,2,3106,0)="END K FBGTOT,FBVTOT,FBJ,DFN,FBVEN,FBZ,IFN,VAR,VAL,PGM,FBSW,FBAP,FBENDDT,FBNAME,FBPAYDT,FBVID,FBVNAME,Q,SSN,X,X1,Y"
^XMB(3.9,145986,2,3107,0)="""RTN"",""FBNHPLT"",11,0)"
^XMB(3.9,145986,2,3108,0)=" D CLOSE^FBAAUTL Q"
^XMB(3.9,145986,2,3109,0)="""RTN"",""FBNHPLT"",12,0)"
^XMB(3.9,145986,2,3110,0)="GETVEN S FBGTOT=FBGTOT+FBVTOT,FBVTOT=0,FBVNAME=$S($D(^FBAAV(FBVEN,0)):$P(^(0),""^"",1),1:""""),FBVID=$S(FBVNAME'="""":$P(^(0),""^"",2),1:"""")"
^XMB(3.9,145986,2,3111,0)="""RTN"",""FBNHPLT"",13,0)"
^XMB(3.9,145986,2,3112,0)="PVHED I $Y+3>IOSL W @IOF D HED"
^XMB(3.9,145986,2,3113,0)="""RTN"",""FBNHPLT"",14,0)"
^XMB(3.9,145986,2,3114,0)=" W !!,FBVNAME,?50,FBVID"
^XMB(3.9,145986,2,3115,0)="""RTN"",""FBNHPLT"",15,0)"
^XMB(3.9,145986,2,3116,0)=" Q"
^XMB(3.9,145986,2,3117,0)="""RTN"",""FBNHPLT"",16,0)"
^XMB(3.9,145986,2,3118,0)="HED W ""Community Nursing Home Payment List & Totals for: "",$P(""January^February^March^April^May^June^July^August^September^October^November^December"",""^"",+$E(FBPAYDT,4,5)),"" "",(1700+$E(FBPAYDT,1,3)),!"
^XMB(3.9,145986,2,3119,0)="""RTN"",""FBNHPLT"",17,0)"
^XMB(3.9,145986,2,3120,0)=" D NOW^%DTC S Y=% X ^DD(""DD"") W ?10,""Processed: "",Y,!"
^XMB(3.9,145986,2,3121,0)="""RTN"",""FBNHPLT"",18,0)"
^XMB(3.9,145986,2,3122,0)=" W ""Vendor Name"",?50,""Vendor ID"",!,?8,""Veteran Name"",?39,""   SSN"",?51,""Amount Paid"",!,Q"
^XMB(3.9,145986,2,3123,0)="""RTN"",""FBNHPLT"",19,0)"
^XMB(3.9,145986,2,3124,0)=" Q"
^XMB(3.9,145986,2,3125,0)="""RTN"",""FBNHPLT"",20,0)"
^XMB(3.9,145986,2,3126,0)="MORE S FBNAME=$$NAME^FBCHREQ2(DFN),SSN=$$SSN^FBAAUTL(DFN),FBAP=$P(FBZ,""^"",9),FBVTOT=FBVTOT+FBAP"
^XMB(3.9,145986,2,3127,0)="""RTN"",""FBNHPLT"",21,0)"
^XMB(3.9,145986,2,3128,0)=" I $Y+3>IOSL D PVHED"
^XMB(3.9,145986,2,3129,0)="""RTN"",""FBNHPLT"",22,0)"
^XMB(3.9,145986,2,3130,0)=" W !,?8,FBNAME,?39,SSN,?51,$J(FBAP,7,2)"
^XMB(3.9,145986,2,3131,0)="""RTN"",""FBNHPLT"",23,0)"
^XMB(3.9,145986,2,3132,0)=" Q"
^XMB(3.9,145986,2,3133,0)="""RTN"",""FBNHPLT"",24,0)"
^XMB(3.9,145986,2,3134,0)="TOT W !,?51,""-------"",!,?35,""Vendor Total:"",?51,$J(FBVTOT,7,2) Q"
^XMB(3.9,145986,2,3135,0)="""RTN"",""FBNHPLT"",25,0)"
^XMB(3.9,145986,2,3136,0)="SETUP I $P(FBZ,""^"",14)="""",$P(FBZ,""^"",12)=7,'$D(^FBAAI(IFN,""FBREJ"")) S ^TMP($J,$P(FBZ,""^"",3),$P(FBZ,""^"",4),IFN)="""""
^XMB(3.9,145986,2,3137,0)="""RTN"",""FBNHPLT"",26,0)"
^XMB(3.9,145986,2,3138,0)=" Q"
^XMB(3.9,145986,2,3139,0)="""RTN"",""FBNHRAT1"")"
^XMB(3.9,145986,2,3140,0)="0^16^B7549171"
^XMB(3.9,145986,2,3141,0)="""RTN"",""FBNHRAT1"",1,0)"
^XMB(3.9,145986,2,3142,0)="FBNHRAT1 ;AISC/CMR - ENTER RATES CONT. ;9/19/2014"
^XMB(3.9,145986,2,3143,0)="""RTN"",""FBNHRAT1"",2,0)"
^XMB(3.9,145986,2,3144,0)=" ;;3.5;FEE BASIS;**17,154**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,3145,0)="""RTN"",""FBNHRAT1"",3,0)"
^XMB(3.9,145986,2,3146,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,3147,0)="""RTN"",""FBNHRAT1"",4,0)"
^XMB(3.9,145986,2,3148,0)="VENDAT ;set up rate if contract exists"
^XMB(3.9,145986,2,3149,0)="""RTN"",""FBNHRAT1"",5,0)"
^XMB(3.9,145986,2,3150,0)=" N FBRATE,FBCFDT,FBCTDT,FBI,FBCNUM,FBNRFDT,FBNRTDT"
^XMB(3.9,145986,2,3151,0)="""RTN"",""FBNHRAT1"",6,0)"
^XMB(3.9,145986,2,3152,0)=" S FBCFDT=0"
^XMB(3.9,145986,2,3153,0)="""RTN"",""FBNHRAT1"",7,0)"
^XMB(3.9,145986,2,3154,0)=" I '$O(^FBAA(161.21,""AC"",FBVIEN,0)) D:$G(FBDDT) CKSET(FBNFDT,FBNTDT) Q"
^XMB(3.9,145986,2,3155,0)="""RTN"",""FBNHRAT1"",8,0)"
^XMB(3.9,145986,2,3156,0)="VENDAT1 K FBRET"
^XMB(3.9,145986,2,3157,0)="""RTN"",""FBNHRAT1"",9,0)"
^XMB(3.9,145986,2,3158,0)=" S FBCFDT=$O(^FBAA(161.21,""AC"",FBVIEN,FBCFDT))"
^XMB(3.9,145986,2,3159,0)="""RTN"",""FBNHRAT1"",10,0)"
^XMB(3.9,145986,2,3160,0)=" I FBCFDT']"""" D:$G(FBDDT) CKSET(FBNFDT,FBNTDT) Q"
^XMB(3.9,145986,2,3161,0)="""RTN"",""FBNHRAT1"",11,0)"
^XMB(3.9,145986,2,3162,0)=" S FBI=$O(^FBAA(161.21,""AC"",FBVIEN,FBCFDT,0)) I FBI]"""" S FBCTDT=$P(^FBAA(161.21,FBI,0),""^"",3),FBCNUM=$P(^FBAA(161.21,FBI,0),""^"")"
^XMB(3.9,145986,2,3163,0)="""RTN"",""FBNHRAT1"",12,0)"
^XMB(3.9,145986,2,3164,0)=" I FBNFDT=FBCFDT!(FBNFDT>FBCFDT) D  G:$G(FBRET) VENDAT1 Q"
^XMB(3.9,145986,2,3165,0)="""RTN"",""FBNHRAT1"",13,0)"
^XMB(3.9,145986,2,3166,0)=" .I FBNFDT>FBCTDT S FBRET=1 Q"
^XMB(3.9,145986,2,3167,0)="""RTN"",""FBNHRAT1"",14,0)"
^XMB(3.9,145986,2,3168,0)=" .I FBNTDT=FBCTDT D SET(FBNFDT,FBNTDT,I) Q"
^XMB(3.9,145986,2,3169,0)="""RTN"",""FBNHRAT1"",15,0)"
^XMB(3.9,145986,2,3170,0)=" .I FBNTDT<FBCTDT D SET(FBNFDT,FBNTDT,I) Q"
^XMB(3.9,145986,2,3171,0)="""RTN"",""FBNHRAT1"",16,0)"
^XMB(3.9,145986,2,3172,0)=" .I FBNTDT>FBCTDT D SET(FBNFDT,FBCTDT,I) S FBNFDT=$$CDTC^FBUCUTL(FBCTDT,1),FBRET=1 Q"
^XMB(3.9,145986,2,3173,0)="""RTN"",""FBNHRAT1"",17,0)"
^XMB(3.9,145986,2,3174,0)=" I FBNFDT<FBCFDT D  G:$G(FBRET) VENDAT1 Q"
^XMB(3.9,145986,2,3175,0)="""RTN"",""FBNHRAT1"",18,0)"
^XMB(3.9,145986,2,3176,0)=" .I FBNTDT<FBCFDT D:$G(FBDDT) CKSET(FBNFDT,FBNTDT) Q"
^XMB(3.9,145986,2,3177,0)="""RTN"",""FBNHRAT1"",19,0)"
^XMB(3.9,145986,2,3178,0)=" .I FBNTDT'>FBCTDT D:$G(FBDDT) CKSET(FBNFDT,$$CDTC^FBUCUTL(FBCFDT,-1)) S FBNFDT=FBCFDT D SET(FBNFDT,FBNTDT,I) Q"
^XMB(3.9,145986,2,3179,0)="""RTN"",""FBNHRAT1"",20,0)"
^XMB(3.9,145986,2,3180,0)=" .I FBNTDT>FBCTDT D:$G(FBDDT) CKSET(FBNFDT,$$CDTC^FBUCUTL(FBCFDT,-1)) S FBNFDT=FBCFDT D SET(FBNFDT,FBCTDT,I) S FBNFDT=$$CDTC^FBUCUTL(FBCTDT,1),FBRET=1 Q"
^XMB(3.9,145986,2,3181,0)="""RTN"",""FBNHRAT1"",21,0)"
^XMB(3.9,145986,2,3182,0)=" Q"
^XMB(3.9,145986,2,3183,0)="""RTN"",""FBNHRAT1"",22,0)"
^XMB(3.9,145986,2,3184,0)="SET(FBFR,FBTO,FBDFN) ;set up rate array for pt"
^XMB(3.9,145986,2,3185,0)="""RTN"",""FBNHRAT1"",23,0)"
^XMB(3.9,145986,2,3186,0)=" ;FBFR and FBTO are from and to dates to establish rates for"
^XMB(3.9,145986,2,3187,0)="""RTN"",""FBNHRAT1"",24,0)"
^XMB(3.9,145986,2,3188,0)=" ;FBDFN=DFN for pt."
^XMB(3.9,145986,2,3189,0)="""RTN"",""FBNHRAT1"",25,0)"
^XMB(3.9,145986,2,3190,0)=" ;FBNHARUP (optional)"
^XMB(3.9,145986,2,3191,0)="""RTN"",""FBNHRAT1"",26,0)"
^XMB(3.9,145986,2,3192,0)=" ;  if = ""N"" the call is during payment and a rate cannot be added"
^XMB(3.9,145986,2,3193,0)="""RTN"",""FBNHRAT1"",27,0)"
^XMB(3.9,145986,2,3194,0)=" ;  if = 1 rates are being monitored and a rate has not been added yet"
^XMB(3.9,145986,2,3195,0)="""RTN"",""FBNHRAT1"",28,0)"
^XMB(3.9,145986,2,3196,0)=" ;  if = 11 rates are being monitored and a rate has been added"
^XMB(3.9,145986,2,3197,0)="""RTN"",""FBNHRAT1"",29,0)"
^XMB(3.9,145986,2,3198,0)=" ;output FBFND=1 to indicate that a gap was found to create a rate for"
^XMB(3.9,145986,2,3199,0)="""RTN"",""FBNHRAT1"",30,0)"
^XMB(3.9,145986,2,3200,0)=" ;       FBNHARUP (optional) changed from 1 to 11 if rate added"
^XMB(3.9,145986,2,3201,0)="""RTN"",""FBNHRAT1"",31,0)"
^XMB(3.9,145986,2,3202,0)=" S FBFND=1"
^XMB(3.9,145986,2,3203,0)="""RTN"",""FBNHRAT1"",32,0)"
^XMB(3.9,145986,2,3204,0)=" W !!,*7,""Patient: "",$$NAME^FBCHREQ2(FBDFN),?40,""SSN: "",$$SSN^FBAAUTL(FBDFN)"
^XMB(3.9,145986,2,3205,0)="""RTN"",""FBNHRAT1"",33,0)"
^XMB(3.9,145986,2,3206,0)=" W !,?5,""Rate must be entered for the following period: "",$$DATX^FBAAUTL(FBFR),"" - "",$$DATX^FBAAUTL(FBTO)"
^XMB(3.9,145986,2,3207,0)="""RTN"",""FBNHRAT1"",34,0)"
^XMB(3.9,145986,2,3208,0)=" I $G(FBNHARUP)'=""N"" S FBRATE=1 ; when not ""N"" allow rate to be added"
^XMB(3.9,145986,2,3209,0)="""RTN"",""FBNHRAT1"",35,0)"
^XMB(3.9,145986,2,3210,0)=" D DISPLAY^FBAAVD1 K FBX I '$G(FBRATE) D:$G(FBDDT) CKSET(FBFR,FBTO) Q"
^XMB(3.9,145986,2,3211,0)="""RTN"",""FBNHRAT1"",36,0)"
^XMB(3.9,145986,2,3212,0)=" K DD,DO S DIC=""^FBAA(161.23,"",DIC(0)=""L"",X=FBFR,DIC(""DR"")="".02////^S X=FBTO;.03////^S X=FB7078;.04////^S X=FBDFN;.05////^S X=FBRATE;.06////^S X=FBCNUM"",DLAYGO=161.23 D FILE^DICN K DLAYGO,DIC,X"
^XMB(3.9,145986,2,3213,0)="""RTN"",""FBNHRAT1"",37,0)"
^XMB(3.9,145986,2,3214,0)=" I $G(FBNHARUP)=1 S FBNHARUP=11 ; let caller know a rate was added"
^XMB(3.9,145986,2,3215,0)="""RTN"",""FBNHRAT1"",38,0)"
^XMB(3.9,145986,2,3216,0)=" Q"
^XMB(3.9,145986,2,3217,0)="""RTN"",""FBNHRAT1"",39,0)"
^XMB(3.9,145986,2,3218,0)="CKSET(FRDT,TODT) ;sets FBUNR array for timeframe unable to establish rate for."
^XMB(3.9,145986,2,3219,0)="""RTN"",""FBNHRAT1"",40,0)"
^XMB(3.9,145986,2,3220,0)=" ;FBUNR array is only set if variable FBDDT is passed to subroutine"
^XMB(3.9,145986,2,3221,0)="""RTN"",""FBNHRAT1"",41,0)"
^XMB(3.9,145986,2,3222,0)=" ;and the attempt to create a rate (call to VENDAT) was unsuccessful."
^XMB(3.9,145986,2,3223,0)="""RTN"",""FBNHRAT1"",42,0)"
^XMB(3.9,145986,2,3224,0)=" ;FBUNR array, if defined, is returned to calling program."
^XMB(3.9,145986,2,3225,0)="""RTN"",""FBNHRAT1"",43,0)"
^XMB(3.9,145986,2,3226,0)=" ;FRDT=from date TODT=to date  of unsuccessful rate setup"
^XMB(3.9,145986,2,3227,0)="""RTN"",""FBNHRAT1"",44,0)"
^XMB(3.9,145986,2,3228,0)=" S FBUNR(FRDT,TODT)="""""
^XMB(3.9,145986,2,3229,0)="""RTN"",""FBNHRAT1"",45,0)"
^XMB(3.9,145986,2,3230,0)=" Q"
^XMB(3.9,145986,2,3231,0)="""RTN"",""FBPAY671"")"
^XMB(3.9,145986,2,3232,0)="0^4^B38061313"
^XMB(3.9,145986,2,3233,0)="""RTN"",""FBPAY671"",1,0)"
^XMB(3.9,145986,2,3234,0)="FBPAY671 ;AISC/DMK,TET,BPOIFO/MEC - CH/CNH PAYMENT HISTORY PRINT ; 9/14/09 3:34pm"
^XMB(3.9,145986,2,3235,0)="""RTN"",""FBPAY671"",2,0)"
^XMB(3.9,145986,2,3236,0)=" ;;3.5;FEE BASIS;**4,32,55,69,101,108**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,3237,0)="""RTN"",""FBPAY671"",3,0)"
^XMB(3.9,145986,2,3238,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145986,2,3239,0)="""RTN"",""FBPAY671"",4,0)"
^XMB(3.9,145986,2,3240,0)="PRINT ;print data from tmp global"
^XMB(3.9,145986,2,3241,0)="""RTN"",""FBPAY671"",5,0)"
^XMB(3.9,145986,2,3242,0)=" S FBOUT=0 D:FBCRT&(FBPG) CR Q:FBOUT"
^XMB(3.9,145986,2,3243,0)="""RTN"",""FBPAY671"",6,0)"
^XMB(3.9,145986,2,3244,0)=" S FBHEAD=$S(FBSORT:""VETERAN"",1:""VENDOR"")"
^XMB(3.9,145986,2,3245,0)="""RTN"",""FBPAY671"",7,0)"
^XMB(3.9,145986,2,3246,0)="EN1 N FBI,FBINV ;entry point from fbchdi"
^XMB(3.9,145986,2,3247,0)="""RTN"",""FBPAY671"",8,0)"
^XMB(3.9,145986,2,3248,0)=" D HDR S FBVI="""" F  S FBVI=$O(^TMP($J,""FB"",FBPI,FBVI)) Q:FBVI']""""!(FBOUT)  D:FBSORT SH Q:FBOUT  S FBPT="""" F  S FBPT=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT)) Q:FBPT']""""!(FBOUT)  D  Q:FBOUT  D CKANC Q:FBOUT"
^XMB(3.9,145986,2,3249,0)="""RTN"",""FBPAY671"",9,0)"
^XMB(3.9,145986,2,3250,0)=" .D:'FBSORT SH Q:FBOUT  S FBDT=0 F  S FBDT=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT)) Q:'FBDT!(FBOUT)  S FBI=0 F  S FBI=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI)) Q:'FBI!(FBOUT)  D  Q:FBOUT"
^XMB(3.9,145986,2,3251,0)="""RTN"",""FBPAY671"",10,0)"
^XMB(3.9,145986,2,3252,0)=" ..I ($Y+5)>IOSL D PAGE Q:FBOUT"
^XMB(3.9,145986,2,3253,0)="""RTN"",""FBPAY671"",11,0)"
^XMB(3.9,145986,2,3254,0)=" ..S FBDATA=^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI),A2=$$EXTRL^FBMRASVR($P(FBDATA,U,3))"
^XMB(3.9,145986,2,3255,0)="""RTN"",""FBPAY671"",12,0)"
^XMB(3.9,145986,2,3256,0)=" ..S FBINV=^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI,""FBINV"")"
^XMB(3.9,145986,2,3257,0)="""RTN"",""FBPAY671"",13,0)"
^XMB(3.9,145986,2,3258,0)=" ..W ! W:$P(FBDATA,U,8)[""R"" ""*"" W:$P(FBDATA,U,9)]"""" ""#"""
^XMB(3.9,145986,2,3259,0)="""RTN"",""FBPAY671"",14,0)"
^XMB(3.9,145986,2,3260,0)=" ..W ?2,$P(FBDATA,U,1),?15,$P(FBDATA,U,5),?31,$P(FBDATA,U,6)"
^XMB(3.9,145986,2,3261,0)="""RTN"",""FBPAY671"",15,0)"
^XMB(3.9,145986,2,3262,0)=" ..W ?47,$P(FBDATA,U,7),?57,$P(FBINV,U,2)"
^XMB(3.9,145986,2,3263,0)="""RTN"",""FBPAY671"",16,0)"
^XMB(3.9,145986,2,3264,0)=" ..W !?2,$P(FBDATA,U,2),?15,$P(FBDATA,U,3),?25,$P(FBINV,U,1)"
^XMB(3.9,145986,2,3265,0)="""RTN"",""FBPAY671"",17,0)"
^XMB(3.9,145986,2,3266,0)=" .. ;Print adj reasons, if null then print suspend code"
^XMB(3.9,145986,2,3267,0)="""RTN"",""FBPAY671"",18,0)"
^XMB(3.9,145986,2,3268,0)=" ..W ?36,$S($P(FBINV,U,5)]"""":$P(FBINV,U,5),1:$P(FBDATA,U,4))"
^XMB(3.9,145986,2,3269,0)="""RTN"",""FBPAY671"",19,0)"
^XMB(3.9,145986,2,3270,0)=" ..W ?46,$S($P(FBINV,U,5)]"""":$J($P(FBINV,U,6),14),1:$J($P(FBDATA,U,10),14))"
^XMB(3.9,145986,2,3271,0)="""RTN"",""FBPAY671"",20,0)"
^XMB(3.9,145986,2,3272,0)=" ..W ?63,$P(FBINV,U,7)"
^XMB(3.9,145986,2,3273,0)="""RTN"",""FBPAY671"",21,0)"
^XMB(3.9,145986,2,3274,0)=" .. ;If FPPS Claim ID exists then print it."
^XMB(3.9,145986,2,3275,0)="""RTN"",""FBPAY671"",22,0)"
^XMB(3.9,145986,2,3276,0)=" ..I $P(FBINV,U,3)]"""" D"
^XMB(3.9,145986,2,3277,0)="""RTN"",""FBPAY671"",23,0)"
^XMB(3.9,145986,2,3278,0)=" ...W !?5,""FPPS Claim ID: "",$P(FBINV,U,3),""    FPPS Line Item: "",$P(FBINV,U,4)"
^XMB(3.9,145986,2,3279,0)="""RTN"",""FBPAY671"",24,0)"
^XMB(3.9,145986,2,3280,0)=" .. ; write admitting diagnosis if present"
^XMB(3.9,145986,2,3281,0)="""RTN"",""FBPAY671"",25,0)"
^XMB(3.9,145986,2,3282,0)=" ..I $P(FBINV,U,8)'="""" W !?6,""Admit Dx: "",$P(FBINV,U,8)"
^XMB(3.9,145986,2,3283,0)="""RTN"",""FBPAY671"",26,0)"
^XMB(3.9,145986,2,3284,0)=" ..I $D(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI,""DX"")) S FBDATA=^(""DX""),FBSL=$L(FBDATA,""^"") F I=1:1:FBSL D WRTDX"
^XMB(3.9,145986,2,3285,0)="""RTN"",""FBPAY671"",27,0)"
^XMB(3.9,145986,2,3286,0)=" ..I $D(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI,""PROC"")) S FBDATA=^(""PROC""),FBSL=$L(FBDATA,""^"") F I=1:1:FBSL D WRTPC"
^XMB(3.9,145986,2,3287,0)="""RTN"",""FBPAY671"",28,0)"
^XMB(3.9,145986,2,3288,0)=" ..I $D(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI,""FBCK"")) D EFBCK^FBPAY21(^TMP($J,""FB"",FBPI,FBVI,FBPT,FBDT,FBI,""FBCK"")) D PMNT^FBAACCB2 K A2"
^XMB(3.9,145986,2,3289,0)="""RTN"",""FBPAY671"",29,0)"
^XMB(3.9,145986,2,3290,0)=" Q"
^XMB(3.9,145986,2,3291,0)="""RTN"",""FBPAY671"",30,0)"
^XMB(3.9,145986,2,3292,0)="CKANC I +$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",0)) D PANC(FBI) Q:FBOUT  W !,FBDASH1"
^XMB(3.9,145986,2,3293,0)="""RTN"",""FBPAY671"",31,0)"
^XMB(3.9,145986,2,3294,0)=" Q"
^XMB(3.9,145986,2,3295,0)="""RTN"",""FBPAY671"",32,0)"
^XMB(3.9,145986,2,3296,0)="PANC(FBI) ;print anc data - FBI = unique number; called by fbpay3"
^XMB(3.9,145986,2,3297,0)="""RTN"",""FBPAY671"",33,0)"
^XMB(3.9,145986,2,3298,0)=" S (FBOV,FBK)=0,FBSL=8,FBLOC=1_U_12_U_23_U_33_U_43_U_56_U_62_U_71 D SHA Q:FBOUT"
^XMB(3.9,145986,2,3299,0)="""RTN"",""FBPAY671"",34,0)"
^XMB(3.9,145986,2,3300,0)=" F  S FBK=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK)) Q:'FBK!(FBOUT)  S FBL=0 F  S FBL=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK,FBL)) Q:'FBL!(FBOUT)  S FBM=0 F  S FBM=$O(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK,FBL,FBM)) Q:'FBM!(FBOUT)  D"
^XMB(3.9,145986,2,3301,0)="""RTN"",""FBPAY671"",35,0)"
^XMB(3.9,145986,2,3302,0)=" .S FBDATA=^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK,FBL,FBM)"
^XMB(3.9,145986,2,3303,0)="""RTN"",""FBPAY671"",36,0)"
^XMB(3.9,145986,2,3304,0)=" .S FBV=$P(FBDATA,U,12)_"";""_$P(FBDATA,U,13)"
^XMB(3.9,145986,2,3305,0)="""RTN"",""FBPAY671"",37,0)"
^XMB(3.9,145986,2,3306,0)=" .D WRT"
^XMB(3.9,145986,2,3307,0)="""RTN"",""FBPAY671"",38,0)"
^XMB(3.9,145986,2,3308,0)=" K FBK,FBL,FBM Q"
^XMB(3.9,145986,2,3309,0)="""RTN"",""FBPAY671"",39,0)"
^XMB(3.9,145986,2,3310,0)="WRT ;write ancillary info"
^XMB(3.9,145986,2,3311,0)="""RTN"",""FBPAY671"",40,0)"
^XMB(3.9,145986,2,3312,0)=" I ($Y+6)>IOSL D PAGE Q:FBOUT  D SHA Q:FBOUT  D SHA2 Q:FBOUT"
^XMB(3.9,145986,2,3313,0)="""RTN"",""FBPAY671"",41,0)"
^XMB(3.9,145986,2,3314,0)=" D:FBOV'=FBV SHA2"
^XMB(3.9,145986,2,3315,0)="""RTN"",""FBPAY671"",42,0)"
^XMB(3.9,145986,2,3316,0)=" S FBCKIN=$G(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK,FBL,FBM,""FBCK"")) D EFBCK^FBPAY21(FBCKIN)"
^XMB(3.9,145986,2,3317,0)="""RTN"",""FBPAY671"",43,0)"
^XMB(3.9,145986,2,3318,0)=" S FBADJ=$G(^TMP($J,""FB"",FBPI,FBVI,FBPT,""A"",FBK,FBL,FBM,""FBADJ""))"
^XMB(3.9,145986,2,3319,0)="""RTN"",""FBPAY671"",44,0)"
^XMB(3.9,145986,2,3320,0)=" W ! W:$G(FBCAN)]"""" ""+"""
^XMB(3.9,145986,2,3321,0)="""RTN"",""FBPAY671"",45,0)"
^XMB(3.9,145986,2,3322,0)=" W ?1,$P(FBDATA,U,1)"
^XMB(3.9,145986,2,3323,0)="""RTN"",""FBPAY671"",46,0)"
^XMB(3.9,145986,2,3324,0)=" W ?11,$P($P(FBDATA,U,2),"","")"
^XMB(3.9,145986,2,3325,0)="""RTN"",""FBPAY671"",47,0)"
^XMB(3.9,145986,2,3326,0)=" W ?22,$P(FBADJ,U,9)"
^XMB(3.9,145986,2,3327,0)="""RTN"",""FBPAY671"",48,0)"
^XMB(3.9,145986,2,3328,0)=" W ?31,$J($P(FBADJ,U,2),10)"
^XMB(3.9,145986,2,3329,0)="""RTN"",""FBPAY671"",49,0)"
^XMB(3.9,145986,2,3330,0)=" W ?43,$P(FBDATA,U,6)"
^XMB(3.9,145986,2,3331,0)="""RTN"",""FBPAY671"",50,0)"
^XMB(3.9,145986,2,3332,0)=" W ?54,$P(FBDATA,U,7)"
^XMB(3.9,145986,2,3333,0)="""RTN"",""FBPAY671"",51,0)"
^XMB(3.9,145986,2,3334,0)=" W ?64,$P(FBDATA,U,8)"
^XMB(3.9,145986,2,3335,0)="""RTN"",""FBPAY671"",52,0)"
^XMB(3.9,145986,2,3336,0)=" I $P($P(FBDATA,U,2),"","",2)]"""" D  Q:FBOUT"
^XMB(3.9,145986,2,3337,0)="""RTN"",""FBPAY671"",53,0)"
^XMB(3.9,145986,2,3338,0)=" . N FBI,FBMOD"
^XMB(3.9,145986,2,3339,0)="""RTN"",""FBPAY671"",54,0)"
^XMB(3.9,145986,2,3340,0)=" . F FBI=2:1 S FBMOD=$P($P(FBDATA,U,2),"","",FBI) Q:FBMOD=""""  D  Q:FBOUT"
^XMB(3.9,145986,2,3341,0)="""RTN"",""FBPAY671"",55,0)"
^XMB(3.9,145986,2,3342,0)=" . . I $Y+7>IOSL D PAGE Q:FBOUT  D SHA Q:FBOUT  D SHA2 Q:FBOUT  W !,""  (continued)"""
^XMB(3.9,145986,2,3343,0)="""RTN"",""FBPAY671"",56,0)"
^XMB(3.9,145986,2,3344,0)=" . . W !?16,""-"",FBMOD"
^XMB(3.9,145986,2,3345,0)="""RTN"",""FBPAY671"",57,0)"
^XMB(3.9,145986,2,3346,0)=" W !,$P(FBDATA,U,3)"
^XMB(3.9,145986,2,3347,0)="""RTN"",""FBPAY671"",58,0)"
^XMB(3.9,145986,2,3348,0)=" W ?13,$P(FBDATA,U,4)"
^XMB(3.9,145986,2,3349,0)="""RTN"",""FBPAY671"",59,0)"
^XMB(3.9,145986,2,3350,0)=" W ?23,$S($P(FBADJ,U,3)]"""":$P(FBADJ,U,3),1:$P(FBDATA,U,5))"
^XMB(3.9,145986,2,3351,0)="""RTN"",""FBPAY671"",60,0)"
^XMB(3.9,145986,2,3352,0)=" W ?33,$J($S($P(FBADJ,U,4)]"""":$J($P(FBADJ,U,4),14),1:$P(FBADJ,U,1)),14)"
^XMB(3.9,145986,2,3353,0)="""RTN"",""FBPAY671"",61,0)"
^XMB(3.9,145986,2,3354,0)=" W ?48,$P(FBADJ,U,5)"
^XMB(3.9,145986,2,3355,0)="""RTN"",""FBPAY671"",62,0)"
^XMB(3.9,145986,2,3356,0)=" W ?60,$P(FBADJ,U,6)"
^XMB(3.9,145986,2,3357,0)="""RTN"",""FBPAY671"",63,0)"
^XMB(3.9,145986,2,3358,0)=" ;If FPPS Claim ID exists then print it."
^XMB(3.9,145986,2,3359,0)="""RTN"",""FBPAY671"",64,0)"
^XMB(3.9,145986,2,3360,0)=" I $P(FBADJ,U,7)]"""" D"
^XMB(3.9,145986,2,3361,0)="""RTN"",""FBPAY671"",65,0)"
^XMB(3.9,145986,2,3362,0)=" .W !?5,""FPPS Claim ID: "",$P(FBADJ,U,7),""    FPPS Line Item: "",$P(FBADJ,U,8)"
^XMB(3.9,145986,2,3363,0)="""RTN"",""FBPAY671"",66,0)"
^XMB(3.9,145986,2,3364,0)=" W !?4,""Primary Dx: "",$P(FBDATA,U,10),?40,""S/C Condition? "",$P(FBDATA,U,9),?66,""Obl.#: "",$P(FBDATA,U,11)"
^XMB(3.9,145986,2,3365,0)="""RTN"",""FBPAY671"",67,0)"
^XMB(3.9,145986,2,3366,0)=" N A2 S A2=$$EXTRL^FBMRASVR($P(FBDATA,U,4))"
^XMB(3.9,145986,2,3367,0)="""RTN"",""FBPAY671"",68,0)"
^XMB(3.9,145986,2,3368,0)=" D PMNT^FBAACCB2"
^XMB(3.9,145986,2,3369,0)="""RTN"",""FBPAY671"",69,0)"
^XMB(3.9,145986,2,3370,0)=" Q"
^XMB(3.9,145986,2,3371,0)="""RTN"",""FBPAY671"",70,0)"
^XMB(3.9,145986,2,3372,0)="HDR ;main header"
^XMB(3.9,145986,2,3373,0)="""RTN"",""FBPAY671"",71,0)"
^XMB(3.9,145986,2,3374,0)=" I FBPG>0!FBCRT W @IOF"
^XMB(3.9,145986,2,3375,0)="""RTN"",""FBPAY671"",72,0)"
^XMB(3.9,145986,2,3376,0)=" S FBPG=FBPG+1"
^XMB(3.9,145986,2,3377,0)="""RTN"",""FBPAY671"",73,0)"
^XMB(3.9,145986,2,3378,0)=" I $D(FBHEAD) D"
^XMB(3.9,145986,2,3379,0)="""RTN"",""FBPAY671"",74,0)"
^XMB(3.9,145986,2,3380,0)=" .W !?25,FBHEAD_"" PAYMENT HISTORY"""
^XMB(3.9,145986,2,3381,0)="""RTN"",""FBPAY671"",75,0)"
^XMB(3.9,145986,2,3382,0)=" .I $G(FB1725R)]"""",FB1725R'=""A"" W "" "",$S(FB1725R=""M"":""for 38 U.S.C. 1725 Claims"",1:""excluding 38 U.S.C. 1725 Claims"")"
^XMB(3.9,145986,2,3383,0)="""RTN"",""FBPAY671"",76,0)"
^XMB(3.9,145986,2,3384,0)=" .W !,?24,$E(FBDASH,1,24),?71,""Page: "",FBPG,!?48,""Date Range: "",$$DATX^FBAAUTL(FBBDATE),"" to "",$$DATX^FBAAUTL(FBEDATE)"
^XMB(3.9,145986,2,3385,0)="""RTN"",""FBPAY671"",77,0)"
^XMB(3.9,145986,2,3386,0)=" I '$D(FBHEAD) W !?30,""INVOICE DISPLAY"",!?29,$E(FBDASH,1,17),!"
^XMB(3.9,145986,2,3387,0)="""RTN"",""FBPAY671"",78,0)"
^XMB(3.9,145986,2,3388,0)=" W ! W:FBSORT ""Patient: "",FBPNAME,?41,""Patient ID: "",FBPID W:'FBSORT ""Vendor: "",FBVNAME,?41,""Vendor ID: "",FBVID"
^XMB(3.9,145986,2,3389,0)="""RTN"",""FBPAY671"",79,0)"
^XMB(3.9,145986,2,3390,0)=" W !?(IOM-(13+$L(FBPROG(+FBPI)))/2),""FEE PROGRAM: "",FBPROG(+FBPI)"
^XMB(3.9,145986,2,3391,0)="""RTN"",""FBPAY671"",80,0)"
^XMB(3.9,145986,2,3392,0)=" W !?3,""('*' Reimb. to Patient  '+' Cancel. Activity  '#' Voided Payment)"""
^XMB(3.9,145986,2,3393,0)="""RTN"",""FBPAY671"",81,0)"
^XMB(3.9,145986,2,3394,0)=" W !,?3,""(paid symbol: 'R' RBRVS  'F' 75th percentile  'C' contract  'M' Mill Bill"""
^XMB(3.9,145986,2,3395,0)="""RTN"",""FBPAY671"",82,0)"
^XMB(3.9,145986,2,3396,0)=" W !,?3,""              'U' U&C)"""
^XMB(3.9,145986,2,3397,0)="""RTN"",""FBPAY671"",83,0)"
^XMB(3.9,145986,2,3398,0)=" W !?1,""Invoice Date"",?15,""Invoice No."",?31,""From Date"",?48,""To Date"",?57,""Patient Control #"""
^XMB(3.9,145986,2,3399,0)="""RTN"",""FBPAY671"",84,0)"
^XMB(3.9,145986,2,3400,0)=" W !?1,""Amt Claimed"",?15,""Amt Paid"",?25,""Cov Days"",?36,""Adj Codes"",?49,""Adj Amounts"",?63,""Remit Remarks"",!,FBDASH"
^XMB(3.9,145986,2,3401,0)="""RTN"",""FBPAY671"",85,0)"
^XMB(3.9,145986,2,3402,0)=" Q"
^XMB(3.9,145986,2,3403,0)="""RTN"",""FBPAY671"",86,0)"
^XMB(3.9,145986,2,3404,0)="SH ;subheader - vendor if fbsort; patient if 'fbsort, prints when name changed"
^XMB(3.9,145986,2,3405,0)="""RTN"",""FBPAY671"",87,0)"
