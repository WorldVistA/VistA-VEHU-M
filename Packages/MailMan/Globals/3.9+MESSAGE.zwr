^XMB(3.9,145960,2,347,0)="""RTN"",""MAGGTU4T"",47,0)"
^XMB(3.9,145960,2,348,0)=" ;        - Patch 182"
^XMB(3.9,145960,2,349,0)="""RTN"",""MAGGTU4T"",48,0)"
