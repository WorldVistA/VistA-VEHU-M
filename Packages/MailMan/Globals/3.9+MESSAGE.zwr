^XMB(3.9,145986,2,1844,0)="HED I FBREF=""FB583"" W !?22,$S(FB1725R=""M"":""MILL BILL (1725) "",FB1725R=""N"":""  NON-MILL BILL "",1:""        ""),""UNAUTHORIZED CLAIMS"""
^XMB(3.9,145986,2,1845,0)="""RTN"",""FBCHCR"",44,0)"
^XMB(3.9,145986,2,1846,0)=" W !,@$S(FBTP=6:""?25"",1:""?22""),""COST REPORT FOR "",$S(FBTP=6:""CIVIL HOSPITAL"",1:""CONTRACT NURSING HOME""),!?28,$$DATX^FBAAUTL(BEGDATE),"" THROUGH "",$$DATX^FBAAUTL(ENDDATE),!,@$S(FBTP=6:""?25"",1:""?22""),Q I FBTP=7 F J=1:1:7 W ""-"""
^XMB(3.9,145986,2,1847,0)="""RTN"",""FBCHCR"",45,0)"
^XMB(3.9,145986,2,1848,0)=" I $G(FBEND) D HED2 Q"
^XMB(3.9,145986,2,1849,0)="""RTN"",""FBCHCR"",46,0)"
^XMB(3.9,145986,2,1850,0)=" W !!!,""PATIENT NAME"",?25,""PATIENT ID"""
^XMB(3.9,145986,2,1851,0)="""RTN"",""FBCHCR"",47,0)"
^XMB(3.9,145986,2,1852,0)=" I FBREF=""FB583"" W ?40,""DT CLAIM REC"""
^XMB(3.9,145986,2,1853,0)="""RTN"",""FBCHCR"",48,0)"
^XMB(3.9,145986,2,1854,0)=" I FBREF=""FB7078"" W ?40,""ASSOC 7078"""
^XMB(3.9,145986,2,1855,0)="""RTN"",""FBCHCR"",49,0)"
