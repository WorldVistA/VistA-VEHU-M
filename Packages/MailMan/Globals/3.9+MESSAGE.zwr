^XMB(3.9,145946,2,4936,0)="UNSEL(SELECTED) ;EP"
^XMB(3.9,145946,2,4937,0)="""RTN"",""IBCNILK"",300,0)"
^XMB(3.9,145946,2,4938,0)=" ; Protocol Action to deselect an already selected insurance company"
