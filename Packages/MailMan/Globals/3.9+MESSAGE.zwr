^XMB(3.9,145982,2,612,0)="This field will be displayed as the first address field on patient"
^XMB(3.9,145982,2,613,0)="""^DD"",340,340,1.01,21,9,0)"
^XMB(3.9,145982,2,614,0)="statements and profiles."
