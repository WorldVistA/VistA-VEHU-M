^XMB(3.9,145952,2,1747,0)="""RTN"",""SDES2CLINICLIST"",28,0)"
^XMB(3.9,145952,2,1748,0)=" I $D(ERRORS) S ERRORS(""Clinics"")="""" D BUILDJSON^SDES2JSON(.RETNJSON,.ERRORS) Q"
^XMB(3.9,145952,2,1749,0)="""RTN"",""SDES2CLINICLIST"",29,0)"
^XMB(3.9,145952,2,1750,0)=" D BUILDCLINICS(.RETNJSON,.SDCONTEXT,.SDPARAM,.ERRORS)"
^XMB(3.9,145952,2,1751,0)="""RTN"",""SDES2CLINICLIST"",30,0)"
^XMB(3.9,145952,2,1752,0)=" Q"
^XMB(3.9,145952,2,1753,0)="""RTN"",""SDES2CLINICLIST"",31,0)"
^XMB(3.9,145952,2,1754,0)=" ;"
^XMB(3.9,145952,2,1755,0)="""RTN"",""SDES2CLINICLIST"",32,0)"
^XMB(3.9,145952,2,1756,0)="BUILDCLINICS(RETNJSON,SDCONTEXT,SDPARAM,ERRORS) ; "
^XMB(3.9,145952,2,1757,0)="""RTN"",""SDES2CLINICLIST"",33,0)"
^XMB(3.9,145952,2,1758,0)=" N APPTLIST,IENCOUNT,YESTERDAYFM,TODAYFM,CLINICIEN,PRVUSERS,CLINTODAY,TODAY"
^XMB(3.9,145952,2,1759,0)="""RTN"",""SDES2CLINICLIST"",34,0)"
^XMB(3.9,145952,2,1760,0)=" S TODAY=$$FMTISO^SDAMUTDT($$NOW^XLFDT)"
^XMB(3.9,145952,2,1761,0)="""RTN"",""SDES2CLINICLIST"",35,0)"
^XMB(3.9,145952,2,1762,0)=" S IENCOUNT=0"
^XMB(3.9,145952,2,1763,0)="""RTN"",""SDES2CLINICLIST"",36,0)"
^XMB(3.9,145952,2,1764,0)=" F  S IENCOUNT=$O(SDPARAM(""CLINIC IEN"",IENCOUNT)) Q:'IENCOUNT  S CLINICIEN=SDPARAM(""CLINIC IEN"",IENCOUNT) D"
^XMB(3.9,145952,2,1765,0)="""RTN"",""SDES2CLINICLIST"",37,0)"
^XMB(3.9,145952,2,1766,0)=" . N TEMPLIST,DIVISION,INSTITUT,STATION"
^XMB(3.9,145952,2,1767,0)="""RTN"",""SDES2CLINICLIST"",38,0)"
^XMB(3.9,145952,2,1768,0)=" . S CLINTODAY=$P($$ISOTFM^SDAMUTDT(TODAY,CLINICIEN),""."",1)"
^XMB(3.9,145952,2,1769,0)="""RTN"",""SDES2CLINICLIST"",39,0)"
^XMB(3.9,145952,2,1770,0)=" . S YESTERDAYFM=$$FMADD^XLFDT(CLINTODAY,"""","""","""",-1)"
^XMB(3.9,145952,2,1771,0)="""RTN"",""SDES2CLINICLIST"",40,0)"
^XMB(3.9,145952,2,1772,0)=" . S TODAYFM=$$FMADD^XLFDT(CLINTODAY,"""",23,59,59)"
^XMB(3.9,145952,2,1773,0)="""RTN"",""SDES2CLINICLIST"",41,0)"
^XMB(3.9,145952,2,1774,0)=" . D APPTBYCLINIC2(.TEMPLIST,CLINICIEN,YESTERDAYFM,TODAYFM,$G(SDCONTEXT(""ACHERON AUDIT ID"")))"
^XMB(3.9,145952,2,1775,0)="""RTN"",""SDES2CLINICLIST"",42,0)"
^XMB(3.9,145952,2,1776,0)=" . S DIVISION=$$GET1^DIQ(44,CLINICIEN,3.5,""I"")"
^XMB(3.9,145952,2,1777,0)="""RTN"",""SDES2CLINICLIST"",43,0)"
^XMB(3.9,145952,2,1778,0)=" . S INSTITUT=$$GET1^DIQ(40.8,DIVISION,.07,""I"")"
^XMB(3.9,145952,2,1779,0)="""RTN"",""SDES2CLINICLIST"",44,0)"
^XMB(3.9,145952,2,1780,0)=" . S STATION=$$GET1^DIQ(4,INSTITUT,99,""I"")"
^XMB(3.9,145952,2,1781,0)="""RTN"",""SDES2CLINICLIST"",45,0)"
^XMB(3.9,145952,2,1782,0)=" . S APPTLIST(""Clinics"",IENCOUNT,""Station"")=STATION"
^XMB(3.9,145952,2,1783,0)="""RTN"",""SDES2CLINICLIST"",46,0)"
^XMB(3.9,145952,2,1784,0)=" . S APPTLIST(""Clinics"",IENCOUNT,""IEN"")=CLINICIEN"
^XMB(3.9,145952,2,1785,0)="""RTN"",""SDES2CLINICLIST"",47,0)"
^XMB(3.9,145952,2,1786,0)=" . M APPTLIST(""Clinics"",IENCOUNT)=TEMPLIST"
^XMB(3.9,145952,2,1787,0)="""RTN"",""SDES2CLINICLIST"",48,0)"
^XMB(3.9,145952,2,1788,0)=" D BUILDJSON^SDES2JSON(.RETNJSON,.APPTLIST)"
^XMB(3.9,145952,2,1789,0)="""RTN"",""SDES2CLINICLIST"",49,0)"
^XMB(3.9,145952,2,1790,0)=" Q"
^XMB(3.9,145952,2,1791,0)="""RTN"",""SDES2CLINICLIST"",50,0)"
^XMB(3.9,145952,2,1792,0)=" ;"
^XMB(3.9,145952,2,1793,0)="""RTN"",""SDES2CLINICLIST"",51,0)"
^XMB(3.9,145952,2,1794,0)="VALPARAM(ERRORS,SDPARAM) ; Validate the clinics in the INPUTARRAY"
^XMB(3.9,145952,2,1795,0)="""RTN"",""SDES2CLINICLIST"",52,0)"
^XMB(3.9,145952,2,1796,0)=" N INDEX,CLNIEN S INDEX="""""
^XMB(3.9,145952,2,1797,0)="""RTN"",""SDES2CLINICLIST"",53,0)"
^XMB(3.9,145952,2,1798,0)=" I $D(SDPARAM(""CLINIC IEN""))'>1 D ERRLOG^SDES2JSON(.ERRORS,18) Q  ; no clinic array to build "
^XMB(3.9,145952,2,1799,0)="""RTN"",""SDES2CLINICLIST"",54,0)"
^XMB(3.9,145952,2,1800,0)=" ; Check the clinic IEN to make sure they are valid"
^XMB(3.9,145952,2,1801,0)="""RTN"",""SDES2CLINICLIST"",55,0)"
^XMB(3.9,145952,2,1802,0)=" F  S INDEX=$O(SDPARAM(""CLINIC IEN"",INDEX)) Q:INDEX=""""  S CLNIEN=SDPARAM(""CLINIC IEN"",INDEX) D VALCLINIEN^SDES2VAL44(.ERRORS,CLNIEN,1,0)"
^XMB(3.9,145952,2,1803,0)="""RTN"",""SDES2CLINICLIST"",56,0)"
^XMB(3.9,145952,2,1804,0)=" Q"
^XMB(3.9,145952,2,1805,0)="""RTN"",""SDES2CLINICLIST"",57,0)"
^XMB(3.9,145952,2,1806,0)=" ;"
^XMB(3.9,145952,2,1807,0)="""RTN"",""SDES2CLINICLIST"",58,0)"
^XMB(3.9,145952,2,1808,0)="APPTBYCLINIC2(SDAPPT,SDCLINICIEN,SDBEG,SDEND,SDEAS) ;"
^XMB(3.9,145952,2,1809,0)="""RTN"",""SDES2CLINICLIST"",59,0)"
^XMB(3.9,145952,2,1810,0)=" N POP,APPTIEN,APPTDT,APPTDATA,COUNTER,JSONERR,DFN,PATIENT,RESTYPE,SDRESIEN"
^XMB(3.9,145952,2,1811,0)="""RTN"",""SDES2CLINICLIST"",60,0)"
^XMB(3.9,145952,2,1812,0)=" S (POP,APPTIEN,COUNTER,JSONERR)="""""
^XMB(3.9,145952,2,1813,0)="""RTN"",""SDES2CLINICLIST"",61,0)"
^XMB(3.9,145952,2,1814,0)=" K SDECY"
^XMB(3.9,145952,2,1815,0)="""RTN"",""SDES2CLINICLIST"",62,0)"
^XMB(3.9,145952,2,1816,0)=" ;Validate input parameters"
^XMB(3.9,145952,2,1817,0)="""RTN"",""SDES2CLINICLIST"",63,0)"
^XMB(3.9,145952,2,1818,0)=" S SDBEG=$G(SDBEG)"
^XMB(3.9,145952,2,1819,0)="""RTN"",""SDES2CLINICLIST"",64,0)"
^XMB(3.9,145952,2,1820,0)=" S SDEND=$G(SDEND)"
^XMB(3.9,145952,2,1821,0)="""RTN"",""SDES2CLINICLIST"",65,0)"
^XMB(3.9,145952,2,1822,0)=" S SDRESIEN="""""
^XMB(3.9,145952,2,1823,0)="""RTN"",""SDES2CLINICLIST"",66,0)"
^XMB(3.9,145952,2,1824,0)=" F  S SDRESIEN=$O(^SDEC(409.831,""ALOC"",SDCLINICIEN,SDRESIEN)) Q:SDRESIEN=""""  D"
^XMB(3.9,145952,2,1825,0)="""RTN"",""SDES2CLINICLIST"",67,0)"
^XMB(3.9,145952,2,1826,0)=" . S RESTYPE=$P($G(^SDEC(409.831,SDRESIEN,0)),""^"",11)"
^XMB(3.9,145952,2,1827,0)="""RTN"",""SDES2CLINICLIST"",68,0)"
^XMB(3.9,145952,2,1828,0)=" . I $P(RESTYPE,"";"",2)'=""SC("" Q    ;Must be a Hospital Loc"
^XMB(3.9,145952,2,1829,0)="""RTN"",""SDES2CLINICLIST"",69,0)"
^XMB(3.9,145952,2,1830,0)=" . S APPTDT=SDBEG"
^XMB(3.9,145952,2,1831,0)="""RTN"",""SDES2CLINICLIST"",70,0)"
^XMB(3.9,145952,2,1832,0)=" . F  S APPTDT=$O(^SDEC(409.84,""ARSRC"",SDRESIEN,APPTDT)) Q:APPTDT=""""  D  Q:POP"
^XMB(3.9,145952,2,1833,0)="""RTN"",""SDES2CLINICLIST"",71,0)"
^XMB(3.9,145952,2,1834,0)=" .. I SDEND,APPTDT>SDEND S POP=1 Q  ;End loop since past the end date"
^XMB(3.9,145952,2,1835,0)="""RTN"",""SDES2CLINICLIST"",72,0)"
^XMB(3.9,145952,2,1836,0)=" .. S APPTIEN="""""
^XMB(3.9,145952,2,1837,0)="""RTN"",""SDES2CLINICLIST"",73,0)"
^XMB(3.9,145952,2,1838,0)=" .. F  S APPTIEN=$O(^SDEC(409.84,""ARSRC"",SDRESIEN,APPTDT,APPTIEN)) Q:APPTIEN=""""  D"
^XMB(3.9,145952,2,1839,0)="""RTN"",""SDES2CLINICLIST"",74,0)"
^XMB(3.9,145952,2,1840,0)=" ... D SUMMARY(.APPTDATA,APPTIEN)"
^XMB(3.9,145952,2,1841,0)="""RTN"",""SDES2CLINICLIST"",75,0)"
^XMB(3.9,145952,2,1842,0)=" ... S COUNTER=$G(COUNTER)+1"
^XMB(3.9,145952,2,1843,0)="""RTN"",""SDES2CLINICLIST"",76,0)"
^XMB(3.9,145952,2,1844,0)=" ... M SDAPPT(""Appt"",COUNTER)=APPTDATA"
^XMB(3.9,145952,2,1845,0)="""RTN"",""SDES2CLINICLIST"",77,0)"
^XMB(3.9,145952,2,1846,0)=" ... S DFN=$G(SDAPPT(""Appt"",COUNTER,""DFN""))"
^XMB(3.9,145952,2,1847,0)="""RTN"",""SDES2CLINICLIST"",78,0)"
^XMB(3.9,145952,2,1848,0)=" ... S PATIENT="""""
^XMB(3.9,145952,2,1849,0)="""RTN"",""SDES2CLINICLIST"",79,0)"
^XMB(3.9,145952,2,1850,0)=" ... D PATIENTADDON^SDES2PATDATA(.PATIENT,DFN)"
^XMB(3.9,145952,2,1851,0)="""RTN"",""SDES2CLINICLIST"",80,0)"
^XMB(3.9,145952,2,1852,0)=" ... M SDAPPT(""Appt"",COUNTER,""Patient"")=PATIENT"
^XMB(3.9,145952,2,1853,0)="""RTN"",""SDES2CLINICLIST"",81,0)"
^XMB(3.9,145952,2,1854,0)=" I '$D(SDAPPT(""Appt"")) S SDAPPT(""Appt"")="""""
^XMB(3.9,145952,2,1855,0)="""RTN"",""SDES2CLINICLIST"",82,0)"
^XMB(3.9,145952,2,1856,0)=" Q"
^XMB(3.9,145952,2,1857,0)="""RTN"",""SDES2CLINICLIST"",83,0)"
^XMB(3.9,145952,2,1858,0)=" ;"
^XMB(3.9,145952,2,1859,0)="""RTN"",""SDES2CLINICLIST"",84,0)"
^XMB(3.9,145952,2,1860,0)="SUMMARY(APPTDATA,IEN) ;"
^XMB(3.9,145952,2,1861,0)="""RTN"",""SDES2CLINICLIST"",85,0)"
^XMB(3.9,145952,2,1862,0)=" ;Returns a basic set of data for a specific appointment"
^XMB(3.9,145952,2,1863,0)="""RTN"",""SDES2CLINICLIST"",86,0)"
^XMB(3.9,145952,2,1864,0)=" ;"
^XMB(3.9,145952,2,1865,0)="""RTN"",""SDES2CLINICLIST"",87,0)"
^XMB(3.9,145952,2,1866,0)=" ; Input"
^XMB(3.9,145952,2,1867,0)="""RTN"",""SDES2CLINICLIST"",88,0)"
^XMB(3.9,145952,2,1868,0)=" ;  IEN - Specific appointment IEN"
^XMB(3.9,145952,2,1869,0)="""RTN"",""SDES2CLINICLIST"",89,0)"
^XMB(3.9,145952,2,1870,0)=" ; Return"
^XMB(3.9,145952,2,1871,0)="""RTN"",""SDES2CLINICLIST"",90,0)"
^XMB(3.9,145952,2,1872,0)=" ;  APPTDATA - Array of field names and the data for the field based on the IEN"
^XMB(3.9,145952,2,1873,0)="""RTN"",""SDES2CLINICLIST"",91,0)"
^XMB(3.9,145952,2,1874,0)=" ;"
^XMB(3.9,145952,2,1875,0)="""RTN"",""SDES2CLINICLIST"",92,0)"
^XMB(3.9,145952,2,1876,0)=" N APPTARY,FN,IENS,SDMSG,SDDFN,RESOURCEIEN,CLINICIEN,SIEN,OVERBOOK,STIME,ETIME,X"
^XMB(3.9,145952,2,1877,0)="""RTN"",""SDES2CLINICLIST"",93,0)"
^XMB(3.9,145952,2,1878,0)=" N DATETIME,NUM,STATPOINTER,CLINICARY,STAT,CLINICDATA,PROV,CLINICAPPT,CUSER"
^XMB(3.9,145952,2,1879,0)="""RTN"",""SDES2CLINICLIST"",94,0)"
^XMB(3.9,145952,2,1880,0)=" K APPTDATA"
^XMB(3.9,145952,2,1881,0)="""RTN"",""SDES2CLINICLIST"",95,0)"
^XMB(3.9,145952,2,1882,0)=" S FN=409.84,IENS=IEN_"","",OVERBOOK=0"
^XMB(3.9,145952,2,1883,0)="""RTN"",""SDES2CLINICLIST"",96,0)"
^XMB(3.9,145952,2,1884,0)=" D GETS^DIQ(FN,IENS,"".01;.02;.03;.04;.05;.06;.07;.12;.13;.121;.122;.14;.16;.17;.18;.22;1;3;4;100"",""IE"",""APPTARY"",""SDMSG"") ;SD,814-Added 100 for the EAS Tracking Number"
^XMB(3.9,145952,2,1885,0)="""RTN"",""SDES2CLINICLIST"",97,0)"
^XMB(3.9,145952,2,1886,0)=" S RESOURCEIEN=$G(APPTARY(FN,IENS,.07,""I""))"
^XMB(3.9,145952,2,1887,0)="""RTN"",""SDES2CLINICLIST"",98,0)"
^XMB(3.9,145952,2,1888,0)=" S CLINICIEN=$$GET1^DIQ(409.831,RESOURCEIEN,.04,""I"")"
^XMB(3.9,145952,2,1889,0)="""RTN"",""SDES2CLINICLIST"",99,0)"
^XMB(3.9,145952,2,1890,0)=" S APPTDATA(""StartTime"")=$G(APPTARY(FN,IENS,.01,""E""))"
^XMB(3.9,145952,2,1891,0)="""RTN"",""SDES2CLINICLIST"",100,0)"
^XMB(3.9,145952,2,1892,0)=" S APPTDATA(""StartTimeFM"")=$G(APPTARY(FN,IENS,.01,""I""))"
^XMB(3.9,145952,2,1893,0)="""RTN"",""SDES2CLINICLIST"",101,0)"
^XMB(3.9,145952,2,1894,0)=" S STIME=$G(APPTARY(FN,IENS,.01,""I""))"
^XMB(3.9,145952,2,1895,0)="""RTN"",""SDES2CLINICLIST"",102,0)"
^XMB(3.9,145952,2,1896,0)=" S APPTDATA(""EndTime"")=$G(APPTARY(FN,IENS,.02,""E""))"
^XMB(3.9,145952,2,1897,0)="""RTN"",""SDES2CLINICLIST"",103,0)"
^XMB(3.9,145952,2,1898,0)=" S ETIME=$G(APPTARY(FN,IENS,.02,""I""))"
^XMB(3.9,145952,2,1899,0)="""RTN"",""SDES2CLINICLIST"",104,0)"
^XMB(3.9,145952,2,1900,0)=" S APPTDATA(""AppointmentTypeIEN"")=$G(APPTARY(FN,IENS,.06,""I""))"
^XMB(3.9,145952,2,1901,0)="""RTN"",""SDES2CLINICLIST"",105,0)"
^XMB(3.9,145952,2,1902,0)=" S APPTDATA(""LengthOfAppt"")=$G(APPTARY(FN,IENS,.18,""E""))"
^XMB(3.9,145952,2,1903,0)="""RTN"",""SDES2CLINICLIST"",106,0)"
^XMB(3.9,145952,2,1904,0)=" S APPTDATA(""RequestType"")=$G(APPTARY(FN,IENS,.22,""E""))"
^XMB(3.9,145952,2,1905,0)="""RTN"",""SDES2CLINICLIST"",107,0)"
^XMB(3.9,145952,2,1906,0)=" S APPTDATA(""RequestIEN"")=$P($G(APPTARY(FN,IENS,.22,""I"")),"";"")"
^XMB(3.9,145952,2,1907,0)="""RTN"",""SDES2CLINICLIST"",108,0)"
^XMB(3.9,145952,2,1908,0)=" K APPTARY(FN,IENS,1,""I""),APPTARY(FN,IENS,1,""E"")"
^XMB(3.9,145952,2,1909,0)="""RTN"",""SDES2CLINICLIST"",109,0)"
^XMB(3.9,145952,2,1910,0)=" I $D(APPTARY(FN,IENS,1)) M APPTDATA(""Note"")=APPTARY(FN,IENS,1)"
^XMB(3.9,145952,2,1911,0)="""RTN"",""SDES2CLINICLIST"",110,0)"
^XMB(3.9,145952,2,1912,0)=" E  S APPTDATA(""Note"")="""""
^XMB(3.9,145952,2,1913,0)="""RTN"",""SDES2CLINICLIST"",111,0)"
^XMB(3.9,145952,2,1914,0)=" S APPTDATA(""AppointmentIEN"")=IEN"
^XMB(3.9,145952,2,1915,0)="""RTN"",""SDES2CLINICLIST"",112,0)"
^XMB(3.9,145952,2,1916,0)=" S DATETIME=$G(APPTARY(FN,IENS,.03,""I""))"
^XMB(3.9,145952,2,1917,0)="""RTN"",""SDES2CLINICLIST"",113,0)"
^XMB(3.9,145952,2,1918,0)=" S APPTDATA(""CheckIn"")=$$FMTE^XLFDT(DATETIME)"
^XMB(3.9,145952,2,1919,0)="""RTN"",""SDES2CLINICLIST"",114,0)"
^XMB(3.9,145952,2,1920,0)=" S DATETIME=$G(APPTARY(FN,IENS,.04,""I""))"
^XMB(3.9,145952,2,1921,0)="""RTN"",""SDES2CLINICLIST"",115,0)"
^XMB(3.9,145952,2,1922,0)=" S APPTDATA(""CheckInEntered"")=$$FMTE^XLFDT(DATETIME)"
^XMB(3.9,145952,2,1923,0)="""RTN"",""SDES2CLINICLIST"",116,0)"
^XMB(3.9,145952,2,1924,0)=" S DATETIME=$G(APPTARY(FN,IENS,.14,""I""))"
^XMB(3.9,145952,2,1925,0)="""RTN"",""SDES2CLINICLIST"",117,0)"
^XMB(3.9,145952,2,1926,0)=" S APPTDATA(""CheckOut"")=$$FMTE^XLFDT(DATETIME)"
^XMB(3.9,145952,2,1927,0)="""RTN"",""SDES2CLINICLIST"",118,0)"
^XMB(3.9,145952,2,1928,0)=" S APPTDATA(""EASTrackingNumber"")=$G(APPTARY(FN,IENS,100,""I"")) ;SD,814-Retrieve EAS Tracking Number"
^XMB(3.9,145952,2,1929,0)="""RTN"",""SDES2CLINICLIST"",119,0)"
^XMB(3.9,145952,2,1930,0)=" S APPTDATA(""CancelDateTime"")=$$FMTE^XLFDT($G(APPTARY(FN,IENS,.12,""I"")))"
^XMB(3.9,145952,2,1931,0)="""RTN"",""SDES2CLINICLIST"",120,0)"
^XMB(3.9,145952,2,1932,0)=" S APPTDATA(""CancellationReason"")=$G(APPTARY(FN,IENS,.122,""E""))"
^XMB(3.9,145952,2,1933,0)="""RTN"",""SDES2CLINICLIST"",121,0)"
^XMB(3.9,145952,2,1934,0)=" ;CancelledByUser Data Elements"
^XMB(3.9,145952,2,1935,0)="""RTN"",""SDES2CLINICLIST"",122,0)"
^XMB(3.9,145952,2,1936,0)=" S CUSER=$G(APPTARY(FN,IENS,.121,""I""))"
^XMB(3.9,145952,2,1937,0)="""RTN"",""SDES2CLINICLIST"",123,0)"
^XMB(3.9,145952,2,1938,0)=" I CUSER D"
