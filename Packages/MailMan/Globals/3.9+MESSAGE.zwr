^XMB(3.9,145989,2,638,0)=" I PSOASVER=""3.0"" Q """""
^XMB(3.9,145989,2,639,0)="""RTN"",""PSOASAP0"",177,0)"
^XMB(3.9,145989,2,640,0)=" Q $$FMTHL7^XLFDT($P($G(VADM(3)),""^"",1))"
^XMB(3.9,145989,2,641,0)="""RTN"",""PSOASAP0"",178,0)"
