^XMB(3.9,145980,2,5457,0)="""RTN"",""SDES2CREATEAPPT2"",285,0)"
^XMB(3.9,145980,2,5458,0)=" ;"
^XMB(3.9,145980,2,5459,0)="""RTN"",""SDES2CREATEAPPT2"",286,0)"
^XMB(3.9,145980,2,5460,0)=" I APPOINTMENT(""MRTC""),'$L($G(APPOINTMENT(""MRTC PARENT""))) D ERRLOG^SDESJSON(.ERRORS,536)"
^XMB(3.9,145980,2,5461,0)="""RTN"",""SDES2CREATEAPPT2"",287,0)"
^XMB(3.9,145980,2,5462,0)=" I $L($G(APPOINTMENT(""MRTC PARENT""))),$$GET1^DIQ(409.85,$G(APPOINTMENT(""MRTC PARENT""))_"","",.01,""I"")'=$G(APPOINTMENT(""DFN"")) D ERRLOG^SDESJSON(.ERRORS,536)"
