^XMB(3.9,145944,2,243,0)="""QUES"",""XPZ2"",0)"
^XMB(3.9,145944,2,244,0)="Y"
^XMB(3.9,145944,2,245,0)="""QUES"",""XPZ2"",""??"")"
^XMB(3.9,145944,2,246,0)="^D RTN^XPDH"
^XMB(3.9,145944,2,247,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145944,2,248,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145944,2,249,0)="""QUES"",""XPZ2"",""B"")"
