^XMB(3.9,145944,2,1777,0)="""RTN"",""IBJDF6"",114,0)"
^XMB(3.9,145944,2,1778,0)=" D ^DIR K DIR G:$D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1779,0)="""RTN"",""IBJDF6"",115,0)"
^XMB(3.9,145944,2,1780,0)=" S IBSH=+Y K DIROUT,DTOUT,DUOUT,DIRUT G:'IBSH DEV"
^XMB(3.9,145944,2,1781,0)="""RTN"",""IBJDF6"",116,0)"
^XMB(3.9,145944,2,1782,0)=" ;"
^XMB(3.9,145944,2,1783,0)="""RTN"",""IBJDF6"",117,0)"
^XMB(3.9,145944,2,1784,0)=" S DIR(0)=""SA^A:ALL;M:MOST RECENT"""
^XMB(3.9,145944,2,1785,0)="""RTN"",""IBJDF6"",118,0)"
^XMB(3.9,145944,2,1786,0)=" S DIR(""A"")=""Print (A)LL comments or the (M)OST RECENT comment: """
^XMB(3.9,145944,2,1787,0)="""RTN"",""IBJDF6"",119,0)"
