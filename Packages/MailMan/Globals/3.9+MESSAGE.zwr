^XMB(3.9,145986,2,3997,0)="""RTN"",""FBPCR"",249,0)"
^XMB(3.9,145986,2,3998,0)="INS  ;Print Insurance Information FB*3.5*163"
^XMB(3.9,145986,2,3999,0)="""RTN"",""FBPCR"",250,0)"
^XMB(3.9,145986,2,4000,0)=" N FBYN,FBINS,FBRTN,FBERR,FBX,FBSTAT,FBVAL"
^XMB(3.9,145986,2,4001,0)="""RTN"",""FBPCR"",251,0)"
^XMB(3.9,145986,2,4002,0)=" W !,""    Health Insurance: """
^XMB(3.9,145986,2,4003,0)="""RTN"",""FBPCR"",252,0)"
