^XMB(3.9,145984,2,2034,0)=" ;"
^XMB(3.9,145984,2,2035,0)="""RTN"",""PSOERXI1"",169,0)"
^XMB(3.9,145984,2,2036,0)=" ; Auto-holds for MbM"
