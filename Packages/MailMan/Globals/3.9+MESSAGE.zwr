^XMB(3.9,145946,2,715,0)="""RTN"",""IBCMDT"",36,0)"
^XMB(3.9,145946,2,716,0)=" ;"
^XMB(3.9,145946,2,717,0)="""RTN"",""IBCMDT"",37,0)"
^XMB(3.9,145946,2,718,0)=" ; IBMDTSPC(""IBPCN"") 0 = ignore Missing PCN (Processor Control Number) filter."
^XMB(3.9,145946,2,719,0)="""RTN"",""IBCMDT"",38,0)"
^XMB(3.9,145946,2,720,0)=" ;                   1 = include Missing PCN (Processor Control Number) filter."
^XMB(3.9,145946,2,721,0)="""RTN"",""IBCMDT"",39,0)"
^XMB(3.9,145946,2,722,0)=" ; IBMDTSPC(""IBNMSPC"") = $J of the parent job (if queued)"
^XMB(3.9,145946,2,723,0)="""RTN"",""IBCMDT"",40,0)"
^XMB(3.9,145946,2,724,0)=" ;"
^XMB(3.9,145946,2,725,0)="""RTN"",""IBCMDT"",41,0)"
^XMB(3.9,145946,2,726,0)="EN ; Main Entry point."
^XMB(3.9,145946,2,727,0)="""RTN"",""IBCMDT"",42,0)"
^XMB(3.9,145946,2,728,0)=" ; Initialize variables."
^XMB(3.9,145946,2,729,0)="""RTN"",""IBCMDT"",43,0)"
^XMB(3.9,145946,2,730,0)=" N IBAI,IBMDTSPC,POP,STOP"
^XMB(3.9,145946,2,731,0)="""RTN"",""IBCMDT"",44,0)"
^XMB(3.9,145946,2,732,0)=" ;"
^XMB(3.9,145946,2,733,0)="""RTN"",""IBCMDT"",45,0)"
^XMB(3.9,145946,2,734,0)="C0 ; Start the Insurance Company Prompts."
^XMB(3.9,145946,2,735,0)="""RTN"",""IBCMDT"",46,0)"
^XMB(3.9,145946,2,736,0)=" K IBMDTSPC,^TMP(""IBCMDT"",$J),^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,737,0)="""RTN"",""IBCMDT"",47,0)"
^XMB(3.9,145946,2,738,0)=" S STOP=0,IBMDTSPC(""IBNMSPC"")=$J"
^XMB(3.9,145946,2,739,0)="""RTN"",""IBCMDT"",48,0)"
^XMB(3.9,145946,2,740,0)=" ;"
^XMB(3.9,145946,2,741,0)="""RTN"",""IBCMDT"",49,0)"
^XMB(3.9,145946,2,742,0)=" W @IOF"
^XMB(3.9,145946,2,743,0)="""RTN"",""IBCMDT"",50,0)"
^XMB(3.9,145946,2,744,0)=" ;IB*763/CKB - the intro sentence should reference group plans not insurance companies"
^XMB(3.9,145946,2,745,0)="""RTN"",""IBCMDT"",51,0)"
^XMB(3.9,145946,2,746,0)=" W !!?5,""This report will generate a list of ACTIVE group plans"""
^XMB(3.9,145946,2,747,0)="""RTN"",""IBCMDT"",52,0)"
^XMB(3.9,145946,2,748,0)=" W !?5,""that are missing the data that you select to be reported upon."",!!"
^XMB(3.9,145946,2,749,0)="""RTN"",""IBCMDT"",53,0)"
^XMB(3.9,145946,2,750,0)=" ;"
^XMB(3.9,145946,2,751,0)="""RTN"",""IBCMDT"",54,0)"
^XMB(3.9,145946,2,752,0)=" ; Select Insurance Companies or All Insurance Companies w/Plans"
^XMB(3.9,145946,2,753,0)="""RTN"",""IBCMDT"",55,0)"
^XMB(3.9,145946,2,754,0)="C10 D SLAI^IBCMDT1 I STOP G:$$STOP EXIT G C0"
^XMB(3.9,145946,2,755,0)="""RTN"",""IBCMDT"",56,0)"
^XMB(3.9,145946,2,756,0)=" N IBQUIT S IBQUIT=0"
^XMB(3.9,145946,2,757,0)="""RTN"",""IBCMDT"",57,0)"
^XMB(3.9,145946,2,758,0)=" S IBAI=+$G(IBMDTSPC(""IBAI""))"
^XMB(3.9,145946,2,759,0)="""RTN"",""IBCMDT"",58,0)"
^XMB(3.9,145946,2,760,0)=" D START"
^XMB(3.9,145946,2,761,0)="""RTN"",""IBCMDT"",59,0)"
^XMB(3.9,145946,2,762,0)=" I IBQUIT G EXIT"
^XMB(3.9,145946,2,763,0)="""RTN"",""IBCMDT"",60,0)"
^XMB(3.9,145946,2,764,0)=" I '$D(^TMP(""IBCMDT"",$J)) W !!,""No plans selected!"" G EXIT"
^XMB(3.9,145946,2,765,0)="""RTN"",""IBCMDT"",61,0)"
^XMB(3.9,145946,2,766,0)=" ;"
^XMB(3.9,145946,2,767,0)="""RTN"",""IBCMDT"",62,0)"
^XMB(3.9,145946,2,768,0)="FILTERS ; Begin the Filtering Questions."
^XMB(3.9,145946,2,769,0)="""RTN"",""IBCMDT"",63,0)"
^XMB(3.9,145946,2,770,0)=" ;"
^XMB(3.9,145946,2,771,0)="""RTN"",""IBCMDT"",64,0)"
^XMB(3.9,145946,2,772,0)=" N STOP"
^XMB(3.9,145946,2,773,0)="""RTN"",""IBCMDT"",65,0)"
^XMB(3.9,145946,2,774,0)="F0 ; Start of Filters."
^XMB(3.9,145946,2,775,0)="""RTN"",""IBCMDT"",66,0)"
^XMB(3.9,145946,2,776,0)=" S (IBMDTSPC(""FLTRS""),STOP)=0"
^XMB(3.9,145946,2,777,0)="""RTN"",""IBCMDT"",67,0)"
^XMB(3.9,145946,2,778,0)=" S IBMDTSPC(""SUBHD"")=""Missing Data: """
^XMB(3.9,145946,2,779,0)="""RTN"",""IBCMDT"",68,0)"
^XMB(3.9,145946,2,780,0)=" ; Filter on Missing Group Number"
^XMB(3.9,145946,2,781,0)="""RTN"",""IBCMDT"",69,0)"
^XMB(3.9,145946,2,782,0)="F10 D SLGRN^IBCMDT1"
^XMB(3.9,145946,2,783,0)="""RTN"",""IBCMDT"",70,0)"
^XMB(3.9,145946,2,784,0)=" I STOP G:$$STOP EXIT G C0"
^XMB(3.9,145946,2,785,0)="""RTN"",""IBCMDT"",71,0)"
^XMB(3.9,145946,2,786,0)=" I +IBMDTSPC(""IBGRN"") D"
^XMB(3.9,145946,2,787,0)="""RTN"",""IBCMDT"",72,0)"
^XMB(3.9,145946,2,788,0)=" . S IBMDTSPC(""SUBHD"")=IBMDTSPC(""SUBHD"")_""Group #"""
^XMB(3.9,145946,2,789,0)="""RTN"",""IBCMDT"",73,0)"
^XMB(3.9,145946,2,790,0)=" . S IBMDTSPC(""FLTRS"")=IBMDTSPC(""FLTRS"")+1"
^XMB(3.9,145946,2,791,0)="""RTN"",""IBCMDT"",74,0)"
