^XMB(3.9,145946,2,662,0)=" ;Other relevant variables:"
^XMB(3.9,145946,2,663,0)="""RTN"",""IBCMDT"",10,0)"
^XMB(3.9,145946,2,664,0)=" ; ZTSAVED for queuing"
^XMB(3.9,145946,2,665,0)="""RTN"",""IBCMDT"",11,0)"
^XMB(3.9,145946,2,666,0)=" ;"
^XMB(3.9,145946,2,667,0)="""RTN"",""IBCMDT"",12,0)"
^XMB(3.9,145946,2,668,0)=" ; IBMDTSPC(""FLTRS"") n where n is the number of filters selected"
^XMB(3.9,145946,2,669,0)="""RTN"",""IBCMDT"",13,0)"
^XMB(3.9,145946,2,670,0)=" ; IBMDTSPC(""IBAI"")  0 = user selected insurance companies."
^XMB(3.9,145946,2,671,0)="""RTN"",""IBCMDT"",14,0)"
^XMB(3.9,145946,2,672,0)=" ;                   1 = all insurance companies w/plans."
^XMB(3.9,145946,2,673,0)="""RTN"",""IBCMDT"",15,0)"
^XMB(3.9,145946,2,674,0)=" ;"
^XMB(3.9,145946,2,675,0)="""RTN"",""IBCMDT"",16,0)"
^XMB(3.9,145946,2,676,0)=" ; IBMDTSPC(""IBAPL"") 0 = user selected plans (may be ALL for certain companies, some for other companies)."
^XMB(3.9,145946,2,677,0)="""RTN"",""IBCMDT"",17,0)"
^XMB(3.9,145946,2,678,0)=" ;                   1 = all plans for the insurance companies (all or selected)."
^XMB(3.9,145946,2,679,0)="""RTN"",""IBCMDT"",18,0)"
^XMB(3.9,145946,2,680,0)=" ;"
^XMB(3.9,145946,2,681,0)="""RTN"",""IBCMDT"",19,0)"
^XMB(3.9,145946,2,682,0)=" ; IBMDTSPC(""IBGRN"") 0 = ignore Missing Group Number filter."
