^XMB(3.9,145958,2,1562,0)=" I PKG'=""PS"" Q"
^XMB(3.9,145958,2,1563,0)="""RTN"",""ORWDXA"",276,0)"
^XMB(3.9,145958,2,1564,0)=" I $L($G(^OR(100,+ORID,3))),('$L($P(^(3),U,9))) Q"
^XMB(3.9,145958,2,1565,0)="""RTN"",""ORWDXA"",277,0)"
^XMB(3.9,145958,2,1566,0)=" S (NUMCHDS,NOWID,NOWVAL,X3,ORDA)=0"
^XMB(3.9,145958,2,1567,0)="""RTN"",""ORWDXA"",278,0)"
^XMB(3.9,145958,2,1568,0)=" S PRTORDER=+$P(^(3),U,9)"
^XMB(3.9,145958,2,1569,0)="""RTN"",""ORWDXA"",279,0)"
^XMB(3.9,145958,2,1570,0)=" S X3=$G(^OR(100,PRTORDER,3)),ORDA=$P(X3,U,7)"
^XMB(3.9,145958,2,1571,0)="""RTN"",""ORWDXA"",280,0)"
^XMB(3.9,145958,2,1572,0)=" S PRTORDER=PRTORDER_"";""_ORDA"
^XMB(3.9,145958,2,1573,0)="""RTN"",""ORWDXA"",281,0)"
^XMB(3.9,145958,2,1574,0)=" S NUMCHDS=$P($G(^OR(100,+PRTORDER,2,0)),U,4)"
^XMB(3.9,145958,2,1575,0)="""RTN"",""ORWDXA"",282,0)"
^XMB(3.9,145958,2,1576,0)=" I NUMCHDS>2 S ORY=""COMPLEX-PSI""_U_PRTORDER"
^XMB(3.9,145958,2,1577,0)="""RTN"",""ORWDXA"",283,0)"
^XMB(3.9,145958,2,1578,0)=" S:$D(^OR(100,+PRTORDER,4.5,""ID"",""NOW"")) NOWID=$O(^(""NOW"",0))"
^XMB(3.9,145958,2,1579,0)="""RTN"",""ORWDXA"",284,0)"
^XMB(3.9,145958,2,1580,0)=" S:NOWID NOWVAL=$G(^OR(100,+PRTORDER,4.5,NOWID,1))"
^XMB(3.9,145958,2,1581,0)="""RTN"",""ORWDXA"",285,0)"
^XMB(3.9,145958,2,1582,0)=" I NOWVAL=1 Q"
^XMB(3.9,145958,2,1583,0)="""RTN"",""ORWDXA"",286,0)"
^XMB(3.9,145958,2,1584,0)=" E  S ORY=""COMPLEX-PSI""_U_PRTORDER"
^XMB(3.9,145958,2,1585,0)="""RTN"",""ORWDXA"",287,0)"
^XMB(3.9,145958,2,1586,0)=" Q"
^XMB(3.9,145958,2,1587,0)="""RTN"",""ORWDXA"",288,0)"
^XMB(3.9,145958,2,1588,0)="ISACTOI(ORY,OI) ; Is ord item active?"
^XMB(3.9,145958,2,1589,0)="""RTN"",""ORWDXA"",289,0)"
