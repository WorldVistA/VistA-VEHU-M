^XMB(3.9,145981,2,305,0)="""RTN"",""IBECECX1"",33,0)"
^XMB(3.9,145981,2,306,0)=" . S IBCLNDT=$S(IBCLNDT:IBCLNDT,1:$$FMADD^XLFDT(IBCLDT,364))  ;Calc Billing Clock end date when null"
