^XMB(3.9,145957,2,674,0)=" S GMRCPSIT=$$IEN^XUAF4($P($P(GMRCORC,""|"",2),U,2))"
^XMB(3.9,145957,2,675,0)="""RTN"",""GMRCIMSG"",192,0)"
^XMB(3.9,145957,2,676,0)=" S GMRCFDA=+$P(GMRCORC,""|"",3)"
^XMB(3.9,145957,2,677,0)="""RTN"",""GMRCIMSG"",193,0)"
^XMB(3.9,145957,2,678,0)=" S GMRCFSIT=$$IEN^XUAF4($P($P(GMRCORC,""|"",3),U,2))"
