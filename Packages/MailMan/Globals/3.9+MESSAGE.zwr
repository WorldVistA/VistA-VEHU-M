^XMB(3.9,145944,2,2168,0)=" ;"
^XMB(3.9,145944,2,2169,0)="""RTN"",""IBJDF61"",150,0)"
^XMB(3.9,145944,2,2170,0)=" I (INI'=""@""&('DFN)) S Y="""" G PDQ"
^XMB(3.9,145944,2,2171,0)="""RTN"",""IBJDF61"",151,0)"
^XMB(3.9,145944,2,2172,0)=" I ALL=""ALL""&('DFN)!(ALL=""NULL""&(DFN)) S Y="""" G PDQ"
