^XMB(3.9,145957,2,1161,0)="""RTN"",""GMRCRFC0"",28,0)"
^XMB(3.9,145957,2,1162,0)=" ;is there a local consult ien? has it already been filed in 668?"
^XMB(3.9,145957,2,1163,0)="""RTN"",""GMRCRFC0"",29,0)"
^XMB(3.9,145957,2,1164,0)=" I RMPRST=""NW"" D"
