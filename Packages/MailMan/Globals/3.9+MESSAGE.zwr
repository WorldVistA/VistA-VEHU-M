^XMB(3.9,145983,2,1475,0)="""RTN"",""RCRPNP"",191,0)"
^XMB(3.9,145983,2,1476,0)=" S DA=RCIEN,DIE=""^RCRP(340.5,"""
^XMB(3.9,145983,2,1477,0)="""RTN"",""RCRPNP"",192,0)"
