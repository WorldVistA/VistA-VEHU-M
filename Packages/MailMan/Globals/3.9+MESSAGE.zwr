^XMB(3.9,145986,2,3579,0)="""RTN"",""FBPCR"",40,0)"
^XMB(3.9,145986,2,3580,0)=" . D ^DIR K DIR"
^XMB(3.9,145986,2,3581,0)="""RTN"",""FBPCR"",41,0)"
^XMB(3.9,145986,2,3582,0)=" . I $G(DIRUT) S FBINCUNK=-1 Q"
^XMB(3.9,145986,2,3583,0)="""RTN"",""FBPCR"",42,0)"
^XMB(3.9,145986,2,3584,0)=" . I $G(Y)=0 S FBINCUNK=0"
^XMB(3.9,145986,2,3585,0)="""RTN"",""FBPCR"",43,0)"
^XMB(3.9,145986,2,3586,0)=" I FBINCUNK=-1 G EXIT ;uparrow - exit"
^XMB(3.9,145986,2,3587,0)="""RTN"",""FBPCR"",44,0)"
^XMB(3.9,145986,2,3588,0)=" N FBINEXCL  ; FB*3.5*135"
^XMB(3.9,145986,2,3589,0)="""RTN"",""FBPCR"",45,0)"
^XMB(3.9,145986,2,3590,0)=" D EXCLINS  ;select insurances to be excluded ; FB*3.5*135"
^XMB(3.9,145986,2,3591,0)="""RTN"",""FBPCR"",46,0)"
