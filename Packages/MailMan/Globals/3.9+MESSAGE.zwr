^XMB(3.9,145989,2,722,0)=" I PSOASVER=""3.0"" Q $S($G(RECTYPE)=""N"":""01"",$G(RECTYPE)=""R"":""02"",$G(RECTYPE)=""V"":""03"",1:"""")"
^XMB(3.9,145989,2,723,0)="""RTN"",""PSOASAP0"",219,0)"
