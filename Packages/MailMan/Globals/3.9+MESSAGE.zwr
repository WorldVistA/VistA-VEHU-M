^XMB(3.9,145979,2,240,0)="0^1^B54961481"
^XMB(3.9,145979,2,241,0)="""RTN"",""PSJCOM1"",1,0)"
^XMB(3.9,145979,2,242,0)="PSJCOM1 ;BIR/CML3 - DISPLAY COMPLEX ORDERS FOR DISCONTINUE ; 10/18/19 2:40pm"
^XMB(3.9,145979,2,243,0)="""RTN"",""PSJCOM1"",2,0)"
^XMB(3.9,145979,2,244,0)=" ;;5.0;INPATIENT MEDICATIONS;**110,127,281,315,327,393**;16 DEC 97;Build 0"
^XMB(3.9,145979,2,245,0)="""RTN"",""PSJCOM1"",3,0)"
^XMB(3.9,145979,2,246,0)=" ;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145979,2,247,0)="""RTN"",""PSJCOM1"",4,0)"
^XMB(3.9,145979,2,248,0)=" ; Reference to ^VALM1 via DBIA 10116"
^XMB(3.9,145979,2,249,0)="""RTN"",""PSJCOM1"",5,0)"
^XMB(3.9,145979,2,250,0)=" ; Reference to ^PS(55 via DBIA 2191"
^XMB(3.9,145979,2,251,0)="""RTN"",""PSJCOM1"",6,0)"
^XMB(3.9,145979,2,252,0)=" ; Reference to ^%DTC via DBIA 10000"
^XMB(3.9,145979,2,253,0)="""RTN"",""PSJCOM1"",7,0)"
^XMB(3.9,145979,2,254,0)=" ; Reference to ^PS(51.2 via DBIA 2178"
^XMB(3.9,145979,2,255,0)="""RTN"",""PSJCOM1"",8,0)"
^XMB(3.9,145979,2,256,0)=" ; Reference to ^DIE via DBIA 10018"
^XMB(3.9,145979,2,257,0)="""RTN"",""PSJCOM1"",9,0)"
^XMB(3.9,145979,2,258,0)=" ; Reference to ^DIR via DBIA 10026"
^XMB(3.9,145979,2,259,0)="""RTN"",""PSJCOM1"",10,0)"
^XMB(3.9,145979,2,260,0)=" ; Reference to ^TMP(""PSODAOC"",$J) via DBIA 6071"
^XMB(3.9,145979,2,261,0)="""RTN"",""PSJCOM1"",11,0)"
^XMB(3.9,145979,2,262,0)=" ;"
^XMB(3.9,145979,2,263,0)="""RTN"",""PSJCOM1"",12,0)"
^XMB(3.9,145979,2,264,0)="CMPLX(PSGP,ON,PSGORD) ;"
^XMB(3.9,145979,2,265,0)="""RTN"",""PSJCOM1"",13,0)"
^XMB(3.9,145979,2,266,0)=" D PAUSE K PSJCM"
^XMB(3.9,145979,2,267,0)="""RTN"",""PSJCOM1"",14,0)"
^XMB(3.9,145979,2,268,0)=" N PSJLINE,PSX,PSCM"
^XMB(3.9,145979,2,269,0)="""RTN"",""PSJCOM1"",15,0)"
^XMB(3.9,145979,2,270,0)=" S PSJLINE=1"
^XMB(3.9,145979,2,271,0)="""RTN"",""PSJCOM1"",16,0)"
^XMB(3.9,145979,2,272,0)=" I PSGORD[""P"" N PSJO S PSJO=0 F  S PSJO=$O(^PS(53.1,""ACX"",ON,PSJO)) Q:'PSJO  D"
^XMB(3.9,145979,2,273,0)="""RTN"",""PSJCOM1"",17,0)"
^XMB(3.9,145979,2,274,0)=" .Q:PSJO=+PSGORD  S PSJOO=PSGORD D DSPLORDU(PSGP,PSJO_""P"") S PSJCM(PSJO_""P"",PSJLINE)="""",PSJLINE=PSJLINE+1"
^XMB(3.9,145979,2,275,0)="""RTN"",""PSJCOM1"",18,0)"
^XMB(3.9,145979,2,276,0)=" I PSGORD'[""P"" N PSJO,PSJOO S PSJOO="""",PSJO=0 F  S PSJO=$O(^PS(55,""ACX"",ON,PSJO)) Q:'PSJO  F  S PSJOO=$O(^PS(55,""ACX"",ON,PSJO,PSJOO)) Q:PSJOO=""""  D"
^XMB(3.9,145979,2,277,0)="""RTN"",""PSJCOM1"",19,0)"
^XMB(3.9,145979,2,278,0)=" .Q:PSJOO=PSGORD  D:PSJOO[""U"" DSPLORDU(PSGP,PSJOO) D:PSJOO[""V"" DSPLORDV(PSGP,PSJOO) S PSJCM(PSJOO,PSJLINE)="""",PSJLINE=PSJLINE+1"
^XMB(3.9,145979,2,279,0)="""RTN"",""PSJCOM1"",20,0)"
^XMB(3.9,145979,2,280,0)=" N ON S ON="""" F  S ON=$O(PSJCM(ON)) Q:ON=""""  D"
^XMB(3.9,145979,2,281,0)="""RTN"",""PSJCOM1"",21,0)"
^XMB(3.9,145979,2,282,0)=" .W ! F PSX=0:0 S PSX=$O(PSJCM(ON,PSX)) Q:'PSX  D"
^XMB(3.9,145979,2,283,0)="""RTN"",""PSJCOM1"",22,0)"
^XMB(3.9,145979,2,284,0)=" ..W !,PSJCM(ON,PSX) D:'(PSX#6) PAUSE"
^XMB(3.9,145979,2,285,0)="""RTN"",""PSJCOM1"",23,0)"
^XMB(3.9,145979,2,286,0)=" W !"
^XMB(3.9,145979,2,287,0)="""RTN"",""PSJCOM1"",24,0)"
^XMB(3.9,145979,2,288,0)=" Q"
^XMB(3.9,145979,2,289,0)="""RTN"",""PSJCOM1"",25,0)"
^XMB(3.9,145979,2,290,0)=" ;"
^XMB(3.9,145979,2,291,0)="""RTN"",""PSJCOM1"",26,0)"
^XMB(3.9,145979,2,292,0)="CMPLX2(PSGP,ON,PSGORD) ;"
^XMB(3.9,145979,2,293,0)="""RTN"",""PSJCOM1"",27,0)"
^XMB(3.9,145979,2,294,0)=" Q:$G(PSGORD)'[""U"""
^XMB(3.9,145979,2,295,0)="""RTN"",""PSJCOM1"",28,0)"
^XMB(3.9,145979,2,296,0)=" ;; START NCC REMEDIATION >> 327*RJS"
^XMB(3.9,145979,2,297,0)="""RTN"",""PSJCOM1"",29,0)"
^XMB(3.9,145979,2,298,0)=" N CLOZFLG I PSGORD[""U"" S CLOZFLG=$$ISCLOZ^PSJCLOZ(,,PSGP,+PSGORD) I 1"
^XMB(3.9,145979,2,299,0)="""RTN"",""PSJCOM1"",30,0)"
^XMB(3.9,145979,2,300,0)=" E  S CLOZFLG=$$ISCLOZ^PSJCLOZ(+PSGORD)"
^XMB(3.9,145979,2,301,0)="""RTN"",""PSJCOM1"",31,0)"
^XMB(3.9,145979,2,302,0)=" I CLOZFLG D"
^XMB(3.9,145979,2,303,0)="""RTN"",""PSJCOM1"",32,0)"
^XMB(3.9,145979,2,304,0)=" .N PSGDN S PSGDN=$P(CLOZFLG,U,2)"
^XMB(3.9,145979,2,305,0)="""RTN"",""PSJCOM1"",33,0)"
^XMB(3.9,145979,2,306,0)=" .D PSJFILE^PSJCLOZ(PSGP),INPSND^YSCLTST5 K:$D(^TMP($J,""CLOZFLG"",PSGP)) ^TMP($J,""CLOZFLG"",PSGP)"
^XMB(3.9,145979,2,307,0)="""RTN"",""PSJCOM1"",34,0)"
^XMB(3.9,145979,2,308,0)=" ;; END NCC REMEDIATION >> 327*RJS"
^XMB(3.9,145979,2,309,0)="""RTN"",""PSJCOM1"",35,0)"
^XMB(3.9,145979,2,310,0)=" N PSJLINE S PSJLINE=0"
^XMB(3.9,145979,2,311,0)="""RTN"",""PSJCOM1"",36,0)"
^XMB(3.9,145979,2,312,0)=" D FULL^VALM1"
^XMB(3.9,145979,2,313,0)="""RTN"",""PSJCOM1"",37,0)"
^XMB(3.9,145979,2,314,0)=" D DSPLORDU(PSGP,PSGORD)"
^XMB(3.9,145979,2,315,0)="""RTN"",""PSJCOM1"",38,0)"
^XMB(3.9,145979,2,316,0)=" W ! S PSJLINE="""" F  S PSJLINE=$O(PSJCM(PSGORD,PSJLINE)) Q:PSJLINE=""""  W !,PSJCM(PSGORD,PSJLINE) D:'((PSJLINE+1)#6) PAUSE"
^XMB(3.9,145979,2,317,0)="""RTN"",""PSJCOM1"",39,0)"
^XMB(3.9,145979,2,318,0)=" D EN^PSGPEN(PSGORD)"
^XMB(3.9,145979,2,319,0)="""RTN"",""PSJCOM1"",40,0)"
^XMB(3.9,145979,2,320,0)=" S ^TMP(""PSODAOC"",$J,""IP IEN"")=PSJO_""P"",^TMP(""PSODAOC"",$J,""IP NEW IEN"")=PSGORD"
^XMB(3.9,145979,2,321,0)="""RTN"",""PSJCOM1"",41,0)"
^XMB(3.9,145979,2,322,0)=" D SETOC^PSJNEWOC(PSGORD)"
^XMB(3.9,145979,2,323,0)="""RTN"",""PSJCOM1"",42,0)"
^XMB(3.9,145979,2,324,0)=" W !"
^XMB(3.9,145979,2,325,0)="""RTN"",""PSJCOM1"",43,0)"
^XMB(3.9,145979,2,326,0)=" Q"
^XMB(3.9,145979,2,327,0)="""RTN"",""PSJCOM1"",44,0)"
^XMB(3.9,145979,2,328,0)=" ;"
^XMB(3.9,145979,2,329,0)="""RTN"",""PSJCOM1"",45,0)"
^XMB(3.9,145979,2,330,0)="UPDATE ; Refresh array, actions, & display."
^XMB(3.9,145979,2,331,0)="""RTN"",""PSJCOM1"",46,0)"
^XMB(3.9,145979,2,332,0)=" D GETUD^PSJLMGUD(DFN,ON),INIT^PSJLMUDE(DFN,ON) S VALMBCK=""R"""
^XMB(3.9,145979,2,333,0)="""RTN"",""PSJCOM1"",47,0)"
^XMB(3.9,145979,2,334,0)=" Q"
^XMB(3.9,145979,2,335,0)="""RTN"",""PSJCOM1"",48,0)"
^XMB(3.9,145979,2,336,0)="HOLDHDR ; Freeze header text while processing order actions"
^XMB(3.9,145979,2,337,0)="""RTN"",""PSJCOM1"",49,0)"
^XMB(3.9,145979,2,338,0)=" I $D(VALM(""TM"")) S IOTM=VALM(""TM""),IOBM=IOSL W IOSC W @IOSTBM W IORC"
^XMB(3.9,145979,2,339,0)="""RTN"",""PSJCOM1"",50,0)"
^XMB(3.9,145979,2,340,0)=" Q"
^XMB(3.9,145979,2,341,0)="""RTN"",""PSJCOM1"",51,0)"
^XMB(3.9,145979,2,342,0)=" ;"
^XMB(3.9,145979,2,343,0)="""RTN"",""PSJCOM1"",52,0)"
^XMB(3.9,145979,2,344,0)="DSPLORDU(PSGP,ON)   ; Display UD order for order check as in the Inpat Profile."
^XMB(3.9,145979,2,345,0)="""RTN"",""PSJCOM1"",53,0)"
^XMB(3.9,145979,2,346,0)=" NEW DRUGNAME,F,NODE0,NODE2,PSJID,PSJX,SCH,SD,STAT,X,Y K PSJCM"
^XMB(3.9,145979,2,347,0)="""RTN"",""PSJCOM1"",54,0)"
^XMB(3.9,145979,2,348,0)=" S F=$S(ON[""U"":""^PS(55,PSGP,5,""_+ON_"","",1:""^PS(53.1,""_+ON_"","")"
^XMB(3.9,145979,2,349,0)="""RTN"",""PSJCOM1"",55,0)"
^XMB(3.9,145979,2,350,0)=" S NODE0=$G(@(F_""0)"")),NODE2=$G(@(F_""2)""))"
^XMB(3.9,145979,2,351,0)="""RTN"",""PSJCOM1"",56,0)"
^XMB(3.9,145979,2,352,0)=" D DRGDISP^PSJLMUT1(PSGP,ON,39,54,.DRUGNAME,0)"
^XMB(3.9,145979,2,353,0)="""RTN"",""PSJCOM1"",57,0)"
^XMB(3.9,145979,2,354,0)=" I ON[""P"",$P(NODE0,U,4)=""F"" D DSPLORDV(PSGP,ON) Q"
^XMB(3.9,145979,2,355,0)="""RTN"",""PSJCOM1"",58,0)"
^XMB(3.9,145979,2,356,0)=" S SCH=$P(NODE0,U,7)"
^XMB(3.9,145979,2,357,0)="""RTN"",""PSJCOM1"",59,0)"
^XMB(3.9,145979,2,358,0)=" S STAT=$P(NODE0,U,9)"
^XMB(3.9,145979,2,359,0)="""RTN"",""PSJCOM1"",60,0)"
^XMB(3.9,145979,2,360,0)=" D NOW^%DTC I ""A""[STAT I $P(NODE2,U,4)<% D EXPIRE S STAT=""E"""
^XMB(3.9,145979,2,361,0)="""RTN"",""PSJCOM1"",61,0)"
^XMB(3.9,145979,2,362,0)=" I STAT=""A"",$P(NODE0,U,27)=""R"" S STAT=""R"""
^XMB(3.9,145979,2,363,0)="""RTN"",""PSJCOM1"",62,0)"
^XMB(3.9,145979,2,364,0)=" I STAT'=""P"" S PSJID=$E($$ENDTC^PSGMI($P(NODE2,U,2)),1,5),SD=$E($$ENDTC^PSGMI($P(NODE2,U,4)),1,5)"
^XMB(3.9,145979,2,365,0)="""RTN"",""PSJCOM1"",63,0)"
^XMB(3.9,145979,2,366,0)=" I STAT=""P"" S (PSJID,SD)=""*****"",SCH=""?"""
^XMB(3.9,145979,2,367,0)="""RTN"",""PSJCOM1"",64,0)"
^XMB(3.9,145979,2,368,0)=" I $G(PSGPDN)[""CLOZ"" N PSGORD S PSGORD=+$G(NODE0),PSSD="""" D DISPCMP^PSJCLOZ(PSGORD,.PSSD) I $G(PSSD) S SD=$E($$ENDTC^PSGMI(PSSD),1,5) K PSSD"
^XMB(3.9,145979,2,369,0)="""RTN"",""PSJCOM1"",65,0)"
^XMB(3.9,145979,2,370,0)=" F PSJX=0:0 S PSJX=$O(DRUGNAME(PSJX)) Q:'PSJX  D"
^XMB(3.9,145979,2,371,0)="""RTN"",""PSJCOM1"",66,0)"
^XMB(3.9,145979,2,372,0)=" . S:PSJX=1 X=SCH_""  ""_PSJID_""  ""_SD_""  ""_$E(STAT,1)"
^XMB(3.9,145979,2,373,0)="""RTN"",""PSJCOM1"",67,0)"
^XMB(3.9,145979,2,374,0)=" . S:PSJX=1 DRUGNAME(1)=$$SETSTR^VALM1(X,$E(DRUGNAME(1),1,40),42,20)"
^XMB(3.9,145979,2,375,0)="""RTN"",""PSJCOM1"",68,0)"
^XMB(3.9,145979,2,376,0)=" . S PSJCM(ON,PSJLINE)=""        ""_DRUGNAME(PSJX)"
^XMB(3.9,145979,2,377,0)="""RTN"",""PSJCOM1"",69,0)"
^XMB(3.9,145979,2,378,0)=" . S PSJLINE=PSJLINE+1"
^XMB(3.9,145979,2,379,0)="""RTN"",""PSJCOM1"",70,0)"
^XMB(3.9,145979,2,380,0)=" Q"
^XMB(3.9,145979,2,381,0)="""RTN"",""PSJCOM1"",71,0)"
^XMB(3.9,145979,2,382,0)="DSPLORDV(DFN,ON)   ; Display IV order for order check as in the Inpat Profile."
^XMB(3.9,145979,2,383,0)="""RTN"",""PSJCOM1"",72,0)"
^XMB(3.9,145979,2,384,0)=" N DRG,DRGI,DRGT,DRGX,FIL,ND,ON55,P,PSJIVFLG,PSJORIFN,TYP,X,Y"
^XMB(3.9,145979,2,385,0)="""RTN"",""PSJCOM1"",73,0)"
^XMB(3.9,145979,2,386,0)=" S TYP=""?"" I ON[""V"" D"
^XMB(3.9,145979,2,387,0)="""RTN"",""PSJCOM1"",74,0)"
^XMB(3.9,145979,2,388,0)=" .S Y=$G(^PS(55,DFN,""IV"",+ON,0)) F X=2,3,4,5,8,9,17,23 S P(X)=$P(Y,U,X)"
^XMB(3.9,145979,2,389,0)="""RTN"",""PSJCOM1"",75,0)"
^XMB(3.9,145979,2,390,0)=" .D NOW^%DTC I ""A""[P(17) I P(3)<% D EXPIRE S P(17)=""E"""
^XMB(3.9,145979,2,391,0)="""RTN"",""PSJCOM1"",76,0)"
^XMB(3.9,145979,2,392,0)=" .S TYP=$$ONE^PSJBCMA(DFN,ON,P(9),P(2),P(3)) I TYP'=""O"" S TYP=""C"""
^XMB(3.9,145979,2,393,0)="""RTN"",""PSJCOM1"",77,0)"
^XMB(3.9,145979,2,394,0)=" .S ON55=ON,P(""OT"")=$S(P(4)=""A"":""F"",P(4)=""H"":""H"",1:""I"") D GTDRG^PSIVORFB,GTOT^PSIVUTL(P(4))"
^XMB(3.9,145979,2,395,0)="""RTN"",""PSJCOM1"",78,0)"
^XMB(3.9,145979,2,396,0)=" S PSJCT=0,PSJL="""""
^XMB(3.9,145979,2,397,0)="""RTN"",""PSJCOM1"",79,0)"
^XMB(3.9,145979,2,398,0)=" I ON'[""V"" S (P(2),P(3))="""",P(17)=$P($G(^PS(53.1,+ON,0)),U,9),Y=$G(^(8)),P(4)=$P(Y,U),P(8)=$P(Y,U,5),P(9)=$P($G(^(2)),U) D GTDRG^PSIVORFA,GTOT^PSIVUTL(P(4))"
^XMB(3.9,145979,2,399,0)="""RTN"",""PSJCOM1"",80,0)"
^XMB(3.9,145979,2,400,0)=" S PSJIVFLG=1 D PIVAD,SOL"
^XMB(3.9,145979,2,401,0)="""RTN"",""PSJCOM1"",81,0)"
^XMB(3.9,145979,2,402,0)=" Q"
^XMB(3.9,145979,2,403,0)="""RTN"",""PSJCOM1"",82,0)"
^XMB(3.9,145979,2,404,0)="SOL ;"
^XMB(3.9,145979,2,405,0)="""RTN"",""PSJCOM1"",83,0)"
