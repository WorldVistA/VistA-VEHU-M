^XMB(3.9,145958,2,1160,0)=" Q"
^XMB(3.9,145958,2,1161,0)="""RTN"",""ORWDXA"",75,0)"
^XMB(3.9,145958,2,1162,0)=" ;"
^XMB(3.9,145958,2,1163,0)="""RTN"",""ORWDXA"",76,0)"
^XMB(3.9,145958,2,1164,0)="HOLD(REC,ORID,ORNP) ; Place order on hold"
