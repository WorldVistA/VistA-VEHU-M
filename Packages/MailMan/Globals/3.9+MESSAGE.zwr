^XMB(3.9,145980,2,3885,0)="""RTN"",""SDES2CANCELAPPT2"",99,0)"
^XMB(3.9,145980,2,3886,0)=" D POPULATE(APPTIEN,.APPTSTARTTIME,.REQUESTTYPE,.REQUESTIEN,.APPTENDTIME,.APPTLENGTH,.APPTTYPE,.RESOURCE,.WALKIN,.MRTC,.PARENTREQUEST,.PARENTSTATUS,.SLOTSTATUSSTRING)"
^XMB(3.9,145980,2,3887,0)="""RTN"",""SDES2CANCELAPPT2"",100,0)"
^XMB(3.9,145980,2,3888,0)=" S ROLLBACK(""WALKIN"")=WALKIN"
^XMB(3.9,145980,2,3889,0)="""RTN"",""SDES2CANCELAPPT2"",101,0)"
^XMB(3.9,145980,2,3890,0)=" S IENS44=$$GET44RECORDIENS(CLINICIEN,APPTSTARTTIME,DFN)"
^XMB(3.9,145980,2,3891,0)="""RTN"",""SDES2CANCELAPPT2"",102,0)"
^XMB(3.9,145980,2,3892,0)=" ; first event handler"
