^XMB(3.9,145946,2,3548,0)=" Q"
^XMB(3.9,145946,2,3549,0)="""RTN"",""IBCNEQU"",16,0)"
^XMB(3.9,145946,2,3550,0)=" ;"
^XMB(3.9,145946,2,3551,0)="""RTN"",""IBCNEQU"",17,0)"
^XMB(3.9,145946,2,3552,0)="EN ; Entry pt"
^XMB(3.9,145946,2,3553,0)="""RTN"",""IBCNEQU"",18,0)"
^XMB(3.9,145946,2,3554,0)=" ; Init vars"
^XMB(3.9,145946,2,3555,0)="""RTN"",""IBCNEQU"",19,0)"
^XMB(3.9,145946,2,3556,0)=" N DFN,X,POP,IBFASTXT,VALMCNT,VALMBG,VALMHDR,VALMBCK,IDUZ"
^XMB(3.9,145946,2,3557,0)="""RTN"",""IBCNEQU"",20,0)"
^XMB(3.9,145946,2,3558,0)=" ;"
^XMB(3.9,145946,2,3559,0)="""RTN"",""IBCNEQU"",21,0)"
^XMB(3.9,145946,2,3560,0)="EN1 I $G(IBFASTXT) G ENX"
^XMB(3.9,145946,2,3561,0)="""RTN"",""IBCNEQU"",22,0)"
^XMB(3.9,145946,2,3562,0)=" S DFN=$$PAT I 'DFN G ENX"
^XMB(3.9,145946,2,3563,0)="""RTN"",""IBCNEQU"",23,0)"
^XMB(3.9,145946,2,3564,0)=" D EN^VALM(""IBCNE REQUEST INS INQUIRY LIST"")"
^XMB(3.9,145946,2,3565,0)="""RTN"",""IBCNEQU"",24,0)"
^XMB(3.9,145946,2,3566,0)=" G EN1"
^XMB(3.9,145946,2,3567,0)="""RTN"",""IBCNEQU"",25,0)"
^XMB(3.9,145946,2,3568,0)=" ;"
^XMB(3.9,145946,2,3569,0)="""RTN"",""IBCNEQU"",26,0)"
^XMB(3.9,145946,2,3570,0)="ENX ; EN exit pt"
^XMB(3.9,145946,2,3571,0)="""RTN"",""IBCNEQU"",27,0)"
^XMB(3.9,145946,2,3572,0)=" Q"
^XMB(3.9,145946,2,3573,0)="""RTN"",""IBCNEQU"",28,0)"
^XMB(3.9,145946,2,3574,0)=" ;"
^XMB(3.9,145946,2,3575,0)="""RTN"",""IBCNEQU"",29,0)"
^XMB(3.9,145946,2,3576,0)="PI ; Entry point for Patient Insurance Info View/Edit (PI)"
^XMB(3.9,145946,2,3577,0)="""RTN"",""IBCNEQU"",30,0)"
^XMB(3.9,145946,2,3578,0)=" Q   ;IB*822/CKB - this tag will be implemented as part of IB*827"
^XMB(3.9,145946,2,3579,0)="""RTN"",""IBCNEQU"",31,0)"
^XMB(3.9,145946,2,3580,0)=" N IBFASTXT"
^XMB(3.9,145946,2,3581,0)="""RTN"",""IBCNEQU"",32,0)"
^XMB(3.9,145946,2,3582,0)=" I '$G(DFN) G PIX"
^XMB(3.9,145946,2,3583,0)="""RTN"",""IBCNEQU"",33,0)"
^XMB(3.9,145946,2,3584,0)=" D EN^VALM(""IBCNE REQUEST INS INQUIRY LIST"")"
^XMB(3.9,145946,2,3585,0)="""RTN"",""IBCNEQU"",34,0)"
^XMB(3.9,145946,2,3586,0)="PIX ;"
^XMB(3.9,145946,2,3587,0)="""RTN"",""IBCNEQU"",35,0)"
^XMB(3.9,145946,2,3588,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,3589,0)="""RTN"",""IBCNEQU"",36,0)"
^XMB(3.9,145946,2,3590,0)=" Q"
^XMB(3.9,145946,2,3591,0)="""RTN"",""IBCNEQU"",37,0)"
^XMB(3.9,145946,2,3592,0)=" ;"
^XMB(3.9,145946,2,3593,0)="""RTN"",""IBCNEQU"",38,0)"
^XMB(3.9,145946,2,3594,0)="INIT ; -- set up initial variables"
^XMB(3.9,145946,2,3595,0)="""RTN"",""IBCNEQU"",39,0)"
^XMB(3.9,145946,2,3596,0)=" S VALMCNT=0,VALMBG=1,IDUZ=DUZ"
^XMB(3.9,145946,2,3597,0)="""RTN"",""IBCNEQU"",40,0)"
^XMB(3.9,145946,2,3598,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J),^TMP(""IBCNEQUDTS"",$J)"
^XMB(3.9,145946,2,3599,0)="""RTN"",""IBCNEQU"",41,0)"
^XMB(3.9,145946,2,3600,0)=" D HDR"
^XMB(3.9,145946,2,3601,0)="""RTN"",""IBCNEQU"",42,0)"
^XMB(3.9,145946,2,3602,0)=" D BLD(DFN)"
^XMB(3.9,145946,2,3603,0)="""RTN"",""IBCNEQU"",43,0)"
^XMB(3.9,145946,2,3604,0)=" ;"
^XMB(3.9,145946,2,3605,0)="""RTN"",""IBCNEQU"",44,0)"
^XMB(3.9,145946,2,3606,0)="INITX ; INIT exit pt"
^XMB(3.9,145946,2,3607,0)="""RTN"",""IBCNEQU"",45,0)"
^XMB(3.9,145946,2,3608,0)=" Q"
^XMB(3.9,145946,2,3609,0)="""RTN"",""IBCNEQU"",46,0)"
^XMB(3.9,145946,2,3610,0)=" ;"
^XMB(3.9,145946,2,3611,0)="""RTN"",""IBCNEQU"",47,0)"
^XMB(3.9,145946,2,3612,0)="HDR ; -- screen header for initial screen"
^XMB(3.9,145946,2,3613,0)="""RTN"",""IBCNEQU"",48,0)"
^XMB(3.9,145946,2,3614,0)=" N VA,VAERR,%DT,II"
^XMB(3.9,145946,2,3615,0)="""RTN"",""IBCNEQU"",49,0)"
^XMB(3.9,145946,2,3616,0)=" D PID^VADPT"
^XMB(3.9,145946,2,3617,0)="""RTN"",""IBCNEQU"",50,0)"
^XMB(3.9,145946,2,3618,0)=" S VALMHDR(1)=""Request Electronic Insurance Inquiry for Patient: ""_$E($P($G(^DPT(DFN,0)),U),1,20)_"" ""_$E($G(^(0)),1)_VA(""BID"")"
^XMB(3.9,145946,2,3619,0)="""RTN"",""IBCNEQU"",51,0)"
^XMB(3.9,145946,2,3620,0)=" S VALMHDR(2)="" """
^XMB(3.9,145946,2,3621,0)="""RTN"",""IBCNEQU"",52,0)"
^XMB(3.9,145946,2,3622,0)=" S VALMHDR(3)="" """
^XMB(3.9,145946,2,3623,0)="""RTN"",""IBCNEQU"",53,0)"
^XMB(3.9,145946,2,3624,0)=" S II=1"
^XMB(3.9,145946,2,3625,0)="""RTN"",""IBCNEQU"",54,0)"
^XMB(3.9,145946,2,3626,0)=" I +$$BUFFER^IBCNBU1(DFN) S II=II+1,VALMHDR(II)=""*** Patient has Insurance Buffer Records"""
^XMB(3.9,145946,2,3627,0)="""RTN"",""IBCNEQU"",55,0)"
^XMB(3.9,145946,2,3628,0)=" I $P($G(^DPT(DFN,.35)),U)'="""" S II=II+1,VALMHDR(II)=""*** Date of Death: ""_$$FMTE^XLFDT($P($G(^DPT(DFN,.35)),U)\1,""5Z"")"
^XMB(3.9,145946,2,3629,0)="""RTN"",""IBCNEQU"",56,0)"
^XMB(3.9,145946,2,3630,0)=" Q"
^XMB(3.9,145946,2,3631,0)="""RTN"",""IBCNEQU"",57,0)"
^XMB(3.9,145946,2,3632,0)=" ;"
^XMB(3.9,145946,2,3633,0)="""RTN"",""IBCNEQU"",58,0)"
^XMB(3.9,145946,2,3634,0)="HELP ; -- help code"
^XMB(3.9,145946,2,3635,0)="""RTN"",""IBCNEQU"",59,0)"
^XMB(3.9,145946,2,3636,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,3637,0)="""RTN"",""IBCNEQU"",60,0)"
^XMB(3.9,145946,2,3638,0)=" W @IOF"
^XMB(3.9,145946,2,3639,0)="""RTN"",""IBCNEQU"",61,0)"
^XMB(3.9,145946,2,3640,0)=" W !,""When requesting an Electronic Insurance Inquiry..."" ; IB*2*601/DM"
^XMB(3.9,145946,2,3641,0)="""RTN"",""IBCNEQU"",62,0)"
^XMB(3.9,145946,2,3642,0)=" W !,""This screen lists all eligible (non-Medicaid) Insurance policies for the"""
^XMB(3.9,145946,2,3643,0)="""RTN"",""IBCNEQU"",63,0)"
^XMB(3.9,145946,2,3644,0)=" W !,""patient. Selecting an entry here creates an Insurance Buffer entry with Source"""
^XMB(3.9,145946,2,3645,0)="""RTN"",""IBCNEQU"",64,0)"
^XMB(3.9,145946,2,3646,0)=" W !,""'eIV' and Override Freshness Flag 'Yes'. Setting this flag is designed to force"""
^XMB(3.9,145946,2,3647,0)="""RTN"",""IBCNEQU"",65,0)"
^XMB(3.9,145946,2,3648,0)=" W !,""the eIV extract to attempt to create an insurance inquiry based on this entry."""
^XMB(3.9,145946,2,3649,0)="""RTN"",""IBCNEQU"",66,0)"
^XMB(3.9,145946,2,3650,0)=" W !!,""Entries with an asterisk (*) preceding the Insurance Co name already exist in"""
^XMB(3.9,145946,2,3651,0)="""RTN"",""IBCNEQU"",67,0)"
^XMB(3.9,145946,2,3652,0)=" W !,""the Insurance Buffer with the exact same name, the exact same Group Number,"""
^XMB(3.9,145946,2,3653,0)="""RTN"",""IBCNEQU"",68,0)"
^XMB(3.9,145946,2,3654,0)=" W !,""and the Override Freshness Flag set to 'Yes'."""
^XMB(3.9,145946,2,3655,0)="""RTN"",""IBCNEQU"",69,0)"
^XMB(3.9,145946,2,3656,0)=" ; IB*2*601/DM"
^XMB(3.9,145946,2,3657,0)="""RTN"",""IBCNEQU"",70,0)"
^XMB(3.9,145946,2,3658,0)=" W !!,""When requesting a MBI lookup..."""
^XMB(3.9,145946,2,3659,0)="""RTN"",""IBCNEQU"",71,0)"
^XMB(3.9,145946,2,3660,0)=" W !,""Policies will be listed as described above for electronic insurance inquiry;"""
^XMB(3.9,145946,2,3661,0)="""RTN"",""IBCNEQU"",72,0)"
^XMB(3.9,145946,2,3662,0)=" W !,""however, no special 'checks' will be made. The MBI request will be initiated """
^XMB(3.9,145946,2,3663,0)="""RTN"",""IBCNEQU"",73,0)"
^XMB(3.9,145946,2,3664,0)=" W !,""immediately, regardless of policies above and resulting buffer entry will have"""
^XMB(3.9,145946,2,3665,0)="""RTN"",""IBCNEQU"",74,0)"
^XMB(3.9,145946,2,3666,0)=" W !,""source 'Medicare'."""
^XMB(3.9,145946,2,3667,0)="""RTN"",""IBCNEQU"",75,0)"
^XMB(3.9,145946,2,3668,0)=" ; IB*2*702/TAZ - Added following lines"
^XMB(3.9,145946,2,3669,0)="""RTN"",""IBCNEQU"",76,0)"
^XMB(3.9,145946,2,3670,0)=" W !!,""When initiating an EICD Request..."""
^XMB(3.9,145946,2,3671,0)="""RTN"",""IBCNEQU"",77,0)"
^XMB(3.9,145946,2,3672,0)=" W !,""An EICD request will be initiated if the following conditions are met:"""
^XMB(3.9,145946,2,3673,0)="""RTN"",""IBCNEQU"",78,0)"
^XMB(3.9,145946,2,3674,0)=" W !,"" - The patient does not have active insurance on file."""
^XMB(3.9,145946,2,3675,0)="""RTN"",""IBCNEQU"",79,0)"
^XMB(3.9,145946,2,3676,0)=" W !,"" - The patient does not have an eligibility exclusion."""
^XMB(3.9,145946,2,3677,0)="""RTN"",""IBCNEQU"",80,0)"
^XMB(3.9,145946,2,3678,0)=" W !,"" - There have been no other recent EICD requests."""
^XMB(3.9,145946,2,3679,0)="""RTN"",""IBCNEQU"",81,0)"
^XMB(3.9,145946,2,3680,0)=" W !"
^XMB(3.9,145946,2,3681,0)="""RTN"",""IBCNEQU"",82,0)"
^XMB(3.9,145946,2,3682,0)=" ;"
^XMB(3.9,145946,2,3683,0)="""RTN"",""IBCNEQU"",83,0)"
^XMB(3.9,145946,2,3684,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,3685,0)="""RTN"",""IBCNEQU"",84,0)"
^XMB(3.9,145946,2,3686,0)=" Q"
^XMB(3.9,145946,2,3687,0)="""RTN"",""IBCNEQU"",85,0)"
^XMB(3.9,145946,2,3688,0)=" ;"
^XMB(3.9,145946,2,3689,0)="""RTN"",""IBCNEQU"",86,0)"
^XMB(3.9,145946,2,3690,0)="EXIT ; -- exit code"
^XMB(3.9,145946,2,3691,0)="""RTN"",""IBCNEQU"",87,0)"
^XMB(3.9,145946,2,3692,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J)"
^XMB(3.9,145946,2,3693,0)="""RTN"",""IBCNEQU"",88,0)"
^XMB(3.9,145946,2,3694,0)=" Q"
^XMB(3.9,145946,2,3695,0)="""RTN"",""IBCNEQU"",89,0)"
^XMB(3.9,145946,2,3696,0)=" ;"
^XMB(3.9,145946,2,3697,0)="""RTN"",""IBCNEQU"",90,0)"
^XMB(3.9,145946,2,3698,0)="PAT() ; Prompt user to select a patient"
^XMB(3.9,145946,2,3699,0)="""RTN"",""IBCNEQU"",91,0)"
^XMB(3.9,145946,2,3700,0)=" ; Init vars"
^XMB(3.9,145946,2,3701,0)="""RTN"",""IBCNEQU"",92,0)"
^XMB(3.9,145946,2,3702,0)=" N DIC,X,Y,DISYS,%H,%I,DUOUT,DTOUT"
^XMB(3.9,145946,2,3703,0)="""RTN"",""IBCNEQU"",93,0)"
^XMB(3.9,145946,2,3704,0)=" ;"
^XMB(3.9,145946,2,3705,0)="""RTN"",""IBCNEQU"",94,0)"
^XMB(3.9,145946,2,3706,0)=" W !"
^XMB(3.9,145946,2,3707,0)="""RTN"",""IBCNEQU"",95,0)"
^XMB(3.9,145946,2,3708,0)=" ;IB*822/CKB - allow the selection of non-Veterans, only exclude Test patients ; Exclude non-Veterans"
^XMB(3.9,145946,2,3709,0)="""RTN"",""IBCNEQU"",96,0)"
^XMB(3.9,145946,2,3710,0)=" S DIC(0)=""AEQMN"""
^XMB(3.9,145946,2,3711,0)="""RTN"",""IBCNEQU"",97,0)"
^XMB(3.9,145946,2,3712,0)=" ;S DIC(""S"")=""I $G(^(""""VET""""))=""""Y"""",('$P($G(^(0)),U,21))"",DIC=""^DPT("""
^XMB(3.9,145946,2,3713,0)="""RTN"",""IBCNEQU"",98,0)"
^XMB(3.9,145946,2,3714,0)=" S DIC(""S"")=""I '$P($G(^(0)),U,21)"",DIC=""^DPT("""
^XMB(3.9,145946,2,3715,0)="""RTN"",""IBCNEQU"",99,0)"
^XMB(3.9,145946,2,3716,0)=" D ^DIC"
^XMB(3.9,145946,2,3717,0)="""RTN"",""IBCNEQU"",100,0)"
^XMB(3.9,145946,2,3718,0)=" I $D(DUOUT)!$D(DTOUT)!(Y<1) Q """""
^XMB(3.9,145946,2,3719,0)="""RTN"",""IBCNEQU"",101,0)"
^XMB(3.9,145946,2,3720,0)=" ;"
^XMB(3.9,145946,2,3721,0)="""RTN"",""IBCNEQU"",102,0)"
^XMB(3.9,145946,2,3722,0)=" Q +Y"
^XMB(3.9,145946,2,3723,0)="""RTN"",""IBCNEQU"",103,0)"
^XMB(3.9,145946,2,3724,0)=" ;"
^XMB(3.9,145946,2,3725,0)="""RTN"",""IBCNEQU"",104,0)"
^XMB(3.9,145946,2,3726,0)="BLD(DFN) ; Build list of all insurance for patient"
^XMB(3.9,145946,2,3727,0)="""RTN"",""IBCNEQU"",105,0)"
^XMB(3.9,145946,2,3728,0)=" N IBCT,IBINS,IBDATA0,IBDATA1,IBDATA2,II,STR,IBINSIEN,IBINAME,IBHOLD"
^XMB(3.9,145946,2,3729,0)="""RTN"",""IBCNEQU"",106,0)"
^XMB(3.9,145946,2,3730,0)=" N VNODT,X,POP,IBBUF,IBBUFNM,IBIEN,IBBUFDT,TMPNM,GRPNUM,SFANAME"
^XMB(3.9,145946,2,3731,0)="""RTN"",""IBCNEQU"",107,0)"
^XMB(3.9,145946,2,3732,0)=" ;"
^XMB(3.9,145946,2,3733,0)="""RTN"",""IBCNEQU"",108,0)"
^XMB(3.9,145946,2,3734,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J)"
^XMB(3.9,145946,2,3735,0)="""RTN"",""IBCNEQU"",109,0)"
^XMB(3.9,145946,2,3736,0)=" ;"
^XMB(3.9,145946,2,3737,0)="""RTN"",""IBCNEQU"",110,0)"
^XMB(3.9,145946,2,3738,0)=" S (IBCT,VALMCNT)=0"
^XMB(3.9,145946,2,3739,0)="""RTN"",""IBCNEQU"",111,0)"
^XMB(3.9,145946,2,3740,0)=" ;"
^XMB(3.9,145946,2,3741,0)="""RTN"",""IBCNEQU"",112,0)"
^XMB(3.9,145946,2,3742,0)=" ; Determine if buffer entries exist for this DFN and build array by name"
^XMB(3.9,145946,2,3743,0)="""RTN"",""IBCNEQU"",113,0)"
^XMB(3.9,145946,2,3744,0)=" S IBIEN=0"
^XMB(3.9,145946,2,3745,0)="""RTN"",""IBCNEQU"",114,0)"
^XMB(3.9,145946,2,3746,0)=" F  S IBIEN=$O(^IBA(355.33,""C"",DFN,IBIEN)) Q:'IBIEN  D"
^XMB(3.9,145946,2,3747,0)="""RTN"",""IBCNEQU"",115,0)"
^XMB(3.9,145946,2,3748,0)=" . S IBBUFDT=$G(^IBA(355.33,IBIEN,0))"
^XMB(3.9,145946,2,3749,0)="""RTN"",""IBCNEQU"",116,0)"
^XMB(3.9,145946,2,3750,0)=" . ; Include E status only"
^XMB(3.9,145946,2,3751,0)="""RTN"",""IBCNEQU"",117,0)"
^XMB(3.9,145946,2,3752,0)=" . I $P(IBBUFDT,U,4)'=""E"" Q"
^XMB(3.9,145946,2,3753,0)="""RTN"",""IBCNEQU"",118,0)"
^XMB(3.9,145946,2,3754,0)=" . S IBBUFNM=$$TRIM^XLFSTR($P($G(^IBA(355.33,IBIEN,20)),U))"
^XMB(3.9,145946,2,3755,0)="""RTN"",""IBCNEQU"",119,0)"
^XMB(3.9,145946,2,3756,0)=" . I IBBUFNM="""" Q"
