^XMB(3.9,145946,2,645,0)="""RTN"",""IBCMDT"",1,0)"
^XMB(3.9,145946,2,646,0)="IBCMDT ;ALB/VD - INSURANCE PLANS MISSING DATA REPORT (DRIVER) ; 10-APR-15"
^XMB(3.9,145946,2,647,0)="""RTN"",""IBCMDT"",2,0)"
