^XMB(3.9,145946,2,3961,0)="""RTN"",""IBCNEQU"",222,0)"
^XMB(3.9,145946,2,3962,0)=" ;"
^XMB(3.9,145946,2,3963,0)="""RTN"",""IBCNEQU"",223,0)"
^XMB(3.9,145946,2,3964,0)=" S IBSELN="""""
^XMB(3.9,145946,2,3965,0)="""RTN"",""IBCNEQU"",224,0)"
^XMB(3.9,145946,2,3966,0)=" ; Select entry to reconfirm"
^XMB(3.9,145946,2,3967,0)="""RTN"",""IBCNEQU"",225,0)"
^XMB(3.9,145946,2,3968,0)=" S DIR(0)=""NO^1:""_$G(^TMP(""IBCNEQUX"",$J))_"":0"""
^XMB(3.9,145946,2,3969,0)="""RTN"",""IBCNEQU"",226,0)"
^XMB(3.9,145946,2,3970,0)=" S DIR(""A"")=""Select entry to request electronic inquiry"""
^XMB(3.9,145946,2,3971,0)="""RTN"",""IBCNEQU"",227,0)"
^XMB(3.9,145946,2,3972,0)=" S DIR(""?"",1)=""  Select an entry to initiate an insurance inquiry."""
^XMB(3.9,145946,2,3973,0)="""RTN"",""IBCNEQU"",228,0)"
^XMB(3.9,145946,2,3974,0)=" S DIR(""?"",2)=""  If entry contains an Insurance Co name, an Insurance"""
^XMB(3.9,145946,2,3975,0)="""RTN"",""IBCNEQU"",229,0)"
^XMB(3.9,145946,2,3976,0)=" S DIR(""?"",3)=""  Buffer entry will be created for nightly batch extract."""
^XMB(3.9,145946,2,3977,0)="""RTN"",""IBCNEQU"",230,0)"
^XMB(3.9,145946,2,3978,0)=" S DIR(""?"")=""  """
^XMB(3.9,145946,2,3979,0)="""RTN"",""IBCNEQU"",231,0)"
^XMB(3.9,145946,2,3980,0)=" D ^DIR K DIR"
^XMB(3.9,145946,2,3981,0)="""RTN"",""IBCNEQU"",232,0)"
^XMB(3.9,145946,2,3982,0)=" I $D(DIRUT)!$D(DUOUT)!(Y<1) G SELX"
^XMB(3.9,145946,2,3983,0)="""RTN"",""IBCNEQU"",233,0)"
^XMB(3.9,145946,2,3984,0)=" S IBSELN=$O(^TMP(""IBCNEQU"",$J,""IDX"",Y,0))"
^XMB(3.9,145946,2,3985,0)="""RTN"",""IBCNEQU"",234,0)"
^XMB(3.9,145946,2,3986,0)=" I IBSELN S IBSELN=$P($G(^TMP(""IBCNEQUX"",$J,IBSELN)),U,2,99)"
^XMB(3.9,145946,2,3987,0)="""RTN"",""IBCNEQU"",235,0)"
^XMB(3.9,145946,2,3988,0)=" I $E($P(IBSELN,U,3))=""*"" W ! D  S IBSELN="""" G SELX"
^XMB(3.9,145946,2,3989,0)="""RTN"",""IBCNEQU"",236,0)"
^XMB(3.9,145946,2,3990,0)=" .S DIR(0)=""EA"""
^XMB(3.9,145946,2,3991,0)="""RTN"",""IBCNEQU"",237,0)"
^XMB(3.9,145946,2,3992,0)=" .S DIR(""A"",1)="""""
^XMB(3.9,145946,2,3993,0)="""RTN"",""IBCNEQU"",238,0)"
^XMB(3.9,145946,2,3994,0)=" .S DIR(""A"",2)=""Selected policy has an existing buffer entry."""
^XMB(3.9,145946,2,3995,0)="""RTN"",""IBCNEQU"",239,0)"
^XMB(3.9,145946,2,3996,0)=" .S DIR(""A"",3)=""You must first process the existing buffer entry."""
^XMB(3.9,145946,2,3997,0)="""RTN"",""IBCNEQU"",240,0)"
^XMB(3.9,145946,2,3998,0)=" .S DIR(""A"")=""Press RETURN to continue "" D ^DIR K DIR W !"
^XMB(3.9,145946,2,3999,0)="""RTN"",""IBCNEQU"",241,0)"
^XMB(3.9,145946,2,4000,0)=" .Q"
^XMB(3.9,145946,2,4001,0)="""RTN"",""IBCNEQU"",242,0)"
^XMB(3.9,145946,2,4002,0)=" ;"
^XMB(3.9,145946,2,4003,0)="""RTN"",""IBCNEQU"",243,0)"
^XMB(3.9,145946,2,4004,0)=" ; Get service type code"
^XMB(3.9,145946,2,4005,0)="""RTN"",""IBCNEQU"",244,0)"
^XMB(3.9,145946,2,4006,0)=" D STC"
^XMB(3.9,145946,2,4007,0)="""RTN"",""IBCNEQU"",245,0)"
^XMB(3.9,145946,2,4008,0)=" I X=""^"" S IBSELN="""" G SELX  ; '^' entered thus backup a level & re-ask Insurance question"
^XMB(3.9,145946,2,4009,0)="""RTN"",""IBCNEQU"",246,0)"
^XMB(3.9,145946,2,4010,0)=" ; Get eligibility date"
^XMB(3.9,145946,2,4011,0)="""RTN"",""IBCNEQU"",247,0)"
^XMB(3.9,145946,2,4012,0)=" S IBELIGDT=$$ELIGDT() I 'IBELIGDT S IBSELN="""" G SELX"
^XMB(3.9,145946,2,4013,0)="""RTN"",""IBCNEQU"",248,0)"
^XMB(3.9,145946,2,4014,0)=" W !"
^XMB(3.9,145946,2,4015,0)="""RTN"",""IBCNEQU"",249,0)"
^XMB(3.9,145946,2,4016,0)=" S DIR(0)=""Y"""
^XMB(3.9,145946,2,4017,0)="""RTN"",""IBCNEQU"",250,0)"
^XMB(3.9,145946,2,4018,0)=" S DIR(""A"")=""Are you sure you want to request an insurance inquiry"""
^XMB(3.9,145946,2,4019,0)="""RTN"",""IBCNEQU"",251,0)"
^XMB(3.9,145946,2,4020,0)=" S DIR(""B"")=""NO"""
^XMB(3.9,145946,2,4021,0)="""RTN"",""IBCNEQU"",252,0)"
^XMB(3.9,145946,2,4022,0)=" S DIR(""?"",1)=""  If yes, a request will be created for the nightly batch."""
^XMB(3.9,145946,2,4023,0)="""RTN"",""IBCNEQU"",253,0)"
^XMB(3.9,145946,2,4024,0)=" D ^DIR K DIR"
^XMB(3.9,145946,2,4025,0)="""RTN"",""IBCNEQU"",254,0)"
^XMB(3.9,145946,2,4026,0)=" I $D(DIRUT)!$D(DUOUT)!('Y) S IBSELN="""""
^XMB(3.9,145946,2,4027,0)="""RTN"",""IBCNEQU"",255,0)"
^XMB(3.9,145946,2,4028,0)=" ;"
^XMB(3.9,145946,2,4029,0)="""RTN"",""IBCNEQU"",256,0)"
^XMB(3.9,145946,2,4030,0)="SELX Q IBSELN"
^XMB(3.9,145946,2,4031,0)="""RTN"",""IBCNEQU"",257,0)"
^XMB(3.9,145946,2,4032,0)=" ;"
^XMB(3.9,145946,2,4033,0)="""RTN"",""IBCNEQU"",258,0)"
^XMB(3.9,145946,2,4034,0)="STC ; Ask for service type code to send"
^XMB(3.9,145946,2,4035,0)="""RTN"",""IBCNEQU"",259,0)"
^XMB(3.9,145946,2,4036,0)=" ; IB*582/HN - Modified Default Service Type Code to pull from the MCCF Billing Parameters File (350.9,60.01)"
^XMB(3.9,145946,2,4037,0)="""RTN"",""IBCNEQU"",260,0)"
^XMB(3.9,145946,2,4038,0)=" N DIR,X,Y"
^XMB(3.9,145946,2,4039,0)="""RTN"",""IBCNEQU"",261,0)"
^XMB(3.9,145946,2,4040,0)=" ; IBEISTC used as STC variable"
^XMB(3.9,145946,2,4041,0)="""RTN"",""IBCNEQU"",262,0)"
^XMB(3.9,145946,2,4042,0)=" S IBEISTC="""""
^XMB(3.9,145946,2,4043,0)="""RTN"",""IBCNEQU"",263,0)"
^XMB(3.9,145946,2,4044,0)=" S DIR(0)=""PAO^365.013:EMZ"",DIR(""A"")=""Enter Service Type Code: """
^XMB(3.9,145946,2,4045,0)="""RTN"",""IBCNEQU"",264,0)"
^XMB(3.9,145946,2,4046,0)=" S DIR(""B"")=$$GET1^DIQ(350.9,1_"","",60.01,""E"")"
^XMB(3.9,145946,2,4047,0)="""RTN"",""IBCNEQU"",265,0)"
^XMB(3.9,145946,2,4048,0)=" S DIR(""??"")=""^D HELPSTC2^IBCNEQU"""
^XMB(3.9,145946,2,4049,0)="""RTN"",""IBCNEQU"",266,0)"
^XMB(3.9,145946,2,4050,0)="STCEN ; Intital and re-enterant tag upon error"
^XMB(3.9,145946,2,4051,0)="""RTN"",""IBCNEQU"",267,0)"
^XMB(3.9,145946,2,4052,0)=" D ^DIR Q:X=""^"""
^XMB(3.9,145946,2,4053,0)="""RTN"",""IBCNEQU"",268,0)"
^XMB(3.9,145946,2,4054,0)=" ; Check to verify code is active, if not, display error and ask again"
^XMB(3.9,145946,2,4055,0)="""RTN"",""IBCNEQU"",269,0)"
^XMB(3.9,145946,2,4056,0)=" I $P($G(Y(0)),U,3)'="""" W !,""Code selected is not an active code - please select another code."",! G STCEN"
^XMB(3.9,145946,2,4057,0)="""RTN"",""IBCNEQU"",270,0)"
^XMB(3.9,145946,2,4058,0)=" ; If valid STC entered, set IBEISTC to be STC IEN. If no code entered, default to service code 30"
^XMB(3.9,145946,2,4059,0)="""RTN"",""IBCNEQU"",271,0)"
^XMB(3.9,145946,2,4060,0)=" ;S IBEISTC=$S(+Y>0:$P(Y,U,1),1:$O(^IBE(365.013,""B"",30,"""")))"
^XMB(3.9,145946,2,4061,0)="""RTN"",""IBCNEQU"",272,0)"
^XMB(3.9,145946,2,4062,0)=" ; If valid STC entered, set IBEISTC to be STCIEN."
^XMB(3.9,145946,2,4063,0)="""RTN"",""IBCNEQU"",273,0)"
^XMB(3.9,145946,2,4064,0)=" S IBEISTC=$P(Y,U,1)"
^XMB(3.9,145946,2,4065,0)="""RTN"",""IBCNEQU"",274,0)"
^XMB(3.9,145946,2,4066,0)=" Q"
^XMB(3.9,145946,2,4067,0)="""RTN"",""IBCNEQU"",275,0)"
^XMB(3.9,145946,2,4068,0)=" ;"
^XMB(3.9,145946,2,4069,0)="""RTN"",""IBCNEQU"",276,0)"
^XMB(3.9,145946,2,4070,0)="FASTEXIT ; Sets flag to indicate a quick exit from the option"
^XMB(3.9,145946,2,4071,0)="""RTN"",""IBCNEQU"",277,0)"
^XMB(3.9,145946,2,4072,0)=" N DIR,DIRUT,X,Y"
^XMB(3.9,145946,2,4073,0)="""RTN"",""IBCNEQU"",278,0)"
^XMB(3.9,145946,2,4074,0)=" S VALMBCK=""Q"""
^XMB(3.9,145946,2,4075,0)="""RTN"",""IBCNEQU"",279,0)"
^XMB(3.9,145946,2,4076,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,4077,0)="""RTN"",""IBCNEQU"",280,0)"
^XMB(3.9,145946,2,4078,0)=" S DIR(0)=""Y"",DIR(""A"")=""Exit option entirely"",DIR(""B"")=""NO"""
^XMB(3.9,145946,2,4079,0)="""RTN"",""IBCNEQU"",281,0)"
^XMB(3.9,145946,2,4080,0)=" D ^DIR"
^XMB(3.9,145946,2,4081,0)="""RTN"",""IBCNEQU"",282,0)"
^XMB(3.9,145946,2,4082,0)=" I +Y S IBFASTXT=1"
^XMB(3.9,145946,2,4083,0)="""RTN"",""IBCNEQU"",283,0)"
^XMB(3.9,145946,2,4084,0)=" Q"
^XMB(3.9,145946,2,4085,0)="""RTN"",""IBCNEQU"",284,0)"
^XMB(3.9,145946,2,4086,0)=" ;"
^XMB(3.9,145946,2,4087,0)="""RTN"",""IBCNEQU"",285,0)"
^XMB(3.9,145946,2,4088,0)="HELPSTC2 ; Text to display in response to '??' entry"
^XMB(3.9,145946,2,4089,0)="""RTN"",""IBCNEQU"",286,0)"
^XMB(3.9,145946,2,4090,0)=" N DIR"
^XMB(3.9,145946,2,4091,0)="""RTN"",""IBCNEQU"",287,0)"
^XMB(3.9,145946,2,4092,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,4093,0)="""RTN"",""IBCNEQU"",288,0)"
^XMB(3.9,145946,2,4094,0)=" W @IOF"
^XMB(3.9,145946,2,4095,0)="""RTN"",""IBCNEQU"",289,0)"
^XMB(3.9,145946,2,4096,0)=" ;IB*732/DTG start - change help text to reflect code is dictionary driven"
^XMB(3.9,145946,2,4097,0)="""RTN"",""IBCNEQU"",290,0)"
^XMB(3.9,145946,2,4098,0)=" W !,""Enter the single SERVICE TYPE CODE to be sent with inquiry or press"""
^XMB(3.9,145946,2,4099,0)="""RTN"",""IBCNEQU"",291,0)"
^XMB(3.9,145946,2,4100,0)=" W !,""'ENTER' to send default service type code. The default service type"""
^XMB(3.9,145946,2,4101,0)="""RTN"",""IBCNEQU"",292,0)"
^XMB(3.9,145946,2,4102,0)=" W !,""code may auto-update. All other service types will not auto-update."""
^XMB(3.9,145946,2,4103,0)="""RTN"",""IBCNEQU"",293,0)"
^XMB(3.9,145946,2,4104,0)=" ;IB*732/DTG end - change help text to reflect code is dictionary driven"
^XMB(3.9,145946,2,4105,0)="""RTN"",""IBCNEQU"",294,0)"
^XMB(3.9,145946,2,4106,0)=" Q"
^XMB(3.9,145946,2,4107,0)="""RTN"",""IBCNEQU"",295,0)"
^XMB(3.9,145946,2,4108,0)=" ;"
^XMB(3.9,145946,2,4109,0)="""RTN"",""IBCNEQU"",296,0)"
^XMB(3.9,145946,2,4110,0)="ELIGDT() ; Prompt user for eligibility date"
^XMB(3.9,145946,2,4111,0)="""RTN"",""IBCNEQU"",297,0)"
^XMB(3.9,145946,2,4112,0)=" ;IB*822/CKB - modify the allowable DOS value within Request Electronic"
^XMB(3.9,145946,2,4113,0)="""RTN"",""IBCNEQU"",298,0)"
^XMB(3.9,145946,2,4114,0)=" N DIR,X,Y,DIRUT,DUOUT,EADT,ENDDT,ELIGDT,INSIEN"
^XMB(3.9,145946,2,4115,0)="""RTN"",""IBCNEQU"",299,0)"
^XMB(3.9,145946,2,4116,0)=" N PAYERSTR,PEDT,PIEN,PSDT,PYRAPP,PYRFUTURE,PYRPAST,SADT,STARTDT"
^XMB(3.9,145946,2,4117,0)="""RTN"",""IBCNEQU"",300,0)"
^XMB(3.9,145946,2,4118,0)=" S ELIGDT="""""
^XMB(3.9,145946,2,4119,0)="""RTN"",""IBCNEQU"",301,0)"
^XMB(3.9,145946,2,4120,0)=" ;D DT^DILF(,""T-12M"",.STARTDT) ; start date within the last 12 months"
^XMB(3.9,145946,2,4121,0)="""RTN"",""IBCNEQU"",302,0)"
^XMB(3.9,145946,2,4122,0)=" ; allow end date up to the end of the current month"
^XMB(3.9,145946,2,4123,0)="""RTN"",""IBCNEQU"",303,0)"
^XMB(3.9,145946,2,4124,0)=" ;S ENDDT=$$SCH^XLFDT(""1M(L@1A)"",DT)\1 ; ICR#10103 this call returns the last day of the current month at 1 AM.  If not time was sent, it would actually return the next to last day at 2400 hours."
^XMB(3.9,145946,2,4125,0)="""RTN"",""IBCNEQU"",304,0)"
^XMB(3.9,145946,2,4126,0)=" ; "
^XMB(3.9,145946,2,4127,0)="""RTN"",""IBCNEQU"",305,0)"
^XMB(3.9,145946,2,4128,0)=" ; From the Payer, get the number of FUTURE SERVICE DAYS and PAST SERVICE DAYS"
^XMB(3.9,145946,2,4129,0)="""RTN"",""IBCNEQU"",306,0)"
^XMB(3.9,145946,2,4130,0)=" D GETPYR"
^XMB(3.9,145946,2,4131,0)="""RTN"",""IBCNEQU"",307,0)"
^XMB(3.9,145946,2,4132,0)=" ; set the Payer Start & End date"
^XMB(3.9,145946,2,4133,0)="""RTN"",""IBCNEQU"",308,0)"
^XMB(3.9,145946,2,4134,0)=" I PYRPAST'=0 D DT^DILF(,""T-""_PYRPAST_""D"",.PSDT) ; ICR #2054"
^XMB(3.9,145946,2,4135,0)="""RTN"",""IBCNEQU"",309,0)"
^XMB(3.9,145946,2,4136,0)=" I PYRPAST=0 S PSDT=DT"
^XMB(3.9,145946,2,4137,0)="""RTN"",""IBCNEQU"",310,0)"
^XMB(3.9,145946,2,4138,0)=" I PYRFUTURE'=0 D DT^DILF(,""T+""_PYRFUTURE_""D"",.PEDT)"
^XMB(3.9,145946,2,4139,0)="""RTN"",""IBCNEQU"",311,0)"
^XMB(3.9,145946,2,4140,0)=" I PYRFUTURE=0 S PEDT=DT"
^XMB(3.9,145946,2,4141,0)="""RTN"",""IBCNEQU"",312,0)"
^XMB(3.9,145946,2,4142,0)=" ; set the ""allowable"" Start & End dates"
^XMB(3.9,145946,2,4143,0)="""RTN"",""IBCNEQU"",313,0)"
^XMB(3.9,145946,2,4144,0)=" D DT^DILF(,""T-72M"",.SADT)     ; 6 years or 72 months in the Past"
^XMB(3.9,145946,2,4145,0)="""RTN"",""IBCNEQU"",314,0)"
^XMB(3.9,145946,2,4146,0)=" D DT^DILF(,""T+4M"",.EADT)      ; 4 months in the Future"
^XMB(3.9,145946,2,4147,0)="""RTN"",""IBCNEQU"",315,0)"
^XMB(3.9,145946,2,4148,0)=" ; compare ALLOWABLE dates against PAYER dates, select whichever is closest to today"
^XMB(3.9,145946,2,4149,0)="""RTN"",""IBCNEQU"",316,0)"
^XMB(3.9,145946,2,4150,0)=" S STARTDT=$S(SADT<PSDT:PSDT,1:SADT)"
^XMB(3.9,145946,2,4151,0)="""RTN"",""IBCNEQU"",317,0)"
^XMB(3.9,145946,2,4152,0)=" S ENDDT=$S(EADT>PEDT:PEDT,1:EADT)"
^XMB(3.9,145946,2,4153,0)="""RTN"",""IBCNEQU"",318,0)"
^XMB(3.9,145946,2,4154,0)=" ;"
^XMB(3.9,145946,2,4155,0)="""RTN"",""IBCNEQU"",319,0)"
^XMB(3.9,145946,2,4156,0)=" W !!,""For this policy,"",!,""the allowable eligibility dates are between """
^XMB(3.9,145946,2,4157,0)="""RTN"",""IBCNEQU"",320,0)"
^XMB(3.9,145946,2,4158,0)=" W $$FMTE^XLFDT(STARTDT,2)_"" and ""_$$FMTE^XLFDT(ENDDT,2)_"", inclusive."",!"
^XMB(3.9,145946,2,4159,0)="""RTN"",""IBCNEQU"",321,0)"
^XMB(3.9,145946,2,4160,0)=" ;"
^XMB(3.9,145946,2,4161,0)="""RTN"",""IBCNEQU"",322,0)"
^XMB(3.9,145946,2,4162,0)=" S DIR(0)=""DA^""_STARTDT_"":""_ENDDT_"":""_""EX"""
^XMB(3.9,145946,2,4163,0)="""RTN"",""IBCNEQU"",323,0)"
^XMB(3.9,145946,2,4164,0)=" S DIR(""A"")=""Enter Eligibility Date: "",DIR(""B"")=""TODAY"""
^XMB(3.9,145946,2,4165,0)="""RTN"",""IBCNEQU"",324,0)"
^XMB(3.9,145946,2,4166,0)=" S DIR(""?"",1)=""Enter an eligibility date to be sent in the inquiry."""
^XMB(3.9,145946,2,4167,0)="""RTN"",""IBCNEQU"",325,0)"
^XMB(3.9,145946,2,4168,0)=" S DIR(""?"")=""Date must be within the range ""_$$FMTE^XLFDT(STARTDT,2)_"" and ""_$$FMTE^XLFDT(ENDDT,2)_"", inclusive."""
^XMB(3.9,145946,2,4169,0)="""RTN"",""IBCNEQU"",326,0)"
^XMB(3.9,145946,2,4170,0)=" D ^DIR"
^XMB(3.9,145946,2,4171,0)="""RTN"",""IBCNEQU"",327,0)"
^XMB(3.9,145946,2,4172,0)=" I $D(DIRUT)!$D(DUOUT)!('Y) G ELIGDTX"
^XMB(3.9,145946,2,4173,0)="""RTN"",""IBCNEQU"",328,0)"
^XMB(3.9,145946,2,4174,0)=" S ELIGDT=Y"
^XMB(3.9,145946,2,4175,0)="""RTN"",""IBCNEQU"",329,0)"
^XMB(3.9,145946,2,4176,0)="ELIGDTX ; "
^XMB(3.9,145946,2,4177,0)="""RTN"",""IBCNEQU"",330,0)"
^XMB(3.9,145946,2,4178,0)=" Q ELIGDT"
^XMB(3.9,145946,2,4179,0)="""RTN"",""IBCNEQU"",331,0)"
^XMB(3.9,145946,2,4180,0)=" ;"
^XMB(3.9,145946,2,4181,0)="""RTN"",""IBCNEQU"",332,0)"
^XMB(3.9,145946,2,4182,0)="MBIREQ ; User requested a MBI lookup request"
^XMB(3.9,145946,2,4183,0)="""RTN"",""IBCNEQU"",333,0)"
^XMB(3.9,145946,2,4184,0)=" ;/vd-IB*2*668 - Added the variable APIEN"
^XMB(3.9,145946,2,4185,0)="""RTN"",""IBCNEQU"",334,0)"
^XMB(3.9,145946,2,4186,0)=" N APIEN,DIR,X,Y,DIRUT,DUOUT"
^XMB(3.9,145946,2,4187,0)="""RTN"",""IBCNEQU"",335,0)"
^XMB(3.9,145946,2,4188,0)=" N IBMBIPYR,IBBUF,IBFDA"
^XMB(3.9,145946,2,4189,0)="""RTN"",""IBCNEQU"",336,0)"
^XMB(3.9,145946,2,4190,0)=" ;"
^XMB(3.9,145946,2,4191,0)="""RTN"",""IBCNEQU"",337,0)"
^XMB(3.9,145946,2,4192,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,4193,0)="""RTN"",""IBCNEQU"",338,0)"
^XMB(3.9,145946,2,4194,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,4195,0)="""RTN"",""IBCNEQU"",339,0)"
^XMB(3.9,145946,2,4196,0)=" K DIR"
^XMB(3.9,145946,2,4197,0)="""RTN"",""IBCNEQU"",340,0)"
^XMB(3.9,145946,2,4198,0)=" ;"
^XMB(3.9,145946,2,4199,0)="""RTN"",""IBCNEQU"",341,0)"
^XMB(3.9,145946,2,4200,0)=" ; see if the MBI PAYER site parameter has been populated "
^XMB(3.9,145946,2,4201,0)="""RTN"",""IBCNEQU"",342,0)"
^XMB(3.9,145946,2,4202,0)=" S IBMBIPYR=+$$GET1^DIQ(350.9,""1,"",""MBI PAYER"",""I"")"
^XMB(3.9,145946,2,4203,0)="""RTN"",""IBCNEQU"",343,0)"
^XMB(3.9,145946,2,4204,0)=" I 'IBMBIPYR D  G MBIREQX"
^XMB(3.9,145946,2,4205,0)="""RTN"",""IBCNEQU"",344,0)"
^XMB(3.9,145946,2,4206,0)=" . W !!,"" The required MBI Payer site parameter is not populated; try again later"",!"
^XMB(3.9,145946,2,4207,0)="""RTN"",""IBCNEQU"",345,0)"
^XMB(3.9,145946,2,4208,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,4209,0)="""RTN"",""IBCNEQU"",346,0)"
^XMB(3.9,145946,2,4210,0)=" ;"
^XMB(3.9,145946,2,4211,0)="""RTN"",""IBCNEQU"",347,0)"
^XMB(3.9,145946,2,4212,0)=" S APIEN=$$PYRAPP^IBCNEUT5(""EIV"",IBMBIPYR)   ;/vd-IB*2*668"
^XMB(3.9,145946,2,4213,0)="""RTN"",""IBCNEQU"",348,0)"
^XMB(3.9,145946,2,4214,0)=" ;/vd-IB*2*668 - Replaced the following 2 lines of code to remove a hardcoded value."
^XMB(3.9,145946,2,4215,0)="""RTN"",""IBCNEQU"",349,0)"
^XMB(3.9,145946,2,4216,0)=" ;I '($$GET1^DIQ(365.121,""1,""_IBMBIPYR_"","",.02,""I"")) D  G MBIREQX"
^XMB(3.9,145946,2,4217,0)="""RTN"",""IBCNEQU"",350,0)"
^XMB(3.9,145946,2,4218,0)=" ;. W !!,"" The MBI Payer is not nationally active; try again later"",!"
^XMB(3.9,145946,2,4219,0)="""RTN"",""IBCNEQU"",351,0)"
^XMB(3.9,145946,2,4220,0)=" I '($$GET1^DIQ(365.121,APIEN_"",""_IBMBIPYR_"","",.02,""I"")) D  G MBIREQX"
^XMB(3.9,145946,2,4221,0)="""RTN"",""IBCNEQU"",352,0)"
^XMB(3.9,145946,2,4222,0)=" . W !!,"" The MBI Payer is not NATIONALLY Enabled; try again later"",!"
^XMB(3.9,145946,2,4223,0)="""RTN"",""IBCNEQU"",353,0)"
^XMB(3.9,145946,2,4224,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,4225,0)="""RTN"",""IBCNEQU"",354,0)"
^XMB(3.9,145946,2,4226,0)=" ;"
^XMB(3.9,145946,2,4227,0)="""RTN"",""IBCNEQU"",355,0)"
^XMB(3.9,145946,2,4228,0)=" ;/vd-IB*2*668 - Replaced the following 2 lines of code to remove a hardcoded value."
^XMB(3.9,145946,2,4229,0)="""RTN"",""IBCNEQU"",356,0)"
^XMB(3.9,145946,2,4230,0)=" ;I '($$GET1^DIQ(365.121,""1,""_IBMBIPYR_"","",.03,""I"")) D  G MBIREQX"
^XMB(3.9,145946,2,4231,0)="""RTN"",""IBCNEQU"",357,0)"
^XMB(3.9,145946,2,4232,0)=" ;. W !!,"" The MBI Payer LOCAL ACTIVE field is set to 'NO'; it must be 'YES' to proceed"",!"
^XMB(3.9,145946,2,4233,0)="""RTN"",""IBCNEQU"",358,0)"
^XMB(3.9,145946,2,4234,0)=" I '($$GET1^DIQ(365.121,APIEN_"",""_IBMBIPYR_"","",.03,""I"")) D  G MBIREQX"
^XMB(3.9,145946,2,4235,0)="""RTN"",""IBCNEQU"",359,0)"
^XMB(3.9,145946,2,4236,0)=" . W !!,"" The MBI Payer is not LOCALLY Enabled; try again later"",!"
^XMB(3.9,145946,2,4237,0)="""RTN"",""IBCNEQU"",360,0)"
^XMB(3.9,145946,2,4238,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,4239,0)="""RTN"",""IBCNEQU"",361,0)"
^XMB(3.9,145946,2,4240,0)=" ;"
^XMB(3.9,145946,2,4241,0)="""RTN"",""IBCNEQU"",362,0)"
^XMB(3.9,145946,2,4242,0)=" D DEM^VADPT ; ; ICR#10061"
^XMB(3.9,145946,2,4243,0)="""RTN"",""IBCNEQU"",363,0)"
^XMB(3.9,145946,2,4244,0)=" I ($P(VADM(2),U)="""")!($P(VADM(3),U)="""") D  G MBIREQX"
^XMB(3.9,145946,2,4245,0)="""RTN"",""IBCNEQU"",364,0)"
^XMB(3.9,145946,2,4246,0)=" . W !!,"" SSN and DOB are required fields, they must be populated in order to proceed"",!"
^XMB(3.9,145946,2,4247,0)="""RTN"",""IBCNEQU"",365,0)"
^XMB(3.9,145946,2,4248,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,4249,0)="""RTN"",""IBCNEQU"",366,0)"
^XMB(3.9,145946,2,4250,0)=" ; "
^XMB(3.9,145946,2,4251,0)="""RTN"",""IBCNEQU"",367,0)"
^XMB(3.9,145946,2,4252,0)=" S DIR(0)=""Y"""
^XMB(3.9,145946,2,4253,0)="""RTN"",""IBCNEQU"",368,0)"
^XMB(3.9,145946,2,4254,0)=" S DIR(""A"")=""Are you sure you want to request this Patient's Medicare Beneficiary ID"""
^XMB(3.9,145946,2,4255,0)="""RTN"",""IBCNEQU"",369,0)"
^XMB(3.9,145946,2,4256,0)=" S DIR(""B"")=""YES"""
^XMB(3.9,145946,2,4257,0)="""RTN"",""IBCNEQU"",370,0)"
^XMB(3.9,145946,2,4258,0)=" S DIR(""?"",1)=""  If yes, a MBI request will be initiated immediately."""
^XMB(3.9,145946,2,4259,0)="""RTN"",""IBCNEQU"",371,0)"
^XMB(3.9,145946,2,4260,0)=" S DIR(""?"")=""  If no, the MBI request will be cancelled."""
^XMB(3.9,145946,2,4261,0)="""RTN"",""IBCNEQU"",372,0)"
^XMB(3.9,145946,2,4262,0)=" D ^DIR K DIR"
^XMB(3.9,145946,2,4263,0)="""RTN"",""IBCNEQU"",373,0)"
^XMB(3.9,145946,2,4264,0)=" I $D(DIRUT)!$D(DUOUT)!('Y) G MBIREQX"
^XMB(3.9,145946,2,4265,0)="""RTN"",""IBCNEQU"",374,0)"
^XMB(3.9,145946,2,4266,0)=" ;"
^XMB(3.9,145946,2,4267,0)="""RTN"",""IBCNEQU"",375,0)"
^XMB(3.9,145946,2,4268,0)=" ;write a buffer entry "
^XMB(3.9,145946,2,4269,0)="""RTN"",""IBCNEQU"",376,0)"
^XMB(3.9,145946,2,4270,0)=" ;the real time process will set the patient relationship to self automatically"
^XMB(3.9,145946,2,4271,0)="""RTN"",""IBCNEQU"",377,0)"
^XMB(3.9,145946,2,4272,0)=" ;patient fields, name, dob and ssn will be populated automatically"
^XMB(3.9,145946,2,4273,0)="""RTN"",""IBCNEQU"",378,0)"
^XMB(3.9,145946,2,4274,0)=" K IBBUF"
^XMB(3.9,145946,2,4275,0)="""RTN"",""IBCNEQU"",379,0)"
^XMB(3.9,145946,2,4276,0)=" S IBBUF(.02)=DUZ  ; Entered By"
^XMB(3.9,145946,2,4277,0)="""RTN"",""IBCNEQU"",380,0)"
^XMB(3.9,145946,2,4278,0)=" S IBBUF(.12)=$P($$PAYER^IBCNEUT4(IBMBIPYR),U) ; Buffer Symbol "
^XMB(3.9,145946,2,4279,0)="""RTN"",""IBCNEQU"",381,0)"
^XMB(3.9,145946,2,4280,0)=" S IBBUF(20.01)=$$GET1^DIQ(350.9,""1,"",""MBI PAYER"",""E"")"
^XMB(3.9,145946,2,4281,0)="""RTN"",""IBCNEQU"",382,0)"
^XMB(3.9,145946,2,4282,0)=" S IBBUF(60.01)=DFN ; Patient IEN"
^XMB(3.9,145946,2,4283,0)="""RTN"",""IBCNEQU"",383,0)"
^XMB(3.9,145946,2,4284,0)=" S IBBUF(90.03)=""MBIrequest"" ; MBI placeholder for subscriber ID"
^XMB(3.9,145946,2,4285,0)="""RTN"",""IBCNEQU"",384,0)"
^XMB(3.9,145946,2,4286,0)=" S IBBUF(91.01)=VADM(1) ; patient (subscriber) name "
^XMB(3.9,145946,2,4287,0)="""RTN"",""IBCNEQU"",385,0)"
^XMB(3.9,145946,2,4288,0)=" ; the following call in-turn, calls EDITSTF^IBCNBES which will make sure to file subscriber ID last, automatically"
^XMB(3.9,145946,2,4289,0)="""RTN"",""IBCNEQU"",386,0)"
^XMB(3.9,145946,2,4290,0)=" S IBFDA=$$ADDSTF^IBCNBES($$FIND1^DIC(355.12,,,""MEDICARE"",""C""),DFN,.IBBUF)"
^XMB(3.9,145946,2,4291,0)="""RTN"",""IBCNEQU"",387,0)"
^XMB(3.9,145946,2,4292,0)=" ;"
^XMB(3.9,145946,2,4293,0)="""RTN"",""IBCNEQU"",388,0)"
^XMB(3.9,145946,2,4294,0)=" W !!,""The MBI request was successful, check the buffer for results."",!"
^XMB(3.9,145946,2,4295,0)="""RTN"",""IBCNEQU"",389,0)"
^XMB(3.9,145946,2,4296,0)=" S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,145946,2,4297,0)="""RTN"",""IBCNEQU"",390,0)"
^XMB(3.9,145946,2,4298,0)=" S VALMBCK=""Q"""
^XMB(3.9,145946,2,4299,0)="""RTN"",""IBCNEQU"",391,0)"
^XMB(3.9,145946,2,4300,0)=" Q"
^XMB(3.9,145946,2,4301,0)="""RTN"",""IBCNEQU"",392,0)"
^XMB(3.9,145946,2,4302,0)="MBIREQX ;"
^XMB(3.9,145946,2,4303,0)="""RTN"",""IBCNEQU"",393,0)"
^XMB(3.9,145946,2,4304,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,4305,0)="""RTN"",""IBCNEQU"",394,0)"
^XMB(3.9,145946,2,4306,0)=" Q"
^XMB(3.9,145946,2,4307,0)="""RTN"",""IBCNEQU"",395,0)"
^XMB(3.9,145946,2,4308,0)=" ;"
^XMB(3.9,145946,2,4309,0)="""RTN"",""IBCNEQU"",396,0)"
^XMB(3.9,145946,2,4310,0)="GETPYR ;IB*822/CKB - Get the Insurance Company Payer and payer info"
^XMB(3.9,145946,2,4311,0)="""RTN"",""IBCNEQU"",397,0)"
^XMB(3.9,145946,2,4312,0)=" S INSIEN=$P(IBSELN,U,4)"
^XMB(3.9,145946,2,4313,0)="""RTN"",""IBCNEQU"",398,0)"
^XMB(3.9,145946,2,4314,0)=" ;Get Payer info"
^XMB(3.9,145946,2,4315,0)="""RTN"",""IBCNEQU"",399,0)"
^XMB(3.9,145946,2,4316,0)=" S PAYERSTR=$$INSERROR^IBCNEUT3(""I"",INSIEN)"
^XMB(3.9,145946,2,4317,0)="""RTN"",""IBCNEQU"",400,0)"
^XMB(3.9,145946,2,4318,0)=" S PIEN=$P(PAYERSTR,U,2)"
^XMB(3.9,145946,2,4319,0)="""RTN"",""IBCNEQU"",401,0)"
^XMB(3.9,145946,2,4320,0)=" S PYRAPP=$$PYRAPP^IBCNEUT5(""EIV"",PIEN)"
^XMB(3.9,145946,2,4321,0)="""RTN"",""IBCNEQU"",402,0)"
^XMB(3.9,145946,2,4322,0)=" ;"
^XMB(3.9,145946,2,4323,0)="""RTN"",""IBCNEQU"",403,0)"
^XMB(3.9,145946,2,4324,0)=" ;Get FUTURE SERVICE DAYS"
^XMB(3.9,145946,2,4325,0)="""RTN"",""IBCNEQU"",404,0)"
^XMB(3.9,145946,2,4326,0)=" S PYRFUTURE=$$GET1^DIQ(365.121,PYRAPP_"",""_PIEN_"","",4.03,""I"")"
^XMB(3.9,145946,2,4327,0)="""RTN"",""IBCNEQU"",405,0)"
^XMB(3.9,145946,2,4328,0)=" I PYRFUTURE="""" S PYRFUTURE=9999"
^XMB(3.9,145946,2,4329,0)="""RTN"",""IBCNEQU"",406,0)"
^XMB(3.9,145946,2,4330,0)=" ;Get PAST SERVICE DAYS"
^XMB(3.9,145946,2,4331,0)="""RTN"",""IBCNEQU"",407,0)"
^XMB(3.9,145946,2,4332,0)=" S PYRPAST=$$GET1^DIQ(365.121,PYRAPP_"",""_PIEN_"","",4.04,""I"")"
^XMB(3.9,145946,2,4333,0)="""RTN"",""IBCNEQU"",408,0)"
^XMB(3.9,145946,2,4334,0)=" I PYRPAST="""" S PYRPAST=9999"
^XMB(3.9,145946,2,4335,0)="""RTN"",""IBCNEQU"",409,0)"
^XMB(3.9,145946,2,4336,0)=" Q"
^XMB(3.9,145946,2,4337,0)="""RTN"",""IBCNILK"")"
^XMB(3.9,145946,2,4338,0)="0^8^B154519292"
^XMB(3.9,145946,2,4339,0)="""RTN"",""IBCNILK"",1,0)"
^XMB(3.9,145946,2,4340,0)="IBCNILK ;ALB/FA - Insurance Company Selection ; 02-OCT-2015"
^XMB(3.9,145946,2,4341,0)="""RTN"",""IBCNILK"",2,0)"
^XMB(3.9,145946,2,4342,0)=" ;;2.0;INTEGRATED BILLING;**549,713,737,763**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,4343,0)="""RTN"",""IBCNILK"",3,0)"
^XMB(3.9,145946,2,4344,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,4345,0)="""RTN"",""IBCNILK"",4,0)"
^XMB(3.9,145946,2,4346,0)=" ;;"
^XMB(3.9,145946,2,4347,0)="""RTN"",""IBCNILK"",5,0)"
^XMB(3.9,145946,2,4348,0)=" ;"
^XMB(3.9,145946,2,4349,0)="""RTN"",""IBCNILK"",6,0)"
^XMB(3.9,145946,2,4350,0)="EN(WHICH,PIEN,FILTER) ;EP"
^XMB(3.9,145946,2,4351,0)="""RTN"",""IBCNILK"",7,0)"
^XMB(3.9,145946,2,4352,0)=" ; Main entry point for the Insurance Company Selection template"
^XMB(3.9,145946,2,4353,0)="""RTN"",""IBCNILK"",8,0)"
^XMB(3.9,145946,2,4354,0)=" ; Input:   WHICH     - 1 - Only Show Active Insurance Companies"
^XMB(3.9,145946,2,4355,0)="""RTN"",""IBCNILK"",9,0)"
^XMB(3.9,145946,2,4356,0)=" ;                      0 - Only Show Inactive Insurance Companies"
^XMB(3.9,145946,2,4357,0)="""RTN"",""IBCNILK"",10,0)"
^XMB(3.9,145946,2,4358,0)=" ;                      2 - Show Both Active and Inactive Insurance Companies"
^XMB(3.9,145946,2,4359,0)="""RTN"",""IBCNILK"",11,0)"
^XMB(3.9,145946,2,4360,0)=" ;          PIEN      - IEN of the Payer to use to filter Insurance Company"
^XMB(3.9,145946,2,4361,0)="""RTN"",""IBCNILK"",12,0)"
^XMB(3.9,145946,2,4362,0)=" ;                      lookups. Optional, defaults to """"."
^XMB(3.9,145946,2,4363,0)="""RTN"",""IBCNILK"",13,0)"
^XMB(3.9,145946,2,4364,0)=" ;          FILTER    - A^B^C Where:"
^XMB(3.9,145946,2,4365,0)="""RTN"",""IBCNILK"",14,0)"
^XMB(3.9,145946,2,4366,0)=" ;                       A - 1 - Search for Insurance Companies that begin with"
^XMB(3.9,145946,2,4367,0)="""RTN"",""IBCNILK"",15,0)"
^XMB(3.9,145946,2,4368,0)=" ;                               the specified text (case insensitive)"
^XMB(3.9,145946,2,4369,0)="""RTN"",""IBCNILK"",16,0)"
^XMB(3.9,145946,2,4370,0)=" ;                           2 - Search for Insurance Companies that contain"
^XMB(3.9,145946,2,4371,0)="""RTN"",""IBCNILK"",17,0)"
^XMB(3.9,145946,2,4372,0)=" ;                               the specified text (case insensitive)"
^XMB(3.9,145946,2,4373,0)="""RTN"",""IBCNILK"",18,0)"
^XMB(3.9,145946,2,4374,0)=" ;                           3 - Search for Insurance Companies in a specified"
^XMB(3.9,145946,2,4375,0)="""RTN"",""IBCNILK"",19,0)"
^XMB(3.9,145946,2,4376,0)=" ;                               range (inclusive, case insensitive)"
^XMB(3.9,145946,2,4377,0)="""RTN"",""IBCNILK"",20,0)"
^XMB(3.9,145946,2,4378,0)=" ;                           4 - Search for Name(s) that are blank (null)"
^XMB(3.9,145946,2,4379,0)="""RTN"",""IBCNILK"",21,0)"
^XMB(3.9,145946,2,4380,0)=" ;                           5 - Filter by Selected Payer only"
^XMB(3.9,145946,2,4381,0)="""RTN"",""IBCNILK"",22,0)"
^XMB(3.9,145946,2,4382,0)=" ;IB*737/CKB - changed what was Filter '4' to '5' and updated '4'. When the Coverage Limitations Report was added,"
^XMB(3.9,145946,2,4383,0)="""RTN"",""IBCNILK"",23,0)"
^XMB(3.9,145946,2,4384,0)=" ; it uses '4' to 'search for Name(s) that are blank (null)' when calling $$FILTER^IBCNINSU."
^XMB(3.9,145946,2,4385,0)="""RTN"",""IBCNILK"",24,0)"
^XMB(3.9,145946,2,4386,0)=" ;"
^XMB(3.9,145946,2,4387,0)="""RTN"",""IBCNILK"",25,0)"
^XMB(3.9,145946,2,4388,0)=" ;                       B - Begin with text if A=1, Contains Text if A=2 or"
^XMB(3.9,145946,2,4389,0)="""RTN"",""IBCNILK"",26,0)"
^XMB(3.9,145946,2,4390,0)=" ;                            the range start if A=3"
^XMB(3.9,145946,2,4391,0)="""RTN"",""IBCNILK"",27,0)"
^XMB(3.9,145946,2,4392,0)=" ;                       C - Range End text (only present when A=3)"
^XMB(3.9,145946,2,4393,0)="""RTN"",""IBCNILK"",28,0)"
^XMB(3.9,145946,2,4394,0)=" ;                      Optional, if not passed, user is prompted for filter"
^XMB(3.9,145946,2,4395,0)="""RTN"",""IBCNILK"",29,0)"
^XMB(3.9,145946,2,4396,0)=" ;                      selection"
^XMB(3.9,145946,2,4397,0)="""RTN"",""IBCNILK"",30,0)"
^XMB(3.9,145946,2,4398,0)=" ; Output:  ^TMP(""IBCNILKA,$J,IIEN)    - Array of selected insurance companies"
^XMB(3.9,145946,2,4399,0)="""RTN"",""IBCNILK"",31,0)"
^XMB(3.9,145946,2,4400,0)=" N NUMSEL"
^XMB(3.9,145946,2,4401,0)="""RTN"",""IBCNILK"",32,0)"
^XMB(3.9,145946,2,4402,0)=" S:'$D(PIEN) PIEN="""""
^XMB(3.9,145946,2,4403,0)="""RTN"",""IBCNILK"",33,0)"
^XMB(3.9,145946,2,4404,0)=" S:'$D(FILTER) FILTER=$$GETFILT()"
^XMB(3.9,145946,2,4405,0)="""RTN"",""IBCNILK"",34,0)"
^XMB(3.9,145946,2,4406,0)=" ;IB*713/CKB - allow user to exit"
^XMB(3.9,145946,2,4407,0)="""RTN"",""IBCNILK"",35,0)"
^XMB(3.9,145946,2,4408,0)=" I $G(FILTER)=""^"" Q"
^XMB(3.9,145946,2,4409,0)="""RTN"",""IBCNILK"",36,0)"
^XMB(3.9,145946,2,4410,0)=" Q:FILTER="""""
^XMB(3.9,145946,2,4411,0)="""RTN"",""IBCNILK"",37,0)"
^XMB(3.9,145946,2,4412,0)=" S NUMSEL=0"
^XMB(3.9,145946,2,4413,0)="""RTN"",""IBCNILK"",38,0)"
^XMB(3.9,145946,2,4414,0)=" K ^TMP(""IBCNILKA"",$J)"
^XMB(3.9,145946,2,4415,0)="""RTN"",""IBCNILK"",39,0)"
^XMB(3.9,145946,2,4416,0)=" D EN^VALM(""IBCN INS CO SELECTOR"")"
^XMB(3.9,145946,2,4417,0)="""RTN"",""IBCNILK"",40,0)"
^XMB(3.9,145946,2,4418,0)=" Q"
^XMB(3.9,145946,2,4419,0)="""RTN"",""IBCNILK"",41,0)"
^XMB(3.9,145946,2,4420,0)=" ;"
^XMB(3.9,145946,2,4421,0)="""RTN"",""IBCNILK"",42,0)"
^XMB(3.9,145946,2,4422,0)="NEWSRCH() ; EP"
^XMB(3.9,145946,2,4423,0)="""RTN"",""IBCNILK"",43,0)"
^XMB(3.9,145946,2,4424,0)=" ; Protocol action to get new filter criteria and redisplay the listman"
^XMB(3.9,145946,2,4425,0)="""RTN"",""IBCNILK"",44,0)"
^XMB(3.9,145946,2,4426,0)=" ; template body and header"
^XMB(3.9,145946,2,4427,0)="""RTN"",""IBCNILK"",45,0)"
^XMB(3.9,145946,2,4428,0)=" ; Input:   FILTER      - Current Insurance Company Filter (See EN for details)"
^XMB(3.9,145946,2,4429,0)="""RTN"",""IBCNILK"",46,0)"
^XMB(3.9,145946,2,4430,0)=" ; Output:  FILTER      - Update Insurance Company Filter (See EN for details)"
^XMB(3.9,145946,2,4431,0)="""RTN"",""IBCNILK"",47,0)"
^XMB(3.9,145946,2,4432,0)=" N XX"
^XMB(3.9,145946,2,4433,0)="""RTN"",""IBCNILK"",48,0)"
^XMB(3.9,145946,2,4434,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,4435,0)="""RTN"",""IBCNILK"",49,0)"
^XMB(3.9,145946,2,4436,0)=" ;IB*713/CKB - reset VALMBG so the New Search (Insurance Company Lookup) will start on Page 1"
^XMB(3.9,145946,2,4437,0)="""RTN"",""IBCNILK"",50,0)"
^XMB(3.9,145946,2,4438,0)=" S VALMBG=1"
^XMB(3.9,145946,2,4439,0)="""RTN"",""IBCNILK"",51,0)"
^XMB(3.9,145946,2,4440,0)=" D FULL^VALM1"
^XMB(3.9,145946,2,4441,0)="""RTN"",""IBCNILK"",52,0)"
^XMB(3.9,145946,2,4442,0)=" ;IB*713/CKB&TAZ - added clean up of TMP, removed it from below"
^XMB(3.9,145946,2,4443,0)="""RTN"",""IBCNILK"",53,0)"
^XMB(3.9,145946,2,4444,0)=" K ^TMP(""IBCNILK"",$J),^TMP(""IBCNILKIX"",$J)"
^XMB(3.9,145946,2,4445,0)="""RTN"",""IBCNILK"",54,0)"
^XMB(3.9,145946,2,4446,0)=" W !!"
^XMB(3.9,145946,2,4447,0)="""RTN"",""IBCNILK"",55,0)"
^XMB(3.9,145946,2,4448,0)=" S XX=$$GETFILT()"
^XMB(3.9,145946,2,4449,0)="""RTN"",""IBCNILK"",56,0)"
^XMB(3.9,145946,2,4450,0)=" ;IB*713/CKB - allow user to exit, preventing 'jumping'"
^XMB(3.9,145946,2,4451,0)="""RTN"",""IBCNILK"",57,0)"
^XMB(3.9,145946,2,4452,0)=" I XX=""^"" D PAUSE^VALM1 Q"
^XMB(3.9,145946,2,4453,0)="""RTN"",""IBCNILK"",58,0)"
^XMB(3.9,145946,2,4454,0)=" I XX=-1 D  Q"
^XMB(3.9,145946,2,4455,0)="""RTN"",""IBCNILK"",59,0)"
^XMB(3.9,145946,2,4456,0)=" . W *7,""Invalid Filter - nothing done"""
^XMB(3.9,145946,2,4457,0)="""RTN"",""IBCNILK"",60,0)"
^XMB(3.9,145946,2,4458,0)=" . D PAUSE^VALM1"
^XMB(3.9,145946,2,4459,0)="""RTN"",""IBCNILK"",61,0)"
^XMB(3.9,145946,2,4460,0)=" S FILTER=XX"
^XMB(3.9,145946,2,4461,0)="""RTN"",""IBCNILK"",62,0)"
^XMB(3.9,145946,2,4462,0)=" ;K ^TMP(""IBCNILK"",$J),^TMP(""IBCNILKIX"",$J)"
^XMB(3.9,145946,2,4463,0)="""RTN"",""IBCNILK"",63,0)"
^XMB(3.9,145946,2,4464,0)=" D BLD,HDR"
^XMB(3.9,145946,2,4465,0)="""RTN"",""IBCNILK"",64,0)"
^XMB(3.9,145946,2,4466,0)=" Q"
^XMB(3.9,145946,2,4467,0)="""RTN"",""IBCNILK"",65,0)"
^XMB(3.9,145946,2,4468,0)=" ;"
^XMB(3.9,145946,2,4469,0)="""RTN"",""IBCNILK"",66,0)"
^XMB(3.9,145946,2,4470,0)="GETFILT() ; Gets the Insurance company filter"
^XMB(3.9,145946,2,4471,0)="""RTN"",""IBCNILK"",67,0)"
^XMB(3.9,145946,2,4472,0)=" ; Input:   None"
^XMB(3.9,145946,2,4473,0)="""RTN"",""IBCNILK"",68,0)"
^XMB(3.9,145946,2,4474,0)=" ; Returns: A^B^C Where:"
^XMB(3.9,145946,2,4475,0)="""RTN"",""IBCNILK"",69,0)"
^XMB(3.9,145946,2,4476,0)=" ;           A - 1 - Search for Insurance Companies that begin with"
^XMB(3.9,145946,2,4477,0)="""RTN"",""IBCNILK"",70,0)"
^XMB(3.9,145946,2,4478,0)=" ;                   the specified text (case insensitive)"
^XMB(3.9,145946,2,4479,0)="""RTN"",""IBCNILK"",71,0)"
^XMB(3.9,145946,2,4480,0)=" ;               2 - Search for Insurance Companies that contain"
^XMB(3.9,145946,2,4481,0)="""RTN"",""IBCNILK"",72,0)"
^XMB(3.9,145946,2,4482,0)=" ;                   the specified text (case insensitive)"
^XMB(3.9,145946,2,4483,0)="""RTN"",""IBCNILK"",73,0)"
^XMB(3.9,145946,2,4484,0)=" ;               3 - Search for Insurance Companies in a specified"
^XMB(3.9,145946,2,4485,0)="""RTN"",""IBCNILK"",74,0)"
^XMB(3.9,145946,2,4486,0)=" ;                   range (inclusive, case insensitive)"
^XMB(3.9,145946,2,4487,0)="""RTN"",""IBCNILK"",75,0)"
^XMB(3.9,145946,2,4488,0)=" ;           B - Begin with text if A=1, Contains Text if A=2 or"
^XMB(3.9,145946,2,4489,0)="""RTN"",""IBCNILK"",76,0)"
^XMB(3.9,145946,2,4490,0)=" ;               the range start if A=3"
^XMB(3.9,145946,2,4491,0)="""RTN"",""IBCNILK"",77,0)"
^XMB(3.9,145946,2,4492,0)=" ;           C - Range End text (only present when A=3)"
^XMB(3.9,145946,2,4493,0)="""RTN"",""IBCNILK"",78,0)"
^XMB(3.9,145946,2,4494,0)=" ;         -1 if a valid filter was not selected"
^XMB(3.9,145946,2,4495,0)="""RTN"",""IBCNILK"",79,0)"
^XMB(3.9,145946,2,4496,0)=" ;          ^ if user wants to exit"
^XMB(3.9,145946,2,4497,0)="""RTN"",""IBCNILK"",80,0)"
^XMB(3.9,145946,2,4498,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,FILTER,X,XX,Y"
^XMB(3.9,145946,2,4499,0)="""RTN"",""IBCNILK"",81,0)"
^XMB(3.9,145946,2,4500,0)=" ;"
^XMB(3.9,145946,2,4501,0)="""RTN"",""IBCNILK"",82,0)"
^XMB(3.9,145946,2,4502,0)=" ; First ask what kind of filter to use"
^XMB(3.9,145946,2,4503,0)="""RTN"",""IBCNILK"",83,0)"
^XMB(3.9,145946,2,4504,0)=" ;IB*763/CKB - 'Select' was modified to 'SELECT' in several places below"
^XMB(3.9,145946,2,4505,0)="""RTN"",""IBCNILK"",84,0)"
^XMB(3.9,145946,2,4506,0)=" ;"
^XMB(3.9,145946,2,4507,0)="""RTN"",""IBCNILK"",85,0)"
^XMB(3.9,145946,2,4508,0)=" W !"
^XMB(3.9,145946,2,4509,0)="""RTN"",""IBCNILK"",86,0)"
^XMB(3.9,145946,2,4510,0)=" S DIR(0)=""SA^1:Begins with;2:Contains;3:Range"""
^XMB(3.9,145946,2,4511,0)="""RTN"",""IBCNILK"",87,0)"
^XMB(3.9,145946,2,4512,0)=" S DIR(""A"")=""     SELECT 1, 2 or 3: ""  ;IB*763/CKB"
^XMB(3.9,145946,2,4513,0)="""RTN"",""IBCNILK"",88,0)"
^XMB(3.9,145946,2,4514,0)=" S DIR(""A"",1)="" 1 - Select Insurance Companies that Begin with: XXX"""
^XMB(3.9,145946,2,4515,0)="""RTN"",""IBCNILK"",89,0)"
^XMB(3.9,145946,2,4516,0)=" S DIR(""A"",2)="" 2 - Select Insurance Companies that Contain: XXX"""
^XMB(3.9,145946,2,4517,0)="""RTN"",""IBCNILK"",90,0)"
^XMB(3.9,145946,2,4518,0)=" S DIR(""A"",3)="" 3 - Select Insurance Companies in Range: XXX - YYY"""
^XMB(3.9,145946,2,4519,0)="""RTN"",""IBCNILK"",91,0)"
^XMB(3.9,145946,2,4520,0)=" S DIR(""B"")=1"
^XMB(3.9,145946,2,4521,0)="""RTN"",""IBCNILK"",92,0)"
^XMB(3.9,145946,2,4522,0)=" S DIR(""?"",1)=""Select the type of filter to determine what Insurance Companies"""
^XMB(3.9,145946,2,4523,0)="""RTN"",""IBCNILK"",93,0)"
^XMB(3.9,145946,2,4524,0)=" S DIR(""?"",2)=""will be displayed as follows:"""
^XMB(3.9,145946,2,4525,0)="""RTN"",""IBCNILK"",94,0)"
^XMB(3.9,145946,2,4526,0)=" S DIR(""?"",3)=""   Begins with - Displays all insurance companies that begin with"""
^XMB(3.9,145946,2,4527,0)="""RTN"",""IBCNILK"",95,0)"
^XMB(3.9,145946,2,4528,0)=" S DIR(""?"",4)=""                 the specified text (inclusive, case insensitive)"""
^XMB(3.9,145946,2,4529,0)="""RTN"",""IBCNILK"",96,0)"
^XMB(3.9,145946,2,4530,0)=" S DIR(""?"",5)=""   Contains    - Displays all insurance companies that contain"""
^XMB(3.9,145946,2,4531,0)="""RTN"",""IBCNILK"",97,0)"
^XMB(3.9,145946,2,4532,0)=" S DIR(""?"",6)=""                 the specified text (inclusive, case insensitive)"""
^XMB(3.9,145946,2,4533,0)="""RTN"",""IBCNILK"",98,0)"
^XMB(3.9,145946,2,4534,0)=" S DIR(""?"",7)=""   Range       - Displays all insurance companies within the """
^XMB(3.9,145946,2,4535,0)="""RTN"",""IBCNILK"",99,0)"
^XMB(3.9,145946,2,4536,0)=" S DIR(""?"")=""                 the specified range (inclusive, case insensitive)"""
^XMB(3.9,145946,2,4537,0)="""RTN"",""IBCNILK"",100,0)"
^XMB(3.9,145946,2,4538,0)=" S XX=""1:Begins with;2:Contains;3:Range"""
^XMB(3.9,145946,2,4539,0)="""RTN"",""IBCNILK"",101,0)"
^XMB(3.9,145946,2,4540,0)=" D ^DIR"
^XMB(3.9,145946,2,4541,0)="""RTN"",""IBCNILK"",102,0)"
^XMB(3.9,145946,2,4542,0)=" I Y=""^"" Q Y ;IB*713/CKB - allow user to exit"
^XMB(3.9,145946,2,4543,0)="""RTN"",""IBCNILK"",103,0)"
^XMB(3.9,145946,2,4544,0)=" I $D(DTOUT)!$D(DUOUT) Q -1                 ; No valid search selected"
^XMB(3.9,145946,2,4545,0)="""RTN"",""IBCNILK"",104,0)"
^XMB(3.9,145946,2,4546,0)=" S FILTER=Y"
^XMB(3.9,145946,2,4547,0)="""RTN"",""IBCNILK"",105,0)"
^XMB(3.9,145946,2,4548,0)=" ;"
^XMB(3.9,145946,2,4549,0)="""RTN"",""IBCNILK"",106,0)"
^XMB(3.9,145946,2,4550,0)=" ; Next ask for 'Begin with', 'Contains' or 'Range Start' text"
^XMB(3.9,145946,2,4551,0)="""RTN"",""IBCNILK"",107,0)"
^XMB(3.9,145946,2,4552,0)=" W !"
^XMB(3.9,145946,2,4553,0)="""RTN"",""IBCNILK"",108,0)"
^XMB(3.9,145946,2,4554,0)=" K DIR"
^XMB(3.9,145946,2,4555,0)="""RTN"",""IBCNILK"",109,0)"
^XMB(3.9,145946,2,4556,0)=" S DIR(0)=""F^1;30"""
^XMB(3.9,145946,2,4557,0)="""RTN"",""IBCNILK"",110,0)"
^XMB(3.9,145946,2,4558,0)=" S XX=$S(FILTER=1:""that begin with"",FILTER=2:""that contain"",1:""Start of Range"")"
^XMB(3.9,145946,2,4559,0)="""RTN"",""IBCNILK"",111,0)"
^XMB(3.9,145946,2,4560,0)=" S DIR(""A"")=""     SELECT Insurance Companies ""_XX   ;IB*763/CKB"
^XMB(3.9,145946,2,4561,0)="""RTN"",""IBCNILK"",112,0)"
^XMB(3.9,145946,2,4562,0)=" I FILTER=1 D"
^XMB(3.9,145946,2,4563,0)="""RTN"",""IBCNILK"",113,0)"
^XMB(3.9,145946,2,4564,0)=" . S DIR(""?"")=""Enter the text the each Insurance Company will begin with"""
^XMB(3.9,145946,2,4565,0)="""RTN"",""IBCNILK"",114,0)"
^XMB(3.9,145946,2,4566,0)=" I FILTER=2 D"
^XMB(3.9,145946,2,4567,0)="""RTN"",""IBCNILK"",115,0)"
^XMB(3.9,145946,2,4568,0)=" . S DIR(""?"")=""Enter the text the each Insurance Company will contains"""
^XMB(3.9,145946,2,4569,0)="""RTN"",""IBCNILK"",116,0)"
^XMB(3.9,145946,2,4570,0)=" I FILTER=3 D"
^XMB(3.9,145946,2,4571,0)="""RTN"",""IBCNILK"",117,0)"
^XMB(3.9,145946,2,4572,0)=" . S DIR(""?"")=""Enter the starting range text"""
^XMB(3.9,145946,2,4573,0)="""RTN"",""IBCNILK"",118,0)"
^XMB(3.9,145946,2,4574,0)=" D ^DIR K DIR"
^XMB(3.9,145946,2,4575,0)="""RTN"",""IBCNILK"",119,0)"
^XMB(3.9,145946,2,4576,0)=" I Y=""^"" Q Y ;IB*713/CKB - allow user to exit"
^XMB(3.9,145946,2,4577,0)="""RTN"",""IBCNILK"",120,0)"
^XMB(3.9,145946,2,4578,0)=" I $D(DTOUT)!$D(DUOUT) Q -1                 ; No valid search selected"
^XMB(3.9,145946,2,4579,0)="""RTN"",""IBCNILK"",121,0)"
^XMB(3.9,145946,2,4580,0)=" S $P(FILTER,""^"",2)=Y"
^XMB(3.9,145946,2,4581,0)="""RTN"",""IBCNILK"",122,0)"
^XMB(3.9,145946,2,4582,0)=" Q:$P(FILTER,""^"",1)'=3 FILTER"
^XMB(3.9,145946,2,4583,0)="""RTN"",""IBCNILK"",123,0)"
^XMB(3.9,145946,2,4584,0)=" ;"
^XMB(3.9,145946,2,4585,0)="""RTN"",""IBCNILK"",124,0)"
^XMB(3.9,145946,2,4586,0)=" ; Finally, ask for 'Range End' text if using a range filter"
^XMB(3.9,145946,2,4587,0)="""RTN"",""IBCNILK"",125,0)"
^XMB(3.9,145946,2,4588,0)=" W !"
^XMB(3.9,145946,2,4589,0)="""RTN"",""IBCNILK"",126,0)"
^XMB(3.9,145946,2,4590,0)=" K DIR"
^XMB(3.9,145946,2,4591,0)="""RTN"",""IBCNILK"",127,0)"
^XMB(3.9,145946,2,4592,0)=" S DIR(0)=""F^1;30"""
^XMB(3.9,145946,2,4593,0)="""RTN"",""IBCNILK"",128,0)"
^XMB(3.9,145946,2,4594,0)=" S DIR(""A"")=""     SELECT Insurance Companies End of Range""   ;IB*763/CKB"
^XMB(3.9,145946,2,4595,0)="""RTN"",""IBCNILK"",129,0)"
^XMB(3.9,145946,2,4596,0)=" S DIR(""B"")=$P(FILTER,""^"",2)"
^XMB(3.9,145946,2,4597,0)="""RTN"",""IBCNILK"",130,0)"
^XMB(3.9,145946,2,4598,0)=" S DIR(""?"")=""Enter the ending Range text"""
^XMB(3.9,145946,2,4599,0)="""RTN"",""IBCNILK"",131,0)"
^XMB(3.9,145946,2,4600,0)=" D ^DIR"
^XMB(3.9,145946,2,4601,0)="""RTN"",""IBCNILK"",132,0)"
^XMB(3.9,145946,2,4602,0)=" I Y=""^"" Q Y ;IB*713/CKB - allow user to exit"
^XMB(3.9,145946,2,4603,0)="""RTN"",""IBCNILK"",133,0)"
^XMB(3.9,145946,2,4604,0)=" I $D(DTOUT)!$D(DUOUT) Q -1                 ; No valid search selected"
^XMB(3.9,145946,2,4605,0)="""RTN"",""IBCNILK"",134,0)"
^XMB(3.9,145946,2,4606,0)=" S $P(FILTER,""^"",3)=Y"
^XMB(3.9,145946,2,4607,0)="""RTN"",""IBCNILK"",135,0)"
^XMB(3.9,145946,2,4608,0)=" Q FILTER"
^XMB(3.9,145946,2,4609,0)="""RTN"",""IBCNILK"",136,0)"
^XMB(3.9,145946,2,4610,0)=" ;"
^XMB(3.9,145946,2,4611,0)="""RTN"",""IBCNILK"",137,0)"
^XMB(3.9,145946,2,4612,0)="HDR(SELECTED) ;EP"
^XMB(3.9,145946,2,4613,0)="""RTN"",""IBCNILK"",138,0)"
^XMB(3.9,145946,2,4614,0)=" ; Header code for the Insurance Company Selection template"
^XMB(3.9,145946,2,4615,0)="""RTN"",""IBCNILK"",139,0)"
^XMB(3.9,145946,2,4616,0)=" ; Input:   SELECTED        - 1 - Showing header for selected listman"
^XMB(3.9,145946,2,4617,0)="""RTN"",""IBCNILK"",140,0)"
^XMB(3.9,145946,2,4618,0)=" ;                                Optional, defaults to 0"
^XMB(3.9,145946,2,4619,0)="""RTN"",""IBCNILK"",141,0)"
^XMB(3.9,145946,2,4620,0)=" ;          NUMSEL          - Current # of Insurance Companies Selected"
^XMB(3.9,145946,2,4621,0)="""RTN"",""IBCNILK"",142,0)"
^XMB(3.9,145946,2,4622,0)=" ;          FILTER          - Current Insurance Company Filter (See EN for details)"
^XMB(3.9,145946,2,4623,0)="""RTN"",""IBCNILK"",143,0)"
^XMB(3.9,145946,2,4624,0)=" ;          WHICH           - Active/Inactive/Both filter option"
^XMB(3.9,145946,2,4625,0)="""RTN"",""IBCNILK"",144,0)"
^XMB(3.9,145946,2,4626,0)=" ; Output:  VALMHDR         - Header information to display"
^XMB(3.9,145946,2,4627,0)="""RTN"",""IBCNILK"",145,0)"
^XMB(3.9,145946,2,4628,0)=" N PNM,XX"
^XMB(3.9,145946,2,4629,0)="""RTN"",""IBCNILK"",146,0)"
^XMB(3.9,145946,2,4630,0)=" S:'$D(SELECTED) SELECTED=0"
^XMB(3.9,145946,2,4631,0)="""RTN"",""IBCNILK"",147,0)"
^XMB(3.9,145946,2,4632,0)=" I 'SELECTED D"
^XMB(3.9,145946,2,4633,0)="""RTN"",""IBCNILK"",148,0)"
^XMB(3.9,145946,2,4634,0)=" . I $P(FILTER,""^"",1)=4 S VALMHDR(1)="""" Q"
^XMB(3.9,145946,2,4635,0)="""RTN"",""IBCNILK"",149,0)"
^XMB(3.9,145946,2,4636,0)=" . I $P(FILTER,""^"",1)=1 D  Q"
^XMB(3.9,145946,2,4637,0)="""RTN"",""IBCNILK"",150,0)"
^XMB(3.9,145946,2,4638,0)=" . . S VALMHDR(1)=""Insurance Companies that begin with: ""_$P(FILTER,""^"",2)"
^XMB(3.9,145946,2,4639,0)="""RTN"",""IBCNILK"",151,0)"
^XMB(3.9,145946,2,4640,0)=" . I $P(FILTER,""^"",1)=2 D  Q"
^XMB(3.9,145946,2,4641,0)="""RTN"",""IBCNILK"",152,0)"
^XMB(3.9,145946,2,4642,0)=" . . S VALMHDR(1)=""Insurance Companies that contain: ""_$P(FILTER,""^"",2)"
^XMB(3.9,145946,2,4643,0)="""RTN"",""IBCNILK"",153,0)"
^XMB(3.9,145946,2,4644,0)=" . S XX=$P(FILTER,""^"",2)_"" - ""_$P(FILTER,""^"",3)"
^XMB(3.9,145946,2,4645,0)="""RTN"",""IBCNILK"",154,0)"
^XMB(3.9,145946,2,4646,0)=" . S VALMHDR(1)=""Insurance Companies in range: ""_XX"
^XMB(3.9,145946,2,4647,0)="""RTN"",""IBCNILK"",155,0)"
^XMB(3.9,145946,2,4648,0)=" S XX=$S(WHICH=1:""Active "",WHICH=0:""Inactive "",1:""All "")"
^XMB(3.9,145946,2,4649,0)="""RTN"",""IBCNILK"",156,0)"
^XMB(3.9,145946,2,4650,0)=" S XX=""Showing ""_XX_""Insurance Companies"""
^XMB(3.9,145946,2,4651,0)="""RTN"",""IBCNILK"",157,0)"
^XMB(3.9,145946,2,4652,0)=" ;"
^XMB(3.9,145946,2,4653,0)="""RTN"",""IBCNILK"",158,0)"
^XMB(3.9,145946,2,4654,0)=" ; Add Payer filter, if present"
^XMB(3.9,145946,2,4655,0)="""RTN"",""IBCNILK"",159,0)"
^XMB(3.9,145946,2,4656,0)=" I PIEN'="""" D"
^XMB(3.9,145946,2,4657,0)="""RTN"",""IBCNILK"",160,0)"
^XMB(3.9,145946,2,4658,0)=" . S PNM=$E($$GET1^DIQ(365.12,PIEN_"","",.01),1,30)"
^XMB(3.9,145946,2,4659,0)="""RTN"",""IBCNILK"",161,0)"
^XMB(3.9,145946,2,4660,0)=" . S PNM=""Payer: ""_PNM"
^XMB(3.9,145946,2,4661,0)="""RTN"",""IBCNILK"",162,0)"
^XMB(3.9,145946,2,4662,0)=" . S XX=$$SETSTR^VALM1(PNM,XX,40,40)        ; Payer Name"
^XMB(3.9,145946,2,4663,0)="""RTN"",""IBCNILK"",163,0)"
^XMB(3.9,145946,2,4664,0)=" S VALMHDR(2)=XX"
^XMB(3.9,145946,2,4665,0)="""RTN"",""IBCNILK"",164,0)"
^XMB(3.9,145946,2,4666,0)=" S VALMHDR(3)=NUMSEL_"" Insurance Companies selected"""
^XMB(3.9,145946,2,4667,0)="""RTN"",""IBCNILK"",165,0)"
^XMB(3.9,145946,2,4668,0)=" Q"
^XMB(3.9,145946,2,4669,0)="""RTN"",""IBCNILK"",166,0)"
^XMB(3.9,145946,2,4670,0)=" ;"
^XMB(3.9,145946,2,4671,0)="""RTN"",""IBCNILK"",167,0)"
^XMB(3.9,145946,2,4672,0)="INIT ;EP"
^XMB(3.9,145946,2,4673,0)="""RTN"",""IBCNILK"",168,0)"
^XMB(3.9,145946,2,4674,0)=" ; Initialize variables and list array"
^XMB(3.9,145946,2,4675,0)="""RTN"",""IBCNILK"",169,0)"
^XMB(3.9,145946,2,4676,0)=" ; Input: None"
^XMB(3.9,145946,2,4677,0)="""RTN"",""IBCNILK"",170,0)"
^XMB(3.9,145946,2,4678,0)=" ; Output:  ^TMP(""IBCNILK"",$J) - Body lines to display"
^XMB(3.9,145946,2,4679,0)="""RTN"",""IBCNILK"",171,0)"
^XMB(3.9,145946,2,4680,0)=" K ^TMP(""IBCNILK"",$J),^TMP(""IBCNILKIX"",$J),^TMP(""IBCNILKA"",$J)"
^XMB(3.9,145946,2,4681,0)="""RTN"",""IBCNILK"",172,0)"
^XMB(3.9,145946,2,4682,0)=" D BLD"
^XMB(3.9,145946,2,4683,0)="""RTN"",""IBCNILK"",173,0)"
^XMB(3.9,145946,2,4684,0)=" Q"
^XMB(3.9,145946,2,4685,0)="""RTN"",""IBCNILK"",174,0)"
^XMB(3.9,145946,2,4686,0)=" ;"
^XMB(3.9,145946,2,4687,0)="""RTN"",""IBCNILK"",175,0)"
^XMB(3.9,145946,2,4688,0)="BLD ; Build listman body"
^XMB(3.9,145946,2,4689,0)="""RTN"",""IBCNILK"",176,0)"
^XMB(3.9,145946,2,4690,0)=" ; Input:   FILTER    - Current Insurance Company Filter (See EN for details)"
^XMB(3.9,145946,2,4691,0)="""RTN"",""IBCNILK"",177,0)"
^XMB(3.9,145946,2,4692,0)=" ;          WHICH     - 1 - Only Show Active Insurance Companies"
^XMB(3.9,145946,2,4693,0)="""RTN"",""IBCNILK"",178,0)"
^XMB(3.9,145946,2,4694,0)=" ;                      0 - Only Show Inactive Insurance Companies"
^XMB(3.9,145946,2,4695,0)="""RTN"",""IBCNILK"",179,0)"
^XMB(3.9,145946,2,4696,0)=" ;                      2 - Show Both Active and Inactive Insurance Companies"
^XMB(3.9,145946,2,4697,0)="""RTN"",""IBCNILK"",180,0)"
^XMB(3.9,145946,2,4698,0)=" ; Output:  VALMCNT   - Total number of lines displayed in the body"
^XMB(3.9,145946,2,4699,0)="""RTN"",""IBCNILK"",181,0)"
^XMB(3.9,145946,2,4700,0)=" ;          ^TMP(""IBCNILK"",$J)   - Body lines to display"
^XMB(3.9,145946,2,4701,0)="""RTN"",""IBCNILK"",182,0)"
^XMB(3.9,145946,2,4702,0)=" ;          ^TMP(""IBCNILKIX"",$J) - Index of Entry IENs by display line"
^XMB(3.9,145946,2,4703,0)="""RTN"",""IBCNILK"",183,0)"
^XMB(3.9,145946,2,4704,0)=" N FTEXT1,FTEXT2,FTYPE,ICTR,IIEN,INACT,INM,INMU,LINE,PLEN,SKIP,START,STOP,XX"
^XMB(3.9,145946,2,4705,0)="""RTN"",""IBCNILK"",184,0)"
^XMB(3.9,145946,2,4706,0)=" N PLA ; IB*713/DTG"
^XMB(3.9,145946,2,4707,0)="""RTN"",""IBCNILK"",185,0)"
^XMB(3.9,145946,2,4708,0)=" S FTYPE=$P(FILTER,""^"",1)"
^XMB(3.9,145946,2,4709,0)="""RTN"",""IBCNILK"",186,0)"
^XMB(3.9,145946,2,4710,0)=" S FTEXT1=$P(FILTER,""^"",2),FTEXT1=$$UP^XLFSTR(FTEXT1)"
^XMB(3.9,145946,2,4711,0)="""RTN"",""IBCNILK"",187,0)"
^XMB(3.9,145946,2,4712,0)=" S FTEXT2=$P(FILTER,""^"",3),FTEXT2=$$UP^XLFSTR(FTEXT2)"
^XMB(3.9,145946,2,4713,0)="""RTN"",""IBCNILK"",188,0)"
^XMB(3.9,145946,2,4714,0)=" ;IB*737/CKB - changed FTYPE from '4' to '5'. FTYPE=5 is only used by GETCOMPS^IBCNERPF."
^XMB(3.9,145946,2,4715,0)="""RTN"",""IBCNILK"",189,0)"
^XMB(3.9,145946,2,4716,0)=" S:FTYPE=5 FTEXT1=""A"""
^XMB(3.9,145946,2,4717,0)="""RTN"",""IBCNILK"",190,0)"
^XMB(3.9,145946,2,4718,0)=" S:FTYPE=1 PLEN=$L(FTEXT1)"
^XMB(3.9,145946,2,4719,0)="""RTN"",""IBCNILK"",191,0)"
^XMB(3.9,145946,2,4720,0)=" S:FTYPE=3 PLEN=$L(FTEXT2)"
^XMB(3.9,145946,2,4721,0)="""RTN"",""IBCNILK"",192,0)"
^XMB(3.9,145946,2,4722,0)=" S (ICTR,STOP,VALMCNT)=0,INM="""""
^XMB(3.9,145946,2,4723,0)="""RTN"",""IBCNILK"",193,0)"
^XMB(3.9,145946,2,4724,0)=" ;IB*713/DTG start allow all searches to use full index"
^XMB(3.9,145946,2,4725,0)="""RTN"",""IBCNILK"",194,0)"
^XMB(3.9,145946,2,4726,0)=" ;S:FTYPE'=2 INM=$O(^DIC(36,""B"",FTEXT1),-1)"
^XMB(3.9,145946,2,4727,0)="""RTN"",""IBCNILK"",195,0)"
^XMB(3.9,145946,2,4728,0)=" F  D  Q:(INM="""")!STOP"
^XMB(3.9,145946,2,4729,0)="""RTN"",""IBCNILK"",196,0)"
^XMB(3.9,145946,2,4730,0)=" . S INM=$O(^DIC(36,""B"",INM))"
^XMB(3.9,145946,2,4731,0)="""RTN"",""IBCNILK"",197,0)"
^XMB(3.9,145946,2,4732,0)=" . Q:INM="""""
^XMB(3.9,145946,2,4733,0)="""RTN"",""IBCNILK"",198,0)"
^XMB(3.9,145946,2,4734,0)=" . S INMU=$$UP^XLFSTR(INM)"
^XMB(3.9,145946,2,4735,0)="""RTN"",""IBCNILK"",199,0)"
^XMB(3.9,145946,2,4736,0)=" . ;IB*713/TAZ&CKB - use utility to check Begins, Contains, and Range"
^XMB(3.9,145946,2,4737,0)="""RTN"",""IBCNILK"",200,0)"
^XMB(3.9,145946,2,4738,0)=" . I '$$FILTER^IBCNINSU(INM,FILTER) Q"
^XMB(3.9,145946,2,4739,0)="""RTN"",""IBCNILK"",201,0)"
^XMB(3.9,145946,2,4740,0)=" . ;IB*713/DTG start allow search to cycle through lower case and upper case insurance company names"
^XMB(3.9,145946,2,4741,0)="""RTN"",""IBCNILK"",202,0)"
^XMB(3.9,145946,2,4742,0)=" . S IIEN="""""
^XMB(3.9,145946,2,4743,0)="""RTN"",""IBCNILK"",203,0)"
^XMB(3.9,145946,2,4744,0)=" . F  D  Q:IIEN="""""
^XMB(3.9,145946,2,4745,0)="""RTN"",""IBCNILK"",204,0)"
^XMB(3.9,145946,2,4746,0)=" . . S IIEN=$O(^DIC(36,""B"",INM,IIEN))"
^XMB(3.9,145946,2,4747,0)="""RTN"",""IBCNILK"",205,0)"
^XMB(3.9,145946,2,4748,0)=" . . Q:IIEN="""""
^XMB(3.9,145946,2,4749,0)="""RTN"",""IBCNILK"",206,0)"
^XMB(3.9,145946,2,4750,0)=" . . Q:'$D(^DIC(36,IIEN))                   ; Corrupt data index, skip"
^XMB(3.9,145946,2,4751,0)="""RTN"",""IBCNILK"",207,0)"
^XMB(3.9,145946,2,4752,0)=" . . S SKIP=0"
^XMB(3.9,145946,2,4753,0)="""RTN"",""IBCNILK"",208,0)"
^XMB(3.9,145946,2,4754,0)=" . . I PIEN'="""" D  Q:SKIP                   ; Wrong payer"
^XMB(3.9,145946,2,4755,0)="""RTN"",""IBCNILK"",209,0)"
^XMB(3.9,145946,2,4756,0)=" . . . S XX=$$GET1^DIQ(36,IIEN_"","",3.1,""I"")"
^XMB(3.9,145946,2,4757,0)="""RTN"",""IBCNILK"",210,0)"
^XMB(3.9,145946,2,4758,0)=" . . . S:XX'=PIEN SKIP=1"
^XMB(3.9,145946,2,4759,0)="""RTN"",""IBCNILK"",211,0)"
^XMB(3.9,145946,2,4760,0)=" . . S INACT=+$$GET1^DIQ(36,IIEN_"","",.05,""I"")"
^XMB(3.9,145946,2,4761,0)="""RTN"",""IBCNILK"",212,0)"
^XMB(3.9,145946,2,4762,0)=" . . I WHICH=1,INACT=1 Q                    ; Not Active"
^XMB(3.9,145946,2,4763,0)="""RTN"",""IBCNILK"",213,0)"
^XMB(3.9,145946,2,4764,0)=" . . I WHICH=0,INACT=0 Q                    ; Not Inactive"
^XMB(3.9,145946,2,4765,0)="""RTN"",""IBCNILK"",214,0)"
^XMB(3.9,145946,2,4766,0)=" . . S ICTR=ICTR+1"
^XMB(3.9,145946,2,4767,0)="""RTN"",""IBCNILK"",215,0)"
^XMB(3.9,145946,2,4768,0)=" . . S LINE=$$BLDLN(ICTR,IIEN)"
^XMB(3.9,145946,2,4769,0)="""RTN"",""IBCNILK"",216,0)"
^XMB(3.9,145946,2,4770,0)=" . . S VALMCNT=VALMCNT+1"
^XMB(3.9,145946,2,4771,0)="""RTN"",""IBCNILK"",217,0)"
^XMB(3.9,145946,2,4772,0)=" . . D SET^VALM10(VALMCNT,LINE,LINE)"
^XMB(3.9,145946,2,4773,0)="""RTN"",""IBCNILK"",218,0)"
^XMB(3.9,145946,2,4774,0)=" . . S ^TMP(""IBCNILKIX"",$J,ICTR)=IIEN"
^XMB(3.9,145946,2,4775,0)="""RTN"",""IBCNILK"",219,0)"
^XMB(3.9,145946,2,4776,0)=" ;"
^XMB(3.9,145946,2,4777,0)="""RTN"",""IBCNILK"",220,0)"
^XMB(3.9,145946,2,4778,0)=" I VALMCNT=0 D"
^XMB(3.9,145946,2,4779,0)="""RTN"",""IBCNILK"",221,0)"
^XMB(3.9,145946,2,4780,0)=" . S ^TMP(""IBCNILK"",$J,1,0)=""No Insurance Companies matching filter criteria were found."""
^XMB(3.9,145946,2,4781,0)="""RTN"",""IBCNILK"",222,0)"
^XMB(3.9,145946,2,4782,0)=" Q"
^XMB(3.9,145946,2,4783,0)="""RTN"",""IBCNILK"",223,0)"
^XMB(3.9,145946,2,4784,0)=" ;"
^XMB(3.9,145946,2,4785,0)="""RTN"",""IBCNILK"",224,0)"
^XMB(3.9,145946,2,4786,0)="BLDLN(ICTR,IIEN) ;EP"
^XMB(3.9,145946,2,4787,0)="""RTN"",""IBCNILK"",225,0)"
^XMB(3.9,145946,2,4788,0)=" ; Builds a line to display one insurance company"
^XMB(3.9,145946,2,4789,0)="""RTN"",""IBCNILK"",226,0)"
^XMB(3.9,145946,2,4790,0)=" ; Input:   ICTR                        - Selection Number"
^XMB(3.9,145946,2,4791,0)="""RTN"",""IBCNILK"",227,0)"
^XMB(3.9,145946,2,4792,0)=" ;          IIEN                        - IEN of the insurance company to be"
^XMB(3.9,145946,2,4793,0)="""RTN"",""IBCNILK"",228,0)"
^XMB(3.9,145946,2,4794,0)=" ;                                        displayed"
^XMB(3.9,145946,2,4795,0)="""RTN"",""IBCNILK"",229,0)"
^XMB(3.9,145946,2,4796,0)=" ;          ^TMP(""IBCNILKA"",$J,IIEN)   - Array of currently selected"
^XMB(3.9,145946,2,4797,0)="""RTN"",""IBCNILK"",230,0)"
^XMB(3.9,145946,2,4798,0)=" ;                                        Insurance Companies"
^XMB(3.9,145946,2,4799,0)="""RTN"",""IBCNILK"",231,0)"
^XMB(3.9,145946,2,4800,0)=" ; Output:  LINE    - Formatted for setting into the list display"
^XMB(3.9,145946,2,4801,0)="""RTN"",""IBCNILK"",232,0)"
^XMB(3.9,145946,2,4802,0)=" N LINE,LINEI,XX"
^XMB(3.9,145946,2,4803,0)="""RTN"",""IBCNILK"",233,0)"
^XMB(3.9,145946,2,4804,0)=" S:$D(^TMP(""IBCNILKA"",$J,IIEN)) ICTR=ICTR_"">""       ; Mark as selected"
^XMB(3.9,145946,2,4805,0)="""RTN"",""IBCNILK"",234,0)"
^XMB(3.9,145946,2,4806,0)=" S LINE=$$SETSTR^VALM1(ICTR,"""",1,4)                 ; Selection #"
^XMB(3.9,145946,2,4807,0)="""RTN"",""IBCNILK"",235,0)"
^XMB(3.9,145946,2,4808,0)=" S XX=$$GET1^DIQ(36,IIEN_"","",.01)"
^XMB(3.9,145946,2,4809,0)="""RTN"",""IBCNILK"",236,0)"
^XMB(3.9,145946,2,4810,0)=" S LINE=$$SETSTR^VALM1(XX,LINE,7,30)                ; Ins Co Name"
