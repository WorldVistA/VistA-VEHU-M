^XMB(3.9,145944,2,1862,0)="ENQ K IBSDA,IBSDF,IBSDL,IBSDV,IBSEL,IBSN,IBSNA,IBSNF,IBSNL,IBSH,IBSH1,IBSH2"
^XMB(3.9,145944,2,1863,0)="""RTN"",""IBJDF6"",157,0)"
^XMB(3.9,145944,2,1864,0)=" K IBCTG,IBCTS,IBOFF,IBPRT,IBRPT,IBSAM,IBSMN,IBSMX,IBTEXT,IBI,DIROUT"
^XMB(3.9,145944,2,1865,0)="""RTN"",""IBJDF6"",158,0)"
^XMB(3.9,145944,2,1866,0)=" K DTOUT,DUOUT,DIRUT,POP,VAUTD,%ZIS,ZTDESC,ZTRTN,ZTSAVE,I,X,Y,Z"
^XMB(3.9,145944,2,1867,0)="""RTN"",""IBJDF6"",159,0)"
^XMB(3.9,145944,2,1868,0)=" Q"
^XMB(3.9,145944,2,1869,0)="""RTN"",""IBJDF61"")"
^XMB(3.9,145944,2,1870,0)="0^2^B66883609"
^XMB(3.9,145944,2,1871,0)="""RTN"",""IBJDF61"",1,0)"
^XMB(3.9,145944,2,1872,0)="IBJDF61 ;ALB/RB - MISC. BILLS FOLLOW-UP REPORT (COMPILE) ;15-APR-00"
^XMB(3.9,145944,2,1873,0)="""RTN"",""IBJDF61"",2,0)"
^XMB(3.9,145944,2,1874,0)=" ;;2.0;INTEGRATED BILLING;**123,159,356,618**;21-MAR-94;Build 0"
^XMB(3.9,145944,2,1875,0)="""RTN"",""IBJDF61"",3,0)"
^XMB(3.9,145944,2,1876,0)=" ;;Per VHA Directive 6402, this routine should not be modified."
^XMB(3.9,145944,2,1877,0)="""RTN"",""IBJDF61"",4,0)"
^XMB(3.9,145944,2,1878,0)=" ;"
^XMB(3.9,145944,2,1879,0)="""RTN"",""IBJDF61"",5,0)"
^XMB(3.9,145944,2,1880,0)="ST ; - Tasked entry point."
^XMB(3.9,145944,2,1881,0)="""RTN"",""IBJDF61"",6,0)"
^XMB(3.9,145944,2,1882,0)=" K IB,IBCAT,^TMP(""IBJDF6P"",$J),^TMP(""IBJDF6D"",$J) S IBQ=0"
^XMB(3.9,145944,2,1883,0)="""RTN"",""IBJDF61"",7,0)"
^XMB(3.9,145944,2,1884,0)=" N IBPDFLG   ;Patient (1) or Debtor (0) flag"
^XMB(3.9,145944,2,1885,0)="""RTN"",""IBJDF61"",8,0)"
^XMB(3.9,145944,2,1886,0)=" ;"
^XMB(3.9,145944,2,1887,0)="""RTN"",""IBJDF61"",9,0)"
^XMB(3.9,145944,2,1888,0)=" ; - Set selected categories for report."
^XMB(3.9,145944,2,1889,0)="""RTN"",""IBJDF61"",10,0)"
^XMB(3.9,145944,2,1890,0)=" ; IB*2.0*618 - Added Community Care Misc. Categories"
^XMB(3.9,145944,2,1891,0)="""RTN"",""IBJDF61"",11,0)"
^XMB(3.9,145944,2,1892,0)=" I IBSEL["",1,"" S IBCAT(21)=1        ; MEDICARE"
^XMB(3.9,145944,2,1893,0)="""RTN"",""IBJDF61"",12,0)"
^XMB(3.9,145944,2,1894,0)=" I IBSEL["",2,"" S IBCAT(7)=2         ; NO-FAULT AUTO ACCIDENT"
^XMB(3.9,145944,2,1895,0)="""RTN"",""IBJDF61"",13,0)"
^XMB(3.9,145944,2,1896,0)=" I IBSEL["",3,"" D                    ; COMMUNITY CARE NO-FAULT AUTO"
^XMB(3.9,145944,2,1897,0)="""RTN"",""IBJDF61"",14,0)"
^XMB(3.9,145944,2,1898,0)=" . S IBCAT(52)=3"
^XMB(3.9,145944,2,1899,0)="""RTN"",""IBJDF61"",15,0)"
^XMB(3.9,145944,2,1900,0)=" . S IBCAT(55)=3"
^XMB(3.9,145944,2,1901,0)="""RTN"",""IBJDF61"",16,0)"
^XMB(3.9,145944,2,1902,0)=" . S IBCAT(58)=3"
^XMB(3.9,145944,2,1903,0)="""RTN"",""IBJDF61"",17,0)"
^XMB(3.9,145944,2,1904,0)=" I IBSEL["",4,"" S IBCAT(10)=4        ; TORT FEASOR"
^XMB(3.9,145944,2,1905,0)="""RTN"",""IBJDF61"",18,0)"
^XMB(3.9,145944,2,1906,0)=" I IBSEL["",5,"" D                    ; COMMUNITY CARE TORT FEASOR"
^XMB(3.9,145944,2,1907,0)="""RTN"",""IBJDF61"",19,0)"
^XMB(3.9,145944,2,1908,0)=" . S IBCAT(53)=5"
^XMB(3.9,145944,2,1909,0)="""RTN"",""IBJDF61"",20,0)"
^XMB(3.9,145944,2,1910,0)=" . S IBCAT(56)=5"
^XMB(3.9,145944,2,1911,0)="""RTN"",""IBJDF61"",21,0)"
^XMB(3.9,145944,2,1912,0)=" . S IBCAT(59)=5"
^XMB(3.9,145944,2,1913,0)="""RTN"",""IBJDF61"",22,0)"
^XMB(3.9,145944,2,1914,0)=" I IBSEL[6 S IBCAT(6)=6             ; WORKMEN'S COMP"
^XMB(3.9,145944,2,1915,0)="""RTN"",""IBJDF61"",23,0)"
^XMB(3.9,145944,2,1916,0)=" I IBSEL[7 D                        ; COMMUNITY CARE NO-FAULT AUTO"
^XMB(3.9,145944,2,1917,0)="""RTN"",""IBJDF61"",24,0)"
^XMB(3.9,145944,2,1918,0)=" . S IBCAT(54)=7"
^XMB(3.9,145944,2,1919,0)="""RTN"",""IBJDF61"",25,0)"
^XMB(3.9,145944,2,1920,0)=" . S IBCAT(57)=7"
^XMB(3.9,145944,2,1921,0)="""RTN"",""IBJDF61"",26,0)"
^XMB(3.9,145944,2,1922,0)=" . S IBCAT(60)=7"
^XMB(3.9,145944,2,1923,0)="""RTN"",""IBJDF61"",27,0)"
^XMB(3.9,145944,2,1924,0)=" I IBSEL[8 S IBCAT(16)=8            ; CURRENT EMPLOYEE"
^XMB(3.9,145944,2,1925,0)="""RTN"",""IBJDF61"",28,0)"
^XMB(3.9,145944,2,1926,0)=" I IBSEL[9 S IBCAT(15)=9            ; EX-EMPLOYEE"
^XMB(3.9,145944,2,1927,0)="""RTN"",""IBJDF61"",29,0)"
^XMB(3.9,145944,2,1928,0)=" I IBSEL[10 S IBCAT(13)=10          ; FEDERAL AGENCIES-REFUND"
^XMB(3.9,145944,2,1929,0)="""RTN"",""IBJDF61"",30,0)"
^XMB(3.9,145944,2,1930,0)=" I IBSEL[11 S IBCAT(14)=11          ; FEDERAL AGENCIES-REIMBURSEMENT"
^XMB(3.9,145944,2,1931,0)="""RTN"",""IBJDF61"",31,0)"
^XMB(3.9,145944,2,1932,0)=" I IBSEL[12 S IBCAT(12)=12          ; MILITARY"
^XMB(3.9,145944,2,1933,0)="""RTN"",""IBJDF61"",32,0)"
^XMB(3.9,145944,2,1934,0)=" I IBSEL[13 S IBCAT(20)=13          ; INTERAGENCY"
^XMB(3.9,145944,2,1935,0)="""RTN"",""IBJDF61"",33,0)"
^XMB(3.9,145944,2,1936,0)=" I IBSEL[14 S IBCAT(17)=14          ; VENDOR"
^XMB(3.9,145944,2,1937,0)="""RTN"",""IBJDF61"",34,0)"
^XMB(3.9,145944,2,1938,0)=" ;"
^XMB(3.9,145944,2,1939,0)="""RTN"",""IBJDF61"",35,0)"
^XMB(3.9,145944,2,1940,0)=" ; Initialize the Summary Information"
^XMB(3.9,145944,2,1941,0)="""RTN"",""IBJDF61"",36,0)"
^XMB(3.9,145944,2,1942,0)=" S IBCAT="""" F  S IBCAT=$O(IBCAT(IBCAT)) Q:IBCAT=""""  D"
^XMB(3.9,145944,2,1943,0)="""RTN"",""IBJDF61"",37,0)"
^XMB(3.9,145944,2,1944,0)=" . S IBDIV=0"
^XMB(3.9,145944,2,1945,0)="""RTN"",""IBJDF61"",38,0)"
^XMB(3.9,145944,2,1946,0)=" . I IBSDV,$$CATCHK(IBCAT) D  Q    ;IB*2.0*618"
^XMB(3.9,145944,2,1947,0)="""RTN"",""IBJDF61"",39,0)"
^XMB(3.9,145944,2,1948,0)=" . . F  S IBDIV=$O(VAUTD(IBDIV)) Q:IBDIV=""""  D INIT^IBJDF63"
^XMB(3.9,145944,2,1949,0)="""RTN"",""IBJDF61"",40,0)"
^XMB(3.9,145944,2,1950,0)=" . D INIT^IBJDF63"
^XMB(3.9,145944,2,1951,0)="""RTN"",""IBJDF61"",41,0)"
^XMB(3.9,145944,2,1952,0)=" ;"
^XMB(3.9,145944,2,1953,0)="""RTN"",""IBJDF61"",42,0)"
^XMB(3.9,145944,2,1954,0)=" ; - Print the header line for the Excel spreadsheet"
^XMB(3.9,145944,2,1955,0)="""RTN"",""IBJDF61"",43,0)"
^XMB(3.9,145944,2,1956,0)=" I $G(IBEXCEL) D PHDL"
^XMB(3.9,145944,2,1957,0)="""RTN"",""IBJDF61"",44,0)"
^XMB(3.9,145944,2,1958,0)=" ;"
^XMB(3.9,145944,2,1959,0)="""RTN"",""IBJDF61"",45,0)"
^XMB(3.9,145944,2,1960,0)=" ; - Find data required for the report."
^XMB(3.9,145944,2,1961,0)="""RTN"",""IBJDF61"",46,0)"
^XMB(3.9,145944,2,1962,0)=" S IBA=0 F  S IBA=$O(^PRCA(430,""AC"",16,IBA)) Q:'IBA  D  Q:IBQ"
^XMB(3.9,145944,2,1963,0)="""RTN"",""IBJDF61"",47,0)"
^XMB(3.9,145944,2,1964,0)=" . I IBA#100=0 D  Q:IBQ"
^XMB(3.9,145944,2,1965,0)="""RTN"",""IBJDF61"",48,0)"
^XMB(3.9,145944,2,1966,0)=" . . S IBQ=$$STOP^IBOUTL(""Miscellaneous Bills Follow-Up Report"")"
^XMB(3.9,145944,2,1967,0)="""RTN"",""IBJDF61"",49,0)"
^XMB(3.9,145944,2,1968,0)=" . S IBAR=$G(^PRCA(430,IBA,0)) Q:'IBAR"
^XMB(3.9,145944,2,1969,0)="""RTN"",""IBJDF61"",50,0)"
^XMB(3.9,145944,2,1970,0)=" . S IBCAT=+$P(IBAR,U,2) Q:'$D(IBCAT(IBCAT))  ;     Invalid AR category."
^XMB(3.9,145944,2,1971,0)="""RTN"",""IBJDF61"",51,0)"
^XMB(3.9,145944,2,1972,0)=" . S IBCAT1=IBCAT(IBCAT),IBPDFLG=$$CATCHK(IBCAT)"
^XMB(3.9,145944,2,1973,0)="""RTN"",""IBJDF61"",52,0)"
^XMB(3.9,145944,2,1974,0)=" . I IBPDFLG,'$D(^DGCR(399,IBA,0)) Q  ; No claim."
^XMB(3.9,145944,2,1975,0)="""RTN"",""IBJDF61"",53,0)"
^XMB(3.9,145944,2,1976,0)=" . I IBPDFLG,$P($G(^DGCR(399,IBA,0)),U,13)=7 Q  ;      Cancelled claim."
^XMB(3.9,145944,2,1977,0)="""RTN"",""IBJDF61"",54,0)"
^XMB(3.9,145944,2,1978,0)=" . ;"
^XMB(3.9,145944,2,1979,0)="""RTN"",""IBJDF61"",55,0)"
^XMB(3.9,145944,2,1980,0)=" . ; - Get division, if necessary."
^XMB(3.9,145944,2,1981,0)="""RTN"",""IBJDF61"",56,0)"
^XMB(3.9,145944,2,1982,0)=" . I (IBCAT1>7),(IBCAT1<15) S IBDIV=0   ;IB*2.0*618"
^XMB(3.9,145944,2,1983,0)="""RTN"",""IBJDF61"",57,0)"
^XMB(3.9,145944,2,1984,0)=" . E  D"
^XMB(3.9,145944,2,1985,0)="""RTN"",""IBJDF61"",58,0)"
^XMB(3.9,145944,2,1986,0)=" . . I 'IBSDV S IBDIV=0"
^XMB(3.9,145944,2,1987,0)="""RTN"",""IBJDF61"",59,0)"
^XMB(3.9,145944,2,1988,0)=" . . E  S IBDIV=$$DIV^IBJDF51(IBA)"
^XMB(3.9,145944,2,1989,0)="""RTN"",""IBJDF61"",60,0)"
^XMB(3.9,145944,2,1990,0)=" . ;"
^XMB(3.9,145944,2,1991,0)="""RTN"",""IBJDF61"",61,0)"
^XMB(3.9,145944,2,1992,0)=" . I IBSDV,IBDIV,'VAUTD Q:'$D(VAUTD(IBDIV))  ; Not a selected division."
^XMB(3.9,145944,2,1993,0)="""RTN"",""IBJDF61"",62,0)"
^XMB(3.9,145944,2,1994,0)=" . ;"
^XMB(3.9,145944,2,1995,0)="""RTN"",""IBJDF61"",63,0)"
^XMB(3.9,145944,2,1996,0)=" . ; - Get patient or debtor for report."
^XMB(3.9,145944,2,1997,0)="""RTN"",""IBJDF61"",64,0)"
^XMB(3.9,145944,2,1998,0)=" . I IBRPT=""D"" S IBPTDB=$$PTDB(IBA) Q:IBPTDB="""""
^XMB(3.9,145944,2,1999,0)="""RTN"",""IBJDF61"",65,0)"
^XMB(3.9,145944,2,2000,0)=" . ;"
^XMB(3.9,145944,2,2001,0)="""RTN"",""IBJDF61"",66,0)"
^XMB(3.9,145944,2,2002,0)=" . ; - Check the receivable age, if necessary."
^XMB(3.9,145944,2,2003,0)="""RTN"",""IBJDF61"",67,0)"
^XMB(3.9,145944,2,2004,0)=" . I IBRPT=""D"",IBSMN D  I (IBARD)<IBSMN!(IBARD>IBSMX) Q"
^XMB(3.9,145944,2,2005,0)="""RTN"",""IBJDF61"",68,0)"
^XMB(3.9,145944,2,2006,0)=" . . S IBARD=+$$ACT^IBJDF2(IBA) S:IBARD IBARD=$$FMDIFF^XLFDT(DT,IBARD)"
^XMB(3.9,145944,2,2007,0)="""RTN"",""IBJDF61"",69,0)"
^XMB(3.9,145944,2,2008,0)=" . ;"
^XMB(3.9,145944,2,2009,0)="""RTN"",""IBJDF61"",70,0)"
^XMB(3.9,145944,2,2010,0)=" . ; - Check the minimum balance amount, if necessary."
^XMB(3.9,145944,2,2011,0)="""RTN"",""IBJDF61"",71,0)"
^XMB(3.9,145944,2,2012,0)=" . S IBBA=0 F X=1:1:5 S IBBA=IBBA+$P($G(^PRCA(430,IBA,7)),U,X)"
^XMB(3.9,145944,2,2013,0)="""RTN"",""IBJDF61"",72,0)"
^XMB(3.9,145944,2,2014,0)=" . I IBRPT=""D"",IBSAM,IBBA<IBSAM Q"
^XMB(3.9,145944,2,2015,0)="""RTN"",""IBJDF61"",73,0)"
^XMB(3.9,145944,2,2016,0)=" . ;"
^XMB(3.9,145944,2,2017,0)="""RTN"",""IBJDF61"",74,0)"
^XMB(3.9,145944,2,2018,0)=" . ; - Get stats for summary"
^XMB(3.9,145944,2,2019,0)="""RTN"",""IBJDF61"",75,0)"
^XMB(3.9,145944,2,2020,0)=" . I '$G(IBEXCEL) D EN^IBJDF63 Q:IBRPT=""S"""
^XMB(3.9,145944,2,2021,0)="""RTN"",""IBJDF61"",76,0)"
^XMB(3.9,145944,2,2022,0)=" . ;"
^XMB(3.9,145944,2,2023,0)="""RTN"",""IBJDF61"",77,0)"
^XMB(3.9,145944,2,2024,0)=" . ; - Get remaining AR/claim info and set indexes for detailed report."
^XMB(3.9,145944,2,2025,0)="""RTN"",""IBJDF61"",78,0)"
^XMB(3.9,145944,2,2026,0)=" . S (IBFR,IBLP,IBOI,IBTO,IBCLM)="""",IBIN=0"
^XMB(3.9,145944,2,2027,0)="""RTN"",""IBJDF61"",79,0)"
^XMB(3.9,145944,2,2028,0)=" . S IBBN=$P(IBAR,U),IBOR=$P(IBAR,U,3),IBDP=$P(IBAR,U,10)"
^XMB(3.9,145944,2,2029,0)="""RTN"",""IBJDF61"",80,0)"
^XMB(3.9,145944,2,2030,0)=" . I IBPDFLG D  Q:'IBI!('IBCLM)     ;IB*2.0*618"
^XMB(3.9,145944,2,2031,0)="""RTN"",""IBJDF61"",81,0)"
^XMB(3.9,145944,2,2032,0)=" . . S IBI=+$G(^DGCR(399,IBA,""MP"")) Q:'IBI  ; Get primary ins carrier."
^XMB(3.9,145944,2,2033,0)="""RTN"",""IBJDF61"",82,0)"
^XMB(3.9,145944,2,2034,0)=" . . S IBIN=$P($G(^DIC(36,IBI,0)),U)_""@@""_IBI,DFN=$P($P(IBPTDB,U),""@@"",2)"
^XMB(3.9,145944,2,2035,0)="""RTN"",""IBJDF61"",83,0)"
^XMB(3.9,145944,2,2036,0)=" . . S IBDP=$P(IBAR,U,10),IBCLM=$$CLMACT^IBJD(IBA,IBCAT) Q:IBCLM="""""
^XMB(3.9,145944,2,2037,0)="""RTN"",""IBJDF61"",84,0)"
^XMB(3.9,145944,2,2038,0)=" . . S IBR=$S(+IBCLM=1:$G(^IB($P(IBCLM,U,2),0)),+IBCLM=2:$G(^DGCR(399,IBA,""U"")),1:IBDP)"
^XMB(3.9,145944,2,2039,0)="""RTN"",""IBJDF61"",85,0)"
^XMB(3.9,145944,2,2040,0)=" . . S IBFR=$P(IBR,U,$S(+IBCLM=1:14,1:1)),IBTO=$P(IBR,U,$S(+IBCLM=1:15,+IBCLM=2:2,1:1))"
^XMB(3.9,145944,2,2041,0)="""RTN"",""IBJDF61"",86,0)"
^XMB(3.9,145944,2,2042,0)=" . . S IBOI=$$OTH(DFN,$P(IBIN,""@@"",2),IBFR) ; Get other insurance carrier."
^XMB(3.9,145944,2,2043,0)="""RTN"",""IBJDF61"",87,0)"
^XMB(3.9,145944,2,2044,0)=" . . I $G(IBEXCEL) Q"
^XMB(3.9,145944,2,2045,0)="""RTN"",""IBJDF61"",88,0)"
^XMB(3.9,145944,2,2046,0)=" . . I '($D(^TMP(""IBJDF6P"",$J,IBDIV,IBCAT,IBIN,$P(IBPTDB,U)))#10) D"
^XMB(3.9,145944,2,2047,0)="""RTN"",""IBJDF61"",89,0)"
^XMB(3.9,145944,2,2048,0)=" . . . S ^TMP(""IBJDF6P"",$J,IBDIV,IBCAT,IBIN,$P(IBPTDB,U))=$P(IBPTDB,U,2)_"" ""_$P(IBPTDB,U,6)_U_$P(IBPTDB,U,3,4)_U_IBOI"
^XMB(3.9,145944,2,2049,0)="""RTN"",""IBJDF61"",90,0)"
^XMB(3.9,145944,2,2050,0)=" . . S ^TMP(""IBJDF6P"",$J,IBDIV,IBCAT,IBIN,$P(IBPTDB,U),IBBN)=IBDP_U_IBFR_U_IBTO_U_IBOR_U_IBBA"
^XMB(3.9,145944,2,2051,0)="""RTN"",""IBJDF61"",91,0)"
^XMB(3.9,145944,2,2052,0)=" . I 'IBPDFLG D"
^XMB(3.9,145944,2,2053,0)="""RTN"",""IBJDF61"",92,0)"
^XMB(3.9,145944,2,2054,0)=" . . S IBLP=+$P($$PYMT^IBJD1(IBA),U,2)"
^XMB(3.9,145944,2,2055,0)="""RTN"",""IBJDF61"",93,0)"
^XMB(3.9,145944,2,2056,0)=" . . I '($D(^TMP(""IBJDF6D"",$J,IBDIV,IBCAT,0,$P(IBPTDB,U)))#10) D"
^XMB(3.9,145944,2,2057,0)="""RTN"",""IBJDF61"",94,0)"
^XMB(3.9,145944,2,2058,0)=" . . . S ^TMP(""IBJDF6D"",$J,IBDIV,IBCAT,0,$P(IBPTDB,U))=$P(IBPTDB,U,2)_"" ""_$P(IBPTDB,U,6)"
^XMB(3.9,145944,2,2059,0)="""RTN"",""IBJDF61"",95,0)"
^XMB(3.9,145944,2,2060,0)=" . . S ^TMP(""IBJDF6D"",$J,IBDIV,IBCAT,0,$P(IBPTDB,U),IBBN)=IBDP_U_$P(IBPTDB,U,5)_U_IBOR_U_IBLP_U_IBBA"
^XMB(3.9,145944,2,2061,0)="""RTN"",""IBJDF61"",96,0)"
^XMB(3.9,145944,2,2062,0)=" . ;"
^XMB(3.9,145944,2,2063,0)="""RTN"",""IBJDF61"",97,0)"
^XMB(3.9,145944,2,2064,0)=" . I '$G(IBEXCEL) D:IBSH COM Q"
^XMB(3.9,145944,2,2065,0)="""RTN"",""IBJDF61"",98,0)"
^XMB(3.9,145944,2,2066,0)=" . ;"
^XMB(3.9,145944,2,2067,0)="""RTN"",""IBJDF61"",99,0)"
^XMB(3.9,145944,2,2068,0)=" . ; - Set up and write line for Excel document."
^XMB(3.9,145944,2,2069,0)="""RTN"",""IBJDF61"",100,0)"
^XMB(3.9,145944,2,2070,0)=" . S IBDIV=$P($G(^DG(40.8,$S('IBDIV:+$$PRIM^VASITE(),1:IBDIV),0)),U)"
^XMB(3.9,145944,2,2071,0)="""RTN"",""IBJDF61"",101,0)"
^XMB(3.9,145944,2,2072,0)=" . S IBEXCEL1=IBDIV_U_$P($G(^PRCA(430.2,IBCAT,0)),U,2)_U_$S(IBIN=0:"""",1:$P(IBIN,""@@""))"
^XMB(3.9,145944,2,2073,0)="""RTN"",""IBJDF61"",102,0)"
^XMB(3.9,145944,2,2074,0)=" . S IBEXCEL1=IBEXCEL1_U_$P(IBPTDB,U,2)_U_$S($P(IBPTDB,""^"",6)=""*"":""E"",1:"""")_U_$TR($P(IBPTDB,U,4),""-"")"
