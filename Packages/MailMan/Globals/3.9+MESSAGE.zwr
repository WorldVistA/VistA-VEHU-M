^XMB(3.9,145944,2,1658,0)=" . W !!,""These receivables will be sorted by PATIENT/SSN:"",!"
^XMB(3.9,145944,2,1659,0)="""RTN"",""IBJDF6"",55,0)"
^XMB(3.9,145944,2,1660,0)=" . F X=2:1 S Y=$P(IBSEL,"","",X) Q:'Y  I Y<8 W !?6,IBCTG(Y)"
^XMB(3.9,145944,2,1661,0)="""RTN"",""IBJDF6"",56,0)"
^XMB(3.9,145944,2,1662,0)=" . ; - Determine the PATIENT range"
^XMB(3.9,145944,2,1663,0)="""RTN"",""IBJDF6"",57,0)"
^XMB(3.9,145944,2,1664,0)=" . S X=$$INTV^IBJD(""PATIENT ""_$S(IBSN=""N"":""NAME"",1:""LAST 4"")) Q:X=""^"""
^XMB(3.9,145944,2,1665,0)="""RTN"",""IBJDF6"",58,0)"
^XMB(3.9,145944,2,1666,0)=" . S IBSNF=$P(X,""^"",1),IBSNL=$P(X,""^"",2),IBSNA=$P(X,""^"",3)"
^XMB(3.9,145944,2,1667,0)="""RTN"",""IBJDF6"",59,0)"
^XMB(3.9,145944,2,1668,0)=" ;"
^XMB(3.9,145944,2,1669,0)="""RTN"",""IBJDF6"",60,0)"
^XMB(3.9,145944,2,1670,0)=" ; - Determine range of debtors."
^XMB(3.9,145944,2,1671,0)="""RTN"",""IBJDF6"",61,0)"
^XMB(3.9,145944,2,1672,0)=" I 'IB1 G AGE"
^XMB(3.9,145944,2,1673,0)="""RTN"",""IBJDF6"",62,0)"
^XMB(3.9,145944,2,1674,0)=" ;"
^XMB(3.9,145944,2,1675,0)="""RTN"",""IBJDF6"",63,0)"
^XMB(3.9,145944,2,1676,0)=" I IB1 D"
^XMB(3.9,145944,2,1677,0)="""RTN"",""IBJDF6"",64,0)"
^XMB(3.9,145944,2,1678,0)=" . W !!,""These receivables will be sorted by DEBTOR:"",!"
^XMB(3.9,145944,2,1679,0)="""RTN"",""IBJDF6"",65,0)"
^XMB(3.9,145944,2,1680,0)=" . F X=2:1 S Y=$P(IBSEL,"","",X) Q:'Y  I Y>4 W !?6,IBCTG(Y)"
^XMB(3.9,145944,2,1681,0)="""RTN"",""IBJDF6"",66,0)"
^XMB(3.9,145944,2,1682,0)=" S VAUTD(0)="""""
^XMB(3.9,145944,2,1683,0)="""RTN"",""IBJDF6"",67,0)"
^XMB(3.9,145944,2,1684,0)=" ;"
^XMB(3.9,145944,2,1685,0)="""RTN"",""IBJDF6"",68,0)"
^XMB(3.9,145944,2,1686,0)=" ; - Determine the DEBTOR range"
^XMB(3.9,145944,2,1687,0)="""RTN"",""IBJDF6"",69,0)"
^XMB(3.9,145944,2,1688,0)=" S X=$$INTV^IBJD(""DEBTOR"") G ENQ:X=""^"""
^XMB(3.9,145944,2,1689,0)="""RTN"",""IBJDF6"",70,0)"
^XMB(3.9,145944,2,1690,0)=" S IBSDF=$P(X,""^"",1),IBSDL=$P(X,""^"",2),IBSDA=$P(X,""^"",3)"
^XMB(3.9,145944,2,1691,0)="""RTN"",""IBJDF6"",71,0)"
^XMB(3.9,145944,2,1692,0)=" ;"
^XMB(3.9,145944,2,1693,0)="""RTN"",""IBJDF6"",72,0)"
^XMB(3.9,145944,2,1694,0)="AGE ; - Determine if the active receivable must be within an age range."
^XMB(3.9,145944,2,1695,0)="""RTN"",""IBJDF6"",73,0)"
^XMB(3.9,145944,2,1696,0)=" W !!,""Include (A)LL active AR's or those within an AGE (R)ANGE: ALL// """
^XMB(3.9,145944,2,1697,0)="""RTN"",""IBJDF6"",74,0)"
^XMB(3.9,145944,2,1698,0)=" R X:DTIME G:'$T!(X[""^"") ENQ S:X="""" X=""A"" S X=$E(X)"
^XMB(3.9,145944,2,1699,0)="""RTN"",""IBJDF6"",75,0)"
^XMB(3.9,145944,2,1700,0)=" I ""ARar""'[X S IBOFF=1 D HELP^IBJDF6H G AGE"
^XMB(3.9,145944,2,1701,0)="""RTN"",""IBJDF6"",76,0)"
^XMB(3.9,145944,2,1702,0)=" W ""  "",$S(""Rr""[X:""RANGE"",1:""ALL"")"
^XMB(3.9,145944,2,1703,0)="""RTN"",""IBJDF6"",77,0)"
^XMB(3.9,145944,2,1704,0)=" S IBSMN=$S(""Rr""[X:""R"",1:""A"") G:IBSMN=""A"" AMT"
^XMB(3.9,145944,2,1705,0)="""RTN"",""IBJDF6"",78,0)"
^XMB(3.9,145944,2,1706,0)=" ;"
^XMB(3.9,145944,2,1707,0)="""RTN"",""IBJDF6"",79,0)"
^XMB(3.9,145944,2,1708,0)=" ; - Determine the active receivable age range."
^XMB(3.9,145944,2,1709,0)="""RTN"",""IBJDF6"",80,0)"
^XMB(3.9,145944,2,1710,0)=" S DIR(0)=""NA^1:99999"""
^XMB(3.9,145944,2,1711,0)="""RTN"",""IBJDF6"",81,0)"
^XMB(3.9,145944,2,1712,0)=" S DIR(""A"")=""Enter the minimum age of the active receivable: """
^XMB(3.9,145944,2,1713,0)="""RTN"",""IBJDF6"",82,0)"
^XMB(3.9,145944,2,1714,0)=" S DIR(""T"")=DTIME,DIR(""?"")=""^S IBOFF=9 D HELP^IBJDF6H"""
^XMB(3.9,145944,2,1715,0)="""RTN"",""IBJDF6"",83,0)"
^XMB(3.9,145944,2,1716,0)=" D ^DIR K DIR G:$D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1717,0)="""RTN"",""IBJDF6"",84,0)"
^XMB(3.9,145944,2,1718,0)=" S IBSMN=+Y W ""   "",IBSMN,"" DAYS"" K DIROUT,DTOUT,DUOUT,DIRUT"
^XMB(3.9,145944,2,1719,0)="""RTN"",""IBJDF6"",85,0)"
^XMB(3.9,145944,2,1720,0)=" ;"
^XMB(3.9,145944,2,1721,0)="""RTN"",""IBJDF6"",86,0)"
^XMB(3.9,145944,2,1722,0)=" S DIR(0)=""NA^""_IBSMN_"":99999"",DIR(""B"")=IBSMN"
^XMB(3.9,145944,2,1723,0)="""RTN"",""IBJDF6"",87,0)"
^XMB(3.9,145944,2,1724,0)=" S DIR(""A"")=""Enter the maximum age of the active receivable: """
^XMB(3.9,145944,2,1725,0)="""RTN"",""IBJDF6"",88,0)"
^XMB(3.9,145944,2,1726,0)=" S DIR(""T"")=DTIME,DIR(""?"")=""^S IBOFF=14 D HELP^IBJDF6H"""
^XMB(3.9,145944,2,1727,0)="""RTN"",""IBJDF6"",89,0)"
^XMB(3.9,145944,2,1728,0)=" D ^DIR K DIR G:$D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1729,0)="""RTN"",""IBJDF6"",90,0)"
^XMB(3.9,145944,2,1730,0)=" S IBSMX=+Y W ""   "",IBSMX,"" DAYS"" K DIROUT,DTOUT,DUOUT,DIRUT"
^XMB(3.9,145944,2,1731,0)="""RTN"",""IBJDF6"",91,0)"
^XMB(3.9,145944,2,1732,0)=" ;"
^XMB(3.9,145944,2,1733,0)="""RTN"",""IBJDF6"",92,0)"
^XMB(3.9,145944,2,1734,0)="AMT ; - Print receivables with a minimum balance."
^XMB(3.9,145944,2,1735,0)="""RTN"",""IBJDF6"",93,0)"
^XMB(3.9,145944,2,1736,0)=" S DIR(0)=""Y"",DIR(""B"")=""NO"" W !"
^XMB(3.9,145944,2,1737,0)="""RTN"",""IBJDF6"",94,0)"
^XMB(3.9,145944,2,1738,0)=" S DIR(""A"")=""Print receivables with a minimum balance"""
^XMB(3.9,145944,2,1739,0)="""RTN"",""IBJDF6"",95,0)"
