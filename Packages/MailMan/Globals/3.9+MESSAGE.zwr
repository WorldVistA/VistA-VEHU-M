^XMB(3.9,145983,2,754,0)=" .S RCIEN=$$SELRPP^RCRPU1()"
^XMB(3.9,145983,2,755,0)="""RTN"",""RCRPENTR"",83,0)"
^XMB(3.9,145983,2,756,0)=" .I +RCIEN<1 S RCEXIT=-1 Q"
^XMB(3.9,145983,2,757,0)="""RTN"",""RCRPENTR"",84,0)"
^XMB(3.9,145983,2,758,0)=" .D EDITPLAN(RCIEN)  ; PRCA*4.5*389"
^XMB(3.9,145983,2,759,0)="""RTN"",""RCRPENTR"",85,0)"
^XMB(3.9,145983,2,760,0)=" .Q"
^XMB(3.9,145983,2,761,0)="""RTN"",""RCRPENTR"",86,0)"
^XMB(3.9,145983,2,762,0)=" ;"
^XMB(3.9,145983,2,763,0)="""RTN"",""RCRPENTR"",87,0)"
^XMB(3.9,145983,2,764,0)=" Q RCEXIT"
^XMB(3.9,145983,2,765,0)="""RTN"",""RCRPENTR"",88,0)"
^XMB(3.9,145983,2,766,0)=" ;"
^XMB(3.9,145983,2,767,0)="""RTN"",""RCRPENTR"",89,0)"
^XMB(3.9,145983,2,768,0)="EDITPLAN(RCIEN) ; edit selected plan, entry point from repayment plan worklist  PRCA*4.5*389"
^XMB(3.9,145983,2,769,0)="""RTN"",""RCRPENTR"",90,0)"
^XMB(3.9,145983,2,770,0)=" ;"
^XMB(3.9,145983,2,771,0)="""RTN"",""RCRPENTR"",91,0)"
^XMB(3.9,145983,2,772,0)=" ; RCIEN - file 340.5 ien"
^XMB(3.9,145983,2,773,0)="""RTN"",""RCRPENTR"",92,0)"
^XMB(3.9,145983,2,774,0)=" ;"
^XMB(3.9,145983,2,775,0)="""RTN"",""RCRPENTR"",93,0)"
^XMB(3.9,145983,2,776,0)=" N RCAFLG,RCDBTR,RCDBTRN,RCERROR,RCEXIT1,RCIENC,RCLNG,RCLP,RCMNAMT,RCMSCT,RCPYMD,RCRPID,RCSTAT,RCSTDT"
^XMB(3.9,145983,2,777,0)="""RTN"",""RCRPENTR"",94,0)"
^XMB(3.9,145983,2,778,0)=" ; don't allow editing of plans in ""closed"", ""paid in full"", and ""terminated"" status"
^XMB(3.9,145983,2,779,0)="""RTN"",""RCRPENTR"",95,0)"
^XMB(3.9,145983,2,780,0)=" I ""^6^7^8^""[$$GET1^DIQ(340.5,RCIEN_"","",.07,""I"")_U W !!,""Can't edit a closed repayment plan."",! D PAUSE^RCRPRPU Q"
^XMB(3.9,145983,2,781,0)="""RTN"",""RCRPENTR"",96,0)"
^XMB(3.9,145983,2,782,0)=" F  D  Q:RCEXIT1<1"
^XMB(3.9,145983,2,783,0)="""RTN"",""RCRPENTR"",97,0)"
^XMB(3.9,145983,2,784,0)=" .S (RCDATA,RCERROR)="""",RCIENC=RCIEN_"","""
^XMB(3.9,145983,2,785,0)="""RTN"",""RCRPENTR"",98,0)"
^XMB(3.9,145983,2,786,0)=" .; Get the Plan information"
^XMB(3.9,145983,2,787,0)="""RTN"",""RCRPENTR"",99,0)"
^XMB(3.9,145983,2,788,0)=" .K RCDATA N RCDATA ; Clear and redefine RCDATA before reprinting screen"
^XMB(3.9,145983,2,789,0)="""RTN"",""RCRPENTR"",100,0)"
^XMB(3.9,145983,2,790,0)=" .D GETS^DIQ(340.5,RCIENC,""**"",""EI"",""RCDATA"",""RCERROR"")"
^XMB(3.9,145983,2,791,0)="""RTN"",""RCRPENTR"",101,0)"
^XMB(3.9,145983,2,792,0)=" .; Get the Base info"
^XMB(3.9,145983,2,793,0)="""RTN"",""RCRPENTR"",102,0)"
^XMB(3.9,145983,2,794,0)=" .S RCRPID=RCDATA(340.5,RCIENC,.01,""E"")"
^XMB(3.9,145983,2,795,0)="""RTN"",""RCRPENTR"",103,0)"
^XMB(3.9,145983,2,796,0)=" .S RCDBTRN=RCDATA(340.5,RCIENC,.02,""E"")"
^XMB(3.9,145983,2,797,0)="""RTN"",""RCRPENTR"",104,0)"
^XMB(3.9,145983,2,798,0)=" .S RCDBTR=RCDATA(340.5,RCIENC,.02,""I"")"
^XMB(3.9,145983,2,799,0)="""RTN"",""RCRPENTR"",105,0)"
^XMB(3.9,145983,2,800,0)=" .S RCSTDT=RCDATA(340.5,RCIENC,.04,""I"")"
^XMB(3.9,145983,2,801,0)="""RTN"",""RCRPENTR"",106,0)"
^XMB(3.9,145983,2,802,0)=" .S RCMNAMT=RCDATA(340.5,RCIENC,.06,""E"")"
^XMB(3.9,145983,2,803,0)="""RTN"",""RCRPENTR"",107,0)"
^XMB(3.9,145983,2,804,0)=" .S RCLNG=RCDATA(340.5,RCIENC,.05,""E"")"
^XMB(3.9,145983,2,805,0)="""RTN"",""RCRPENTR"",108,0)"
^XMB(3.9,145983,2,806,0)=" .S RCSTAT=RCDATA(340.5,RCIENC,.07,""E"")"
^XMB(3.9,145983,2,807,0)="""RTN"",""RCRPENTR"",109,0)"
^XMB(3.9,145983,2,808,0)=" .S RCAFLG=RCDATA(340.5,RCIENC,.12,""E"")"
^XMB(3.9,145983,2,809,0)="""RTN"",""RCRPENTR"",110,0)"
^XMB(3.9,145983,2,810,0)=" .; Calculate the # payments remaining"
^XMB(3.9,145983,2,811,0)="""RTN"",""RCRPENTR"",111,0)"
^XMB(3.9,145983,2,812,0)=" .S RCLP="""",RCMSCT=0"
^XMB(3.9,145983,2,813,0)="""RTN"",""RCRPENTR"",112,0)"
^XMB(3.9,145983,2,814,0)=" .F  S RCLP=$O(RCDATA(340.52,RCLP)) Q:'RCLP  D"
^XMB(3.9,145983,2,815,0)="""RTN"",""RCRPENTR"",113,0)"
^XMB(3.9,145983,2,816,0)=" ..S RCPYMD=RCDATA(340.52,RCLP,1,""I""),RCPYFB=RCDATA(340.52,RCLP,2,""I"")"
^XMB(3.9,145983,2,817,0)="""RTN"",""RCRPENTR"",114,0)"
^XMB(3.9,145983,2,818,0)=" ..I 'RCPYMD,'RCPYFB S RCMSCT=RCMSCT+1"
^XMB(3.9,145983,2,819,0)="""RTN"",""RCRPENTR"",115,0)"
^XMB(3.9,145983,2,820,0)=" ..Q"
^XMB(3.9,145983,2,821,0)="""RTN"",""RCRPENTR"",116,0)"
^XMB(3.9,145983,2,822,0)=" .; Display the Plan summary information"
^XMB(3.9,145983,2,823,0)="""RTN"",""RCRPENTR"",117,0)"
^XMB(3.9,145983,2,824,0)=" .W @IOF,!,""--------------------------------------------------------------------------------"""
^XMB(3.9,145983,2,825,0)="""RTN"",""RCRPENTR"",118,0)"
^XMB(3.9,145983,2,826,0)=" .W !,""Repayment Plan Overview for AR Debtor: "",RCDBTRN,!"
^XMB(3.9,145983,2,827,0)="""RTN"",""RCRPENTR"",119,0)"
^XMB(3.9,145983,2,828,0)=" .W !,?23,""Repayment Plan ID: "",RCRPID,!"
^XMB(3.9,145983,2,829,0)="""RTN"",""RCRPENTR"",120,0)"
^XMB(3.9,145983,2,830,0)=" .W !,""Monthly Repayment Amount:"",?32,""$"",$J(RCMNAMT,0,2)"
^XMB(3.9,145983,2,831,0)="""RTN"",""RCRPENTR"",121,0)"
^XMB(3.9,145983,2,832,0)=" .W ?45,""Original # of Payments:"",?70,RCLNG"
^XMB(3.9,145983,2,833,0)="""RTN"",""RCRPENTR"",122,0)"
^XMB(3.9,145983,2,834,0)=" .W !,""# of Remaining Payments:"",?32,RCMSCT"
^XMB(3.9,145983,2,835,0)="""RTN"",""RCRPENTR"",123,0)"
^XMB(3.9,145983,2,836,0)=" .W ?45,""Current Status:"",?70,RCSTAT"
^XMB(3.9,145983,2,837,0)="""RTN"",""RCRPENTR"",124,0)"
^XMB(3.9,145983,2,838,0)=" .W !,""Date First Payment Due:"",?32,$$FMTE^XLFDT(RCSTDT,""5DZ"")"
^XMB(3.9,145983,2,839,0)="""RTN"",""RCRPENTR"",125,0)"
^XMB(3.9,145983,2,840,0)=" .W ?45,""Auto Add New Bills:"",?70,RCAFLG"
^XMB(3.9,145983,2,841,0)="""RTN"",""RCRPENTR"",126,0)"
^XMB(3.9,145983,2,842,0)=" .W !,""--------------------------------------------------------------------------------"",!"
^XMB(3.9,145983,2,843,0)="""RTN"",""RCRPENTR"",127,0)"
^XMB(3.9,145983,2,844,0)=" .; Ask user what to edit (Close Plan, Edit Monthly Payment, or Allow Auto Adding of Bills"
^XMB(3.9,145983,2,845,0)="""RTN"",""RCRPENTR"",128,0)"
^XMB(3.9,145983,2,846,0)=" .S RCEXIT1=0"
^XMB(3.9,145983,2,847,0)="""RTN"",""RCRPENTR"",129,0)"
^XMB(3.9,145983,2,848,0)=" .S RCEDTYPE=$$GETTYPE"
^XMB(3.9,145983,2,849,0)="""RTN"",""RCRPENTR"",130,0)"
^XMB(3.9,145983,2,850,0)=" .I RCEDTYPE=-1 S RCEXIT1=0 Q   ; Time out or user ""^"" to exit option"
^XMB(3.9,145983,2,851,0)="""RTN"",""RCRPENTR"",131,0)"
^XMB(3.9,145983,2,852,0)=" .; PRCA*4.5*378 - Added 2 new user prompts"
^XMB(3.9,145983,2,853,0)="""RTN"",""RCRPENTR"",132,0)"
^XMB(3.9,145983,2,854,0)=" .I RCEDTYPE=""Q"" S RCEXIT1=0 Q     ;User requested Exit pla using prompt"
^XMB(3.9,145983,2,855,0)="""RTN"",""RCRPENTR"",133,0)"
^XMB(3.9,145983,2,856,0)=" .I RCEDTYPE=""C"" D CLOSE(RCIEN) K ^TMP($J,""RPPFLDNO"") S RCEXIT1=0 Q"
^XMB(3.9,145983,2,857,0)="""RTN"",""RCRPENTR"",134,0)"
^XMB(3.9,145983,2,858,0)=" .I RCEDTYPE=""E"" D EDMN(RCDBTR,RCIEN,RCMSCT,.RCEXIT) Q  ; PRCA*4.5*422"
^XMB(3.9,145983,2,859,0)="""RTN"",""RCRPENTR"",135,0)"
^XMB(3.9,145983,2,860,0)=" .I RCEDTYPE=""A"" S RCAUTO=$$AUTOADD^RCRPU1 D:RCAUTO'<0 UPDAUTO^RCRPU1(RCIEN,RCAUTO) S RCEXIT1=1"
^XMB(3.9,145983,2,861,0)="""RTN"",""RCRPENTR"",136,0)"
^XMB(3.9,145983,2,862,0)=" .Q"
^XMB(3.9,145983,2,863,0)="""RTN"",""RCRPENTR"",137,0)"
^XMB(3.9,145983,2,864,0)=" Q "
^XMB(3.9,145983,2,865,0)="""RTN"",""RCRPENTR"",138,0)"
^XMB(3.9,145983,2,866,0)=" ;"
^XMB(3.9,145983,2,867,0)="""RTN"",""RCRPENTR"",139,0)"
^XMB(3.9,145983,2,868,0)="GETTYPE() ;Get the user requested type of editing."
^XMB(3.9,145983,2,869,0)="""RTN"",""RCRPENTR"",140,0)"
^XMB(3.9,145983,2,870,0)=" ;"
^XMB(3.9,145983,2,871,0)="""RTN"",""RCRPENTR"",141,0)"
^XMB(3.9,145983,2,872,0)=" N X,Y,DTOUT,DUOUT,DIR,DIROUT,DIRUT"
^XMB(3.9,145983,2,873,0)="""RTN"",""RCRPENTR"",142,0)"
^XMB(3.9,145983,2,874,0)=" ;"
^XMB(3.9,145983,2,875,0)="""RTN"",""RCRPENTR"",143,0)"
^XMB(3.9,145983,2,876,0)=" ; Prompt Summary or Detail version"
^XMB(3.9,145983,2,877,0)="""RTN"",""RCRPENTR"",144,0)"
^XMB(3.9,145983,2,878,0)=" ;S DIR(""A"")=""(C)lose the Plan or (E)dit Monthly Payment?  """
^XMB(3.9,145983,2,879,0)="""RTN"",""RCRPENTR"",145,0)"
^XMB(3.9,145983,2,880,0)=" S DIR(""A"")=""(C)lose Plan, (E)dit Monthly Payment, (A)llow Bill Auto-Add, or (Q)uit?  """
^XMB(3.9,145983,2,881,0)="""RTN"",""RCRPENTR"",146,0)"
^XMB(3.9,145983,2,882,0)=" S DIR(""B"")=""Q"""
^XMB(3.9,145983,2,883,0)="""RTN"",""RCRPENTR"",147,0)"
^XMB(3.9,145983,2,884,0)=" S DIR(0)=""SA^C:Close Plan;E:Edit Payment Amount;A:Allow Auto-add;Q:Quit"""
^XMB(3.9,145983,2,885,0)="""RTN"",""RCRPENTR"",148,0)"
^XMB(3.9,145983,2,886,0)=" S DIR(""?"")=""Select whether to Close the plan, Change the amount of the Monthly Payment, Turn on or off the Auto-add of bills ability, or Quit."""
^XMB(3.9,145983,2,887,0)="""RTN"",""RCRPENTR"",149,0)"
^XMB(3.9,145983,2,888,0)=" ;"
^XMB(3.9,145983,2,889,0)="""RTN"",""RCRPENTR"",150,0)"
^XMB(3.9,145983,2,890,0)=" D ^DIR K DIR"
^XMB(3.9,145983,2,891,0)="""RTN"",""RCRPENTR"",151,0)"
^XMB(3.9,145983,2,892,0)=" ;"
^XMB(3.9,145983,2,893,0)="""RTN"",""RCRPENTR"",152,0)"
^XMB(3.9,145983,2,894,0)=" I $D(DTOUT)!$D(DUOUT)!($G(Y)="""") Q -1"
^XMB(3.9,145983,2,895,0)="""RTN"",""RCRPENTR"",153,0)"
^XMB(3.9,145983,2,896,0)=" ;"
^XMB(3.9,145983,2,897,0)="""RTN"",""RCRPENTR"",154,0)"
^XMB(3.9,145983,2,898,0)=" Q Y"
^XMB(3.9,145983,2,899,0)="""RTN"",""RCRPENTR"",155,0)"
^XMB(3.9,145983,2,900,0)=" ;"
^XMB(3.9,145983,2,901,0)="""RTN"",""RCRPENTR"",156,0)"
^XMB(3.9,145983,2,902,0)="EDMN(RCDBTR,RCIEN,RCORLN,RCEXIT) ;Edit the monthly payment"
^XMB(3.9,145983,2,903,0)="""RTN"",""RCRPENTR"",157,0)"
^XMB(3.9,145983,2,904,0)=" ;INPUT - RCIEN - IEN of the Repayment Plan being edited."
^XMB(3.9,145983,2,905,0)="""RTN"",""RCRPENTR"",158,0)"
^XMB(3.9,145983,2,906,0)=" ;        RCORLN - Original # remaining Payments."
^XMB(3.9,145983,2,907,0)="""RTN"",""RCRPENTR"",159,0)"
^XMB(3.9,145983,2,908,0)=" ;        RCEXIT - exit flag for EDITPLAN tag (1/0)"
^XMB(3.9,145983,2,909,0)="""RTN"",""RCRPENTR"",160,0)"
^XMB(3.9,145983,2,910,0)=" ;"
^XMB(3.9,145983,2,911,0)="""RTN"",""RCRPENTR"",161,0)"
^XMB(3.9,145983,2,912,0)=" N N0,RCTOT,RCPLN"
^XMB(3.9,145983,2,913,0)="""RTN"",""RCRPENTR"",162,0)"
^XMB(3.9,145983,2,914,0)=" ;"
^XMB(3.9,145983,2,915,0)="""RTN"",""RCRPENTR"",163,0)"
^XMB(3.9,145983,2,916,0)=" S RCEXIT=1  ; PRCA*4.5*422"
^XMB(3.9,145983,2,917,0)="""RTN"",""RCRPENTR"",164,0)"
^XMB(3.9,145983,2,918,0)=" ;Determine actual amount remaining"
^XMB(3.9,145983,2,919,0)="""RTN"",""RCRPENTR"",165,0)"
^XMB(3.9,145983,2,920,0)=" S RCTOT=$$CALCTOT^RCRPU2(RCIEN)"
^XMB(3.9,145983,2,921,0)="""RTN"",""RCRPENTR"",166,0)"
^XMB(3.9,145983,2,922,0)=" ;"
^XMB(3.9,145983,2,923,0)="""RTN"",""RCRPENTR"",167,0)"
^XMB(3.9,145983,2,924,0)=" ;Ask for the new amount and plan length"
^XMB(3.9,145983,2,925,0)="""RTN"",""RCRPENTR"",168,0)"
^XMB(3.9,145983,2,926,0)=" S RCPLN=$$GETPLN^RCRPU(RCDBTR,RCTOT,1)"
^XMB(3.9,145983,2,927,0)="""RTN"",""RCRPENTR"",169,0)"
^XMB(3.9,145983,2,928,0)=" Q:'RCPLN"
^XMB(3.9,145983,2,929,0)="""RTN"",""RCRPENTR"",170,0)"
^XMB(3.9,145983,2,930,0)=" S N0=^RCRP(340.5,RCIEN,0)  ; PRCA*4.5*422"
^XMB(3.9,145983,2,931,0)="""RTN"",""RCRPENTR"",171,0)"
^XMB(3.9,145983,2,932,0)=" W !!,""You are changing the monthly payment for this repayment plan "",$P(N0,U),"", this plan will be administratively closed. A new plan will be generated."",!  ; PRCA*4.5*422"
^XMB(3.9,145983,2,933,0)="""RTN"",""RCRPENTR"",172,0)"
^XMB(3.9,145983,2,934,0)=" ;"
^XMB(3.9,145983,2,935,0)="""RTN"",""RCRPENTR"",173,0)"
^XMB(3.9,145983,2,936,0)=" ;Confirm that this is correct"
^XMB(3.9,145983,2,937,0)="""RTN"",""RCRPENTR"",174,0)"
^XMB(3.9,145983,2,938,0)=" Q:'$$CORRECT^RCRPU"
^XMB(3.9,145983,2,939,0)="""RTN"",""RCRPENTR"",175,0)"
^XMB(3.9,145983,2,940,0)=" ; close the plan and create a new one  PRCA*4.5*422"
^XMB(3.9,145983,2,941,0)="""RTN"",""RCRPENTR"",176,0)"
^XMB(3.9,145983,2,942,0)=" D CLSPLAN^RCRPU3(RCIEN,""T"")"
^XMB(3.9,145983,2,943,0)="""RTN"",""RCRPENTR"",177,0)"
^XMB(3.9,145983,2,944,0)=" W !,""Repayment plan "",$P(N0,U),"" has been closed."",!"
^XMB(3.9,145983,2,945,0)="""RTN"",""RCRPENTR"",178,0)"
^XMB(3.9,145983,2,946,0)=" I '$$CPYPLAN^RCRPU3(RCIEN,RCPLN) Q"
^XMB(3.9,145983,2,947,0)="""RTN"",""RCRPENTR"",179,0)"
^XMB(3.9,145983,2,948,0)=" S RCEXIT=0"
^XMB(3.9,145983,2,949,0)="""RTN"",""RCRPENTR"",180,0)"
^XMB(3.9,145983,2,950,0)=" D PAUSE^RCRPU"
^XMB(3.9,145983,2,951,0)="""RTN"",""RCRPENTR"",181,0)"
^XMB(3.9,145983,2,952,0)=" ;"
^XMB(3.9,145983,2,953,0)="""RTN"",""RCRPENTR"",182,0)"
^XMB(3.9,145983,2,954,0)=" Q"
^XMB(3.9,145983,2,955,0)="""RTN"",""RCRPENTR"",183,0)"
^XMB(3.9,145983,2,956,0)=" ;"
^XMB(3.9,145983,2,957,0)="""RTN"",""RCRPENTR"",184,0)"
^XMB(3.9,145983,2,958,0)="CLOSE(RCIEN) ; Close the plan  PRCA*4.5*422"
^XMB(3.9,145983,2,959,0)="""RTN"",""RCRPENTR"",185,0)"
^XMB(3.9,145983,2,960,0)=" ;"
^XMB(3.9,145983,2,961,0)="""RTN"",""RCRPENTR"",186,0)"
