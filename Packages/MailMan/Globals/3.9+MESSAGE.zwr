^XMB(3.9,145987,2,2300,0)="STATUS(DFN,SDT,SDCL,SDATA,SDDA) ; return appt status"
^XMB(3.9,145987,2,2301,0)="""RTN"",""SDES2SETCHECKOUT"",426,0)"
