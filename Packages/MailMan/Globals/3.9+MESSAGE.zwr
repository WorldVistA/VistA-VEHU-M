^XMB(3.9,145951,2,1929,0)="""RTN"",""SDES2CRTCLNAVAIL"",257,0)"
^XMB(3.9,145951,2,1930,0)=" I $D(Y)=1 S SDEL=1 G D"
^XMB(3.9,145951,2,1931,0)="""RTN"",""SDES2CRTCLNAVAIL"",258,0)"
^XMB(3.9,145951,2,1932,0)=" I $D(HSI) I HSI=1!(HSI=2) D CKSI1"
^XMB(3.9,145951,2,1933,0)="""RTN"",""SDES2CRTCLNAVAIL"",259,0)"
^XMB(3.9,145951,2,1934,0)=" F Y=1:1 S DH=$D(Y(Y)),X=X_$S('DH&DO:""]"",'DO&DH:""["",Y#SI=1:""|"",1:"" "")_$S(DH:Y(Y),1:"" ""),DO=DH I 'DH,$O(Y(Y))="""" Q"
