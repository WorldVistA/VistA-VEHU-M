^XMB(3.9,145986,2,3425,0)="""RTN"",""FBPAY671"",97,0)"
^XMB(3.9,145986,2,3426,0)=" Q"
^XMB(3.9,145986,2,3427,0)="""RTN"",""FBPAY671"",98,0)"
