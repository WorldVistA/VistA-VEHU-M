^XMB(3.9,145946,2,1031,0)="""RTN"",""IBCMDT"",194,0)"
^XMB(3.9,145946,2,1032,0)=" ;"
^XMB(3.9,145946,2,1033,0)="""RTN"",""IBCMDT"",195,0)"
^XMB(3.9,145946,2,1034,0)=" N I,POP,ZTDESC,ZTRTN,ZTSAVE"
^XMB(3.9,145946,2,1035,0)="""RTN"",""IBCMDT"",196,0)"
^XMB(3.9,145946,2,1036,0)=" W *7,!!!?14,""*** WARNING ***"""
^XMB(3.9,145946,2,1037,0)="""RTN"",""IBCMDT"",197,0)"
^XMB(3.9,145946,2,1038,0)=" W !?2,""This report may take a little while to compile!"""
^XMB(3.9,145946,2,1039,0)="""RTN"",""IBCMDT"",198,0)"
^XMB(3.9,145946,2,1040,0)=" W !!?2,""This report is 132 characters wide."""
^XMB(3.9,145946,2,1041,0)="""RTN"",""IBCMDT"",199,0)"
^XMB(3.9,145946,2,1042,0)=" W !?2,""Please choose an appropriate device."",!"
^XMB(3.9,145946,2,1043,0)="""RTN"",""IBCMDT"",200,0)"
^XMB(3.9,145946,2,1044,0)=" S ZTRTN=""COMPILE^IBCMDT(.IBMDTSPC)"""
^XMB(3.9,145946,2,1045,0)="""RTN"",""IBCMDT"",201,0)"
^XMB(3.9,145946,2,1046,0)=" S ZTDESC=""IB - INSURANCE PLANS MISSING DATA REPORT"""
^XMB(3.9,145946,2,1047,0)="""RTN"",""IBCMDT"",202,0)"
^XMB(3.9,145946,2,1048,0)=" S ZTSAVE(""IBMDTSPC("")="""""
^XMB(3.9,145946,2,1049,0)="""RTN"",""IBCMDT"",203,0)"
^XMB(3.9,145946,2,1050,0)=" S ZTSAVE(""^TMP(""""IBCMDT"""",$J,"")="""""
^XMB(3.9,145946,2,1051,0)="""RTN"",""IBCMDT"",204,0)"
^XMB(3.9,145946,2,1052,0)=" D EN^XUTMDEVQ(ZTRTN,ZTDESC,.ZTSAVE,""QM"",1)"
^XMB(3.9,145946,2,1053,0)="""RTN"",""IBCMDT"",205,0)"
