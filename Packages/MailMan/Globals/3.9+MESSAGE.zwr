^XMB(3.9,145952,2,2845,0)="""RTN"",""SDESGETCLINAPPT"",48,0)"
^XMB(3.9,145952,2,2846,0)=" Q:NUM"
^XMB(3.9,145952,2,2847,0)="""RTN"",""SDESGETCLINAPPT"",49,0)"
^XMB(3.9,145952,2,2848,0)=" I $L(SDENDDT,""."")=1 S SDENDDT=SDENDDT_.24"
^XMB(3.9,145952,2,2849,0)="""RTN"",""SDESGETCLINAPPT"",50,0)"
