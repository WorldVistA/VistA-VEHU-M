^XMB(3.9,145983,2,1787,0)="""RTN"",""RCRPU1"",9,0)"
^XMB(3.9,145983,2,1788,0)=" N DR,DIE,DA,X,Y"
^XMB(3.9,145983,2,1789,0)="""RTN"",""RCRPU1"",10,0)"
^XMB(3.9,145983,2,1790,0)=" N FLG36,FLG60,N1,PMNTS,RPMNTS"
^XMB(3.9,145983,2,1791,0)="""RTN"",""RCRPU1"",11,0)"
^XMB(3.9,145983,2,1792,0)=" S N1=$G(^RCRP(340.5,RCRPIEN,1))"
^XMB(3.9,145983,2,1793,0)="""RTN"",""RCRPU1"",12,0)"
^XMB(3.9,145983,2,1794,0)=" S FLG36=$P(N1,U,6)  ; 36 months review flag"
^XMB(3.9,145983,2,1795,0)="""RTN"",""RCRPU1"",13,0)"
^XMB(3.9,145983,2,1796,0)=" S FLG60=$P(N1,U)  ; 60 months review flag"
^XMB(3.9,145983,2,1797,0)="""RTN"",""RCRPU1"",14,0)"
^XMB(3.9,145983,2,1798,0)=" S PMNTS=+$P(RCPLNS,U,2)"
^XMB(3.9,145983,2,1799,0)="""RTN"",""RCRPU1"",15,0)"
^XMB(3.9,145983,2,1800,0)=" S DR="".05////""_PMNTS_"";.06////""_+RCPLNS"
^XMB(3.9,145983,2,1801,0)="""RTN"",""RCRPU1"",16,0)"
