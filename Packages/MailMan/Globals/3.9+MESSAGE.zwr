^XMB(3.9,145989,2,276,0)="^D RTN^XPDH"
^XMB(3.9,145989,2,277,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145989,2,278,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145989,2,279,0)="""QUES"",""XPZ2"",""B"")"
