^XMB(3.9,145980,2,3869,0)="""RTN"",""SDES2CANCELAPPT2"",91,0)"
^XMB(3.9,145980,2,3870,0)=" N %DT,C,DSIHCL,DSIHFS,DSPV150,EVN,HL16,HL7STRG,HLA,HLECH,HLFS,HLQ,IEN,J,PIVOT,R,REF,RTN,S,SDCODES,SEQ,SLOTSTATUSSTRING,VA,VACNTRY,VAERR,XQXFLG,XS,XX,Y,Z0"
^XMB(3.9,145980,2,3871,0)="""RTN"",""SDES2CANCELAPPT2"",92,0)"
