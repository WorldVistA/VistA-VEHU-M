^XMB(3.9,145945,2,451,0)="""RTN"",""GECSUSEL"",106,0)"
^XMB(3.9,145945,2,452,0)=" I GECSDICS'="""" S DIC(""S"")=GECSDICS"
^XMB(3.9,145945,2,453,0)="""RTN"",""GECSUSEL"",107,0)"
^XMB(3.9,145945,2,454,0)=" W ! D ^DIC I Y'>0 Q 0"
^XMB(3.9,145945,2,455,0)="""RTN"",""GECSUSEL"",108,0)"
^XMB(3.9,145945,2,456,0)=" Q +Y"
^XMB(3.9,145945,2,457,0)="""RTN"",""GECSUSEL"",109,0)"
^XMB(3.9,145945,2,458,0)=" ;"
^XMB(3.9,145945,2,459,0)="""RTN"",""GECSUSEL"",110,0)"
^XMB(3.9,145945,2,460,0)=" ;"
^XMB(3.9,145945,2,461,0)="""RTN"",""GECSUSEL"",111,0)"
^XMB(3.9,145945,2,462,0)="GEC2P41 ;;GEC*2*41  check for batch scheduled to be disabled - SSNR, PDL"
^XMB(3.9,145945,2,463,0)="""RTN"",""GECSUSEL"",112,0)"
^XMB(3.9,145945,2,464,0)=" N I,GECB,GECBL,GECMSG,%,%I,XMSUB,XMTEXT,XMY"
^XMB(3.9,145945,2,465,0)="""RTN"",""GECSUSEL"",113,0)"
^XMB(3.9,145945,2,466,0)=" ; INITIALIZE LIST OF BATCHES TO CHECK IN GECBL"
^XMB(3.9,145945,2,467,0)="""RTN"",""GECSUSEL"",114,0)"
^XMB(3.9,145945,2,468,0)=" S I=1,GECBL=""^"" F  S GECB=$T(GEC2P41B+I) Q:GECB[""GEC2P41B_END""  S GECBL($P(GECB,"";"",3))="""",I=I+1"
^XMB(3.9,145945,2,469,0)="""RTN"",""GECSUSEL"",115,0)"
^XMB(3.9,145945,2,470,0)=" D:$D(GECBL(GECS(""BATCH"")))"
^XMB(3.9,145945,2,471,0)="""RTN"",""GECSUSEL"",116,0)"
^XMB(3.9,145945,2,472,0)="  . D NOW^%DTC"
^XMB(3.9,145945,2,473,0)="""RTN"",""GECSUSEL"",117,0)"
^XMB(3.9,145945,2,474,0)="  . W !!,""**************"""
^XMB(3.9,145945,2,475,0)="""RTN"",""GECSUSEL"",118,0)"
^XMB(3.9,145945,2,476,0)="  . W !,""NOTE: This batch type is scheduled to be disabled in May 2026."""
^XMB(3.9,145945,2,477,0)="""RTN"",""GECSUSEL"",119,0)"
^XMB(3.9,145945,2,478,0)="  . W !,""Please enter a ServiceNOW ticket for 'VistA - Generic Code Sheet'"""
^XMB(3.9,145945,2,479,0)="""RTN"",""GECSUSEL"",120,0)"
^XMB(3.9,145945,2,480,0)="  . W !,""if there are questions/concerns."""
^XMB(3.9,145945,2,481,0)="""RTN"",""GECSUSEL"",121,0)"
^XMB(3.9,145945,2,482,0)="  . W !,""**************"""
^XMB(3.9,145945,2,483,0)="""RTN"",""GECSUSEL"",122,0)"
^XMB(3.9,145945,2,484,0)="  . ;RECORD IN XTMP"
^XMB(3.9,145945,2,485,0)="""RTN"",""GECSUSEL"",123,0)"
^XMB(3.9,145945,2,486,0)="  . S ^XTMP(""GEC2P41"",0)=$$FMADD^XLFDT(DT,90)_""^""_DT_""^GEC*2*41 - batch type usage"""
^XMB(3.9,145945,2,487,0)="""RTN"",""GECSUSEL"",124,0)"
^XMB(3.9,145945,2,488,0)="  . S ^XTMP(""GEC2P41"",%)=GECS(""BATCH"")_""^""_DUZ"
^XMB(3.9,145945,2,489,0)="""RTN"",""GECSUSEL"",125,0)"
^XMB(3.9,145945,2,490,0)="  . ;SEND MSG"
^XMB(3.9,145945,2,491,0)="""RTN"",""GECSUSEL"",126,0)"
^XMB(3.9,145945,2,492,0)="  . S XMY(.5)="""",XMY(DUZ)="""",XMY(""FiscalMgmt@domain.ext"")="""""
^XMB(3.9,145945,2,493,0)="""RTN"",""GECSUSEL"",127,0)"
^XMB(3.9,145945,2,494,0)="  . S XMSUB=""GEC*2*41 Usage Notification"",XMTEXT=""GECMSG"""
^XMB(3.9,145945,2,495,0)="""RTN"",""GECSUSEL"",128,0)"
^XMB(3.9,145945,2,496,0)="  . S GECMSG(1)=""GEC*2*41 Site ""_$G(DUZ(2))_"" had unexpected usage of GEC Batch Type ""_GECS(""BATCH"")"
^XMB(3.9,145945,2,497,0)="""RTN"",""GECSUSEL"",129,0)"
^XMB(3.9,145945,2,498,0)="  . D SENDMSG^XMXAPI(DUZ,XMSUB,XMTEXT,.XMY)"
^XMB(3.9,145945,2,499,0)="""RTN"",""GECSUSEL"",130,0)"
^XMB(3.9,145945,2,500,0)=" Q"
^XMB(3.9,145945,2,501,0)="""RTN"",""GECSUSEL"",131,0)"
^XMB(3.9,145945,2,502,0)="GEC2P41B ;;$Text list of batch types to be discontinued (future patch) for SSNR"
^XMB(3.9,145945,2,503,0)="""RTN"",""GECSUSEL"",132,0)"
^XMB(3.9,145945,2,504,0)=" ;;A1BO CENSUS ROLL-UP"
^XMB(3.9,145945,2,505,0)="""RTN"",""GECSUSEL"",133,0)"
^XMB(3.9,145945,2,506,0)=" ;;CONSULTING/ATTENDING"
^XMB(3.9,145945,2,507,0)="""RTN"",""GECSUSEL"",134,0)"
^XMB(3.9,145945,2,508,0)=" ;;DDCSS - MENTAL HEALTH"
^XMB(3.9,145945,2,509,0)="""RTN"",""GECSUSEL"",135,0)"
^XMB(3.9,145945,2,510,0)=" ;;HOSPITAL BASED HOME CARE- GECO"
^XMB(3.9,145945,2,511,0)="""RTN"",""GECSUSEL"",136,0)"
^XMB(3.9,145945,2,512,0)=" ;;VOLUNTARY"
^XMB(3.9,145945,2,513,0)="""RTN"",""GECSUSEL"",137,0)"
^XMB(3.9,145945,2,514,0)=" ;;GEC2P41B_END"
^XMB(3.9,145945,2,515,0)="""RTN"",""GECSUSEL"",138,0)"
^XMB(3.9,145945,2,516,0)=" Q"
