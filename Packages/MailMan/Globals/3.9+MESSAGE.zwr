^XMB(3.9,145958,2,1708,0)=" Q"
^XMB(3.9,145958,2,1709,0)="""RTN"",""ORWPT"",34,0)"
^XMB(3.9,145958,2,1710,0)="IDINFO(REC,DFN) ; Return identifying information for a patient"
^XMB(3.9,145958,2,1711,0)="""RTN"",""ORWPT"",35,0)"
^XMB(3.9,145958,2,1712,0)=" ; PID^DOB^SEX^VET^SC%^WARD^RM-BED^NAME"
^XMB(3.9,145958,2,1713,0)="""RTN"",""ORWPT"",36,0)"
^XMB(3.9,145958,2,1714,0)=" N X0,X1,X101,X3,XV,X24,VADM,VAEL,ATT  ; name/dob/sex/ssn, ward, room-bed, sc%, vet, SIGI, Attending Physician"
^XMB(3.9,145958,2,1715,0)="""RTN"",""ORWPT"",37,0)"
^XMB(3.9,145958,2,1716,0)=" D ELIG^VADPT S XV=$S(VAEL(4):""Y"",1:""N""),X3=$P(VAEL(3),""^"",2)"
^XMB(3.9,145958,2,1717,0)="""RTN"",""ORWPT"",38,0)"
^XMB(3.9,145958,2,1718,0)=" D DEM^VADPT S X24=$P($G(VADM(14,5)),""^"")"
^XMB(3.9,145958,2,1719,0)="""RTN"",""ORWPT"",39,0)"
^XMB(3.9,145958,2,1720,0)=" S ATT=$P($G(^DPT(DFN,.1041)),""^"") I ATT]"""" S ATT=$$GET1^DIQ(200,ATT,.01)"
^XMB(3.9,145958,2,1721,0)="""RTN"",""ORWPT"",40,0)"
^XMB(3.9,145958,2,1722,0)=" S X0=$G(^DPT(DFN,0)),X1=$G(^(.1)),X101=$G(^(.101))"
^XMB(3.9,145958,2,1723,0)="""RTN"",""ORWPT"",41,0)"
^XMB(3.9,145958,2,1724,0)=" S REC=$$SSN^DPTLK1(DFN)_U_$$DOB^DPTLK1(DFN,2)_U_$P(X0,U,2)_U_XV_U_X3_U_$P(X1,U)_U_$P(X101,U)_U_$P(X0,U)_U_X24_U_ATT ;DG249"
^XMB(3.9,145958,2,1725,0)="""RTN"",""ORWPT"",42,0)"
^XMB(3.9,145958,2,1726,0)=" Q"
^XMB(3.9,145958,2,1727,0)="""RTN"",""ORWPT"",43,0)"
^XMB(3.9,145958,2,1728,0)="PTINQ(REF,DFN) ; Return formatted pt inquiry report"
^XMB(3.9,145958,2,1729,0)="""RTN"",""ORWPT"",44,0)"
^XMB(3.9,145958,2,1730,0)=" S REF=$NA(^TMP(""ORDATA"",$J,1)) K @REF"
^XMB(3.9,145958,2,1731,0)="""RTN"",""ORWPT"",45,0)"
^XMB(3.9,145958,2,1732,0)=" I '+$G(DFN) D SETITEM^ORWRP(.REF,""Invalid patient number."") Q "
^XMB(3.9,145958,2,1733,0)="""RTN"",""ORWPT"",46,0)"
^XMB(3.9,145958,2,1734,0)=" I '$D(^DPT(DFN)) D SETITEM^ORWRP(.REF,""Patient not found on local system."") Q "
^XMB(3.9,145958,2,1735,0)="""RTN"",""ORWPT"",47,0)"
^XMB(3.9,145958,2,1736,0)=" D DGINQ^ORCXPND1(DFN)"
^XMB(3.9,145958,2,1737,0)="""RTN"",""ORWPT"",48,0)"
^XMB(3.9,145958,2,1738,0)=" ; insert persian gulf indicator *628 ajb"
^XMB(3.9,145958,2,1739,0)="""RTN"",""ORWPT"",49,0)"
^XMB(3.9,145958,2,1740,0)=" N DATA,TDATA M TDATA=@REF K @REF"
^XMB(3.9,145958,2,1741,0)="""RTN"",""ORWPT"",50,0)"
^XMB(3.9,145958,2,1742,0)=" N X,Y S (X,Y)=0 F  S X=$O(TDATA(X)) Q:'X  D  ; hard code to insert data after 'Preferred Language' :("
^XMB(3.9,145958,2,1743,0)="""RTN"",""ORWPT"",51,0)"
^XMB(3.9,145958,2,1744,0)=" . S Y=Y+1,DATA(Y)=TDATA(X)"
^XMB(3.9,145958,2,1745,0)="""RTN"",""ORWPT"",52,0)"
^XMB(3.9,145958,2,1746,0)=" . I DATA(Y)[""Preferred Language"" S Y=Y+1,DATA(Y)="""",Y=Y+1,DATA(Y)=$$PGULF(DFN)"
^XMB(3.9,145958,2,1747,0)="""RTN"",""ORWPT"",53,0)"
^XMB(3.9,145958,2,1748,0)=" M ^TMP(""ORDATA"",$J,1)=DATA"
^XMB(3.9,145958,2,1749,0)="""RTN"",""ORWPT"",54,0)"
^XMB(3.9,145958,2,1750,0)=" Q"
^XMB(3.9,145958,2,1751,0)="""RTN"",""ORWPT"",55,0)"
^XMB(3.9,145958,2,1752,0)="PGULF(DFN) ; persian gulf indicator"
^XMB(3.9,145958,2,1753,0)="""RTN"",""ORWPT"",56,0)"
^XMB(3.9,145958,2,1754,0)=" N OUT,VAERR,VAROOT,X,Y"
^XMB(3.9,145958,2,1755,0)="""RTN"",""ORWPT"",57,0)"
^XMB(3.9,145958,2,1756,0)=" I '$D(^TMP($J,""SVC"",DFN)) S VAROOT=""^TMP($J,""""SVC"""",DFN)"" D SVC^VADPT,KVAR^VADPT"
^XMB(3.9,145958,2,1757,0)="""RTN"",""ORWPT"",58,0)"
^XMB(3.9,145958,2,1758,0)=" S OUT=$G(^TMP($J,""SVC"",DFN,16)),OUT=""Persian Gulf Indicator:  ""_$S(OUT="""":""<no data>"",1:$P(OUT,U,2))"
^XMB(3.9,145958,2,1759,0)="""RTN"",""ORWPT"",59,0)"
^XMB(3.9,145958,2,1760,0)=" Q OUT"
^XMB(3.9,145958,2,1761,0)="""RTN"",""ORWPT"",60,0)"
^XMB(3.9,145958,2,1762,0)="SCDIS(LST,DFN) ; Return service connected % and rated disabilities"
^XMB(3.9,145958,2,1763,0)="""RTN"",""ORWPT"",61,0)"
^XMB(3.9,145958,2,1764,0)=" N VAEL,VAERR,I,ILST,DIS,SC,X"
^XMB(3.9,145958,2,1765,0)="""RTN"",""ORWPT"",62,0)"
^XMB(3.9,145958,2,1766,0)=" D ELIG^VADPT"
^XMB(3.9,145958,2,1767,0)="""RTN"",""ORWPT"",63,0)"
^XMB(3.9,145958,2,1768,0)=" S LST(1)=""Service Connected: ""_$S(+VAEL(3):$P(VAEL(3),U,2)_""%"",1:""NO"")"
^XMB(3.9,145958,2,1769,0)="""RTN"",""ORWPT"",64,0)"
^XMB(3.9,145958,2,1770,0)=" I 'VAEL(4),'$P($G(^DG(391,+VAEL(6),0)),U,2) S LST(2)=""NOT A VETERAN."" Q"
^XMB(3.9,145958,2,1771,0)="""RTN"",""ORWPT"",65,0)"
^XMB(3.9,145958,2,1772,0)=" S I=0,ILST=1 F  S I=$O(^DPT(DFN,.372,I)) Q:'I  S X=^(I,0) D"
^XMB(3.9,145958,2,1773,0)="""RTN"",""ORWPT"",66,0)"
^XMB(3.9,145958,2,1774,0)=" . S DIS=$P($G(^DIC(31,+X,0)),U) Q:DIS="""""
^XMB(3.9,145958,2,1775,0)="""RTN"",""ORWPT"",67,0)"
^XMB(3.9,145958,2,1776,0)=" . S SC=$S($P(X,U,3):""SC"",$P(X,U,3)']"""":""not specified"",1:""NSC"")"
^XMB(3.9,145958,2,1777,0)="""RTN"",""ORWPT"",68,0)"
^XMB(3.9,145958,2,1778,0)=" . S ILST=ILST+1,LST(ILST)=DIS_"" (""_$P(X,U,2)_""% ""_SC_"")"""
^XMB(3.9,145958,2,1779,0)="""RTN"",""ORWPT"",69,0)"
^XMB(3.9,145958,2,1780,0)=" I ILST=1 S LST(2)=""Rated Disabilities: NONE STATED"""
^XMB(3.9,145958,2,1781,0)="""RTN"",""ORWPT"",70,0)"
^XMB(3.9,145958,2,1782,0)=" Q"
^XMB(3.9,145958,2,1783,0)="""RTN"",""ORWPT"",71,0)"
^XMB(3.9,145958,2,1784,0)="SHOW ; temporary - show patient inquiry screen"
^XMB(3.9,145958,2,1785,0)="""RTN"",""ORWPT"",72,0)"
^XMB(3.9,145958,2,1786,0)=" N I,Y,DIC S DIC=2,DIC(0)=""AEMQ"" D ^DIC Q:'Y"
^XMB(3.9,145958,2,1787,0)="""RTN"",""ORWPT"",73,0)"
^XMB(3.9,145958,2,1788,0)=" K ^TMP(""ORDATA"",$J,1)"
^XMB(3.9,145958,2,1789,0)="""RTN"",""ORWPT"",74,0)"
^XMB(3.9,145958,2,1790,0)=" D DGINQ^ORCXPND1(+Y)"
^XMB(3.9,145958,2,1791,0)="""RTN"",""ORWPT"",75,0)"
^XMB(3.9,145958,2,1792,0)=" S I=0 F  S I=$O(^TMP(""ORDATA"",$J,1,I)) Q:'I  W !,^(I)"
^XMB(3.9,145958,2,1793,0)="""RTN"",""ORWPT"",76,0)"
^XMB(3.9,145958,2,1794,0)=" K ^TMP(""ORDATA"",$J,1)"
^XMB(3.9,145958,2,1795,0)="""RTN"",""ORWPT"",77,0)"
^XMB(3.9,145958,2,1796,0)=" Q"
^XMB(3.9,145958,2,1797,0)="""RTN"",""ORWPT"",78,0)"
^XMB(3.9,145958,2,1798,0)="SELCHK(REC,DFN) ; Check for sensitive pt"
