^XMB(3.9,145944,2,1246,0)="WBIL ; - Write bill data."
^XMB(3.9,145944,2,1247,0)="""RTN"",""IBJDF42"",107,0)"
^XMB(3.9,145944,2,1248,0)=" W ! W:'$D(IBFLG(IBCAT)) $E(IBCT(IBCAT),1,11) W ?13,IB0   ;IB*2.0*618 - Limit length to 11 chars"
^XMB(3.9,145944,2,1249,0)="""RTN"",""IBJDF42"",108,0)"
^XMB(3.9,145944,2,1250,0)=" W:$P(IBN,""^"",6) ?25,$J(""(""_$P(IBN,""^"",6)_"")"",4)"
^XMB(3.9,145944,2,1251,0)="""RTN"",""IBJDF42"",109,0)"
^XMB(3.9,145944,2,1252,0)=" W ?30,$$DAT1^IBOUTL(+IBN)"
^XMB(3.9,145944,2,1253,0)="""RTN"",""IBJDF42"",110,0)"
^XMB(3.9,145944,2,1254,0)=" W ?39,$J($FN($P(IBN,U,2),"","",2),10),?50,$J($FN($P(IBN,U,3),"","",2),10)"
^XMB(3.9,145944,2,1255,0)="""RTN"",""IBJDF42"",111,0)"
^XMB(3.9,145944,2,1256,0)=" W ?61,$J($FN($P(IBN,U,4),"","",2),9),?71,$J($FN($P(IBN,U,5),"","",2),9)"
^XMB(3.9,145944,2,1257,0)="""RTN"",""IBJDF42"",112,0)"
^XMB(3.9,145944,2,1258,0)=" I ""SB""[IBSTA,$P(IBN,U,7)]"""" W ?82,IBSUS($P(IBN,U,7))"
^XMB(3.9,145944,2,1259,0)="""RTN"",""IBJDF42"",113,0)"
^XMB(3.9,145944,2,1260,0)=" S $P(IBTOT,""^"")=$P(IBTOT,""^"")+$P(IBN,U,2)"
^XMB(3.9,145944,2,1261,0)="""RTN"",""IBJDF42"",114,0)"
^XMB(3.9,145944,2,1262,0)=" S $P(IBTOT,""^"",2)=$P(IBTOT,""^"",2)+$P(IBN,U,3)"
^XMB(3.9,145944,2,1263,0)="""RTN"",""IBJDF42"",115,0)"
^XMB(3.9,145944,2,1264,0)=" S $P(IBTOT,""^"",3)=$P(IBTOT,""^"",3)+$P(IBN,U,4)"
^XMB(3.9,145944,2,1265,0)="""RTN"",""IBJDF42"",116,0)"
^XMB(3.9,145944,2,1266,0)=" S $P(IBTOT,""^"",4)=$P(IBTOT,""^"",4)+$P(IBN,U,5)"
^XMB(3.9,145944,2,1267,0)="""RTN"",""IBJDF42"",117,0)"
