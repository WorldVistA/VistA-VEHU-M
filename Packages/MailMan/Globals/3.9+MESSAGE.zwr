^XMB(3.9,145956,2,607,0)="""RTN"",""TIUALRT"",155,0)"
^XMB(3.9,145956,2,608,0)=" N TIUQUIK,TIUDA,TIUPRM0,TIUPRM1,TIUPRM3 S TIUQUIK=1 K XQAKILL"
^XMB(3.9,145956,2,609,0)="""RTN"",""TIUALRT"",156,0)"
^XMB(3.9,145956,2,610,0)=" S TIUDA=$P(XQADATA,U),XQAKILL=1"
^XMB(3.9,145956,2,611,0)="""RTN"",""TIUALRT"",157,0)"
^XMB(3.9,145956,2,612,0)=" I '$D(^TIU(8925,+TIUDA,0)) D ADDENDEL(TIUDA) Q"
^XMB(3.9,145956,2,613,0)="""RTN"",""TIUALRT"",158,0)"
^XMB(3.9,145956,2,614,0)=" W !!,""A NEW Addendum has been added to your document..."",!"
^XMB(3.9,145956,2,615,0)="""RTN"",""TIUALRT"",159,0)"
^XMB(3.9,145956,2,616,0)=" W:$L($P($G(XQX),U,3)) !,$P($G(XQX),U,3),!"
^XMB(3.9,145956,2,617,0)="""RTN"",""TIUALRT"",160,0)"
^XMB(3.9,145956,2,618,0)=" I '+$$READ^TIUU(""YAO"",""Do you wish to Browse the Addendum now? "",""NO"") Q"
