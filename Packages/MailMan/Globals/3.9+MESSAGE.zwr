^XMB(3.9,145989,2,693,0)="""RTN"",""PSOASAP0"",204,0)"
^XMB(3.9,145989,2,694,0)=" . S RX08=$$GET1^DIQ(52,+$G(RXIEN),21,""I"")\1"
^XMB(3.9,145989,2,695,0)="""RTN"",""PSOASAP0"",205,0)"
