^XMB(3.9,145956,2,2282,0)=" N I"
^XMB(3.9,145956,2,2283,0)="""RTN"",""TIUTIUS"",199,0)"
^XMB(3.9,145956,2,2284,0)=" I '$D(AUMTMSPT) D TMSPT^ORQPTQ1(.AUMTMSPT,DFN)"
