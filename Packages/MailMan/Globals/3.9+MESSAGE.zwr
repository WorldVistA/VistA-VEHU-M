^XMB(3.9,145986,2,3438,0)="CR ;read for display"
^XMB(3.9,145986,2,3439,0)="""RTN"",""FBPAY671"",104,0)"
^XMB(3.9,145986,2,3440,0)=" Q:'FBPG  S DIR(0)=""E"" W ! D ^DIR K DIR S:$D(DUOUT)!($D(DTOUT)) FBOUT=1"
^XMB(3.9,145986,2,3441,0)="""RTN"",""FBPAY671"",105,0)"
