^XMB(3.9,145986,2,595,0)="""QUES"",""XPZ1"",""??"")"
^XMB(3.9,145986,2,596,0)="^D OPT^XPDH"
^XMB(3.9,145986,2,597,0)="""QUES"",""XPZ1"",""A"")"
^XMB(3.9,145986,2,598,0)="Want to DISABLE Scheduled Options, Menu Options, and Protocols"
^XMB(3.9,145986,2,599,0)="""QUES"",""XPZ1"",""B"")"
