^XMB(3.9,145946,2,6102,0)=" ;         R - Report"
^XMB(3.9,145946,2,6103,0)="""RTN"",""IBCOPP"",24,0)"
^XMB(3.9,145946,2,6104,0)=" ; IBAPA=  0 - List Insurance Plans by Insurance Company"
^XMB(3.9,145946,2,6105,0)="""RTN"",""IBCOPP"",25,0)"
^XMB(3.9,145946,2,6106,0)=" ;         1 - List Insurance Plans by Insurance Company with Subscriber"
