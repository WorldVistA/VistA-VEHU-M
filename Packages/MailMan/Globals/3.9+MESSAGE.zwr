^XMB(3.9,145942,2,239,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145942,2,240,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145942,2,241,0)="""QUES"",""XPZ2"",""B"")"
