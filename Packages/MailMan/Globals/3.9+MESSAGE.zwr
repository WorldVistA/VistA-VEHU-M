^XMB(3.9,145980,2,3827,0)="""RTN"",""SDES2CANCELAPPT2"",70,0)"
^XMB(3.9,145980,2,3828,0)=" ;"
^XMB(3.9,145980,2,3829,0)="""RTN"",""SDES2CANCELAPPT2"",71,0)"
^XMB(3.9,145980,2,3830,0)="VALNOTE(NOTE,CANCELHASH) ;"
^XMB(3.9,145980,2,3831,0)="""RTN"",""SDES2CANCELAPPT2"",72,0)"
^XMB(3.9,145980,2,3832,0)=" N SDECJ"
^XMB(3.9,145980,2,3833,0)="""RTN"",""SDES2CANCELAPPT2"",73,0)"
^XMB(3.9,145980,2,3834,0)=" S NOTE=$$CTRL^XMXUTIL1(NOTE)"
^XMB(3.9,145980,2,3835,0)="""RTN"",""SDES2CANCELAPPT2"",74,0)"
^XMB(3.9,145980,2,3836,0)=" S NOTE=$TR($G(NOTE),""^"","" "") ;"
^XMB(3.9,145980,2,3837,0)="""RTN"",""SDES2CANCELAPPT2"",75,0)"
^XMB(3.9,145980,2,3838,0)=" S CANCELHASH=$$CTRL^XMXUTIL1(CANCELHASH)"
^XMB(3.9,145980,2,3839,0)="""RTN"",""SDES2CANCELAPPT2"",76,0)"
