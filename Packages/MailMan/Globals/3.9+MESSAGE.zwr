^XMB(3.9,145960,2,336,0)=" ;        - Patch 281"
^XMB(3.9,145960,2,337,0)="""RTN"",""MAGGTU4T"",42,0)"
^XMB(3.9,145960,2,338,0)=" ;  Patch 320 removed support for"
^XMB(3.9,145960,2,339,0)="""RTN"",""MAGGTU4T"",43,0)"
^XMB(3.9,145960,2,340,0)=" ;        - Patch 242"
^XMB(3.9,145960,2,341,0)="""RTN"",""MAGGTU4T"",44,0)"
^XMB(3.9,145960,2,342,0)=" ;  Patch 292 removed support for"
