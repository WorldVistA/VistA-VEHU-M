^XMB(3.9,145983,2,1602,0)=" S EXCEL=$$ASKEXCEL^RCRPRPU() I EXCEL<0 Q"
^XMB(3.9,145983,2,1603,0)="""RTN"",""RCRPTLR"",15,0)"
^XMB(3.9,145983,2,1604,0)=" I EXCEL D EXCMSG^RCTCSJR    ; Display Excel display message I EXCEL"
^XMB(3.9,145983,2,1605,0)="""RTN"",""RCRPTLR"",16,0)"
^XMB(3.9,145983,2,1606,0)=" I 'EXCEL W !!,""This report requires 132 characters"",!"
^XMB(3.9,145983,2,1607,0)="""RTN"",""RCRPTLR"",17,0)"
^XMB(3.9,145983,2,1608,0)=" ; ask for device"
^XMB(3.9,145983,2,1609,0)="""RTN"",""RCRPTLR"",18,0)"
^XMB(3.9,145983,2,1610,0)=" K IOP,IO(""Q"")"
^XMB(3.9,145983,2,1611,0)="""RTN"",""RCRPTLR"",19,0)"
^XMB(3.9,145983,2,1612,0)=" S %ZIS=""MQ"",%ZIS(""B"")="""",POP=0 D ^%ZIS Q:POP"
^XMB(3.9,145983,2,1613,0)="""RTN"",""RCRPTLR"",20,0)"
^XMB(3.9,145983,2,1614,0)=" I $D(IO(""Q"")) D  Q  ; queued report"
^XMB(3.9,145983,2,1615,0)="""RTN"",""RCRPTLR"",21,0)"
^XMB(3.9,145983,2,1616,0)=" .S ZTDESC=""Repayment Plan Term Length Exceeded Report"",ZTRTN=""COMPILE^RCRPTLR"""
^XMB(3.9,145983,2,1617,0)="""RTN"",""RCRPTLR"",22,0)"
^XMB(3.9,145983,2,1618,0)=" .S ZTSAVE(""EXCEL"")="""",ZTSAVE(""ZTREQ"")=""@"""
^XMB(3.9,145983,2,1619,0)="""RTN"",""RCRPTLR"",23,0)"
^XMB(3.9,145983,2,1620,0)=" .D ^%ZTLOAD,HOME^%ZIS"
^XMB(3.9,145983,2,1621,0)="""RTN"",""RCRPTLR"",24,0)"
^XMB(3.9,145983,2,1622,0)=" .I $G(ZTSK) W !!,""Report compilation has started with task# "",ZTSK,""."",! D PAUSE^RCRPRPU"
^XMB(3.9,145983,2,1623,0)="""RTN"",""RCRPTLR"",25,0)"
^XMB(3.9,145983,2,1624,0)=" .Q"
^XMB(3.9,145983,2,1625,0)="""RTN"",""RCRPTLR"",26,0)"
^XMB(3.9,145983,2,1626,0)=" D COMPILE"
^XMB(3.9,145983,2,1627,0)="""RTN"",""RCRPTLR"",27,0)"
^XMB(3.9,145983,2,1628,0)=" ;"
^XMB(3.9,145983,2,1629,0)="""RTN"",""RCRPTLR"",28,0)"
^XMB(3.9,145983,2,1630,0)=" Q"
^XMB(3.9,145983,2,1631,0)="""RTN"",""RCRPTLR"",29,0)"
^XMB(3.9,145983,2,1632,0)=" ;"
^XMB(3.9,145983,2,1633,0)="""RTN"",""RCRPTLR"",30,0)"
^XMB(3.9,145983,2,1634,0)="COMPILE ; compile report"
^XMB(3.9,145983,2,1635,0)="""RTN"",""RCRPTLR"",31,0)"
^XMB(3.9,145983,2,1636,0)=" N CNT,DEBTOR,N0,NAME,RPIEN,RPPID,SSN,TEDT,Z"
^XMB(3.9,145983,2,1637,0)="""RTN"",""RCRPTLR"",32,0)"
^XMB(3.9,145983,2,1638,0)=" S (CNT,TEDT)=0 F  S TEDT=$O(^RCRP(340.5,""C"",TEDT)) Q:'TEDT  D"
^XMB(3.9,145983,2,1639,0)="""RTN"",""RCRPTLR"",33,0)"
^XMB(3.9,145983,2,1640,0)=" .S RPIEN=0 F  S RPIEN=$O(^RCRP(340.5,""C"",TEDT,RPIEN)) Q:'RPIEN  D"
^XMB(3.9,145983,2,1641,0)="""RTN"",""RCRPTLR"",34,0)"
^XMB(3.9,145983,2,1642,0)=" ..S N0=^RCRP(340.5,RPIEN,0)              ; 0-node in file 340.5"
^XMB(3.9,145983,2,1643,0)="""RTN"",""RCRPTLR"",35,0)"
^XMB(3.9,145983,2,1644,0)=" ..I ""^6^7^8^""[(U_$P(N0,U,7)_U) Q         ; skip plans in Closed, Paid in Full, or Terminated status"
^XMB(3.9,145983,2,1645,0)="""RTN"",""RCRPTLR"",36,0)"
^XMB(3.9,145983,2,1646,0)=" ..S DEBTOR=$P(N0,U,2)                    ; pointer to file 340"
^XMB(3.9,145983,2,1647,0)="""RTN"",""RCRPTLR"",37,0)"
^XMB(3.9,145983,2,1648,0)=" ..S NAME=$$NAM^RCFN01(DEBTOR) Q:NAME=""""  ; debtor name"
^XMB(3.9,145983,2,1649,0)="""RTN"",""RCRPTLR"",38,0)"
^XMB(3.9,145983,2,1650,0)=" ..S SSN=$$SSN^RCFN01(DEBTOR) Q:SSN'>0    ; debtor SSN"
^XMB(3.9,145983,2,1651,0)="""RTN"",""RCRPTLR"",39,0)"
^XMB(3.9,145983,2,1652,0)=" ..S RPPID=$P(N0,U)                       ; RPP ID"
^XMB(3.9,145983,2,1653,0)="""RTN"",""RCRPTLR"",40,0)"
^XMB(3.9,145983,2,1654,0)=" ..; each entry is: ^TMP(""RCRPTLR"",$J,n) = RPP ID ^ name ^ ssn ^ term length (remaining # of payments) ^ term limit exceeded date"
^XMB(3.9,145983,2,1655,0)="""RTN"",""RCRPTLR"",41,0)"
^XMB(3.9,145983,2,1656,0)=" ..S CNT=CNT+1,^TMP(""RCRPTLR"",$J,CNT)=RPPID_U_NAME_U_SSN_U_$$REMPMNTS^RCRPU3(RPIEN,+$P(N0,U,6))_U_TEDT  ; PRCA*4.5*423"
^XMB(3.9,145983,2,1657,0)="""RTN"",""RCRPTLR"",42,0)"
^XMB(3.9,145983,2,1658,0)=" ..S Z=$S(SORT=""N"":NAME,SORT=""S"":SSN,1:RPPID) Q:Z="""""
^XMB(3.9,145983,2,1659,0)="""RTN"",""RCRPTLR"",43,0)"
^XMB(3.9,145983,2,1660,0)=" ..S Z="" ""_Z    ;Add space to force correct sort order"
^XMB(3.9,145983,2,1661,0)="""RTN"",""RCRPTLR"",44,0)"
^XMB(3.9,145983,2,1662,0)=" ..S ^TMP(""RCRPTLR"",$J,""IDX"",Z,CNT)="""""
^XMB(3.9,145983,2,1663,0)="""RTN"",""RCRPTLR"",45,0)"
^XMB(3.9,145983,2,1664,0)=" ..Q"
^XMB(3.9,145983,2,1665,0)="""RTN"",""RCRPTLR"",46,0)"
^XMB(3.9,145983,2,1666,0)=" .Q"
^XMB(3.9,145983,2,1667,0)="""RTN"",""RCRPTLR"",47,0)"
^XMB(3.9,145983,2,1668,0)=" D PRINT"
^XMB(3.9,145983,2,1669,0)="""RTN"",""RCRPTLR"",48,0)"
^XMB(3.9,145983,2,1670,0)=" K ^TMP(""RCRPTLR"",$J)"
^XMB(3.9,145983,2,1671,0)="""RTN"",""RCRPTLR"",49,0)"
^XMB(3.9,145983,2,1672,0)=" Q"
^XMB(3.9,145983,2,1673,0)="""RTN"",""RCRPTLR"",50,0)"
^XMB(3.9,145983,2,1674,0)=" ;"
^XMB(3.9,145983,2,1675,0)="""RTN"",""RCRPTLR"",51,0)"
^XMB(3.9,145983,2,1676,0)="PRINT ; print report"
^XMB(3.9,145983,2,1677,0)="""RTN"",""RCRPTLR"",52,0)"
^XMB(3.9,145983,2,1678,0)=" N CNT,DATA,EXTDT,LN,PAGE,Z"
^XMB(3.9,145983,2,1679,0)="""RTN"",""RCRPTLR"",53,0)"
^XMB(3.9,145983,2,1680,0)=" U IO"
^XMB(3.9,145983,2,1681,0)="""RTN"",""RCRPTLR"",54,0)"
^XMB(3.9,145983,2,1682,0)=" S PAGE=0"
^XMB(3.9,145983,2,1683,0)="""RTN"",""RCRPTLR"",55,0)"
^XMB(3.9,145983,2,1684,0)=" S EXTDT=$$FMTE^XLFDT(DT)"
^XMB(3.9,145983,2,1685,0)="""RTN"",""RCRPTLR"",56,0)"
^XMB(3.9,145983,2,1686,0)=" I EXCEL D"
^XMB(3.9,145983,2,1687,0)="""RTN"",""RCRPTLR"",57,0)"
^XMB(3.9,145983,2,1688,0)=" .W !,""Repayment Plan Term Length Exceeded Report^"",EXTDT"
^XMB(3.9,145983,2,1689,0)="""RTN"",""RCRPTLR"",58,0)"
^XMB(3.9,145983,2,1690,0)=" .W !,""Name^SSN^RPP ID^Term Length^Term Limit Exceeded Date"""
^XMB(3.9,145983,2,1691,0)="""RTN"",""RCRPTLR"",59,0)"
^XMB(3.9,145983,2,1692,0)=" .Q"
^XMB(3.9,145983,2,1693,0)="""RTN"",""RCRPTLR"",60,0)"
^XMB(3.9,145983,2,1694,0)=" I 'EXCEL D"
^XMB(3.9,145983,2,1695,0)="""RTN"",""RCRPTLR"",61,0)"
^XMB(3.9,145983,2,1696,0)=" .I $E(IOST,1,2)[""C-"",'$D(ZTQUEUED) W @IOF"
^XMB(3.9,145983,2,1697,0)="""RTN"",""RCRPTLR"",62,0)"
^XMB(3.9,145983,2,1698,0)=" .D HDR"
^XMB(3.9,145983,2,1699,0)="""RTN"",""RCRPTLR"",63,0)"
^XMB(3.9,145983,2,1700,0)=" .Q"
^XMB(3.9,145983,2,1701,0)="""RTN"",""RCRPTLR"",64,0)"
^XMB(3.9,145983,2,1702,0)=" I '$D(^TMP(""RCRPTLR"",$J)) D  Q"
^XMB(3.9,145983,2,1703,0)="""RTN"",""RCRPTLR"",65,0)"
^XMB(3.9,145983,2,1704,0)=" .I EXCEL W !!,""No records found."" Q"
^XMB(3.9,145983,2,1705,0)="""RTN"",""RCRPTLR"",66,0)"
^XMB(3.9,145983,2,1706,0)=" .W !!,$$CJ^XLFSTR(""No records found."",80)"
^XMB(3.9,145983,2,1707,0)="""RTN"",""RCRPTLR"",67,0)"
^XMB(3.9,145983,2,1708,0)=" .Q"
^XMB(3.9,145983,2,1709,0)="""RTN"",""RCRPTLR"",68,0)"
^XMB(3.9,145983,2,1710,0)=" S Z="""" F  S Z=$O(^TMP(""RCRPTLR"",$J,""IDX"",Z)) Q:Z=""""  D"
^XMB(3.9,145983,2,1711,0)="""RTN"",""RCRPTLR"",69,0)"
^XMB(3.9,145983,2,1712,0)=" .S CNT=0 F  S CNT=$O(^TMP(""RCRPTLR"",$J,""IDX"",Z,CNT)) Q:'CNT  D"
^XMB(3.9,145983,2,1713,0)="""RTN"",""RCRPTLR"",70,0)"
^XMB(3.9,145983,2,1714,0)=" ..S DATA=^TMP(""RCRPTLR"",$J,CNT)"
^XMB(3.9,145983,2,1715,0)="""RTN"",""RCRPTLR"",71,0)"
^XMB(3.9,145983,2,1716,0)=" ..I EXCEL W !,$P(DATA,U,2),U,$P(DATA,U,3),U,$P(DATA,U),U,$P(DATA,U,4),U,$$FMTE^XLFDT($P(DATA,U,5),""5DZ"") Q"
^XMB(3.9,145983,2,1717,0)="""RTN"",""RCRPTLR"",72,0)"
^XMB(3.9,145983,2,1718,0)=" ..S LN=LN+1"
^XMB(3.9,145983,2,1719,0)="""RTN"",""RCRPTLR"",73,0)"
^XMB(3.9,145983,2,1720,0)=" ..W !,$E($P(DATA,U,2),1,26),?28,$P(DATA,U,3),?40,$P(DATA,U),?65,$P(DATA,U,4),?70,$$FMTE^XLFDT($P(DATA,U,5),""5DZ"")"
^XMB(3.9,145983,2,1721,0)="""RTN"",""RCRPTLR"",74,0)"
^XMB(3.9,145983,2,1722,0)=" ..I LN>(IOSL-3) D HDR"
^XMB(3.9,145983,2,1723,0)="""RTN"",""RCRPTLR"",75,0)"
