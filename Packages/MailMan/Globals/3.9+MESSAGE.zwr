^XMB(3.9,145957,2,668,0)=" I $P(GMRCORC,""|"")=""NW"" Q 1 ; no #'s to match on new order ; MKN GMRC*3.0*154 added GMRCCRNR"
^XMB(3.9,145957,2,669,0)="""RTN"",""GMRCIMSG"",189,0)"
^XMB(3.9,145957,2,670,0)=" N GMRCPDA,GMRCFDA,GMRCPSIT,GMRCFSIT,GMRCROL,GMRCOK"
