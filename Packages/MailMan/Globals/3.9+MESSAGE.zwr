^XMB(3.9,145978,2,225,0)="""QUES"",""XPZ1"",""M"")"
^XMB(3.9,145978,2,226,0)="D XPZ1^XPDIQ"
^XMB(3.9,145978,2,227,0)="""QUES"",""XPZ2"",0)"
^XMB(3.9,145978,2,228,0)="Y"
^XMB(3.9,145978,2,229,0)="""QUES"",""XPZ2"",""??"")"
^XMB(3.9,145978,2,230,0)="^D RTN^XPDH"
^XMB(3.9,145978,2,231,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145978,2,232,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145978,2,233,0)="""QUES"",""XPZ2"",""B"")"
^XMB(3.9,145978,2,234,0)="NO"
^XMB(3.9,145978,2,235,0)="""QUES"",""XPZ2"",""M"")"
^XMB(3.9,145978,2,236,0)="D XPZ2^XPDIQ"
^XMB(3.9,145978,2,237,0)="""RTN"")"
^XMB(3.9,145978,2,238,0)=1
^XMB(3.9,145978,2,239,0)="""RTN"",""DGSEC4"")"
^XMB(3.9,145978,2,240,0)="0^1^B52433846"
^XMB(3.9,145978,2,241,0)="""RTN"",""DGSEC4"",1,0)"
^XMB(3.9,145978,2,242,0)="DGSEC4 ;ALB/MM,JAP,LAB,ATG/JPN,ISL/DKA - Utilities for record access & sensitive record processing ;July 6, 2020@21:55"
^XMB(3.9,145978,2,243,0)="""RTN"",""DGSEC4"",2,0)"
^XMB(3.9,145978,2,244,0)=" ;;5.3;Registration;**249,281,391,471,684,699,964,1130**;Aug 13, 1993;Build 0"
^XMB(3.9,145978,2,245,0)="""RTN"",""DGSEC4"",3,0)"
^XMB(3.9,145978,2,246,0)=" ;Per VHA Directive 6402, this routine should not be modified."
^XMB(3.9,145978,2,247,0)="""RTN"",""DGSEC4"",4,0)"
^XMB(3.9,145978,2,248,0)=" ;"
^XMB(3.9,145978,2,249,0)="""RTN"",""DGSEC4"",5,0)"
^XMB(3.9,145978,2,250,0)=" ;Line tags OWNREC & SENS moved from DGSEC in DG*5.3*249 when DGSEC "
^XMB(3.9,145978,2,251,0)="""RTN"",""DGSEC4"",6,0)"
^XMB(3.9,145978,2,252,0)=" ;reached the maximum routine size."
^XMB(3.9,145978,2,253,0)="""RTN"",""DGSEC4"",7,0)"
^XMB(3.9,145978,2,254,0)=" ;"
^XMB(3.9,145978,2,255,0)="""RTN"",""DGSEC4"",8,0)"
^XMB(3.9,145978,2,256,0)="PTSEC(RESULT,DFN,DGMSG,DGOPT) ;RPC/API entry point for patient sensitive & record access checks"
^XMB(3.9,145978,2,257,0)="""RTN"",""DGSEC4"",9,0)"
^XMB(3.9,145978,2,258,0)=" ;Output array (Required)"
^XMB(3.9,145978,2,259,0)="""RTN"",""DGSEC4"",10,0)"
^XMB(3.9,145978,2,260,0)=" ;    RESULT(1)= -1-RPC/API failed"
^XMB(3.9,145978,2,261,0)="""RTN"",""DGSEC4"",11,0)"
^XMB(3.9,145978,2,262,0)=" ;                  Required variable not defined"
^XMB(3.9,145978,2,263,0)="""RTN"",""DGSEC4"",12,0)"
^XMB(3.9,145978,2,264,0)=" ;                0-No display/action required"
^XMB(3.9,145978,2,265,0)="""RTN"",""DGSEC4"",13,0)"
^XMB(3.9,145978,2,266,0)=" ;                  Not accessing own, employee, or sensitive record"
^XMB(3.9,145978,2,267,0)="""RTN"",""DGSEC4"",14,0)"
^XMB(3.9,145978,2,268,0)=" ;                1-Display warning message"
^XMB(3.9,145978,2,269,0)="""RTN"",""DGSEC4"",15,0)"
^XMB(3.9,145978,2,270,0)=" ;                  Sensitive and DG SENSITIVITY key holder"
^XMB(3.9,145978,2,271,0)="""RTN"",""DGSEC4"",16,0)"
^XMB(3.9,145978,2,272,0)=" ;                  or Employee and DG SECURITY OFFICER key holder"
^XMB(3.9,145978,2,273,0)="""RTN"",""DGSEC4"",17,0)"
^XMB(3.9,145978,2,274,0)=" ;                2-Display warning message/require OK to continue"
^XMB(3.9,145978,2,275,0)="""RTN"",""DGSEC4"",18,0)"
^XMB(3.9,145978,2,276,0)=" ;                  Sensitive and not a DG SENSITIVITY key holder"
^XMB(3.9,145978,2,277,0)="""RTN"",""DGSEC4"",19,0)"
^XMB(3.9,145978,2,278,0)=" ;                  Employee and not a DG SECURITY OFFICER key holder"
^XMB(3.9,145978,2,279,0)="""RTN"",""DGSEC4"",20,0)"
^XMB(3.9,145978,2,280,0)=" ;                3-Access to record denied"
^XMB(3.9,145978,2,281,0)="""RTN"",""DGSEC4"",21,0)"
^XMB(3.9,145978,2,282,0)=" ;                  Accessing own record"
^XMB(3.9,145978,2,283,0)="""RTN"",""DGSEC4"",22,0)"
^XMB(3.9,145978,2,284,0)=" ;                4-Access to Patient (#2) file records denied"
^XMB(3.9,145978,2,285,0)="""RTN"",""DGSEC4"",23,0)"
^XMB(3.9,145978,2,286,0)=" ;                  SSN not defined"
^XMB(3.9,145978,2,287,0)="""RTN"",""DGSEC4"",24,0)"
^XMB(3.9,145978,2,288,0)=" ;   RESULT(2-10) = error or display messages"
^XMB(3.9,145978,2,289,0)="""RTN"",""DGSEC4"",25,0)"
^XMB(3.9,145978,2,290,0)=" ;"
^XMB(3.9,145978,2,291,0)="""RTN"",""DGSEC4"",26,0)"
^XMB(3.9,145978,2,292,0)=" ;Input parameters: DFN = Patient file entry (Required)"
^XMB(3.9,145978,2,293,0)="""RTN"",""DGSEC4"",27,0)"
^XMB(3.9,145978,2,294,0)=" ;                  DGMSG = If 1, generate message (optional)"
^XMB(3.9,145978,2,295,0)="""RTN"",""DGSEC4"",28,0)"
^XMB(3.9,145978,2,296,0)=" ;                  DGOPT  = Option name^Menu text (Optional)"
^XMB(3.9,145978,2,297,0)="""RTN"",""DGSEC4"",29,0)"
^XMB(3.9,145978,2,298,0)=" ;"
^XMB(3.9,145978,2,299,0)="""RTN"",""DGSEC4"",30,0)"
^XMB(3.9,145978,2,300,0)=" K RESULT"
^XMB(3.9,145978,2,301,0)="""RTN"",""DGSEC4"",31,0)"
^XMB(3.9,145978,2,302,0)=" I $G(DFN)="""" D  Q"
^XMB(3.9,145978,2,303,0)="""RTN"",""DGSEC4"",32,0)"
^XMB(3.9,145978,2,304,0)=" .S RESULT(1)=-1"
^XMB(3.9,145978,2,305,0)="""RTN"",""DGSEC4"",33,0)"
^XMB(3.9,145978,2,306,0)=" .S RESULT(2)=""Required variable missing."""
^XMB(3.9,145978,2,307,0)="""RTN"",""DGSEC4"",34,0)"
^XMB(3.9,145978,2,308,0)=" S DGMSG=$G(DGMSG)"
^XMB(3.9,145978,2,309,0)="""RTN"",""DGSEC4"",35,0)"
^XMB(3.9,145978,2,310,0)=" D OWNREC(.RESULT,DFN,$G(DUZ),DGMSG)"
^XMB(3.9,145978,2,311,0)="""RTN"",""DGSEC4"",36,0)"
^XMB(3.9,145978,2,312,0)=" I RESULT(1)=1 S RESULT(1)=3 Q"
^XMB(3.9,145978,2,313,0)="""RTN"",""DGSEC4"",37,0)"
^XMB(3.9,145978,2,314,0)=" I RESULT(1)=2 S RESULT(1)=4 Q"
^XMB(3.9,145978,2,315,0)="""RTN"",""DGSEC4"",38,0)"
^XMB(3.9,145978,2,316,0)=" K RESULT"
^XMB(3.9,145978,2,317,0)="""RTN"",""DGSEC4"",39,0)"
^XMB(3.9,145978,2,318,0)=" D SENS(.RESULT,DFN,$G(DUZ))"
^XMB(3.9,145978,2,319,0)="""RTN"",""DGSEC4"",40,0)"
^XMB(3.9,145978,2,320,0)=" I RESULT(1)=1 D"
^XMB(3.9,145978,2,321,0)="""RTN"",""DGSEC4"",41,0)"
^XMB(3.9,145978,2,322,0)=" .I $G(DUZ)="""" D  Q"
^XMB(3.9,145978,2,323,0)="""RTN"",""DGSEC4"",42,0)"
^XMB(3.9,145978,2,324,0)=" ..;DUZ must be defined to access sensitive record & update DG Security log"
^XMB(3.9,145978,2,325,0)="""RTN"",""DGSEC4"",43,0)"
^XMB(3.9,145978,2,326,0)=" ..S RESULT(1)=-1"
^XMB(3.9,145978,2,327,0)="""RTN"",""DGSEC4"",44,0)"
^XMB(3.9,145978,2,328,0)=" ..S RESULT(2)=""Your user code is undefined.  This must be defined to access a restricted patient record."""
^XMB(3.9,145978,2,329,0)="""RTN"",""DGSEC4"",45,0)"
^XMB(3.9,145978,2,330,0)=" .D SETLOG1^DGSEC(DFN,DUZ,,$G(DGOPT))"
^XMB(3.9,145978,2,331,0)="""RTN"",""DGSEC4"",46,0)"
^XMB(3.9,145978,2,332,0)=" ;DG*5.3*964 hook to call VistA Audit Solution (VAS) for non-sensitive patient inquiries"
^XMB(3.9,145978,2,333,0)="""RTN"",""DGSEC4"",47,0)"
^XMB(3.9,145978,2,334,0)=" I (RESULT(1)=0) I $$GET1^DIQ(46.5,1,.02,""I"") D SELAUD^DGAUDIT2(2,$G(DFN),""INQUIRY"",$G(DGOPT))"
^XMB(3.9,145978,2,335,0)="""RTN"",""DGSEC4"",48,0)"
^XMB(3.9,145978,2,336,0)=" Q"
^XMB(3.9,145978,2,337,0)="""RTN"",""DGSEC4"",49,0)"
^XMB(3.9,145978,2,338,0)="NOTICE(RESULT,DFN,DGOPT,ACTION) ;RPC/API entry point for log entry and message generation"
^XMB(3.9,145978,2,339,0)="""RTN"",""DGSEC4"",50,0)"
^XMB(3.9,145978,2,340,0)=" ;Input parameters:  "
^XMB(3.9,145978,2,341,0)="""RTN"",""DGSEC4"",51,0)"
^XMB(3.9,145978,2,342,0)=" ;  DFN    = Patient file DFN"
^XMB(3.9,145978,2,343,0)="""RTN"",""DGSEC4"",52,0)"
^XMB(3.9,145978,2,344,0)=" ;  DGOPT  = Option name^Menu text (Optional)"
^XMB(3.9,145978,2,345,0)="""RTN"",""DGSEC4"",53,0)"
^XMB(3.9,145978,2,346,0)=" ;  ACTION = 1 - Set DG Security Log entry, 2 - Generate mail "
^XMB(3.9,145978,2,347,0)="""RTN"",""DGSEC4"",54,0)"
^XMB(3.9,145978,2,348,0)=" ;           message, 3 - Both (Optional - Defaults to both)"
^XMB(3.9,145978,2,349,0)="""RTN"",""DGSEC4"",55,0)"
^XMB(3.9,145978,2,350,0)=" ;"
^XMB(3.9,145978,2,351,0)="""RTN"",""DGSEC4"",56,0)"
^XMB(3.9,145978,2,352,0)=" ;Output:  RESULT = 1 - DG Security Log updated and/or Sensitive Record msg sent (Determined by ACTION value)"
^XMB(3.9,145978,2,353,0)="""RTN"",""DGSEC4"",57,0)"
^XMB(3.9,145978,2,354,0)=" ;                  0 - Required variable undefined"
^XMB(3.9,145978,2,355,0)="""RTN"",""DGSEC4"",58,0)"
^XMB(3.9,145978,2,356,0)=" ;"
^XMB(3.9,145978,2,357,0)="""RTN"",""DGSEC4"",59,0)"
^XMB(3.9,145978,2,358,0)=" I $G(DFN)="""" S RESULT=0 Q"
^XMB(3.9,145978,2,359,0)="""RTN"",""DGSEC4"",60,0)"
^XMB(3.9,145978,2,360,0)=" I $G(DUZ)="""" S RESULT=0 Q"
^XMB(3.9,145978,2,361,0)="""RTN"",""DGSEC4"",61,0)"
^XMB(3.9,145978,2,362,0)=" S DGOPT=$G(DGOPT)"
^XMB(3.9,145978,2,363,0)="""RTN"",""DGSEC4"",62,0)"
^XMB(3.9,145978,2,364,0)=" I $G(ACTION)="""" S ACTION=3"
^XMB(3.9,145978,2,365,0)="""RTN"",""DGSEC4"",63,0)"
^XMB(3.9,145978,2,366,0)=" I ACTION'=1 D BULTIN1^DGSEC(DFN,DUZ,DGOPT)"
^XMB(3.9,145978,2,367,0)="""RTN"",""DGSEC4"",64,0)"
^XMB(3.9,145978,2,368,0)=" I ACTION'=2 D SETLOG1^DGSEC(DFN,DUZ,,DGOPT)"
^XMB(3.9,145978,2,369,0)="""RTN"",""DGSEC4"",65,0)"
^XMB(3.9,145978,2,370,0)=" S RESULT=1"
^XMB(3.9,145978,2,371,0)="""RTN"",""DGSEC4"",66,0)"
^XMB(3.9,145978,2,372,0)=" Q"
^XMB(3.9,145978,2,373,0)="""RTN"",""DGSEC4"",67,0)"
^XMB(3.9,145978,2,374,0)=" ;"
^XMB(3.9,145978,2,375,0)="""RTN"",""DGSEC4"",68,0)"
^XMB(3.9,145978,2,376,0)="OWNREC(DGREC,DFN,DGDUZ,DGMSG,DGNEWPT,DGPTSSN) ;Determine if user accessing his/her own Patient file (#2) record"
^XMB(3.9,145978,2,377,0)="""RTN"",""DGSEC4"",69,0)"
^XMB(3.9,145978,2,378,0)=" ;Input:"
^XMB(3.9,145978,2,379,0)="""RTN"",""DGSEC4"",70,0)"
^XMB(3.9,145978,2,380,0)=" ; DGREC - Array name passed by reference"
^XMB(3.9,145978,2,381,0)="""RTN"",""DGSEC4"",71,0)"
^XMB(3.9,145978,2,382,0)=" ; DFN - Patient (#2) file IEN"
^XMB(3.9,145978,2,383,0)="""RTN"",""DGSEC4"",72,0)"
^XMB(3.9,145978,2,384,0)=" ; DGDUZ - New Person (#200) file IEN (Not required. If not sent will return 0.)"
^XMB(3.9,145978,2,385,0)="""RTN"",""DGSEC4"",73,0)"
^XMB(3.9,145978,2,386,0)=" ; DGMSG - If 1, generate message (Optional) Will default to 1"
^XMB(3.9,145978,2,387,0)="""RTN"",""DGSEC4"",74,0)"
^XMB(3.9,145978,2,388,0)=" ; DGNEWPT - Set to 1 when adding a new entry to the Patient file"
^XMB(3.9,145978,2,389,0)="""RTN"",""DGSEC4"",75,0)"
^XMB(3.9,145978,2,390,0)=" ; DGPTSSN - new patient's SSN"
^XMB(3.9,145978,2,391,0)="""RTN"",""DGSEC4"",76,0)"
^XMB(3.9,145978,2,392,0)=" ;   DGNEWPT & DGPTSSN parameters only defined if DPTLK is adding"
^XMB(3.9,145978,2,393,0)="""RTN"",""DGSEC4"",77,0)"
^XMB(3.9,145978,2,394,0)=" ;   a new Patient (#2) file entry  "
^XMB(3.9,145978,2,395,0)="""RTN"",""DGSEC4"",78,0)"
^XMB(3.9,145978,2,396,0)=" ;"
^XMB(3.9,145978,2,397,0)="""RTN"",""DGSEC4"",79,0)"
^XMB(3.9,145978,2,398,0)=" ;Output:"
^XMB(3.9,145978,2,399,0)="""RTN"",""DGSEC4"",80,0)"
^XMB(3.9,145978,2,400,0)=" ; DGREC(1)=0 - Not attempting to access own Patient (#2) file record, "
^XMB(3.9,145978,2,401,0)="""RTN"",""DGSEC4"",81,0)"
^XMB(3.9,145978,2,402,0)=" ;            DUZ not defined, RESTRICT PATIENT RECORD ACCESS parameter"
^XMB(3.9,145978,2,403,0)="""RTN"",""DGSEC4"",82,0)"
^XMB(3.9,145978,2,404,0)=" ;            in MAS Parameters (#43) file not set to yes, or user holds"
^XMB(3.9,145978,2,405,0)="""RTN"",""DGSEC4"",83,0)"
^XMB(3.9,145978,2,406,0)=" ;            DG RECORD ACCESS security key."
^XMB(3.9,145978,2,407,0)="""RTN"",""DGSEC4"",84,0)"
^XMB(3.9,145978,2,408,0)=" ;         =1 - Attempting to access own Patient file record"
^XMB(3.9,145978,2,409,0)="""RTN"",""DGSEC4"",85,0)"
^XMB(3.9,145978,2,410,0)=" ;         =2 - SSN undefined"
^XMB(3.9,145978,2,411,0)="""RTN"",""DGSEC4"",86,0)"
^XMB(3.9,145978,2,412,0)=" ;         =-1 - Required variable not defined."
^XMB(3.9,145978,2,413,0)="""RTN"",""DGSEC4"",87,0)"
^XMB(3.9,145978,2,414,0)=" ; Other nodes in array will contain error message text."
^XMB(3.9,145978,2,415,0)="""RTN"",""DGSEC4"",88,0)"
^XMB(3.9,145978,2,416,0)=" ;"
^XMB(3.9,145978,2,417,0)="""RTN"",""DGSEC4"",89,0)"
^XMB(3.9,145978,2,418,0)=" ;DFN required"
^XMB(3.9,145978,2,419,0)="""RTN"",""DGSEC4"",90,0)"
^XMB(3.9,145978,2,420,0)=" I '$D(DFN),($G(DGNEWPT)'=1) D  Q"
^XMB(3.9,145978,2,421,0)="""RTN"",""DGSEC4"",91,0)"
^XMB(3.9,145978,2,422,0)=" .S DGREC(1)=-1"
^XMB(3.9,145978,2,423,0)="""RTN"",""DGSEC4"",92,0)"
^XMB(3.9,145978,2,424,0)=" .S DGREC(2)=""DFN not defined."""
^XMB(3.9,145978,2,425,0)="""RTN"",""DGSEC4"",93,0)"
^XMB(3.9,145978,2,426,0)=" S DGREC(1)=0"
^XMB(3.9,145978,2,427,0)="""RTN"",""DGSEC4"",94,0)"
^XMB(3.9,145978,2,428,0)=" ;Check if parameter is on"
^XMB(3.9,145978,2,429,0)="""RTN"",""DGSEC4"",95,0)"
^XMB(3.9,145978,2,430,0)=" I +$P($G(^DG(43,1,""REC"")),U)=0 Q"
^XMB(3.9,145978,2,431,0)="""RTN"",""DGSEC4"",96,0)"
^XMB(3.9,145978,2,432,0)=" N DGNPSSN"
^XMB(3.9,145978,2,433,0)="""RTN"",""DGSEC4"",97,0)"
^XMB(3.9,145978,2,434,0)=" ;I $D(DUZ)=0 Q"
^XMB(3.9,145978,2,435,0)="""RTN"",""DGSEC4"",98,0)"
^XMB(3.9,145978,2,436,0)=" I (+$G(DGDUZ))<1 Q"
^XMB(3.9,145978,2,437,0)="""RTN"",""DGSEC4"",99,0)"
^XMB(3.9,145978,2,438,0)=" ;Check if user holds security key"
^XMB(3.9,145978,2,439,0)="""RTN"",""DGSEC4"",100,0)"
^XMB(3.9,145978,2,440,0)=" I $D(^XUSEC(""DG RECORD ACCESS"",DGDUZ)) Q"
^XMB(3.9,145978,2,441,0)="""RTN"",""DGSEC4"",101,0)"
^XMB(3.9,145978,2,442,0)=" I $G(DGMSG)="""" S DGMSG=1"
^XMB(3.9,145978,2,443,0)="""RTN"",""DGSEC4"",102,0)"
^XMB(3.9,145978,2,444,0)=" N DGNPERR"
^XMB(3.9,145978,2,445,0)="""RTN"",""DGSEC4"",103,0)"
^XMB(3.9,145978,2,446,0)=" ; quit if user is a proxy user, i.e., not a real person"
^XMB(3.9,145978,2,447,0)="""RTN"",""DGSEC4"",104,0)"
^XMB(3.9,145978,2,448,0)=" I $$ACTIVE^XUSAP(DGDUZ),$$USERTYPE^XUSAP(DGDUZ,""CONNECTOR PROXY"")!($$USERTYPE^XUSAP(DGDUZ,""APPLICATION PROXY"")) Q"
^XMB(3.9,145978,2,449,0)="""RTN"",""DGSEC4"",105,0)"
^XMB(3.9,145978,2,450,0)=" S DGNPSSN=$$GET1^DIQ(200,DGDUZ_"","",9,""I"","""",""DGNPERR"")"
^XMB(3.9,145978,2,451,0)="""RTN"",""DGSEC4"",106,0)"
^XMB(3.9,145978,2,452,0)=" I 'DGNPSSN D  Q"
^XMB(3.9,145978,2,453,0)="""RTN"",""DGSEC4"",107,0)"
^XMB(3.9,145978,2,454,0)=" .S DGREC(1)=2"
^XMB(3.9,145978,2,455,0)="""RTN"",""DGSEC4"",108,0)"
^XMB(3.9,145978,2,456,0)=" .S DGREC(2)=""Your SSN is missing from the NEW PERSON file.  Contact your ADP Coordinator."""
^XMB(3.9,145978,2,457,0)="""RTN"",""DGSEC4"",109,0)"
^XMB(3.9,145978,2,458,0)=" .;Only send message if parameter set to 1"
^XMB(3.9,145978,2,459,0)="""RTN"",""DGSEC4"",110,0)"
^XMB(3.9,145978,2,460,0)=" .I DGMSG=1 D MSG(DGDUZ)"
^XMB(3.9,145978,2,461,0)="""RTN"",""DGSEC4"",111,0)"
^XMB(3.9,145978,2,462,0)=" I +$G(DGNEWPT)'=1 S DGPTSSN=$P($G(^DPT(DFN,0)),U,9)"
^XMB(3.9,145978,2,463,0)="""RTN"",""DGSEC4"",112,0)"
^XMB(3.9,145978,2,464,0)=" I +$G(DGNEWPT)=1 S DGPTSSN=$TR(DGPTSSN,""-"","""")"
^XMB(3.9,145978,2,465,0)="""RTN"",""DGSEC4"",113,0)"
^XMB(3.9,145978,2,466,0)=" I DGNPSSN=DGPTSSN D  Q"
^XMB(3.9,145978,2,467,0)="""RTN"",""DGSEC4"",114,0)"
^XMB(3.9,145978,2,468,0)=" .S DGREC(1)=1"
^XMB(3.9,145978,2,469,0)="""RTN"",""DGSEC4"",115,0)"
^XMB(3.9,145978,2,470,0)=" .S DGREC(2)=""Security regulations prohibit computer access to your own medical record."""
^XMB(3.9,145978,2,471,0)="""RTN"",""DGSEC4"",116,0)"
^XMB(3.9,145978,2,472,0)=" Q"
^XMB(3.9,145978,2,473,0)="""RTN"",""DGSEC4"",117,0)"
^XMB(3.9,145978,2,474,0)="MSG(DGDUZ) ;Send Missing SSN in New Person file message to mailgroup"
^XMB(3.9,145978,2,475,0)="""RTN"",""DGSEC4"",118,0)"
^XMB(3.9,145978,2,476,0)=" ;Input:  DGDUZ - New Person (#200) file IEN (Required)"
^XMB(3.9,145978,2,477,0)="""RTN"",""DGSEC4"",119,0)"
^XMB(3.9,145978,2,478,0)=" ;"
^XMB(3.9,145978,2,479,0)="""RTN"",""DGSEC4"",120,0)"
^XMB(3.9,145978,2,480,0)=" N DGNPERR,DGNPNAME,DGTEXT,XMCHAN,XMDUZ,XMSUB,XMTEXT,XMY,XMZ"
^XMB(3.9,145978,2,481,0)="""RTN"",""DGSEC4"",121,0)"
^XMB(3.9,145978,2,482,0)=" S DGNPNAME=$$GET1^DIQ(200,DGDUZ_"","",.01,"""",""DGNPERR"")"
^XMB(3.9,145978,2,483,0)="""RTN"",""DGSEC4"",122,0)"
^XMB(3.9,145978,2,484,0)=" S XMSUB=""MISSING SSN IN NEW PERSON FILE"""
^XMB(3.9,145978,2,485,0)="""RTN"",""DGSEC4"",123,0)"
^XMB(3.9,145978,2,486,0)=" S DGTEXT(1)=""The following NEW PERSON record does not contain a Social Security Number."""
^XMB(3.9,145978,2,487,0)="""RTN"",""DGSEC4"",124,0)"
^XMB(3.9,145978,2,488,0)=" S DGTEXT(2)=""This is required to access PATIENT file entries."""
^XMB(3.9,145978,2,489,0)="""RTN"",""DGSEC4"",125,0)"
^XMB(3.9,145978,2,490,0)=" S DGTEXT(3)="""""
^XMB(3.9,145978,2,491,0)="""RTN"",""DGSEC4"",126,0)"
^XMB(3.9,145978,2,492,0)=" S DGTEXT(4)=$S(DGNPNAME'="""":DGNPNAME,1:""UNKNOWN"")"
^XMB(3.9,145978,2,493,0)="""RTN"",""DGSEC4"",127,0)"
^XMB(3.9,145978,2,494,0)=" S DGTEXT(5)=""NEW PERSON (#200) File Internal Entry Number (DUZ):  ""_+DGDUZ"
^XMB(3.9,145978,2,495,0)="""RTN"",""DGSEC4"",128,0)"
^XMB(3.9,145978,2,496,0)=" S DGTEXT(6)="""""
^XMB(3.9,145978,2,497,0)="""RTN"",""DGSEC4"",129,0)"
^XMB(3.9,145978,2,498,0)=" S DGTEXT(7)=""This message has been sent to DG MISSING NEW PERSON SSN mail group."""
^XMB(3.9,145978,2,499,0)="""RTN"",""DGSEC4"",130,0)"
^XMB(3.9,145978,2,500,0)=" S DGTEXT(8)=""Please take appropriate action."""
^XMB(3.9,145978,2,501,0)="""RTN"",""DGSEC4"",131,0)"
^XMB(3.9,145978,2,502,0)=" S XMTEXT=""DGTEXT("""
^XMB(3.9,145978,2,503,0)="""RTN"",""DGSEC4"",132,0)"
^XMB(3.9,145978,2,504,0)=" S XMDUZ=$S(DGNPNAME'="""":DGNPNAME,1:.5)"
^XMB(3.9,145978,2,505,0)="""RTN"",""DGSEC4"",133,0)"
^XMB(3.9,145978,2,506,0)=" S XMY(""G.DG MISSING NEW PERSON SSN"")="""""
^XMB(3.9,145978,2,507,0)="""RTN"",""DGSEC4"",134,0)"
^XMB(3.9,145978,2,508,0)=" S XMCHAN=1"
^XMB(3.9,145978,2,509,0)="""RTN"",""DGSEC4"",135,0)"
^XMB(3.9,145978,2,510,0)=" D ^XMD"
^XMB(3.9,145978,2,511,0)="""RTN"",""DGSEC4"",136,0)"
^XMB(3.9,145978,2,512,0)=" Q"
^XMB(3.9,145978,2,513,0)="""RTN"",""DGSEC4"",137,0)"
^XMB(3.9,145978,2,514,0)="SENS(DGSENS,DFN,DGDUZ,DDS,DGSENFLG) ;Determine if sensitive record"
^XMB(3.9,145978,2,515,0)="""RTN"",""DGSEC4"",138,0)"
^XMB(3.9,145978,2,516,0)=" ;Input:"
^XMB(3.9,145978,2,517,0)="""RTN"",""DGSEC4"",139,0)"
^XMB(3.9,145978,2,518,0)=" ;  DGSENS - Array name passed by reference"
^XMB(3.9,145978,2,519,0)="""RTN"",""DGSEC4"",140,0)"
^XMB(3.9,145978,2,520,0)=" ;  DFN - Patient (#2) file IEN (Required)"
^XMB(3.9,145978,2,521,0)="""RTN"",""DGSEC4"",141,0)"
^XMB(3.9,145978,2,522,0)=" ;  DGDUZ - New Person (#200) file IEN"
^XMB(3.9,145978,2,523,0)="""RTN"",""DGSEC4"",142,0)"
^XMB(3.9,145978,2,524,0)=" ;  DDS - Screenman variable"
^XMB(3.9,145978,2,525,0)="""RTN"",""DGSEC4"",143,0)"
^XMB(3.9,145978,2,526,0)=" ;  DGSENFLG - If defined, patient record sensitivity not checked"
^XMB(3.9,145978,2,527,0)="""RTN"",""DGSEC4"",144,0)"
^XMB(3.9,145978,2,528,0)=" ;"
^XMB(3.9,145978,2,529,0)="""RTN"",""DGSEC4"",145,0)"
^XMB(3.9,145978,2,530,0)=" ;Output:"
^XMB(3.9,145978,2,531,0)="""RTN"",""DGSEC4"",146,0)"
^XMB(3.9,145978,2,532,0)=" ;  DGSENS(1)=0 - Record is not sensitive or DGSENFLG set"
^XMB(3.9,145978,2,533,0)="""RTN"",""DGSEC4"",147,0)"
^XMB(3.9,145978,2,534,0)=" ;           =1 - Sensitive record and user holds DG SENSITIVITY key"
^XMB(3.9,145978,2,535,0)="""RTN"",""DGSEC4"",148,0)"
^XMB(3.9,145978,2,536,0)=" ;              - Employee and user holds DG SECURITY OFFICER key"
^XMB(3.9,145978,2,537,0)="""RTN"",""DGSEC4"",149,0)"
^XMB(3.9,145978,2,538,0)=" ;           =2 - Sensitive record and user does not hold key"
^XMB(3.9,145978,2,539,0)="""RTN"",""DGSEC4"",150,0)"
^XMB(3.9,145978,2,540,0)=" ;              - Employee and user does not hold key"
^XMB(3.9,145978,2,541,0)="""RTN"",""DGSEC4"",151,0)"
^XMB(3.9,145978,2,542,0)=" ;           =-1 - Required input variable not defined"
^XMB(3.9,145978,2,543,0)="""RTN"",""DGSEC4"",152,0)"
^XMB(3.9,145978,2,544,0)=" ;  If 1, 2 or -1, array will contain error/display message"
^XMB(3.9,145978,2,545,0)="""RTN"",""DGSEC4"",153,0)"
^XMB(3.9,145978,2,546,0)=" ;"
^XMB(3.9,145978,2,547,0)="""RTN"",""DGSEC4"",154,0)"
^XMB(3.9,145978,2,548,0)=" N DGMSG,DGA1,DG1,DGDATE,DGLNE,DGT,DGTIME,DGEMPLEE"
^XMB(3.9,145978,2,549,0)="""RTN"",""DGSEC4"",155,0)"
^XMB(3.9,145978,2,550,0)=" ;Patient file DFN must be defined."
^XMB(3.9,145978,2,551,0)="""RTN"",""DGSEC4"",156,0)"
^XMB(3.9,145978,2,552,0)=" I '$D(DFN) D  Q "
^XMB(3.9,145978,2,553,0)="""RTN"",""DGSEC4"",157,0)"
^XMB(3.9,145978,2,554,0)=" .S DGSENS(1)=-1"
^XMB(3.9,145978,2,555,0)="""RTN"",""DGSEC4"",158,0)"
^XMB(3.9,145978,2,556,0)=" .S DGSENS(2)=""DFN not defined."""
^XMB(3.9,145978,2,557,0)="""RTN"",""DGSEC4"",159,0)"
^XMB(3.9,145978,2,558,0)=" S DGSENS(1)=0"
^XMB(3.9,145978,2,559,0)="""RTN"",""DGSEC4"",160,0)"
^XMB(3.9,145978,2,560,0)=" I $D(DGSENFLG) Q"
^XMB(3.9,145978,2,561,0)="""RTN"",""DGSEC4"",161,0)"
^XMB(3.9,145978,2,562,0)=" ;Determine if patient is employee"
^XMB(3.9,145978,2,563,0)="""RTN"",""DGSEC4"",162,0)"
^XMB(3.9,145978,2,564,0)=" S DGEMPLEE=$$EMPL(DFN)"
^XMB(3.9,145978,2,565,0)="""RTN"",""DGSEC4"",163,0)"
^XMB(3.9,145978,2,566,0)=" ;Quit if not an employee & not found in DG Security Log file"
^XMB(3.9,145978,2,567,0)="""RTN"",""DGSEC4"",164,0)"
^XMB(3.9,145978,2,568,0)=" I 'DGEMPLEE,('$D(^DGSL(38.1,+DFN,0))) Q"
^XMB(3.9,145978,2,569,0)="""RTN"",""DGSEC4"",165,0)"
^XMB(3.9,145978,2,570,0)=" ;Quit if not an employee and not flagged as sensitive"
^XMB(3.9,145978,2,571,0)="""RTN"",""DGSEC4"",166,0)"
^XMB(3.9,145978,2,572,0)=" I 'DGEMPLEE,($P($G(^DGSL(38.1,+DFN,0)),U,2)'=1) Q"
^XMB(3.9,145978,2,573,0)="""RTN"",""DGSEC4"",167,0)"
^XMB(3.9,145978,2,574,0)=" ;DUZ & user name must be defined"
^XMB(3.9,145978,2,575,0)="""RTN"",""DGSEC4"",168,0)"
^XMB(3.9,145978,2,576,0)=" S DGMSG=$S('$G(DGDUZ):""user code"",'$D(^VA(200,DGDUZ,0)):""user name"",1:"""")"
^XMB(3.9,145978,2,577,0)="""RTN"",""DGSEC4"",169,0)"
^XMB(3.9,145978,2,578,0)=" I DGMSG'="""" D  Q"
^XMB(3.9,145978,2,579,0)="""RTN"",""DGSEC4"",170,0)"
^XMB(3.9,145978,2,580,0)=" .S DGSENS(1)=-1"
^XMB(3.9,145978,2,581,0)="""RTN"",""DGSEC4"",171,0)"
^XMB(3.9,145978,2,582,0)=" .S DGSENS(2)=""Your ""_DGMSG_"" is undefined.  This must be defined to access"""
^XMB(3.9,145978,2,583,0)="""RTN"",""DGSEC4"",172,0)"
^XMB(3.9,145978,2,584,0)=" .S DGSENS(3)="" a restricted patient record."""
^XMB(3.9,145978,2,585,0)="""RTN"",""DGSEC4"",173,0)"
^XMB(3.9,145978,2,586,0)=" S DGSENS(1)=1"
^XMB(3.9,145978,2,587,0)="""RTN"",""DGSEC4"",174,0)"
^XMB(3.9,145978,2,588,0)=" ;Inpatient check - no longer used (kept for future reference)"
^XMB(3.9,145978,2,589,0)="""RTN"",""DGSEC4"",175,0)"
^XMB(3.9,145978,2,590,0)=" ;D H^DGUTL S DGT=DGTIME D ^DGPMSTAT"
^XMB(3.9,145978,2,591,0)="""RTN"",""DGSEC4"",176,0)"
^XMB(3.9,145978,2,592,0)=" S DGSENS(2)=""***WARNING***"""
^XMB(3.9,145978,2,593,0)="""RTN"",""DGSEC4"",177,0)"
^XMB(3.9,145978,2,594,0)=" I $G(DDS)'="""" S DGSENS(2)=DGSENS(2)_""  ***RESTRICTED RECORD***"""
^XMB(3.9,145978,2,595,0)="""RTN"",""DGSEC4"",178,0)"
^XMB(3.9,145978,2,596,0)=" I $G(DDS)="""" S DGSENS(3)=""***RESTRICTED RECORD***"""
^XMB(3.9,145978,2,597,0)="""RTN"",""DGSEC4"",179,0)"
^XMB(3.9,145978,2,598,0)=" I DGEMPLEE,('$D(^XUSEC(""DG SECURITY OFFICER"",+$G(DGDUZ)))) D  Q"
^XMB(3.9,145978,2,599,0)="""RTN"",""DGSEC4"",180,0)"
^XMB(3.9,145978,2,600,0)=" .S DGSENS(1)=2"
^XMB(3.9,145978,2,601,0)="""RTN"",""DGSEC4"",181,0)"
^XMB(3.9,145978,2,602,0)=" .D PRIV"
^XMB(3.9,145978,2,603,0)="""RTN"",""DGSEC4"",182,0)"
^XMB(3.9,145978,2,604,0)=" I '$D(^XUSEC(""DG SENSITIVITY"",+$G(DGDUZ))) D"
^XMB(3.9,145978,2,605,0)="""RTN"",""DGSEC4"",183,0)"
^XMB(3.9,145978,2,606,0)=" .S DGSENS(1)=2"
^XMB(3.9,145978,2,607,0)="""RTN"",""DGSEC4"",184,0)"
^XMB(3.9,145978,2,608,0)=" .D PRIV"
^XMB(3.9,145978,2,609,0)="""RTN"",""DGSEC4"",185,0)"
^XMB(3.9,145978,2,610,0)=" Q"
^XMB(3.9,145978,2,611,0)="""RTN"",""DGSEC4"",186,0)"
^XMB(3.9,145978,2,612,0)="PRIV ;Privacy Act statement for DGSENS array"
^XMB(3.9,145978,2,613,0)="""RTN"",""DGSEC4"",187,0)"
^XMB(3.9,145978,2,614,0)=" I $G(DDS)="""" S DGSENS(4)="""""
^XMB(3.9,145978,2,615,0)="""RTN"",""DGSEC4"",188,0)"
^XMB(3.9,145978,2,616,0)=" S DGSENS(5)=""1. STOP"""
^XMB(3.9,145978,2,617,0)="""RTN"",""DGSEC4"",189,0)"
^XMB(3.9,145978,2,618,0)=" S DGSENS(6)=""2. Confirm you need access to this Restricted patient record"""
^XMB(3.9,145978,2,619,0)="""RTN"",""DGSEC4"",190,0)"
^XMB(3.9,145978,2,620,0)=" S DGSENS(7)="""""
^XMB(3.9,145978,2,621,0)="""RTN"",""DGSEC4"",191,0)"
^XMB(3.9,145978,2,622,0)=" S DGSENS(8)=""This record is protected by the Privacy Act of 1974 and the Health"""
^XMB(3.9,145978,2,623,0)="""RTN"",""DGSEC4"",192,0)"
^XMB(3.9,145978,2,624,0)=" S DGSENS(9)=""Insurance Portability and Accountability Act (HIPAA) Privacy Rule."""
^XMB(3.9,145978,2,625,0)="""RTN"",""DGSEC4"",193,0)"
^XMB(3.9,145978,2,626,0)=" S DGSENS(10)="" * Access to this patient record is tracked and monitored."""
^XMB(3.9,145978,2,627,0)="""RTN"",""DGSEC4"",194,0)"
^XMB(3.9,145978,2,628,0)=" S DGSENS(11)="" * You must have need for this record to accomplish officially"""
^XMB(3.9,145978,2,629,0)="""RTN"",""DGSEC4"",195,0)"
^XMB(3.9,145978,2,630,0)=" S DGSENS(12)=""  authorized and assigned duties, such as direct patient care, to"""
^XMB(3.9,145978,2,631,0)="""RTN"",""DGSEC4"",196,0)"
^XMB(3.9,145978,2,632,0)=" S DGSENS(13)=""  proceed."""
^XMB(3.9,145978,2,633,0)="""RTN"",""DGSEC4"",197,0)"
^XMB(3.9,145978,2,634,0)=" S DGSENS(14)="" * You must provide justification for your access upon request."""
^XMB(3.9,145978,2,635,0)="""RTN"",""DGSEC4"",198,0)"
^XMB(3.9,145978,2,636,0)=" S DGSENS(15)="" * Failure to comply may result in disciplinary or adverse action up to"""
^XMB(3.9,145978,2,637,0)="""RTN"",""DGSEC4"",199,0)"
^XMB(3.9,145978,2,638,0)=" S DGSENS(16)=""  and including removal from Federal service, and civil and criminal"""
^XMB(3.9,145978,2,639,0)="""RTN"",""DGSEC4"",200,0)"
^XMB(3.9,145978,2,640,0)=" S DGSENS(17)=""  penalties."""
^XMB(3.9,145978,2,641,0)="""RTN"",""DGSEC4"",201,0)"
^XMB(3.9,145978,2,642,0)=" I $G(DDS)="""" S DGSENS(18)="""""
^XMB(3.9,145978,2,643,0)="""RTN"",""DGSEC4"",202,0)"
^XMB(3.9,145978,2,644,0)=" Q"
^XMB(3.9,145978,2,645,0)="""RTN"",""DGSEC4"",203,0)"
^XMB(3.9,145978,2,646,0)="EMPL(DFN,DGCHELIG) ;Does patient have any eligibility codes equal to"
^XMB(3.9,145978,2,647,0)="""RTN"",""DGSEC4"",204,0)"
^XMB(3.9,145978,2,648,0)=" ;                EMPLOYEE"
^XMB(3.9,145978,2,649,0)="""RTN"",""DGSEC4"",205,0)"
^XMB(3.9,145978,2,650,0)=" ;Input:"
^XMB(3.9,145978,2,651,0)="""RTN"",""DGSEC4"",206,0)"
^XMB(3.9,145978,2,652,0)=" ;       DFN - Patient (#2) file IEN (required)."
^XMB(3.9,145978,2,653,0)="""RTN"",""DGSEC4"",207,0)"
^XMB(3.9,145978,2,654,0)=" ;  DGCHELIG - Flags to determine mode of execution (optional)."
^XMB(3.9,145978,2,655,0)="""RTN"",""DGSEC4"",208,0)"
^XMB(3.9,145978,2,656,0)=" ;             Value of the parameter can contain any combination"
^XMB(3.9,145978,2,657,0)="""RTN"",""DGSEC4"",209,0)"
^XMB(3.9,145978,2,658,0)=" ;             of the following characters:"
^XMB(3.9,145978,2,659,0)="""RTN"",""DGSEC4"",210,0)"
^XMB(3.9,145978,2,660,0)=" ;               ""P"" - check primary eligibility code"
^XMB(3.9,145978,2,661,0)="""RTN"",""DGSEC4"",211,0)"
^XMB(3.9,145978,2,662,0)=" ;               ""S"" - check secondary eligibility codes"
^XMB(3.9,145978,2,663,0)="""RTN"",""DGSEC4"",212,0)"
^XMB(3.9,145978,2,664,0)=" ;"
^XMB(3.9,145978,2,665,0)="""RTN"",""DGSEC4"",213,0)"
^XMB(3.9,145978,2,666,0)=" ;             If this parameter is either not defined or set to an"
^XMB(3.9,145978,2,667,0)="""RTN"",""DGSEC4"",214,0)"
^XMB(3.9,145978,2,668,0)=" ;             illegal value, the value of ""PS"" will be assumed."
^XMB(3.9,145978,2,669,0)="""RTN"",""DGSEC4"",215,0)"
^XMB(3.9,145978,2,670,0)=" ;Output:"
^XMB(3.9,145978,2,671,0)="""RTN"",""DGSEC4"",216,0)"
^XMB(3.9,145978,2,672,0)=" ;         1 - Patient has EMPLOYEE as an eligibility code"
^XMB(3.9,145978,2,673,0)="""RTN"",""DGSEC4"",217,0)"
^XMB(3.9,145978,2,674,0)=" ;         0 - Patient doesn't have EMPLOYEE as an eligibility code"
^XMB(3.9,145978,2,675,0)="""RTN"",""DGSEC4"",218,0)"
^XMB(3.9,145978,2,676,0)=" ;"
^XMB(3.9,145978,2,677,0)="""RTN"",""DGSEC4"",219,0)"
^XMB(3.9,145978,2,678,0)=" ;Notes: EMPLOYEE is entry 14 in the MAS ELIGIBILITY CODE file (#8.1)"
^XMB(3.9,145978,2,679,0)="""RTN"",""DGSEC4"",220,0)"
^XMB(3.9,145978,2,680,0)=" N DGELIG,DGEMPLEE"
^XMB(3.9,145978,2,681,0)="""RTN"",""DGSEC4"",221,0)"
^XMB(3.9,145978,2,682,0)=" S DGEMPLEE=0"
^XMB(3.9,145978,2,683,0)="""RTN"",""DGSEC4"",222,0)"
^XMB(3.9,145978,2,684,0)=" I $G(DGCHELIG)'[""P"",$G(DGCHELIG)'[""S"" S DGCHELIG=""PS"""
^XMB(3.9,145978,2,685,0)="""RTN"",""DGSEC4"",223,0)"
^XMB(3.9,145978,2,686,0)=" ;Check primary eligibility"
^XMB(3.9,145978,2,687,0)="""RTN"",""DGSEC4"",224,0)"
^XMB(3.9,145978,2,688,0)=" I DGCHELIG[""P"" D"
^XMB(3.9,145978,2,689,0)="""RTN"",""DGSEC4"",225,0)"
^XMB(3.9,145978,2,690,0)=" .S DGELIG=+$G(^DPT(DFN,.36))"
^XMB(3.9,145978,2,691,0)="""RTN"",""DGSEC4"",226,0)"
^XMB(3.9,145978,2,692,0)=" .I $D(^DIC(8,""D"",14,DGELIG)) S DGEMPLEE=1"
^XMB(3.9,145978,2,693,0)="""RTN"",""DGSEC4"",227,0)"
^XMB(3.9,145978,2,694,0)=" ;Check secondary eligibilities (if needed)"
^XMB(3.9,145978,2,695,0)="""RTN"",""DGSEC4"",228,0)"
^XMB(3.9,145978,2,696,0)=" I DGCHELIG[""S"",'DGEMPLEE D"
^XMB(3.9,145978,2,697,0)="""RTN"",""DGSEC4"",229,0)"
^XMB(3.9,145978,2,698,0)=" .S DGELIG=0"
^XMB(3.9,145978,2,699,0)="""RTN"",""DGSEC4"",230,0)"
^XMB(3.9,145978,2,700,0)=" .F  S DGELIG=+$O(^DPT(""AEL"",DFN,DGELIG)) Q:'DGELIG  I $D(^DIC(8,""D"",14,DGELIG)) S DGEMPLEE=1 Q"
^XMB(3.9,145978,2,701,0)="""RTN"",""DGSEC4"",231,0)"
^XMB(3.9,145978,2,702,0)=" Q DGEMPLEE"
^XMB(3.9,145978,2,703,0)="""VER"")"
