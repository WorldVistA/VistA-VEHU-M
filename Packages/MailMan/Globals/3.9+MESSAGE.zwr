^XMB(3.9,145981,2,298,0)=" . S IB903=$P(^IBE(351,IBIEN,0),U,7)                  ;3rd QTR Billing"
^XMB(3.9,145981,2,299,0)="""RTN"",""IBECECX1"",30,0)"
^XMB(3.9,145981,2,300,0)=" . S IB904=$P(^IBE(351,IBIEN,0),U,8)                  ;4th QTR Billing"
^XMB(3.9,145981,2,301,0)="""RTN"",""IBECECX1"",31,0)"
^XMB(3.9,145981,2,302,0)=" . S IBCLDAY=$P(^IBE(351,IBIEN,0),U,9)                ;Number of Inpatient days"
