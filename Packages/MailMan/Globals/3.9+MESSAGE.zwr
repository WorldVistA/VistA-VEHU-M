^XMB(3.9,145944,2,1801,0)="""RTN"",""IBJDF6"",126,0)"
^XMB(3.9,145944,2,1802,0)=" D ^DIR K DIR G:$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1803,0)="""RTN"",""IBJDF6"",127,0)"
^XMB(3.9,145944,2,1804,0)=" S IBSH2=+Y W:IBSH2 "" DAYS"" K DIROUT,DTOUT,DUOUT,DIRUT"
^XMB(3.9,145944,2,1805,0)="""RTN"",""IBJDF6"",128,0)"
^XMB(3.9,145944,2,1806,0)=" ;"
^XMB(3.9,145944,2,1807,0)="""RTN"",""IBJDF6"",129,0)"
^XMB(3.9,145944,2,1808,0)="DEV ; - Select a device."
^XMB(3.9,145944,2,1809,0)="""RTN"",""IBJDF6"",130,0)"
^XMB(3.9,145944,2,1810,0)=" K IB0,IB1,IB2"
^XMB(3.9,145944,2,1811,0)="""RTN"",""IBJDF6"",131,0)"
^XMB(3.9,145944,2,1812,0)=" I '$G(IBEXCEL) D"
^XMB(3.9,145944,2,1813,0)="""RTN"",""IBJDF6"",132,0)"
^XMB(3.9,145944,2,1814,0)=" . S X=$S(IBRPT=""S"":80,1:132)"
^XMB(3.9,145944,2,1815,0)="""RTN"",""IBJDF6"",133,0)"
^XMB(3.9,145944,2,1816,0)=" . W !!,""You will need a "",X,"" column printer for this report!"",!"
^XMB(3.9,145944,2,1817,0)="""RTN"",""IBJDF6"",134,0)"
^XMB(3.9,145944,2,1818,0)=" . W !,""Note: This report will search through all  active  receivables."""
^XMB(3.9,145944,2,1819,0)="""RTN"",""IBJDF6"",135,0)"
^XMB(3.9,145944,2,1820,0)=" . W !,""      You should  queue it to run after normal business hours."",!"
^XMB(3.9,145944,2,1821,0)="""RTN"",""IBJDF6"",136,0)"
^XMB(3.9,145944,2,1822,0)=" ;"
^XMB(3.9,145944,2,1823,0)="""RTN"",""IBJDF6"",137,0)"
^XMB(3.9,145944,2,1824,0)=" I $G(IBEXCEL) D EXMSG^IBJD"
^XMB(3.9,145944,2,1825,0)="""RTN"",""IBJDF6"",138,0)"
^XMB(3.9,145944,2,1826,0)=" ;"
^XMB(3.9,145944,2,1827,0)="""RTN"",""IBJDF6"",139,0)"
^XMB(3.9,145944,2,1828,0)=" W ! S %ZIS=""QM"" D ^%ZIS G:POP ENQ"
^XMB(3.9,145944,2,1829,0)="""RTN"",""IBJDF6"",140,0)"
^XMB(3.9,145944,2,1830,0)=" I $D(IO(""Q"")) D  G ENQ"
^XMB(3.9,145944,2,1831,0)="""RTN"",""IBJDF6"",141,0)"
^XMB(3.9,145944,2,1832,0)=" . S ZTRTN=""DQ^IBJDF6"",ZTDESC=""IB - MISC. BILLS FOLLOW-UP REPORT"""
^XMB(3.9,145944,2,1833,0)="""RTN"",""IBJDF6"",142,0)"
^XMB(3.9,145944,2,1834,0)=" . F I=""IB*"",""VAUTD"",""VAUTD("" S ZTSAVE(I)="""""
^XMB(3.9,145944,2,1835,0)="""RTN"",""IBJDF6"",143,0)"
^XMB(3.9,145944,2,1836,0)=" . D ^%ZTLOAD"
^XMB(3.9,145944,2,1837,0)="""RTN"",""IBJDF6"",144,0)"
^XMB(3.9,145944,2,1838,0)=" . I $D(ZTSK) W !!,""This job has been queued. Task number is "",ZTSK,""."""
^XMB(3.9,145944,2,1839,0)="""RTN"",""IBJDF6"",145,0)"
^XMB(3.9,145944,2,1840,0)=" . E  W !!,""Unable to queue this job."""
^XMB(3.9,145944,2,1841,0)="""RTN"",""IBJDF6"",146,0)"
^XMB(3.9,145944,2,1842,0)=" . K ZTSK,IO(""Q"") D HOME^%ZIS"
^XMB(3.9,145944,2,1843,0)="""RTN"",""IBJDF6"",147,0)"
^XMB(3.9,145944,2,1844,0)=" ;"
^XMB(3.9,145944,2,1845,0)="""RTN"",""IBJDF6"",148,0)"
^XMB(3.9,145944,2,1846,0)=" U IO"
^XMB(3.9,145944,2,1847,0)="""RTN"",""IBJDF6"",149,0)"
^XMB(3.9,145944,2,1848,0)=" ;"
^XMB(3.9,145944,2,1849,0)="""RTN"",""IBJDF6"",150,0)"
^XMB(3.9,145944,2,1850,0)=" ; If called by the Extraction Module, change extract status for the 3 "
^XMB(3.9,145944,2,1851,0)="""RTN"",""IBJDF6"",151,0)"
^XMB(3.9,145944,2,1852,0)=" ; reports: No-fault auto accident, Tort Feasor and Workman's Comp"
