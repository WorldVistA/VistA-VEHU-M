^XMB(3.9,145952,2,2825,0)="""RTN"",""SDESGETCLINAPPT"",38,0)"
^XMB(3.9,145952,2,2826,0)=" Q"
^XMB(3.9,145952,2,2827,0)="""RTN"",""SDESGETCLINAPPT"",39,0)"
^XMB(3.9,145952,2,2828,0)=" ;"
