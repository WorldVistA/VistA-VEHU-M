^XMB(3.9,145942,2,195,0)="""QUES"",""XPI1"",0)"
^XMB(3.9,145942,2,196,0)="YO"
^XMB(3.9,145942,2,197,0)="""QUES"",""XPI1"",""??"")"
^XMB(3.9,145942,2,198,0)="^D INHIBIT^XPDH"
^XMB(3.9,145942,2,199,0)="""QUES"",""XPI1"",""A"")"
