^XMB(3.9,145946,2,4956,0)=" ;          ^TMP(""IBCNILKA,$J,IIEN)- Current Array of selected Ins Cos"
^XMB(3.9,145946,2,4957,0)="""RTN"",""IBCNILK"",310,0)"
