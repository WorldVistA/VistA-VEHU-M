^XMB(3.9,145986,2,1857,0)="""RTN"",""FBCHCR"",50,0)"
^XMB(3.9,145986,2,1858,0)=" Q"
^XMB(3.9,145986,2,1859,0)="""RTN"",""FBCHCR"",51,0)"
^XMB(3.9,145986,2,1860,0)="HED1 W !!?5,""TREATING SPECIALTY:  "" F I=1:1:8 S J=$T(TEXT+I) I $P(J,"";"",3)=FBPTC W $P(J,"";"",4) Q"
