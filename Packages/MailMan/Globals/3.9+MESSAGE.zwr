^XMB(3.9,145949,2,460,0)=" I $P(^PSRX(RXN,""SIG""),""^"",2)=1 N L S L=0 F  S L=$O(^PSRX(RXN,""SIG1"",L)) Q:L'>0  S SIG=$G(^PSRX(RXN,""SIG1"",L,0)) D TSTCHAR Q:SIG="""""
