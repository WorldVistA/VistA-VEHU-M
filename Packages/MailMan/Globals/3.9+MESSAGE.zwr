^XMB(3.9,145980,2,5543,0)="""RTN"",""SDES2CRTCLNAVAL2"",38,0)"
^XMB(3.9,145980,2,5544,0)=" ..D CREATEDATESTIMES(.DATES,.TIMES,.NUMBEROFSLOTS,.INPUTS,$P($G(INPUTS(""TIMESLOT"",TIMESLOTCNT,""START DATE TIME"",CNT)),""T""),NUMBEROFENTRIES,.SLOTSTOCANCEL)"
^XMB(3.9,145980,2,5545,0)="""RTN"",""SDES2CRTCLNAVAL2"",39,0)"
^XMB(3.9,145980,2,5546,0)=" ..I $D(SLOTSTOCANCEL(""Error"")) M RETURNAVAIL=SLOTSTOCANCEL S DONE=1 Q"
^XMB(3.9,145980,2,5547,0)="""RTN"",""SDES2CRTCLNAVAL2"",40,0)"
^XMB(3.9,145980,2,5548,0)=" ..;"
^XMB(3.9,145980,2,5549,0)="""RTN"",""SDES2CRTCLNAVAL2"",41,0)"
