^XMB(3.9,145986,2,3473,0)="""RTN"",""FBPAY671"",121,0)"
^XMB(3.9,145986,2,3474,0)=" Q"
^XMB(3.9,145986,2,3475,0)="""RTN"",""FBPAY671"",122,0)"
^XMB(3.9,145986,2,3476,0)="WRTSC ;write service connected"
^XMB(3.9,145986,2,3477,0)="""RTN"",""FBPAY671"",123,0)"
^XMB(3.9,145986,2,3478,0)=" W !,""SERVICE CONNECTED? "",$S(+VAEL(3):""YES"",1:""NO""),!"
^XMB(3.9,145986,2,3479,0)="""RTN"",""FBPAY671"",124,0)"
^XMB(3.9,145986,2,3480,0)=" Q"
^XMB(3.9,145986,2,3481,0)="""RTN"",""FBPAY671"",125,0)"
^XMB(3.9,145986,2,3482,0)="TRAV ;write out travel payments, (FBPAT,FBSORT) must be defined"
^XMB(3.9,145986,2,3483,0)="""RTN"",""FBPAY671"",126,0)"
^XMB(3.9,145986,2,3484,0)=" S FBTRDT=0"
^XMB(3.9,145986,2,3485,0)="""RTN"",""FBPAY671"",127,0)"
^XMB(3.9,145986,2,3486,0)=" F  S FBTRDT=$O(^TMP($J,""FBTR"",FBPAT,FBTRDT)) Q:'FBTRDT  S FBTRX=0 F  S FBTRX=$O(^TMP($J,""FBTR"",FBPAT,FBTRDT,FBTRX)) Q:'FBTRX  S FBCKIN=^(FBTRX),A2=$P(FBCKIN,""^"") D TRCK Q:FBOUT  W:$G(FBTRCK) !,?5,""TRAVEL PAYMENTS: "" D  K FBTRCK"
^XMB(3.9,145986,2,3487,0)="""RTN"",""FBPAY671"",128,0)"
^XMB(3.9,145986,2,3488,0)=" .W ?22,$$DATX^FBAAUTL(FBTRDT),?35,A2"
^XMB(3.9,145986,2,3489,0)="""RTN"",""FBPAY671"",129,0)"
^XMB(3.9,145986,2,3490,0)=" .S A2=$$EXTRL^FBMRASVR(A2) D EFBCK^FBPAY21(FBCKIN),PMNT^FBAACCB2"
^XMB(3.9,145986,2,3491,0)="""RTN"",""FBPAY671"",130,0)"
^XMB(3.9,145986,2,3492,0)=" .K A2 W ! Q"
