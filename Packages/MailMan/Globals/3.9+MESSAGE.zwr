^XMB(3.9,145976,2,252,0)="MAGGTU4D ;WOIFO/SG/NST/JSL/GEK/DAC/JSJ/MKN - VERSION CONTROL (CLINICAL DISPLAY); Apr 23, 2023@10:41"
