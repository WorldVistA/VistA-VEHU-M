^XMB(3.9,145952,2,2739,0)="""RTN"",""SDESAPPTDATA"",223,0)"
^XMB(3.9,145952,2,2740,0)=" .S COUNT=COUNT+1"
^XMB(3.9,145952,2,2741,0)="""RTN"",""SDESAPPTDATA"",224,0)"
