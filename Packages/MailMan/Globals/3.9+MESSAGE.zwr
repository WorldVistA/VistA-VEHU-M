^XMB(3.9,145946,2,5417,0)="""RTN"",""IBCNSU21"",68,0)"
^XMB(3.9,145946,2,5418,0)=" S X2=$$GET1^DIQ(36,+IBCNS_"","",.01)"
^XMB(3.9,145946,2,5419,0)="""RTN"",""IBCNSU21"",69,0)"
^XMB(3.9,145946,2,5420,0)=" S VALMHDR(1)=$$SETSTR^VALM1(X,IBLEAD_X2,81-$L(X),40)"
^XMB(3.9,145946,2,5421,0)="""RTN"",""IBCNSU21"",70,0)"
