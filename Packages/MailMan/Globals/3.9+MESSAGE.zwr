^XMB(3.9,145983,2,249,0)="""RTN"")"
^XMB(3.9,145983,2,250,0)=5
^XMB(3.9,145983,2,251,0)="""RTN"",""RCRPDR"")"
^XMB(3.9,145983,2,252,0)="0^4^B42313638"
^XMB(3.9,145983,2,253,0)="""RTN"",""RCRPDR"",1,0)"
^XMB(3.9,145983,2,254,0)="RCRPDR ;EDE/YMG - REPAYMENT PLAN DELINQUENT / DEFAULT LETTER REPORTS; 12/28/2020"
^XMB(3.9,145983,2,255,0)="""RTN"",""RCRPDR"",2,0)"
^XMB(3.9,145983,2,256,0)=" ;;4.5;Accounts Receivable;**378,389,429**;Mar 20, 1995;Build 0"
^XMB(3.9,145983,2,257,0)="""RTN"",""RCRPDR"",3,0)"
^XMB(3.9,145983,2,258,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145983,2,259,0)="""RTN"",""RCRPDR"",4,0)"
^XMB(3.9,145983,2,260,0)=" ;"
^XMB(3.9,145983,2,261,0)="""RTN"",""RCRPDR"",5,0)"
^XMB(3.9,145983,2,262,0)=" Q"
^XMB(3.9,145983,2,263,0)="""RTN"",""RCRPDR"",6,0)"
^XMB(3.9,145983,2,264,0)=" ;"
^XMB(3.9,145983,2,265,0)="""RTN"",""RCRPDR"",7,0)"
^XMB(3.9,145983,2,266,0)="EN(TYPE) ; entry point"
^XMB(3.9,145983,2,267,0)="""RTN"",""RCRPDR"",8,0)"
^XMB(3.9,145983,2,268,0)=" ;"
^XMB(3.9,145983,2,269,0)="""RTN"",""RCRPDR"",9,0)"
^XMB(3.9,145983,2,270,0)=" ; TYPE = 0 for delinquent letter report, 1 for default letter report"
^XMB(3.9,145983,2,271,0)="""RTN"",""RCRPDR"",10,0)"
^XMB(3.9,145983,2,272,0)=" ;"
^XMB(3.9,145983,2,273,0)="""RTN"",""RCRPDR"",11,0)"
^XMB(3.9,145983,2,274,0)=" N CLEARQ,EXCEL,POP,ZTDESC,ZTRTN,ZTSAVE,ZTSK,%ZIS"
^XMB(3.9,145983,2,275,0)="""RTN"",""RCRPDR"",12,0)"
^XMB(3.9,145983,2,276,0)=" K ^TMP(""RCRPDR"",$J)"
^XMB(3.9,145983,2,277,0)="""RTN"",""RCRPDR"",13,0)"
^XMB(3.9,145983,2,278,0)=" W !!,""Print "",$S(TYPE=1:""Default"",1:""Delinquent""),"" Letter Report"",!"
^XMB(3.9,145983,2,279,0)="""RTN"",""RCRPDR"",14,0)"
^XMB(3.9,145983,2,280,0)=" ; export to Excel?"
^XMB(3.9,145983,2,281,0)="""RTN"",""RCRPDR"",15,0)"
^XMB(3.9,145983,2,282,0)=" W !,""Answer Yes to print this report in a Mail-merge compatible format."""
^XMB(3.9,145983,2,283,0)="""RTN"",""RCRPDR"",16,0)"
^XMB(3.9,145983,2,284,0)=" W !!,""If you Answer No, the Statement Account Number for the Debtor will not""  ; PRCA*4.5*389"
^XMB(3.9,145983,2,285,0)="""RTN"",""RCRPDR"",17,0)"
^XMB(3.9,145983,2,286,0)=" W !,""appear on the screen."",!!  ; PRCA*4.5*389"
^XMB(3.9,145983,2,287,0)="""RTN"",""RCRPDR"",18,0)"
^XMB(3.9,145983,2,288,0)=" S EXCEL=$$ASKEXCEL^RCRPRPU() I EXCEL<0 Q"
^XMB(3.9,145983,2,289,0)="""RTN"",""RCRPDR"",19,0)"
^XMB(3.9,145983,2,290,0)=" I 'EXCEL W !!,""This report requires 132 characters"",!"
^XMB(3.9,145983,2,291,0)="""RTN"",""RCRPDR"",20,0)"
^XMB(3.9,145983,2,292,0)=" I EXCEL D EXCMSG^RCTCSJR    ; Display Excel display message I EXCEL"
^XMB(3.9,145983,2,293,0)="""RTN"",""RCRPDR"",21,0)"
^XMB(3.9,145983,2,294,0)=" ; ask for device"
^XMB(3.9,145983,2,295,0)="""RTN"",""RCRPDR"",22,0)"
^XMB(3.9,145983,2,296,0)=" K IOP,IO(""Q"")"
^XMB(3.9,145983,2,297,0)="""RTN"",""RCRPDR"",23,0)"
^XMB(3.9,145983,2,298,0)=" S %ZIS=""MQ"",%ZIS(""B"")="""",POP=0 D ^%ZIS Q:POP"
^XMB(3.9,145983,2,299,0)="""RTN"",""RCRPDR"",24,0)"
^XMB(3.9,145983,2,300,0)=" I $D(IO(""Q"")) S CLEARQ=$$ASKCLR() Q:CLEARQ<0  D  Q  ; queued report: ask if print queue should be cleared, then queue task"
^XMB(3.9,145983,2,301,0)="""RTN"",""RCRPDR"",25,0)"
^XMB(3.9,145983,2,302,0)=" .S ZTDESC=""Repayment Plan ""_$S(TYPE=1:""Default"",1:""Delinquent"")_"" Letter Report"""
^XMB(3.9,145983,2,303,0)="""RTN"",""RCRPDR"",26,0)"
^XMB(3.9,145983,2,304,0)=" .S ZTRTN=""COMPILE^RCRPDR"""
^XMB(3.9,145983,2,305,0)="""RTN"",""RCRPDR"",27,0)"
^XMB(3.9,145983,2,306,0)=" .S ZTSAVE(""TYPE"")="""",ZTSAVE(""EXCEL"")="""",ZTSAVE(""CLEARQ"")="""",ZTSAVE(""ZTREQ"")=""@"""
^XMB(3.9,145983,2,307,0)="""RTN"",""RCRPDR"",28,0)"
^XMB(3.9,145983,2,308,0)=" .D ^%ZTLOAD,HOME^%ZIS"
^XMB(3.9,145983,2,309,0)="""RTN"",""RCRPDR"",29,0)"
^XMB(3.9,145983,2,310,0)=" .I $G(ZTSK) W !!,""Report compilation has started with task# "",ZTSK,""."",! D PAUSE^RCRPRPU"
^XMB(3.9,145983,2,311,0)="""RTN"",""RCRPDR"",30,0)"
^XMB(3.9,145983,2,312,0)=" .Q"
^XMB(3.9,145983,2,313,0)="""RTN"",""RCRPDR"",31,0)"
^XMB(3.9,145983,2,314,0)=" D COMPILE"
^XMB(3.9,145983,2,315,0)="""RTN"",""RCRPDR"",32,0)"
^XMB(3.9,145983,2,316,0)=" Q"
^XMB(3.9,145983,2,317,0)="""RTN"",""RCRPDR"",33,0)"
^XMB(3.9,145983,2,318,0)=" ;"
^XMB(3.9,145983,2,319,0)="""RTN"",""RCRPDR"",34,0)"
^XMB(3.9,145983,2,320,0)="COMPILE ; compile report"
^XMB(3.9,145983,2,321,0)="""RTN"",""RCRPDR"",35,0)"
^XMB(3.9,145983,2,322,0)=" N ACCTNUM,ADDRSTR,CRNTDT,DEBT,DEBTOR,MED,N0,NAME,RPIEN,RPPID,TMP,TMPSTR,XREF"
^XMB(3.9,145983,2,323,0)="""RTN"",""RCRPDR"",36,0)"
^XMB(3.9,145983,2,324,0)=" S XREF=$S(TYPE:""PRTDEF"",1:""PRTDEL"")"
^XMB(3.9,145983,2,325,0)="""RTN"",""RCRPDR"",37,0)"
^XMB(3.9,145983,2,326,0)=" S RPIEN=0 F  S RPIEN=$O(^RCRP(340.5,XREF,1,RPIEN)) Q:'RPIEN  D"
^XMB(3.9,145983,2,327,0)="""RTN"",""RCRPDR"",38,0)"
^XMB(3.9,145983,2,328,0)=" .S N0=^RCRP(340.5,RPIEN,0)"
^XMB(3.9,145983,2,329,0)="""RTN"",""RCRPDR"",39,0)"
^XMB(3.9,145983,2,330,0)=" .S RPPID=$P(N0,U),DEBTOR=+$P(N0,U,2) Q:DEBTOR'>0"
^XMB(3.9,145983,2,331,0)="""RTN"",""RCRPDR"",40,0)"
^XMB(3.9,145983,2,332,0)=" .S ADDRSTR=$P($$DADD^RCAMADD(DEBTOR,1),U,1,6)     ; ADDRSTR = Str1^Str2^Str3^City^State^ZIP"
^XMB(3.9,145983,2,333,0)="""RTN"",""RCRPDR"",41,0)"
^XMB(3.9,145983,2,334,0)=" .S NAME=$$NAM^RCFN01(DEBTOR) Q:NAME=""""  ; debtor name"
^XMB(3.9,145983,2,335,0)="""RTN"",""RCRPDR"",42,0)"
^XMB(3.9,145983,2,336,0)=" .S DEBT=U_$P(NAME,"","")  ; needed for ACCT^PRCAAPR1, 2nd piece contains last name of the debtor  PRCA*4.5*389"
^XMB(3.9,145983,2,337,0)="""RTN"",""RCRPDR"",43,0)"
^XMB(3.9,145983,2,338,0)=" .; PRCA*4.5*429"
^XMB(3.9,145983,2,339,0)="""RTN"",""RCRPDR"",44,0)"
^XMB(3.9,145983,2,340,0)=" .S TMP=$P($G(^RCD(340,DEBTOR,0)),U)"
^XMB(3.9,145983,2,341,0)="""RTN"",""RCRPDR"",45,0)"
^XMB(3.9,145983,2,342,0)=" .S MED=1 I $P(TMP,"";"",2)'=""DPT("" S MED=0  ; non-medical debt"
^XMB(3.9,145983,2,343,0)="""RTN"",""RCRPDR"",46,0)"
^XMB(3.9,145983,2,344,0)=" .S ACCTNUM=""N/A"" I MED S ACCTNUM=$$ACCT^PRCAAPR1($P(TMP,"";""))"
^XMB(3.9,145983,2,345,0)="""RTN"",""RCRPDR"",47,0)"
^XMB(3.9,145983,2,346,0)=" .I 'MED S NAME=""*""_NAME"
^XMB(3.9,145983,2,347,0)="""RTN"",""RCRPDR"",48,0)"
^XMB(3.9,145983,2,348,0)=" .;"
^XMB(3.9,145983,2,349,0)="""RTN"",""RCRPDR"",49,0)"
^XMB(3.9,145983,2,350,0)=" .S TMPSTR="""" S TMPSTR=$$CALC(RPIEN,+$P(N0,U,6)) Q:'+$P(TMPSTR,U)  ; PRCA*4.5*389"
^XMB(3.9,145983,2,351,0)="""RTN"",""RCRPDR"",50,0)"
^XMB(3.9,145983,2,352,0)=" .S ^TMP(""RCRPDR"",$J,NAME)=ADDRSTR_U_ACCTNUM  ; PRCA*4.5*389"
^XMB(3.9,145983,2,353,0)="""RTN"",""RCRPDR"",51,0)"
^XMB(3.9,145983,2,354,0)=" .S ^TMP(""RCRPDR"",$J,NAME,RPPID)=TMPSTR"
^XMB(3.9,145983,2,355,0)="""RTN"",""RCRPDR"",52,0)"
^XMB(3.9,145983,2,356,0)=" .S ^TMP(""RCRPDR"",$J,NAME,RPPID,""IEN"")=RPIEN"
^XMB(3.9,145983,2,357,0)="""RTN"",""RCRPDR"",53,0)"
^XMB(3.9,145983,2,358,0)=" .Q"
^XMB(3.9,145983,2,359,0)="""RTN"",""RCRPDR"",54,0)"
^XMB(3.9,145983,2,360,0)=" ;"
^XMB(3.9,145983,2,361,0)="""RTN"",""RCRPDR"",55,0)"
^XMB(3.9,145983,2,362,0)=" D PRINT"
^XMB(3.9,145983,2,363,0)="""RTN"",""RCRPDR"",56,0)"
^XMB(3.9,145983,2,364,0)=" K ^TMP(""RCRPDR"",$J)"
^XMB(3.9,145983,2,365,0)="""RTN"",""RCRPDR"",57,0)"
^XMB(3.9,145983,2,366,0)=" Q"
^XMB(3.9,145983,2,367,0)="""RTN"",""RCRPDR"",58,0)"
^XMB(3.9,145983,2,368,0)=" ;"
^XMB(3.9,145983,2,369,0)="""RTN"",""RCRPDR"",59,0)"
^XMB(3.9,145983,2,370,0)="PRINT ; print report"
^XMB(3.9,145983,2,371,0)="""RTN"",""RCRPDR"",60,0)"
^XMB(3.9,145983,2,372,0)=" N ACCTNUM,ADDR,AMNT,CNT,DATA,DATA1,EXTDT,LN,NAME,PAGE,RPPID,UPDT"
^XMB(3.9,145983,2,373,0)="""RTN"",""RCRPDR"",61,0)"
^XMB(3.9,145983,2,374,0)=" U IO"
^XMB(3.9,145983,2,375,0)="""RTN"",""RCRPDR"",62,0)"
^XMB(3.9,145983,2,376,0)=" S PAGE=0"
^XMB(3.9,145983,2,377,0)="""RTN"",""RCRPDR"",63,0)"
^XMB(3.9,145983,2,378,0)=" S EXTDT=$$FMTE^XLFDT(DT)"
^XMB(3.9,145983,2,379,0)="""RTN"",""RCRPDR"",64,0)"
^XMB(3.9,145983,2,380,0)=" I EXCEL D"
^XMB(3.9,145983,2,381,0)="""RTN"",""RCRPDR"",65,0)"
^XMB(3.9,145983,2,382,0)=" .W !,""Print "",$S(TYPE=1:""Default"",1:""Delinquent""),"" Letter Report;"",EXTDT"
^XMB(3.9,145983,2,383,0)="""RTN"",""RCRPDR"",66,0)"
^XMB(3.9,145983,2,384,0)=" .W !,""Name^Statement Account Number^Street Address^Address 2^Address 3^City^State^Zip Code^RPP ID^Amount Due"" W:'TYPE ""^Current Through"""
^XMB(3.9,145983,2,385,0)="""RTN"",""RCRPDR"",67,0)"
^XMB(3.9,145983,2,386,0)=" .Q"
^XMB(3.9,145983,2,387,0)="""RTN"",""RCRPDR"",68,0)"
^XMB(3.9,145983,2,388,0)=" I 'EXCEL D"
^XMB(3.9,145983,2,389,0)="""RTN"",""RCRPDR"",69,0)"
^XMB(3.9,145983,2,390,0)=" .I $E(IOST,1,2)[""C-"",'$D(ZTQUEUED) W @IOF"
^XMB(3.9,145983,2,391,0)="""RTN"",""RCRPDR"",70,0)"
^XMB(3.9,145983,2,392,0)=" .D HDR"
^XMB(3.9,145983,2,393,0)="""RTN"",""RCRPDR"",71,0)"
^XMB(3.9,145983,2,394,0)=" .Q"
^XMB(3.9,145983,2,395,0)="""RTN"",""RCRPDR"",72,0)"
^XMB(3.9,145983,2,396,0)=" I '$D(^TMP(""RCRPDR"",$J)) D  Q"
^XMB(3.9,145983,2,397,0)="""RTN"",""RCRPDR"",73,0)"
^XMB(3.9,145983,2,398,0)=" .I EXCEL W !!,""No records found."" Q"
^XMB(3.9,145983,2,399,0)="""RTN"",""RCRPDR"",74,0)"
^XMB(3.9,145983,2,400,0)=" .W !!,$$CJ^XLFSTR(""No records found."",132)"
^XMB(3.9,145983,2,401,0)="""RTN"",""RCRPDR"",75,0)"
^XMB(3.9,145983,2,402,0)=" .Q"
^XMB(3.9,145983,2,403,0)="""RTN"",""RCRPDR"",76,0)"
^XMB(3.9,145983,2,404,0)=" S NAME="""" F  S NAME=$O(^TMP(""RCRPDR"",$J,NAME)) Q:NAME=""""  D"
^XMB(3.9,145983,2,405,0)="""RTN"",""RCRPDR"",77,0)"
^XMB(3.9,145983,2,406,0)=" .S RPPID="""" F  S RPPID=$O(^TMP(""RCRPDR"",$J,NAME,RPPID)) Q:RPPID=""""  D"
^XMB(3.9,145983,2,407,0)="""RTN"",""RCRPDR"",78,0)"
^XMB(3.9,145983,2,408,0)=" ..S DATA1=^TMP(""RCRPDR"",$J,NAME),ADDR=$P(DATA1,U,1,6),ACCTNUM=$P(DATA1,U,7)  ; PRCA*4.5*389"
^XMB(3.9,145983,2,409,0)="""RTN"",""RCRPDR"",79,0)"
^XMB(3.9,145983,2,410,0)=" ..S DATA=^TMP(""RCRPDR"",$J,NAME,RPPID)"
^XMB(3.9,145983,2,411,0)="""RTN"",""RCRPDR"",80,0)"
^XMB(3.9,145983,2,412,0)=" ..S AMNT=$FN($P(DATA,U),"""",2)"
^XMB(3.9,145983,2,413,0)="""RTN"",""RCRPDR"",81,0)"
^XMB(3.9,145983,2,414,0)=" ..I 'TYPE S UPDT=$$FMTE^XLFDT($P(DATA,U,2),""5DZ"")"
^XMB(3.9,145983,2,415,0)="""RTN"",""RCRPDR"",82,0)"
^XMB(3.9,145983,2,416,0)=" ..I EXCEL D  Q"
^XMB(3.9,145983,2,417,0)="""RTN"",""RCRPDR"",83,0)"
^XMB(3.9,145983,2,418,0)=" ...W !,NAME,U,ACCTNUM,U,$P(ADDR,U),U,$P(ADDR,U,2),U,$P(ADDR,U,3),U,$P(ADDR,U,4),U,$P(ADDR,U,5),U,$P(ADDR,U,6),U,RPPID,U,AMNT  ; PRCA*4.5*389"
^XMB(3.9,145983,2,419,0)="""RTN"",""RCRPDR"",84,0)"
^XMB(3.9,145983,2,420,0)=" ...I 'TYPE W U,UPDT  ; PRCA*4.5*389"
^XMB(3.9,145983,2,421,0)="""RTN"",""RCRPDR"",85,0)"
^XMB(3.9,145983,2,422,0)=" ...Q"
^XMB(3.9,145983,2,423,0)="""RTN"",""RCRPDR"",86,0)"
^XMB(3.9,145983,2,424,0)=" ..S LN=LN+1"
^XMB(3.9,145983,2,425,0)="""RTN"",""RCRPDR"",87,0)"
^XMB(3.9,145983,2,426,0)=" ..W !,$E(NAME,1,26)"
^XMB(3.9,145983,2,427,0)="""RTN"",""RCRPDR"",88,0)"
^XMB(3.9,145983,2,428,0)=" ..W ?28,$E($P(ADDR,U)_"" ""_$P(ADDR,U,2)_"" ""_$P(ADDR,U,3)_"", ""_$P(ADDR,U,4)_"", ""_$P(ADDR,U,5)_"" ""_$P(ADDR,U,6),1,56)"
^XMB(3.9,145983,2,429,0)="""RTN"",""RCRPDR"",89,0)"
^XMB(3.9,145983,2,430,0)=" ..W ?86,RPPID,?107,AMNT W:'TYPE ?119,UPDT  ; PRCA*4.5*389"
^XMB(3.9,145983,2,431,0)="""RTN"",""RCRPDR"",90,0)"
^XMB(3.9,145983,2,432,0)=" ..I LN>(IOSL-4) D HDR"
^XMB(3.9,145983,2,433,0)="""RTN"",""RCRPDR"",91,0)"
^XMB(3.9,145983,2,434,0)=" ..Q"
^XMB(3.9,145983,2,435,0)="""RTN"",""RCRPDR"",92,0)"
^XMB(3.9,145983,2,436,0)=" .Q"
^XMB(3.9,145983,2,437,0)="""RTN"",""RCRPDR"",93,0)"
^XMB(3.9,145983,2,438,0)=" ; if not queued, clear print queue if necessary"
^XMB(3.9,145983,2,439,0)="""RTN"",""RCRPDR"",94,0)"
^XMB(3.9,145983,2,440,0)=" I '$D(ZTQUEUED),EXCEL W ! S CLEARQ=$$ASKCLR() I CLEARQ=1 D"
^XMB(3.9,145983,2,441,0)="""RTN"",""RCRPDR"",95,0)"
^XMB(3.9,145983,2,442,0)=" .; clear print flag in file 340.5"
^XMB(3.9,145983,2,443,0)="""RTN"",""RCRPDR"",96,0)"
^XMB(3.9,145983,2,444,0)=" .S NAME="""" F  S NAME=$O(^TMP(""RCRPDR"",$J,NAME)) Q:NAME=""""  D"
^XMB(3.9,145983,2,445,0)="""RTN"",""RCRPDR"",97,0)"
^XMB(3.9,145983,2,446,0)=" ..S RPPID="""" F  S RPPID=$O(^TMP(""RCRPDR"",$J,NAME,RPPID)) Q:RPPID=""""  D CLRPRNT(^TMP(""RCRPDR"",$J,NAME,RPPID,""IEN""),TYPE)"
^XMB(3.9,145983,2,447,0)="""RTN"",""RCRPDR"",98,0)"
^XMB(3.9,145983,2,448,0)=" ..Q"
^XMB(3.9,145983,2,449,0)="""RTN"",""RCRPDR"",99,0)"
^XMB(3.9,145983,2,450,0)=" .Q"
^XMB(3.9,145983,2,451,0)="""RTN"",""RCRPDR"",100,0)"
^XMB(3.9,145983,2,452,0)=" Q"
^XMB(3.9,145983,2,453,0)="""RTN"",""RCRPDR"",101,0)"
^XMB(3.9,145983,2,454,0)=" ;"
^XMB(3.9,145983,2,455,0)="""RTN"",""RCRPDR"",102,0)"
^XMB(3.9,145983,2,456,0)="HDR ; print header"
^XMB(3.9,145983,2,457,0)="""RTN"",""RCRPDR"",103,0)"
^XMB(3.9,145983,2,458,0)=" I PAGE>0,'$D(ZTQUEUED) D PAUSE^RCRPRPU"
^XMB(3.9,145983,2,459,0)="""RTN"",""RCRPDR"",104,0)"
^XMB(3.9,145983,2,460,0)=" W @IOF"
^XMB(3.9,145983,2,461,0)="""RTN"",""RCRPDR"",105,0)"
^XMB(3.9,145983,2,462,0)=" S PAGE=PAGE+1,LN=4"
^XMB(3.9,145983,2,463,0)="""RTN"",""RCRPDR"",106,0)"
^XMB(3.9,145983,2,464,0)=" W !,""Print "",$S(TYPE=1:""Default"",1:""Delinquent""),"" Letter Report"",?66,EXTDT,?120,""Page: "",PAGE"
^XMB(3.9,145983,2,465,0)="""RTN"",""RCRPDR"",107,0)"
^XMB(3.9,145983,2,466,0)=" W !!,""* Indicates a non-medical debt repayment plan"""
^XMB(3.9,145983,2,467,0)="""RTN"",""RCRPDR"",108,0)"
^XMB(3.9,145983,2,468,0)=" W !!,?11,""Name"",?53,""Address"",?91,""RPP ID"",?105,""Amount Due"" W:'TYPE ?117,""Current Through""  ; PRCA*4.5*389"
^XMB(3.9,145983,2,469,0)="""RTN"",""RCRPDR"",109,0)"
^XMB(3.9,145983,2,470,0)=" W ! D DASH^RCRPRPU(132)"
^XMB(3.9,145983,2,471,0)="""RTN"",""RCRPDR"",110,0)"
^XMB(3.9,145983,2,472,0)=" Q"
^XMB(3.9,145983,2,473,0)="""RTN"",""RCRPDR"",111,0)"
^XMB(3.9,145983,2,474,0)=" ;"
^XMB(3.9,145983,2,475,0)="""RTN"",""RCRPDR"",112,0)"
^XMB(3.9,145983,2,476,0)="CALC(RPIEN,MAMNT) ; calculate amount due and ""current through"" date"
^XMB(3.9,145983,2,477,0)="""RTN"",""RCRPDR"",113,0)"
^XMB(3.9,145983,2,478,0)=" ;"
^XMB(3.9,145983,2,479,0)="""RTN"",""RCRPDR"",114,0)"
^XMB(3.9,145983,2,480,0)=" ; RPIEN - file 340.5 ien"
^XMB(3.9,145983,2,481,0)="""RTN"",""RCRPDR"",115,0)"
^XMB(3.9,145983,2,482,0)=" ; MAMNT - monthly amount (340.5/.06)"
^XMB(3.9,145983,2,483,0)="""RTN"",""RCRPDR"",116,0)"
^XMB(3.9,145983,2,484,0)=" ;"
^XMB(3.9,145983,2,485,0)="""RTN"",""RCRPDR"",117,0)"
^XMB(3.9,145983,2,486,0)=" ; returns amount due ^ ""current through"" date, or """" if no missing payments were found"
^XMB(3.9,145983,2,487,0)="""RTN"",""RCRPDR"",118,0)"
^XMB(3.9,145983,2,488,0)=" ;"
^XMB(3.9,145983,2,489,0)="""RTN"",""RCRPDR"",119,0)"
^XMB(3.9,145983,2,490,0)=" N CNT,LSTDT,N0,RPDT,TOTAL,UPDT,Z"
^XMB(3.9,145983,2,491,0)="""RTN"",""RCRPDR"",120,0)"
^XMB(3.9,145983,2,492,0)=" I $G(MAMNT)'>0 Q """""
^XMB(3.9,145983,2,493,0)="""RTN"",""RCRPDR"",121,0)"
^XMB(3.9,145983,2,494,0)=" S LSTDT=$O(^RCRP(340.5,RPIEN,2,""B"",""""),-1) ; last due date in the schedule  PRCA*4.5*429"
^XMB(3.9,145983,2,495,0)="""RTN"",""RCRPDR"",122,0)"
^XMB(3.9,145983,2,496,0)=" ; loop backwards from today's date, count entries with no payment and no forbearance"
^XMB(3.9,145983,2,497,0)="""RTN"",""RCRPDR"",123,0)"
^XMB(3.9,145983,2,498,0)=" S CNT=0,RPDT=DT F  S RPDT=$O(^RCRP(340.5,RPIEN,2,""B"",RPDT),-1) Q:'RPDT  D"
^XMB(3.9,145983,2,499,0)="""RTN"",""RCRPDR"",124,0)"
^XMB(3.9,145983,2,500,0)=" .S Z=$O(^RCRP(340.5,RPIEN,2,""B"",RPDT,"""")) Q:'Z"
^XMB(3.9,145983,2,501,0)="""RTN"",""RCRPDR"",125,0)"
^XMB(3.9,145983,2,502,0)=" .S N0=^RCRP(340.5,RPIEN,2,Z,0) I +$P(N0,U,2)=0,+$P(N0,U,3)=0 S CNT=CNT+1"
^XMB(3.9,145983,2,503,0)="""RTN"",""RCRPDR"",126,0)"
^XMB(3.9,145983,2,504,0)=" .Q"
^XMB(3.9,145983,2,505,0)="""RTN"",""RCRPDR"",127,0)"
^XMB(3.9,145983,2,506,0)=" I CNT=0 Q """"  ; no missing payments found"
^XMB(3.9,145983,2,507,0)="""RTN"",""RCRPDR"",128,0)"
^XMB(3.9,145983,2,508,0)=" S UPDT=LSTDT I DT'>LSTDT D  ; PRCA*4.5*429"
^XMB(3.9,145983,2,509,0)="""RTN"",""RCRPDR"",129,0)"
^XMB(3.9,145983,2,510,0)=" .S CNT=CNT+1  ; add upcoming payment"
^XMB(3.9,145983,2,511,0)="""RTN"",""RCRPDR"",130,0)"
^XMB(3.9,145983,2,512,0)=" .S UPDT=$O(^RCRP(340.5,RPIEN,2,""B"",DT))  ; upcoming payment date"
^XMB(3.9,145983,2,513,0)="""RTN"",""RCRPDR"",131,0)"
^XMB(3.9,145983,2,514,0)=" .; if today's date is between 21st and 28th, add 2nd upcoming payment and go to the next upcoming payment date"
^XMB(3.9,145983,2,515,0)="""RTN"",""RCRPDR"",132,0)"
^XMB(3.9,145983,2,516,0)=" .I DT'>$O(^RCRP(340.5,RPIEN,2,""B"",LSTDT),-1) S Z=$E(DT,6,7) I Z>21,Z<28 S CNT=CNT+1,UPDT=$O(^RCRP(340.5,RPIEN,2,""B"",UPDT))"
^XMB(3.9,145983,2,517,0)="""RTN"",""RCRPDR"",133,0)"
^XMB(3.9,145983,2,518,0)=" .Q"
^XMB(3.9,145983,2,519,0)="""RTN"",""RCRPDR"",134,0)"
^XMB(3.9,145983,2,520,0)=" S TOTAL=MAMNT*CNT ; total amount owed for missed payments"
^XMB(3.9,145983,2,521,0)="""RTN"",""RCRPDR"",135,0)"
^XMB(3.9,145983,2,522,0)=" Q TOTAL_U_UPDT"
^XMB(3.9,145983,2,523,0)="""RTN"",""RCRPDR"",136,0)"
^XMB(3.9,145983,2,524,0)=" ;"
^XMB(3.9,145983,2,525,0)="""RTN"",""RCRPDR"",137,0)"
^XMB(3.9,145983,2,526,0)="ASKCLR() ; display ""clear print queue?"" prompt"
^XMB(3.9,145983,2,527,0)="""RTN"",""RCRPDR"",138,0)"
^XMB(3.9,145983,2,528,0)=" ;"
^XMB(3.9,145983,2,529,0)="""RTN"",""RCRPDR"",139,0)"
^XMB(3.9,145983,2,530,0)=" ; returns 1 for Yes, 0 for No, -1 for no selection"
^XMB(3.9,145983,2,531,0)="""RTN"",""RCRPDR"",140,0)"
^XMB(3.9,145983,2,532,0)=" ;"
^XMB(3.9,145983,2,533,0)="""RTN"",""RCRPDR"",141,0)"
^XMB(3.9,145983,2,534,0)=" ;Ask if the user wishes to clear the queue"
^XMB(3.9,145983,2,535,0)="""RTN"",""RCRPDR"",142,0)"
^XMB(3.9,145983,2,536,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,X,Y"
^XMB(3.9,145983,2,537,0)="""RTN"",""RCRPDR"",143,0)"
^XMB(3.9,145983,2,538,0)=" S DIR(0)=""Y"",DIR(""B"")=""NO"""
^XMB(3.9,145983,2,539,0)="""RTN"",""RCRPDR"",144,0)"
^XMB(3.9,145983,2,540,0)=" S DIR(""A"")=""Clear the print queue after printing? (Y/N)"""
^XMB(3.9,145983,2,541,0)="""RTN"",""RCRPDR"",145,0)"
^XMB(3.9,145983,2,542,0)=" D ^DIR I $D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) Q -1"
^XMB(3.9,145983,2,543,0)="""RTN"",""RCRPDR"",146,0)"
^XMB(3.9,145983,2,544,0)=" Q:+Y'=1 0"
^XMB(3.9,145983,2,545,0)="""RTN"",""RCRPDR"",147,0)"
^XMB(3.9,145983,2,546,0)=" ;"
^XMB(3.9,145983,2,547,0)="""RTN"",""RCRPDR"",148,0)"
^XMB(3.9,145983,2,548,0)=" ;Confirm that the user wishes to clear the queue"
^XMB(3.9,145983,2,549,0)="""RTN"",""RCRPDR"",149,0)"
^XMB(3.9,145983,2,550,0)=" S DIR(0)=""Y"",DIR(""B"")=""NO"""
^XMB(3.9,145983,2,551,0)="""RTN"",""RCRPDR"",150,0)"
^XMB(3.9,145983,2,552,0)=" S DIR(""A"")=""Are you sure you wish to clear the queue?  If you do, the data in this report will be lost. (Y/N)"""
^XMB(3.9,145983,2,553,0)="""RTN"",""RCRPDR"",151,0)"
^XMB(3.9,145983,2,554,0)=" D ^DIR I $D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) Q -1"
^XMB(3.9,145983,2,555,0)="""RTN"",""RCRPDR"",152,0)"
^XMB(3.9,145983,2,556,0)=" Q Y"
^XMB(3.9,145983,2,557,0)="""RTN"",""RCRPDR"",153,0)"
^XMB(3.9,145983,2,558,0)=" ;"
^XMB(3.9,145983,2,559,0)="""RTN"",""RCRPDR"",154,0)"
^XMB(3.9,145983,2,560,0)="CLRPRNT(RPIEN,TYPE) ; clear print delinquent / print default flag for a given RPP"
^XMB(3.9,145983,2,561,0)="""RTN"",""RCRPDR"",155,0)"
^XMB(3.9,145983,2,562,0)=" ;"
^XMB(3.9,145983,2,563,0)="""RTN"",""RCRPDR"",156,0)"
^XMB(3.9,145983,2,564,0)=" ; RPIEN - repayment plan ien (file 340.5)"
^XMB(3.9,145983,2,565,0)="""RTN"",""RCRPDR"",157,0)"
^XMB(3.9,145983,2,566,0)=" ; TYPE - 0 for print delinquent? field (340.5/1.03), 1 for print default? field (340.5/1.02)"
^XMB(3.9,145983,2,567,0)="""RTN"",""RCRPDR"",158,0)"
^XMB(3.9,145983,2,568,0)=" ;"
^XMB(3.9,145983,2,569,0)="""RTN"",""RCRPDR"",159,0)"
^XMB(3.9,145983,2,570,0)=" N FDA,FLD"
^XMB(3.9,145983,2,571,0)="""RTN"",""RCRPDR"",160,0)"
^XMB(3.9,145983,2,572,0)=" I RPIEN'>0 Q"
^XMB(3.9,145983,2,573,0)="""RTN"",""RCRPDR"",161,0)"
^XMB(3.9,145983,2,574,0)=" S FLD=$S(TYPE:1.02,1:1.03)"
^XMB(3.9,145983,2,575,0)="""RTN"",""RCRPDR"",162,0)"
^XMB(3.9,145983,2,576,0)=" L +^RCRP(340.5,RPIEN):5 I '$T Q"
^XMB(3.9,145983,2,577,0)="""RTN"",""RCRPDR"",163,0)"
^XMB(3.9,145983,2,578,0)=" S FDA(340.5,RPIEN_"","",FLD)=0"
^XMB(3.9,145983,2,579,0)="""RTN"",""RCRPDR"",164,0)"
^XMB(3.9,145983,2,580,0)=" D FILE^DIE("""",""FDA"")"
^XMB(3.9,145983,2,581,0)="""RTN"",""RCRPDR"",165,0)"
^XMB(3.9,145983,2,582,0)=" ; update audit log"
^XMB(3.9,145983,2,583,0)="""RTN"",""RCRPDR"",166,0)"
^XMB(3.9,145983,2,584,0)=" D UPDAUDIT^RCRPU2(RPIEN,DT,""E"",$S(TYPE:""DF"",1:""DL""))"
^XMB(3.9,145983,2,585,0)="""RTN"",""RCRPDR"",167,0)"
^XMB(3.9,145983,2,586,0)=" L -^RCRP(340.5,RPIEN)"
^XMB(3.9,145983,2,587,0)="""RTN"",""RCRPDR"",168,0)"
^XMB(3.9,145983,2,588,0)=" Q"
^XMB(3.9,145983,2,589,0)="""RTN"",""RCRPENTR"")"
^XMB(3.9,145983,2,590,0)="0^3^B72750916"
^XMB(3.9,145983,2,591,0)="""RTN"",""RCRPENTR"",1,0)"
^XMB(3.9,145983,2,592,0)="RCRPENTR ;EDE/SAB - CREATE NEW REPAYMENT PLAN;11/16/2020  7:40 AM"
^XMB(3.9,145983,2,593,0)="""RTN"",""RCRPENTR"",2,0)"
^XMB(3.9,145983,2,594,0)=" ;;4.5;Accounts Receivable;**377,381,378,389,422**;Mar 20, 1995;Build 0"
^XMB(3.9,145983,2,595,0)="""RTN"",""RCRPENTR"",3,0)"
^XMB(3.9,145983,2,596,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145983,2,597,0)="""RTN"",""RCRPENTR"",4,0)"
^XMB(3.9,145983,2,598,0)=" ;"
^XMB(3.9,145983,2,599,0)="""RTN"",""RCRPENTR"",5,0)"
^XMB(3.9,145983,2,600,0)=" Q"
^XMB(3.9,145983,2,601,0)="""RTN"",""RCRPENTR"",6,0)"
^XMB(3.9,145983,2,602,0)="ENTER ; Main Entry Point"
^XMB(3.9,145983,2,603,0)="""RTN"",""RCRPENTR"",7,0)"
^XMB(3.9,145983,2,604,0)=" ;"
^XMB(3.9,145983,2,605,0)="""RTN"",""RCRPENTR"",8,0)"
^XMB(3.9,145983,2,606,0)=" N RCAUTO,RCDBTR,RCCTS,RCACPL,RCTOT,RCBLCH,RCALLFLG,RCDONE,RCSVFLG,Z"
^XMB(3.9,145983,2,607,0)="""RTN"",""RCRPENTR"",9,0)"
^XMB(3.9,145983,2,608,0)=" ;"
^XMB(3.9,145983,2,609,0)="""RTN"",""RCRPENTR"",10,0)"
^XMB(3.9,145983,2,610,0)=" F  D  Q:+RCDBTR=0"
^XMB(3.9,145983,2,611,0)="""RTN"",""RCRPENTR"",11,0)"
^XMB(3.9,145983,2,612,0)=" . ;"
^XMB(3.9,145983,2,613,0)="""RTN"",""RCRPENTR"",12,0)"
^XMB(3.9,145983,2,614,0)=" . S RCDONE=0"
^XMB(3.9,145983,2,615,0)="""RTN"",""RCRPENTR"",13,0)"
^XMB(3.9,145983,2,616,0)=" . W @IOF"
^XMB(3.9,145983,2,617,0)="""RTN"",""RCRPENTR"",14,0)"
^XMB(3.9,145983,2,618,0)=" . ;Ask user for Debtor to build the plan for"
^XMB(3.9,145983,2,619,0)="""RTN"",""RCRPENTR"",15,0)"
^XMB(3.9,145983,2,620,0)=" . S RCDBTR=$$GETDBTR^RCRPU"
^XMB(3.9,145983,2,621,0)="""RTN"",""RCRPENTR"",16,0)"
^XMB(3.9,145983,2,622,0)=" . Q:+RCDBTR=0"
^XMB(3.9,145983,2,623,0)="""RTN"",""RCRPENTR"",17,0)"
^XMB(3.9,145983,2,624,0)=" . ;"
^XMB(3.9,145983,2,625,0)="""RTN"",""RCRPENTR"",18,0)"
^XMB(3.9,145983,2,626,0)=" . ;clear working array"
^XMB(3.9,145983,2,627,0)="""RTN"",""RCRPENTR"",19,0)"
^XMB(3.9,145983,2,628,0)=" . K ^TMP(""RCRPP"",$J)"
^XMB(3.9,145983,2,629,0)="""RTN"",""RCRPENTR"",20,0)"
^XMB(3.9,145983,2,630,0)=" . ;"
^XMB(3.9,145983,2,631,0)="""RTN"",""RCRPENTR"",21,0)"
^XMB(3.9,145983,2,632,0)=" . ;Check for an active Repayment Plan"
^XMB(3.9,145983,2,633,0)="""RTN"",""RCRPENTR"",22,0)"
^XMB(3.9,145983,2,634,0)=" . S RCACPL=$$CHKACT^RCRPU(+RCDBTR)"
^XMB(3.9,145983,2,635,0)="""RTN"",""RCRPENTR"",23,0)"
^XMB(3.9,145983,2,636,0)=" . ;If an active repayment plan print warning message to user and exit."
^XMB(3.9,145983,2,637,0)="""RTN"",""RCRPENTR"",24,0)"
^XMB(3.9,145983,2,638,0)=" . I +RCACPL D  Q"
^XMB(3.9,145983,2,639,0)="""RTN"",""RCRPENTR"",25,0)"
^XMB(3.9,145983,2,640,0)=" . . W !,""This Debtor already has a Repayment Plan that is active."""
^XMB(3.9,145983,2,641,0)="""RTN"",""RCRPENTR"",26,0)"
^XMB(3.9,145983,2,642,0)=" . . W !,""A new plan was not created."",!"
^XMB(3.9,145983,2,643,0)="""RTN"",""RCRPENTR"",27,0)"
^XMB(3.9,145983,2,644,0)=" . . D PAUSE^RCRPU ;Any key to continue prompt"
^XMB(3.9,145983,2,645,0)="""RTN"",""RCRPENTR"",28,0)"
^XMB(3.9,145983,2,646,0)=" . ;Otherwise, print the list of Active Bills"
^XMB(3.9,145983,2,647,0)="""RTN"",""RCRPENTR"",29,0)"
^XMB(3.9,145983,2,648,0)=" . W !,""This Debtor does not have a Repayment Plan"",!!,""List of Active Bills:"",!!"
^XMB(3.9,145983,2,649,0)="""RTN"",""RCRPENTR"",30,0)"
^XMB(3.9,145983,2,650,0)=" . S RCCTS=$$GETACTS^RCRPU(+RCDBTR)"
^XMB(3.9,145983,2,651,0)="""RTN"",""RCRPENTR"",31,0)"
^XMB(3.9,145983,2,652,0)=" . W @IOF"
^XMB(3.9,145983,2,653,0)="""RTN"",""RCRPENTR"",32,0)"
^XMB(3.9,145983,2,654,0)=" . D PRTACTS^RCRPU(+RCCTS)"
^XMB(3.9,145983,2,655,0)="""RTN"",""RCRPENTR"",33,0)"
^XMB(3.9,145983,2,656,0)=" . ;Ask user which Active bills to add to new plan (single, range, or all)"
^XMB(3.9,145983,2,657,0)="""RTN"",""RCRPENTR"",34,0)"
^XMB(3.9,145983,2,658,0)=" . S RCBLCH=$$GETBILLS^RCRPU(+RCCTS)"
^XMB(3.9,145983,2,659,0)="""RTN"",""RCRPENTR"",35,0)"
^XMB(3.9,145983,2,660,0)=" . S RCALLFLG=+RCBLCH,RCBLCH=$P(RCBLCH,U,2)"
^XMB(3.9,145983,2,661,0)="""RTN"",""RCRPENTR"",36,0)"
^XMB(3.9,145983,2,662,0)=" . ;If no bills selected, exit."
^XMB(3.9,145983,2,663,0)="""RTN"",""RCRPENTR"",37,0)"
^XMB(3.9,145983,2,664,0)=" . I RCBLCH="""" D  Q"
^XMB(3.9,145983,2,665,0)="""RTN"",""RCRPENTR"",38,0)"
^XMB(3.9,145983,2,666,0)=" . . W !,""No Bills selected"",!"
^XMB(3.9,145983,2,667,0)="""RTN"",""RCRPENTR"",39,0)"
^XMB(3.9,145983,2,668,0)=" . . D PAUSE^RCRPU"
^XMB(3.9,145983,2,669,0)="""RTN"",""RCRPENTR"",40,0)"
^XMB(3.9,145983,2,670,0)=" . . W @IOF"
^XMB(3.9,145983,2,671,0)="""RTN"",""RCRPENTR"",41,0)"
^XMB(3.9,145983,2,672,0)=" . ;Display Bills selected if All Bills not selected"
^XMB(3.9,145983,2,673,0)="""RTN"",""RCRPENTR"",42,0)"
^XMB(3.9,145983,2,674,0)=" . I 'RCALLFLG D  Q:'RCDONE"
^XMB(3.9,145983,2,675,0)="""RTN"",""RCRPENTR"",43,0)"
^XMB(3.9,145983,2,676,0)=" . . S RCDONE=$$ECHOBL^RCRPADD($P(RCBLCH,U,2))"
^XMB(3.9,145983,2,677,0)="""RTN"",""RCRPENTR"",44,0)"
^XMB(3.9,145983,2,678,0)=" . ;Display total sum of bills chosen and confirm with user, exit if no."
^XMB(3.9,145983,2,679,0)="""RTN"",""RCRPENTR"",45,0)"
^XMB(3.9,145983,2,680,0)=" . S RCTOT=$$TOT^RCRPU(RCBLCH)"
^XMB(3.9,145983,2,681,0)="""RTN"",""RCRPENTR"",46,0)"
^XMB(3.9,145983,2,682,0)=" . I '+RCTOT D  Q"
^XMB(3.9,145983,2,683,0)="""RTN"",""RCRPENTR"",47,0)"
^XMB(3.9,145983,2,684,0)=" . . D PAUSE^RCRPU    ;Any key to continue prompt"
^XMB(3.9,145983,2,685,0)="""RTN"",""RCRPENTR"",48,0)"
^XMB(3.9,145983,2,686,0)=" . S RCAUTO=$$AUTOADD^RCRPU1(0) Q:RCAUTO<0  ; prompt for auto-adding bills to the RPP PRCA*4.5*378"
^XMB(3.9,145983,2,687,0)="""RTN"",""RCRPENTR"",49,0)"
^XMB(3.9,145983,2,688,0)=" . ;Strip confirm flag to get total."
^XMB(3.9,145983,2,689,0)="""RTN"",""RCRPENTR"",50,0)"
^XMB(3.9,145983,2,690,0)=" . S RCTOT=$P(RCTOT,U,2)"
^XMB(3.9,145983,2,691,0)="""RTN"",""RCRPENTR"",51,0)"
^XMB(3.9,145983,2,692,0)=" . ;Get the repayment plan details and save"
^XMB(3.9,145983,2,693,0)="""RTN"",""RCRPENTR"",52,0)"
^XMB(3.9,145983,2,694,0)=" . S RCSVFLG=$$GETDET^RCRPU(RCBLCH,RCTOT,RCDBTR,RCAUTO,""N"",0)  ; PRCA*4.5*422"
^XMB(3.9,145983,2,695,0)="""RTN"",""RCRPENTR"",53,0)"
^XMB(3.9,145983,2,696,0)=" . Q:RCSVFLG<1"
^XMB(3.9,145983,2,697,0)="""RTN"",""RCRPENTR"",54,0)"
^XMB(3.9,145983,2,698,0)=" . ;Display bills at CS and recall them if necessary"
^XMB(3.9,145983,2,699,0)="""RTN"",""RCRPENTR"",55,0)"
^XMB(3.9,145983,2,700,0)=" . D ASKRCL^RCRPU2  ; PRCA*4.5*389"
