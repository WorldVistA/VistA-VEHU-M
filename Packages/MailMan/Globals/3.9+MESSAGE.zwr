^XMB(3.9,145946,2,5615,0)="""RTN"",""IBCNSU21"",167,0)"
^XMB(3.9,145946,2,5616,0)=" ;          ^TMP(""IBCNSU21IX"",$J)   - Current Index of displayed policies"
^XMB(3.9,145946,2,5617,0)="""RTN"",""IBCNSU21"",168,0)"
^XMB(3.9,145946,2,5618,0)=" ;          ^TMP(""IBCNSU21A,$J,IIEN)- Current Array of selected policies"
^XMB(3.9,145946,2,5619,0)="""RTN"",""IBCNSU21"",169,0)"
^XMB(3.9,145946,2,5620,0)=" ; Output:  NUMSEL                  - Current number of selected policies"
^XMB(3.9,145946,2,5621,0)="""RTN"",""IBCNSU21"",170,0)"
^XMB(3.9,145946,2,5622,0)=" ;          ^TMP(""IBCNSU21A,$J,IIEN)- Updated Array of selected policies"
^XMB(3.9,145946,2,5623,0)="""RTN"",""IBCNSU21"",171,0)"
^XMB(3.9,145946,2,5624,0)=" ;          Selected policy is removed from the worklist "
