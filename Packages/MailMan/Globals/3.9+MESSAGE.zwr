^XMB(3.9,145946,2,5252,0)=" . . D SET^VALM10(VALMCNT,LINE,LINE)"
^XMB(3.9,145946,2,5253,0)="""RTN"",""IBCNILK"",458,0)"
^XMB(3.9,145946,2,5254,0)=" . . S ^TMP(""IBCNILKSIX"",$J,ICTR)=IIEN"
^XMB(3.9,145946,2,5255,0)="""RTN"",""IBCNILK"",459,0)"
^XMB(3.9,145946,2,5256,0)=" ;"
^XMB(3.9,145946,2,5257,0)="""RTN"",""IBCNILK"",460,0)"
^XMB(3.9,145946,2,5258,0)=" I VALMCNT=0 D"
^XMB(3.9,145946,2,5259,0)="""RTN"",""IBCNILK"",461,0)"
^XMB(3.9,145946,2,5260,0)=" . S ^TMP(""IBCNILK"",$J,1,0)=""No Selected Insurance Companies were found."""
^XMB(3.9,145946,2,5261,0)="""RTN"",""IBCNILK"",462,0)"
^XMB(3.9,145946,2,5262,0)=" Q"
^XMB(3.9,145946,2,5263,0)="""RTN"",""IBCNILK"",463,0)"
^XMB(3.9,145946,2,5264,0)=" ;"
^XMB(3.9,145946,2,5265,0)="""RTN"",""IBCNILK"",464,0)"
^XMB(3.9,145946,2,5266,0)="EXIT2 ;EP for Show Selections"
^XMB(3.9,145946,2,5267,0)="""RTN"",""IBCNILK"",465,0)"
^XMB(3.9,145946,2,5268,0)=" ; Exit code"
^XMB(3.9,145946,2,5269,0)="""RTN"",""IBCNILK"",466,0)"
^XMB(3.9,145946,2,5270,0)=" ; Input: None"
^XMB(3.9,145946,2,5271,0)="""RTN"",""IBCNILK"",467,0)"
^XMB(3.9,145946,2,5272,0)=" K ^TMP(""IBCNILKS"",$J),^TMP(""IBCNILKSIX"",$J)"
^XMB(3.9,145946,2,5273,0)="""RTN"",""IBCNILK"",468,0)"
^XMB(3.9,145946,2,5274,0)=" D CLEAR^VALM1"
^XMB(3.9,145946,2,5275,0)="""RTN"",""IBCNILK"",469,0)"
^XMB(3.9,145946,2,5276,0)=" Q"
^XMB(3.9,145946,2,5277,0)="""RTN"",""IBCNILK"",470,0)"
^XMB(3.9,145946,2,5278,0)=" ;"
^XMB(3.9,145946,2,5279,0)="""RTN"",""IBCNILK1"")"
^XMB(3.9,145946,2,5280,0)="1^9"
^XMB(3.9,145946,2,5281,0)="""RTN"",""IBCNSU21"")"
^XMB(3.9,145946,2,5282,0)="0^10^B100327781"
^XMB(3.9,145946,2,5283,0)="""RTN"",""IBCNSU21"",1,0)"
^XMB(3.9,145946,2,5284,0)="IBCNSU21 ;ALB/TAZ - INSURANCE PLAN SELECTOR UTILITY ; 13-OCT-2021"
^XMB(3.9,145946,2,5285,0)="""RTN"",""IBCNSU21"",2,0)"
^XMB(3.9,145946,2,5286,0)=" ;;2.0;INTEGRATED BILLING;**702**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,5287,0)="""RTN"",""IBCNSU21"",3,0)"
^XMB(3.9,145946,2,5288,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,5289,0)="""RTN"",""IBCNSU21"",4,0)"
^XMB(3.9,145946,2,5290,0)=" ;"
^XMB(3.9,145946,2,5291,0)="""RTN"",""IBCNSU21"",5,0)"
^XMB(3.9,145946,2,5292,0)="LKP(IBCNS,IBIND,IBACT,IBIGN,IBFIL) ; Select Utility for Insurance Company Plans"
^XMB(3.9,145946,2,5293,0)="""RTN"",""IBCNSU21"",6,0)"
^XMB(3.9,145946,2,5294,0)=" ;"
^XMB(3.9,145946,2,5295,0)="""RTN"",""IBCNSU21"",7,0)"
^XMB(3.9,145946,2,5296,0)=" ;Input:   "
^XMB(3.9,145946,2,5297,0)="""RTN"",""IBCNSU21"",8,0)"
^XMB(3.9,145946,2,5298,0)=" ; IBCNS   - IEN of the Insurance Company (file 36)"
^XMB(3.9,145946,2,5299,0)="""RTN"",""IBCNSU21"",9,0)"
^XMB(3.9,145946,2,5300,0)=" ; IBIND   - Include Individual Plans?  (1 - Yes | 0 - No)"
^XMB(3.9,145946,2,5301,0)="""RTN"",""IBCNSU21"",10,0)"
^XMB(3.9,145946,2,5302,0)=" ; IBACT   - Optional, defaults to 0"
^XMB(3.9,145946,2,5303,0)="""RTN"",""IBCNSU21"",11,0)"
^XMB(3.9,145946,2,5304,0)=" ;           0 - Only allow inactive plans"
^XMB(3.9,145946,2,5305,0)="""RTN"",""IBCNSU21"",12,0)"
^XMB(3.9,145946,2,5306,0)=" ;           1 - Only allow active plans"
^XMB(3.9,145946,2,5307,0)="""RTN"",""IBCNSU21"",13,0)"
^XMB(3.9,145946,2,5308,0)=" ;           2 - Allow both inactive and active plans to be chosen"
^XMB(3.9,145946,2,5309,0)="""RTN"",""IBCNSU21"",14,0)"
^XMB(3.9,145946,2,5310,0)=" ; IBIGN   - 0 - search Group Name"
^XMB(3.9,145946,2,5311,0)="""RTN"",""IBCNSU21"",15,0)"
^XMB(3.9,145946,2,5312,0)=" ;           1 - search Group Number"
^XMB(3.9,145946,2,5313,0)="""RTN"",""IBCNSU21"",16,0)"
^XMB(3.9,145946,2,5314,0)=" ;           2 - search Both Group Name and Group Number"
^XMB(3.9,145946,2,5315,0)="""RTN"",""IBCNSU21"",17,0)"
^XMB(3.9,145946,2,5316,0)=" ; IBFIL  A^B^C"
^XMB(3.9,145946,2,5317,0)="""RTN"",""IBCNSU21"",18,0)"
^XMB(3.9,145946,2,5318,0)=" ;           A - 1 - Search for Group(s) that Begin with specified text (case insensitive)"
^XMB(3.9,145946,2,5319,0)="""RTN"",""IBCNSU21"",19,0)"
^XMB(3.9,145946,2,5320,0)=" ;               2 - Search for Group(s) that Contain the specified text (case insensitive)"
^XMB(3.9,145946,2,5321,0)="""RTN"",""IBCNSU21"",20,0)"
^XMB(3.9,145946,2,5322,0)=" ;               3 - Search for Group(s) in a specified Range (inclusive, case insensitive)"
^XMB(3.9,145946,2,5323,0)="""RTN"",""IBCNSU21"",21,0)"
^XMB(3.9,145946,2,5324,0)=" ;           B - Begin with text if A=1, Contains Text if A=2 or Range start if A=3"
^XMB(3.9,145946,2,5325,0)="""RTN"",""IBCNSU21"",22,0)"
^XMB(3.9,145946,2,5326,0)=" ;           C - Range End text (only present when A=3)"
^XMB(3.9,145946,2,5327,0)="""RTN"",""IBCNSU21"",23,0)"
^XMB(3.9,145946,2,5328,0)=" ;Output:  "
^XMB(3.9,145946,2,5329,0)="""RTN"",""IBCNSU21"",24,0)"
^XMB(3.9,145946,2,5330,0)=" ; ^TMP($J,""IBSEL"",PIEN) - Array of selected plan iens (where PIEN"
^XMB(3.9,145946,2,5331,0)="""RTN"",""IBCNSU21"",25,0)"
^XMB(3.9,145946,2,5332,0)=" ;                     is the plan IEN) is returned if multiple plans may"
^XMB(3.9,145946,2,5333,0)="""RTN"",""IBCNSU21"",26,0)"
^XMB(3.9,145946,2,5334,0)=" ;                     be selected."
^XMB(3.9,145946,2,5335,0)="""RTN"",""IBCNSU21"",27,0)"
^XMB(3.9,145946,2,5336,0)=" ;"
^XMB(3.9,145946,2,5337,0)="""RTN"",""IBCNSU21"",28,0)"
^XMB(3.9,145946,2,5338,0)=" Q:'$G(IBCNS)                               ; No Insurance Company"
^XMB(3.9,145946,2,5339,0)="""RTN"",""IBCNSU21"",29,0)"
^XMB(3.9,145946,2,5340,0)=" N IBMULT,IDX,NUMSEL,SELECTED,VALMBG,VALMCNT,VALMY,VALMHDR"
^XMB(3.9,145946,2,5341,0)="""RTN"",""IBCNSU21"",30,0)"
^XMB(3.9,145946,2,5342,0)=" F IDX=""IBCNSU21"",""IBCNSU21A"",""IBCNSU21IX"" K ^TMP(IDX,$J)"
^XMB(3.9,145946,2,5343,0)="""RTN"",""IBCNSU21"",31,0)"
^XMB(3.9,145946,2,5344,0)=" S IBIND=+$G(IBIND)"
^XMB(3.9,145946,2,5345,0)="""RTN"",""IBCNSU21"",32,0)"
^XMB(3.9,145946,2,5346,0)=" S IBACT=+$G(IBACT)"
^XMB(3.9,145946,2,5347,0)="""RTN"",""IBCNSU21"",33,0)"
^XMB(3.9,145946,2,5348,0)=" S IBFIL=$G(IBFIL)"
^XMB(3.9,145946,2,5349,0)="""RTN"",""IBCNSU21"",34,0)"
^XMB(3.9,145946,2,5350,0)=" S IBMULT=1,NUMSEL=0"
^XMB(3.9,145946,2,5351,0)="""RTN"",""IBCNSU21"",35,0)"
^XMB(3.9,145946,2,5352,0)=" D EN^VALM(""IBCNS PLAN SELECTOR"")"
^XMB(3.9,145946,2,5353,0)="""RTN"",""IBCNSU21"",36,0)"
^XMB(3.9,145946,2,5354,0)=" Q"
^XMB(3.9,145946,2,5355,0)="""RTN"",""IBCNSU21"",37,0)"
^XMB(3.9,145946,2,5356,0)=" ;"
^XMB(3.9,145946,2,5357,0)="""RTN"",""IBCNSU21"",38,0)"
^XMB(3.9,145946,2,5358,0)="INIT ; Build the list of plans."
^XMB(3.9,145946,2,5359,0)="""RTN"",""IBCNSU21"",39,0)"
