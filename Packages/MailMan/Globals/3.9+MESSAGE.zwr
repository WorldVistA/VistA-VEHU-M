^XMB(3.9,145984,2,2006,0)=" . N EPAT,VPAT,SUGVPAT,MTCHDT S EPAT=+$$GET1^DIQ(52.49,+CURREC,.04,""I""),(VPAT,SUGVPAT,MTCHDT)=0"
