^XMB(3.9,145986,2,3619,0)="""RTN"",""FBPCR"",60,0)"
^XMB(3.9,145986,2,3620,0)="Q K ^TMP($J,""FB""),^TMP($J,""FBINSIBAPI""),DIC"
^XMB(3.9,145986,2,3621,0)="""RTN"",""FBPCR"",61,0)"
^XMB(3.9,145986,2,3622,0)=" ;"
^XMB(3.9,145986,2,3623,0)="""RTN"",""FBPCR"",62,0)"
^XMB(3.9,145986,2,3624,0)=" S VAR=""FBINCUNK^FBARRLTC^FBARRLTC(^FBPARTY^FBCOPAY^FBNAME^FBIEN^FBID^FBBEG^FBEND^FBBDATE^FBEDATE^FBPSV^FBPSV(^FBPROG("",VAL=VAR,PGM=""DQ^FBPCR"",IOP=""Q"" D ZIS^FBAAUTL G:FBPOP EXIT"
^XMB(3.9,145986,2,3625,0)="""RTN"",""FBPCR"",63,0)"
^XMB(3.9,145986,2,3626,0)="DQ S $P(FBDASH,""="",80)="""",$P(FBDASH1,""-"",80)="""",FBPG=0,FBCRT=$S($E(IOST,1,2)=""C-"":1,1:0),FBOUT=0,FBBEG=FBBEG-.9 U IO"
^XMB(3.9,145986,2,3627,0)="""RTN"",""FBPCR"",64,0)"
^XMB(3.9,145986,2,3628,0)="SORT ;sort driver for payment output(s)"
^XMB(3.9,145986,2,3629,0)="""RTN"",""FBPCR"",65,0)"
^XMB(3.9,145986,2,3630,0)=" S FBPI=0 F  S FBPI=$O(FBPROG(FBPI)) Q:'FBPI  S FBXPROG=FBPROG(FBPI) D"
^XMB(3.9,145986,2,3631,0)="""RTN"",""FBPCR"",66,0)"
^XMB(3.9,145986,2,3632,0)=" .I FBPI=2 D EN^FBPCR2 ;outpatient payments"
^XMB(3.9,145986,2,3633,0)="""RTN"",""FBPCR"",67,0)"
^XMB(3.9,145986,2,3634,0)=" .I FBPI=3 D EN^FBPCR3 ;pharmacy payments"
^XMB(3.9,145986,2,3635,0)="""RTN"",""FBPCR"",68,0)"
^XMB(3.9,145986,2,3636,0)=" .I FBPI=6!(FBPI=7) S:FBPI=6&($D(FBPROG(7))) FBPI=67 D EN^FBPCR67 S:FBPI=67 FBPI=7 ;civil hospital/cnh payments"
^XMB(3.9,145986,2,3637,0)="""RTN"",""FBPCR"",69,0)"
^XMB(3.9,145986,2,3638,0)="PRINT ;print driver for payment output(s)"
^XMB(3.9,145986,2,3639,0)="""RTN"",""FBPCR"",70,0)"
^XMB(3.9,145986,2,3640,0)=" I $G(^TMP($J,""FBINSIBAPI""))>0 D HDRUNK"
^XMB(3.9,145986,2,3641,0)="""RTN"",""FBPCR"",71,0)"
^XMB(3.9,145986,2,3642,0)=" S FBPI=$O(^TMP($J,""FB"",0)) I FBPI']"""" D WMSG G OUT"
^XMB(3.9,145986,2,3643,0)="""RTN"",""FBPCR"",72,0)"
^XMB(3.9,145986,2,3644,0)=" S FBSTA=0"
^XMB(3.9,145986,2,3645,0)="""RTN"",""FBPCR"",73,0)"
^XMB(3.9,145986,2,3646,0)=" S FBFIRST=0 ; FB*3.5*163"
^XMB(3.9,145986,2,3647,0)="""RTN"",""FBPCR"",74,0)"
^XMB(3.9,145986,2,3648,0)=" S FBPSF=0 F  S FBPSF=$O(^TMP($J,""FB"",FBPSF)) Q:'FBPSF!FBOUT  D STA S FBPT="""" F  S FBPT=$O(^TMP($J,""FB"",FBPSF,FBPT)) Q:FBPT']""""!FBOUT  S DFN=$P(FBPT,"";"",2) D VET S FBPI=0 F  S FBPI=$O(FBPROG(FBPI)) Q:'FBPI  S FBXPROG=FBPROG(FBPI) D  Q:FBOUT"
^XMB(3.9,145986,2,3649,0)="""RTN"",""FBPCR"",75,0)"
^XMB(3.9,145986,2,3650,0)=" .I FBPSF_FBPT'=FBSTA D HDR Q:FBOUT"
^XMB(3.9,145986,2,3651,0)="""RTN"",""FBPCR"",76,0)"
^XMB(3.9,145986,2,3652,0)=" .I FBPI=2,$D(^TMP($J,""FB"",FBPSF,FBPT,FBPI)) D PRINT^FBPCR2 Q"
^XMB(3.9,145986,2,3653,0)="""RTN"",""FBPCR"",77,0)"
^XMB(3.9,145986,2,3654,0)=" .I FBPI=3 D:$D(^TMP($J,""FB"",FBPSF,FBPT,FBPI)) PRINT^FBPCR3 Q"
^XMB(3.9,145986,2,3655,0)="""RTN"",""FBPCR"",78,0)"
^XMB(3.9,145986,2,3656,0)=" .I FBPI=6!(FBPI=7) D:$D(^TMP($J,""FB"",FBPSF,FBPT,FBPI)) PRINT^FBPCR671 Q"
^XMB(3.9,145986,2,3657,0)="""RTN"",""FBPCR"",79,0)"
^XMB(3.9,145986,2,3658,0)="OUT I $G(^TMP($J,""FBINSIBAPI""))>0 D ERRHDL^FBPCR4"
^XMB(3.9,145986,2,3659,0)="""RTN"",""FBPCR"",80,0)"
^XMB(3.9,145986,2,3660,0)=" I FBFIRST=0 D WMSG  ; FB*3.5*163"
^XMB(3.9,145986,2,3661,0)="""RTN"",""FBPCR"",81,0)"
^XMB(3.9,145986,2,3662,0)=" I FBOUT!$D(ZTQUEUED) G EXIT"
^XMB(3.9,145986,2,3663,0)="""RTN"",""FBPCR"",82,0)"
^XMB(3.9,145986,2,3664,0)=" D EXIT G PSF"
^XMB(3.9,145986,2,3665,0)="""RTN"",""FBPCR"",83,0)"
^XMB(3.9,145986,2,3666,0)=" Q"
^XMB(3.9,145986,2,3667,0)="""RTN"",""FBPCR"",84,0)"
^XMB(3.9,145986,2,3668,0)=" ;"
^XMB(3.9,145986,2,3669,0)="""RTN"",""FBPCR"",85,0)"
^XMB(3.9,145986,2,3670,0)="EXCLINS ;create list of insurance type to be excluded ; FB*3.5*135"
^XMB(3.9,145986,2,3671,0)="""RTN"",""FBPCR"",86,0)"
^XMB(3.9,145986,2,3672,0)=" N Y,X,DIC,DTOUT,DUOUT,DIR,DIRUT,DIROUT"
^XMB(3.9,145986,2,3673,0)="""RTN"",""FBPCR"",87,0)"
^XMB(3.9,145986,2,3674,0)=" K FBINEXCL S FBINEXCL=0,X=1"
^XMB(3.9,145986,2,3675,0)="""RTN"",""FBPCR"",88,0)"
^XMB(3.9,145986,2,3676,0)=" W !!!,""Select the TYPE of INSURANCE PLANS to be EXCLUDED from the PCR report:"""
^XMB(3.9,145986,2,3677,0)="""RTN"",""FBPCR"",89,0)"
^XMB(3.9,145986,2,3678,0)=" F  Q:$G(X)=""""  S DIC=""^IBE(355.1,"",DIC(0)=""QEAFIBS"",DIC(""S"")=""I '$P($G(^(0)),U,4)"" K X,Y D ^DIC I $G(Y)>0 S FBINEXCL(+Y)=$P(Y,U,2),FBINEXCL(""INS"",$P(Y,U,2))=+Y"
^XMB(3.9,145986,2,3679,0)="""RTN"",""FBPCR"",90,0)"
^XMB(3.9,145986,2,3680,0)=" S FBINEXCL=""A"",X=0 F  S FBINEXCL=$O(FBINEXCL(""INS"",FBINEXCL)) Q:FBINEXCL=""""  W:'X !!,""Type of Plan selected for EXCLUSION: "" S X=1 W ?41,FBINEXCL,!"
^XMB(3.9,145986,2,3681,0)="""RTN"",""FBPCR"",91,0)"
^XMB(3.9,145986,2,3682,0)=" I $O(FBINEXCL(0)) K X,Y S DIR(0)=""Y"",DIR(""B"")=""NO"",DIR(""A"")=""Recreate Exclusion List"" D ^DIR I Y D EXCLINS"
^XMB(3.9,145986,2,3683,0)="""RTN"",""FBPCR"",92,0)"
^XMB(3.9,145986,2,3684,0)=" K FBINEXCL(""INS"")"
^XMB(3.9,145986,2,3685,0)="""RTN"",""FBPCR"",93,0)"
^XMB(3.9,145986,2,3686,0)=" Q"
^XMB(3.9,145986,2,3687,0)="""RTN"",""FBPCR"",94,0)"
^XMB(3.9,145986,2,3688,0)=" ;"
^XMB(3.9,145986,2,3689,0)="""RTN"",""FBPCR"",95,0)"
^XMB(3.9,145986,2,3690,0)="EXIT ;kill and quit"
^XMB(3.9,145986,2,3691,0)="""RTN"",""FBPCR"",96,0)"
^XMB(3.9,145986,2,3692,0)="KILL ;kill all variables set in the FBPCR* routines, other than fbx"
^XMB(3.9,145986,2,3693,0)="""RTN"",""FBPCR"",97,0)"
^XMB(3.9,145986,2,3694,0)=" D CLOSE^FBAAUTL K ^TMP($J,""FB"")"
^XMB(3.9,145986,2,3695,0)="""RTN"",""FBPCR"",98,0)"
^XMB(3.9,145986,2,3696,0)=" K A1,A2,A3,BEGDATE,C,D,D2,DFN,DIC,DIR,DTOUT,DUOUT,ENDDATE,FBPDXC,FBPARTY,FBCOPAY,FBARRLTC,FBINCUNK,FBFIRST"
^XMB(3.9,145986,2,3697,0)="""RTN"",""FBPCR"",99,0)"
^XMB(3.9,145986,2,3698,0)=" K FBAAA,FBAACPTC,FBAC,FBAP,FBBATCH,FBBDATE,FBBEG,FBBN,FBCATC,FBCNT,FBCP,FBCRT,FBDA1,FBDASH,FBDASH1,FBDATA,FBDOB,FBDRUG,FBDT,FBDT1,FBDOS,FBDX,FBDX1,FBEDATE,FBEND,FBERR,FBFD,FBFD1,FBHEAD"
^XMB(3.9,145986,2,3699,0)="""RTN"",""FBPCR"",100,0)"
^XMB(3.9,145986,2,3700,0)=" K FBI,FBID,FBIEN,FBIN,FBINS,FBINVN,FBIX,FBJ,FBLOC,FBM,FBNAME,FBOB,FBOPI,FBOUT,FBOV,FBP,FBPAT,FBPD,FBPDX,FBPG,FBPI,FBPID,FBPIN,FBPNAME,FBPROC,FBPROC1,FBPROG,FBPSF,FBPSFNAM,FBPSFNUM,FBPSV,FBPT,FBPV,FBQTY,FBREIM,FBRX"
^XMB(3.9,145986,2,3701,0)="""RTN"",""FBPCR"",101,0)"
^XMB(3.9,145986,2,3702,0)=" K FBSC,FBSL,FBSTA,FBSTR,FBSUSP,FBTA,FBTYPE,FBV,FBVCHAIN,FBVEN,FBVENID,FBVNAME,FBVI,FBVID,FBVP,FBXPROG,FBY,FBZ,I,IOP,J,K,L,M,N,PGM,T,V,VA,VAERR,VAL,VAR,VAUTNI,VAUTSTR,VAUTVB,X,Y,Z,FBSTANPI,FBXX"
^XMB(3.9,145986,2,3703,0)="""RTN"",""FBPCR"",102,0)"
^XMB(3.9,145986,2,3704,0)=" Q"
^XMB(3.9,145986,2,3705,0)="""RTN"",""FBPCR"",103,0)"
^XMB(3.9,145986,2,3706,0)=" ;"
^XMB(3.9,145986,2,3707,0)="""RTN"",""FBPCR"",104,0)"
^XMB(3.9,145986,2,3708,0)="WMSG ;write message if no matches found"
^XMB(3.9,145986,2,3709,0)="""RTN"",""FBPCR"",105,0)"
^XMB(3.9,145986,2,3710,0)=" D HDR W !!?3,""There are no potential cost recoveries on file"""
^XMB(3.9,145986,2,3711,0)="""RTN"",""FBPCR"",106,0)"
^XMB(3.9,145986,2,3712,0)=" W !?5,""for specified date range:  "",$$DATX^FBAAUTL(FBBDATE),"" through "",$$DATX^FBAAUTL(FBEDATE)"
^XMB(3.9,145986,2,3713,0)="""RTN"",""FBPCR"",107,0)"
^XMB(3.9,145986,2,3714,0)=" I 'FBPSV D"
^XMB(3.9,145986,2,3715,0)="""RTN"",""FBPCR"",108,0)"
^XMB(3.9,145986,2,3716,0)=" .W "","",!?5,""and selected Primary Service Area(s):"""
^XMB(3.9,145986,2,3717,0)="""RTN"",""FBPCR"",109,0)"
^XMB(3.9,145986,2,3718,0)=" .S FBPSF=0 F  S FBPSF=$O(FBPSV(FBPSF)) Q:'FBPSF  W !?31,$G(FBPSV(FBPSF))"
^XMB(3.9,145986,2,3719,0)="""RTN"",""FBPCR"",110,0)"
^XMB(3.9,145986,2,3720,0)=" E  W !?5,""and ALL Primary Service Areas """
^XMB(3.9,145986,2,3721,0)="""RTN"",""FBPCR"",111,0)"
^XMB(3.9,145986,2,3722,0)=" W ""."",*7,!!"
^XMB(3.9,145986,2,3723,0)="""RTN"",""FBPCR"",112,0)"
^XMB(3.9,145986,2,3724,0)=" Q"
^XMB(3.9,145986,2,3725,0)="""RTN"",""FBPCR"",113,0)"
^XMB(3.9,145986,2,3726,0)=" ;"
^XMB(3.9,145986,2,3727,0)="""RTN"",""FBPCR"",114,0)"
^XMB(3.9,145986,2,3728,0)="CATC(DFN,FBDT,FBPOV) ; "
^XMB(3.9,145986,2,3729,0)="""RTN"",""FBPCR"",115,0)"
^XMB(3.9,145986,2,3730,0)=" ;treats all copays as Means test for date < 3020705 (JULY 5,2002)"
^XMB(3.9,145986,2,3731,0)="""RTN"",""FBPCR"",116,0)"
^XMB(3.9,145986,2,3732,0)=" ;check if patient is liable for copay"
^XMB(3.9,145986,2,3733,0)="""RTN"",""FBPCR"",117,0)"
^XMB(3.9,145986,2,3734,0)=" ;INPUT:"
^XMB(3.9,145986,2,3735,0)="""RTN"",""FBPCR"",118,0)"
^XMB(3.9,145986,2,3736,0)=" ; DFN = IEN of Patient file"
^XMB(3.9,145986,2,3737,0)="""RTN"",""FBPCR"",119,0)"
^XMB(3.9,145986,2,3738,0)=" ; FBDT= Date"
^XMB(3.9,145986,2,3739,0)="""RTN"",""FBPCR"",120,0)"
^XMB(3.9,145986,2,3740,0)=" ; FBPOV = POV code (for LTC determination)"
^XMB(3.9,145986,2,3741,0)="""RTN"",""FBPCR"",121,0)"
^XMB(3.9,145986,2,3742,0)=" ;OUTPUT:"
^XMB(3.9,145986,2,3743,0)="""RTN"",""FBPCR"",122,0)"
^XMB(3.9,145986,2,3744,0)=" ;0 - the patient is not liable for any co-pay;"
^XMB(3.9,145986,2,3745,0)="""RTN"",""FBPCR"",123,0)"
^XMB(3.9,145986,2,3746,0)=" ;1 - if Means test catc or pending adjudication and agree to pay deduc"
^XMB(3.9,145986,2,3747,0)="""RTN"",""FBPCR"",124,0)"
^XMB(3.9,145986,2,3748,0)=" ;2 - the patient is liable for LTC co-pay;"
^XMB(3.9,145986,2,3749,0)="""RTN"",""FBPCR"",125,0)"
^XMB(3.9,145986,2,3750,0)=" ;3 - no 1010EC on file"
^XMB(3.9,145986,2,3751,0)="""RTN"",""FBPCR"",126,0)"
^XMB(3.9,145986,2,3752,0)=" ;4 - more analysis is needed to determine the patient liability"
^XMB(3.9,145986,2,3753,0)="""RTN"",""FBPCR"",127,0)"
^XMB(3.9,145986,2,3754,0)=" N FBLTC,FBISLTC"
^XMB(3.9,145986,2,3755,0)="""RTN"",""FBPCR"",128,0)"
^XMB(3.9,145986,2,3756,0)=" S FBCATC=$$BIL^DGMTUB(DFN,FBDT)"
^XMB(3.9,145986,2,3757,0)="""RTN"",""FBPCR"",129,0)"
^XMB(3.9,145986,2,3758,0)=" I '$D(FBPOV)!(FBDT<3020705) Q $S(FBCATC:1,1:0)"
^XMB(3.9,145986,2,3759,0)="""RTN"",""FBPCR"",130,0)"
^XMB(3.9,145986,2,3760,0)=" S FBISLTC=$$ISLTC^FBPCR4(FBPOV)"
^XMB(3.9,145986,2,3761,0)="""RTN"",""FBPCR"",131,0)"
^XMB(3.9,145986,2,3762,0)=" I FBISLTC=0 Q $S(FBCATC:1,1:0)  ;Means test"
^XMB(3.9,145986,2,3763,0)="""RTN"",""FBPCR"",132,0)"
^XMB(3.9,145986,2,3764,0)=" I FBISLTC=2 Q 0  ;LTC-service, but LTC-copay is not applicable"
^XMB(3.9,145986,2,3765,0)="""RTN"",""FBPCR"",133,0)"
^XMB(3.9,145986,2,3766,0)=" S FBLTC=$$LTCST^FBPCR4(DFN,FBDT)"
^XMB(3.9,145986,2,3767,0)="""RTN"",""FBPCR"",134,0)"
^XMB(3.9,145986,2,3768,0)=" I FBLTC=2 Q 2  ;LTC copay"
^XMB(3.9,145986,2,3769,0)="""RTN"",""FBPCR"",135,0)"
^XMB(3.9,145986,2,3770,0)=" I FBLTC=0 Q 3  ;no 1010EC on file"
^XMB(3.9,145986,2,3771,0)="""RTN"",""FBPCR"",136,0)"
^XMB(3.9,145986,2,3772,0)=" I FBLTC=4 Q 4  ;more info needed"
^XMB(3.9,145986,2,3773,0)="""RTN"",""FBPCR"",137,0)"
^XMB(3.9,145986,2,3774,0)=" Q 0  ;exemption from LTC -copay"
^XMB(3.9,145986,2,3775,0)="""RTN"",""FBPCR"",138,0)"
^XMB(3.9,145986,2,3776,0)=" ;"
^XMB(3.9,145986,2,3777,0)="""RTN"",""FBPCR"",139,0)"
^XMB(3.9,145986,2,3778,0)="VET ;set vet name/ssn/dob info"
^XMB(3.9,145986,2,3779,0)="""RTN"",""FBPCR"",140,0)"
^XMB(3.9,145986,2,3780,0)=" ;INPUT:  DFN  = IEN of Patient file"
^XMB(3.9,145986,2,3781,0)="""RTN"",""FBPCR"",141,0)"
^XMB(3.9,145986,2,3782,0)=" ;      FBPI = IEN of fee program (optional)"
^XMB(3.9,145986,2,3783,0)="""RTN"",""FBPCR"",142,0)"
^XMB(3.9,145986,2,3784,0)=" ;OUTPUT:  FBPNAME = Patient's name"
^XMB(3.9,145986,2,3785,0)="""RTN"",""FBPCR"",143,0)"
^XMB(3.9,145986,2,3786,0)=" ;      FBPID   = Patient's pid"
^XMB(3.9,145986,2,3787,0)="""RTN"",""FBPCR"",144,0)"
^XMB(3.9,145986,2,3788,0)=" ;      FBDOB   = Patient's dob (if pharmacy fee program)"
^XMB(3.9,145986,2,3789,0)="""RTN"",""FBPCR"",145,0)"
^XMB(3.9,145986,2,3790,0)=" N N"
^XMB(3.9,145986,2,3791,0)="""RTN"",""FBPCR"",146,0)"
^XMB(3.9,145986,2,3792,0)=" S N=$G(^DPT(DFN,0)),FBPNAME=$P(N,U),FBPID=$$SSN^FBAAUTL(DFN),FBDOB=$$FMTE^XLFDT($P(N,U,3))"
^XMB(3.9,145986,2,3793,0)="""RTN"",""FBPCR"",147,0)"
^XMB(3.9,145986,2,3794,0)=" Q"
^XMB(3.9,145986,2,3795,0)="""RTN"",""FBPCR"",148,0)"
^XMB(3.9,145986,2,3796,0)=" ;"
^XMB(3.9,145986,2,3797,0)="""RTN"",""FBPCR"",149,0)"
^XMB(3.9,145986,2,3798,0)="STA ;set station name & number"
^XMB(3.9,145986,2,3799,0)="""RTN"",""FBPCR"",150,0)"
^XMB(3.9,145986,2,3800,0)=" ;INPUT = FBPSF - IEN to institution file"
^XMB(3.9,145986,2,3801,0)="""RTN"",""FBPCR"",151,0)"
^XMB(3.9,145986,2,3802,0)=" ;OUTPUT = FBPSFNAM = station name"
^XMB(3.9,145986,2,3803,0)="""RTN"",""FBPCR"",152,0)"
^XMB(3.9,145986,2,3804,0)=" ;      FBPSFNUM = station number"
^XMB(3.9,145986,2,3805,0)="""RTN"",""FBPCR"",153,0)"
^XMB(3.9,145986,2,3806,0)=" S FBPSFNAM=$P($G(^DIC(4,FBPSF,0)),U),FBPSFNUM=$P($G(^DIC(4,FBPSF,99)),U)"
^XMB(3.9,145986,2,3807,0)="""RTN"",""FBPCR"",154,0)"
^XMB(3.9,145986,2,3808,0)=" S:FBPSFNAM=+FBPSFNAM FBPSFNAM=""UNKNOWN"""
^XMB(3.9,145986,2,3809,0)="""RTN"",""FBPCR"",155,0)"
