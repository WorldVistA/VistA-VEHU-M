^XMB(3.9,145946,2,4906,0)=" S IIENS=$$SELINS(1,PROMPT,.DLINE,1,""IBCNILKIX"")"
^XMB(3.9,145946,2,4907,0)="""RTN"",""IBCNILK"",285,0)"
^XMB(3.9,145946,2,4908,0)=" I IIENS="""" S VALMBCK=""R"" Q                 ; None Selected"
