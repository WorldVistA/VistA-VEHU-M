^XMB(3.9,145956,2,2235,0)="""RTN"",""TIUTIUS"",175,0)"
^XMB(3.9,145956,2,2236,0)=" N AUMTJ,AUMTK,AUMTL,AUMTX"
^XMB(3.9,145956,2,2237,0)="""RTN"",""TIUTIUS"",176,0)"
^XMB(3.9,145956,2,2238,0)=" S (AUMTJ,AUMTK,AUMTL)=0"
^XMB(3.9,145956,2,2239,0)="""RTN"",""TIUTIUS"",177,0)"
^XMB(3.9,145956,2,2240,0)=" F  S AUMTL=$O(^TIU(8925.71,AUMTI,4.5,AUMTL)) Q:'AUMTL  D"
^XMB(3.9,145956,2,2241,0)="""RTN"",""TIUTIUS"",178,0)"
^XMB(3.9,145956,2,2242,0)=" . S AUMTL(0)=^TIU(8925.71,AUMTI,4.5,AUMTL,0)"
^XMB(3.9,145956,2,2243,0)="""RTN"",""TIUTIUS"",179,0)"
^XMB(3.9,145956,2,2244,0)=" . S AUMTK=$P(AUMTL(0),""^"")"
^XMB(3.9,145956,2,2245,0)="""RTN"",""TIUTIUS"",180,0)"
^XMB(3.9,145956,2,2246,0)=" . I AUMTK<4 D  Q"
