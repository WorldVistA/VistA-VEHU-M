^XMB(3.9,145980,2,6536,0)=" S SD409840REC=^SDEC(409.84,APPTIEN,0) ; APPT"
^XMB(3.9,145980,2,6537,0)="""RTN"",""SDESRECALLREQ"",15,0)"
^XMB(3.9,145980,2,6538,0)=" ; Only re-open Appt Request for approved Cancellation Reasons VSE-1112"
^XMB(3.9,145980,2,6539,0)="""RTN"",""SDESRECALLREQ"",16,0)"
^XMB(3.9,145980,2,6540,0)=" S CANREASONPTR=$G(APPTDAT(409.84,APPTIENS,.122,""I""))"
^XMB(3.9,145980,2,6541,0)="""RTN"",""SDESRECALLREQ"",17,0)"
