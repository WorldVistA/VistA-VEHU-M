^XMB(3.9,145986,2,1657,0)="""RTN"",""FBAAVS"",16,0)"
^XMB(3.9,145986,2,1658,0)="HED W @IOF,""Patient Name: "",$P(^DPT(DFN,0),""^"",1),?50,""SSN: "",$P(^(0),""^"",9),!!,?2,""VENDOR: "",$P(^FBAAV(DA,0),""^"",1),!?5,$P(^FBAAV(DA,0),""^"",3) S FBST=$P(^FBAAV(DA,0),""^"",5)"
^XMB(3.9,145986,2,1659,0)="""RTN"",""FBAAVS"",17,0)"
^XMB(3.9,145986,2,1660,0)=" W !?5,$P(^FBAAV(DA,0),""^"",4)_"", ""_$P($G(^DIC(5,+FBST,0)),U)_""   ""_$P(^FBAAV(DA,0),""^"",6)"
^XMB(3.9,145986,2,1661,0)="""RTN"",""FBAAVS"",18,0)"
^XMB(3.9,145986,2,1662,0)=" W !,?10,""('*' Reimb. to Patient  '+' Cancel. Activity   '#' Voided Payment)"""
^XMB(3.9,145986,2,1663,0)="""RTN"",""FBAAVS"",19,0)"
^XMB(3.9,145986,2,1664,0)=" W !,?2,""SVC DATE"",?12,""CPT-MOD"",?22,""REV.CODE"",?32,""UNITS"",?39,""PATIENT ACCOUNT NO."",?61,""INVOICE #"",?72,""BATCH #"""
^XMB(3.9,145986,2,1665,0)="""RTN"",""FBAAVS"",20,0)"
^XMB(3.9,145986,2,1666,0)=" W !,?12,""AMT CLAIMED"",?25,""AMT PAID"",?38,""ADJ CODE"",?48,""ADJ AMOUNT"",?65,""REMIT REMARK"""
^XMB(3.9,145986,2,1667,0)="""RTN"",""FBAAVS"",21,0)"
^XMB(3.9,145986,2,1668,0)=" W !,Q,!"
^XMB(3.9,145986,2,1669,0)="""RTN"",""FBAAVS"",22,0)"
^XMB(3.9,145986,2,1670,0)=" Q"
^XMB(3.9,145986,2,1671,0)="""RTN"",""FBAAVS"",23,0)"
^XMB(3.9,145986,2,1672,0)="WRT I $E(IOST,1,2)[""C-"",$Y+3>IOSL S DIR(0)=""E"" D ^DIR K DIR S:'Y FBAAOUT=1 Q:FBAAOUT  D HED"
^XMB(3.9,145986,2,1673,0)="""RTN"",""FBAAVS"",24,0)"
^XMB(3.9,145986,2,1674,0)=" S FBAADT=$P(^FBAAC(DFN,1,DA,1,B,0),""^"",1),FBAADT=$E(FBAADT,4,5)_""/""_$E(FBAADT,6,7)_""/""_$E(FBAADT,2,3),B1=$P(L,""^"",8),B2=$S(B1="""":"""",$D(^FBAA(161.7,B1,0)):$P(^FBAA(161.7,B1,0),""^"",1),1:"""")"
^XMB(3.9,145986,2,1675,0)="""RTN"",""FBAAVS"",25,0)"
^XMB(3.9,145986,2,1676,0)=" S TAMT=$FN($P(L,U,4),"""",2)"
^XMB(3.9,145986,2,1677,0)="""RTN"",""FBAAVS"",26,0)"
^XMB(3.9,145986,2,1678,0)=" S A1=$P(L,""^"",2)+.0001,A2=$P(L,""^"",3)+.0001,A1=$P(A1,""."",1)_"".""_$E($P(A1,""."",2),1,2),A2=$P(A2,""."",1)_"".""_$E($P(A2,""."",2),1,2),FBIN=$P(L,""^"",16)"
^XMB(3.9,145986,2,1679,0)="""RTN"",""FBAAVS"",27,0)"
^XMB(3.9,145986,2,1680,0)=" S FBAACPT=$$CPT^FBAAUTL4($P(L,""^"",1))"
^XMB(3.9,145986,2,1681,0)="""RTN"",""FBAAVS"",28,0)"
^XMB(3.9,145986,2,1682,0)=" S FBUNITS=$P(FBY2,U,14)"
^XMB(3.9,145986,2,1683,0)="""RTN"",""FBAAVS"",29,0)"
^XMB(3.9,145986,2,1684,0)=" S FBCSID=$P(FBY2,U,16)"
^XMB(3.9,145986,2,1685,0)="""RTN"",""FBAAVS"",30,0)"
^XMB(3.9,145986,2,1686,0)=" S FBFPPSC=$P(FBY3,U)"
^XMB(3.9,145986,2,1687,0)="""RTN"",""FBAAVS"",31,0)"
^XMB(3.9,145986,2,1688,0)=" S FBFPPSL=$P(FBY3,U,2)"
^XMB(3.9,145986,2,1689,0)="""RTN"",""FBAAVS"",32,0)"
^XMB(3.9,145986,2,1690,0)=" D FBCKO^FBAACCB2(DFN,DA,B,K)"
^XMB(3.9,145986,2,1691,0)="""RTN"",""FBAAVS"",33,0)"
^XMB(3.9,145986,2,1692,0)=" W !,$S(ZS=""R"":""*"",1:""""),$S(V=""VP"":""#"",1:""""),$S($G(FBCAN)]"""":""+"",1:"""")"
^XMB(3.9,145986,2,1693,0)="""RTN"",""FBAAVS"",34,0)"
^XMB(3.9,145986,2,1694,0)=" W ?2,FBAADT,?12,FBAACPT_$S($G(FBMODLE)]"""":""-""_$P(FBMODLE,"",""),1:""""),?22,FBAARCE,?32,FBUNITS,?39,FBCSID,?61,FBIN,?72,B2"
^XMB(3.9,145986,2,1695,0)="""RTN"",""FBAAVS"",35,0)"
^XMB(3.9,145986,2,1696,0)=" ; write additional modifiers (if any)"
^XMB(3.9,145986,2,1697,0)="""RTN"",""FBAAVS"",36,0)"
^XMB(3.9,145986,2,1698,0)=" I $P($G(FBMODLE),"","",2)]"""" D  Q:FBAAOUT"
^XMB(3.9,145986,2,1699,0)="""RTN"",""FBAAVS"",37,0)"
^XMB(3.9,145986,2,1700,0)=" . N FBI,FBMOD"
^XMB(3.9,145986,2,1701,0)="""RTN"",""FBAAVS"",38,0)"
^XMB(3.9,145986,2,1702,0)=" . F FBI=2:1 S FBMOD=$P(FBMODLE,"","",FBI) Q:FBMOD=""""  D  Q:FBAAOUT"
^XMB(3.9,145986,2,1703,0)="""RTN"",""FBAAVS"",39,0)"
^XMB(3.9,145986,2,1704,0)=" . . I $Y+4>IOSL D  Q:FBAAOUT"
^XMB(3.9,145986,2,1705,0)="""RTN"",""FBAAVS"",40,0)"
^XMB(3.9,145986,2,1706,0)=" . . . I $E(IOST,1,2)=""C-"" S DIR(0)=""E"" D ^DIR K DIR I 'Y S FBAAOUT=1 Q"
^XMB(3.9,145986,2,1707,0)="""RTN"",""FBAAVS"",41,0)"
^XMB(3.9,145986,2,1708,0)=" . . . D HED W !,""(continued)"""
^XMB(3.9,145986,2,1709,0)="""RTN"",""FBAAVS"",42,0)"
^XMB(3.9,145986,2,1710,0)=" . . W !,?17,""-"",FBMOD"
^XMB(3.9,145986,2,1711,0)="""RTN"",""FBAAVS"",43,0)"
^XMB(3.9,145986,2,1712,0)=" W !?12,""$"",$J(A1,8),?25,""$"",$J(A2,8)"
^XMB(3.9,145986,2,1713,0)="""RTN"",""FBAAVS"",44,0)"
^XMB(3.9,145986,2,1714,0)=" ; write adjustment reasons, if null then write suspend code"
^XMB(3.9,145986,2,1715,0)="""RTN"",""FBAAVS"",45,0)"
^XMB(3.9,145986,2,1716,0)=" W ?38,$S(FBADJLR]"""":FBADJLR,1:T)"
^XMB(3.9,145986,2,1717,0)="""RTN"",""FBAAVS"",46,0)"
^XMB(3.9,145986,2,1718,0)=" ; write adjustment amounts, if null then write amount suspended"
^XMB(3.9,145986,2,1719,0)="""RTN"",""FBAAVS"",47,0)"
^XMB(3.9,145986,2,1720,0)=" W ?48,""$"",$S(FBADJLA]"""":FBADJLA,1:TAMT)"
^XMB(3.9,145986,2,1721,0)="""RTN"",""FBAAVS"",48,0)"
^XMB(3.9,145986,2,1722,0)=" W ?65,FBRRMKL"
^XMB(3.9,145986,2,1723,0)="""RTN"",""FBAAVS"",49,0)"
^XMB(3.9,145986,2,1724,0)=" I FBFPPSC]"""" W !,?12,""FPPS Claim ID: "",FBFPPSC,?40,""FPPS Line Item: "",FBFPPSL"
^XMB(3.9,145986,2,1725,0)="""RTN"",""FBAAVS"",50,0)"
^XMB(3.9,145986,2,1726,0)=" D PMNT^FBAACCB2"
^XMB(3.9,145986,2,1727,0)="""RTN"",""FBAAVS"",51,0)"
^XMB(3.9,145986,2,1728,0)=" Q"
^XMB(3.9,145986,2,1729,0)="""RTN"",""FBAAVS"",52,0)"
^XMB(3.9,145986,2,1730,0)="Q K DIC,DIE,DA,DF,DA(1),FBAAOUT,A,A1,A2,B1,B2,D1,FBAACPT,FBAADT,FBAAPD,FBIN,K,L,Q,X,Y,ZS,V,FBST,FBMODLE"
^XMB(3.9,145986,2,1731,0)="""RTN"",""FBAAVS"",53,0)"
^XMB(3.9,145986,2,1732,0)=" Q"
^XMB(3.9,145986,2,1733,0)="""RTN"",""FBAAVS"",54,0)"
^XMB(3.9,145986,2,1734,0)="MORE N FBX"
^XMB(3.9,145986,2,1735,0)="""RTN"",""FBAAVS"",55,0)"
^XMB(3.9,145986,2,1736,0)=" S FBMODLE=$$MODL^FBAAUTL4(""^FBAAC(""_DFN_"",1,""_DA_"",1,""_B_"",1,""_K_"",""""M"""")"",""E"")"
^XMB(3.9,145986,2,1737,0)="""RTN"",""FBAAVS"",56,0)"
^XMB(3.9,145986,2,1738,0)=" S T=$P(L,""^"",5),T=$S(T>9:$P(^FBAA(161.27,T,0),""^""),1:T),ZS=$P(L,""^"",20),V=$P(L,""^"",21)"
^XMB(3.9,145986,2,1739,0)="""RTN"",""FBAAVS"",57,0)"
^XMB(3.9,145986,2,1740,0)=" S FBY2=$G(^FBAAC(DFN,1,DA,1,B,1,K,2))"
^XMB(3.9,145986,2,1741,0)="""RTN"",""FBAAVS"",58,0)"
^XMB(3.9,145986,2,1742,0)=" S FBY3=$G(^FBAAC(DFN,1,DA,1,B,1,K,3))"
^XMB(3.9,145986,2,1743,0)="""RTN"",""FBAAVS"",59,0)"
^XMB(3.9,145986,2,1744,0)=" S FBX=$$ADJLRA^FBAAFA(K_"",""_B_"",""_DA_"",""_DFN_"","")"
^XMB(3.9,145986,2,1745,0)="""RTN"",""FBAAVS"",60,0)"
^XMB(3.9,145986,2,1746,0)=" S FBADJLR=$P(FBX,U)"
^XMB(3.9,145986,2,1747,0)="""RTN"",""FBAAVS"",61,0)"
^XMB(3.9,145986,2,1748,0)=" S FBADJLA=$P(FBX,U,2)"
^XMB(3.9,145986,2,1749,0)="""RTN"",""FBAAVS"",62,0)"
^XMB(3.9,145986,2,1750,0)=" S FBRRMKL=$$RRL^FBAAFR(K_"",""_B_"",""_DA_"",""_DFN_"","")"
^XMB(3.9,145986,2,1751,0)="""RTN"",""FBAAVS"",63,0)"
^XMB(3.9,145986,2,1752,0)=" S FBAARCE=$$GET1^DIQ(162.03,K_"",""_B_"",""_DA_"",""_DFN_"","",48)"
^XMB(3.9,145986,2,1753,0)="""RTN"",""FBAAVS"",64,0)"
^XMB(3.9,145986,2,1754,0)=" Q"
^XMB(3.9,145986,2,1755,0)="""RTN"",""FBAAVS"",65,0)"
^XMB(3.9,145986,2,1756,0)="NOCL W !,""Vendor has no Payment data for this Patient!"",! G RDV"
^XMB(3.9,145986,2,1757,0)="""RTN"",""FBCHCR"")"
^XMB(3.9,145986,2,1758,0)="0^7^B27602540"
^XMB(3.9,145986,2,1759,0)="""RTN"",""FBCHCR"",1,0)"
^XMB(3.9,145986,2,1760,0)="FBCHCR ;AISC/CMR-CIVIL HOSPITAL COST REPORT ;7/23/01"
^XMB(3.9,145986,2,1761,0)="""RTN"",""FBCHCR"",2,0)"
^XMB(3.9,145986,2,1762,0)=" ;;3.5;FEE BASIS;**32**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,1763,0)="""RTN"",""FBCHCR"",3,0)"
^XMB(3.9,145986,2,1764,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,1765,0)="""RTN"",""FBCHCR"",4,0)"
^XMB(3.9,145986,2,1766,0)=" ;FBTP SET IN OPTION ENTRANCE ACTION (6=CH/7=CNH)"
^XMB(3.9,145986,2,1767,0)="""RTN"",""FBCHCR"",5,0)"
^XMB(3.9,145986,2,1768,0)=" ;FBREF SET IN OPTION ENTRANCE ACTION (FBREF=""FB7078"" OR ""FB583"")"
^XMB(3.9,145986,2,1769,0)="""RTN"",""FBCHCR"",6,0)"
^XMB(3.9,145986,2,1770,0)=" D DATE^FBAAUTL G END:FBPOP"
^XMB(3.9,145986,2,1771,0)="""RTN"",""FBCHCR"",7,0)"
^XMB(3.9,145986,2,1772,0)=" ; if UC ask if report for just mill-bill (1725) or just non-mill bill"
^XMB(3.9,145986,2,1773,0)="""RTN"",""FBCHCR"",8,0)"
^XMB(3.9,145986,2,1774,0)=" S FB1725R="""""
^XMB(3.9,145986,2,1775,0)="""RTN"",""FBCHCR"",9,0)"
^XMB(3.9,145986,2,1776,0)=" I FBTP=6,FBREF=""FB583"" S FB1725R=$$ASKMB^FBUCUTL9 I FB1725R="""" G END"
^XMB(3.9,145986,2,1777,0)="""RTN"",""FBCHCR"",10,0)"
^XMB(3.9,145986,2,1778,0)=" S DIR(0)=""S^D:DETAILED REPORT;S:SUMMARY ONLY"",DIR(""A"")=""Choose Report Type"",DIR(""B"")=""S"" D ^DIR K DIR G END:$D(DIRUT)  S FBRT=Y W !"
^XMB(3.9,145986,2,1779,0)="""RTN"",""FBCHCR"",11,0)"
^XMB(3.9,145986,2,1780,0)=" S VAR=""BEGDATE^ENDDATE^FBTP^FBREF^FBRT^FB1725R"",VAL=BEGDATE_""^""_ENDDATE_""^""_FBTP_""^""_FBREF_""^""_FBRT,PGM=""START^FBCHCR"",IOP=""Q"" D ZIS^FBAAUTL G END:FBPOP"
^XMB(3.9,145986,2,1781,0)="""RTN"",""FBCHCR"",12,0)"
^XMB(3.9,145986,2,1782,0)="START K ^TMP($J,""FBCHCR"") S (FBIEN,FBCTR,FBTAMT,FBTLOS,FBAAOUT)=0,BEGDT=BEGDATE-1,Q=""-"",$P(Q,""-"",30)=""-"",QQ=""="",$P(QQ,""="",80)=""="""
^XMB(3.9,145986,2,1783,0)="""RTN"",""FBCHCR"",13,0)"
^XMB(3.9,145986,2,1784,0)=" F FBDT=BEGDT:0 S FBDT=$O(^FBAAI(""AD"",FBDT)) Q:FBDT'>0!(FBDT>ENDDATE)  F  S FBIEN=$O(^FBAAI(""AD"",FBDT,FBIEN)) Q:FBIEN'>0  S FBTYPE=$P($G(^FBAAI(FBIEN,0)),""^"",12) I FBTYPE]"""",(FBTP=FBTYPE) D"
^XMB(3.9,145986,2,1785,0)="""RTN"",""FBCHCR"",14,0)"
^XMB(3.9,145986,2,1786,0)=" .S FBINV=^FBAAI(FBIEN,0),FBPTC=$P(FBINV,""^"",19) S:FBPTC="""" FBPTC=""99"" S @FBREF=$S($P(FBINV,""^"",5)[FBREF:+$P(FBINV,""^"",5),1:"""") Q:@FBREF<1"
^XMB(3.9,145986,2,1787,0)="""RTN"",""FBCHCR"",15,0)"
^XMB(3.9,145986,2,1788,0)=" .;if UC and user requested just Mill Bill or just non-Mill Bill then"
^XMB(3.9,145986,2,1789,0)="""RTN"",""FBCHCR"",16,0)"
^XMB(3.9,145986,2,1790,0)=" .;check claim and skip when appropriate"
^XMB(3.9,145986,2,1791,0)="""RTN"",""FBCHCR"",17,0)"
^XMB(3.9,145986,2,1792,0)=" .I FBTP=6,FBREF=""FB583"",""^M^N^""[(U_FB1725R_U),$P(FBINV,""^"",5)[FBREF S FB1725=+$P($G(^FB583(+$P(FBINV,U,5),0)),U,28) Q:$S(FB1725R=""M""&'FB1725:1,FB1725R=""N""&FB1725:1,1:0)"
^XMB(3.9,145986,2,1793,0)="""RTN"",""FBCHCR"",18,0)"
^XMB(3.9,145986,2,1794,0)=" .S DFN=$P(FBINV,""^"",4) Q:'$G(DFN)  S FBNAME=$$NAME^FBCHREQ2(DFN),FBAMT=$P(FBINV,""^"",9),FBDRG=$P(FBINV,""^"",24),X1=$P(FBINV,""^"",7),X2=$P(FBINV,""^"",6) D ^%DTC S FBLOS=$S(X>0:X,1:1)"
^XMB(3.9,145986,2,1795,0)="""RTN"",""FBCHCR"",19,0)"
^XMB(3.9,145986,2,1796,0)=" .I FBLOS>0 S FBSUM=$G(^TMP($J,""FBCHCR"",""SUM"",FBPTC,FBLOS)),$P(FBSUM,""^"")=($P(FBSUM,""^"")+1),$P(FBSUM,""^"",2)=($P(FBSUM,""^"",2)+FBAMT) D"
^XMB(3.9,145986,2,1797,0)="""RTN"",""FBCHCR"",20,0)"
^XMB(3.9,145986,2,1798,0)=" ..S ^TMP($J,""FBCHCR"",""SUM"",FBPTC,FBLOS)=FBSUM"
^XMB(3.9,145986,2,1799,0)="""RTN"",""FBCHCR"",21,0)"
^XMB(3.9,145986,2,1800,0)=" .S ^TMP($J,""FBCHCR"",FBPTC,FBNAME,@FBREF,""INV"",FBIEN)=DFN_""^""_FBAMT_""^""_FBDRG_""^""_FBLOS"
^XMB(3.9,145986,2,1801,0)="""RTN"",""FBCHCR"",22,0)"
^XMB(3.9,145986,2,1802,0)=" D ANCIL^FBCHCR1"
^XMB(3.9,145986,2,1803,0)="""RTN"",""FBCHCR"",23,0)"
^XMB(3.9,145986,2,1804,0)=" U IO W:$E(IOST,1,2)[""C-"" @IOF I '$D(^TMP($J,""FBCHCR"")) S FBEND=1 D HED W !!,""No payments found within specified timeframe!"" G END"
^XMB(3.9,145986,2,1805,0)="""RTN"",""FBCHCR"",24,0)"
^XMB(3.9,145986,2,1806,0)="DETAIL S (FBIEN,FBPTC,FBREF1,DFN,FBAMT,FBLOS,FBANC,L,M,N)=0,(FBNAME,FBDRG,FBCHK)="""""
^XMB(3.9,145986,2,1807,0)="""RTN"",""FBCHCR"",25,0)"
^XMB(3.9,145986,2,1808,0)=" I FBRT=""D"" D HED"
^XMB(3.9,145986,2,1809,0)="""RTN"",""FBCHCR"",26,0)"
^XMB(3.9,145986,2,1810,0)=" F  S FBPTC=$O(^TMP($J,""FBCHCR"",FBPTC)) Q:FBPTC=""""!(FBAAOUT)  F  S FBNAME=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME)) Q:FBNAME=""""!(FBAAOUT)   F  S FBREF1=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1)) Q:FBREF1'>0!(FBAAOUT)  D"
^XMB(3.9,145986,2,1811,0)="""RTN"",""FBCHCR"",27,0)"
^XMB(3.9,145986,2,1812,0)=" .I $D(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""INV"")) D"
^XMB(3.9,145986,2,1813,0)="""RTN"",""FBCHCR"",28,0)"
^XMB(3.9,145986,2,1814,0)=" ..F  S FBIEN=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""INV"",FBIEN)) Q:FBIEN=""""!(FBAAOUT)  S FBCTR=FBCTR+1 D"
^XMB(3.9,145986,2,1815,0)="""RTN"",""FBCHCR"",29,0)"
^XMB(3.9,145986,2,1816,0)=" ...S FBINV=^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""INV"",FBIEN),DFN=+FBINV,FBAMT=$P(FBINV,""^"",2),FBDRG=$P(FBINV,""^"",3),FBLOS=$P(FBINV,""^"",4),FBTAMT=FBTAMT+FBAMT,FBTLOS=FBTLOS+FBLOS D PRINT:FBRT=""D"""
^XMB(3.9,145986,2,1817,0)="""RTN"",""FBCHCR"",30,0)"
^XMB(3.9,145986,2,1818,0)=" .I $D(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""ANC"")) F  S L=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""ANC"",L)) Q:'L!(FBAAOUT)  D"
^XMB(3.9,145986,2,1819,0)="""RTN"",""FBCHCR"",31,0)"
^XMB(3.9,145986,2,1820,0)=" ..F  S M=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""ANC"",L,M)) Q:'M!(FBAAOUT)  F  S N=$O(^TMP($J,""FBCHCR"",FBPTC,FBNAME,FBREF1,""ANC"",L,M,N)) Q:'N!(FBAAOUT)  D"
^XMB(3.9,145986,2,1821,0)="""RTN"",""FBCHCR"",32,0)"
