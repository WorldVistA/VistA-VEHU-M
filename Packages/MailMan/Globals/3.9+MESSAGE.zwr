^XMB(3.9,145957,2,175,0)="""IX"",123.7,123.7,""C"",0)"
^XMB(3.9,145957,2,176,0)="123.7^C^This cross-reference stores the entry name in upper case.^R^^F^IR^I^123.7^^^^^LS"
^XMB(3.9,145957,2,177,0)="""IX"",123.7,123.7,""C"",.1,0)"
^XMB(3.9,145957,2,178,0)="^^2^2^3240517^"
^XMB(3.9,145957,2,179,0)="""IX"",123.7,123.7,""C"",.1,1,0)"
^XMB(3.9,145957,2,180,0)="This cross-reference stores the name of the orderable item in upper case"
^XMB(3.9,145957,2,181,0)="""IX"",123.7,123.7,""C"",.1,2,0)"
^XMB(3.9,145957,2,182,0)="for lookup by the IFC processor."
^XMB(3.9,145957,2,183,0)="""IX"",123.7,123.7,""C"",1)"
^XMB(3.9,145957,2,184,0)="S ^GMR(123.7,""C"",$E(X,1,60),DA)="""""
^XMB(3.9,145957,2,185,0)="""IX"",123.7,123.7,""C"",2)"
^XMB(3.9,145957,2,186,0)="K ^GMR(123.7,""C"",$E(X,1,60),DA)"
^XMB(3.9,145957,2,187,0)="""IX"",123.7,123.7,""C"",2.5)"
