^XMB(3.9,145980,2,3863,0)="""RTN"",""SDES2CANCELAPPT2"",88,0)"
^XMB(3.9,145980,2,3864,0)=" ;Cancel Patient's Appt"
^XMB(3.9,145980,2,3865,0)="""RTN"",""SDES2CANCELAPPT2"",89,0)"
^XMB(3.9,145980,2,3866,0)="TRY2CANCEL(SDRETURN,SDCONTEXT,PARAMS,SDERRORS) ;"
