^XMB(3.9,145987,2,1535,0)="""RTN"",""SDES2SETCHECKOUT"",43,0)"
^XMB(3.9,145987,2,1536,0)=" ; Get APPT data"
^XMB(3.9,145987,2,1537,0)="""RTN"",""SDES2SETCHECKOUT"",44,0)"
^XMB(3.9,145987,2,1538,0)=" ;"
^XMB(3.9,145987,2,1539,0)="""RTN"",""SDES2SETCHECKOUT"",45,0)"
^XMB(3.9,145987,2,1540,0)=" D GETS^DIQ(409.84,APPTIENS,"".01;.03;.05;.07;.12;.16"",""I"",""APPTDATA"")"
^XMB(3.9,145987,2,1541,0)="""RTN"",""SDES2SETCHECKOUT"",46,0)"
^XMB(3.9,145987,2,1542,0)=" I $G(APPTDATA(409.84,APPTIENS,.12,""I"")) D  Q"
^XMB(3.9,145987,2,1543,0)="""RTN"",""SDES2SETCHECKOUT"",47,0)"
^XMB(3.9,145987,2,1544,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,322) M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""""
^XMB(3.9,145987,2,1545,0)="""RTN"",""SDES2SETCHECKOUT"",48,0)"
^XMB(3.9,145987,2,1546,0)=" . D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1547,0)="""RTN"",""SDES2SETCHECKOUT"",49,0)"
^XMB(3.9,145987,2,1548,0)=" ;"
^XMB(3.9,145987,2,1549,0)="""RTN"",""SDES2SETCHECKOUT"",50,0)"
^XMB(3.9,145987,2,1550,0)=" S APPTDTTM=$G(APPTDATA(409.84,APPTIENS,.01,""I""))"
^XMB(3.9,145987,2,1551,0)="""RTN"",""SDES2SETCHECKOUT"",51,0)"
^XMB(3.9,145987,2,1552,0)=" S CHKIN=$G(APPTDATA(409.84,APPTIENS,.03,""I""))"
^XMB(3.9,145987,2,1553,0)="""RTN"",""SDES2SETCHECKOUT"",52,0)"
^XMB(3.9,145987,2,1554,0)=" S DFN=$G(APPTDATA(409.84,APPTIENS,.05,""I""))"
^XMB(3.9,145987,2,1555,0)="""RTN"",""SDES2SETCHECKOUT"",53,0)"
^XMB(3.9,145987,2,1556,0)=" S RESOURCE=$G(APPTDATA(409.84,APPTIENS,.07,""I""))"
^XMB(3.9,145987,2,1557,0)="""RTN"",""SDES2SETCHECKOUT"",54,0)"
^XMB(3.9,145987,2,1558,0)=" S VPRV=$G(APPTDATA(409.84,APPTIENS,.16,""I""))"
^XMB(3.9,145987,2,1559,0)="""RTN"",""SDES2SETCHECKOUT"",55,0)"
^XMB(3.9,145987,2,1560,0)=" S CLINICIEN=$$GET1^DIQ(409.831,RESOURCE,.04,""I"")"
^XMB(3.9,145987,2,1561,0)="""RTN"",""SDES2SETCHECKOUT"",56,0)"
^XMB(3.9,145987,2,1562,0)=" ;"
^XMB(3.9,145987,2,1563,0)="""RTN"",""SDES2SETCHECKOUT"",57,0)"
^XMB(3.9,145987,2,1564,0)=" ; Validate Checkout Date/Time"
^XMB(3.9,145987,2,1565,0)="""RTN"",""SDES2SETCHECKOUT"",58,0)"
^XMB(3.9,145987,2,1566,0)=" ;"
^XMB(3.9,145987,2,1567,0)="""RTN"",""SDES2SETCHECKOUT"",59,0)"
^XMB(3.9,145987,2,1568,0)=" S CHKOUTDT=$G(PARAMS(""CHECKOUT DATE""))"
^XMB(3.9,145987,2,1569,0)="""RTN"",""SDES2SETCHECKOUT"",60,0)"
^XMB(3.9,145987,2,1570,0)=" S CHKOUTDT=$$VALCHCKOUT(CHKOUTDT,CHKIN,CLINICIEN,.SDERRORS)"
^XMB(3.9,145987,2,1571,0)="""RTN"",""SDES2SETCHECKOUT"",61,0)"
^XMB(3.9,145987,2,1572,0)=" I $D(SDERRORS) M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN) Q"
^XMB(3.9,145987,2,1573,0)="""RTN"",""SDES2SETCHECKOUT"",62,0)"
^XMB(3.9,145987,2,1574,0)=" ;"
^XMB(3.9,145987,2,1575,0)="""RTN"",""SDES2SETCHECKOUT"",63,0)"
^XMB(3.9,145987,2,1576,0)=" S SDDA=0,SDASK=0,SDCOACT=""CO"",SDLNE="""",SDQUIET=1"
^XMB(3.9,145987,2,1577,0)="""RTN"",""SDES2SETCHECKOUT"",64,0)"
^XMB(3.9,145987,2,1578,0)=" ;"
^XMB(3.9,145987,2,1579,0)="""RTN"",""SDES2SETCHECKOUT"",65,0)"
^XMB(3.9,145987,2,1580,0)=" ;  Event driver ""BEFORE"" actions"
^XMB(3.9,145987,2,1581,0)="""RTN"",""SDES2SETCHECKOUT"",66,0)"
^XMB(3.9,145987,2,1582,0)=" ;"
^XMB(3.9,145987,2,1583,0)="""RTN"",""SDES2SETCHECKOUT"",67,0)"
^XMB(3.9,145987,2,1584,0)=" N SDATA,SDDA,SDCIHDL ;"
^XMB(3.9,145987,2,1585,0)="""RTN"",""SDES2SETCHECKOUT"",68,0)"
^XMB(3.9,145987,2,1586,0)=" S SDDA=$$FIND(DFN,APPTDTTM,CLINICIEN)"
^XMB(3.9,145987,2,1587,0)="""RTN"",""SDES2SETCHECKOUT"",69,0)"
^XMB(3.9,145987,2,1588,0)=" I 'SDDA D  Q"
^XMB(3.9,145987,2,1589,0)="""RTN"",""SDES2SETCHECKOUT"",70,0)"
^XMB(3.9,145987,2,1590,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,317) M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""""
^XMB(3.9,145987,2,1591,0)="""RTN"",""SDES2SETCHECKOUT"",71,0)"
^XMB(3.9,145987,2,1592,0)=" . D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1593,0)="""RTN"",""SDES2SETCHECKOUT"",72,0)"
^XMB(3.9,145987,2,1594,0)=" I '$$GET1^DIQ(44.003,SDDA_"",""_APPTDTTM_"",""_CLINICIEN_"","",309,""I"") D  Q"
^XMB(3.9,145987,2,1595,0)="""RTN"",""SDES2SETCHECKOUT"",73,0)"
^XMB(3.9,145987,2,1596,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,318) M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""""
^XMB(3.9,145987,2,1597,0)="""RTN"",""SDES2SETCHECKOUT"",74,0)"
^XMB(3.9,145987,2,1598,0)=" . D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1599,0)="""RTN"",""SDES2SETCHECKOUT"",75,0)"
^XMB(3.9,145987,2,1600,0)=" ;"
^XMB(3.9,145987,2,1601,0)="""RTN"",""SDES2SETCHECKOUT"",76,0)"
^XMB(3.9,145987,2,1602,0)=" S SDATA=SDDA_U_DFN_U_APPTDTTM_U_CLINICIEN"
^XMB(3.9,145987,2,1603,0)="""RTN"",""SDES2SETCHECKOUT"",77,0)"
^XMB(3.9,145987,2,1604,0)=" S SDCIHDL=$$HANDLE^SDAMEVT(1) ;"
^XMB(3.9,145987,2,1605,0)="""RTN"",""SDES2SETCHECKOUT"",78,0)"
^XMB(3.9,145987,2,1606,0)=" ;  Event driver ""BEFORE"" actions"
^XMB(3.9,145987,2,1607,0)="""RTN"",""SDES2SETCHECKOUT"",79,0)"
^XMB(3.9,145987,2,1608,0)=" D BEFORE^SDAMEVT(.SDATA,DFN,APPTDTTM,CLINICIEN,SDDA,SDCIHDL) ;"
^XMB(3.9,145987,2,1609,0)="""RTN"",""SDES2SETCHECKOUT"",80,0)"
^XMB(3.9,145987,2,1610,0)=" ; Appointment checkout"
^XMB(3.9,145987,2,1611,0)="""RTN"",""SDES2SETCHECKOUT"",81,0)"
^XMB(3.9,145987,2,1612,0)=" D CHKOUT(DFN,APPTDTTM,CLINICIEN,SDDA,SDASK,CHKOUTDT,SDCOACT,SDLNE,APPTIEN,SDQUIET,VPRV,.SDERRORS)"
^XMB(3.9,145987,2,1613,0)="""RTN"",""SDES2SETCHECKOUT"",82,0)"
^XMB(3.9,145987,2,1614,0)=" ; Skip event driver actions if error occurred checking appointment out."
^XMB(3.9,145987,2,1615,0)="""RTN"",""SDES2SETCHECKOUT"",83,0)"
^XMB(3.9,145987,2,1616,0)=" I $D(SDERRORS) D  Q"
^XMB(3.9,145987,2,1617,0)="""RTN"",""SDES2SETCHECKOUT"",84,0)"
^XMB(3.9,145987,2,1618,0)=" . M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""""
^XMB(3.9,145987,2,1619,0)="""RTN"",""SDES2SETCHECKOUT"",85,0)"
^XMB(3.9,145987,2,1620,0)=" . D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1621,0)="""RTN"",""SDES2SETCHECKOUT"",86,0)"
^XMB(3.9,145987,2,1622,0)=" ;  Event driver ""AFTER"" actions"
^XMB(3.9,145987,2,1623,0)="""RTN"",""SDES2SETCHECKOUT"",87,0)"
^XMB(3.9,145987,2,1624,0)=" D AFTER^SDAMEVT(.SDATA,DFN,APPTDTTM,CLINICIEN,SDDA,SDCIHDL) ;"
^XMB(3.9,145987,2,1625,0)="""RTN"",""SDES2SETCHECKOUT"",88,0)"
^XMB(3.9,145987,2,1626,0)=" ;  Execute event driver.  5=Checkout (see #409.66), 2=non-interactive"
^XMB(3.9,145987,2,1627,0)="""RTN"",""SDES2SETCHECKOUT"",89,0)"
^XMB(3.9,145987,2,1628,0)=" D EVT^SDAMEVT(.SDATA,5,2,SDCIHDL) ;"
^XMB(3.9,145987,2,1629,0)="""RTN"",""SDES2SETCHECKOUT"",90,0)"
^XMB(3.9,145987,2,1630,0)=" S SDRETURN(""Checkout"",1)=""Checked Out."""
^XMB(3.9,145987,2,1631,0)="""RTN"",""SDES2SETCHECKOUT"",91,0)"
^XMB(3.9,145987,2,1632,0)=" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1633,0)="""RTN"",""SDES2SETCHECKOUT"",92,0)"
^XMB(3.9,145987,2,1634,0)=" Q"
^XMB(3.9,145987,2,1635,0)="""RTN"",""SDES2SETCHECKOUT"",93,0)"
^XMB(3.9,145987,2,1636,0)=" ;"
^XMB(3.9,145987,2,1637,0)="""RTN"",""SDES2SETCHECKOUT"",94,0)"
^XMB(3.9,145987,2,1638,0)="VALAPPTIEN(APPTIEN,SDERRORS) ; Validate Appt IEN"
^XMB(3.9,145987,2,1639,0)="""RTN"",""SDES2SETCHECKOUT"",95,0)"
^XMB(3.9,145987,2,1640,0)=" ;"
^XMB(3.9,145987,2,1641,0)="""RTN"",""SDES2SETCHECKOUT"",96,0)"
^XMB(3.9,145987,2,1642,0)=" N VALRET"
^XMB(3.9,145987,2,1643,0)="""RTN"",""SDES2SETCHECKOUT"",97,0)"
^XMB(3.9,145987,2,1644,0)=" D VALFILEIEN^SDES2VALUTIL(.VALRET,.SDERRORS,409.84,APPTIEN,1,0,14,15)"
^XMB(3.9,145987,2,1645,0)="""RTN"",""SDES2SETCHECKOUT"",98,0)"
^XMB(3.9,145987,2,1646,0)=" Q APPTIEN_"","""
^XMB(3.9,145987,2,1647,0)="""RTN"",""SDES2SETCHECKOUT"",99,0)"
^XMB(3.9,145987,2,1648,0)=" ;"
^XMB(3.9,145987,2,1649,0)="""RTN"",""SDES2SETCHECKOUT"",100,0)"
^XMB(3.9,145987,2,1650,0)="VALCHCKOUT(CHKOUTDT,CHKIN,CLINICIEN,SDERRORS) ; Validate and Process Checkout Date/Time"
^XMB(3.9,145987,2,1651,0)="""RTN"",""SDES2SETCHECKOUT"",101,0)"
^XMB(3.9,145987,2,1652,0)=" ;"
^XMB(3.9,145987,2,1653,0)="""RTN"",""SDES2SETCHECKOUT"",102,0)"
^XMB(3.9,145987,2,1654,0)=" N CHKOUTDTFM S CHKOUTDTFM="""""
^XMB(3.9,145987,2,1655,0)="""RTN"",""SDES2SETCHECKOUT"",103,0)"
^XMB(3.9,145987,2,1656,0)=" S CHKOUTDTFM=$$VALISODTTM^SDES2VALISODTTM(.SDERRORS,CHKOUTDT,CLINICIEN,1,23,24)"
^XMB(3.9,145987,2,1657,0)="""RTN"",""SDES2SETCHECKOUT"",104,0)"
^XMB(3.9,145987,2,1658,0)=" I $D(SDERRORS) Q 0"
^XMB(3.9,145987,2,1659,0)="""RTN"",""SDES2SETCHECKOUT"",105,0)"
^XMB(3.9,145987,2,1660,0)=" ; checkout time must be included"
^XMB(3.9,145987,2,1661,0)="""RTN"",""SDES2SETCHECKOUT"",106,0)"
^XMB(3.9,145987,2,1662,0)=" I $P(CHKOUTDTFM,""."",2)="""" D ERRLOG^SDES2JSON(.SDERRORS,321) Q 0"
^XMB(3.9,145987,2,1663,0)="""RTN"",""SDES2SETCHECKOUT"",107,0)"
^XMB(3.9,145987,2,1664,0)=" ; checkout time cannot be in the future"
^XMB(3.9,145987,2,1665,0)="""RTN"",""SDES2SETCHECKOUT"",108,0)"
^XMB(3.9,145987,2,1666,0)=" I CHKOUTDTFM>$$NOW^XLFDT D ERRLOG^SDES2JSON(.SDERRORS,320) Q 0"
^XMB(3.9,145987,2,1667,0)="""RTN"",""SDES2SETCHECKOUT"",109,0)"
^XMB(3.9,145987,2,1668,0)=" ; make sure checkout time is after checkin time"
^XMB(3.9,145987,2,1669,0)="""RTN"",""SDES2SETCHECKOUT"",110,0)"
^XMB(3.9,145987,2,1670,0)=" I CHKOUTDTFM'>CHKIN D ERRLOG^SDES2JSON(.SDERRORS,52,""Checkout time must be at least 1 minute after the Check-In time of ""_$TR($$FMTE^XLFDT(CHKIN),""@"","" "")_""."") Q 0"
^XMB(3.9,145987,2,1671,0)="""RTN"",""SDES2SETCHECKOUT"",111,0)"
^XMB(3.9,145987,2,1672,0)=" Q CHKOUTDTFM"
^XMB(3.9,145987,2,1673,0)="""RTN"",""SDES2SETCHECKOUT"",112,0)"
^XMB(3.9,145987,2,1674,0)=" ;"
^XMB(3.9,145987,2,1675,0)="""RTN"",""SDES2SETCHECKOUT"",113,0)"
^XMB(3.9,145987,2,1676,0)="FIND(DFN,APPTDTTM,CLINICIEN) ; return appt ifn for pat"
^XMB(3.9,145987,2,1677,0)="""RTN"",""SDES2SETCHECKOUT"",114,0)"
^XMB(3.9,145987,2,1678,0)=" ;   input:       DFN := ifn of pat."
^XMB(3.9,145987,2,1679,0)="""RTN"",""SDES2SETCHECKOUT"",115,0)"
^XMB(3.9,145987,2,1680,0)=" ;           APPTDTTM := appt d/t"
^XMB(3.9,145987,2,1681,0)="""RTN"",""SDES2SETCHECKOUT"",116,0)"
^XMB(3.9,145987,2,1682,0)=" ;          CLINICIEN := ifn of clinic"
^XMB(3.9,145987,2,1683,0)="""RTN"",""SDES2SETCHECKOUT"",117,0)"
^XMB(3.9,145987,2,1684,0)=" ;  output: [returned] := ifn if pat has appt on date/time"
^XMB(3.9,145987,2,1685,0)="""RTN"",""SDES2SETCHECKOUT"",118,0)"
^XMB(3.9,145987,2,1686,0)=" ;"
^XMB(3.9,145987,2,1687,0)="""RTN"",""SDES2SETCHECKOUT"",119,0)"
^XMB(3.9,145987,2,1688,0)=" N Y,FOUND,RET"
^XMB(3.9,145987,2,1689,0)="""RTN"",""SDES2SETCHECKOUT"",120,0)"
^XMB(3.9,145987,2,1690,0)=" S RET="""""
^XMB(3.9,145987,2,1691,0)="""RTN"",""SDES2SETCHECKOUT"",121,0)"
^XMB(3.9,145987,2,1692,0)=" S (Y,FOUND)=0"
^XMB(3.9,145987,2,1693,0)="""RTN"",""SDES2SETCHECKOUT"",122,0)"
^XMB(3.9,145987,2,1694,0)=" F  S Y=$O(^SC(CLINICIEN,""S"",APPTDTTM,1,Y)) Q:'Y!(FOUND)  D"
^XMB(3.9,145987,2,1695,0)="""RTN"",""SDES2SETCHECKOUT"",123,0)"
^XMB(3.9,145987,2,1696,0)=" .I '$D(^SC(CLINICIEN,""S"",APPTDTTM,1,Y,0)) Q"
^XMB(3.9,145987,2,1697,0)="""RTN"",""SDES2SETCHECKOUT"",124,0)"
^XMB(3.9,145987,2,1698,0)=" .I DFN'=$$GET1^DIQ(44.003,Y_"",""_APPTDTTM_"",""_CLINICIEN_"","",.01,""I"") Q"
^XMB(3.9,145987,2,1699,0)="""RTN"",""SDES2SETCHECKOUT"",125,0)"
^XMB(3.9,145987,2,1700,0)=" .I $D(^DPT(DFN,""S"",APPTDTTM,0)),$$VALID(DFN,CLINICIEN,APPTDTTM,Y) S FOUND=1,RET=Y Q"
^XMB(3.9,145987,2,1701,0)="""RTN"",""SDES2SETCHECKOUT"",126,0)"
^XMB(3.9,145987,2,1702,0)=" Q RET"
^XMB(3.9,145987,2,1703,0)="""RTN"",""SDES2SETCHECKOUT"",127,0)"
^XMB(3.9,145987,2,1704,0)=" ;"
^XMB(3.9,145987,2,1705,0)="""RTN"",""SDES2SETCHECKOUT"",128,0)"
^XMB(3.9,145987,2,1706,0)="VALID(DFN,CLINICIEN,APPTDTTM,SDDA) ; return valid appt."
^XMB(3.9,145987,2,1707,0)="""RTN"",""SDES2SETCHECKOUT"",129,0)"
^XMB(3.9,145987,2,1708,0)=" ;   input:       DFN := ifn of pat."
^XMB(3.9,145987,2,1709,0)="""RTN"",""SDES2SETCHECKOUT"",130,0)"
^XMB(3.9,145987,2,1710,0)=" ;           APPTDTTM := appt d/t"
^XMB(3.9,145987,2,1711,0)="""RTN"",""SDES2SETCHECKOUT"",131,0)"
^XMB(3.9,145987,2,1712,0)=" ;          CLINICIEN := ifn of clinic"
^XMB(3.9,145987,2,1713,0)="""RTN"",""SDES2SETCHECKOUT"",132,0)"
^XMB(3.9,145987,2,1714,0)=" ;               SDDA := ifn of appt"
^XMB(3.9,145987,2,1715,0)="""RTN"",""SDES2SETCHECKOUT"",133,0)"
^XMB(3.9,145987,2,1716,0)=" ;  output: [returned] := 1 for valid appt., 0 for not valid"
^XMB(3.9,145987,2,1717,0)="""RTN"",""SDES2SETCHECKOUT"",134,0)"
^XMB(3.9,145987,2,1718,0)=" N APPTCAN44,APPTCAN2"
^XMB(3.9,145987,2,1719,0)="""RTN"",""SDES2SETCHECKOUT"",135,0)"
^XMB(3.9,145987,2,1720,0)=" S APPTCAN44=$$GET1^DIQ(44.003,SDDA_"",""_APPTDTTM_"",""_CLINICIEN_"","",310,""I"")"
^XMB(3.9,145987,2,1721,0)="""RTN"",""SDES2SETCHECKOUT"",136,0)"
^XMB(3.9,145987,2,1722,0)=" S APPTCAN2=$$GET1^DIQ(2.98,APPTDTTM_"",""_DFN_"","",3,""I"")"
^XMB(3.9,145987,2,1723,0)="""RTN"",""SDES2SETCHECKOUT"",137,0)"
^XMB(3.9,145987,2,1724,0)=" Q $S(APPTCAN44'=""C"":1,APPTCAN2[""C"":1,1:0)"
^XMB(3.9,145987,2,1725,0)="""RTN"",""SDES2SETCHECKOUT"",138,0)"
^XMB(3.9,145987,2,1726,0)=" ;"
^XMB(3.9,145987,2,1727,0)="""RTN"",""SDES2SETCHECKOUT"",139,0)"
^XMB(3.9,145987,2,1728,0)=" ; from CO^SDEC25A"
^XMB(3.9,145987,2,1729,0)="""RTN"",""SDES2SETCHECKOUT"",140,0)"
^XMB(3.9,145987,2,1730,0)="CHKOUT(DFN,APPTDTTM,CLINICIEN,SDDA,SDASK,CHKOUTDT,SDCOACT,SDLNE,SDECAPTID,SDQUIET,VPRV,SDERRORS) ;Appt Check Out"
^XMB(3.9,145987,2,1731,0)="""RTN"",""SDES2SETCHECKOUT"",141,0)"
^XMB(3.9,145987,2,1732,0)=" ; Input"
^XMB(3.9,145987,2,1733,0)="""RTN"",""SDES2SETCHECKOUT"",142,0)"
^XMB(3.9,145987,2,1734,0)=" ;  DFN        Patient file IEN"
^XMB(3.9,145987,2,1735,0)="""RTN"",""SDES2SETCHECKOUT"",143,0)"
^XMB(3.9,145987,2,1736,0)=" ;  APPTDTTM   Appointment Date/Time"
^XMB(3.9,145987,2,1737,0)="""RTN"",""SDES2SETCHECKOUT"",144,0)"
^XMB(3.9,145987,2,1738,0)=" ;  CLINICIEN  Hospital Location file IEN for Appt"
^XMB(3.9,145987,2,1739,0)="""RTN"",""SDES2SETCHECKOUT"",145,0)"
^XMB(3.9,145987,2,1740,0)=" ;  SDDA       IEN in ^SC multiple or null [Optional]"
^XMB(3.9,145987,2,1741,0)="""RTN"",""SDES2SETCHECKOUT"",146,0)"
^XMB(3.9,145987,2,1742,0)=" ;  SDASK      Ask Checkout Date/Time      [Optional]"
^XMB(3.9,145987,2,1743,0)="""RTN"",""SDES2SETCHECKOUT"",147,0)"
^XMB(3.9,145987,2,1744,0)=" ;  CHKOUTDT   Date/Time of Checkout       [Optional]"
^XMB(3.9,145987,2,1745,0)="""RTN"",""SDES2SETCHECKOUT"",148,0)"
^XMB(3.9,145987,2,1746,0)=" ;  SDCOACT    Appt Mgmt Checkout Action   [Optional]"
^XMB(3.9,145987,2,1747,0)="""RTN"",""SDES2SETCHECKOUT"",149,0)"
^XMB(3.9,145987,2,1748,0)=" ;  SDLNE      Appt Mgmt Line Number       [Optional]"
^XMB(3.9,145987,2,1749,0)="""RTN"",""SDES2SETCHECKOUT"",150,0)"
^XMB(3.9,145987,2,1750,0)=" ;  SDECAPTID  Appointment ID"
^XMB(3.9,145987,2,1751,0)="""RTN"",""SDES2SETCHECKOUT"",151,0)"
^XMB(3.9,145987,2,1752,0)=" ;  SDQUIET    No Terminal output 0=allow display 1=do not allow"
^XMB(3.9,145987,2,1753,0)="""RTN"",""SDES2SETCHECKOUT"",152,0)"
^XMB(3.9,145987,2,1754,0)=" ;  VPRV       V Provider IEN - pointer to V PROVIDER file"
^XMB(3.9,145987,2,1755,0)="""RTN"",""SDES2SETCHECKOUT"",153,0)"
^XMB(3.9,145987,2,1756,0)=" ;  SDERRORS   Returned Array of errors"
^XMB(3.9,145987,2,1757,0)="""RTN"",""SDES2SETCHECKOUT"",154,0)"
^XMB(3.9,145987,2,1758,0)=" ;"
^XMB(3.9,145987,2,1759,0)="""RTN"",""SDES2SETCHECKOUT"",155,0)"
^XMB(3.9,145987,2,1760,0)=" N SDCOQUIT,SDOE,SDATA"
^XMB(3.9,145987,2,1761,0)="""RTN"",""SDES2SETCHECKOUT"",156,0)"
^XMB(3.9,145987,2,1762,0)=" S SDATA=$G(^DPT(DFN,""S"",APPTDTTM,0))"
^XMB(3.9,145987,2,1763,0)="""RTN"",""SDES2SETCHECKOUT"",157,0)"
^XMB(3.9,145987,2,1764,0)=" ; if new encounter, pass to PCE"
^XMB(3.9,145987,2,1765,0)="""RTN"",""SDES2SETCHECKOUT"",158,0)"
^XMB(3.9,145987,2,1766,0)=" I $$NEW(APPTDTTM) D  Q"
^XMB(3.9,145987,2,1767,0)="""RTN"",""SDES2SETCHECKOUT"",159,0)"
^XMB(3.9,145987,2,1768,0)=" .N SDCOED"
^XMB(3.9,145987,2,1769,0)="""RTN"",""SDES2SETCHECKOUT"",160,0)"
^XMB(3.9,145987,2,1770,0)=" .S SDOE=$$GETAPT(DFN,APPTDTTM,CLINICIEN,.SDERRORS)"
^XMB(3.9,145987,2,1771,0)="""RTN"",""SDES2SETCHECKOUT"",161,0)"
^XMB(3.9,145987,2,1772,0)=" .I $D(SDERRORS) Q"
^XMB(3.9,145987,2,1773,0)="""RTN"",""SDES2SETCHECKOUT"",162,0)"
^XMB(3.9,145987,2,1774,0)=" .;"
^XMB(3.9,145987,2,1775,0)="""RTN"",""SDES2SETCHECKOUT"",163,0)"
^XMB(3.9,145987,2,1776,0)=" .S SDCOED=$$CHK($TR($$STATUS(DFN,APPTDTTM,CLINICIEN,SDATA,SDDA),"";"",""^""))"
^XMB(3.9,145987,2,1777,0)="""RTN"",""SDES2SETCHECKOUT"",164,0)"
^XMB(3.9,145987,2,1778,0)=" .; appt has already been checked out"
^XMB(3.9,145987,2,1779,0)="""RTN"",""SDES2SETCHECKOUT"",165,0)"
^XMB(3.9,145987,2,1780,0)=" .I $$CODT(DFN,APPTDTTM,CLINICIEN,SDDA)!(SDCOED) D  Q"
^XMB(3.9,145987,2,1781,0)="""RTN"",""SDES2SETCHECKOUT"",166,0)"
^XMB(3.9,145987,2,1782,0)=" ..D ERRLOG^SDES2JSON(.SDERRORS,319)"
^XMB(3.9,145987,2,1783,0)="""RTN"",""SDES2SETCHECKOUT"",167,0)"
^XMB(3.9,145987,2,1784,0)=" .D CHKOUT2(SDOE,DFN,APPTDTTM,CLINICIEN,CHKOUTDT,SDECAPTID,SDQUIET,VPRV,.SDERRORS)"
^XMB(3.9,145987,2,1785,0)="""RTN"",""SDES2SETCHECKOUT"",168,0)"
^XMB(3.9,145987,2,1786,0)=" Q"
^XMB(3.9,145987,2,1787,0)="""RTN"",""SDES2SETCHECKOUT"",169,0)"
^XMB(3.9,145987,2,1788,0)="CODT(DFN,SDT,SDCL,SDDA) ; does appt have co date"
^XMB(3.9,145987,2,1789,0)="""RTN"",""SDES2SETCHECKOUT"",170,0)"
^XMB(3.9,145987,2,1790,0)=" Q $$GET1^DIQ(44.003,SDDA_"",""_SDT_"",""_SDCL_"","",303,""I"")"
^XMB(3.9,145987,2,1791,0)="""RTN"",""SDES2SETCHECKOUT"",171,0)"
^XMB(3.9,145987,2,1792,0)=" ;"
^XMB(3.9,145987,2,1793,0)="""RTN"",""SDES2SETCHECKOUT"",172,0)"
^XMB(3.9,145987,2,1794,0)="NEW(DATE) ; This function will return 1 if SD is turned on for"
^XMB(3.9,145987,2,1795,0)="""RTN"",""SDES2SETCHECKOUT"",173,0)"
^XMB(3.9,145987,2,1796,0)=" ; Visit Tracking and optionally check if the date is past"
^XMB(3.9,145987,2,1797,0)="""RTN"",""SDES2SETCHECKOUT"",174,0)"
^XMB(3.9,145987,2,1798,0)=" ; the cut over date for the new PCE interface."
^XMB(3.9,145987,2,1799,0)="""RTN"",""SDES2SETCHECKOUT"",175,0)"
^XMB(3.9,145987,2,1800,0)=" ; INPUT : DATE (Optional) Date to check for cut over."
^XMB(3.9,145987,2,1801,0)="""RTN"",""SDES2SETCHECKOUT"",176,0)"
^XMB(3.9,145987,2,1802,0)=" ; OUTPUT: 1 Yes, 0 No"
^XMB(3.9,145987,2,1803,0)="""RTN"",""SDES2SETCHECKOUT"",177,0)"
^XMB(3.9,145987,2,1804,0)=" N SDRES,SDX,SDY"
^XMB(3.9,145987,2,1805,0)="""RTN"",""SDES2SETCHECKOUT"",178,0)"
^XMB(3.9,145987,2,1806,0)=" I '$G(DATE) S DATE=DT"
^XMB(3.9,145987,2,1807,0)="""RTN"",""SDES2SETCHECKOUT"",179,0)"
^XMB(3.9,145987,2,1808,0)=" ; is Scheduling on ?"
^XMB(3.9,145987,2,1809,0)="""RTN"",""SDES2SETCHECKOUT"",180,0)"
^XMB(3.9,145987,2,1810,0)=" S SDRES=0,SDY=$$PKGON^VSIT(""SD"")"
^XMB(3.9,145987,2,1811,0)="""RTN"",""SDES2SETCHECKOUT"",181,0)"
^XMB(3.9,145987,2,1812,0)=" ; if date is it pass cut over?"
^XMB(3.9,145987,2,1813,0)="""RTN"",""SDES2SETCHECKOUT"",182,0)"
^XMB(3.9,145987,2,1814,0)=" S SDX=1 I $G(DATE) S SDX=$$SWITCHCK^PXAPI(DATE)"
^XMB(3.9,145987,2,1815,0)="""RTN"",""SDES2SETCHECKOUT"",183,0)"
^XMB(3.9,145987,2,1816,0)=" ; And together"
^XMB(3.9,145987,2,1817,0)="""RTN"",""SDES2SETCHECKOUT"",184,0)"
^XMB(3.9,145987,2,1818,0)=" I SDX,SDY S SDRES=1"
^XMB(3.9,145987,2,1819,0)="""RTN"",""SDES2SETCHECKOUT"",185,0)"
^XMB(3.9,145987,2,1820,0)=" Q SDRES"
^XMB(3.9,145987,2,1821,0)="""RTN"",""SDES2SETCHECKOUT"",186,0)"
^XMB(3.9,145987,2,1822,0)=" ;"
^XMB(3.9,145987,2,1823,0)="""RTN"",""SDES2SETCHECKOUT"",187,0)"
^XMB(3.9,145987,2,1824,0)="GETAPT(DFN,SDT,SDCL,SDVIEN,SDERRORS) ;Look-up Outpatient Encounter IEN for Appt"
^XMB(3.9,145987,2,1825,0)="""RTN"",""SDES2SETCHECKOUT"",188,0)"
^XMB(3.9,145987,2,1826,0)=" ; This utility will return the existing IEN for an Outpatient"
^XMB(3.9,145987,2,1827,0)="""RTN"",""SDES2SETCHECKOUT"",189,0)"
^XMB(3.9,145987,2,1828,0)=" ; Encounter. If it fails to find an existing encounter,"
^XMB(3.9,145987,2,1829,0)="""RTN"",""SDES2SETCHECKOUT"",190,0)"
^XMB(3.9,145987,2,1830,0)=" ; it will create a new Encounter and return the new IEN."
^XMB(3.9,145987,2,1831,0)="""RTN"",""SDES2SETCHECKOUT"",191,0)"
^XMB(3.9,145987,2,1832,0)=" ;"
^XMB(3.9,145987,2,1833,0)="""RTN"",""SDES2SETCHECKOUT"",192,0)"
^XMB(3.9,145987,2,1834,0)=" ; Input:  DFN      Patient file IEN"
^XMB(3.9,145987,2,1835,0)="""RTN"",""SDES2SETCHECKOUT"",193,0)"
^XMB(3.9,145987,2,1836,0)=" ;         SDT      Appointment Date/Time"
^XMB(3.9,145987,2,1837,0)="""RTN"",""SDES2SETCHECKOUT"",194,0)"
^XMB(3.9,145987,2,1838,0)=" ;         SDCL     Hospital Location file IEN for Appt"
^XMB(3.9,145987,2,1839,0)="""RTN"",""SDES2SETCHECKOUT"",195,0)"
^XMB(3.9,145987,2,1840,0)=" ;         SDVIEN   Visit file pointer [optional]"
^XMB(3.9,145987,2,1841,0)="""RTN"",""SDES2SETCHECKOUT"",196,0)"
^XMB(3.9,145987,2,1842,0)=" ; Output  Outpatient Encounter file IEN"
^XMB(3.9,145987,2,1843,0)="""RTN"",""SDES2SETCHECKOUT"",197,0)"
^XMB(3.9,145987,2,1844,0)=" N Y"
^XMB(3.9,145987,2,1845,0)="""RTN"",""SDES2SETCHECKOUT"",198,0)"
^XMB(3.9,145987,2,1846,0)=" S Y=$$GET1^DIQ(2.98,SDT_"",""_DFN_"","",21,""I"")"
^XMB(3.9,145987,2,1847,0)="""RTN"",""SDES2SETCHECKOUT"",199,0)"
^XMB(3.9,145987,2,1848,0)=" I 'Y D APPT(DFN,SDT,SDCL,$G(SDVIEN),.SDERRORS)"
^XMB(3.9,145987,2,1849,0)="""RTN"",""SDES2SETCHECKOUT"",200,0)"
^XMB(3.9,145987,2,1850,0)=" I $D(SDERRORS) Q +$G(Y)"
^XMB(3.9,145987,2,1851,0)="""RTN"",""SDES2SETCHECKOUT"",201,0)"
^XMB(3.9,145987,2,1852,0)=" I '$D(SDERRORS) S Y=$$GET1^DIQ(2.98,SDT_"",""_DFN_"","",21,""I"")"
^XMB(3.9,145987,2,1853,0)="""RTN"",""SDES2SETCHECKOUT"",202,0)"
^XMB(3.9,145987,2,1854,0)=" ;"
^XMB(3.9,145987,2,1855,0)="""RTN"",""SDES2SETCHECKOUT"",203,0)"
^XMB(3.9,145987,2,1856,0)=" I Y D VIEN(Y,$G(SDVIEN))"
^XMB(3.9,145987,2,1857,0)="""RTN"",""SDES2SETCHECKOUT"",204,0)"
^XMB(3.9,145987,2,1858,0)=" Q +$G(Y)"
^XMB(3.9,145987,2,1859,0)="""RTN"",""SDES2SETCHECKOUT"",205,0)"
^XMB(3.9,145987,2,1860,0)=" ;"
^XMB(3.9,145987,2,1861,0)="""RTN"",""SDES2SETCHECKOUT"",206,0)"
^XMB(3.9,145987,2,1862,0)=" ; FROM APPT^SDVSIT"
^XMB(3.9,145987,2,1863,0)="""RTN"",""SDES2SETCHECKOUT"",207,0)"
^XMB(3.9,145987,2,1864,0)="APPT(DFN,SDT,SDCL,SDVIEN,SDERRORS) ; process appt"
^XMB(3.9,145987,2,1865,0)="""RTN"",""SDES2SETCHECKOUT"",208,0)"
^XMB(3.9,145987,2,1866,0)=" ; input     DFN = ien of patient file entry"
^XMB(3.9,145987,2,1867,0)="""RTN"",""SDES2SETCHECKOUT"",209,0)"
^XMB(3.9,145987,2,1868,0)=" ;           SDT = visit date internal format"
^XMB(3.9,145987,2,1869,0)="""RTN"",""SDES2SETCHECKOUT"",210,0)"
^XMB(3.9,145987,2,1870,0)=" ;          SDCL = ien of hospital location file entry"
^XMB(3.9,145987,2,1871,0)="""RTN"",""SDES2SETCHECKOUT"",211,0)"
^XMB(3.9,145987,2,1872,0)=" ;        SDVIEN = Visit file pointer [optional]"
^XMB(3.9,145987,2,1873,0)="""RTN"",""SDES2SETCHECKOUT"",212,0)"
^XMB(3.9,145987,2,1874,0)=" ;"
^XMB(3.9,145987,2,1875,0)="""RTN"",""SDES2SETCHECKOUT"",213,0)"
^XMB(3.9,145987,2,1876,0)=" N SDVSIT,SDOE,DA,DIE,DR,SDPT,SDSC,SDCL0,SDDA,SDLOCK,SDLCKS"
^XMB(3.9,145987,2,1877,0)="""RTN"",""SDES2SETCHECKOUT"",214,0)"
^XMB(3.9,145987,2,1878,0)=" ;"
^XMB(3.9,145987,2,1879,0)="""RTN"",""SDES2SETCHECKOUT"",215,0)"
^XMB(3.9,145987,2,1880,0)=" ; set lock data and lock"
^XMB(3.9,145987,2,1881,0)="""RTN"",""SDES2SETCHECKOUT"",216,0)"
^XMB(3.9,145987,2,1882,0)=" S SDLOCK(""DFN"")=DFN"
^XMB(3.9,145987,2,1883,0)="""RTN"",""SDES2SETCHECKOUT"",217,0)"
^XMB(3.9,145987,2,1884,0)=" S SDLOCK(""EVENT DATE/TIME"")=SDT"
^XMB(3.9,145987,2,1885,0)="""RTN"",""SDES2SETCHECKOUT"",218,0)"
^XMB(3.9,145987,2,1886,0)=" I '$$LOCK(.SDLOCK) D ERRLOG^SDES2JSON(.SDERRORS,174) Q"
^XMB(3.9,145987,2,1887,0)="""RTN"",""SDES2SETCHECKOUT"",219,0)"
^XMB(3.9,145987,2,1888,0)=" ;"
^XMB(3.9,145987,2,1889,0)="""RTN"",""SDES2SETCHECKOUT"",220,0)"
^XMB(3.9,145987,2,1890,0)=" ; set node vars"
^XMB(3.9,145987,2,1891,0)="""RTN"",""SDES2SETCHECKOUT"",221,0)"
^XMB(3.9,145987,2,1892,0)=" S SDPT=$G(^DPT(DFN,""S"",SDT,0))"
^XMB(3.9,145987,2,1893,0)="""RTN"",""SDES2SETCHECKOUT"",222,0)"
^XMB(3.9,145987,2,1894,0)=" S SDCL0=$G(^SC(SDCL,0)),SDDA=+$$FIND^SDAM2(DFN,SDT,SDCL)"
^XMB(3.9,145987,2,1895,0)="""RTN"",""SDES2SETCHECKOUT"",223,0)"
^XMB(3.9,145987,2,1896,0)=" S SDSC=$G(^SC(SDCL,""S"",SDT,1,SDDA,0))"
^XMB(3.9,145987,2,1897,0)="""RTN"",""SDES2SETCHECKOUT"",224,0)"
^XMB(3.9,145987,2,1898,0)=" S SDVSIT(""CLN"")=$P(SDCL0,U,7),SDVSIT(""DIV"")=$$DIV($P(SDCL0,U,15))"
^XMB(3.9,145987,2,1899,0)="""RTN"",""SDES2SETCHECKOUT"",225,0)"
^XMB(3.9,145987,2,1900,0)=" ;"
^XMB(3.9,145987,2,1901,0)="""RTN"",""SDES2SETCHECKOUT"",226,0)"
^XMB(3.9,145987,2,1902,0)=" ; do checks"
^XMB(3.9,145987,2,1903,0)="""RTN"",""SDES2SETCHECKOUT"",227,0)"
^XMB(3.9,145987,2,1904,0)=" I 'SDPT!('SDSC)!($P(SDCL0,U,3)'=""C"") D UNLOCK(.SDLOCK) Q"
^XMB(3.9,145987,2,1905,0)="""RTN"",""SDES2SETCHECKOUT"",228,0)"
^XMB(3.9,145987,2,1906,0)=" I SDCL,+SDPT'=SDCL D UNLOCK(.SDLOCK) Q"
^XMB(3.9,145987,2,1907,0)="""RTN"",""SDES2SETCHECKOUT"",229,0)"
^XMB(3.9,145987,2,1908,0)=" I $P(SDPT,U,20) D UNLOCK(.SDLOCK) Q"
^XMB(3.9,145987,2,1909,0)="""RTN"",""SDES2SETCHECKOUT"",230,0)"
^XMB(3.9,145987,2,1910,0)=" I 'SDVSIT(""CLN"")!('SDVSIT(""DIV"")) D UNLOCK(.SDLOCK)"
^XMB(3.9,145987,2,1911,0)="""RTN"",""SDES2SETCHECKOUT"",231,0)"
^XMB(3.9,145987,2,1912,0)=" ;"
^XMB(3.9,145987,2,1913,0)="""RTN"",""SDES2SETCHECKOUT"",232,0)"
^XMB(3.9,145987,2,1914,0)=" ; set the rest"
^XMB(3.9,145987,2,1915,0)="""RTN"",""SDES2SETCHECKOUT"",233,0)"
^XMB(3.9,145987,2,1916,0)=" S SDVSIT(""DFN"")=DFN,SDVSIT(""LOC"")=SDCL"
^XMB(3.9,145987,2,1917,0)="""RTN"",""SDES2SETCHECKOUT"",234,0)"
^XMB(3.9,145987,2,1918,0)=" S:$P(SDSC,U,10) SDVSIT(""ELG"")=$P(SDSC,U,10)"
^XMB(3.9,145987,2,1919,0)="""RTN"",""SDES2SETCHECKOUT"",235,0)"
^XMB(3.9,145987,2,1920,0)=" S:$P(SDPT,U,16) SDVSIT(""TYP"")=$P(SDPT,U,16)"
^XMB(3.9,145987,2,1921,0)="""RTN"",""SDES2SETCHECKOUT"",236,0)"
^XMB(3.9,145987,2,1922,0)=" ;"
^XMB(3.9,145987,2,1923,0)="""RTN"",""SDES2SETCHECKOUT"",237,0)"
^XMB(3.9,145987,2,1924,0)=" ; call logic to add opt encounter(s)"
^XMB(3.9,145987,2,1925,0)="""RTN"",""SDES2SETCHECKOUT"",238,0)"
^XMB(3.9,145987,2,1926,0)=" S SDVSIT(""ORG"")=1,SDVSIT(""REF"")=SDDA,SDOE=$$SDOE(SDT,.SDVSIT,$G(SDVIEN))"
^XMB(3.9,145987,2,1927,0)="""RTN"",""SDES2SETCHECKOUT"",239,0)"
^XMB(3.9,145987,2,1928,0)=" I SDOE D"
^XMB(3.9,145987,2,1929,0)="""RTN"",""SDES2SETCHECKOUT"",240,0)"
^XMB(3.9,145987,2,1930,0)=" .N FDAIENS,ERR298,FDA298"
^XMB(3.9,145987,2,1931,0)="""RTN"",""SDES2SETCHECKOUT"",241,0)"
^XMB(3.9,145987,2,1932,0)=" .S FDAIENS=SDT_"",""_DFN_"","""
^XMB(3.9,145987,2,1933,0)="""RTN"",""SDES2SETCHECKOUT"",242,0)"
^XMB(3.9,145987,2,1934,0)=" .S FDA298(2.98,FDAIENS,21)=SDOE"
^XMB(3.9,145987,2,1935,0)="""RTN"",""SDES2SETCHECKOUT"",243,0)"
^XMB(3.9,145987,2,1936,0)=" .D FILE^DIE(,""FDA298"",""ERR298"")"
^XMB(3.9,145987,2,1937,0)="""RTN"",""SDES2SETCHECKOUT"",244,0)"
^XMB(3.9,145987,2,1938,0)=" .;"
^XMB(3.9,145987,2,1939,0)="""RTN"",""SDES2SETCHECKOUT"",245,0)"
^XMB(3.9,145987,2,1940,0)=" D CSTOP(SDOE,SDCL,.SDVSIT,SDT)  ;Process credit stop if applicable"
^XMB(3.9,145987,2,1941,0)="""RTN"",""SDES2SETCHECKOUT"",246,0)"
^XMB(3.9,145987,2,1942,0)=" D UNLOCK(.SDLOCK)"
^XMB(3.9,145987,2,1943,0)="""RTN"",""SDES2SETCHECKOUT"",247,0)"
