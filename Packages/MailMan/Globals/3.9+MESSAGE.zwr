^XMB(3.9,145980,2,3873,0)="""RTN"",""SDES2CANCELAPPT2"",93,0)"
^XMB(3.9,145980,2,3874,0)=" S APPTIEN=PARAMS(""APPT IEN""),CLINICIEN=PARAMS(""CLINIC IEN""),DFN=PARAMS(""DFN"")"
^XMB(3.9,145980,2,3875,0)="""RTN"",""SDES2CANCELAPPT2"",94,0)"
