^XMB(3.9,145980,2,3801,0)="""RTN"",""SDES2CANCELAPPT2"",57,0)"
^XMB(3.9,145980,2,3802,0)=" I PARAMS(""CANCELLED BY"")'=""C"",PARAMS(""CANCELLED BY"")'=""PC"" D ERRLOG^SDES2JSON(.SDERRORS,189) Q 0"
^XMB(3.9,145980,2,3803,0)="""RTN"",""SDES2CANCELAPPT2"",58,0)"
