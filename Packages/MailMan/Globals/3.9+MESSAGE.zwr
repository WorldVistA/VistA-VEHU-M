^XMB(3.9,145986,2,756,0)="WRT I $Y+8>IOSL D ASKH^FBAACCB0:$E(IOST,1,2)[""C-"" Q:FBAAOUT  W @IOF D HED"
^XMB(3.9,145986,2,757,0)="""RTN"",""FBAACCB"",71,0)"
^XMB(3.9,145986,2,758,0)=" S B(1617)=$S(B="""":"""",$D(^FBAA(161.7,B,0)):$P(^(0),""^""),1:"""")"
^XMB(3.9,145986,2,759,0)="""RTN"",""FBAACCB"",72,0)"
^XMB(3.9,145986,2,760,0)=" W !!,N,?35,$$SSN^FBAAUTL(J),?58,B(1617),?67,$$DATX^FBAAUTL($G(FBVCHDT)),!,?3,V,?42,VID,?55,FBIN,?67,$$DATX^FBAAUTL(FBIN(1))"
^XMB(3.9,145986,2,761,0)="""RTN"",""FBAACCB"",73,0)"
^XMB(3.9,145986,2,762,0)=" W !,$S($D(QQ):QQ_"")"",1:""""),$S(ZS=""R"":""*"",1:""""),$S(FBTYPE=""B3"":FBVP,1:""""),$S(FBTYPE=""B5"":FBPV,1:""""),$S($G(FBCAN)]"""":""+"",1:"""")"
^XMB(3.9,145986,2,763,0)="""RTN"",""FBAACCB"",74,0)"
^XMB(3.9,145986,2,764,0)=" I FBTYPE=""B3"" W ?4,$$DATX^FBAAUTL(D),?14,FBAACPT_$S($G(FBMODLE)]"""":""-""_$P(FBMODLE,"",""),1:""""),?24,CPTDESC,?54,FBFPPSC,?66,FBFPPSL"
^XMB(3.9,145986,2,765,0)="""RTN"",""FBAACCB"",75,0)"
^XMB(3.9,145986,2,766,0)=" I FBTYPE=""B5"" W ?4,$$DATX^FBAAUTL(D),?14,FBAACPT_$S($G(FBMODLE)]"""":""-""_$P(FBMODLE,"",""),1:""""),?24,CPTDESC,?56,FBFPPSC,?68,FBFPPSL"
^XMB(3.9,145986,2,767,0)="""RTN"",""FBAACCB"",76,0)"
^XMB(3.9,145986,2,768,0)=" I $P($G(FBMODLE),"","",2)]"""" D  Q:FBAAOUT"
^XMB(3.9,145986,2,769,0)="""RTN"",""FBAACCB"",77,0)"
^XMB(3.9,145986,2,770,0)=" . N FBI,FBMOD"
^XMB(3.9,145986,2,771,0)="""RTN"",""FBAACCB"",78,0)"
^XMB(3.9,145986,2,772,0)=" . F FBI=2:1 S FBMOD=$P(FBMODLE,"","",FBI) Q:FBMOD=""""  D  Q:FBAAOUT"
^XMB(3.9,145986,2,773,0)="""RTN"",""FBAACCB"",79,0)"
^XMB(3.9,145986,2,774,0)=" . . I $Y+5>IOSL D  Q:FBAAOUT"
^XMB(3.9,145986,2,775,0)="""RTN"",""FBAACCB"",80,0)"
^XMB(3.9,145986,2,776,0)=" . . . I $E(IOST,1,2)=""C-"" D ASKH^FBAACCB0 Q:FBAAOUT"
^XMB(3.9,145986,2,777,0)="""RTN"",""FBAACCB"",81,0)"
^XMB(3.9,145986,2,778,0)=" . . . W @IOF D HED W !,""(continued)"""
^XMB(3.9,145986,2,779,0)="""RTN"",""FBAACCB"",82,0)"
^XMB(3.9,145986,2,780,0)=" . . W !,?19,""-"",FBMOD"
^XMB(3.9,145986,2,781,0)="""RTN"",""FBAACCB"",83,0)"
^XMB(3.9,145986,2,782,0)=" W !?4,$J(A1,6),?17,$J(A2,6)"
^XMB(3.9,145986,2,783,0)="""RTN"",""FBAACCB"",84,0)"
^XMB(3.9,145986,2,784,0)=" ; write adjustment reasons, if null then write suspend code"
^XMB(3.9,145986,2,785,0)="""RTN"",""FBAACCB"",85,0)"
^XMB(3.9,145986,2,786,0)=" W ?30,$S(FBADJLR]"""":FBADJLR,1:T)"
^XMB(3.9,145986,2,787,0)="""RTN"",""FBAACCB"",86,0)"
^XMB(3.9,145986,2,788,0)=" ; write adjustment amounts, if null then write amount suspended"
^XMB(3.9,145986,2,789,0)="""RTN"",""FBAACCB"",87,0)"
^XMB(3.9,145986,2,790,0)=" W ?41,$S(FBADJLA]"""":FBADJLA,1:TAMT)"
^XMB(3.9,145986,2,791,0)="""RTN"",""FBAACCB"",88,0)"
^XMB(3.9,145986,2,792,0)=" ; write attachment IDs FB*3.5*164"
^XMB(3.9,145986,2,793,0)="""RTN"",""FBAACCB"",89,0)"
^XMB(3.9,145986,2,794,0)=" I FBTYPE=""B3"",$D(^FBAAC(J,1,K,1,L,1,M,10)) D"
^XMB(3.9,145986,2,795,0)="""RTN"",""FBAACCB"",90,0)"
^XMB(3.9,145986,2,796,0)=" . N AI,AID,AITI S AI=0 S WRTPC=""Attachment ID:"""
^XMB(3.9,145986,2,797,0)="""RTN"",""FBAACCB"",91,0)"
^XMB(3.9,145986,2,798,0)=" . F  S AI=$O(^FBAAC(J,1,K,1,L,1,M,10,AI)) Q:'AI  D"
^XMB(3.9,145986,2,799,0)="""RTN"",""FBAACCB"",92,0)"
^XMB(3.9,145986,2,800,0)=" . . S AID=$P($G(^FBAAC(J,1,K,1,L,1,M,10,AI,0)),U) I AI>1 S WRTPC=WRTPC_"","""
^XMB(3.9,145986,2,801,0)="""RTN"",""FBAACCB"",93,0)"
^XMB(3.9,145986,2,802,0)=" . . S WRTPC=WRTPC_"" ""_AID"
^XMB(3.9,145986,2,803,0)="""RTN"",""FBAACCB"",94,0)"
^XMB(3.9,145986,2,804,0)=" . . S AITI=$P($G(^FBAAC(J,1,K,1,L,1,M,10,AI,0)),U,2) I AITI D"
^XMB(3.9,145986,2,805,0)="""RTN"",""FBAACCB"",95,0)"
^XMB(3.9,145986,2,806,0)=" . . . S WRTPC=WRTPC_"" (""_$P($G(^IBE(353.3,AITI,0)),U)"
^XMB(3.9,145986,2,807,0)="""RTN"",""FBAACCB"",96,0)"
^XMB(3.9,145986,2,808,0)=" . . . S WRTPC=WRTPC_"" - """
^XMB(3.9,145986,2,809,0)="""RTN"",""FBAACCB"",97,0)"
^XMB(3.9,145986,2,810,0)=" . . . S WRTPC=WRTPC_$P($G(^IBE(353.3,AITI,0)),U,2)_"")"""
^XMB(3.9,145986,2,811,0)="""RTN"",""FBAACCB"",98,0)"
^XMB(3.9,145986,2,812,0)=" . . I $L(WRTPC)>IOM D WRTSTR^FBAACCB1(.WRTPC,IOM)"
^XMB(3.9,145986,2,813,0)="""RTN"",""FBAACCB"",99,0)"
^XMB(3.9,145986,2,814,0)=" . I $L(WRTPC)>0 D WRTSTR^FBAACCB1(.WRTPC,IOM)"
^XMB(3.9,145986,2,815,0)="""RTN"",""FBAACCB"",100,0)"
^XMB(3.9,145986,2,816,0)=" ;"
^XMB(3.9,145986,2,817,0)="""RTN"",""FBAACCB"",101,0)"
^XMB(3.9,145986,2,818,0)=" D PMNT^FBAACCB2 S FBINOLD=FBIN"
^XMB(3.9,145986,2,819,0)="""RTN"",""FBAACCB"",102,0)"
^XMB(3.9,145986,2,820,0)=" Q"
^XMB(3.9,145986,2,821,0)="""RTN"",""FBAACCB"",103,0)"
^XMB(3.9,145986,2,822,0)="HED W ""Patient Name"",?20,""('*' Reimbursement to Patient   '+' Cancellation Activity)"",!,?13,""('#' Voided Payment)"",?58,""Batch #"",?67,""Voucher Date"""
^XMB(3.9,145986,2,823,0)="""RTN"",""FBAACCB"",104,0)"
^XMB(3.9,145986,2,824,0)=" W !,?3,""Vendor Name"",?42,""Vendor ID"",?53,""Invoice #"",?67,""Date Rec'd."""
^XMB(3.9,145986,2,825,0)="""RTN"",""FBAACCB"",105,0)"
^XMB(3.9,145986,2,826,0)=" I FBTYPE=""B3"" D"
^XMB(3.9,145986,2,827,0)="""RTN"",""FBAACCB"",106,0)"
^XMB(3.9,145986,2,828,0)=" . W !,?4,""SVC DATE"",?14,""CPT-MOD"",?24,""SERVICE PROVIDED"",?54,""FPPS CLAIM"",?66,""FPPS LINE"""
^XMB(3.9,145986,2,829,0)="""RTN"",""FBAACCB"",107,0)"
^XMB(3.9,145986,2,830,0)=" . W !,?4,""CLAIMED"",?17,""PAID"",?30,""ADJ CODE"",?41,""ADJ AMOUNT"""
^XMB(3.9,145986,2,831,0)="""RTN"",""FBAACCB"",108,0)"
^XMB(3.9,145986,2,832,0)=" I FBTYPE=""B5"" D"
^XMB(3.9,145986,2,833,0)="""RTN"",""FBAACCB"",109,0)"
^XMB(3.9,145986,2,834,0)=" . W !,?4,""RX  DATE"",?14,""RX #"",?24,""DRUG NAME"",?56,""FPPS CLAIM"",?68,""FPPS LINE"""
^XMB(3.9,145986,2,835,0)="""RTN"",""FBAACCB"",110,0)"
^XMB(3.9,145986,2,836,0)=" . W !,?4,""CLAIMED"",?17,""PAID"",?30,""ADJ CODE"",?41,""ADJ AMOUNT"""
^XMB(3.9,145986,2,837,0)="""RTN"",""FBAACCB"",111,0)"
^XMB(3.9,145986,2,838,0)=" W !,Q,!"
^XMB(3.9,145986,2,839,0)="""RTN"",""FBAACCB"",112,0)"
^XMB(3.9,145986,2,840,0)=" Q"
^XMB(3.9,145986,2,841,0)="""RTN"",""FBAACCB"",113,0)"
^XMB(3.9,145986,2,842,0)="LISTP S Q="""",$P(Q,""="",80)=""="""
^XMB(3.9,145986,2,843,0)="""RTN"",""FBAACCB"",114,0)"
^XMB(3.9,145986,2,844,0)=" S IOP=$S($D(ION):ION,1:""HOME"") D ^%ZIS K IOP"
^XMB(3.9,145986,2,845,0)="""RTN"",""FBAACCB"",115,0)"
^XMB(3.9,145986,2,846,0)="ENP D HED S (FBAAOUT,FBINTOT)=0,FBINOLD="""""
^XMB(3.9,145986,2,847,0)="""RTN"",""FBAACCB"",116,0)"
^XMB(3.9,145986,2,848,0)=" F A=0:0 S A=$O(^FBAA(162.1,""AE"",B,A)) Q:A'>0!($G(FBAAOUT))  S FBIN=A D SETV^FBAACCB0 F B2=0:0 S B2=$O(^FBAA(162.1,""AE"",B,A,B2)) Q:B2'>0!($G(FBAAOUT))  D INTOT^FBAACCB0 I $D(^FBAA(162.1,A,""RX"",B2,0)) S Z(0)=^(0) D MORE^FBAACCB1"
^XMB(3.9,145986,2,849,0)="""RTN"",""FBAACCB"",117,0)"
^XMB(3.9,145986,2,850,0)=" I '$G(FBAAOUT) S FBIN=0 D INTOT^FBAACCB0"
^XMB(3.9,145986,2,851,0)="""RTN"",""FBAACCB"",118,0)"
^XMB(3.9,145986,2,852,0)=" Q"
^XMB(3.9,145986,2,853,0)="""RTN"",""FBAACCB0"")"
^XMB(3.9,145986,2,854,0)="0^15^B9605771"
^XMB(3.9,145986,2,855,0)="""RTN"",""FBAACCB0"",1,0)"
^XMB(3.9,145986,2,856,0)="FBAACCB0 ;AISC/GRR-CLERK CLOSE BATCH CONTINUED ;5/12/1999"
^XMB(3.9,145986,2,857,0)="""RTN"",""FBAACCB0"",2,0)"
^XMB(3.9,145986,2,858,0)=" ;;3.5;FEE BASIS;**5,4,116**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,859,0)="""RTN"",""FBAACCB0"",3,0)"
^XMB(3.9,145986,2,860,0)=" ;;Per VHA Directive 10-93-142, this routine should not be modified."
^XMB(3.9,145986,2,861,0)="""RTN"",""FBAACCB0"",4,0)"
^XMB(3.9,145986,2,862,0)="LISTT S Q="""",$P(Q,""="",80)=""="""
^XMB(3.9,145986,2,863,0)="""RTN"",""FBAACCB0"",5,0)"
^XMB(3.9,145986,2,864,0)=" S IOP=$S($D(ION):ION,1:""HOME"") D ^%ZIS K IOP"
^XMB(3.9,145986,2,865,0)="""RTN"",""FBAACCB0"",6,0)"
^XMB(3.9,145986,2,866,0)="ENT S FBAAOUT=0"
^XMB(3.9,145986,2,867,0)="""RTN"",""FBAACCB0"",7,0)"
^XMB(3.9,145986,2,868,0)=" D HEDP F J=0:0 S J=$O(^FBAAC(""AD"",B,J)) Q:J'>0!($G(FBAAOUT))  F K=0:0 S K=$O(^FBAAC(""AD"",B,J,K)) Q:K'>0!($G(FBAAOUT))  I $D(^FBAAC(J,3,K,0)) S Y(0)=^(0) D SETT"
^XMB(3.9,145986,2,869,0)="""RTN"",""FBAACCB0"",8,0)"
^XMB(3.9,145986,2,870,0)=" K FBCAN,FBCANDT,FBCANR,FBCK,FBCKDT,FBCKINT,FBDIS"
^XMB(3.9,145986,2,871,0)="""RTN"",""FBAACCB0"",9,0)"
^XMB(3.9,145986,2,872,0)=" Q"
^XMB(3.9,145986,2,873,0)="""RTN"",""FBAACCB0"",10,0)"
^XMB(3.9,145986,2,874,0)="HEDP W ?23,""'+' Represents Cancellation Activity"",!?4,""Patient Name"",?36,""SSN"",?49,""Date"",?56,""Travel Amount"",!,Q,! Q"
^XMB(3.9,145986,2,875,0)="""RTN"",""FBAACCB0"",11,0)"
^XMB(3.9,145986,2,876,0)="WRTT I $Y+7>IOSL D ASKH:$E(IOST,1,2)[""C-"" Q:FBAAOUT  W @IOF D HEDP"
^XMB(3.9,145986,2,877,0)="""RTN"",""FBAACCB0"",12,0)"
^XMB(3.9,145986,2,878,0)=" I A2'="".00"" W !,$S($D(QQ):QQ_"") "",1:""""),$S($G(FBCAN)]"""":""+"",1:""""),?4,N,?32,$E(S,1,3),""-"",$E(S,4,5),""-"",$E(S,6,10),?47,$E(D,4,5),""/"",$E(D,6,7),""/"",$E(D,2,3),?59,""$ "",$J(A2,4,2)  D PMNT^FBAACCB2 Q"
^XMB(3.9,145986,2,879,0)="""RTN"",""FBAACCB0"",13,0)"
^XMB(3.9,145986,2,880,0)="SETT S N=$S($D(^DPT(J,0)):$P(^(0),""^"",1),1:""""),S=$S(N]"""":$P(^(0),""^"",9),1:""""),A2=$P(Y(0),""^"",3),D=$P(Y(0),""^"",1) D FBCKT(J,K),WRTT Q"
^XMB(3.9,145986,2,881,0)="""RTN"",""FBAACCB0"",14,0)"
^XMB(3.9,145986,2,882,0)=" Q"
^XMB(3.9,145986,2,883,0)="""RTN"",""FBAACCB0"",15,0)"
^XMB(3.9,145986,2,884,0)="SETV S K=$S($D(^FBAA(162.1,A,0)):$P(^(0),""^"",4),1:"""")"
^XMB(3.9,145986,2,885,0)="""RTN"",""FBAACCB0"",16,0)"
^XMB(3.9,145986,2,886,0)="ENV S (V,VID)="""" I K]"""" S V=$S($D(^FBAAV(K,0)):$P(^(0),""^"",1),1:""""),VID=$S(V]"""":$P(^(0),""^"",2),1:"""")"
^XMB(3.9,145986,2,887,0)="""RTN"",""FBAACCB0"",17,0)"
^XMB(3.9,145986,2,888,0)=" Q"
^XMB(3.9,145986,2,889,0)="""RTN"",""FBAACCB0"",18,0)"
^XMB(3.9,145986,2,890,0)="ASKH S DIR(0)=""E"" D ^DIR K DIR S:'Y FBAAOUT=1 Q"
^XMB(3.9,145986,2,891,0)="""RTN"",""FBAACCB0"",19,0)"
^XMB(3.9,145986,2,892,0)="GMORE F K=0:0 S K=$O(^FBAAC(""AJ"",B,FBIN,J,K)) Q:K'>0!(FBAAOUT)  F L=0:0 S L=$O(^FBAAC(""AJ"",B,FBIN,J,K,L)) Q:L'>0!(FBAAOUT)  F M=0:0 S M=$O(^FBAAC(""AJ"",B,FBIN,J,K,L,M)) Q:M'>0!(FBAAOUT)  D SET^FBAACCB"
^XMB(3.9,145986,2,893,0)="""RTN"",""FBAACCB0"",20,0)"
^XMB(3.9,145986,2,894,0)=" Q"
^XMB(3.9,145986,2,895,0)="""RTN"",""FBAACCB0"",21,0)"
^XMB(3.9,145986,2,896,0)="INTOT ;; HIPAA 5010 - count line items that have 0.00 amount paid"
^XMB(3.9,145986,2,897,0)="""RTN"",""FBAACCB0"",22,0)"
^XMB(3.9,145986,2,898,0)=" ;I FBINOLD'=FBIN&(FBINTOT>0) W !!,?15,""Invoice #: ""_FBINOLD_""   Totals: $ ""_$J(FBINTOT,1,2) S FBINTOT=0 Q"
^XMB(3.9,145986,2,899,0)="""RTN"",""FBAACCB0"",23,0)"
^XMB(3.9,145986,2,900,0)=" I +FBINOLD'=0,FBINOLD'=FBIN&(FBINTOT]"""") W !!,?15,""Invoice #: ""_FBINOLD_""   Totals: $ ""_$J(FBINTOT,1,2) S FBINTOT=0 Q"
^XMB(3.9,145986,2,901,0)="""RTN"",""FBAACCB0"",24,0)"
^XMB(3.9,145986,2,902,0)=" Q"
^XMB(3.9,145986,2,903,0)="""RTN"",""FBAACCB0"",25,0)"
^XMB(3.9,145986,2,904,0)="Q K C,B,J,K,L,M,T,X,Y,FZ,A,A1,A2,B2,CPTDESC,DO,DA,DIC,DIRUT,DL,DR,DRX,DX,FBAACPT,FBAAOUT,FBIN,FBINOLD,FBINTOT,FBVP,FBTYPE,FBPV,N,Q,S,V,VID,ZIS,XY,ZS,FBMODLE,FBVCHDT"
^XMB(3.9,145986,2,905,0)="""RTN"",""FBAACCB0"",26,0)"
^XMB(3.9,145986,2,906,0)=" K FBAC,FBAP,FBDX,FBFD,FBI,FBK,FBLISTC,FBPDT,FBSC,FBTD Q"
^XMB(3.9,145986,2,907,0)="""RTN"",""FBAACCB0"",27,0)"
^XMB(3.9,145986,2,908,0)="FBCKT(J,K) ;set travel check variables"
^XMB(3.9,145986,2,909,0)="""RTN"",""FBAACCB0"",28,0)"
^XMB(3.9,145986,2,910,0)=" ;j,k required variables j=DA(1),k=DA"
^XMB(3.9,145986,2,911,0)="""RTN"",""FBAACCB0"",29,0)"
^XMB(3.9,145986,2,912,0)=" I 'J!('K) S (FBCAN,FBCK,FBCANDT,FBCANR,FBDIS,FBCKDT,FBCKINT)="""" Q"
^XMB(3.9,145986,2,913,0)="""RTN"",""FBAACCB0"",30,0)"
^XMB(3.9,145986,2,914,0)=" S FBCKIN=$G(^FBAAC(J,3,K,0))"
^XMB(3.9,145986,2,915,0)="""RTN"",""FBAACCB0"",31,0)"
^XMB(3.9,145986,2,916,0)=" S FBCAN=$P(FBCKIN,""^"",10),FBCK=$P(FBCKIN,""^"",7),FBCANDT=$P(FBCKIN,""^"",8),FBCANR=$P(FBCKIN,""^"",9),FBDIS=$P(FBCKIN,""^"",11),FBCKDT=$P(FBCKIN,""^"",6),FBCKINT=$P(FBCKIN,""^"",12)"
^XMB(3.9,145986,2,917,0)="""RTN"",""FBAACCB0"",32,0)"
^XMB(3.9,145986,2,918,0)=" K FBCKIN Q"
^XMB(3.9,145986,2,919,0)="""RTN"",""FBAACCB1"")"
^XMB(3.9,145986,2,920,0)="0^13^B36081848"
^XMB(3.9,145986,2,921,0)="""RTN"",""FBAACCB1"",1,0)"
^XMB(3.9,145986,2,922,0)="FBAACCB1 ;AISC/GRR-CLERK CLOSE BATCH CONTINUED ; 11/24/10 10:27am"
