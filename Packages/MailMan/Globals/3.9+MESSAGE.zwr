^XMB(3.9,145980,2,3877,0)="""RTN"",""SDES2CANCELAPPT2"",95,0)"
^XMB(3.9,145980,2,3878,0)=" S NOTE=$G(PARAMS(""NOTE"")),EAS=$G(SDCONTEXT(""ACHERON AUDIT ID"")),NEWPID=$G(PARAMS(""NEW PID""))"
^XMB(3.9,145980,2,3879,0)="""RTN"",""SDES2CANCELAPPT2"",96,0)"
^XMB(3.9,145980,2,3880,0)=" ;"
^XMB(3.9,145980,2,3881,0)="""RTN"",""SDES2CANCELAPPT2"",97,0)"
^XMB(3.9,145980,2,3882,0)=" N SDATA,APPTENDTIME,APPTLENGTH,APPTSTARTTIME,APPTTYPE,CLINICSUBIEN,EDITED,MRTC,OLDRECALLPTR,PROVIEN,WALKIN"
^XMB(3.9,145980,2,3883,0)="""RTN"",""SDES2CANCELAPPT2"",98,0)"
