^XMB(3.9,145986,2,3851,0)="""RTN"",""FBPCR"",176,0)"
^XMB(3.9,145986,2,3852,0)=" W !,""Patient: "",$G(FBPNAME),?40,""Pat. ID: "",$G(FBPID),?62,""DOB: "",$G(FBDOB)"
^XMB(3.9,145986,2,3853,0)="""RTN"",""FBPCR"",177,0)"
^XMB(3.9,145986,2,3854,0)=" W !"
^XMB(3.9,145986,2,3855,0)="""RTN"",""FBPCR"",178,0)"
^XMB(3.9,145986,2,3856,0)=" S FBFIRST=1  ;FB*3.5*163"
^XMB(3.9,145986,2,3857,0)="""RTN"",""FBPCR"",179,0)"
^XMB(3.9,145986,2,3858,0)=" I '$D(DFN) Q  ;FB*3.5*163"
^XMB(3.9,145986,2,3859,0)="""RTN"",""FBPCR"",180,0)"
^XMB(3.9,145986,2,3860,0)=" D PATDEMO ;FB*3.5*163"
^XMB(3.9,145986,2,3861,0)="""RTN"",""FBPCR"",181,0)"
^XMB(3.9,145986,2,3862,0)=" I FBINCUNK=1,$D(^TMP($J,""FBINSIBAPI"",+$G(DFN))) W "">> Warning: accurate insurance information for the patient is unavailable"""
^XMB(3.9,145986,2,3863,0)="""RTN"",""FBPCR"",182,0)"
^XMB(3.9,145986,2,3864,0)=" W !?3,""('*' Represents Reimbursement to Patient"",?50,""'#' Represents Voided Payment)"""
^XMB(3.9,145986,2,3865,0)="""RTN"",""FBPCR"",183,0)"
