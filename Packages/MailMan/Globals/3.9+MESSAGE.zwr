^XMB(3.9,145983,2,1727,0)="""RTN"",""RCRPTLR"",77,0)"
^XMB(3.9,145983,2,1728,0)=" Q"
^XMB(3.9,145983,2,1729,0)="""RTN"",""RCRPTLR"",78,0)"
^XMB(3.9,145983,2,1730,0)=" ;"
^XMB(3.9,145983,2,1731,0)="""RTN"",""RCRPTLR"",79,0)"
^XMB(3.9,145983,2,1732,0)="HDR ; print header"
^XMB(3.9,145983,2,1733,0)="""RTN"",""RCRPTLR"",80,0)"
^XMB(3.9,145983,2,1734,0)=" I PAGE>0,'$D(ZTQUEUED) D PAUSE^RCRPRPU"
^XMB(3.9,145983,2,1735,0)="""RTN"",""RCRPTLR"",81,0)"
^XMB(3.9,145983,2,1736,0)=" W @IOF"
^XMB(3.9,145983,2,1737,0)="""RTN"",""RCRPTLR"",82,0)"
