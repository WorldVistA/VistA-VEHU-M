^XMB(3.9,145986,2,4009,0)="""RTN"",""FBPCR"",255,0)"
^XMB(3.9,145986,2,4010,0)=" S:FBYN<0 FBERR=$O(FBRTN(""IBBAPI"",""INSUR"",""ERROR"",0))"
