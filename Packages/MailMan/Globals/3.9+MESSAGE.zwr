^XMB(3.9,145946,2,6184,0)=" . . S XX=$E($$GET1^DIQ(36,IBCNS_"","",.01),1,25)"
^XMB(3.9,145946,2,6185,0)="""RTN"",""IBCOPP"",65,0)"
^XMB(3.9,145946,2,6186,0)=" . . S ^TMP(""IBINC"",$J,XX,IBCNS)="""""
^XMB(3.9,145946,2,6187,0)="""RTN"",""IBCOPP"",66,0)"
