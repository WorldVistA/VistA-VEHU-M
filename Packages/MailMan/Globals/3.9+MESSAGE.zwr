^XMB(3.9,145944,2,251,0)="""QUES"",""XPZ2"",""M"")"
^XMB(3.9,145944,2,252,0)="D XPZ2^XPDIQ"
^XMB(3.9,145944,2,253,0)="""RTN"")"
^XMB(3.9,145944,2,254,0)=5
^XMB(3.9,145944,2,255,0)="""RTN"",""IBJDF41"")"
^XMB(3.9,145944,2,256,0)="0^4^B152147973"
^XMB(3.9,145944,2,257,0)="""RTN"",""IBJDF41"",1,0)"
^XMB(3.9,145944,2,258,0)="IBJDF41 ;ALB/RB - FIRST PARTY FOLLOW-UP REPORT (COMPILE) ;15-APR-00"
^XMB(3.9,145944,2,259,0)="""RTN"",""IBJDF41"",2,0)"
^XMB(3.9,145944,2,260,0)=" ;;2.0;INTEGRATED BILLING;**123,159,204,356,451,473,568,618,651,694,705,715,739**;21-MAR-94;Build 0"
^XMB(3.9,145944,2,261,0)="""RTN"",""IBJDF41"",3,0)"
^XMB(3.9,145944,2,262,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145944,2,263,0)="""RTN"",""IBJDF41"",4,0)"
^XMB(3.9,145944,2,264,0)=" ;"
^XMB(3.9,145944,2,265,0)="""RTN"",""IBJDF41"",5,0)"
^XMB(3.9,145944,2,266,0)=" ; Reference to FILE 433.001 in ICR #7321"
^XMB(3.9,145944,2,267,0)="""RTN"",""IBJDF41"",6,0)"
^XMB(3.9,145944,2,268,0)=" ;"
^XMB(3.9,145944,2,269,0)="""RTN"",""IBJDF41"",7,0)"
^XMB(3.9,145944,2,270,0)="ST ; - Tasked entry point."
^XMB(3.9,145944,2,271,0)="""RTN"",""IBJDF41"",8,0)"
^XMB(3.9,145944,2,272,0)=" K IB,IBCAT,^TMP(""IBJDF4"",$J)"
^XMB(3.9,145944,2,273,0)="""RTN"",""IBJDF41"",9,0)"
^XMB(3.9,145944,2,274,0)=" S IBQ=0"
^XMB(3.9,145944,2,275,0)="""RTN"",""IBJDF41"",10,0)"
^XMB(3.9,145944,2,276,0)=" ;"
^XMB(3.9,145944,2,277,0)="""RTN"",""IBJDF41"",11,0)"
^XMB(3.9,145944,2,278,0)=" ; - Set selected categories for report."
^XMB(3.9,145944,2,279,0)="""RTN"",""IBJDF41"",12,0)"
^XMB(3.9,145944,2,280,0)=" I IBSEL[1 S IBCAT(2)=1"
^XMB(3.9,145944,2,281,0)="""RTN"",""IBJDF41"",13,0)"
^XMB(3.9,145944,2,282,0)=" I IBSEL[2 S IBCAT(1)=2"
^XMB(3.9,145944,2,283,0)="""RTN"",""IBJDF41"",14,0)"
^XMB(3.9,145944,2,284,0)=" I IBSEL[3 S IBCAT(18)=3 F X=22,23 S IBCAT(X)=3"
^XMB(3.9,145944,2,285,0)="""RTN"",""IBJDF41"",15,0)"
^XMB(3.9,145944,2,286,0)=" I IBSEL[4 F X=33:1:39 S IBCAT(X)=4"
^XMB(3.9,145944,2,287,0)="""RTN"",""IBJDF41"",16,0)"
^XMB(3.9,145944,2,288,0)=" ; *** new code"
^XMB(3.9,145944,2,289,0)="""RTN"",""IBJDF41"",17,0)"
^XMB(3.9,145944,2,290,0)=" I IBSEL[5 D"
^XMB(3.9,145944,2,291,0)="""RTN"",""IBJDF41"",18,0)"
^XMB(3.9,145944,2,292,0)=" . F X=61:1:74 S IBCAT(X)=5"
^XMB(3.9,145944,2,293,0)="""RTN"",""IBJDF41"",19,0)"
^XMB(3.9,145944,2,294,0)=" . F X=81:1:85 S IBCAT(X)=5"
^XMB(3.9,145944,2,295,0)="""RTN"",""IBJDF41"",20,0)"
^XMB(3.9,145944,2,296,0)=" ;"
^XMB(3.9,145944,2,297,0)="""RTN"",""IBJDF41"",21,0)"
^XMB(3.9,145944,2,298,0)=" ; - Print the header line for the Excel spreadsheet"
^XMB(3.9,145944,2,299,0)="""RTN"",""IBJDF41"",22,0)"
^XMB(3.9,145944,2,300,0)=" I $G(IBEXCEL) D PHDL"
^XMB(3.9,145944,2,301,0)="""RTN"",""IBJDF41"",23,0)"
^XMB(3.9,145944,2,302,0)=" ;"
^XMB(3.9,145944,2,303,0)="""RTN"",""IBJDF41"",24,0)"
^XMB(3.9,145944,2,304,0)=" ; - Find data required for report."
^XMB(3.9,145944,2,305,0)="""RTN"",""IBJDF41"",25,0)"
^XMB(3.9,145944,2,306,0)=" F IB=16,19,40 D  G:IBQ ENQ"
^XMB(3.9,145944,2,307,0)="""RTN"",""IBJDF41"",26,0)"
^XMB(3.9,145944,2,308,0)=" . I IBSTA=""A"",IB'=16 Q  ;      Active AR's only."
^XMB(3.9,145944,2,309,0)="""RTN"",""IBJDF41"",27,0)"
^XMB(3.9,145944,2,310,0)=" . I IBSTA=""S"",IB=16 Q   ;      Suspended AR's only."
^XMB(3.9,145944,2,311,0)="""RTN"",""IBJDF41"",28,0)"
^XMB(3.9,145944,2,312,0)=" . I IB'=40 D "
^XMB(3.9,145944,2,313,0)="""RTN"",""IBJDF41"",29,0)"
^XMB(3.9,145944,2,314,0)=" . . S IBCAT="""""
^XMB(3.9,145944,2,315,0)="""RTN"",""IBJDF41"",30,0)"
^XMB(3.9,145944,2,316,0)=" . . F  S IBCAT=$O(IBCAT(IBCAT)) Q:IBCAT=""""  D"
^XMB(3.9,145944,2,317,0)="""RTN"",""IBJDF41"",31,0)"
^XMB(3.9,145944,2,318,0)=" . . . D INIT^IBJDF43"
^XMB(3.9,145944,2,319,0)="""RTN"",""IBJDF41"",32,0)"
^XMB(3.9,145944,2,320,0)=" . S IBA=0"
^XMB(3.9,145944,2,321,0)="""RTN"",""IBJDF41"",33,0)"
^XMB(3.9,145944,2,322,0)=" . F  S IBA=$O(^PRCA(430,""AC"",IB,IBA)) Q:'IBA  D  Q:IBQ"
^XMB(3.9,145944,2,323,0)="""RTN"",""IBJDF41"",34,0)"
^XMB(3.9,145944,2,324,0)=" . . D PROC"
^XMB(3.9,145944,2,325,0)="""RTN"",""IBJDF41"",35,0)"
^XMB(3.9,145944,2,326,0)=" ;"
^XMB(3.9,145944,2,327,0)="""RTN"",""IBJDF41"",36,0)"
^XMB(3.9,145944,2,328,0)=" I 'IBQ,'$G(IBEXCEL) D EN^IBJDF42 ; Print the report."
^XMB(3.9,145944,2,329,0)="""RTN"",""IBJDF41"",37,0)"
^XMB(3.9,145944,2,330,0)=" ;"
^XMB(3.9,145944,2,331,0)="""RTN"",""IBJDF41"",38,0)"
^XMB(3.9,145944,2,332,0)="ENQ K ^TMP(""IBJDF4"",$J)"
^XMB(3.9,145944,2,333,0)="""RTN"",""IBJDF41"",39,0)"
^XMB(3.9,145944,2,334,0)=" I $D(ZTQUEUED) S ZTREQ=""@"" G ENQ1"
^XMB(3.9,145944,2,335,0)="""RTN"",""IBJDF41"",40,0)"
^XMB(3.9,145944,2,336,0)=" ;"
^XMB(3.9,145944,2,337,0)="""RTN"",""IBJDF41"",41,0)"
^XMB(3.9,145944,2,338,0)=" D ^%ZISC"
^XMB(3.9,145944,2,339,0)="""RTN"",""IBJDF41"",42,0)"
^XMB(3.9,145944,2,340,0)="ENQ1 K IB,IB0,IBA,IBA1,IBADM,IBAGE,IBAR,IBAR1,IBBA,IBBN,IBBU,IBC,IBCAT,IBCAT1"
^XMB(3.9,145944,2,341,0)="""RTN"",""IBJDF41"",43,0)"
^XMB(3.9,145944,2,342,0)=" K IBELIG,IBEXCEL,IBFLG,IBAI,IBAIQ,IBIDX,IBIO,IBINT,IBN,IBPA,IBPD,IBPAT"
^XMB(3.9,145944,2,343,0)="""RTN"",""IBJDF41"",44,0)"
^XMB(3.9,145944,2,344,0)=" K IBPT,IBQ,IBRFD,IBRFT,IBSRC,IBRP,IBVA,COM,COM1,DAT,DFN,X,X1,X2,Y,Z"
^XMB(3.9,145944,2,345,0)="""RTN"",""IBJDF41"",45,0)"
^XMB(3.9,145944,2,346,0)=" Q"
^XMB(3.9,145944,2,347,0)="""RTN"",""IBJDF41"",46,0)"
^XMB(3.9,145944,2,348,0)=" ;"
^XMB(3.9,145944,2,349,0)="""RTN"",""IBJDF41"",47,0)"
^XMB(3.9,145944,2,350,0)="PROC ; - Process data for report(s)."
^XMB(3.9,145944,2,351,0)="""RTN"",""IBJDF41"",48,0)"
^XMB(3.9,145944,2,352,0)=" I IBA#100=0 D  Q:IBQ"
^XMB(3.9,145944,2,353,0)="""RTN"",""IBJDF41"",49,0)"
^XMB(3.9,145944,2,354,0)=" . S IBQ=$$STOP^IBOUTL(""First Party Follow-Up Report"")"
^XMB(3.9,145944,2,355,0)="""RTN"",""IBJDF41"",50,0)"
^XMB(3.9,145944,2,356,0)=" S IBAR=$G(^PRCA(430,IBA,0)) I 'IBAR Q"
^XMB(3.9,145944,2,357,0)="""RTN"",""IBJDF41"",51,0)"
^XMB(3.9,145944,2,358,0)=" S IBCAT=+$P(IBAR,U,2) I '$D(IBCAT(IBCAT)) Q  ; Get valid AR category."
^XMB(3.9,145944,2,359,0)="""RTN"",""IBJDF41"",52,0)"
^XMB(3.9,145944,2,360,0)=" I '$$CLMACT^IBJD(IBA,IBCAT) Q  ;               Invalid IB claim/action."
^XMB(3.9,145944,2,361,0)="""RTN"",""IBJDF41"",53,0)"
^XMB(3.9,145944,2,362,0)=" S IBSUSTYP="""""
^XMB(3.9,145944,2,363,0)="""RTN"",""IBJDF41"",54,0)"
^XMB(3.9,145944,2,364,0)=" I IB=40 S IBSUSTYP=$$SUST(IBA)"
^XMB(3.9,145944,2,365,0)="""RTN"",""IBJDF41"",55,0)"
^XMB(3.9,145944,2,366,0)=" I IBSTA=""S"",IBSELST'[("",""_IBSUSTYP_"","") Q  ;   Filter by suspended type IB*2*568/DRF"
^XMB(3.9,145944,2,367,0)="""RTN"",""IBJDF41"",56,0)"
^XMB(3.9,145944,2,368,0)=" S IBPT=$$PAT(IBA) I IBPT="""" Q  ;               Get patient info."
^XMB(3.9,145944,2,369,0)="""RTN"",""IBJDF41"",57,0)"
^XMB(3.9,145944,2,370,0)=" S DFN=$P(IBPT,U,2)"
^XMB(3.9,145944,2,371,0)="""RTN"",""IBJDF41"",58,0)"
^XMB(3.9,145944,2,372,0)=" S IBAGE=$$FMDIFF^XLFDT(DT,+$P(IBAR,U,10))"
^XMB(3.9,145944,2,373,0)="""RTN"",""IBJDF41"",59,0)"
^XMB(3.9,145944,2,374,0)=" I IBSMN,IBAGE<IBSMN!(IBAGE>IBSMX) Q  ;         AR outside age range."
^XMB(3.9,145944,2,375,0)="""RTN"",""IBJDF41"",60,0)"
^XMB(3.9,145944,2,376,0)=" S IBVA=$$VA^IBJD1(DFN),IBBN=$P(IBAR,U),IBPD=$P($$PYMT^IBJD1(IBA),U)"
^XMB(3.9,145944,2,377,0)="""RTN"",""IBJDF41"",61,0)"
^XMB(3.9,145944,2,378,0)=" S IBPAT=$P(IBPT,U)_""@@""_DFN"
^XMB(3.9,145944,2,379,0)="""RTN"",""IBJDF41"",62,0)"
^XMB(3.9,145944,2,380,0)=" ;"
^XMB(3.9,145944,2,381,0)="""RTN"",""IBJDF41"",63,0)"
^XMB(3.9,145944,2,382,0)=" ; - Check the AR balance amounts, if necessary."
^XMB(3.9,145944,2,383,0)="""RTN"",""IBJDF41"",64,0)"
^XMB(3.9,145944,2,384,0)=" S (IBADM,IBBA,IBINT,IBPA)=0,IBN=$G(^PRCA(430,IBA,7))"
^XMB(3.9,145944,2,385,0)="""RTN"",""IBJDF41"",65,0)"
^XMB(3.9,145944,2,386,0)=" F X=1:1:5 D"
^XMB(3.9,145944,2,387,0)="""RTN"",""IBJDF41"",66,0)"
^XMB(3.9,145944,2,388,0)=" . S IBBA=IBBA+$P(IBN,U,X)"
^XMB(3.9,145944,2,389,0)="""RTN"",""IBJDF41"",67,0)"
^XMB(3.9,145944,2,390,0)=" . S:X=1 IBPA=+IBN S:X=2 IBINT=$P(IBN,U,2) S:X=3 IBADM=$P(IBN,U,3)"
^XMB(3.9,145944,2,391,0)="""RTN"",""IBJDF41"",68,0)"
^XMB(3.9,145944,2,392,0)=" ;"
^XMB(3.9,145944,2,393,0)="""RTN"",""IBJDF41"",69,0)"
^XMB(3.9,145944,2,394,0)=" I '$G(IBEXCEL) D EN^IBJDF43 I IBRPT=""S""!(IBRPT=""O"") Q  ;   Get summary stats."
^XMB(3.9,145944,2,395,0)="""RTN"",""IBJDF41"",70,0)"
^XMB(3.9,145944,2,396,0)=" ;"
^XMB(3.9,145944,2,397,0)="""RTN"",""IBJDF41"",71,0)"
^XMB(3.9,145944,2,398,0)=" I IBSAM,IBBA<IBSAM Q"
^XMB(3.9,145944,2,399,0)="""RTN"",""IBJDF41"",72,0)"
^XMB(3.9,145944,2,400,0)=" ;"
^XMB(3.9,145944,2,401,0)="""RTN"",""IBJDF41"",73,0)"
^XMB(3.9,145944,2,402,0)=" ; - Check if AR was referred to R-Regional Counsel, D-DMC, T-TOP,"
^XMB(3.9,145944,2,403,0)="""RTN"",""IBJDF41"",74,0)"
^XMB(3.9,145944,2,404,0)=" ;   or C-CROSS SERVICING and exclude, if necessary."
^XMB(3.9,145944,2,405,0)="""RTN"",""IBJDF41"",75,0)"
^XMB(3.9,145944,2,406,0)=" S IB0=$S(IB=40:19,1:IB),IBIDX=0,IBRFT="""""
^XMB(3.9,145944,2,407,0)="""RTN"",""IBJDF41"",76,0)"
^XMB(3.9,145944,2,408,0)=" S IBAIQ=0,IBAI=$G(^TMP(""IBJDF4"",$J,IBPAT,0,""A""))"
^XMB(3.9,145944,2,409,0)="""RTN"",""IBJDF41"",77,0)"
^XMB(3.9,145944,2,410,0)=" S IBRFD=$P($G(^PRCA(430,IBA,6)),U,4)"
^XMB(3.9,145944,2,411,0)="""RTN"",""IBJDF41"",78,0)"
^XMB(3.9,145944,2,412,0)=" I IBRPT=""D"",IBRFD D  I IBAIQ Q                   ; Referred to RC"
^XMB(3.9,145944,2,413,0)="""RTN"",""IBJDF41"",79,0)"
^XMB(3.9,145944,2,414,0)=" . S IBRFT=""R"" I IBAI'[""R"" S IBAI=IBAI_""R"""
^XMB(3.9,145944,2,415,0)="""RTN"",""IBJDF41"",80,0)"
^XMB(3.9,145944,2,416,0)=" . I 'IBSRC S IBAIQ=1 Q"
^XMB(3.9,145944,2,417,0)="""RTN"",""IBJDF41"",81,0)"
^XMB(3.9,145944,2,418,0)=" . D SREF(""R"",IBRFD,IB0,,.IBIDX)"
^XMB(3.9,145944,2,419,0)="""RTN"",""IBJDF41"",82,0)"
^XMB(3.9,145944,2,420,0)=" S IBRFD=+$G(^PRCA(430,IBA,12))"
^XMB(3.9,145944,2,421,0)="""RTN"",""IBJDF41"",83,0)"
^XMB(3.9,145944,2,422,0)=" I IBRPT=""D"",IBRFD D                              ; Referred to DMC"
^XMB(3.9,145944,2,423,0)="""RTN"",""IBJDF41"",84,0)"
^XMB(3.9,145944,2,424,0)=" . S IBRFT=IBRFT_""D"" I IBAI'[""D"" S IBAI=IBAI_""D"""
^XMB(3.9,145944,2,425,0)="""RTN"",""IBJDF41"",85,0)"
^XMB(3.9,145944,2,426,0)=" . D SREF(""D"",IBRFD,IB0,,.IBIDX)"
^XMB(3.9,145944,2,427,0)="""RTN"",""IBJDF41"",86,0)"
^XMB(3.9,145944,2,428,0)=" S IBRFD=+$G(^PRCA(430,IBA,14))"
^XMB(3.9,145944,2,429,0)="""RTN"",""IBJDF41"",87,0)"
^XMB(3.9,145944,2,430,0)=" I IBRPT=""D"",IBRFD D                              ; Referred to TOP"
^XMB(3.9,145944,2,431,0)="""RTN"",""IBJDF41"",88,0)"
^XMB(3.9,145944,2,432,0)=" . S IBRFT=IBRFT_""T"" I IBAI'[""T"" S IBAI=IBAI_""T"""
^XMB(3.9,145944,2,433,0)="""RTN"",""IBJDF41"",89,0)"
^XMB(3.9,145944,2,434,0)=" . D SREF(""T"",IBRFD,IB0,,.IBIDX)"
^XMB(3.9,145944,2,435,0)="""RTN"",""IBJDF41"",90,0)"
^XMB(3.9,145944,2,436,0)=" ; PRCA*4.5*338 added CS "
^XMB(3.9,145944,2,437,0)="""RTN"",""IBJDF41"",91,0)"
^XMB(3.9,145944,2,438,0)=" S IBRFD=+$G(^PRCA(430,IBA,15))"
^XMB(3.9,145944,2,439,0)="""RTN"",""IBJDF41"",92,0)"
^XMB(3.9,145944,2,440,0)=" I IBRPT=""D"",IBRFD D                              ; Referred to CS "
^XMB(3.9,145944,2,441,0)="""RTN"",""IBJDF41"",93,0)"
^XMB(3.9,145944,2,442,0)=" . S IBRFT=IBRFT_""C"" I IBAI'[""C"" S IBAI=IBAI_""C"""
^XMB(3.9,145944,2,443,0)="""RTN"",""IBJDF41"",94,0)"
^XMB(3.9,145944,2,444,0)=" . D SREF(""C"",IBRFD,IB0,,.IBIDX)"
^XMB(3.9,145944,2,445,0)="""RTN"",""IBJDF41"",95,0)"
^XMB(3.9,145944,2,446,0)=" ;"
^XMB(3.9,145944,2,447,0)="""RTN"",""IBJDF41"",96,0)"
^XMB(3.9,145944,2,448,0)=" ; - Check if AR is on P-Repayment plan or F-Defaulted repayment plan."
^XMB(3.9,145944,2,449,0)="""RTN"",""IBJDF41"",97,0)"
^XMB(3.9,145944,2,450,0)=" ;   and exclude if repayment plan is active."
^XMB(3.9,145944,2,451,0)="""RTN"",""IBJDF41"",98,0)"
^XMB(3.9,145944,2,452,0)=" S IBRP=$$RP(IBA)"
^XMB(3.9,145944,2,453,0)="""RTN"",""IBJDF41"",99,0)"
^XMB(3.9,145944,2,454,0)=" I IBRP D"
^XMB(3.9,145944,2,455,0)="""RTN"",""IBJDF41"",100,0)"
^XMB(3.9,145944,2,456,0)=" . I IBRP=2 S IBRFT=IBRFT_""F""  I IBAI'[""F"" S IBAI=IBAI_""F"""
^XMB(3.9,145944,2,457,0)="""RTN"",""IBJDF41"",101,0)"
^XMB(3.9,145944,2,458,0)=" . I IBRP=1 S IBRFT=IBRFT_""P"" I IBAI'[""P""&(IBAI'[""F"") S IBAI=IBAI_""P"""
^XMB(3.9,145944,2,459,0)="""RTN"",""IBJDF41"",102,0)"
^XMB(3.9,145944,2,460,0)=" . D SREF(""P"",$P(IBRP,""^"",2),IB0,$S(+IBRP=2:1,1:0),.IBIDX)"
^XMB(3.9,145944,2,461,0)="""RTN"",""IBJDF41"",103,0)"
^XMB(3.9,145944,2,462,0)=" ;"
^XMB(3.9,145944,2,463,0)="""RTN"",""IBJDF41"",104,0)"
^XMB(3.9,145944,2,464,0)=" I IBIDX S IBFLG=1"
^XMB(3.9,145944,2,465,0)="""RTN"",""IBJDF41"",105,0)"
^XMB(3.9,145944,2,466,0)=" ;"
^XMB(3.9,145944,2,467,0)="""RTN"",""IBJDF41"",106,0)"
^XMB(3.9,145944,2,468,0)=" ; - Check if VA Employee"
^XMB(3.9,145944,2,469,0)="""RTN"",""IBJDF41"",107,0)"
^XMB(3.9,145944,2,470,0)=" I $P(IBVA,""^"")[""*"",IBAI'[""V"" S IBAI=IBAI_""V"""
^XMB(3.9,145944,2,471,0)="""RTN"",""IBJDF41"",108,0)"
^XMB(3.9,145944,2,472,0)=" ;"
^XMB(3.9,145944,2,473,0)="""RTN"",""IBJDF41"",109,0)"
^XMB(3.9,145944,2,474,0)=" I IBAI'="""" S ^TMP(""IBJDF4"",$J,IBPAT,0,""A"")=IBAI"
^XMB(3.9,145944,2,475,0)="""RTN"",""IBJDF41"",110,0)"
^XMB(3.9,145944,2,476,0)=" ;"
^XMB(3.9,145944,2,477,0)="""RTN"",""IBJDF41"",111,0)"
^XMB(3.9,145944,2,478,0)=" ; IB*2.0*451 - Check for EEOB on associated 3rd party bills and attach EOB indicator '%' if applicable"
^XMB(3.9,145944,2,479,0)="""RTN"",""IBJDF41"",112,0)"
^XMB(3.9,145944,2,480,0)=" S IBBN=$$IBEEOBCK(IBBN,DFN)_IBBN  ; Pass AR BILL#, Pat ID"
^XMB(3.9,145944,2,481,0)="""RTN"",""IBJDF41"",113,0)"
^XMB(3.9,145944,2,482,0)=" ;"
^XMB(3.9,145944,2,483,0)="""RTN"",""IBJDF41"",114,0)"
^XMB(3.9,145944,2,484,0)=" ; - Set up indexes for detail report."
^XMB(3.9,145944,2,485,0)="""RTN"",""IBJDF41"",115,0)"
^XMB(3.9,145944,2,486,0)=" I $G(IBEXCEL) D  Q"
^XMB(3.9,145944,2,487,0)="""RTN"",""IBJDF41"",116,0)"
^XMB(3.9,145944,2,488,0)=" . S IBEXCEL1=$P($G(^PRCA(430.2,IBCAT,0)),U,2)_U_$P(IBPT,U,3)_U_$P(IBVA,U)_U_U_$$DT^IBJD($P(IBPT,U,6),1)_U_$$ELIG^IBJDF42(+$P(IBPT,U,5))_U ;IB*2.0*739"
^XMB(3.9,145944,2,489,0)="""RTN"",""IBJDF41"",117,0)"
^XMB(3.9,145944,2,490,0)=" . S IBEXCEL1=IBEXCEL1_$$GET1^DIQ(2,DFN,.381)_U_$$MTRX(DFN)_U_IBBN_U_$S(IB=16:""A"",1:""S"")_U_$S(""BS""[IBSTA:$$ABBR($G(IBSUSTYP)),1:"""")_U_IBRFT_U_$$DT^IBJD($P(IBAR,U,10),1)_U_$$DT^IBJD(IBPD,1)_U_IBBA_U_IBPA_U_IBINT_U_IBADM_U"
^XMB(3.9,145944,2,491,0)="""RTN"",""IBJDF41"",118,0)"
^XMB(3.9,145944,2,492,0)=" . I IBSH D COM"
^XMB(3.9,145944,2,493,0)="""RTN"",""IBJDF41"",119,0)"
^XMB(3.9,145944,2,494,0)=" . S IBD=0 I DAT!IBPD S IBD=$$FMDIFF^XLFDT(DT,$S('DAT:IBPD,1:$G(DAT)))"
^XMB(3.9,145944,2,495,0)="""RTN"",""IBJDF41"",120,0)"
^XMB(3.9,145944,2,496,0)=" . S IBEXCEL1=IBEXCEL1_U_IBD"
^XMB(3.9,145944,2,497,0)="""RTN"",""IBJDF41"",121,0)"
^XMB(3.9,145944,2,498,0)=" . W !,IBEXCEL1 K IBD,IBEXCEL1"
^XMB(3.9,145944,2,499,0)="""RTN"",""IBJDF41"",122,0)"
^XMB(3.9,145944,2,500,0)=" ;"
^XMB(3.9,145944,2,501,0)="""RTN"",""IBJDF41"",123,0)"
^XMB(3.9,145944,2,502,0)=" I '($D(^TMP(""IBJDF4"",$J,IBPAT))#10) D"
^XMB(3.9,145944,2,503,0)="""RTN"",""IBJDF41"",124,0)"
^XMB(3.9,145944,2,504,0)=" . S ^TMP(""IBJDF4"",$J,IBPAT)=$P(IBPT,U,3,5)_U_$$MTRX(DFN)_U_$P(IBPT,U,6)_""^""_$P(IBVA,""^"",2)_""^""_$$ACCBAL($P(IBPT,U,7))"
^XMB(3.9,145944,2,505,0)="""RTN"",""IBJDF41"",125,0)"
^XMB(3.9,145944,2,506,0)=" S ^TMP(""IBJDF4"",$J,IBPAT,IB0,IBCAT,IBBN)=IBPD_U_IBBA_U_IBPA_U_IBINT_U_IBADM_U_IBIDX_U_$S($D(IBSUSTYP):IBSUSTYP,1:"""")"
^XMB(3.9,145944,2,507,0)="""RTN"",""IBJDF41"",126,0)"
^XMB(3.9,145944,2,508,0)=" ;"
^XMB(3.9,145944,2,509,0)="""RTN"",""IBJDF41"",127,0)"
^XMB(3.9,145944,2,510,0)=" I IBSH D COM"
^XMB(3.9,145944,2,511,0)="""RTN"",""IBJDF41"",128,0)"
^XMB(3.9,145944,2,512,0)=" Q"
^XMB(3.9,145944,2,513,0)="""RTN"",""IBJDF41"",129,0)"
^XMB(3.9,145944,2,514,0)=" ;"
^XMB(3.9,145944,2,515,0)="""RTN"",""IBJDF41"",130,0)"
^XMB(3.9,145944,2,516,0)="ACCBAL(DFN) ; Calculates the Account Balance for the Bill"
^XMB(3.9,145944,2,517,0)="""RTN"",""IBJDF41"",131,0)"
^XMB(3.9,145944,2,518,0)=" ; Input: DFN - Patient/Debtor internal number"
^XMB(3.9,145944,2,519,0)="""RTN"",""IBJDF41"",132,0)"
^XMB(3.9,145944,2,520,0)=" ; Output: BAL - Patient/Debtor Account Balance"
^XMB(3.9,145944,2,521,0)="""RTN"",""IBJDF41"",133,0)"
^XMB(3.9,145944,2,522,0)=" ;"
^XMB(3.9,145944,2,523,0)="""RTN"",""IBJDF41"",134,0)"
^XMB(3.9,145944,2,524,0)=" N B0,B7,BAL,BILL,I"
^XMB(3.9,145944,2,525,0)="""RTN"",""IBJDF41"",135,0)"
^XMB(3.9,145944,2,526,0)=" S (BAL,BILL)=0"
^XMB(3.9,145944,2,527,0)="""RTN"",""IBJDF41"",136,0)"
^XMB(3.9,145944,2,528,0)=" F  S BILL=$O(^PRCA(430,""C"",DFN,BILL)) Q:BILL=""""  D"
^XMB(3.9,145944,2,529,0)="""RTN"",""IBJDF41"",137,0)"
^XMB(3.9,145944,2,530,0)=" . S B0=$G(^PRCA(430,BILL,0)) I $P(B0,""^"",8)'=16 Q"
^XMB(3.9,145944,2,531,0)="""RTN"",""IBJDF41"",138,0)"
^XMB(3.9,145944,2,532,0)=" . S B7=$G(^PRCA(430,BILL,7))"
^XMB(3.9,145944,2,533,0)="""RTN"",""IBJDF41"",139,0)"
^XMB(3.9,145944,2,534,0)=" . F I=1:1:5 S BAL=BAL+$P(B7,""^"",I)"
^XMB(3.9,145944,2,535,0)="""RTN"",""IBJDF41"",140,0)"
^XMB(3.9,145944,2,536,0)=" Q BAL"
^XMB(3.9,145944,2,537,0)="""RTN"",""IBJDF41"",141,0)"
^XMB(3.9,145944,2,538,0)=" ;"
^XMB(3.9,145944,2,539,0)="""RTN"",""IBJDF41"",142,0)"
^XMB(3.9,145944,2,540,0)="PHDL ; - Print the header line for the Excel spreadsheet"
^XMB(3.9,145944,2,541,0)="""RTN"",""IBJDF41"",143,0)"
^XMB(3.9,145944,2,542,0)=" N X"
^XMB(3.9,145944,2,543,0)="""RTN"",""IBJDF41"",144,0)"
^XMB(3.9,145944,2,544,0)=" S X=""Cat^Patient^VA Empl.?^^Dt Death^Prim.Elig.^Med.Elig.?^"" ;IB*2.0*739"
^XMB(3.9,145944,2,545,0)="""RTN"",""IBJDF41"",145,0)"
^XMB(3.9,145944,2,546,0)=" S X=X_""Means Tst Sts^Means Tst Dt^RX Copay Exemp.Sts^RX Copay Exemp.Dt^"""
^XMB(3.9,145944,2,547,0)="""RTN"",""IBJDF41"",146,0)"
^XMB(3.9,145944,2,548,0)=" S X=X_""Bill #^Act/Susp^Reason^Refer. to^Dt Bill prep.^Last Pymt Dt^"" ;Added reason IB*2*568/DRF"
^XMB(3.9,145944,2,549,0)="""RTN"",""IBJDF41"",147,0)"
^XMB(3.9,145944,2,550,0)=" S X=X_""Curr.Bal.^Princ.Bal.^Int.^Admin.^Last Comm.Dt^Days Lst Comm.^"""
^XMB(3.9,145944,2,551,0)="""RTN"",""IBJDF41"",148,0)"
^XMB(3.9,145944,2,552,0)=" W !,X"
^XMB(3.9,145944,2,553,0)="""RTN"",""IBJDF41"",149,0)"
^XMB(3.9,145944,2,554,0)=" Q"
^XMB(3.9,145944,2,555,0)="""RTN"",""IBJDF41"",150,0)"
^XMB(3.9,145944,2,556,0)=" ;"
^XMB(3.9,145944,2,557,0)="""RTN"",""IBJDF41"",151,0)"
^XMB(3.9,145944,2,558,0)="PAT(X) ; - Find the AR patient and decide to include the AR."
^XMB(3.9,145944,2,559,0)="""RTN"",""IBJDF41"",152,0)"
^XMB(3.9,145944,2,560,0)=" ;    Input: X=AR pointer to file #430 and pre-set variables IBS*"
^XMB(3.9,145944,2,561,0)="""RTN"",""IBJDF41"",153,0)"
^XMB(3.9,145944,2,562,0)=" ;   Output: Y=Sort key (name or last 4) ^ Patient pointer to file #2 "
^XMB(3.9,145944,2,563,0)="""RTN"",""IBJDF41"",154,0)"
^XMB(3.9,145944,2,564,0)=" ;             ^ Name ^ SSN ^ Eligibilities ^ Date of death (if any)"
^XMB(3.9,145944,2,565,0)="""RTN"",""IBJDF41"",155,0)"
^XMB(3.9,145944,2,566,0)=" ;             ^ Debtor pointer to file #340"
^XMB(3.9,145944,2,567,0)="""RTN"",""IBJDF41"",156,0)"
^XMB(3.9,145944,2,568,0)=" N PAT,KEY,DBTR,DFN,DEATH,NAME,SSN,VAEL,VADM,X1,X2"
^XMB(3.9,145944,2,569,0)="""RTN"",""IBJDF41"",157,0)"
^XMB(3.9,145944,2,570,0)=" S PAT="""" G:'$G(X) PATQ"
^XMB(3.9,145944,2,571,0)="""RTN"",""IBJDF41"",158,0)"
^XMB(3.9,145944,2,572,0)=" S DBTR=+$P($G(^PRCA(430,X,0)),U,9)"
^XMB(3.9,145944,2,573,0)="""RTN"",""IBJDF41"",159,0)"
^XMB(3.9,145944,2,574,0)=" S X1=$P($G(^RCD(340,DBTR,0)),U) G:X1'[""DPT"" PATQ"
^XMB(3.9,145944,2,575,0)="""RTN"",""IBJDF41"",160,0)"
^XMB(3.9,145944,2,576,0)=" S DFN=+X1 G:'DFN PATQ D DEM^VADPT"
^XMB(3.9,145944,2,577,0)="""RTN"",""IBJDF41"",161,0)"
^XMB(3.9,145944,2,578,0)=" S NAME=VADM(1),SSN=$P(VADM(2),""^""),DEATH=VADM(6)\1"
^XMB(3.9,145944,2,579,0)="""RTN"",""IBJDF41"",162,0)"
^XMB(3.9,145944,2,580,0)=" S KEY=$S(IBSN=""N"":NAME,1:$E(SSN,6,9))"
^XMB(3.9,145944,2,581,0)="""RTN"",""IBJDF41"",163,0)"
^XMB(3.9,145944,2,582,0)=" I KEY=""""!(IBSNF'=""@""&('DFN)) G PATQ"
^XMB(3.9,145944,2,583,0)="""RTN"",""IBJDF41"",164,0)"
^XMB(3.9,145944,2,584,0)=" I $D(IBSNA) G:IBSNA=""ALL""&('DFN) PATQ G:IBSNA=""NULL""&(DFN) PATQ"
^XMB(3.9,145944,2,585,0)="""RTN"",""IBJDF41"",165,0)"
^XMB(3.9,145944,2,586,0)=" I $G(IBSNA)=""ALL"" G PATC"
^XMB(3.9,145944,2,587,0)="""RTN"",""IBJDF41"",166,0)"
^XMB(3.9,145944,2,588,0)=" I IBSNF=""@"",IBSNL=""zzzzz"" G PATC"
^XMB(3.9,145944,2,589,0)="""RTN"",""IBJDF41"",167,0)"
^XMB(3.9,145944,2,590,0)=" I IBSNF'=KEY,IBSNF]KEY G PATQ"
^XMB(3.9,145944,2,591,0)="""RTN"",""IBJDF41"",168,0)"
^XMB(3.9,145944,2,592,0)=" I IBSNL'=KEY,KEY]IBSNL G PATQ"
^XMB(3.9,145944,2,593,0)="""RTN"",""IBJDF41"",169,0)"
^XMB(3.9,145944,2,594,0)=" ;"
^XMB(3.9,145944,2,595,0)="""RTN"",""IBJDF41"",170,0)"
^XMB(3.9,145944,2,596,0)="PATC ; - Set patient eligibilities."
^XMB(3.9,145944,2,597,0)="""RTN"",""IBJDF41"",171,0)"
^XMB(3.9,145944,2,598,0)=" D ELIG^VADPT S X2=+$G(VAEL(1))_"";"""
^XMB(3.9,145944,2,599,0)="""RTN"",""IBJDF41"",172,0)"
^XMB(3.9,145944,2,600,0)=" I +X2 S X1=0 F  S X1=$O(VAEL(1,X1)) Q:'X1  S X2=X2_X1_"";"""
^XMB(3.9,145944,2,601,0)="""RTN"",""IBJDF41"",173,0)"
^XMB(3.9,145944,2,602,0)=" ;"
^XMB(3.9,145944,2,603,0)="""RTN"",""IBJDF41"",174,0)"
^XMB(3.9,145944,2,604,0)=" S PAT=KEY_U_DFN_U_$E(NAME,1,26)_U_SSN_U_X2_U_DEATH"
^XMB(3.9,145944,2,605,0)="""RTN"",""IBJDF41"",175,0)"
^XMB(3.9,145944,2,606,0)=" S PAT=PAT_U_DBTR"
^XMB(3.9,145944,2,607,0)="""RTN"",""IBJDF41"",176,0)"
^XMB(3.9,145944,2,608,0)="PATQ Q PAT"
^XMB(3.9,145944,2,609,0)="""RTN"",""IBJDF41"",177,0)"
^XMB(3.9,145944,2,610,0)=" ;"
^XMB(3.9,145944,2,611,0)="""RTN"",""IBJDF41"",178,0)"
^XMB(3.9,145944,2,612,0)="RP(X) ; - Check if claim/receivable is under a repayment plan."
^XMB(3.9,145944,2,613,0)="""RTN"",""IBJDF41"",179,0)"
^XMB(3.9,145944,2,614,0)=" ;    Input: X=Bill pointer to file #430"
^XMB(3.9,145944,2,615,0)="""RTN"",""IBJDF41"",180,0)"
^XMB(3.9,145944,2,616,0)=" ;   Output: 0-Not on repay plan, 1-On repay plan, 2-On defaulted plan"
^XMB(3.9,145944,2,617,0)="""RTN"",""IBJDF41"",181,0)"
^XMB(3.9,145944,2,618,0)=" N RPIEN,Z"
