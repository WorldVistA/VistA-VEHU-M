^XMB(3.9,145952,2,2834,0)=" S:SDSTDT=-1 NUM=27"
^XMB(3.9,145952,2,2835,0)="""RTN"",""SDESGETCLINAPPT"",43,0)"
^XMB(3.9,145952,2,2836,0)=" Q:NUM"
^XMB(3.9,145952,2,2837,0)="""RTN"",""SDESGETCLINAPPT"",44,0)"
^XMB(3.9,145952,2,2838,0)=" I $L(SDSTDT,""."")=1 S SDSTDT=SDSTDT_.0001"
^XMB(3.9,145952,2,2839,0)="""RTN"",""SDESGETCLINAPPT"",45,0)"
^XMB(3.9,145952,2,2840,0)=" S SDSTDT=$O(^SC(SDCLIN,""S"",SDSTDT),-1)"
^XMB(3.9,145952,2,2841,0)="""RTN"",""SDESGETCLINAPPT"",46,0)"
^XMB(3.9,145952,2,2842,0)=" S SDENDDT=$$ISOTFM^SDAMUTDT(SDENDDTTM,SDCLIN) ;need to convert this from ISO8601 based on clinic time zone"
