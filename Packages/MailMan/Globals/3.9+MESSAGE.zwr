^XMB(3.9,145989,2,643,0)="""RTN"",""PSOASAP0"",179,0)"
^XMB(3.9,145989,2,644,0)="PAT19() ;ASAP 3.0 : Patient DOB"
^XMB(3.9,145989,2,645,0)="""RTN"",""PSOASAP0"",180,0)"
^XMB(3.9,145989,2,646,0)=" ;       ASAP 4.0+: Patient Gender Code"
^XMB(3.9,145989,2,647,0)="""RTN"",""PSOASAP0"",181,0)"
^XMB(3.9,145989,2,648,0)=" I PSOASVER=""3.0"" Q $$FMTHL7^XLFDT($P($G(VADM(3)),""^"",1))"
^XMB(3.9,145989,2,649,0)="""RTN"",""PSOASAP0"",182,0)"
^XMB(3.9,145989,2,650,0)=" Q $S($P($G(VADM(5)),""^"",1)'="""":$P($G(VADM(5)),""^"",1),1:""U"")"
^XMB(3.9,145989,2,651,0)="""RTN"",""PSOASAP0"",183,0)"
