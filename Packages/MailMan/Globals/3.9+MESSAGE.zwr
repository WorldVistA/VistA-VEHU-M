^XMB(3.9,145981,2,402,0)=" S IBADMIT=IBADMIT_"".9999"",IBADMIT=$O(^DGPT(""AAD"",DFN,IBADMIT),-1),IBADM1=IBADMIT I IBADMIT S IBIEN1=$O(^DGPT(""AAD"",DFN,IBADMIT,0)),IBDISCH=$P($G(^DGPT(IBIEN1,70)),U)"
^XMB(3.9,145981,2,403,0)="""RTN"",""IBECECX1"",82,0)"
^XMB(3.9,145981,2,404,0)=" I IBADMIT,$G(IBFR)>IBADMIT S IBADMIT=IBFR ;If bill date is greater than admit date, use bill date for query"
^XMB(3.9,145981,2,405,0)="""RTN"",""IBECECX1"",83,0)"
^XMB(3.9,145981,2,406,0)=" I IBADMIT S IBOADMIT=$$FMTHL7^XLFDT(IBADMIT),IBADMIT=$$FMTHL7^XLFDT($P(IBADMIT,"".""))      ;convert admission date to HL7"
^XMB(3.9,145981,2,407,0)="""RTN"",""IBECECX1"",84,0)"
^XMB(3.9,145981,2,408,0)=" I IBDISCH,IBFR>IBDISCH S IBDISCH=IBFR ;If bill date is greater than discharge date, use bill date for query"
^XMB(3.9,145981,2,409,0)="""RTN"",""IBECECX1"",85,0)"
^XMB(3.9,145981,2,410,0)=" I IBDISCH'="""" S IBODISCH=$$FMTHL7^XLFDT(IBDISCH),IBDISCH=$$FMTHL7^XLFDT($P(IBDISCH,"".""))  ;Get discharge dates (HL7 format), no times needed"
^XMB(3.9,145981,2,411,0)="""RTN"",""IBECECX1"",86,0)"
^XMB(3.9,145981,2,412,0)=" Q"
^XMB(3.9,145981,2,413,0)="""RTN"",""IBECECX1"",87,0)"
^XMB(3.9,145981,2,414,0)=" ;"
^XMB(3.9,145981,2,415,0)="""RTN"",""IBECECX1"",88,0)"
^XMB(3.9,145981,2,416,0)="NOCLOCK ;Set variables if no clock found"
^XMB(3.9,145981,2,417,0)="""RTN"",""IBECECX1"",89,0)"
^XMB(3.9,145981,2,418,0)=" S (IBIEN,IEN,IBCLNDT,IB901,IB902,IB903,IB904,IBCLDAY,IBCKNUM,IBICNUM,IBSTAT,IBSTN,IBVRSN)="""" S:$G(IBCLDT)="""" IBCLDT="""""
^XMB(3.9,145981,2,419,0)="""RTN"",""IBECECX1"",90,0)"
^XMB(3.9,145981,2,420,0)=" S IBERROR=""NO MEANS TEST BILLING CLOCK FOUND"""
^XMB(3.9,145981,2,421,0)="""RTN"",""IBECECX1"",91,0)"
^XMB(3.9,145981,2,422,0)=" Q"
^XMB(3.9,145981,2,423,0)="""RTN"",""IBECECX1"",92,0)"
^XMB(3.9,145981,2,424,0)="CLSDT(IBECDT) ;Calculate billing clock closed date taking into acct leap year"
^XMB(3.9,145981,2,425,0)="""RTN"",""IBECECX1"",93,0)"
^XMB(3.9,145981,2,426,0)=" N IBYEAR,IBMTHDAY,IBLEAP,IBECLDT"
^XMB(3.9,145981,2,427,0)="""RTN"",""IBECECX1"",94,0)"
^XMB(3.9,145981,2,428,0)=" S IBYEAR=$E(IBECDT,1,3),IBMTHDAY=$E(IBECDT,4,7)"
^XMB(3.9,145981,2,429,0)="""RTN"",""IBECECX1"",95,0)"
^XMB(3.9,145981,2,430,0)=" I IBMTHDAY<=229 S IBLEAP=$$LEAP^XLFDT3(IBYEAR)"
^XMB(3.9,145981,2,431,0)="""RTN"",""IBECECX1"",96,0)"
^XMB(3.9,145981,2,432,0)=" I IBMTHDAY>229 S IBLEAP=$$LEAP^XLFDT3(IBYEAR+1)"
^XMB(3.9,145981,2,433,0)="""RTN"",""IBECECX1"",97,0)"
^XMB(3.9,145981,2,434,0)=" I IBLEAP S IBECLDT=$$FMADD^XLFDT(IBECDT,365) Q IBECLDT"
^XMB(3.9,145981,2,435,0)="""RTN"",""IBECECX1"",98,0)"
^XMB(3.9,145981,2,436,0)=" I 'IBLEAP S IBECLDT=$$FMADD^XLFDT(IBECDT,364) Q IBECLDT"
^XMB(3.9,145981,2,437,0)="""RTN"",""IBECECX1"",99,0)"
^XMB(3.9,145981,2,438,0)=" Q IBECLDT"
^XMB(3.9,145981,2,439,0)="""RTN"",""IBECECX1"",100,0)"
^XMB(3.9,145981,2,440,0)="VRSNCHK(IB351IEN) ;Verify Version matches incoming versions"
^XMB(3.9,145981,2,441,0)="""RTN"",""IBECECX1"",101,0)"
^XMB(3.9,145981,2,442,0)=" N IBECVSN"
^XMB(3.9,145981,2,443,0)="""RTN"",""IBECECX1"",102,0)"
^XMB(3.9,145981,2,444,0)=" ;Quit if nothing to compare in IBVARRY"
^XMB(3.9,145981,2,445,0)="""RTN"",""IBECECX1"",103,0)"
^XMB(3.9,145981,2,446,0)=" Q:'$D(IBVARRY) 0"
^XMB(3.9,145981,2,447,0)="""RTN"",""IBECECX1"",104,0)"
^XMB(3.9,145981,2,448,0)=" ;CHECK VERSION ARRAY, SHOULD BE ONLY ONE SUBSCRIPT SO $O AND REVERSE $O SHOULD RETURN THE SAME RESULTS"
^XMB(3.9,145981,2,449,0)="""RTN"",""IBECECX1"",105,0)"
^XMB(3.9,145981,2,450,0)=" I $O(IBVARRY(""""))'=$O(IBVARRY("";""),-1) Q 1"
^XMB(3.9,145981,2,451,0)="""RTN"",""IBECECX1"",106,0)"
^XMB(3.9,145981,2,452,0)=" ;GET CURRENT CLOCK VERSION - IF BLANK, FILE IT (FIRST CLOCK?) AND COMPARE REMAINING DSP DATA"
^XMB(3.9,145981,2,453,0)="""RTN"",""IBECECX1"",107,0)"
^XMB(3.9,145981,2,454,0)=" S IBECVSN=$$GET1^DIQ(351,IB351IEN_"","",17) I IBECVSN="""" D  Q 0"
^XMB(3.9,145981,2,455,0)="""RTN"",""IBECECX1"",108,0)"
^XMB(3.9,145981,2,456,0)=" .L +^IBE(351,IB351IEN):$G(DILOCKTM,5) Q:'$T"
^XMB(3.9,145981,2,457,0)="""RTN"",""IBECECX1"",109,0)"
^XMB(3.9,145981,2,458,0)=" .S DIE=""^IBE(351,"",DA=IB351IEN,DR=""17///""_$O(IBVARRY("""")) D ^DIE"
^XMB(3.9,145981,2,459,0)="""RTN"",""IBECECX1"",110,0)"
^XMB(3.9,145981,2,460,0)=" .L -^IBE(351,IB351IEN)"
^XMB(3.9,145981,2,461,0)="""RTN"",""IBECECX1"",111,0)"
^XMB(3.9,145981,2,462,0)=" ;version stored does not match the version in query indicating clock out of sync (version stored could be from Query Results)"
^XMB(3.9,145981,2,463,0)="""RTN"",""IBECECX1"",112,0)"
^XMB(3.9,145981,2,464,0)=" I $O(IBVARRY(""""))'=IBECVSN Q 1"
^XMB(3.9,145981,2,465,0)="""RTN"",""IBECECX1"",113,0)"
^XMB(3.9,145981,2,466,0)=" Q 0"
^XMB(3.9,145981,2,467,0)="""RTN"",""IBECECX1"",114,0)"
^XMB(3.9,145981,2,468,0)="GETIEN(DFN,IBADM1) ;Get Means Test Billing clock (#351) file ien"
^XMB(3.9,145981,2,469,0)="""RTN"",""IBECECX1"",115,0)"
^XMB(3.9,145981,2,470,0)=" N IBECX,IBIEN,IBDA,IBDAS,IBCLDT,IBFUTCL"
^XMB(3.9,145981,2,471,0)="""RTN"",""IBECECX1"",116,0)"
^XMB(3.9,145981,2,472,0)=" S IBIEN=0"
^XMB(3.9,145981,2,473,0)="""RTN"",""IBECECX1"",117,0)"
^XMB(3.9,145981,2,474,0)=" S IBECX=-$P(IBADM1,""."")_.9999 F  S IBECX=$O(^IBE(351,""AIVDT"",DFN,IBECX)) Q:'IBECX  D  Q:$G(IBIEN)"
^XMB(3.9,145981,2,475,0)="""RTN"",""IBECECX1"",118,0)"
^XMB(3.9,145981,2,476,0)=" .I IBECX  S IBDA="";""  F  S IBDA=$O(^IBE(351,""AIVDT"",DFN,IBECX,IBDA),-1) Q:'IBDA  Q:$G(IBIEN)  S IBDAS=IBDA_"","" I $$GET1^DIQ(351,IBDAS,.04,""I"")'=3  D  Q"
^XMB(3.9,145981,2,477,0)="""RTN"",""IBECECX1"",119,0)"
^XMB(3.9,145981,2,478,0)=" ..S IBCLDT=($$FMADD^XLFDT(-IBECX,364)) ;"
^XMB(3.9,145981,2,479,0)="""RTN"",""IBECECX1"",120,0)"
^XMB(3.9,145981,2,480,0)=" ..S IBIEN=IBDA"
^XMB(3.9,145981,2,481,0)="""RTN"",""IBECECX1"",121,0)"
^XMB(3.9,145981,2,482,0)=" ..I IBADM1>=IBCLDT S IBIEN=0"
^XMB(3.9,145981,2,483,0)="""RTN"",""IBECECX1"",122,0)"
^XMB(3.9,145981,2,484,0)=" I IBIEN Q IBIEN"
^XMB(3.9,145981,2,485,0)="""RTN"",""IBECECX1"",123,0)"
^XMB(3.9,145981,2,486,0)=" ;Search for future clock that this could fall under"
^XMB(3.9,145981,2,487,0)="""RTN"",""IBECECX1"",124,0)"
^XMB(3.9,145981,2,488,0)=" S IBFUTCL=$$FMADD^XLFDT(IBADM1,364) I IBFUTCL<DT Q 0"
^XMB(3.9,145981,2,489,0)="""RTN"",""IBECECX1"",125,0)"
^XMB(3.9,145981,2,490,0)=" S IBECX=-$P(IBFUTCL,""."")_.9999 F  S IBECX=$O(^IBE(351,""AIVDT"",DFN,IBECX)) Q:'IBECX  D  Q:$G(IBIEN)"
^XMB(3.9,145981,2,491,0)="""RTN"",""IBECECX1"",126,0)"
^XMB(3.9,145981,2,492,0)=" .I IBECX  S IBDA="";""  F  S IBDA=$O(^IBE(351,""AIVDT"",DFN,IBECX,IBDA),-1) Q:'IBDA  S IBDAS=IBDA_"","" I $$GET1^DIQ(351,IBDAS,.04,""I"")'=3  D  Q"
^XMB(3.9,145981,2,493,0)="""RTN"",""IBECECX1"",127,0)"
^XMB(3.9,145981,2,494,0)=" ..S IBCLDT=($$FMADD^XLFDT(-IBECX,364))"
^XMB(3.9,145981,2,495,0)="""RTN"",""IBECECX1"",128,0)"
^XMB(3.9,145981,2,496,0)=" ..S IBIEN=IBDA"
^XMB(3.9,145981,2,497,0)="""RTN"",""IBECECX1"",129,0)"
^XMB(3.9,145981,2,498,0)=" ..I IBADM1>=IBCLDT S IBIEN=0"
^XMB(3.9,145981,2,499,0)="""RTN"",""IBECECX1"",130,0)"
^XMB(3.9,145981,2,500,0)=" Q IBIEN"
^XMB(3.9,145981,2,501,0)="""RTN"",""IBECECX1"",131,0)"
^XMB(3.9,145981,2,502,0)=" ;"
^XMB(3.9,145981,2,503,0)="""RTN"",""IBECECX1"",132,0)"
^XMB(3.9,145981,2,504,0)="WRAP(IBCOL1,IBCOL2,IBTEXT) ;Wrap text in IBTEXT variable"
^XMB(3.9,145981,2,505,0)="""RTN"",""IBECECX1"",133,0)"
^XMB(3.9,145981,2,506,0)=" ; Input Parameters Description:"
^XMB(3.9,145981,2,507,0)="""RTN"",""IBECECX1"",134,0)"
^XMB(3.9,145981,2,508,0)=" ;  IBCOL1: Left Column to start"
^XMB(3.9,145981,2,509,0)="""RTN"",""IBECECX1"",135,0)"
^XMB(3.9,145981,2,510,0)=" ;  IBCOL2: Cols to wrap in"
^XMB(3.9,145981,2,511,0)="""RTN"",""IBECECX1"",136,0)"
^XMB(3.9,145981,2,512,0)=" ;  IBTEXT: Text to wrap"
^XMB(3.9,145981,2,513,0)="""RTN"",""IBECECX1"",137,0)"
^XMB(3.9,145981,2,514,0)=" ;"
^XMB(3.9,145981,2,515,0)="""RTN"",""IBECECX1"",138,0)"
^XMB(3.9,145981,2,516,0)=" N IBTEXTO,IBX"
^XMB(3.9,145981,2,517,0)="""RTN"",""IBECECX1"",139,0)"
^XMB(3.9,145981,2,518,0)=" S IBX=0"
^XMB(3.9,145981,2,519,0)="""RTN"",""IBECECX1"",140,0)"
^XMB(3.9,145981,2,520,0)=" F  Q:'$L(IBTEXT)  D"
^XMB(3.9,145981,2,521,0)="""RTN"",""IBECECX1"",141,0)"
^XMB(3.9,145981,2,522,0)=" .F IBTEXTO=IBCOL2:-1:0 I $E(IBTEXT,IBTEXTO)="" "" S IBX=IBX+1,IBTEXT(IBX)=""""  Q"
^XMB(3.9,145981,2,523,0)="""RTN"",""IBECECX1"",142,0)"
^XMB(3.9,145981,2,524,0)=" .S:IBTEXTO<1 IBTEXTO=IBCOL2"
^XMB(3.9,145981,2,525,0)="""RTN"",""IBECECX1"",143,0)"
^XMB(3.9,145981,2,526,0)=" .S IBTEXT(IBX)=IBTEXT(IBX)_$E(IBTEXT,1,IBTEXTO)"
^XMB(3.9,145981,2,527,0)="""RTN"",""IBECECX1"",144,0)"
^XMB(3.9,145981,2,528,0)=" .S IBTEXT=$E(IBTEXT,IBTEXTO+1,$L(IBTEXT))"
^XMB(3.9,145981,2,529,0)="""RTN"",""IBECECX1"",145,0)"
^XMB(3.9,145981,2,530,0)=" Q"
^XMB(3.9,145981,2,531,0)="""RTN"",""IBECECX1"",146,0)"
^XMB(3.9,145981,2,532,0)="ERR1(IBERRMSG) ;Handle error responses for network and software failure issues"
^XMB(3.9,145981,2,533,0)="""RTN"",""IBECECX1"",147,0)"
^XMB(3.9,145981,2,534,0)=" ;"
^XMB(3.9,145981,2,535,0)="""RTN"",""IBECECX1"",148,0)"
^XMB(3.9,145981,2,536,0)=" N XMY,XMSUB,IBL,IB3513D,IBTEXT,IBX,XMDUZ,XMTEXT"
^XMB(3.9,145981,2,537,0)="""RTN"",""IBECECX1"",149,0)"
^XMB(3.9,145981,2,538,0)=" ;IB*2*769 VDIF call to MVI prior to query to ensure patient has Treating Facilities - VDIF will not return any errors for this"
^XMB(3.9,145981,2,539,0)="""RTN"",""IBECECX1"",150,0)"
^XMB(3.9,145981,2,540,0)=" ;I IBERRMSG[""MVI returned no treating facilities for this patient"" D UDCL Q  ;no error message necessary - just update the query sent field"
^XMB(3.9,145981,2,541,0)="""RTN"",""IBECECX1"",151,0)"
^XMB(3.9,145981,2,542,0)=" ;MAIL MESSAGE GENERATION CODE ON HOLD FOR FUTURE REQUIREMENTS"
^XMB(3.9,145981,2,543,0)="""RTN"",""IBECECX1"",152,0)"
^XMB(3.9,145981,2,544,0)=" K ^TMP($J,""IBCPYAC"")"
^XMB(3.9,145981,2,545,0)="""RTN"",""IBECECX1"",153,0)"
^XMB(3.9,145981,2,546,0)=" S XMSUB=""COPAY PATIENT ACCUMULATOR ISSUE"""
^XMB(3.9,145981,2,547,0)="""RTN"",""IBECECX1"",154,0)"
^XMB(3.9,145981,2,548,0)=" S XMY(""G.IB PATIENT ACCUMULATOR"")="""""
^XMB(3.9,145981,2,549,0)="""RTN"",""IBECECX1"",155,0)"
^XMB(3.9,145981,2,550,0)=" S IBL=0"
^XMB(3.9,145981,2,551,0)="""RTN"",""IBECECX1"",156,0)"
^XMB(3.9,145981,2,552,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""ERROR RECEIVED BY VDIF DURING COPAY ACCUMULATOR EVENT:"""
^XMB(3.9,145981,2,553,0)="""RTN"",""IBECECX1"",157,0)"
^XMB(3.9,145981,2,554,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,555,0)="""RTN"",""IBECECX1"",158,0)"
^XMB(3.9,145981,2,556,0)=" S IBTEXT=IBERRMSG D WRAP(0,80,.IBTEXT)"
^XMB(3.9,145981,2,557,0)="""RTN"",""IBECECX1"",159,0)"
^XMB(3.9,145981,2,558,0)=" S IBX=0 F  S IBX=$O(IBTEXT(IBX)) Q:'IBX  D"
^XMB(3.9,145981,2,559,0)="""RTN"",""IBECECX1"",160,0)"
^XMB(3.9,145981,2,560,0)=" .S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=IBTEXT(IBX)"
^XMB(3.9,145981,2,561,0)="""RTN"",""IBECECX1"",161,0)"
^XMB(3.9,145981,2,562,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,563,0)="""RTN"",""IBECECX1"",162,0)"
^XMB(3.9,145981,2,564,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""As a result, the billing clock will not be synced up enterprise wide."""
^XMB(3.9,145981,2,565,0)="""RTN"",""IBECECX1"",163,0)"
^XMB(3.9,145981,2,566,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""Resolution will require an IT ticket to fix the issue(s)"""
^XMB(3.9,145981,2,567,0)="""RTN"",""IBECECX1"",164,0)"
^XMB(3.9,145981,2,568,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""and manual update of billing clocks."""
^XMB(3.9,145981,2,569,0)="""RTN"",""IBECECX1"",165,0)"
^XMB(3.9,145981,2,570,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,571,0)="""RTN"",""IBECECX1"",166,0)"
^XMB(3.9,145981,2,572,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""Only one IT ticket needs to be created for an episode of care,"""
^XMB(3.9,145981,2,573,0)="""RTN"",""IBECECX1"",167,0)"
^XMB(3.9,145981,2,574,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""as a Mailman message will be sent daily while the error persists,"""
^XMB(3.9,145981,2,575,0)="""RTN"",""IBECECX1"",168,0)"
^XMB(3.9,145981,2,576,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""and the veteran remains in an inpatient setting."""
^XMB(3.9,145981,2,577,0)="""RTN"",""IBECECX1"",169,0)"
^XMB(3.9,145981,2,578,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,579,0)="""RTN"",""IBECECX1"",170,0)"
^XMB(3.9,145981,2,580,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""When creating a ticket, please include the following:"""
^XMB(3.9,145981,2,581,0)="""RTN"",""IBECECX1"",171,0)"
^XMB(3.9,145981,2,582,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,583,0)="""RTN"",""IBECECX1"",172,0)"
^XMB(3.9,145981,2,584,0)=" I $D(IBID) S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""HLO MESSAGE ID: ""_IBID"
^XMB(3.9,145981,2,585,0)="""RTN"",""IBECECX1"",173,0)"
^XMB(3.9,145981,2,586,0)=" I $D(IBERRS) S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""STATION WITH ERROR RESPONSE: ""_IBERRS"
^XMB(3.9,145981,2,587,0)="""RTN"",""IBECECX1"",174,0)"
