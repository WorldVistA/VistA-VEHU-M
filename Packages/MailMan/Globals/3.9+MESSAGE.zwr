^XMB(3.9,145957,2,1122,0)=" N HLNODE,SEG,I"
^XMB(3.9,145957,2,1123,0)="""RTN"",""GMRCRFC0"",9,0)"
^XMB(3.9,145957,2,1124,0)=" N %,RMPR123,RMPR123A,RMPR123I,RMPRISIT,RMPRST,RMPRSITIEN,RMPRSTA"
^XMB(3.9,145957,2,1125,0)="""RTN"",""GMRCRFC0"",10,0)"
