^XMB(3.9,145942,2,207,0)="""QUES"",""XPM1"",""??"")"
^XMB(3.9,145942,2,208,0)="^D MG^XPDH"
^XMB(3.9,145942,2,209,0)="""QUES"",""XPM1"",""A"")"
^XMB(3.9,145942,2,210,0)="Enter the Coordinator for Mail Group '|FLAG|'"
