^XMB(3.9,145986,2,3981,0)="""RTN"",""FBPCR"",241,0)"
^XMB(3.9,145986,2,3982,0)=" I $D(FBARR(2)) W ?39,""IONIZING RADIATION"",!"
^XMB(3.9,145986,2,3983,0)="""RTN"",""FBPCR"",242,0)"
^XMB(3.9,145986,2,3984,0)=" I $D(FBARR(4)) W ?39,""SOUTHWEST ASIA"",!"
^XMB(3.9,145986,2,3985,0)="""RTN"",""FBPCR"",243,0)"
