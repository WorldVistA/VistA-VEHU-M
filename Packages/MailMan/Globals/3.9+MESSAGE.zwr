^XMB(3.9,145944,2,2201,0)="""RTN"",""IBJDF61"",166,0)"
^XMB(3.9,145944,2,2202,0)=" ;"
^XMB(3.9,145944,2,2203,0)="""RTN"",""IBJDF61"",167,0)"
^XMB(3.9,145944,2,2204,0)="VAEMP(SSN) ; - Check if the Patient/Debtor is a current VA Employee"
