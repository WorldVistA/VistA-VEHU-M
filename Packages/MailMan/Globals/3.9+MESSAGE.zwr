^XMB(3.9,145952,2,2750,0)="0^5^B45842023"
^XMB(3.9,145952,2,2751,0)="""RTN"",""SDESGETCLINAPPT"",1,0)"
^XMB(3.9,145952,2,2752,0)="SDESGETCLINAPPT ;ALB/LAB - VISTA SCHEDULING READ CLINIC APPOINTMENT ;FEB 21,2023@15:01"
^XMB(3.9,145952,2,2753,0)="""RTN"",""SDESGETCLINAPPT"",2,0)"
^XMB(3.9,145952,2,2754,0)=" ;;5.3;Scheduling;**805,838**;Aug 13, 1993;Build 0"
^XMB(3.9,145952,2,2755,0)="""RTN"",""SDESGETCLINAPPT"",3,0)"
^XMB(3.9,145952,2,2756,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145952,2,2757,0)="""RTN"",""SDESGETCLINAPPT"",4,0)"
^XMB(3.9,145952,2,2758,0)=" Q"
^XMB(3.9,145952,2,2759,0)="""RTN"",""SDESGETCLINAPPT"",5,0)"
^XMB(3.9,145952,2,2760,0)=" ;"
^XMB(3.9,145952,2,2761,0)="""RTN"",""SDESGETCLINAPPT"",6,0)"
^XMB(3.9,145952,2,2762,0)="GETAPPOINTMENTS(SDECY,SDCLIN,SDSTDTTM,SDENDDTTM) ;get all appointments for a given clinic for a given datetime range"
^XMB(3.9,145952,2,2763,0)="""RTN"",""SDESGETCLINAPPT"",7,0)"
^XMB(3.9,145952,2,2764,0)=" ; ALERT!  This tag should NOT be called directly from outside source.  This RPC will be called via an EAS wrapper/layer."
^XMB(3.9,145952,2,2765,0)="""RTN"",""SDESGETCLINAPPT"",8,0)"
^XMB(3.9,145952,2,2766,0)=" ; INPUT:"
^XMB(3.9,145952,2,2767,0)="""RTN"",""SDESGETCLINAPPT"",9,0)"
^XMB(3.9,145952,2,2768,0)=" ; SDCLIN - Pointer to HOSPITAL LOCATION (#44) FILE"
^XMB(3.9,145952,2,2769,0)="""RTN"",""SDESGETCLINAPPT"",10,0)"
^XMB(3.9,145952,2,2770,0)=" ; SDDTTM - start appointment date time in ISO8601 Time format"
^XMB(3.9,145952,2,2771,0)="""RTN"",""SDESGETCLINAPPT"",11,0)"
^XMB(3.9,145952,2,2772,0)=" ; SDENDDTTM  - end appoitnment date time in ISO8601 Time fomat"
^XMB(3.9,145952,2,2773,0)="""RTN"",""SDESGETCLINAPPT"",12,0)"
^XMB(3.9,145952,2,2774,0)=" N APPTREC,SDAPPT,SDSTDT,SDAPPT,SDAPPTNO,SDMSG,SDIEN,NUM,ERR,FOUND,SDENDDT"
^XMB(3.9,145952,2,2775,0)="""RTN"",""SDESGETCLINAPPT"",13,0)"
^XMB(3.9,145952,2,2776,0)=" K SDECY"
^XMB(3.9,145952,2,2777,0)="""RTN"",""SDESGETCLINAPPT"",14,0)"
^XMB(3.9,145952,2,2778,0)=" S NUM=0,FOUND=0"
^XMB(3.9,145952,2,2779,0)="""RTN"",""SDESGETCLINAPPT"",15,0)"
^XMB(3.9,145952,2,2780,0)=" D VALIDATE ;basic validation just to make sure required fields have been sent"
^XMB(3.9,145952,2,2781,0)="""RTN"",""SDESGETCLINAPPT"",16,0)"
^XMB(3.9,145952,2,2782,0)=" D:+NUM ERRLOG^SDESJSON(.SDECY,NUM)"
^XMB(3.9,145952,2,2783,0)="""RTN"",""SDESGETCLINAPPT"",17,0)"
^XMB(3.9,145952,2,2784,0)=" I '+NUM D"
^XMB(3.9,145952,2,2785,0)="""RTN"",""SDESGETCLINAPPT"",18,0)"
^XMB(3.9,145952,2,2786,0)=" . D CONVERTINPDTS"
^XMB(3.9,145952,2,2787,0)="""RTN"",""SDESGETCLINAPPT"",19,0)"
^XMB(3.9,145952,2,2788,0)=" . Q:+NUM"
^XMB(3.9,145952,2,2789,0)="""RTN"",""SDESGETCLINAPPT"",20,0)"
^XMB(3.9,145952,2,2790,0)=" . F  S SDSTDT=$O(^SC(SDCLIN,""S"",SDSTDT)) Q:(SDSTDT="""")!(SDSTDT>SDENDDT)  D"
^XMB(3.9,145952,2,2791,0)="""RTN"",""SDESGETCLINAPPT"",21,0)"
^XMB(3.9,145952,2,2792,0)=" . . S SDAPPTNO=0"
^XMB(3.9,145952,2,2793,0)="""RTN"",""SDESGETCLINAPPT"",22,0)"
^XMB(3.9,145952,2,2794,0)=" . . F  S SDAPPTNO=$O(^SC(SDCLIN,""S"",SDSTDT,1,SDAPPTNO)) Q:SDAPPTNO=""""  D"
^XMB(3.9,145952,2,2795,0)="""RTN"",""SDESGETCLINAPPT"",23,0)"
^XMB(3.9,145952,2,2796,0)=" . . . K SDAPPT,SDMSG"
^XMB(3.9,145952,2,2797,0)="""RTN"",""SDESGETCLINAPPT"",24,0)"
^XMB(3.9,145952,2,2798,0)=" . . . S SDIEN=SDAPPTNO_"",""_SDSTDT_"",""_SDCLIN_"","""
^XMB(3.9,145952,2,2799,0)="""RTN"",""SDESGETCLINAPPT"",25,0)"
^XMB(3.9,145952,2,2800,0)=" . . . D GETS^DIQ(44.003,SDIEN,""**"",""IE"",""SDAPPT"",""SDMSG"")"
^XMB(3.9,145952,2,2801,0)="""RTN"",""SDESGETCLINAPPT"",26,0)"
^XMB(3.9,145952,2,2802,0)=" . . . D BLDREC"
^XMB(3.9,145952,2,2803,0)="""RTN"",""SDESGETCLINAPPT"",27,0)"
^XMB(3.9,145952,2,2804,0)=" I +NUM D"
^XMB(3.9,145952,2,2805,0)="""RTN"",""SDESGETCLINAPPT"",28,0)"
^XMB(3.9,145952,2,2806,0)=" . S FOUND=1"
^XMB(3.9,145952,2,2807,0)="""RTN"",""SDESGETCLINAPPT"",29,0)"
^XMB(3.9,145952,2,2808,0)=" . D ERRLOG^SDESJSON(.APPTREC,NUM)"
^XMB(3.9,145952,2,2809,0)="""RTN"",""SDESGETCLINAPPT"",30,0)"
^XMB(3.9,145952,2,2810,0)=" S:'FOUND APPTREC(""ClinicApptDate"")="""""
^XMB(3.9,145952,2,2811,0)="""RTN"",""SDESGETCLINAPPT"",31,0)"
^XMB(3.9,145952,2,2812,0)=" D BUILDER"
^XMB(3.9,145952,2,2813,0)="""RTN"",""SDESGETCLINAPPT"",32,0)"
^XMB(3.9,145952,2,2814,0)=" Q"
^XMB(3.9,145952,2,2815,0)="""RTN"",""SDESGETCLINAPPT"",33,0)"
^XMB(3.9,145952,2,2816,0)=" ;"
^XMB(3.9,145952,2,2817,0)="""RTN"",""SDESGETCLINAPPT"",34,0)"
^XMB(3.9,145952,2,2818,0)="VALIDATE ;Validate required fields are sent"
^XMB(3.9,145952,2,2819,0)="""RTN"",""SDESGETCLINAPPT"",35,0)"
^XMB(3.9,145952,2,2820,0)=" I ('+$G(SDCLIN)) S NUM=18 Q"
^XMB(3.9,145952,2,2821,0)="""RTN"",""SDESGETCLINAPPT"",36,0)"
^XMB(3.9,145952,2,2822,0)=" I ('+$G(SDSTDTTM)) S NUM=25 Q"
^XMB(3.9,145952,2,2823,0)="""RTN"",""SDESGETCLINAPPT"",37,0)"
