^XMB(3.9,145984,2,1992,0)=" . . S (PASCNT,PAIEN)=0 F  S PAIEN=$O(^DPT(""SSN"",$TR(PACHK(""ssn""),""-"",""""),PAIEN)) Q:'PAIEN  D"
