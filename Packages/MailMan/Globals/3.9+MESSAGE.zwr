^XMB(3.9,145944,2,1327,0)="""RTN"",""IBJDF42"",147,0)"
^XMB(3.9,145944,2,1328,0)=" W:$G(I) !,""("",I,"")"" W:$G(D) ?3,"" - "",$$DAT1^IBOUTL(CMDT),"": """
