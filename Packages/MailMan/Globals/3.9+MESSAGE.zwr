^XMB(3.9,145986,2,1896,0)=" ;;3.5;FEE BASIS;**55,61,122,108,135,144,123,164**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,1897,0)="""RTN"",""FBCHVH"",3,0)"
^XMB(3.9,145986,2,1898,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,1899,0)="""RTN"",""FBCHVH"",4,0)"
^XMB(3.9,145986,2,1900,0)="GETVEN K FBAANQ D GETVEN^FBAAUTL1 G END:IFN']"""""
^XMB(3.9,145986,2,1901,0)="""RTN"",""FBCHVH"",5,0)"
^XMB(3.9,145986,2,1902,0)=" D DATE^FBAAUTL G:FBPOP GETVEN S ZZ=9999999.9999,FBBEG=ZZ-ENDDATE,FBEND=ZZ-BEGDATE"
^XMB(3.9,145986,2,1903,0)="""RTN"",""FBCHVH"",6,0)"
^XMB(3.9,145986,2,1904,0)=" I '$D(^FBAAI(""AF"",IFN)) W !,*7,""No invoices on line for this vendor."" G GETVEN"
^XMB(3.9,145986,2,1905,0)="""RTN"",""FBCHVH"",7,0)"
^XMB(3.9,145986,2,1906,0)=" S VAR=""IFN^FBBEG^FBEND^BEGDATE^ENDDATE""_$S($D(FBPROG):""^FBPROG"",1:""""),VAL=IFN_""^""_FBBEG_""^""_FBEND_""^""_BEGDATE_""^""_ENDDATE_$S($D(FBPROG):""^""_FBPROG,1:""""),PGM=""START^FBCHVH"" D ZIS^FBAAUTL G:FBPOP END S:IO=IO(0) FBAANQ=1"
^XMB(3.9,145986,2,1907,0)="""RTN"",""FBCHVH"",8,0)"
^XMB(3.9,145986,2,1908,0)="START S:'$D(FBPROG) FBPROG=6 S FBHEAD=""VENDOR"",Q="""",$P(Q,""="",80)=""="",FBAAOUT=0 U IO D GETDAT S:$E(IOST,1,2)'[""C-"" FBPG=1 D HEDC"
