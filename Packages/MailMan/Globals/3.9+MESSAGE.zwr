^XMB(3.9,145960,2,354,0)=" ;  Patch 219 did not remove support for any clients."
^XMB(3.9,145960,2,355,0)="""RTN"",""MAGGTU4T"",51,0)"
^XMB(3.9,145960,2,356,0)=" ;  Patch 182 removed support for "
^XMB(3.9,145960,2,357,0)="""RTN"",""MAGGTU4T"",52,0)"
