^XMB(3.9,145944,2,1271,0)="""RTN"",""IBJDF42"",119,0)"
^XMB(3.9,145944,2,1272,0)=" ;"
^XMB(3.9,145944,2,1273,0)="""RTN"",""IBJDF42"",120,0)"
^XMB(3.9,145944,2,1274,0)="WCOM(IBPT,IB) ; - Write bill comments."
^XMB(3.9,145944,2,1275,0)="""RTN"",""IBJDF42"",121,0)"
^XMB(3.9,145944,2,1276,0)=" N CMDT,CONT,DIWL,DIWR,IBIDX,IBTR,IBLN,IBX,X"
^XMB(3.9,145944,2,1277,0)="""RTN"",""IBJDF42"",122,0)"
^XMB(3.9,145944,2,1278,0)=" ;"
^XMB(3.9,145944,2,1279,0)="""RTN"",""IBJDF42"",123,0)"
^XMB(3.9,145944,2,1280,0)=" S (IBIDX,IBTR,IBLN)="""",DIWL=1,DIWR=64 K ^UTILITY($J,""W"")"
^XMB(3.9,145944,2,1281,0)="""RTN"",""IBJDF42"",124,0)"
^XMB(3.9,145944,2,1282,0)=" F  S IBIDX=$O(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX)) Q:IBIDX=""""  D  Q:IBQ"
^XMB(3.9,145944,2,1283,0)="""RTN"",""IBJDF42"",125,0)"
^XMB(3.9,145944,2,1284,0)=" . I $Y>(IOSL-6) D WCPB Q:IBQ"
^XMB(3.9,145944,2,1285,0)="""RTN"",""IBJDF42"",126,0)"
^XMB(3.9,145944,2,1286,0)=" . D WCD(IBIDX)"
^XMB(3.9,145944,2,1287,0)="""RTN"",""IBJDF42"",127,0)"
^XMB(3.9,145944,2,1288,0)=" . F  S IBTR=$O(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX,IBTR)) Q:IBTR=""""  D  Q:IBQ"
^XMB(3.9,145944,2,1289,0)="""RTN"",""IBJDF42"",128,0)"
^XMB(3.9,145944,2,1290,0)=" . . S CMDT=$G(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX,IBTR))"
^XMB(3.9,145944,2,1291,0)="""RTN"",""IBJDF42"",129,0)"
^XMB(3.9,145944,2,1292,0)=" . . I $Y>(IOSL-4) D WCPB Q:IBQ"
^XMB(3.9,145944,2,1293,0)="""RTN"",""IBJDF42"",130,0)"
^XMB(3.9,145944,2,1294,0)=" . . S CONT=0 D WCD(,1,)"
^XMB(3.9,145944,2,1295,0)="""RTN"",""IBJDF42"",131,0)"
^XMB(3.9,145944,2,1296,0)=" . . F  S IBLN=$O(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX,IBTR,IBLN)) Q:IBLN=""""  D  Q:IBQ"
^XMB(3.9,145944,2,1297,0)="""RTN"",""IBJDF42"",132,0)"
^XMB(3.9,145944,2,1298,0)=" . . . S IBX=$G(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX,IBTR,IBLN))"
^XMB(3.9,145944,2,1299,0)="""RTN"",""IBJDF42"",133,0)"
^XMB(3.9,145944,2,1300,0)=" . . . I $E(IBX)="" "",$L(IBX)>1 S $E(IBX)="""""
^XMB(3.9,145944,2,1301,0)="""RTN"",""IBJDF42"",134,0)"
^XMB(3.9,145944,2,1302,0)=" . . . S X=IBX D ^DIWP"
^XMB(3.9,145944,2,1303,0)="""RTN"",""IBJDF42"",135,0)"
^XMB(3.9,145944,2,1304,0)=" . . . I 'CONT,$L(IBX)<66 D WCTX"
^XMB(3.9,145944,2,1305,0)="""RTN"",""IBJDF42"",136,0)"
^XMB(3.9,145944,2,1306,0)=" . . . S CONT=$L(IBX)>65"
^XMB(3.9,145944,2,1307,0)="""RTN"",""IBJDF42"",137,0)"
^XMB(3.9,145944,2,1308,0)=" . . . I '$O(^TMP(""IBJDF4"",$J,IBPT,0,""C"",IB,IBIDX,IBTR,IBLN)) D"
^XMB(3.9,145944,2,1309,0)="""RTN"",""IBJDF42"",138,0)"
^XMB(3.9,145944,2,1310,0)=" . . . . D:$D(^UTILITY($J,""W"")) WCTX"
^XMB(3.9,145944,2,1311,0)="""RTN"",""IBJDF42"",139,0)"
^XMB(3.9,145944,2,1312,0)=" K ^UTILITY($J,""W"")"
^XMB(3.9,145944,2,1313,0)="""RTN"",""IBJDF42"",140,0)"
^XMB(3.9,145944,2,1314,0)=" Q"
^XMB(3.9,145944,2,1315,0)="""RTN"",""IBJDF42"",141,0)"
^XMB(3.9,145944,2,1316,0)=" ;"
^XMB(3.9,145944,2,1317,0)="""RTN"",""IBJDF42"",142,0)"
^XMB(3.9,145944,2,1318,0)="WCD(I,D,C) ; - Write the comment date."
^XMB(3.9,145944,2,1319,0)="""RTN"",""IBJDF42"",143,0)"
^XMB(3.9,145944,2,1320,0)=" ; Input: I - Index #         ""(I)"""
