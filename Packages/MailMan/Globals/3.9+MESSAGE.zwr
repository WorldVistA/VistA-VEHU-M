^XMB(3.9,145986,2,1298,0)=" S Y=$G(^FBAAA(DFN,4)) W:$P(Y,""^"")]"""" !,""Fee ID Card #: "",$P(Y,""^""),?40,""Fee Card Issue Date: "" S Y=$P(Y,""^"",2) D PDF W Y,!"
^XMB(3.9,145986,2,1299,0)="""RTN"",""FBAADEM1"",8,0)"
^XMB(3.9,145986,2,1300,0)=" ;"
^XMB(3.9,145986,2,1301,0)="""RTN"",""FBAADEM1"",9,0)"
^XMB(3.9,145986,2,1302,0)=" I $O(^FBAAA(DFN,1,0)) D  Q:FBAAOUT"
^XMB(3.9,145986,2,1303,0)="""RTN"",""FBAADEM1"",10,0)"
^XMB(3.9,145986,2,1304,0)=" . D HANG:$Y+5>IOSL Q:FBAAOUT"
^XMB(3.9,145986,2,1305,0)="""RTN"",""FBAADEM1"",11,0)"
^XMB(3.9,145986,2,1306,0)=" . W !,""Patient Name: "",VADM(1),?55,""Pt.ID: "",$P(VADM(2),""^"",2)"
^XMB(3.9,145986,2,1307,0)="""RTN"",""FBAADEM1"",12,0)"
^XMB(3.9,145986,2,1308,0)=" . W !!,""AUTHORIZATIONS:"",!"
^XMB(3.9,145986,2,1309,0)="""RTN"",""FBAADEM1"",13,0)"
^XMB(3.9,145986,2,1310,0)=" . K FBAUT"
^XMB(3.9,145986,2,1311,0)="""RTN"",""FBAADEM1"",14,0)"
^XMB(3.9,145986,2,1312,0)=" . S FBZ=0,FBFDT=""9999999"""
^XMB(3.9,145986,2,1313,0)="""RTN"",""FBAADEM1"",15,0)"
^XMB(3.9,145986,2,1314,0)=" . F  S FBFDT=$O(^FBAAA(DFN,1,""B"",FBFDT),-1) Q:'FBFDT  D  Q:FBAAOUT"
^XMB(3.9,145986,2,1315,0)="""RTN"",""FBAADEM1"",16,0)"
^XMB(3.9,145986,2,1316,0)=" . . S FBI=0 F  S FBI=$O(^FBAAA(DFN,1,""B"",FBFDT,FBI)) Q:'FBI  I $D(^FBAAA(DFN,1,FBI,0)) X FBPROG I  S FBZ=FBZ+1,X=^(0) D  Q:FBAAOUT"
^XMB(3.9,145986,2,1317,0)="""RTN"",""FBAADEM1"",17,0)"
^XMB(3.9,145986,2,1318,0)=" . . . S Y=+X,PSA=$P(X,""^"",5),FBT=$P(X,""^"",13),FBV=+$P(X,""^"",4) D PDF"
^XMB(3.9,145986,2,1319,0)="""RTN"",""FBAADEM1"",18,0)"
^XMB(3.9,145986,2,1320,0)=" . . . W ?3,""("",FBZ,"")"",?7,""FR: "",Y,?25,""VENDOR: "",$S($D(^FBAAV(FBV,0)):$P(^(0),""^"")_"" - ""_$P(^(0),""^"",2),1:""Not Specified"")"
^XMB(3.9,145986,2,1321,0)="""RTN"",""FBAADEM1"",19,0)"
^XMB(3.9,145986,2,1322,0)=" . . . S FBDX=$G(^FBAAA(DFN,1,FBI,3))"
^XMB(3.9,145986,2,1323,0)="""RTN"",""FBAADEM1"",20,0)"
^XMB(3.9,145986,2,1324,0)=" . . . W !?7,""TO: "" S Y=$P(X,""^"",2) D PDF W Y"
^XMB(3.9,145986,2,1325,0)="""RTN"",""FBAADEM1"",21,0)"
^XMB(3.9,145986,2,1326,0)=" . . . W:$P(X,""^"",22) ?25,""Contract: "",$P($G(^FBAA(161.43,$P(X,""^"",22),0)),""^"")"
^XMB(3.9,145986,2,1327,0)="""RTN"",""FBAADEM1"",22,0)"
^XMB(3.9,145986,2,1328,0)=" . . . W !?25,""Authorization Type: "" D"
^XMB(3.9,145986,2,1329,0)="""RTN"",""FBAADEM1"",23,0)"
^XMB(3.9,145986,2,1330,0)=" . . . . S FBTYPE=$P(X,""^"",3),FBTYPE=$S(FBTYPE=2:""Outpatient - ""_$S(FBT=1:""Short Term"",FBT=2:""Home Health"",FBT=3:""ID Card"",1:""""),$D(^FBAA(161.8,+FBTYPE,0)):$P(^(0),""^""),1:""Unknown"")"
^XMB(3.9,145986,2,1331,0)="""RTN"",""FBAADEM1"",24,0)"
^XMB(3.9,145986,2,1332,0)=" . . . W FBTYPE W:$P(X,""^"",7) !,?11,""Purpose of Visit: "",$P($G(^FBAA(161.82,$P(X,""^"",7),0)),""^"") I $P(X,""^"",9)[""FB583("" W !?25,"">> Unauthorized Claim <<"""
^XMB(3.9,145986,2,1333,0)="""RTN"",""FBAADEM1"",25,0)"
^XMB(3.9,145986,2,1334,0)=" . . . ; PRXM/KJH - Patch 103. Add Referring Provider and NPI to the display."
^XMB(3.9,145986,2,1335,0)="""RTN"",""FBAADEM1"",26,0)"
^XMB(3.9,145986,2,1336,0)=" . . . ; JLG-FB*3.5*139-ICD10 REMEDIATION- print proper version of diagnosis code"
^XMB(3.9,145986,2,1337,0)="""RTN"",""FBAADEM1"",27,0)"
^XMB(3.9,145986,2,1338,0)=" . . . ;W !?11,""DX: "",$P(X,""^"",8) W ?40,""REF: """
^XMB(3.9,145986,2,1339,0)="""RTN"",""FBAADEM1"",28,0)"
^XMB(3.9,145986,2,1340,0)=" . . . D DC W !?11,""DX: "",FBDC W ?40,""REF: """
^XMB(3.9,145986,2,1341,0)="""RTN"",""FBAADEM1"",29,0)"
^XMB(3.9,145986,2,1342,0)=" . . . I $P(X,""^"",21)'="""" W $$GET1^DIQ(200,$P(X,""^"",21),.01)"
^XMB(3.9,145986,2,1343,0)="""RTN"",""FBAADEM1"",30,0)"
^XMB(3.9,145986,2,1344,0)=" . . . W !?11,""REF NPI: "",$$REFNPI^FBCH78($P(X,""^"",21)),!"
^XMB(3.9,145986,2,1345,0)="""RTN"",""FBAADEM1"",31,0)"
^XMB(3.9,145986,2,1346,0)=" . . . W:$P(FBDX,""^"")]"""" !?15,$P(FBDX,""^"")"
^XMB(3.9,145986,2,1347,0)="""RTN"",""FBAADEM1"",32,0)"
^XMB(3.9,145986,2,1348,0)=" . . . W:$P(FBDX,""^"",2)]"""" !?15,$P(FBDX,""^"",2)"
^XMB(3.9,145986,2,1349,0)="""RTN"",""FBAADEM1"",33,0)"
^XMB(3.9,145986,2,1350,0)=" . . . S FBAUT($P(X,""^""))=$P(X,""^"",2)"
^XMB(3.9,145986,2,1351,0)="""RTN"",""FBAADEM1"",34,0)"
^XMB(3.9,145986,2,1352,0)=" . . . W !?7,""County: "",FBCOUNTY,?40,""PSA: "",$S($D(^DIC(4,+PSA,0)):$P(^(0),""^""),1:""Unknown""),!"
^XMB(3.9,145986,2,1353,0)="""RTN"",""FBAADEM1"",35,0)"
^XMB(3.9,145986,2,1354,0)=" . . . S FBDEL=$G(^FBAAA(DFN,1,FBI,""ADEL"")) I FBDEL]"""" S Y=$P(FBDEL,""^"",2) D PDF W ?12,"">> DELETE MRA SENT TO AUSTIN ON - "",Y,"" >>"",!"
^XMB(3.9,145986,2,1355,0)="""RTN"",""FBAADEM1"",36,0)"
^XMB(3.9,145986,2,1356,0)=" . . . I $D(^FBAAA(DFN,1,FBI,2,0)) K ^UTILITY($J,""W"") S DIWL=15,DIWR=70,DIWF=""W"" D HANG:$Y+6>IOSL Q:FBAAOUT  W !?11,""REMARKS:"" D"
^XMB(3.9,145986,2,1357,0)="""RTN"",""FBAADEM1"",37,0)"
^XMB(3.9,145986,2,1358,0)=" . . . . S FBRR=0 F  S FBRR=$O(^FBAAA(DFN,1,FBI,2,FBRR)) Q:'FBRR  S (FBXX,X)=^(FBRR,0) D ^DIWP"
^XMB(3.9,145986,2,1359,0)="""RTN"",""FBAADEM1"",38,0)"
^XMB(3.9,145986,2,1360,0)=" . . . D ^DIWW:$D(FBXX) K FBXX W !"
^XMB(3.9,145986,2,1361,0)="""RTN"",""FBAADEM1"",39,0)"
^XMB(3.9,145986,2,1362,0)=" . . . K X,FBDX,FBT,FBTYPE,FBV,PSA D HANG:$Y+5>IOSL"
^XMB(3.9,145986,2,1363,0)="""RTN"",""FBAADEM1"",40,0)"
^XMB(3.9,145986,2,1364,0)=" ;"
^XMB(3.9,145986,2,1365,0)="""RTN"",""FBAADEM1"",41,0)"
^XMB(3.9,145986,2,1366,0)=" D HANG:$Y+5>IOSL Q:FBAAOUT"
^XMB(3.9,145986,2,1367,0)="""RTN"",""FBAADEM1"",42,0)"
^XMB(3.9,145986,2,1368,0)=" ;"
^XMB(3.9,145986,2,1369,0)="""RTN"",""FBAADEM1"",43,0)"
^XMB(3.9,145986,2,1370,0)=" I $O(^FBAAA(DFN,2,0))>0 D  Q:FBAAOUT"
^XMB(3.9,145986,2,1371,0)="""RTN"",""FBAADEM1"",44,0)"
^XMB(3.9,145986,2,1372,0)=" . W !,""VENDOR CONTACTS:"""
^XMB(3.9,145986,2,1373,0)="""RTN"",""FBAADEM1"",45,0)"
^XMB(3.9,145986,2,1374,0)=" . S (FBZ,FBI)=0"
^XMB(3.9,145986,2,1375,0)="""RTN"",""FBAADEM1"",46,0)"
^XMB(3.9,145986,2,1376,0)=" . F  S FBI=$O(^FBAAA(DFN,2,FBI)) Q:'FBI!(FBAAOUT)  S FBZ=FBZ+1,X=$G(^(FBI,0)),Y=+X D PDF D"
^XMB(3.9,145986,2,1377,0)="""RTN"",""FBAADEM1"",47,0)"
^XMB(3.9,145986,2,1378,0)=" . . W !?3,""("",FBZ,"")"",?7,""DATE: "",Y,?25,""VENDOR: "",$P(X,""^"",2),?55,""PHONE: "",$S($P(X,""^"",3)]"""":$P(X,""^"",3),1:""Not Found"")"
^XMB(3.9,145986,2,1379,0)="""RTN"",""FBAADEM1"",48,0)"
^XMB(3.9,145986,2,1380,0)=" . . I $D(^FBAAA(DFN,2,FBI,1,0)) K ^UTILITY($J,""W"") S DIWL=20,DIWR=70,DIWF=""W"" D HANG:$Y+5>IOSL Q:FBAAOUT  W !?11,""NARRATIVE:"",! D"
^XMB(3.9,145986,2,1381,0)="""RTN"",""FBAADEM1"",49,0)"
^XMB(3.9,145986,2,1382,0)=" . . . S FBRR=0 F  S FBRR=$O(^FBAAA(DFN,2,FBI,1,FBRR)) Q:'FBRR  S FBXX=^(FBRR,0) D HANG:$Y+5>IOSL Q:FBAAOUT  S X=FBXX D ^DIWP"
^XMB(3.9,145986,2,1383,0)="""RTN"",""FBAADEM1"",50,0)"
^XMB(3.9,145986,2,1384,0)=" . . D ^DIWW:$D(FBXX) K FBXX W !"
^XMB(3.9,145986,2,1385,0)="""RTN"",""FBAADEM1"",51,0)"
^XMB(3.9,145986,2,1386,0)=" Q"
^XMB(3.9,145986,2,1387,0)="""RTN"",""FBAADEM1"",52,0)"
^XMB(3.9,145986,2,1388,0)=" ;"
^XMB(3.9,145986,2,1389,0)="""RTN"",""FBAADEM1"",53,0)"
^XMB(3.9,145986,2,1390,0)="DC ; JLG-FB*3.5*139-ICD10 REMEDIATION- determine diagnosis code based on authorization from date"
^XMB(3.9,145986,2,1391,0)="""RTN"",""FBAADEM1"",54,0)"
^XMB(3.9,145986,2,1392,0)=" S FBDC="""""
^XMB(3.9,145986,2,1393,0)="""RTN"",""FBAADEM1"",55,0)"
^XMB(3.9,145986,2,1394,0)=" N FBVERS S FBVERS=$S(FBFDT<$$IMPDATE^FBCSV1(""10D""):""9"",1:""10"")"
^XMB(3.9,145986,2,1395,0)="""RTN"",""FBAADEM1"",56,0)"
^XMB(3.9,145986,2,1396,0)=" S:FBVERS=9 FBDC=$P(X,""^"",8)"
^XMB(3.9,145986,2,1397,0)="""RTN"",""FBAADEM1"",57,0)"
^XMB(3.9,145986,2,1398,0)=" S:FBVERS=10 FBDC=$$ICD9^FBCSV1($P($G(^FBAAA(DFN,1,FBI,""C"")),""^"",2))"
^XMB(3.9,145986,2,1399,0)="""RTN"",""FBAADEM1"",58,0)"
^XMB(3.9,145986,2,1400,0)=" ;per SME requirement do not print ICD-10 diagnosis code for a CIVIL HOSPITAL unauthorized claim."
^XMB(3.9,145986,2,1401,0)="""RTN"",""FBAADEM1"",59,0)"
^XMB(3.9,145986,2,1402,0)=" S:(FBVERS'=9)&($P(X,""^"",3)=6)&($P(X,""^"",9)[""FB583("") FBDC="""""
^XMB(3.9,145986,2,1403,0)="""RTN"",""FBAADEM1"",60,0)"
^XMB(3.9,145986,2,1404,0)=" K FBVERS"
^XMB(3.9,145986,2,1405,0)="""RTN"",""FBAADEM1"",61,0)"
^XMB(3.9,145986,2,1406,0)=" Q"
^XMB(3.9,145986,2,1407,0)="""RTN"",""FBAADEM1"",62,0)"
^XMB(3.9,145986,2,1408,0)=" ;"
^XMB(3.9,145986,2,1409,0)="""RTN"",""FBAADEM1"",63,0)"
^XMB(3.9,145986,2,1410,0)="HANG I $E(IOST,1,2)=""C-"" S DIR(0)=""E"" D ^DIR K DIR S:'Y FBAAOUT=1"
^XMB(3.9,145986,2,1411,0)="""RTN"",""FBAADEM1"",64,0)"
^XMB(3.9,145986,2,1412,0)=" W @IOF I 'FBAAOUT W !,""Patient Name: "",VADM(1),?55,""Pt.ID: "",$P(VADM(2),""^"",2),!"
^XMB(3.9,145986,2,1413,0)="""RTN"",""FBAADEM1"",65,0)"
^XMB(3.9,145986,2,1414,0)=" Q"
^XMB(3.9,145986,2,1415,0)="""RTN"",""FBAADEM1"",66,0)"
^XMB(3.9,145986,2,1416,0)=" ;"
^XMB(3.9,145986,2,1417,0)="""RTN"",""FBAADEM1"",67,0)"
^XMB(3.9,145986,2,1418,0)="PDF S:Y Y=$$FMTE^XLFDT(Y,5)  ; TRANSLATE TO DISPLAY DATE"
^XMB(3.9,145986,2,1419,0)="""RTN"",""FBAADEM1"",68,0)"
^XMB(3.9,145986,2,1420,0)=" Q"
^XMB(3.9,145986,2,1421,0)="""RTN"",""FBAAVD"")"
^XMB(3.9,145986,2,1422,0)="0^21^B28132185"
^XMB(3.9,145986,2,1423,0)="""RTN"",""FBAAVD"",1,0)"
^XMB(3.9,145986,2,1424,0)="FBAAVD ;AISC/DMK-DISPLAY/EDIT VENDOR DEMOGRAPHICS ; 8/28/09 12:35pm"
^XMB(3.9,145986,2,1425,0)="""RTN"",""FBAAVD"",2,0)"
^XMB(3.9,145986,2,1426,0)=" ;;3.5;FEE BASIS;**9,98,111,122**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,1427,0)="""RTN"",""FBAAVD"",3,0)"
^XMB(3.9,145986,2,1428,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145986,2,1429,0)="""RTN"",""FBAAVD"",4,0)"
^XMB(3.9,145986,2,1430,0)=" ;FBTEMP set = 1 if called from input template"
^XMB(3.9,145986,2,1431,0)="""RTN"",""FBAAVD"",5,0)"
^XMB(3.9,145986,2,1432,0)="RDV ;ask vendor"
^XMB(3.9,145986,2,1433,0)="""RTN"",""FBAAVD"",6,0)"
^XMB(3.9,145986,2,1434,0)=" W ! K DFN,FBRATE S FEEO="""",DIC=""^FBAAV("",DIC(0)=""AEQLM"",DLAYGO=161.2,DIC(""DR"")=""1;6;7;8"" D ^DIC K DIC,DLAYGO G Q:$D(DTOUT)!(X="""")!($D(DUOUT)),RDV:Y<0 S DA=+Y"
^XMB(3.9,145986,2,1435,0)="""RTN"",""FBAAVD"",7,0)"
^XMB(3.9,145986,2,1436,0)=" D NEW:$P(Y,U,3)=1 D EN1"
^XMB(3.9,145986,2,1437,0)="""RTN"",""FBAAVD"",8,0)"
^XMB(3.9,145986,2,1438,0)=" I $G(DA) W ! I $D(^XUSEC(""FBAA ESTABLISH VENDOR"",DUZ)) S DIR(0)=""Y"",DIR(""B"")=""No"",DIR(""A"")=""Want to edit data"" D ^DIR K DIR I $G(Y) D EDITV"
^XMB(3.9,145986,2,1439,0)="""RTN"",""FBAAVD"",9,0)"
^XMB(3.9,145986,2,1440,0)=" Q:$G(FBTEMP)"
^XMB(3.9,145986,2,1441,0)="""RTN"",""FBAAVD"",10,0)"
^XMB(3.9,145986,2,1442,0)=" G RDV"
^XMB(3.9,145986,2,1443,0)="""RTN"",""FBAAVD"",11,0)"
^XMB(3.9,145986,2,1444,0)=" ;"
^XMB(3.9,145986,2,1445,0)="""RTN"",""FBAAVD"",12,0)"
^XMB(3.9,145986,2,1446,0)="EN1 ;display vendor demographics"
^XMB(3.9,145986,2,1447,0)="""RTN"",""FBAAVD"",13,0)"
^XMB(3.9,145986,2,1448,0)=" ;DA = IEN of vendor in file 161.2"
^XMB(3.9,145986,2,1449,0)="""RTN"",""FBAAVD"",14,0)"
^XMB(3.9,145986,2,1450,0)=" ;"
^XMB(3.9,145986,2,1451,0)="""RTN"",""FBAAVD"",15,0)"
^XMB(3.9,145986,2,1452,0)=" N C,I"
^XMB(3.9,145986,2,1453,0)="""RTN"",""FBAAVD"",16,0)"
^XMB(3.9,145986,2,1454,0)=" Q:'$G(DA)"
^XMB(3.9,145986,2,1455,0)="""RTN"",""FBAAVD"",17,0)"
^XMB(3.9,145986,2,1456,0)=" S Z=$G(^FBAAV(DA,0)),V=$G(^(1)),T=$G(^(""AMS"")),A=$G(^(""ADEL"")),FBNPI=$P($G(^(3)),U,2),FBTXC=$P($G(^(3)),U,3)"
^XMB(3.9,145986,2,1457,0)="""RTN"",""FBAAVD"",18,0)"
^XMB(3.9,145986,2,1458,0)=" F X=1:1:17 S Z(X)=$P(Z,U,X)"
^XMB(3.9,145986,2,1459,0)="""RTN"",""FBAAVD"",19,0)"
^XMB(3.9,145986,2,1460,0)=" S FBDEL=$S($P(A,U)=""Y"":1,1:0),FBAAPN=$P(V,U),FBAAFN=$P(V,U,9)"
^XMB(3.9,145986,2,1461,0)="""RTN"",""FBAAVD"",20,0)"
^XMB(3.9,145986,2,1462,0)=" ;Z=zero node,V=one node,T=ams node,A=adel node"
^XMB(3.9,145986,2,1463,0)="""RTN"",""FBAAVD"",21,0)"
^XMB(3.9,145986,2,1464,0)=" ;"
^XMB(3.9,145986,2,1465,0)="""RTN"",""FBAAVD"",22,0)"
^XMB(3.9,145986,2,1466,0)=" S IOP=$S($D(ION):ION,1:""HOME"") D ^%ZIS W @IOF K IOP"
^XMB(3.9,145986,2,1467,0)="""RTN"",""FBAAVD"",23,0)"
^XMB(3.9,145986,2,1468,0)=" I +$G(DFN)>0 W !,""Patient Name: "",$P($G(^DPT(DFN,0)),U),?48,""Pt.ID: "",$$SSN^FBAAUTL(DFN),!"
^XMB(3.9,145986,2,1469,0)="""RTN"",""FBAAVD"",24,0)"
^XMB(3.9,145986,2,1470,0)=" W !?22,""***  VENDOR DEMOGRAPHICS  ***"" D"
^XMB(3.9,145986,2,1471,0)="""RTN"",""FBAAVD"",25,0)"
