^XMB(3.9,145958,2,1605,0)="""RTN"",""ORWDXA"",297,0)"
^XMB(3.9,145958,2,1606,0)=" I COMMID S WPCNT=0 F  S WPCNT=$O(^OR(100,+ORID,4.5,COMMID,2,WPCNT)) Q:'WPCNT!(RET)  D"
^XMB(3.9,145958,2,1607,0)="""RTN"",""ORWDXA"",298,0)"
^XMB(3.9,145958,2,1608,0)=" .I $G(^OR(100,+ORID,4.5,COMMID,2,WPCNT,0))[""^"" S RET=1"
^XMB(3.9,145958,2,1609,0)="""RTN"",""ORWDXA"",299,0)"
^XMB(3.9,145958,2,1610,0)=" S PIID=$O(^OR(100,+ORID,4.5,""ID"",""PI"",0))"
^XMB(3.9,145958,2,1611,0)="""RTN"",""ORWDXA"",300,0)"
^XMB(3.9,145958,2,1612,0)=" I PIID S WPCNT=0 F  S WPCNT=$O(^OR(100,+ORID,4.5,PIID,2,WPCNT)) Q:'WPCNT!(RET)  D"
^XMB(3.9,145958,2,1613,0)="""RTN"",""ORWDXA"",301,0)"
^XMB(3.9,145958,2,1614,0)=" .I $G(^OR(100,+ORID,4.5,PIID,2,WPCNT,0))[""^"" S RET=1"
^XMB(3.9,145958,2,1615,0)="""RTN"",""ORWDXA"",302,0)"
