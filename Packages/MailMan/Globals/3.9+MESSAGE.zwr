^XMB(3.9,145976,2,402,0)=" ;"
^XMB(3.9,145976,2,403,0)="""RTN"",""MAGGTU4D"",77,0)"
^XMB(3.9,145976,2,404,0)=" ;               Text must be stored at nodes with positive numbers"
^XMB(3.9,145976,2,405,0)="""RTN"",""MAGGTU4D"",78,0)"
^XMB(3.9,145976,2,406,0)=" ;               or at the 0-node descendent from those nodes."
^XMB(3.9,145976,2,407,0)="""RTN"",""MAGGTU4D"",79,0)"
^XMB(3.9,145976,2,408,0)=" ;"
^XMB(3.9,145976,2,409,0)="""RTN"",""MAGGTU4D"",80,0)"
