^XMB(3.9,145986,2,2142,0)="CDAT S Y=$E(Y,4,5)_""/""_$S($E(Y,6,7)=""00"":$E(Y,2,3),1:$E(Y,6,7)_""/""_$E(Y,2,3)) Q"
