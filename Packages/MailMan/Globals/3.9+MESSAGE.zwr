^XMB(3.9,145981,2,316,0)=" ;Look for future clocks within 1 year if no past clocks found - IB*2.0*769"
^XMB(3.9,145981,2,317,0)="""RTN"",""IBECECX1"",39,0)"
^XMB(3.9,145981,2,318,0)=" I IBCLDT="""" S IBECFDT=-($$FMADD^XLFDT(IBADMIT,364))_.9999,IBECSTP=-IBADMIT D"
