^XMB(3.9,145946,2,6123,0)="""RTN"",""IBCOPP"",34,0)"
^XMB(3.9,145946,2,6124,0)=" ;         2 - Select both Active and Inactive Insurance Company Plans"
^XMB(3.9,145946,2,6125,0)="""RTN"",""IBCOPP"",35,0)"
^XMB(3.9,145946,2,6126,0)=" ; IBAPL=  0 - Whether some or all ins. co's., user selects plans (may be"
^XMB(3.9,145946,2,6127,0)="""RTN"",""IBCOPP"",36,0)"
^XMB(3.9,145946,2,6128,0)=" ;             all for certain companies, some for other companies)"
^XMB(3.9,145946,2,6129,0)="""RTN"",""IBCOPP"",37,0)"
^XMB(3.9,145946,2,6130,0)=" ;         1 - Whether some or all ins. co's., run report for all plans"
^XMB(3.9,145946,2,6131,0)="""RTN"",""IBCOPP"",38,0)"
^XMB(3.9,145946,2,6132,0)=" ;             associated with those co's."
^XMB(3.9,145946,2,6133,0)="""RTN"",""IBCOPP"",39,0)"
^XMB(3.9,145946,2,6134,0)=" ;"
^XMB(3.9,145946,2,6135,0)="""RTN"",""IBCOPP"",40,0)"
^XMB(3.9,145946,2,6136,0)=" N A,I,IBAO,POP,ZTDESC,ZTDEXC,ZTRTN,ZTSAVE,%ZIS"
^XMB(3.9,145946,2,6137,0)="""RTN"",""IBCOPP"",41,0)"
^XMB(3.9,145946,2,6138,0)=" K ^TMP(""IBINC"",$J)"
^XMB(3.9,145946,2,6139,0)="""RTN"",""IBCOPP"",42,0)"
^XMB(3.9,145946,2,6140,0)=" S IBAPA=$$SELR^IBCOPP1                     ; Report Type prompt"
^XMB(3.9,145946,2,6141,0)="""RTN"",""IBCOPP"",43,0)"
^XMB(3.9,145946,2,6142,0)=" I IBAPA<0 D ENQ Q"
^XMB(3.9,145946,2,6143,0)="""RTN"",""IBCOPP"",44,0)"
^XMB(3.9,145946,2,6144,0)=" S IBAI=$$SELI^IBCOPP1                      ; All/Selected Ins. Cos. prompt"
^XMB(3.9,145946,2,6145,0)="""RTN"",""IBCOPP"",45,0)"
^XMB(3.9,145946,2,6146,0)=" I IBAI<0 D ENQ Q"
^XMB(3.9,145946,2,6147,0)="""RTN"",""IBCOPP"",46,0)"
^XMB(3.9,145946,2,6148,0)=" ;"
^XMB(3.9,145946,2,6149,0)="""RTN"",""IBCOPP"",47,0)"
^XMB(3.9,145946,2,6150,0)=" ; IB*2.0*549 - Inactive/Active/Both Insurance Company look-up filter"
^XMB(3.9,145946,2,6151,0)="""RTN"",""IBCOPP"",48,0)"
^XMB(3.9,145946,2,6152,0)=" ;              Only ask if user didn't select all Insurance Companies"
^XMB(3.9,145946,2,6153,0)="""RTN"",""IBCOPP"",49,0)"
^XMB(3.9,145946,2,6154,0)=" S IBAIA=$$SELA^IBCOPP1"
^XMB(3.9,145946,2,6155,0)="""RTN"",""IBCOPP"",50,0)"
^XMB(3.9,145946,2,6156,0)=" I IBAIA<0 D ENQ Q"
^XMB(3.9,145946,2,6157,0)="""RTN"",""IBCOPP"",51,0)"
^XMB(3.9,145946,2,6158,0)=" ;"
^XMB(3.9,145946,2,6159,0)="""RTN"",""IBCOPP"",52,0)"
^XMB(3.9,145946,2,6160,0)=" ; IB*2.0*549 - Added call to Insurance Company look-up listman template"
^XMB(3.9,145946,2,6161,0)="""RTN"",""IBCOPP"",53,0)"
^XMB(3.9,145946,2,6162,0)=" ;              for selecting, moved from START method"
^XMB(3.9,145946,2,6163,0)="""RTN"",""IBCOPP"",54,0)"
^XMB(3.9,145946,2,6164,0)=" ; Allow user selection of Insurance Companies, if required"
^XMB(3.9,145946,2,6165,0)="""RTN"",""IBCOPP"",55,0)"
^XMB(3.9,145946,2,6166,0)=" I 'IBAI D  I IBQUIT=1 D ENQ Q"
^XMB(3.9,145946,2,6167,0)="""RTN"",""IBCOPP"",56,0)"
^XMB(3.9,145946,2,6168,0)=" . N IBCNS,XX"
^XMB(3.9,145946,2,6169,0)="""RTN"",""IBCOPP"",57,0)"
^XMB(3.9,145946,2,6170,0)=" . S IBQUIT=0"
^XMB(3.9,145946,2,6171,0)="""RTN"",""IBCOPP"",58,0)"
^XMB(3.9,145946,2,6172,0)=" . D EN^IBCNILK(IBAIA)"
^XMB(3.9,145946,2,6173,0)="""RTN"",""IBCOPP"",59,0)"
^XMB(3.9,145946,2,6174,0)=" . I '$D(^TMP(""IBCNILKA"",$J)) S IBQUIT=1 Q  ; No Insurance Companies selected"
^XMB(3.9,145946,2,6175,0)="""RTN"",""IBCOPP"",60,0)"
^XMB(3.9,145946,2,6176,0)=" . S IBCNS="""""
^XMB(3.9,145946,2,6177,0)="""RTN"",""IBCOPP"",61,0)"
^XMB(3.9,145946,2,6178,0)=" . F  S IBCNS=$O(^TMP(""IBCNILKA"",$J,IBCNS)) Q:IBCNS=""""  D"
^XMB(3.9,145946,2,6179,0)="""RTN"",""IBCOPP"",62,0)"
^XMB(3.9,145946,2,6180,0)=" . . ;"
^XMB(3.9,145946,2,6181,0)="""RTN"",""IBCOPP"",63,0)"
^XMB(3.9,145946,2,6182,0)=" . . ; Insurance Company Name"
