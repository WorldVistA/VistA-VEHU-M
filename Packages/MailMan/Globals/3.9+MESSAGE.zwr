^XMB(3.9,145958,2,1192,0)=" D ORCAN^ORNORC(+ORID,""RT"") ; ajb add order number to 100.3"
^XMB(3.9,145958,2,1193,0)="""RTN"",""ORWDXA"",91,0)"
^XMB(3.9,145958,2,1194,0)=" I $G(DCORIG)="""" S DCORIG=0"
^XMB(3.9,145958,2,1195,0)="""RTN"",""ORWDXA"",92,0)"
^XMB(3.9,145958,2,1196,0)=" S CURRACT=0"
^XMB(3.9,145958,2,1197,0)="""RTN"",""ORWDXA"",93,0)"
^XMB(3.9,145958,2,1198,0)=" S ORL(2)=ORL_"";SC("",ORL=ORL(2),NATURE="""""
^XMB(3.9,145958,2,1199,0)="""RTN"",""ORWDXA"",94,0)"
^XMB(3.9,145958,2,1200,0)=" I REASON S NATURE=$P(^ORD(100.02,$P(^ORD(100.03,REASON,0),U,7),0),U,2)"
^XMB(3.9,145958,2,1201,0)="""RTN"",""ORWDXA"",95,0)"
^XMB(3.9,145958,2,1202,0)=" S:NATURE="""" NATURE=""W""  ; S:ORNP=DUZ NATURE=""E"""
^XMB(3.9,145958,2,1203,0)="""RTN"",""ORWDXA"",96,0)"
^XMB(3.9,145958,2,1204,0)=" ;change the way create work to support forcing signature for all DC"
^XMB(3.9,145958,2,1205,0)="""RTN"",""ORWDXA"",97,0)"
^XMB(3.9,145958,2,1206,0)=" ;reasons"
^XMB(3.9,145958,2,1207,0)="""RTN"",""ORWDXA"",98,0)"
^XMB(3.9,145958,2,1208,0)=" S CREATE=1,PRINT=$$PRINT^ORCACT2(NATURE)"
^XMB(3.9,145958,2,1209,0)="""RTN"",""ORWDXA"",99,0)"
^XMB(3.9,145958,2,1210,0)=" S X3=$G(^OR(100,+ORID,3))"
^XMB(3.9,145958,2,1211,0)="""RTN"",""ORWDXA"",100,0)"
^XMB(3.9,145958,2,1212,0)=" S CURRACT=$P(X3,U,7) S:CURRACT<1 CURRACT=+$O(^OR(100,+ORID,8,""?""),-1)"
^XMB(3.9,145958,2,1213,0)="""RTN"",""ORWDXA"",101,0)"
^XMB(3.9,145958,2,1214,0)=" I '$D(^OR(100,+ORID,8,+$P(ORID,"";"",2),0)) D"
^XMB(3.9,145958,2,1215,0)="""RTN"",""ORWDXA"",102,0)"
^XMB(3.9,145958,2,1216,0)=" . S X8=$G(^OR(100,+ORID,8,CURRACT,0))"
^XMB(3.9,145958,2,1217,0)="""RTN"",""ORWDXA"",103,0)"
^XMB(3.9,145958,2,1218,0)=" . S SIGSTS=$P(X8,U,4)"
^XMB(3.9,145958,2,1219,0)="""RTN"",""ORWDXA"",104,0)"
^XMB(3.9,145958,2,1220,0)=" . S $P(ORID,"";"",2)=CURRACT"
^XMB(3.9,145958,2,1221,0)="""RTN"",""ORWDXA"",105,0)"
^XMB(3.9,145958,2,1222,0)=" E  D"
^XMB(3.9,145958,2,1223,0)="""RTN"",""ORWDXA"",106,0)"
^XMB(3.9,145958,2,1224,0)=" . S X8=^OR(100,+ORID,8,+$P(ORID,"";"",2),0)"
^XMB(3.9,145958,2,1225,0)="""RTN"",""ORWDXA"",107,0)"
^XMB(3.9,145958,2,1226,0)=" . S SIGSTS=$P(X8,U,4)"
^XMB(3.9,145958,2,1227,0)="""RTN"",""ORWDXA"",108,0)"
^XMB(3.9,145958,2,1228,0)=" I '$D(SIGSTS) S SIGSTS=1"
^XMB(3.9,145958,2,1229,0)="""RTN"",""ORWDXA"",109,0)"
^XMB(3.9,145958,2,1230,0)=" S STATUS=$P($G(^OR(100,+ORID,8,+$P(ORID,"";"",2),0)),U,15)"
^XMB(3.9,145958,2,1231,0)="""RTN"",""ORWDXA"",110,0)"
^XMB(3.9,145958,2,1232,0)=" I (STATUS=10)!(STATUS=11) D  Q   ; delete/cancel unreleased order"
^XMB(3.9,145958,2,1233,0)="""RTN"",""ORWDXA"",111,0)"
^XMB(3.9,145958,2,1234,0)=" . N RPLORD"
^XMB(3.9,145958,2,1235,0)="""RTN"",""ORWDXA"",112,0)"
^XMB(3.9,145958,2,1236,0)=" . S RPLORD=$P($G(^OR(100,+ORID,3)),U,5)    ; replaced order"
^XMB(3.9,145958,2,1237,0)="""RTN"",""ORWDXA"",113,0)"
^XMB(3.9,145958,2,1238,0)=" . D GETBYIFN^ORWORR(.REC,ORID)"
^XMB(3.9,145958,2,1239,0)="""RTN"",""ORWDXA"",114,0)"
^XMB(3.9,145958,2,1240,0)=" . I STATUS=10,($P(X8,U,4)'=2) D  ; CANCEL signed, delayed, unreleased"
^XMB(3.9,145958,2,1241,0)="""RTN"",""ORWDXA"",115,0)"
^XMB(3.9,145958,2,1242,0)=" . . ; taken from CLRDLY^ORCACT2"
^XMB(3.9,145958,2,1243,0)="""RTN"",""ORWDXA"",116,0)"
^XMB(3.9,145958,2,1244,0)=" . . I REASON D SET^ORCACT2(+ORID,NATURE,REASON,,DCORIG)"
^XMB(3.9,145958,2,1245,0)="""RTN"",""ORWDXA"",117,0)"
^XMB(3.9,145958,2,1246,0)=" . . I 'REASON D SET^ORCACT2(+ORID,""M"","""",""Delayed Order Cancelled"",DCORIG)"
^XMB(3.9,145958,2,1247,0)="""RTN"",""ORWDXA"",118,0)"
^XMB(3.9,145958,2,1248,0)=" . . D STATUS^ORCSAVE2(+ORID,13) S $P(^OR(100,+ORID,8,1,0),U,15)=13"
^XMB(3.9,145958,2,1249,0)="""RTN"",""ORWDXA"",119,0)"
^XMB(3.9,145958,2,1250,0)=" . E  D                           ; CANCEL OR DELETE unsigned, unreleased"
^XMB(3.9,145958,2,1251,0)="""RTN"",""ORWDXA"",120,0)"
^XMB(3.9,145958,2,1252,0)=" . . I $P(X8,U,2)=""DC"" K ^OR(100,+ORID,6)"
^XMB(3.9,145958,2,1253,0)="""RTN"",""ORWDXA"",121,0)"
^XMB(3.9,145958,2,1254,0)=" . . ; delete fwd ptr to order about to be deleted"
^XMB(3.9,145958,2,1255,0)="""RTN"",""ORWDXA"",122,0)"
^XMB(3.9,145958,2,1256,0)=" . . I RPLORD,$P(X8,U,2)=""NW"" S $P(^OR(100,RPLORD,3),U,6)="""""
^XMB(3.9,145958,2,1257,0)="""RTN"",""ORWDXA"",123,0)"
^XMB(3.9,145958,2,1258,0)=" . . ; delete ptr to order in Patient Event file #100.2"
^XMB(3.9,145958,2,1259,0)="""RTN"",""ORWDXA"",124,0)"
^XMB(3.9,145958,2,1260,0)=" . . N EVT S EVT=$P($G(^OR(100,+ORID,0)),U,17) I EVT,EVT=+$O(^ORE(100.2,""AO"",+ORID,0)) S $P(^ORE(100.2,EVT,0),U,4)="""" K ^ORE(100.2,""AO"",+ORID,EVT)"
^XMB(3.9,145958,2,1261,0)="""RTN"",""ORWDXA"",125,0)"
^XMB(3.9,145958,2,1262,0)=" . . N REATXT S REATXT=$S('REASON:""Requesting Physician Cancelled"",1:"""") D SET^ORCACT2(+ORID,NATURE,REASON,REATXT,DCORIG),DELETE^ORCSAVE2(ORID) ;*466"
^XMB(3.9,145958,2,1263,0)="""RTN"",""ORWDXA"",126,0)"
^XMB(3.9,145958,2,1264,0)=" . . ;I $G(ISNEWORD) N REATXT S REATXT=$S('REASON:""Requesting Physician Cancelled"",1:"""") D SET^ORCACT2(+ORID,NATURE,REASON,REATXT,DCORIG),DELETE^ORCSAVE2(ORID) ;*466"
^XMB(3.9,145958,2,1265,0)="""RTN"",""ORWDXA"",127,0)"
^XMB(3.9,145958,2,1266,0)=" . . ;I '$G(ISNEWORD) D CANCEL^ORCSAVE2(ORID)"
^XMB(3.9,145958,2,1267,0)="""RTN"",""ORWDXA"",128,0)"
^XMB(3.9,145958,2,1268,0)=" . I RPLORD,'(SIGSTS=1) S ORID=RPLORD  ; for Renews & Changes, show replaced order"
^XMB(3.9,145958,2,1269,0)="""RTN"",""ORWDXA"",129,0)"
^XMB(3.9,145958,2,1270,0)=" . I '$D(^OR(100,+ORID)) D"
^XMB(3.9,145958,2,1271,0)="""RTN"",""ORWDXA"",130,0)"
^XMB(3.9,145958,2,1272,0)=" . . S $P(REC(1),U)=""~0"",REC(2)=""tDELETED: ""_$E(REC(2),2,245)"
^XMB(3.9,145958,2,1273,0)="""RTN"",""ORWDXA"",131,0)"
^XMB(3.9,145958,2,1274,0)=" . E  D"
^XMB(3.9,145958,2,1275,0)="""RTN"",""ORWDXA"",132,0)"
^XMB(3.9,145958,2,1276,0)=" . . K REC"
^XMB(3.9,145958,2,1277,0)="""RTN"",""ORWDXA"",133,0)"
^XMB(3.9,145958,2,1278,0)=" . . D GETBYIFN^ORWORR(.REC,+ORID_"";""_$P($G(^OR(100,+ORID,3)),U,7))"
^XMB(3.9,145958,2,1279,0)="""RTN"",""ORWDXA"",134,0)"
^XMB(3.9,145958,2,1280,0)=" . S $P(REC(1),U,14)=2 ; DCType = deletion"
^XMB(3.9,145958,2,1281,0)="""RTN"",""ORWDXA"",135,0)"
^XMB(3.9,145958,2,1282,0)=" S ACTDA=$$ACTION^ORCSAVE(""DC"",+ORID,ORNP)"
^XMB(3.9,145958,2,1283,0)="""RTN"",""ORWDXA"",136,0)"
^XMB(3.9,145958,2,1284,0)=" D SET^ORCACT2(+ORID,NATURE,REASON,,DCORIG)"
^XMB(3.9,145958,2,1285,0)="""RTN"",""ORWDXA"",137,0)"
^XMB(3.9,145958,2,1286,0)=" D GETBYIFN^ORWORR(.REC,+ORID_"";""_ACTDA)"
^XMB(3.9,145958,2,1287,0)="""RTN"",""ORWDXA"",138,0)"
^XMB(3.9,145958,2,1288,0)=" S $P(REC(1),U,14)=$S(CREATE:1,1:3)  ;DCType - 1=NewOrder, 3=NewStatus"
^XMB(3.9,145958,2,1289,0)="""RTN"",""ORWDXA"",139,0)"
^XMB(3.9,145958,2,1290,0)=" N PKG"
^XMB(3.9,145958,2,1291,0)="""RTN"",""ORWDXA"",140,0)"
^XMB(3.9,145958,2,1292,0)=" S PKG=$P($G(^OR(100,+ORID,0)),U,14)"
^XMB(3.9,145958,2,1293,0)="""RTN"",""ORWDXA"",141,0)"
^XMB(3.9,145958,2,1294,0)=" S PKG=$$NMSP^ORCD(PKG)"
^XMB(3.9,145958,2,1295,0)="""RTN"",""ORWDXA"",142,0)"
^XMB(3.9,145958,2,1296,0)=" I REASON=16&(PKG=""PS"") D"
^XMB(3.9,145958,2,1297,0)="""RTN"",""ORWDXA"",143,0)"
^XMB(3.9,145958,2,1298,0)=" . N XMB"
^XMB(3.9,145958,2,1299,0)="""RTN"",""ORWDXA"",144,0)"
^XMB(3.9,145958,2,1300,0)=" . S XMB=""OR DRUG ORDER CANCELLED"""
^XMB(3.9,145958,2,1301,0)="""RTN"",""ORWDXA"",145,0)"
^XMB(3.9,145958,2,1302,0)=" . S XMB(1)=$P($G(REC(2)),""tDiscontinue"",2),XMB(4)=$P($G(^VA(200,DUZ,0)),U)"
^XMB(3.9,145958,2,1303,0)="""RTN"",""ORWDXA"",146,0)"
^XMB(3.9,145958,2,1304,0)=" . S XMB(2)=+ORID"
^XMB(3.9,145958,2,1305,0)="""RTN"",""ORWDXA"",147,0)"
^XMB(3.9,145958,2,1306,0)=" . S XMB(3)=+$P($G(^OR(100,+ORID,0)),U,2)"
^XMB(3.9,145958,2,1307,0)="""RTN"",""ORWDXA"",148,0)"
^XMB(3.9,145958,2,1308,0)=" . S XMB(3)=$P($G(^DPT(XMB(3),0)),U)"
^XMB(3.9,145958,2,1309,0)="""RTN"",""ORWDXA"",149,0)"
^XMB(3.9,145958,2,1310,0)=" . D ^XMB"
^XMB(3.9,145958,2,1311,0)="""RTN"",""ORWDXA"",150,0)"
^XMB(3.9,145958,2,1312,0)=" Q"
^XMB(3.9,145958,2,1313,0)="""RTN"",""ORWDXA"",151,0)"
^XMB(3.9,145958,2,1314,0)="DCREQIEN(VAL) ; Return IEN for Req Phys Cancelled reason"
^XMB(3.9,145958,2,1315,0)="""RTN"",""ORWDXA"",152,0)"
^XMB(3.9,145958,2,1316,0)=" S VAL=$O(^ORD(100.03,""S"",""REQ"",0))"
^XMB(3.9,145958,2,1317,0)="""RTN"",""ORWDXA"",153,0)"
^XMB(3.9,145958,2,1318,0)=" Q"
^XMB(3.9,145958,2,1319,0)="""RTN"",""ORWDXA"",154,0)"
^XMB(3.9,145958,2,1320,0)="COMPLETE(REC,ORID,ESCODE) ; Complete order (generic)"
^XMB(3.9,145958,2,1321,0)="""RTN"",""ORWDXA"",155,0)"
^XMB(3.9,145958,2,1322,0)=" ; validate ESCode"
^XMB(3.9,145958,2,1323,0)="""RTN"",""ORWDXA"",156,0)"
^XMB(3.9,145958,2,1324,0)=" D COMP^ORCSAVE2(ORID)"
^XMB(3.9,145958,2,1325,0)="""RTN"",""ORWDXA"",157,0)"
^XMB(3.9,145958,2,1326,0)=" D COMP^ORMBLDOR(ORID)"
^XMB(3.9,145958,2,1327,0)="""RTN"",""ORWDXA"",158,0)"
^XMB(3.9,145958,2,1328,0)=" D GETBYIFN^ORWORR(.REC,ORID)"
^XMB(3.9,145958,2,1329,0)="""RTN"",""ORWDXA"",159,0)"
^XMB(3.9,145958,2,1330,0)=" D COMPLETE^ORUTL5(ORID)"
^XMB(3.9,145958,2,1331,0)="""RTN"",""ORWDXA"",160,0)"
^XMB(3.9,145958,2,1332,0)=" Q"
^XMB(3.9,145958,2,1333,0)="""RTN"",""ORWDXA"",161,0)"
^XMB(3.9,145958,2,1334,0)="VERIFY(REC,ORID,ESCODE,ORVER) ; Verify order"
^XMB(3.9,145958,2,1335,0)="""RTN"",""ORWDXA"",162,0)"
^XMB(3.9,145958,2,1336,0)=" ; validate ESCode"
^XMB(3.9,145958,2,1337,0)="""RTN"",""ORWDXA"",163,0)"
^XMB(3.9,145958,2,1338,0)=" S ORVER=$G(ORVER,$S($D(^XUSEC(""ORELSE"",DUZ)):""N"",$D(^XUSEC(""OREMAS"",DUZ)):""C"",1:U))"
^XMB(3.9,145958,2,1339,0)="""RTN"",""ORWDXA"",164,0)"
^XMB(3.9,145958,2,1340,0)=" I ORVER'=U D"
^XMB(3.9,145958,2,1341,0)="""RTN"",""ORWDXA"",165,0)"
^XMB(3.9,145958,2,1342,0)=" . N ORIFN,ORES,ORI"
^XMB(3.9,145958,2,1343,0)="""RTN"",""ORWDXA"",166,0)"
^XMB(3.9,145958,2,1344,0)=" . ; VERIFY any replaced orders:"
^XMB(3.9,145958,2,1345,0)="""RTN"",""ORWDXA"",167,0)"
^XMB(3.9,145958,2,1346,0)=" . S ORIFN=ORID,ORES(ORIFN)="""" D REPLCD^ORCACT1"
^XMB(3.9,145958,2,1347,0)="""RTN"",""ORWDXA"",168,0)"
^XMB(3.9,145958,2,1348,0)=" . S ORI="""" F  S ORI=$O(ORES(ORI)) Q:ORI=""""  D EN^ORCSEND(ORI,""VR"","""",""""),UNLK1^ORX2(+ORI):ORI'=ORID ;ORID locked prior"
^XMB(3.9,145958,2,1349,0)="""RTN"",""ORWDXA"",169,0)"
^XMB(3.9,145958,2,1350,0)=" D GETBYIFN^ORWORR(.REC,ORID)"
^XMB(3.9,145958,2,1351,0)="""RTN"",""ORWDXA"",170,0)"
^XMB(3.9,145958,2,1352,0)=" Q"
^XMB(3.9,145958,2,1353,0)="""RTN"",""ORWDXA"",171,0)"
^XMB(3.9,145958,2,1354,0)="ALERT(DUMMY,ORID,ORDUZ) ; alert user (ORDUZ) when order (ORID) resulted"
^XMB(3.9,145958,2,1355,0)="""RTN"",""ORWDXA"",172,0)"
^XMB(3.9,145958,2,1356,0)=" ;if no user passed, use ordering provider:"
^XMB(3.9,145958,2,1357,0)="""RTN"",""ORWDXA"",173,0)"
^XMB(3.9,145958,2,1358,0)=" I $G(ORDUZ)<1 S ORDUZ=+$$ORDERER^ORQOR2(+ORID)"
^XMB(3.9,145958,2,1359,0)="""RTN"",""ORWDXA"",174,0)"
^XMB(3.9,145958,2,1360,0)=" I $L($G(ORDUZ))<1 S ORDUZ=DUZ"
^XMB(3.9,145958,2,1361,0)="""RTN"",""ORWDXA"",175,0)"
^XMB(3.9,145958,2,1362,0)=" S DUMMY=1,DA=+ORID,DR=""35///`""_(+ORDUZ),DIE=""^OR(100,"" D ^DIE"
^XMB(3.9,145958,2,1363,0)="""RTN"",""ORWDXA"",176,0)"
^XMB(3.9,145958,2,1364,0)=" Q"
^XMB(3.9,145958,2,1365,0)="""RTN"",""ORWDXA"",177,0)"
^XMB(3.9,145958,2,1366,0)="FLAG(REC,ORIFN,OREASON,ORNP,OREXP,ORLIST) ; Flag order ;p539"
^XMB(3.9,145958,2,1367,0)="""RTN"",""ORWDXA"",178,0)"
^XMB(3.9,145958,2,1368,0)=" ;variable XMZ is not defined by this section, but passed in (if available)"
^XMB(3.9,145958,2,1369,0)="""RTN"",""ORWDXA"",179,0)"
^XMB(3.9,145958,2,1370,0)=" ; need to look at re-ordering this so we don't have to process the ORNP array multiple times"
^XMB(3.9,145958,2,1371,0)="""RTN"",""ORWDXA"",180,0)"
^XMB(3.9,145958,2,1372,0)=" N ORB,ORVP,DA,ORPS,ORNOW,ORFH"
^XMB(3.9,145958,2,1373,0)="""RTN"",""ORWDXA"",181,0)"
^XMB(3.9,145958,2,1374,0)=" N ORFIENS,ORFDA,FDAIEN,ERR,ORUSR,USR,I,IEN"
^XMB(3.9,145958,2,1375,0)="""RTN"",""ORWDXA"",182,0)"
^XMB(3.9,145958,2,1376,0)=" S ORNOW=$$NOW^XLFDT"
^XMB(3.9,145958,2,1377,0)="""RTN"",""ORWDXA"",183,0)"
^XMB(3.9,145958,2,1378,0)=" D BULLETIN"
^XMB(3.9,145958,2,1379,0)="""RTN"",""ORWDXA"",184,0)"
^XMB(3.9,145958,2,1380,0)=" S DA=$P(ORIFN,"";"",2),ORVP=+$P(^OR(100,+ORIFN,0),U,2)"
^XMB(3.9,145958,2,1381,0)="""RTN"",""ORWDXA"",185,0)"
^XMB(3.9,145958,2,1382,0)=" D FLGHST^ORWDXA1(.ORFH,ORIFN)"
^XMB(3.9,145958,2,1383,0)="""RTN"",""ORWDXA"",186,0)"
^XMB(3.9,145958,2,1384,0)=" I $D(ORFH) D SAVFLG(ORIFN,.ORFH)"
^XMB(3.9,145958,2,1385,0)="""RTN"",""ORWDXA"",187,0)"
^XMB(3.9,145958,2,1386,0)=" K ^OR(100,+ORIFN,8,DA,3) S ^(3)=""1^""_$G(XMZ)_U_+$E($$NOW^XLFDT,1,12)_U_DUZ_U_OREASON_$S($G(ORNP):""^^^^""_+ORNP,1:"""")"
^XMB(3.9,145958,2,1387,0)="""RTN"",""ORWDXA"",188,0)"
^XMB(3.9,145958,2,1388,0)=" K ^OR(100,+ORIFN,8,DA,6),^OR(100,+ORIFN,8,DA,9)"
^XMB(3.9,145958,2,1389,0)="""RTN"",""ORWDXA"",189,0)"
^XMB(3.9,145958,2,1390,0)=" I $G(OREXP)'="""" D"
^XMB(3.9,145958,2,1391,0)="""RTN"",""ORWDXA"",190,0)"
^XMB(3.9,145958,2,1392,0)=" . S ORFDA(100.008,DA_"",""_+ORIFN_"","",44)=OREXP"
^XMB(3.9,145958,2,1393,0)="""RTN"",""ORWDXA"",191,0)"
^XMB(3.9,145958,2,1394,0)=" . D UPDATE^DIE("""",""ORFDA"")"
^XMB(3.9,145958,2,1395,0)="""RTN"",""ORWDXA"",192,0)"
^XMB(3.9,145958,2,1396,0)=" . D SCHALRT^ORWDXA1(ORVP,ORIFN,OREXP)"
^XMB(3.9,145958,2,1397,0)="""RTN"",""ORWDXA"",193,0)"
^XMB(3.9,145958,2,1398,0)=" S I=0 F  S I=$O(ORLIST(I)) Q:'I  S USR=+ORLIST(I) I USR S ORUSR(USR)="""""
^XMB(3.9,145958,2,1399,0)="""RTN"",""ORWDXA"",194,0)"
^XMB(3.9,145958,2,1400,0)=" S ORFIENS=""?+1""_"",""_DA_"",""_+ORIFN_"","",IEN=0"
^XMB(3.9,145958,2,1401,0)="""RTN"",""ORWDXA"",195,0)"
^XMB(3.9,145958,2,1402,0)=" F  S IEN=$O(ORUSR(IEN)) Q:'IEN  D"
^XMB(3.9,145958,2,1403,0)="""RTN"",""ORWDXA"",196,0)"
^XMB(3.9,145958,2,1404,0)=" . S ORFDA(100.842,ORFIENS,.01)=IEN"
^XMB(3.9,145958,2,1405,0)="""RTN"",""ORWDXA"",197,0)"
^XMB(3.9,145958,2,1406,0)=" . S ORFDA(100.842,ORFIENS,1)=ORNOW"
^XMB(3.9,145958,2,1407,0)="""RTN"",""ORWDXA"",198,0)"
^XMB(3.9,145958,2,1408,0)=" . S ORFDA(100.842,ORFIENS,2)=DUZ"
^XMB(3.9,145958,2,1409,0)="""RTN"",""ORWDXA"",199,0)"
^XMB(3.9,145958,2,1410,0)=" . D UPDATE^DIE("""",""ORFDA"")"
^XMB(3.9,145958,2,1411,0)="""RTN"",""ORWDXA"",200,0)"
^XMB(3.9,145958,2,1412,0)=" D KILL^XM,MSG^ORCFLAG(ORIFN)"
^XMB(3.9,145958,2,1413,0)="""RTN"",""ORWDXA"",201,0)"
^XMB(3.9,145958,2,1414,0)=" S $P(^OR(100,+ORIFN,3),U)=ORNOW ; Last Activity"
^XMB(3.9,145958,2,1415,0)="""RTN"",""ORWDXA"",202,0)"
^XMB(3.9,145958,2,1416,0)=" I '$D(ORUSR),$G(ORNP)="""" S ORNP=+$P($G(^OR(100,+ORIFN,8,DA,0)),U,3)"
^XMB(3.9,145958,2,1417,0)="""RTN"",""ORWDXA"",203,0)"
^XMB(3.9,145958,2,1418,0)=" S USR=$S($G(ORNP):ORNP,1:$O(ORUSR(""""))) I USR'="""" S ORB=+ORVP_U_+ORIFN_U_USR_""^1"" D EN^OCXOERR(ORB) ; notification"
^XMB(3.9,145958,2,1419,0)="""RTN"",""ORWDXA"",204,0)"
^XMB(3.9,145958,2,1420,0)=" D GETBYIFN^ORWORR(.REC,ORIFN)"
^XMB(3.9,145958,2,1421,0)="""RTN"",""ORWDXA"",205,0)"
^XMB(3.9,145958,2,1422,0)=" Q"
^XMB(3.9,145958,2,1423,0)="""RTN"",""ORWDXA"",206,0)"
^XMB(3.9,145958,2,1424,0)="BULLETIN ; flagged order bulletin"
^XMB(3.9,145958,2,1425,0)="""RTN"",""ORWDXA"",207,0)"
^XMB(3.9,145958,2,1426,0)=" ;variables OREASON and ORIFN are assumed to be defined by the calling process and"
^XMB(3.9,145958,2,1427,0)="""RTN"",""ORWDXA"",208,0)"
^XMB(3.9,145958,2,1428,0)=" ;are neither KILLed or NEWed in this section"
^XMB(3.9,145958,2,1429,0)="""RTN"",""ORWDXA"",209,0)"
^XMB(3.9,145958,2,1430,0)=" N OR0,OR3,ORDTXT,XMB,XMY,XMDUZ,ORENT,BULL,ORSRV,ORUSR"
^XMB(3.9,145958,2,1431,0)="""RTN"",""ORWDXA"",210,0)"
^XMB(3.9,145958,2,1432,0)=" S OR0=$G(^OR(100,+ORIFN,0)),OR3=$G(^(3))"
^XMB(3.9,145958,2,1433,0)="""RTN"",""ORWDXA"",211,0)"
^XMB(3.9,145958,2,1434,0)=" ;CLA - 3/21/96:"
^XMB(3.9,145958,2,1435,0)="""RTN"",""ORWDXA"",212,0)"
^XMB(3.9,145958,2,1436,0)=" S ORUSR=+$P(OR0,U,4)"
^XMB(3.9,145958,2,1437,0)="""RTN"",""ORWDXA"",213,0)"
^XMB(3.9,145958,2,1438,0)=" S ORSRV=$G(^VA(200,ORUSR,5)) I +ORSRV>0 S ORSRV=$P(ORSRV,U)"
^XMB(3.9,145958,2,1439,0)="""RTN"",""ORWDXA"",214,0)"
^XMB(3.9,145958,2,1440,0)=" S ORENT=""USR.`""_ORUSR_""^SRV.`""_$G(ORSRV)_""^DIV^SYS^PKG"""
^XMB(3.9,145958,2,1441,0)="""RTN"",""ORWDXA"",215,0)"
^XMB(3.9,145958,2,1442,0)=" S BULL=$$GET^XPAR(ORENT,""ORB FLAGGED ORDERS BULLETIN"",1,""Q"")"
^XMB(3.9,145958,2,1443,0)="""RTN"",""ORWDXA"",216,0)"
^XMB(3.9,145958,2,1444,0)=" Q:$G(BULL)'=""Y""   ;quit if parm val not 'Y'es"
^XMB(3.9,145958,2,1445,0)="""RTN"",""ORWDXA"",217,0)"
^XMB(3.9,145958,2,1446,0)=" ;"
^XMB(3.9,145958,2,1447,0)="""RTN"",""ORWDXA"",218,0)"
^XMB(3.9,145958,2,1448,0)=" S XMB=""OR FLAGGED ORDER"",XMDUZ=DUZ,XMY(+$P(OR0,U,4))="""""
^XMB(3.9,145958,2,1449,0)="""RTN"",""ORWDXA"",219,0)"
^XMB(3.9,145958,2,1450,0)=" S XMB(1)=$P(^DPT(+$P(OR0,U,2),0),U),XMB(2)=$P(^(0),U,9),XMB(3)="""" ;sb AGE"
^XMB(3.9,145958,2,1451,0)="""RTN"",""ORWDXA"",220,0)"
^XMB(3.9,145958,2,1452,0)=" S XMB(4)=$$FMTE^XLFDT($P(OR0,U,7))"
^XMB(3.9,145958,2,1453,0)="""RTN"",""ORWDXA"",221,0)"
^XMB(3.9,145958,2,1454,0)=" D TEXT^ORQ12(.ORDTXT,+ORIFN,80)"
^XMB(3.9,145958,2,1455,0)="""RTN"",""ORWDXA"",222,0)"
^XMB(3.9,145958,2,1456,0)=" S XMB(5)=$G(ORDTXT(1)),XMB(6)=$G(ORDTXT(2)),XMB(7)=$G(ORDTXT(3))"
^XMB(3.9,145958,2,1457,0)="""RTN"",""ORWDXA"",223,0)"
^XMB(3.9,145958,2,1458,0)=" S XMB(8)=$$FMTE^XLFDT($P(OR0,U,8)),XMB(9)=$$FMTE^XLFDT($P(OR0,U,9)),XMB(10)=OREASON"
^XMB(3.9,145958,2,1459,0)="""RTN"",""ORWDXA"",224,0)"
^XMB(3.9,145958,2,1460,0)=" S XMB(11)=$P($G(^ORD(100.01,+$P(OR3,U,3),0)),U)"
^XMB(3.9,145958,2,1461,0)="""RTN"",""ORWDXA"",225,0)"
^XMB(3.9,145958,2,1462,0)=" D EN^XMB"
^XMB(3.9,145958,2,1463,0)="""RTN"",""ORWDXA"",226,0)"
^XMB(3.9,145958,2,1464,0)=" Q"
^XMB(3.9,145958,2,1465,0)="""RTN"",""ORWDXA"",227,0)"
^XMB(3.9,145958,2,1466,0)="UNFLAG(REC,ORIFN,OREASON) ; Unflag order ;p539"
^XMB(3.9,145958,2,1467,0)="""RTN"",""ORWDXA"",228,0)"
^XMB(3.9,145958,2,1468,0)=" N DA,ORB,ORNP,ORVP,ORPS,ORNOW,ORUSR,I,IEN,USR,ORFB"
^XMB(3.9,145958,2,1469,0)="""RTN"",""ORWDXA"",229,0)"
^XMB(3.9,145958,2,1470,0)=" S ORNOW=$$NOW^XLFDT"
^XMB(3.9,145958,2,1471,0)="""RTN"",""ORWDXA"",230,0)"
^XMB(3.9,145958,2,1472,0)=" S DA=$P(ORIFN,"";"",2),ORVP=+$P(^OR(100,+ORIFN,0),U,2)"
^XMB(3.9,145958,2,1473,0)="""RTN"",""ORWDXA"",231,0)"
^XMB(3.9,145958,2,1474,0)=" S $P(^OR(100,+ORIFN,8,DA,3),U)=0,$P(^(3),U,6,8)=+$E($$NOW^XLFDT,1,12)_U_DUZ_U_OREASON D MSG^ORCFLAG(ORIFN)"
^XMB(3.9,145958,2,1475,0)="""RTN"",""ORWDXA"",232,0)"
^XMB(3.9,145958,2,1476,0)=" S $P(^OR(100,+ORIFN,3),U)=ORNOW  ; Last Activity"
^XMB(3.9,145958,2,1477,0)="""RTN"",""ORWDXA"",233,0)"
^XMB(3.9,145958,2,1478,0)=" ; provider and flagged by user"
^XMB(3.9,145958,2,1479,0)="""RTN"",""ORWDXA"",234,0)"
^XMB(3.9,145958,2,1480,0)=" S ORNP=+$P($G(^OR(100,+ORIFN,8,+$P(ORIFN,"";"",2),0)),U,3)"
^XMB(3.9,145958,2,1481,0)="""RTN"",""ORWDXA"",235,0)"
^XMB(3.9,145958,2,1482,0)=" S ORB=+ORVP_U_+ORIFN_U_ORNP_""^0"" D EN^OCXOERR(ORB) ; notification"
^XMB(3.9,145958,2,1483,0)="""RTN"",""ORWDXA"",236,0)"
^XMB(3.9,145958,2,1484,0)=" D GETBYIFN^ORWORR(.REC,ORIFN)"
^XMB(3.9,145958,2,1485,0)="""RTN"",""ORWDXA"",237,0)"
^XMB(3.9,145958,2,1486,0)=" D CHOREXP^ORWDXA1(+ORIFN)  ;check if entry in file #100.97 needs to be deleted"
^XMB(3.9,145958,2,1487,0)="""RTN"",""ORWDXA"",238,0)"
^XMB(3.9,145958,2,1488,0)=" Q"
^XMB(3.9,145958,2,1489,0)="""RTN"",""ORWDXA"",239,0)"
^XMB(3.9,145958,2,1490,0)="FLAGTXT(LST,ORID) ; flag reason"
^XMB(3.9,145958,2,1491,0)="""RTN"",""ORWDXA"",240,0)"
^XMB(3.9,145958,2,1492,0)=" N FLAG,CNT,I,ORUSR,ORCOM,F"
^XMB(3.9,145958,2,1493,0)="""RTN"",""ORWDXA"",241,0)"
^XMB(3.9,145958,2,1494,0)=" S FLAG=$G(^OR(100,+ORID,8,$P(ORID,"";"",2),3))"
^XMB(3.9,145958,2,1495,0)="""RTN"",""ORWDXA"",242,0)"
^XMB(3.9,145958,2,1496,0)=" S LST(1)=""FLAGGED: ""_$$FMTE^XLFDT($P(FLAG,U,3))_"" by ""_$P($G(^VA(200,+$P(FLAG,U,4),0)),U)"
^XMB(3.9,145958,2,1497,0)="""RTN"",""ORWDXA"",243,0)"
^XMB(3.9,145958,2,1498,0)=" S LST(2)=$P(FLAG,U,5) ; reason"
^XMB(3.9,145958,2,1499,0)="""RTN"",""ORWDXA"",244,0)"
^XMB(3.9,145958,2,1500,0)=" S CNT=2"
^XMB(3.9,145958,2,1501,0)="""RTN"",""ORWDXA"",245,0)"
^XMB(3.9,145958,2,1502,0)=" I $P(FLAG,U,10)'="""" S CNT=CNT+1,LST(CNT)=""NO ACTION ALERT: ""_$$FMTE^XLFDT($P(FLAG,U,10))"
^XMB(3.9,145958,2,1503,0)="""RTN"",""ORWDXA"",246,0)"
^XMB(3.9,145958,2,1504,0)=" D FLAGRCPT^ORWDXA1(.ORUSR,ORID) ; recipients ;p539"
^XMB(3.9,145958,2,1505,0)="""RTN"",""ORWDXA"",247,0)"
^XMB(3.9,145958,2,1506,0)=" S (I,F)=0"
^XMB(3.9,145958,2,1507,0)="""RTN"",""ORWDXA"",248,0)"
^XMB(3.9,145958,2,1508,0)=" F  S I=$O(ORUSR(I)) Q:'I  I +ORUSR(I) D"
^XMB(3.9,145958,2,1509,0)="""RTN"",""ORWDXA"",249,0)"
^XMB(3.9,145958,2,1510,0)=" . S CNT=CNT+1,LST(CNT)=$S('F:""RECIPIENTS:""_$C(9),1:$C(9)_$C(9))_$P(ORUSR(I),U,2),F=1"
^XMB(3.9,145958,2,1511,0)="""RTN"",""ORWDXA"",250,0)"
^XMB(3.9,145958,2,1512,0)=" D FLGCOM^ORWDXA1(.ORCOM,ORID) ; comments ;p539"
^XMB(3.9,145958,2,1513,0)="""RTN"",""ORWDXA"",251,0)"
^XMB(3.9,145958,2,1514,0)=" S (I,F)=0"
^XMB(3.9,145958,2,1515,0)="""RTN"",""ORWDXA"",252,0)"
^XMB(3.9,145958,2,1516,0)=" F  S I=$O(ORCOM(I)) Q:'I  I ORCOM(I)=""<COMMENT>"" S I=$O(ORCOM(I)) D"
^XMB(3.9,145958,2,1517,0)="""RTN"",""ORWDXA"",253,0)"
^XMB(3.9,145958,2,1518,0)=" . S CNT=CNT+1,LST(CNT)=$S('F:""COMMENTS:""_$C(9),1:$C(9)_$C(9))_$P($P(ORCOM(I),U,2),"";"",2)_"" on ""_$P($P(ORCOM(I),U),"";"",2),F=1"
^XMB(3.9,145958,2,1519,0)="""RTN"",""ORWDXA"",254,0)"
^XMB(3.9,145958,2,1520,0)=" . F  S I=$O(ORCOM(I)) Q:ORCOM(I)=""</COMMENT>""  D"
^XMB(3.9,145958,2,1521,0)="""RTN"",""ORWDXA"",255,0)"
^XMB(3.9,145958,2,1522,0)=" . . S CNT=CNT+1,LST(CNT)=$C(9)_ORCOM(I)"
^XMB(3.9,145958,2,1523,0)="""RTN"",""ORWDXA"",256,0)"
^XMB(3.9,145958,2,1524,0)=" Q"
^XMB(3.9,145958,2,1525,0)="""RTN"",""ORWDXA"",257,0)"
^XMB(3.9,145958,2,1526,0)="WCGET(LST,ORID) ; ward comments"
^XMB(3.9,145958,2,1527,0)="""RTN"",""ORWDXA"",258,0)"
^XMB(3.9,145958,2,1528,0)=" N I,ORIFN,ACT S ORIFN=+ORID,ACT=+$P(ORID,"";"",2)"
^XMB(3.9,145958,2,1529,0)="""RTN"",""ORWDXA"",259,0)"
^XMB(3.9,145958,2,1530,0)=" S I=0 F  S I=$O(^OR(100,ORIFN,8,ACT,5,I)) Q:'I  S LST(I)=$G(^(I,0))"
^XMB(3.9,145958,2,1531,0)="""RTN"",""ORWDXA"",260,0)"
^XMB(3.9,145958,2,1532,0)=" Q"
^XMB(3.9,145958,2,1533,0)="""RTN"",""ORWDXA"",261,0)"
^XMB(3.9,145958,2,1534,0)="WCPUT(ERR,ORID,WCLST) ; Set ward comments"
^XMB(3.9,145958,2,1535,0)="""RTN"",""ORWDXA"",262,0)"
^XMB(3.9,145958,2,1536,0)=" N DIERR,ERRLST,ORIFN,ACT S ORIFN=+ORID,ACT=+$P(ORID,"";"",2)"
^XMB(3.9,145958,2,1537,0)="""RTN"",""ORWDXA"",263,0)"
^XMB(3.9,145958,2,1538,0)=" D WP^DIE(100.008,ACT_"",""_ORIFN_"","",50,"""",""WCLST"",""ERRLST"")"
^XMB(3.9,145958,2,1539,0)="""RTN"",""ORWDXA"",264,0)"
^XMB(3.9,145958,2,1540,0)=" S ERR="""" I $D(DIERR) S ERR=""An error occurred while saving comments."""
^XMB(3.9,145958,2,1541,0)="""RTN"",""ORWDXA"",265,0)"
^XMB(3.9,145958,2,1542,0)=" Q"
^XMB(3.9,145958,2,1543,0)="""RTN"",""ORWDXA"",266,0)"
^XMB(3.9,145958,2,1544,0)="OFCPLX(ORY,ORID,PRTORDER) ; is ORID child of PRTORDER"
^XMB(3.9,145958,2,1545,0)="""RTN"",""ORWDXA"",267,0)"
^XMB(3.9,145958,2,1546,0)=" N NUMCHDS,NOWID,NOWVAL,X3,ORDA,ISNOW"
^XMB(3.9,145958,2,1547,0)="""RTN"",""ORWDXA"",268,0)"
^XMB(3.9,145958,2,1548,0)=" Q:'$D(^OR(100,+ORID,0))"
^XMB(3.9,145958,2,1549,0)="""RTN"",""ORWDXA"",269,0)"
^XMB(3.9,145958,2,1550,0)=" S ISNOW=0"
^XMB(3.9,145958,2,1551,0)="""RTN"",""ORWDXA"",270,0)"
^XMB(3.9,145958,2,1552,0)=" D ISNOW^ORWDXR(.ISNOW,+ORID)"
^XMB(3.9,145958,2,1553,0)="""RTN"",""ORWDXA"",271,0)"
^XMB(3.9,145958,2,1554,0)=" Q:ISNOW"
^XMB(3.9,145958,2,1555,0)="""RTN"",""ORWDXA"",272,0)"
^XMB(3.9,145958,2,1556,0)=" N PKG"
^XMB(3.9,145958,2,1557,0)="""RTN"",""ORWDXA"",273,0)"
^XMB(3.9,145958,2,1558,0)=" S PKG=$P($G(^OR(100,+ORID,0)),U,14)"
^XMB(3.9,145958,2,1559,0)="""RTN"",""ORWDXA"",274,0)"
^XMB(3.9,145958,2,1560,0)=" S PKG=$$NMSP^ORCD(PKG)"
