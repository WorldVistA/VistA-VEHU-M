^XMB(3.9,145980,2,3783,0)="""RTN"",""SDES2CANCELAPPT2"",48,0)"
^XMB(3.9,145980,2,3784,0)=" I $$GET1^DIQ(409.84,PARAMS(""APPT IEN""),.05,""I"")'=PARAMS(""DFN"") D ERRLOG^SDES2JSON(.SDERRORS,194) Q 0"
^XMB(3.9,145980,2,3785,0)="""RTN"",""SDES2CANCELAPPT2"",49,0)"
^XMB(3.9,145980,2,3786,0)=" ; Order Lock Check"
