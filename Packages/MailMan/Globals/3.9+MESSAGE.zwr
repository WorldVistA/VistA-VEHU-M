^XMB(3.9,145946,2,5402,0)="HDR ; Build the list header."
^XMB(3.9,145946,2,5403,0)="""RTN"",""IBCNSU21"",61,0)"
^XMB(3.9,145946,2,5404,0)=" N IBCNS0,IBCNS11,IBCNS13,IBLEAD,X,XX,X1,X2"
^XMB(3.9,145946,2,5405,0)="""RTN"",""IBCNSU21"",62,0)"
