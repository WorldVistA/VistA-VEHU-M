^XMB(3.9,145946,2,1115,0)="""RTN"",""IBCMDT1"",1,0)"
^XMB(3.9,145946,2,1116,0)="IBCMDT1 ;ALB/VD - INSURANCE PLANS MISSING DATA REPORT (DRIVER 1) ; 10-APR-15"
^XMB(3.9,145946,2,1117,0)="""RTN"",""IBCMDT1"",2,0)"
^XMB(3.9,145946,2,1118,0)=" ;;2.0;INTEGRATED BILLING ;**549**; 10-APR-15;Build 0"
