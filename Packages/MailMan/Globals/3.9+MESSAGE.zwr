^XMB(3.9,145984,2,2102,0)=" S CRERXIEN=$O(^PS(52.49,""B"",$P(ERXHID,""^"",3),0))"
^XMB(3.9,145984,2,2103,0)="""RTN"",""PSOERXI1"",203,0)"
^XMB(3.9,145984,2,2104,0)=" S ORGERXIEN=$P($G(^PS(52.49,CRERXIEN,0)),""^"",14)"
