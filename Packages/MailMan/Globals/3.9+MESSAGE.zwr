^XMB(3.9,145952,2,2730,0)=" Q"
^XMB(3.9,145952,2,2731,0)="""RTN"",""SDESAPPTDATA"",219,0)"
^XMB(3.9,145952,2,2732,0)="GETPATCOMMENTS(APPTDATA,IEN) ;"
