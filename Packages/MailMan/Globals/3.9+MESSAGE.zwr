^XMB(3.9,145946,2,711,0)="""RTN"",""IBCMDT"",34,0)"
^XMB(3.9,145946,2,712,0)=" ; IBMDTSPC(""IBBIN"") 0 = ignore Missing BIN (Banking Identification Number) filter."
^XMB(3.9,145946,2,713,0)="""RTN"",""IBCMDT"",35,0)"
