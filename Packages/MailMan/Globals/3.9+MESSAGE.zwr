^XMB(3.9,145980,2,5469,0)="""RTN"",""SDES2CRTCLNAVAL2"",1,0)"
^XMB(3.9,145980,2,5470,0)="SDES2CRTCLNAVAL2 ;ALB/BLB,JDJ/BLB,JDJ,AGW,JDJ - SDES2 SET CLINIC AVAILABILITY ;MAR 25, 2026"
^XMB(3.9,145980,2,5471,0)="""RTN"",""SDES2CRTCLNAVAL2"",2,0)"
^XMB(3.9,145980,2,5472,0)=" ;;5.3;Scheduling;**904,914,919,920,922,909,941**;Aug 13, 1993;Build 0"
