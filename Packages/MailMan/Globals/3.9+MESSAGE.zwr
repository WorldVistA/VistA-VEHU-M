^XMB(3.9,145946,2,6196,0)=" ;"
^XMB(3.9,145946,2,6197,0)="""RTN"",""IBCOPP"",71,0)"
^XMB(3.9,145946,2,6198,0)=" ; IB*2.0*549 - Inactive/Active/Both Insurance Company Plan look-up filter"
^XMB(3.9,145946,2,6199,0)="""RTN"",""IBCOPP"",72,0)"
