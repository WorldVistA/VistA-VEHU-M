^XMB(3.9,145946,2,686,0)=" ;"
^XMB(3.9,145946,2,687,0)="""RTN"",""IBCMDT"",22,0)"
^XMB(3.9,145946,2,688,0)=" ; IBMDTSPC(""IBPTY"") 0 = ignore Missing Type of Plan filter."
^XMB(3.9,145946,2,689,0)="""RTN"",""IBCMDT"",23,0)"
^XMB(3.9,145946,2,690,0)=" ;                   1 = include Missing Type of Plan filter."
^XMB(3.9,145946,2,691,0)="""RTN"",""IBCMDT"",24,0)"
^XMB(3.9,145946,2,692,0)=" ;"
^XMB(3.9,145946,2,693,0)="""RTN"",""IBCMDT"",25,0)"
^XMB(3.9,145946,2,694,0)=" ; IBMDTSPC(""IBTFT"") 0 = ignore Missing Timely Filing Time Frame filter."
^XMB(3.9,145946,2,695,0)="""RTN"",""IBCMDT"",26,0)"
^XMB(3.9,145946,2,696,0)=" ;                   1 = include Missing Timely Filing Time Frame filter."
^XMB(3.9,145946,2,697,0)="""RTN"",""IBCMDT"",27,0)"
