^XMB(3.9,145958,2,1044,0)=" ;"
^XMB(3.9,145958,2,1045,0)="""RTN"",""ORWDXA"",17,0)"
^XMB(3.9,145958,2,1046,0)="VALID(VAL,ORID,ACTION,ORNP,ORWNAT) ; Is action valid for order?"
^XMB(3.9,145958,2,1047,0)="""RTN"",""ORWDXA"",18,0)"
^XMB(3.9,145958,2,1048,0)=" N DG,ORACT,ORVP,ORVER,ORIFN,PRTID S VAL="""",PRTID=0"
^XMB(3.9,145958,2,1049,0)="""RTN"",""ORWDXA"",19,0)"
^XMB(3.9,145958,2,1050,0)=" I +ORID=0 S VAL=""This order has been deleted."" Q"
^XMB(3.9,145958,2,1051,0)="""RTN"",""ORWDXA"",20,0)"
^XMB(3.9,145958,2,1052,0)=" I '$D(^OR(100,+ORID,0)) S VAL=""This order has been deleted!"" Q"
^XMB(3.9,145958,2,1053,0)="""RTN"",""ORWDXA"",21,0)"
^XMB(3.9,145958,2,1054,0)=" I ACTION=""XFR"",'$L($T(XFR^ORCACT01)) S ACTION=""RW"" ; for pre-POE"
^XMB(3.9,145958,2,1055,0)="""RTN"",""ORWDXA"",22,0)"
^XMB(3.9,145958,2,1056,0)=" N ORNSS S ORNSS=1"
^XMB(3.9,145958,2,1057,0)="""RTN"",""ORWDXA"",23,0)"
^XMB(3.9,145958,2,1058,0)=" I (ACTION=""RN"") D VALSCH^ORWNSS(.ORNSS,ORID)"
^XMB(3.9,145958,2,1059,0)="""RTN"",""ORWDXA"",24,0)"
^XMB(3.9,145958,2,1060,0)=" I ORNSS=0 S VAL=""This order contains an invalid administration schedule."" Q"
^XMB(3.9,145958,2,1061,0)="""RTN"",""ORWDXA"",25,0)"
^XMB(3.9,145958,2,1062,0)=" I (ACTION=""RN"") D ISVALIV^ORWDPS33(.VAL,ORID,ACTION) I $L(VAL)>0 Q"
^XMB(3.9,145958,2,1063,0)="""RTN"",""ORWDXA"",26,0)"
^XMB(3.9,145958,2,1064,0)=" S ORIFN=ORID,ORVP=$P(^OR(100,+ORID,0),U,2)  ; ORCACT0 expects"
^XMB(3.9,145958,2,1065,0)="""RTN"",""ORWDXA"",27,0)"
^XMB(3.9,145958,2,1066,0)=" I (ACTION=""RN"") D  Q:$L(VAL)"
^XMB(3.9,145958,2,1067,0)="""RTN"",""ORWDXA"",28,0)"
^XMB(3.9,145958,2,1068,0)=" . N DLG S DLG=$P(^OR(100,+ORID,0),U,5) Q:DLG'["";ORD(101.41,"""
^XMB(3.9,145958,2,1069,0)="""RTN"",""ORWDXA"",29,0)"
^XMB(3.9,145958,2,1070,0)=" . I $G(^ORD(101.41,+DLG,3))'[""PROVIDER^ORCDPSIV"" Q"
^XMB(3.9,145958,2,1071,0)="""RTN"",""ORWDXA"",30,0)"
^XMB(3.9,145958,2,1072,0)=" . D AUTH^ORWDPS32(.VAL,ORNP,+DLG)"
^XMB(3.9,145958,2,1073,0)="""RTN"",""ORWDXA"",31,0)"
^XMB(3.9,145958,2,1074,0)=" . I VAL S VAL=$P(VAL,U,2)"
^XMB(3.9,145958,2,1075,0)="""RTN"",""ORWDXA"",32,0)"
^XMB(3.9,145958,2,1076,0)=" . E  S VAL="""""
^XMB(3.9,145958,2,1077,0)="""RTN"",""ORWDXA"",33,0)"
^XMB(3.9,145958,2,1078,0)=" S ORVER=$S(ACTION=""CR"":""R"",$D(^XUSEC(""ORELSE"",DUZ)):""N"",$D(^XUSEC(""OREMAS"",DUZ)):""C"",1:""^"")"
^XMB(3.9,145958,2,1079,0)="""RTN"",""ORWDXA"",34,0)"
^XMB(3.9,145958,2,1080,0)=" I ACTION=""CR"" S ACTION=""VR"""
^XMB(3.9,145958,2,1081,0)="""RTN"",""ORWDXA"",35,0)"
^XMB(3.9,145958,2,1082,0)=" I (ACTION=""ES"")!(ACTION=""OC"")!(ACTION=""RS"") S ORACT=ACTION ; why not defined???"
^XMB(3.9,145958,2,1083,0)="""RTN"",""ORWDXA"",36,0)"
^XMB(3.9,145958,2,1084,0)=" I (ACTION=""VR""),'($D(^XUSEC(""ORELSE"",DUZ))!$D(^XUSEC(""OREMAS"",DUZ))) D  Q"
^XMB(3.9,145958,2,1085,0)="""RTN"",""ORWDXA"",37,0)"
^XMB(3.9,145958,2,1086,0)=" . S VAL=""You are not authorized to verify these orders."""
^XMB(3.9,145958,2,1087,0)="""RTN"",""ORWDXA"",38,0)"
^XMB(3.9,145958,2,1088,0)=" I $L(VAL) Q"
^XMB(3.9,145958,2,1089,0)="""RTN"",""ORWDXA"",39,0)"
^XMB(3.9,145958,2,1090,0)=" N OIIEN,ISIV,IVOD"
^XMB(3.9,145958,2,1091,0)="""RTN"",""ORWDXA"",40,0)"
^XMB(3.9,145958,2,1092,0)=" S (ISIV,OIIEN,IVOD)=0"
^XMB(3.9,145958,2,1093,0)="""RTN"",""ORWDXA"",41,0)"
^XMB(3.9,145958,2,1094,0)=" I (ACTION=""RW"")!(ACTION=""XX"")!(ACTION=""XFR"") D  Q:$L(VAL)"
^XMB(3.9,145958,2,1095,0)="""RTN"",""ORWDXA"",42,0)"
^XMB(3.9,145958,2,1096,0)=" . S ISIV=$P(^OR(100,+ORID,0),U,11)"
^XMB(3.9,145958,2,1097,0)="""RTN"",""ORWDXA"",43,0)"
^XMB(3.9,145958,2,1098,0)=" . I ISIV,($P(^ORD(100.98,ISIV,0),U,3)=""IV RX"") S IVOD=1"
^XMB(3.9,145958,2,1099,0)="""RTN"",""ORWDXA"",44,0)"
^XMB(3.9,145958,2,1100,0)=" . D:'IVOD GTORITM^ORWDXR(.OIIEN,+ORID)"
^XMB(3.9,145958,2,1101,0)="""RTN"",""ORWDXA"",45,0)"
^XMB(3.9,145958,2,1102,0)=" . D:OIIEN ISACTOI(.VAL,OIIEN) I $L(VAL)>0 Q"
^XMB(3.9,145958,2,1103,0)="""RTN"",""ORWDXA"",46,0)"
^XMB(3.9,145958,2,1104,0)=" . N DLG,FRM,A,ORDG,I,TYPE,B"
^XMB(3.9,145958,2,1105,0)="""RTN"",""ORWDXA"",47,0)"
^XMB(3.9,145958,2,1106,0)=" . S A=^OR(100,+ORID,0),DLG=$P(A,U,5),ORDG=$P(A,""^"",11),FRM=0"
^XMB(3.9,145958,2,1107,0)="""RTN"",""ORWDXA"",48,0)"
^XMB(3.9,145958,2,1108,0)=" . I $P(DLG,"";"",2)'=""ORD(101.41,"" S DLG=0"
^XMB(3.9,145958,2,1109,0)="""RTN"",""ORWDXA"",49,0)"
^XMB(3.9,145958,2,1110,0)=" . I DLG D FORMID^ORWDXM(.FRM,+DLG)"
^XMB(3.9,145958,2,1111,0)="""RTN"",""ORWDXA"",50,0)"
^XMB(3.9,145958,2,1112,0)=" . I '(DLG&FRM) D"
^XMB(3.9,145958,2,1113,0)="""RTN"",""ORWDXA"",51,0)"
^XMB(3.9,145958,2,1114,0)=" . . S VAL=""Copy & Change are not implemented for this order that predates CPRS."""
^XMB(3.9,145958,2,1115,0)="""RTN"",""ORWDXA"",52,0)"
^XMB(3.9,145958,2,1116,0)=" . I ACTION=""XX"" D  ;PATLOC is being passed in and not defined in this routine"
^XMB(3.9,145958,2,1117,0)="""RTN"",""ORWDXA"",53,0)"
^XMB(3.9,145958,2,1118,0)=" .. F I=""UNIT DOSE MEDICATIONS"",""INPATIENT MEDICATIONS"",""IV MEDICATIONS"" S A=$O(^ORD(100.98,""B"",I,"""")) I A S A(A)="""""
^XMB(3.9,145958,2,1119,0)="""RTN"",""ORWDXA"",54,0)"
^XMB(3.9,145958,2,1120,0)=" .. S TYPE="""" I $G(PATLOC) S TYPE=$P(^SC(PATLOC,0),""^"",3)"
^XMB(3.9,145958,2,1121,0)="""RTN"",""ORWDXA"",55,0)"
^XMB(3.9,145958,2,1122,0)=" .. I $D(A(ORDG)),TYPE=""C"" S B=1 D SDAUTHCL^SDAMA203(PATLOC,.B) I B=1 S VAL=""Cannot use a Clinic Location for this change. Please check your encounter location."""
^XMB(3.9,145958,2,1123,0)="""RTN"",""ORWDXA"",56,0)"
^XMB(3.9,145958,2,1124,0)=" S DG=$P(^OR(100,+ORID,0),U,11)"
^XMB(3.9,145958,2,1125,0)="""RTN"",""ORWDXA"",57,0)"
^XMB(3.9,145958,2,1126,0)=" I DG,($P(^ORD(100.98,DG,0),U,3)=""CSDAM""),$P($G(^OR(100,+ORID,3)),U,3)=9 S VAL=""Partial Return to Clinic Orders cannot be discontinued."" Q"
^XMB(3.9,145958,2,1127,0)="""RTN"",""ORWDXA"",58,0)"
^XMB(3.9,145958,2,1128,0)=" N OREBUILD,ORSTA"
^XMB(3.9,145958,2,1129,0)="""RTN"",""ORWDXA"",59,0)"
^XMB(3.9,145958,2,1130,0)=" I $$VALID^ORCACT0(ORID,ACTION,.VAL,$G(ORWNAT)) S VAL="""" ; VAL=error"
^XMB(3.9,145958,2,1131,0)="""RTN"",""ORWDXA"",60,0)"
^XMB(3.9,145958,2,1132,0)=" I ACTION=""RN"",$$UPCTCHK(ORID) S VAL=""Cannot renew this order due to an illegal character """"^"""" in the comments or patient instructions."""
^XMB(3.9,145958,2,1133,0)="""RTN"",""ORWDXA"",61,0)"
^XMB(3.9,145958,2,1134,0)=" I ACTION=""RW"",$$UPCTCHK(ORID) S VAL=""Cannot copy this order due to an illegal character """"^"""" in the comments or patient instructions."""
^XMB(3.9,145958,2,1135,0)="""RTN"",""ORWDXA"",62,0)"
^XMB(3.9,145958,2,1136,0)=" S ORSTA=$P($G(^OR(100,+ORID,3)),U,3)  ;p405"
^XMB(3.9,145958,2,1137,0)="""RTN"",""ORWDXA"",63,0)"
^XMB(3.9,145958,2,1138,0)=" I ACTION=""PK"" D"
^XMB(3.9,145958,2,1139,0)="""RTN"",""ORWDXA"",64,0)"
^XMB(3.9,145958,2,1140,0)=" . N ORDA,ORDEA,ORDRG,ORIEN"
^XMB(3.9,145958,2,1141,0)="""RTN"",""ORWDXA"",65,0)"
^XMB(3.9,145958,2,1142,0)=" . K ^TMP($J,""ORWDXA"")"
^XMB(3.9,145958,2,1143,0)="""RTN"",""ORWDXA"",66,0)"
^XMB(3.9,145958,2,1144,0)=" . I ORSTA'=6,ORSTA'=15 S VAL=""Can only park an active order "" Q"
^XMB(3.9,145958,2,1145,0)="""RTN"",""ORWDXA"",67,0)"
^XMB(3.9,145958,2,1146,0)=" . S ORDEA="""" D  I ORDEA[""D"" S VAL=""This drug is not allowed to be parked"" Q"
^XMB(3.9,145958,2,1147,0)="""RTN"",""ORWDXA"",68,0)"
^XMB(3.9,145958,2,1148,0)=" .. S ORIEN="""",ORIEN=$O(^OR(100,+ORID,4.5,""ID"",""DRUG"",ORIEN)),ORDRG=$G(^OR(100,+ORID,4.5,+ORIEN,1)) ;NEW ARF CODE"
^XMB(3.9,145958,2,1149,0)="""RTN"",""ORWDXA"",69,0)"
^XMB(3.9,145958,2,1150,0)=" .. D ZERO^PSS50(+ORDRG,,,,,""ORWDXA"")"
^XMB(3.9,145958,2,1151,0)="""RTN"",""ORWDXA"",70,0)"
^XMB(3.9,145958,2,1152,0)=" .. S ORDEA=$G(^TMP($J,""ORWDXA"",+ORDRG,3))"
^XMB(3.9,145958,2,1153,0)="""RTN"",""ORWDXA"",71,0)"
^XMB(3.9,145958,2,1154,0)=" .. K ^TMP($J,""ORWDXA"")"
^XMB(3.9,145958,2,1155,0)="""RTN"",""ORWDXA"",72,0)"
^XMB(3.9,145958,2,1156,0)=" I ACTION=""UP"" D"
^XMB(3.9,145958,2,1157,0)="""RTN"",""ORWDXA"",73,0)"
^XMB(3.9,145958,2,1158,0)=" . I ORSTA'=6,+$$PARK^PSO52EX(+ORID)=0 S VAL=""Order is not parked """
