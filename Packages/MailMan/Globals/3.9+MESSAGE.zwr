^XMB(3.9,145946,2,1120,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,1121,0)="""RTN"",""IBCMDT1"",4,0)"
^XMB(3.9,145946,2,1122,0)=" ;"
^XMB(3.9,145946,2,1123,0)="""RTN"",""IBCMDT1"",5,0)"
^XMB(3.9,145946,2,1124,0)="SLAI ; Prompt user to select all or subset of insurance companies "
^XMB(3.9,145946,2,1125,0)="""RTN"",""IBCMDT1"",6,0)"
