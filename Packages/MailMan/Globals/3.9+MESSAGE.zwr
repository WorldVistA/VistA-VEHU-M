^XMB(3.9,145946,2,6303,0)="""RTN"",""IBCOPP"",124,0)"
^XMB(3.9,145946,2,6304,0)=" ;"
^XMB(3.9,145946,2,6305,0)="""RTN"",""IBCOPP"",125,0)"
^XMB(3.9,145946,2,6306,0)="START ; Gather plans for all selected companies."
^XMB(3.9,145946,2,6307,0)="""RTN"",""IBCOPP"",126,0)"
^XMB(3.9,145946,2,6308,0)=" ; Input: IBAI  - 0 - User selected Insurance Companies"
