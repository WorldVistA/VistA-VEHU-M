^XMB(3.9,145989,2,679,0)="""RTN"",""PSOASAP0"",197,0)"
^XMB(3.9,145989,2,680,0)=" ;"
^XMB(3.9,145989,2,681,0)="""RTN"",""PSOASAP0"",198,0)"
^XMB(3.9,145989,2,682,0)=" ; *** RX Segment (ASAP 3.0 only) ***"
^XMB(3.9,145989,2,683,0)="""RTN"",""PSOASAP0"",199,0)"
^XMB(3.9,145989,2,684,0)="RX08() ;Date Rx Written (Format: YYYYMMDD)"
