^XMB(3.9,145981,2,241,0)="""RTN"",""IBECECX1"",1,0)"
^XMB(3.9,145981,2,242,0)="IBECECX1 ;BSL/DVA - BILLING  EXTRACTION AND FILING UTILITIES FOR IN PATIENT ACCUMULATOR INTERFACE ; 16 May 2022  8:47 AM"
^XMB(3.9,145981,2,243,0)="""RTN"",""IBECECX1"",2,0)"
^XMB(3.9,145981,2,244,0)=" ;;2.0;INTEGRATED BILLING;**704,769**;21-MAR-94;Build 0"
^XMB(3.9,145981,2,245,0)="""RTN"",""IBECECX1"",3,0)"
^XMB(3.9,145981,2,246,0)=" ;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145981,2,247,0)="""RTN"",""IBECECX1"",4,0)"
^XMB(3.9,145981,2,248,0)=" ; "
^XMB(3.9,145981,2,249,0)="""RTN"",""IBECECX1"",5,0)"
^XMB(3.9,145981,2,250,0)=" ; Reference to ^DGPT(""AAD"",^DGPT( in ICR #418"
^XMB(3.9,145981,2,251,0)="""RTN"",""IBECECX1"",6,0)"
^XMB(3.9,145981,2,252,0)=" ;"
^XMB(3.9,145981,2,253,0)="""RTN"",""IBECECX1"",7,0)"
^XMB(3.9,145981,2,254,0)=" Q   ;No direct routine calls"
^XMB(3.9,145981,2,255,0)="""RTN"",""IBECECX1"",8,0)"
^XMB(3.9,145981,2,256,0)=" ;"
^XMB(3.9,145981,2,257,0)="""RTN"",""IBECECX1"",9,0)"
^XMB(3.9,145981,2,258,0)="EN(DFN) ;Retrieve existing Billing clock if present for this patient"
^XMB(3.9,145981,2,259,0)="""RTN"",""IBECECX1"",10,0)"
^XMB(3.9,145981,2,260,0)=" N IBECDT,IBECLDT,IBECFDT,IBECSTP"
^XMB(3.9,145981,2,261,0)="""RTN"",""IBECECX1"",11,0)"
^XMB(3.9,145981,2,262,0)=" S IBERR=0"
^XMB(3.9,145981,2,263,0)="""RTN"",""IBECECX1"",12,0)"
^XMB(3.9,145981,2,264,0)=" ;S IBEVFAC=+$$SITE^VASITE                             ;Event Facility"
^XMB(3.9,145981,2,265,0)="""RTN"",""IBECECX1"",13,0)"
^XMB(3.9,145981,2,266,0)=" S IBECADM=IBADMIT_.9999"
^XMB(3.9,145981,2,267,0)="""RTN"",""IBECECX1"",14,0)"
^XMB(3.9,145981,2,268,0)=" I 'DFN D NOCLOCK Q  ;bjr - No billing clock data found, set all values NULL (for now)"
^XMB(3.9,145981,2,269,0)="""RTN"",""IBECECX1"",15,0)"
^XMB(3.9,145981,2,270,0)=" ; IBIEN = IEN of billing clock"
^XMB(3.9,145981,2,271,0)="""RTN"",""IBECECX1"",16,0)"
^XMB(3.9,145981,2,272,0)=" S IBECDT=-IBECADM F  S IBECDT=$O(^IBE(351,""AIVDT"",DFN,IBECDT)) D  Q:'IBECDT  Q:$G(IBCLDT)  ;Get billing clock that was active at date/time of admission"
^XMB(3.9,145981,2,273,0)="""RTN"",""IBECECX1"",17,0)"
^XMB(3.9,145981,2,274,0)=" . I 'IBECDT D NOCLOCK Q"
^XMB(3.9,145981,2,275,0)="""RTN"",""IBECECX1"",18,0)"
^XMB(3.9,145981,2,276,0)=" . S IBIEN=$O(^IBE(351,""AIVDT"",DFN,IBECDT,"";""),-1)    ;Get billing clock IEN"
^XMB(3.9,145981,2,277,0)="""RTN"",""IBECECX1"",19,0)"
^XMB(3.9,145981,2,278,0)=" . I IBIEN<1 D NOCLOCK Q"
^XMB(3.9,145981,2,279,0)="""RTN"",""IBECECX1"",20,0)"
^XMB(3.9,145981,2,280,0)=" . S IBECLDT=$$GET1^DIQ(351,IBIEN_"","",.1,""I"") I 'IBECLDT S IBECLDT=$$FMADD^XLFDT(-IBECDT,364) ;IB*2*769 - Clock end clock start +364"
^XMB(3.9,145981,2,281,0)="""RTN"",""IBECECX1"",21,0)"
^XMB(3.9,145981,2,282,0)=" . ;S IBECLDT=$$GET1^DIQ(351,IBIEN_"","",.1,""I"") I 'IBECLDT S IBECLDT=$$CLSDT(-IBECDT)"
^XMB(3.9,145981,2,283,0)="""RTN"",""IBECECX1"",22,0)"
^XMB(3.9,145981,2,284,0)=" . I IBECLDT,(IBECLDT<IBECADM) D NOCLOCK  Q           ;Quit if billing clock closed at time of admission"
^XMB(3.9,145981,2,285,0)="""RTN"",""IBECECX1"",23,0)"
^XMB(3.9,145981,2,286,0)=" . I $P(^IBE(351,IBIEN,0),U,4)=3 D NOCLOCK  Q         ;Don't return canceled clock"
^XMB(3.9,145981,2,287,0)="""RTN"",""IBECECX1"",24,0)"
^XMB(3.9,145981,2,288,0)=" . S IBCLDT=$P(^IBE(351,IBIEN,0),U,3)                 ;Billing clock begin date"
^XMB(3.9,145981,2,289,0)="""RTN"",""IBECECX1"",25,0)"
^XMB(3.9,145981,2,290,0)=" . K IBERROR                                          ;Clear IBERROR flag if good clock found"
^XMB(3.9,145981,2,291,0)="""RTN"",""IBECECX1"",26,0)"
^XMB(3.9,145981,2,292,0)=" . S IBSTAT=$P(^IBE(351,IBIEN,0),U,4)                 ;Status"
^XMB(3.9,145981,2,293,0)="""RTN"",""IBECECX1"",27,0)"
^XMB(3.9,145981,2,294,0)=" . S IB901=$P(^IBE(351,IBIEN,0),U,5)                  ;1st QTR Billing"
^XMB(3.9,145981,2,295,0)="""RTN"",""IBECECX1"",28,0)"
