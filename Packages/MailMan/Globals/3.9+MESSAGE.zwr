^XMB(3.9,145989,2,979,0)="""RTN"",""PSOASAP0"",347,0)"
^XMB(3.9,145989,2,980,0)=" S PRE03=$P($$DEA^XUSER(0,PREIEN),""-"",2,99)"
^XMB(3.9,145989,2,981,0)="""RTN"",""PSOASAP0"",348,0)"
^XMB(3.9,145989,2,982,0)=" I $$PRE02()=$$PHA03() S PRE03=$P($$DEA^XUSER(1,PREIEN),""-"",1)"
^XMB(3.9,145989,2,983,0)="""RTN"",""PSOASAP0"",349,0)"
^XMB(3.9,145989,2,984,0)=" Q PRE03"
^XMB(3.9,145989,2,985,0)="""RTN"",""PSOASAP0"",350,0)"
^XMB(3.9,145989,2,986,0)=" ;"
^XMB(3.9,145989,2,987,0)="""RTN"",""PSOASAP0"",351,0)"
^XMB(3.9,145989,2,988,0)="PRE04() ;ASAP 3.0 : Prescriber DEA Number"
^XMB(3.9,145989,2,989,0)="""RTN"",""PSOASAP0"",352,0)"
^XMB(3.9,145989,2,990,0)=" ;       ASAP 4.0+: Prescriber State License Number (Not Used)"
^XMB(3.9,145989,2,991,0)="""RTN"",""PSOASAP0"",353,0)"
^XMB(3.9,145989,2,992,0)=" I PSOASVER'=""3.0"" Q """""
^XMB(3.9,145989,2,993,0)="""RTN"",""PSOASAP0"",354,0)"
^XMB(3.9,145989,2,994,0)=" ;"
^XMB(3.9,145989,2,995,0)="""RTN"",""PSOASAP0"",355,0)"
^XMB(3.9,145989,2,996,0)=" N PRE04"
^XMB(3.9,145989,2,997,0)="""RTN"",""PSOASAP0"",356,0)"
^XMB(3.9,145989,2,998,0)=" S PRE04=$$PRVDEA() I PRE04'="""" Q $P(PRE04,""-"",1)"
^XMB(3.9,145989,2,999,0)="""RTN"",""PSOASAP0"",357,0)"
^XMB(3.9,145989,2,1000,0)=" S PRE04=$P($$DEA^XUSER(0,PREIEN),""-"",1)"
^XMB(3.9,145989,2,1001,0)="""RTN"",""PSOASAP0"",358,0)"
^XMB(3.9,145989,2,1002,0)=" I (PRE04="""")!($P($$DEA^XUSER(0,PREIEN),""-"",2,99)'="""") S PRE04=$$PHA03()"
^XMB(3.9,145989,2,1003,0)="""RTN"",""PSOASAP0"",359,0)"
^XMB(3.9,145989,2,1004,0)=" Q PRE04"
^XMB(3.9,145989,2,1005,0)="""RTN"",""PSOASAP0"",360,0)"
^XMB(3.9,145989,2,1006,0)=" ;"
^XMB(3.9,145989,2,1007,0)="""RTN"",""PSOASAP0"",361,0)"
^XMB(3.9,145989,2,1008,0)="PRE05() ;ASAP 3.0 : Prescriber DEA Number Suffix"
^XMB(3.9,145989,2,1009,0)="""RTN"",""PSOASAP0"",362,0)"
^XMB(3.9,145989,2,1010,0)=" ;       ASAP 4.0+: Prescriber Last Name"
^XMB(3.9,145989,2,1011,0)="""RTN"",""PSOASAP0"",363,0)"
^XMB(3.9,145989,2,1012,0)=" N PRE05"
^XMB(3.9,145989,2,1013,0)="""RTN"",""PSOASAP0"",364,0)"
^XMB(3.9,145989,2,1014,0)=" I PSOASVER=""3.0"" D  Q PRE05"
^XMB(3.9,145989,2,1015,0)="""RTN"",""PSOASAP0"",365,0)"
^XMB(3.9,145989,2,1016,0)=" . S PRE05=$$PRVDEA() I PRE05'="""" S PRE05=$P(PRE05,""-"",2,99) Q"
^XMB(3.9,145989,2,1017,0)="""RTN"",""PSOASAP0"",366,0)"
^XMB(3.9,145989,2,1018,0)=" . S PRE05=$P($$DEA^XUSER(0,PREIEN),""-"",2,99)"
^XMB(3.9,145989,2,1019,0)="""RTN"",""PSOASAP0"",367,0)"
^XMB(3.9,145989,2,1020,0)=" . I $$PRE04()=$$PHA03() S PRE05=$P($$DEA^XUSER(1,PREIEN),""-"",1)"
^XMB(3.9,145989,2,1021,0)="""RTN"",""PSOASAP0"",368,0)"
^XMB(3.9,145989,2,1022,0)=" ;"
^XMB(3.9,145989,2,1023,0)="""RTN"",""PSOASAP0"",369,0)"
^XMB(3.9,145989,2,1024,0)=" Q $P($$GET1^DIQ(200,PREIEN,.01),"","",1)"
^XMB(3.9,145989,2,1025,0)="""RTN"",""PSOASAP0"",370,0)"
^XMB(3.9,145989,2,1026,0)=" ;"
^XMB(3.9,145989,2,1027,0)="""RTN"",""PSOASAP0"",371,0)"
^XMB(3.9,145989,2,1028,0)="PRE06() ;ASAP 3.0 : Prescriber State Lince Number (Not Used)"
^XMB(3.9,145989,2,1029,0)="""RTN"",""PSOASAP0"",372,0)"
^XMB(3.9,145989,2,1030,0)=" ;       ASAP 4.0+: Prescriber First Name"
^XMB(3.9,145989,2,1031,0)="""RTN"",""PSOASAP0"",373,0)"
^XMB(3.9,145989,2,1032,0)=" I PSOASVER=""3.0"" Q """""
^XMB(3.9,145989,2,1033,0)="""RTN"",""PSOASAP0"",374,0)"
^XMB(3.9,145989,2,1034,0)=" Q $P($P($$GET1^DIQ(200,PREIEN,.01),"","",2),"" "",1)"
^XMB(3.9,145989,2,1035,0)="""RTN"",""PSOASAP0"",375,0)"
^XMB(3.9,145989,2,1036,0)=" ;"
^XMB(3.9,145989,2,1037,0)="""RTN"",""PSOASAP0"",376,0)"
^XMB(3.9,145989,2,1038,0)="PRE07() ;ASAP 3.0 : Prescriber Alternate ID (Not Used)"
^XMB(3.9,145989,2,1039,0)="""RTN"",""PSOASAP0"",377,0)"
^XMB(3.9,145989,2,1040,0)=" ;       ASAP 4.0+: Prescriber Middle Name"
^XMB(3.9,145989,2,1041,0)="""RTN"",""PSOASAP0"",378,0)"
^XMB(3.9,145989,2,1042,0)=" I PSOASVER=""3.0"" Q """""
^XMB(3.9,145989,2,1043,0)="""RTN"",""PSOASAP0"",379,0)"
^XMB(3.9,145989,2,1044,0)=" Q $P($P($$GET1^DIQ(200,PREIEN,.01),"","",2),"" "",2)"
^XMB(3.9,145989,2,1045,0)="""RTN"",""PSOASAP0"",380,0)"
^XMB(3.9,145989,2,1046,0)=" ;"
^XMB(3.9,145989,2,1047,0)="""RTN"",""PSOASAP0"",381,0)"
^XMB(3.9,145989,2,1048,0)="PRE08() ;ASAP 3.0 : Prescriber's Last Name"
^XMB(3.9,145989,2,1049,0)="""RTN"",""PSOASAP0"",382,0)"
^XMB(3.9,145989,2,1050,0)=" ;       ASAP 4.0 & 4.1: N/A (up to PRE07 only)"
^XMB(3.9,145989,2,1051,0)="""RTN"",""PSOASAP0"",383,0)"
^XMB(3.9,145989,2,1052,0)=" ;       ASAP 4.2: Prescriber's Phone Number"
^XMB(3.9,145989,2,1053,0)="""RTN"",""PSOASAP0"",384,0)"
^XMB(3.9,145989,2,1054,0)=" I PSOASVER=""3.0"" Q $P($$GET1^DIQ(200,PREIEN,.01),"","",1)"
^XMB(3.9,145989,2,1055,0)="""RTN"",""PSOASAP0"",385,0)"
^XMB(3.9,145989,2,1056,0)=" I PSOASVER=""4.0""!(PSOASVER=""4.1"") Q """""
^XMB(3.9,145989,2,1057,0)="""RTN"",""PSOASAP0"",386,0)"
^XMB(3.9,145989,2,1058,0)=" N PRE08"
^XMB(3.9,145989,2,1059,0)="""RTN"",""PSOASAP0"",387,0)"
^XMB(3.9,145989,2,1060,0)=" ;Work Phone #"
^XMB(3.9,145989,2,1061,0)="""RTN"",""PSOASAP0"",388,0)"
^XMB(3.9,145989,2,1062,0)=" S PRE08=$$PHONE($$GET1^DIQ(200,PREIEN,.132)) I PRE08 Q PRE08"
^XMB(3.9,145989,2,1063,0)="""RTN"",""PSOASAP0"",389,0)"
^XMB(3.9,145989,2,1064,0)=" ;Institution Phone #"
^XMB(3.9,145989,2,1065,0)="""RTN"",""PSOASAP0"",390,0)"
^XMB(3.9,145989,2,1066,0)=" N DIV,DIVS,CONTACT,CONTACTS,INSPHONE"
^XMB(3.9,145989,2,1067,0)="""RTN"",""PSOASAP0"",391,0)"
^XMB(3.9,145989,2,1068,0)=" I $$DIV4^XUSER(.DIVS,PREIEN) D"
^XMB(3.9,145989,2,1069,0)="""RTN"",""PSOASAP0"",392,0)"
^XMB(3.9,145989,2,1070,0)=" . S DIV=0 F  S DIV=$O(DIVS(DIV)) Q:'DIV  D  I PRE08 Q"
^XMB(3.9,145989,2,1071,0)="""RTN"",""PSOASAP0"",393,0)"
^XMB(3.9,145989,2,1072,0)=" . . K CONTACTS D GETS^DIQ(4,DIV_"","",""4*"","""",""CONTACTS"") I '$D(CONTACTS) Q"
^XMB(3.9,145989,2,1073,0)="""RTN"",""PSOASAP0"",394,0)"
^XMB(3.9,145989,2,1074,0)=" . . S CONTACT="""" F  S CONTACT=$O(CONTACTS(4.03,CONTACT)) Q:(CONTACT="""")  D  I $G(INSPHONE) Q"
^XMB(3.9,145989,2,1075,0)="""RTN"",""PSOASAP0"",395,0)"
^XMB(3.9,145989,2,1076,0)=" . . . I $$PHONE(CONTACTS(4.03,CONTACT,.03))'="""" D"
^XMB(3.9,145989,2,1077,0)="""RTN"",""PSOASAP0"",396,0)"
^XMB(3.9,145989,2,1078,0)=" . . . . S INSPHONE=$$PHONE(CONTACTS(4.03,CONTACT,.03))"
^XMB(3.9,145989,2,1079,0)="""RTN"",""PSOASAP0"",397,0)"
^XMB(3.9,145989,2,1080,0)=" . . ; Default Prescriber Division"
^XMB(3.9,145989,2,1081,0)="""RTN"",""PSOASAP0"",398,0)"
^XMB(3.9,145989,2,1082,0)=" . . I +DIVS(DIV),$G(INSPHONE) S PRE08=INSPHONE Q"
^XMB(3.9,145989,2,1083,0)="""RTN"",""PSOASAP0"",399,0)"
^XMB(3.9,145989,2,1084,0)=" . . I '$O(DIVS(DIV)),'PRE08,$G(INSPHONE) S PRE08=INSPHONE"
^XMB(3.9,145989,2,1085,0)="""RTN"",""PSOASAP0"",400,0)"
^XMB(3.9,145989,2,1086,0)=" I PRE08 Q PRE08"
^XMB(3.9,145989,2,1087,0)="""RTN"",""PSOASAP0"",401,0)"
^XMB(3.9,145989,2,1088,0)=" ;Last resort: Pharmacy Phone #"
^XMB(3.9,145989,2,1089,0)="""RTN"",""PSOASAP0"",402,0)"
^XMB(3.9,145989,2,1090,0)=" Q $$PHA10()"
^XMB(3.9,145989,2,1091,0)="""RTN"",""PSOASAP0"",403,0)"
^XMB(3.9,145989,2,1092,0)=" ;"
^XMB(3.9,145989,2,1093,0)="""RTN"",""PSOASAP0"",404,0)"
^XMB(3.9,145989,2,1094,0)="PRE09() ;ASAP 3.0: Prescriber' First Name"
^XMB(3.9,145989,2,1095,0)="""RTN"",""PSOASAP0"",405,0)"
^XMB(3.9,145989,2,1096,0)=" ;       ASAP 4.2: Prescriber's DETOX Number if DETOX drug"
^XMB(3.9,145989,2,1097,0)="""RTN"",""PSOASAP0"",406,0)"
^XMB(3.9,145989,2,1098,0)=" ;  field has been decommissioned"
^XMB(3.9,145989,2,1099,0)="""RTN"",""PSOASAP0"",407,0)"
^XMB(3.9,145989,2,1100,0)=" N DTXCHK,PRDEA S (DTXCHK,PRDEA)="""""
^XMB(3.9,145989,2,1101,0)="""RTN"",""PSOASAP0"",408,0)"
^XMB(3.9,145989,2,1102,0)=" I PSOASVER=""3.0"" Q $P($P($$GET1^DIQ(200,PREIEN,.01),"","",2),"" "",1)"
^XMB(3.9,145989,2,1103,0)="""RTN"",""PSOASAP0"",409,0)"
^XMB(3.9,145989,2,1104,0)=" I PSOASVER=""4.2"" D"
^XMB(3.9,145989,2,1105,0)="""RTN"",""PSOASAP0"",410,0)"
^XMB(3.9,145989,2,1106,0)=" . S DRUGIEN=$$GET1^DIQ(52,RXIEN,6,""I"")"
^XMB(3.9,145989,2,1107,0)="""RTN"",""PSOASAP0"",411,0)"
^XMB(3.9,145989,2,1108,0)=" . S DTXCHK=$$DETOX^PSSOPKI(DRUGIEN)"
^XMB(3.9,145989,2,1109,0)="""RTN"",""PSOASAP0"",412,0)"
^XMB(3.9,145989,2,1110,0)=" . I DTXCHK S PRDEA=$$PRVDETOX^PSOUTIL(PREIEN)"
^XMB(3.9,145989,2,1111,0)="""RTN"",""PSOASAP0"",413,0)"
^XMB(3.9,145989,2,1112,0)=" Q PRDEA"
^XMB(3.9,145989,2,1113,0)="""RTN"",""PSOASAP0"",414,0)"
^XMB(3.9,145989,2,1114,0)=" ;"
^XMB(3.9,145989,2,1115,0)="""RTN"",""PSOASAP0"",415,0)"
^XMB(3.9,145989,2,1116,0)="PRE10() ;ASAP 3.0: Prescriber' Middle Name"
^XMB(3.9,145989,2,1117,0)="""RTN"",""PSOASAP0"",416,0)"
^XMB(3.9,145989,2,1118,0)=" ;  ASAP 4.2B+ : Jurisdiction or State Issuing Prescriber License Number  "
^XMB(3.9,145989,2,1119,0)="""RTN"",""PSOASAP0"",417,0)"
^XMB(3.9,145989,2,1120,0)=" I PSOASVER'=""3.0"" Q """""
^XMB(3.9,145989,2,1121,0)="""RTN"",""PSOASAP0"",418,0)"
^XMB(3.9,145989,2,1122,0)=" Q $P($P($$GET1^DIQ(200,PREIEN,.01),"","",2),"" "",2)"
^XMB(3.9,145989,2,1123,0)="""RTN"",""PSOASAP0"",419,0)"
^XMB(3.9,145989,2,1124,0)=" ;"
^XMB(3.9,145989,2,1125,0)="""RTN"",""PSOASAP0"",420,0)"
^XMB(3.9,145989,2,1126,0)=" ; *** RPH Pharmacist Information (ASAP 3.0 Only) **"
^XMB(3.9,145989,2,1127,0)="""RTN"",""PSOASAP0"",421,0)"
^XMB(3.9,145989,2,1128,0)="RPH03() ;National Provider Identification (NPI)"
^XMB(3.9,145989,2,1129,0)="""RTN"",""PSOASAP0"",422,0)"
^XMB(3.9,145989,2,1130,0)=" N RPH03"
^XMB(3.9,145989,2,1131,0)="""RTN"",""PSOASAP0"",423,0)"
^XMB(3.9,145989,2,1132,0)=" S RPH03=+$$NPI^XUSNPI(""Individual_ID"",RPHIEN,DT)"
^XMB(3.9,145989,2,1133,0)="""RTN"",""PSOASAP0"",424,0)"
^XMB(3.9,145989,2,1134,0)=" Q $S(RPH03>0:RPH03,1:"""")"
^XMB(3.9,145989,2,1135,0)="""RTN"",""PSOASAP0"",425,0)"
^XMB(3.9,145989,2,1136,0)=" ;"
^XMB(3.9,145989,2,1137,0)="""RTN"",""PSOASAP0"",426,0)"
^XMB(3.9,145989,2,1138,0)="RPH06() ;Pharmacist Last Name"
^XMB(3.9,145989,2,1139,0)="""RTN"",""PSOASAP0"",427,0)"
^XMB(3.9,145989,2,1140,0)=" Q $P($$GET1^DIQ(200,RPHIEN,.01),"","",1)"
^XMB(3.9,145989,2,1141,0)="""RTN"",""PSOASAP0"",428,0)"
^XMB(3.9,145989,2,1142,0)=" ;"
^XMB(3.9,145989,2,1143,0)="""RTN"",""PSOASAP0"",429,0)"
^XMB(3.9,145989,2,1144,0)="RPH07() ;Pharmacist First Name"
^XMB(3.9,145989,2,1145,0)="""RTN"",""PSOASAP0"",430,0)"
^XMB(3.9,145989,2,1146,0)=" Q $P($P($$GET1^DIQ(200,RPHIEN,.01),"","",2),"" "",1)"
^XMB(3.9,145989,2,1147,0)="""RTN"",""PSOASAP0"",431,0)"
^XMB(3.9,145989,2,1148,0)=" ;"
^XMB(3.9,145989,2,1149,0)="""RTN"",""PSOASAP0"",432,0)"
^XMB(3.9,145989,2,1150,0)="RPH08() ;Pharmacist Middle Name"
^XMB(3.9,145989,2,1151,0)="""RTN"",""PSOASAP0"",433,0)"
^XMB(3.9,145989,2,1152,0)=" Q $P($P($$GET1^DIQ(200,RPHIEN,.01),"","",2),"" "",2)"
^XMB(3.9,145989,2,1153,0)="""RTN"",""PSOASAP0"",434,0)"
^XMB(3.9,145989,2,1154,0)=" ;"
^XMB(3.9,145989,2,1155,0)="""RTN"",""PSOASAP0"",435,0)"
^XMB(3.9,145989,2,1156,0)="TT01() ;Transaction Control Number"
^XMB(3.9,145989,2,1157,0)="""RTN"",""PSOASAP0"",436,0)"
^XMB(3.9,145989,2,1158,0)=" ;      ASAP 3.0 : Same as TH03"
^XMB(3.9,145989,2,1159,0)="""RTN"",""PSOASAP0"",437,0)"
^XMB(3.9,145989,2,1160,0)=" ;      ASAP 4.0+: Same as TH02"
^XMB(3.9,145989,2,1161,0)="""RTN"",""PSOASAP0"",438,0)"
^XMB(3.9,145989,2,1162,0)=" I PSOASVER=""3.0"" Q $$TH03()"
^XMB(3.9,145989,2,1163,0)="""RTN"",""PSOASAP0"",439,0)"
^XMB(3.9,145989,2,1164,0)=" Q $$TH02()"
^XMB(3.9,145989,2,1165,0)="""RTN"",""PSOASAP0"",440,0)"
^XMB(3.9,145989,2,1166,0)=" ;"
^XMB(3.9,145989,2,1167,0)="""RTN"",""PSOASAP0"",441,0)"
^XMB(3.9,145989,2,1168,0)="PHONE(NUMBER) ;Returns the Phone number (numeric only - max 10 digits)"
^XMB(3.9,145989,2,1169,0)="""RTN"",""PSOASAP0"",442,0)"
^XMB(3.9,145989,2,1170,0)=" N PHONE"
^XMB(3.9,145989,2,1171,0)="""RTN"",""PSOASAP0"",443,0)"
^XMB(3.9,145989,2,1172,0)=" S PHONE=$$NUMERIC(NUMBER)"
^XMB(3.9,145989,2,1173,0)="""RTN"",""PSOASAP0"",444,0)"
^XMB(3.9,145989,2,1174,0)=" I $E(PHONE,1)=""1"" S $E(PHONE,1)="""""
^XMB(3.9,145989,2,1175,0)="""RTN"",""PSOASAP0"",445,0)"
^XMB(3.9,145989,2,1176,0)=" Q $S($L(PHONE)=10:PHONE,1:"""")"
^XMB(3.9,145989,2,1177,0)="""RTN"",""PSOASAP0"",446,0)"
^XMB(3.9,145989,2,1178,0)=" ;"
^XMB(3.9,145989,2,1179,0)="""RTN"",""PSOASAP0"",447,0)"
^XMB(3.9,145989,2,1180,0)="ADDRESS(VALUE,LINE) ;Returns Address Line1 and Line2 (max 30 characters)"
^XMB(3.9,145989,2,1181,0)="""RTN"",""PSOASAP0"",448,0)"
^XMB(3.9,145989,2,1182,0)=" N ADDRESS,I,DIWL,DIWR,X"
^XMB(3.9,145989,2,1183,0)="""RTN"",""PSOASAP0"",449,0)"
^XMB(3.9,145989,2,1184,0)=" K ^UTILITY($J,""W"") S X=$$TRIM^XLFSTR(VALUE),DIWL=1,DIWR=30 D ^DIWP"
^XMB(3.9,145989,2,1185,0)="""RTN"",""PSOASAP0"",450,0)"
