^XMB(3.9,145944,2,1755,0)="""RTN"",""IBJDF6"",103,0)"
^XMB(3.9,145944,2,1756,0)=" D ^DIR K DIR G:$D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) ENQ"
^XMB(3.9,145944,2,1757,0)="""RTN"",""IBJDF6"",104,0)"
