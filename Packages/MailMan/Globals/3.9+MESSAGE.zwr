^XMB(3.9,145986,2,605,0)="""QUES"",""XPZ2"",""??"")"
^XMB(3.9,145986,2,606,0)="^D RTN^XPDH"
^XMB(3.9,145986,2,607,0)="""QUES"",""XPZ2"",""A"")"
