^XMB(3.9,145989,2,711,0)="""RTN"",""PSOASAP0"",213,0)"
^XMB(3.9,145989,2,712,0)=" ;"
^XMB(3.9,145989,2,713,0)="""RTN"",""PSOASAP0"",214,0)"
^XMB(3.9,145989,2,714,0)=" ; *** DSP Segment ***"
^XMB(3.9,145989,2,715,0)="""RTN"",""PSOASAP0"",215,0)"
^XMB(3.9,145989,2,716,0)="DSP01() ;ASAP 3.0 : Reporting Status (""01"" - Add / ""02"" - Change / ""03"" - Delete)"
^XMB(3.9,145989,2,717,0)="""RTN"",""PSOASAP0"",216,0)"
