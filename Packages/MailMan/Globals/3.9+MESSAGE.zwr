^XMB(3.9,145984,2,1738,0)=" ; This error handling prevents delays at the eRx Hub because it always returns a result"
^XMB(3.9,145984,2,1739,0)="""RTN"",""PSOERXI1"",21,0)"
^XMB(3.9,145984,2,1740,0)=" N $ESTACK,$ETRAP S $ETRAP=""D ERROR^PSOERXI1"""
^XMB(3.9,145984,2,1741,0)="""RTN"",""PSOERXI1"",22,0)"
^XMB(3.9,145984,2,1742,0)=" S MBMSITE=$S($$GET1^DIQ(59.7,1,102,""I"")=""MBM"":1,1:0)"
^XMB(3.9,145984,2,1743,0)="""RTN"",""PSOERXI1"",23,0)"
^XMB(3.9,145984,2,1744,0)=" ; PSO,800 carry forward xlsns definition if needed for xsi:type in subsequent split message blocks."
^XMB(3.9,145984,2,1745,0)="""RTN"",""PSOERXI1"",24,0)"
^XMB(3.9,145984,2,1746,0)=" I XML[""xmlns:xsi"" S XMsgPos=$F(XML,""<Message "") I XMsgPos D"
^XMB(3.9,145984,2,1747,0)="""RTN"",""PSOERXI1"",25,0)"
^XMB(3.9,145984,2,1748,0)=" . S XMsgEnd=$F(XML,"">"",XMsgPos) I 'XMsgEnd Q"
^XMB(3.9,145984,2,1749,0)="""RTN"",""PSOERXI1"",26,0)"
^XMB(3.9,145984,2,1750,0)=" . S XMsgSav=$E(XML,XMsgPos-1,XMsgEnd-1)"
^XMB(3.9,145984,2,1751,0)="""RTN"",""PSOERXI1"",27,0)"
^XMB(3.9,145984,2,1752,0)=" . F XVAR=""XML2"",""XML3"" I (@XVAR[""<Message>"")&(@XVAR[""xsi:"") S $E(@XVAR,($F(@XVAR,""<Message>"")-1))=XMsgSav"
^XMB(3.9,145984,2,1753,0)="""RTN"",""PSOERXI1"",28,0)"
^XMB(3.9,145984,2,1754,0)=" S NPI=$P($G(DIV),U,2),CURREC=$$PARSE^PSOERXI2(.XML,.ERXVALS,NPI,.XML2,.XML3)"
^XMB(3.9,145984,2,1755,0)="""RTN"",""PSOERXI1"",29,0)"
^XMB(3.9,145984,2,1756,0)=" I $P(CURREC,U)<1 D  Q"
^XMB(3.9,145984,2,1757,0)="""RTN"",""PSOERXI1"",30,0)"
^XMB(3.9,145984,2,1758,0)=" . I $L($P(CURREC,U,2)) S RES=CURREC Q"
^XMB(3.9,145984,2,1759,0)="""RTN"",""PSOERXI1"",31,0)"
^XMB(3.9,145984,2,1760,0)=" . S RES=""0^XML received. Error creating or finding associated record in the ERX Holding queue."" Q"
^XMB(3.9,145984,2,1761,0)="""RTN"",""PSOERXI1"",32,0)"
^XMB(3.9,145984,2,1762,0)=" S EIEN=CURREC"
^XMB(3.9,145984,2,1763,0)="""RTN"",""PSOERXI1"",33,0)"
^XMB(3.9,145984,2,1764,0)=" S CURREC=CURREC_"","""
^XMB(3.9,145984,2,1765,0)="""RTN"",""PSOERXI1"",34,0)"
^XMB(3.9,145984,2,1766,0)=" ;If this is an outbound message, file the users DUZ and quit back the response. No drug, patient, or provider auto checks will occur"
^XMB(3.9,145984,2,1767,0)="""RTN"",""PSOERXI1"",35,0)"
^XMB(3.9,145984,2,1768,0)=" I $G(VADAT)]"""" D  Q"
^XMB(3.9,145984,2,1769,0)="""RTN"",""PSOERXI1"",36,0)"
^XMB(3.9,145984,2,1770,0)=" . I $P($G(VADAT),U)>1 D"
^XMB(3.9,145984,2,1771,0)="""RTN"",""PSOERXI1"",37,0)"
^XMB(3.9,145984,2,1772,0)=" . . S FDA(52.49,CURREC,51.1)=DUZ D FILE^DIE(,""FDA"") K FDA"
^XMB(3.9,145984,2,1773,0)="""RTN"",""PSOERXI1"",38,0)"
^XMB(3.9,145984,2,1774,0)=" . I $P(VADAT,U,2) D"
^XMB(3.9,145984,2,1775,0)="""RTN"",""PSOERXI1"",39,0)"
^XMB(3.9,145984,2,1776,0)=" . . S FDA(52.49,CURREC,.13)=$P(VADAT,U,2) D FILE^DIE(,""FDA"") K FDA"
^XMB(3.9,145984,2,1777,0)="""RTN"",""PSOERXI1"",40,0)"
^XMB(3.9,145984,2,1778,0)=" . S RES=""1^Erx Received."""
^XMB(3.9,145984,2,1779,0)="""RTN"",""PSOERXI1"",41,0)"
^XMB(3.9,145984,2,1780,0)=" ;Process auto-validation results. Only log positive results for now"
^XMB(3.9,145984,2,1781,0)="""RTN"",""PSOERXI1"",42,0)"
^XMB(3.9,145984,2,1782,0)=" K FDA"
^XMB(3.9,145984,2,1783,0)="""RTN"",""PSOERXI1"",43,0)"
^XMB(3.9,145984,2,1784,0)=" I $P($G(VADAT),U) S RES=""1^Message Filed."" Q"
^XMB(3.9,145984,2,1785,0)="""RTN"",""PSOERXI1"",44,0)"
^XMB(3.9,145984,2,1786,0)=" ;"
^XMB(3.9,145984,2,1787,0)="""RTN"",""PSOERXI1"",45,0)"
^XMB(3.9,145984,2,1788,0)=" ;Drug Auto-Match (Moved from Hub to VistA - P-692)"
^XMB(3.9,145984,2,1789,0)="""RTN"",""PSOERXI1"",46,0)"
^XMB(3.9,145984,2,1790,0)=" ;Attempting auto-match based on VistA Drug Suggestions (Uses the lastest one)"
^XMB(3.9,145984,2,1791,0)="""RTN"",""PSOERXI1"",47,0)"
^XMB(3.9,145984,2,1792,0)=" N DRUGHASH,MTCHDRUG"
^XMB(3.9,145984,2,1793,0)="""RTN"",""PSOERXI1"",48,0)"
^XMB(3.9,145984,2,1794,0)=" S MTCHDRUG=$$MTCHDRUG(),DRUGHASH=$$DRUGHASH^PSOERUT(+CURREC)"
^XMB(3.9,145984,2,1795,0)="""RTN"",""PSOERXI1"",49,0)"
^XMB(3.9,145984,2,1796,0)=" I MTCHDRUG,DRUGHASH D"
^XMB(3.9,145984,2,1797,0)="""RTN"",""PSOERXI1"",50,0)"
^XMB(3.9,145984,2,1798,0)=" . I $$GET1^DIQ(52.49,CURREC,.08,""I"")=""RE"",$$GET1^DIQ(52.49,CURREC,52.1,""I"")'=""R"" Q"
^XMB(3.9,145984,2,1799,0)="""RTN"",""PSOERXI1"",51,0)"
^XMB(3.9,145984,2,1800,0)=" . I $$GET1^DIQ(52.49,CURREC,.08,""I"")=""CX"",$$GET1^DIQ(52.49,CURREC,52.1,""I"")'=""A"",$$GET1^DIQ(52.49,CURREC,52.1,""I"")'=""AWC"" Q"
^XMB(3.9,145984,2,1801,0)="""RTN"",""PSOERXI1"",52,0)"
^XMB(3.9,145984,2,1802,0)=" . S ERXNDC=$TR($TR($$GET1^DIQ(52.49311,""1,""_CURREC_"","",1.1,""I""),"" ""),""-"")"
^XMB(3.9,145984,2,1803,0)="""RTN"",""PSOERXI1"",53,0)"
^XMB(3.9,145984,2,1804,0)=" . S VISTARX="""" F  S VISTARX=$O(^PS(52.49,""ADRGVRX"",DRUGHASH,VISTARX),-1) Q:'VISTARX  D  I $$GET1^DIQ(52.49,+CURREC,3.2,""I"") Q"
^XMB(3.9,145984,2,1805,0)="""RTN"",""PSOERXI1"",54,0)"
^XMB(3.9,145984,2,1806,0)=" . . S VADRUG=+$$GET1^DIQ(52,VISTARX,6,""I"") I 'VADRUG Q"
^XMB(3.9,145984,2,1807,0)="""RTN"",""PSOERXI1"",55,0)"
^XMB(3.9,145984,2,1808,0)=" . . I $$GET1^DIQ(50,VADRUG,100,""I"") D  Q"
^XMB(3.9,145984,2,1809,0)="""RTN"",""PSOERXI1"",56,0)"
^XMB(3.9,145984,2,1810,0)=" . . . K ^PS(52.49,""ADRGVRX"",DRUGHASH,VISTARX)"
^XMB(3.9,145984,2,1811,0)="""RTN"",""PSOERXI1"",57,0)"
^XMB(3.9,145984,2,1812,0)=" . . ; For pre-populating all drug fields, the incoming NDC/Name should match VistA DRUG/NDF files"
^XMB(3.9,145984,2,1813,0)="""RTN"",""PSOERXI1"",58,0)"
^XMB(3.9,145984,2,1814,0)=" . . I VADRUG'=MTCHDRUG Q"
^XMB(3.9,145984,2,1815,0)="""RTN"",""PSOERXI1"",59,0)"
^XMB(3.9,145984,2,1816,0)=" . . D SAVEDRUG^PSOERUT2(+CURREC,VISTARX)"
^XMB(3.9,145984,2,1817,0)="""RTN"",""PSOERXI1"",60,0)"
^XMB(3.9,145984,2,1818,0)=" . . I $$GET1^DIQ(52.49,+CURREC,3.2,""I"") D"
^XMB(3.9,145984,2,1819,0)="""RTN"",""PSOERXI1"",61,0)"
^XMB(3.9,145984,2,1820,0)=" . . . K DACHK S DACHK(""success"")=""true"",FDA(52.49,CURREC,1.4)=1"
^XMB(3.9,145984,2,1821,0)="""RTN"",""PSOERXI1"",62,0)"
^XMB(3.9,145984,2,1822,0)=" ;Auto-matching the Dispense Drug only"
^XMB(3.9,145984,2,1823,0)="""RTN"",""PSOERXI1"",63,0)"
^XMB(3.9,145984,2,1824,0)=" I '$$GET1^DIQ(52.49,+CURREC,3.2,""I""),+$G(MTCHDRUG) D"
^XMB(3.9,145984,2,1825,0)="""RTN"",""PSOERXI1"",64,0)"
^XMB(3.9,145984,2,1826,0)=" . K DACHK S DACHK(""success"")=""true"""
^XMB(3.9,145984,2,1827,0)="""RTN"",""PSOERXI1"",65,0)"
^XMB(3.9,145984,2,1828,0)=" .;Saving the eRx Audit Log For Auto-Matched Drug"
^XMB(3.9,145984,2,1829,0)="""RTN"",""PSOERXI1"",66,0)"
^XMB(3.9,145984,2,1830,0)=" . S NEWVAL(1)=$$GET1^DIQ(50,MTCHDRUG,.01)_"" (NDC#: ""_$$GETNDC^PSSNDCUT(MTCHDRUG)_"")"""
^XMB(3.9,145984,2,1831,0)="""RTN"",""PSOERXI1"",67,0)"
^XMB(3.9,145984,2,1832,0)=" . D AUDLOG^PSOERXUT(+CURREC,""DRUG"",$$PROXYDUZ^PSOERXUT(),.NEWVAL)"
^XMB(3.9,145984,2,1833,0)="""RTN"",""PSOERXI1"",68,0)"
^XMB(3.9,145984,2,1834,0)=" .;Setting Matched Drug and Auto Match info"
^XMB(3.9,145984,2,1835,0)="""RTN"",""PSOERXI1"",69,0)"
^XMB(3.9,145984,2,1836,0)=" . S FDA(52.49,CURREC,3.2)=MTCHDRUG"
^XMB(3.9,145984,2,1837,0)="""RTN"",""PSOERXI1"",70,0)"
^XMB(3.9,145984,2,1838,0)=" . S FDA(52.49,CURREC,44)=1"
^XMB(3.9,145984,2,1839,0)="""RTN"",""PSOERXI1"",71,0)"
^XMB(3.9,145984,2,1840,0)=" . S VAOI=$$GET1^DIQ(50,MTCHDRUG,2.1,""I"")"
^XMB(3.9,145984,2,1841,0)="""RTN"",""PSOERXI1"",72,0)"
^XMB(3.9,145984,2,1842,0)=" . S VPATINST=$$GET1^DIQ(50.7,VAOI,7,""E"")"
^XMB(3.9,145984,2,1843,0)="""RTN"",""PSOERXI1"",73,0)"
^XMB(3.9,145984,2,1844,0)=" . I $L(VPATINST) D"
^XMB(3.9,145984,2,1845,0)="""RTN"",""PSOERXI1"",74,0)"
^XMB(3.9,145984,2,1846,0)=" . . S (NEWVAL(1),FDA(52.49,CURREC,27))=VPATINST"
^XMB(3.9,145984,2,1847,0)="""RTN"",""PSOERXI1"",75,0)"
^XMB(3.9,145984,2,1848,0)=" . . D AUDLOG^PSOERXUT(+CURREC,""PATIENT INSTRUCTIONS"",$$PROXYDUZ^PSOERXUT(),.NEWVAL)"
^XMB(3.9,145984,2,1849,0)="""RTN"",""PSOERXI1"",76,0)"
^XMB(3.9,145984,2,1850,0)=" . ; Adjusting the # of refills field if over the maximum allowed"
^XMB(3.9,145984,2,1851,0)="""RTN"",""PSOERXI1"",77,0)"
^XMB(3.9,145984,2,1852,0)=" . I $$GET1^DIQ(52.49,+CURREC,20.5)>$$MAXNUMRF^PSOUTIL(MTCHDRUG,$$GET1^DIQ(52.49,+CURREC,20.2)) D"
^XMB(3.9,145984,2,1853,0)="""RTN"",""PSOERXI1"",78,0)"
^XMB(3.9,145984,2,1854,0)=" . . S FDA(52.49,+CURREC_"","",20.5)=$$MAXNUMRF^PSOUTIL(MTCHDRUG,$$GET1^DIQ(52.49,+CURREC,20.2))"
^XMB(3.9,145984,2,1855,0)="""RTN"",""PSOERXI1"",79,0)"
^XMB(3.9,145984,2,1856,0)=" ;"
^XMB(3.9,145984,2,1857,0)="""RTN"",""PSOERXI1"",80,0)"
^XMB(3.9,145984,2,1858,0)=" I $G(DACHK(""success""))'=""true"" D"
^XMB(3.9,145984,2,1859,0)="""RTN"",""PSOERXI1"",81,0)"
^XMB(3.9,145984,2,1860,0)=" . S ERRTXT=$G(DACHK(""error""))"
^XMB(3.9,145984,2,1861,0)="""RTN"",""PSOERXI1"",82,0)"
^XMB(3.9,145984,2,1862,0)=" . S ERRSEQ=$$ERRSEQ^PSOERXU1(EIEN) Q:'ERRSEQ"
^XMB(3.9,145984,2,1863,0)="""RTN"",""PSOERXI1"",83,0)"
^XMB(3.9,145984,2,1864,0)=" . D FILERR^PSOERXU1(CURREC,ERRSEQ,""D"",""E"",ERRTXT)"
^XMB(3.9,145984,2,1865,0)="""RTN"",""PSOERXI1"",84,0)"
^XMB(3.9,145984,2,1866,0)=" ;"
^XMB(3.9,145984,2,1867,0)="""RTN"",""PSOERXI1"",85,0)"
^XMB(3.9,145984,2,1868,0)=" ;Provider Auto-Match (Moved from Hub to VistA - P-692)"
^XMB(3.9,145984,2,1869,0)="""RTN"",""PSOERXI1"",86,0)"
^XMB(3.9,145984,2,1870,0)=" I $G(PRCHK(""success""))=""false"" D"
^XMB(3.9,145984,2,1871,0)="""RTN"",""PSOERXI1"",87,0)"
^XMB(3.9,145984,2,1872,0)=" . N TMP,MSGTYPE,MTCHPROV,TMP,NPI,DEA,CS"
^XMB(3.9,145984,2,1873,0)="""RTN"",""PSOERXI1"",88,0)"
^XMB(3.9,145984,2,1874,0)=" . S MSGTYPE=$O(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,"""")) I MSGTYPE="""" Q"
^XMB(3.9,145984,2,1875,0)="""RTN"",""PSOERXI1"",89,0)"
^XMB(3.9,145984,2,1876,0)=" . S DEA=$G(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,""Prescriber"",0,""NonVeterinarian"",0,""Identification"",0,""DEANumber"",0))"
^XMB(3.9,145984,2,1877,0)="""RTN"",""PSOERXI1"",90,0)"
^XMB(3.9,145984,2,1878,0)=" . S NPI=$G(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,""Prescriber"",0,""NonVeterinarian"",0,""Identification"",0,""NPI"",0))"
^XMB(3.9,145984,2,1879,0)="""RTN"",""PSOERXI1"",91,0)"
^XMB(3.9,145984,2,1880,0)=" . S CS=($G(^TMP($J,""PSOERXO1"",""Message"",0,""Header"",0,""DigitalSignature"",0,""SignatureValue"",0))'="""")"
^XMB(3.9,145984,2,1881,0)="""RTN"",""PSOERXI1"",92,0)"
^XMB(3.9,145984,2,1882,0)=" . D PRVMTCH^PSOERXA0(.MTCHPROV,NPI,DEA,CS)"
^XMB(3.9,145984,2,1883,0)="""RTN"",""PSOERXI1"",93,0)"
^XMB(3.9,145984,2,1884,0)=" . I +$G(MTCHPROV) D"
^XMB(3.9,145984,2,1885,0)="""RTN"",""PSOERXI1"",94,0)"
^XMB(3.9,145984,2,1886,0)=" . . K PRCHK S PRCHK(""success"")=""true"",PRCHK(""IEN"")=+MTCHPROV"
^XMB(3.9,145984,2,1887,0)="""RTN"",""PSOERXI1"",95,0)"
^XMB(3.9,145984,2,1888,0)=" ;Attempting auto-match based on VistA Provider Suggestions (Uses the lastest one)"
^XMB(3.9,145984,2,1889,0)="""RTN"",""PSOERXI1"",96,0)"
^XMB(3.9,145984,2,1890,0)=" I '$G(PRCHK(""IEN"")) D"
^XMB(3.9,145984,2,1891,0)="""RTN"",""PSOERXI1"",97,0)"
^XMB(3.9,145984,2,1892,0)=" . N EPRV,VPRV,SUGVPRV,MTCHDT S EPRV=+$$GET1^DIQ(52.49,+CURREC,2.1,""I""),(VPRV,SUGVPRV,MTCHDT)=0"
^XMB(3.9,145984,2,1893,0)="""RTN"",""PSOERXI1"",98,0)"
^XMB(3.9,145984,2,1894,0)=" . F  S VPRV=$O(^PS(52.49,""APRVVPRV"",EPRV,VPRV)) Q:'VPRV  D"
^XMB(3.9,145984,2,1895,0)="""RTN"",""PSOERXI1"",99,0)"
^XMB(3.9,145984,2,1896,0)=" . . I $$GET1^DIQ(200,VPRV,53.4,""I"") K ^PS(52.49,""APRVVPRV"",EPRV,VPRV) Q   ; VistA Provider is Inactive"
^XMB(3.9,145984,2,1897,0)="""RTN"",""PSOERXI1"",100,0)"
^XMB(3.9,145984,2,1898,0)=" . . I $O(^PS(52.49,""APRVVPRV"",EPRV,VPRV,""""),-1)>MTCHDT D"
^XMB(3.9,145984,2,1899,0)="""RTN"",""PSOERXI1"",101,0)"
^XMB(3.9,145984,2,1900,0)=" . . . S SUGVPRV=VPRV,MTCHDT=$O(^PS(52.49,""APRVVPRV"",EPRV,VPRV,""""),-1)"
^XMB(3.9,145984,2,1901,0)="""RTN"",""PSOERXI1"",102,0)"
^XMB(3.9,145984,2,1902,0)=" . I SUGVPRV D"
^XMB(3.9,145984,2,1903,0)="""RTN"",""PSOERXI1"",103,0)"
^XMB(3.9,145984,2,1904,0)=" . . K PRCHK S PRCHK(""success"")=""true"",FDA(52.49,CURREC,1.2)=1,(FDA(52.49,CURREC,2.3),PRCHK(""IEN""))=SUGVPRV"
^XMB(3.9,145984,2,1905,0)="""RTN"",""PSOERXI1"",104,0)"
^XMB(3.9,145984,2,1906,0)=" ;Auto-Validating Provider"
^XMB(3.9,145984,2,1907,0)="""RTN"",""PSOERXI1"",105,0)"
^XMB(3.9,145984,2,1908,0)=" S PRVAUTOV=0"
^XMB(3.9,145984,2,1909,0)="""RTN"",""PSOERXI1"",106,0)"
^XMB(3.9,145984,2,1910,0)=" I $G(PRCHK(""success""))=""true"",$G(PRCHK(""IEN"")) D"
^XMB(3.9,145984,2,1911,0)="""RTN"",""PSOERXI1"",107,0)"
^XMB(3.9,145984,2,1912,0)=" . S FDA(52.49,CURREC,1.2)=1"
^XMB(3.9,145984,2,1913,0)="""RTN"",""PSOERXI1"",108,0)"
^XMB(3.9,145984,2,1914,0)=" . S FDA(52.49,CURREC,2.3)=PRCHK(""IEN"")"
^XMB(3.9,145984,2,1915,0)="""RTN"",""PSOERXI1"",109,0)"
^XMB(3.9,145984,2,1916,0)=" . ;Auto-Validating Provider if auto-match was successful"
^XMB(3.9,145984,2,1917,0)="""RTN"",""PSOERXI1"",110,0)"
^XMB(3.9,145984,2,1918,0)=" . ;Condition: Non-CS eRx only & Last name, first letter of first name and zip code 5 digits must match"
^XMB(3.9,145984,2,1919,0)="""RTN"",""PSOERXI1"",111,0)"
^XMB(3.9,145984,2,1920,0)=" . N EPRVIEN,EPRVNAM,EPRVZC,EPRVDEA,VPRVIEN,VPRVNAM,VPRVZC"
