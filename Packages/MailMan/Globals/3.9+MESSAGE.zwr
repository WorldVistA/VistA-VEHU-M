^XMB(3.9,145937,2,330,0)=" ;  INST:   Instrument name in MH TESTS AND SURVEYS file (#601.71)"
^XMB(3.9,145937,2,331,0)="""RTN"",""YTQRQAD6"",10,0)"
^XMB(3.9,145937,2,332,0)=" ;  INSTIEN: IEN to instrument in MH TESTS AND SURVEYS file (#601.71)"
^XMB(3.9,145937,2,333,0)="""RTN"",""YTQRQAD6"",11,0)"
^XMB(3.9,145937,2,334,0)=" ;  HRR:    High Risk Requirement"
^XMB(3.9,145937,2,335,0)="""RTN"",""YTQRQAD6"",12,0)"
^XMB(3.9,145937,2,336,0)=" ;             # score greater than #"
^XMB(3.9,145937,2,337,0)="""RTN"",""YTQRQAD6"",13,0)"
^XMB(3.9,145937,2,338,0)=" ;            A# any question with a score >#"
^XMB(3.9,145937,2,339,0)="""RTN"",""YTQRQAD6"",14,0)"
^XMB(3.9,145937,2,340,0)=" ;            I9 Positive I9 question"
^XMB(3.9,145937,2,341,0)="""RTN"",""YTQRQAD6"",15,0)"
^XMB(3.9,145937,2,342,0)=" ;            Y1,2,3,n. Comma delimited list of question numbers. A yes to any is HR"
^XMB(3.9,145937,2,343,0)="""RTN"",""YTQRQAD6"",16,0)"
^XMB(3.9,145937,2,344,0)=" ;            YA Yes to any question"
^XMB(3.9,145937,2,345,0)="""RTN"",""YTQRQAD6"",17,0)"
^XMB(3.9,145937,2,346,0)=" ;            G3^0,5^1,q^n. Comma delimited list of question#^Value for question response Greater Than Value"
^XMB(3.9,145937,2,347,0)="""RTN"",""YTQRQAD6"",18,0)"
^XMB(3.9,145937,2,348,0)=" ;            T#p Can be added to any HRR parameter where # is a positive integer and"
^XMB(3.9,145937,2,349,0)="""RTN"",""YTQRQAD6"",19,0)"
^XMB(3.9,145937,2,350,0)=" ;                p is the time period M months, W weeks, D day. This will be treated as"
^XMB(3.9,145937,2,351,0)="""RTN"",""YTQRQAD6"",20,0)"
^XMB(3.9,145937,2,352,0)=" ;                the most recent administration of the instrument but only if the "
^XMB(3.9,145937,2,353,0)="""RTN"",""YTQRQAD6"",21,0)"
^XMB(3.9,145937,2,354,0)=" ;                  Ex: ""Y,1,2,3,T6M"" indicates Yes to Q 1,2, or 3 within the last 6"
^XMB(3.9,145937,2,355,0)="""RTN"",""YTQRQAD6"",22,0)"
^XMB(3.9,145937,2,356,0)=" ;                      months."
^XMB(3.9,145937,2,357,0)="""RTN"",""YTQRQAD6"",23,0)"
^XMB(3.9,145937,2,358,0)=" ;                  Ex: ""Y,1,2,3,T6M-I9"" is the same as the previous example except that"
^XMB(3.9,145937,2,359,0)="""RTN"",""YTQRQAD6"",24,0)"
^XMB(3.9,145937,2,360,0)=" ;                      a positive I9, without regard to time frame, triggers High Risk."
^XMB(3.9,145937,2,361,0)="""RTN"",""YTQRQAD6"",25,0)"
^XMB(3.9,145937,2,362,0)=" ;           HRR parameters can be combined by adding ""-"" between them indicating an ""or"""
^XMB(3.9,145937,2,363,0)="""RTN"",""YTQRQAD6"",26,0)"
^XMB(3.9,145937,2,364,0)=" ;               such as ""Y,3,4,5,8-I9"""
^XMB(3.9,145937,2,365,0)="""RTN"",""YTQRQAD6"",27,0)"
^XMB(3.9,145937,2,366,0)=" ;  PR:     Positive Response threshold, Score greater than number passed in PR. "
^XMB(3.9,145937,2,367,0)="""RTN"",""YTQRQAD6"",28,0)"
^XMB(3.9,145937,2,368,0)=" ;          Based solely on total score. Ex: 8 indicating any score greater than 8."
^XMB(3.9,145937,2,369,0)="""RTN"",""YTQRQAD6"",29,0)"
^XMB(3.9,145937,2,370,0)=" ;  YSFLAG: Will be 0 for no risk"
^XMB(3.9,145937,2,371,0)="""RTN"",""YTQRQAD6"",30,0)"
^XMB(3.9,145937,2,372,0)=" ;                  1 for Positive Response"
^XMB(3.9,145937,2,373,0)="""RTN"",""YTQRQAD6"",31,0)"
^XMB(3.9,145937,2,374,0)=" ;                  2 for High Risk"
^XMB(3.9,145937,2,375,0)="""RTN"",""YTQRQAD6"",32,0)"
^XMB(3.9,145937,2,376,0)=" ;                  3 for Both Positive response & High Risk"
^XMB(3.9,145937,2,377,0)="""RTN"",""YTQRQAD6"",33,0)"
^XMB(3.9,145937,2,378,0)=" ;          The field SUICIDE RISK (#16) in the MH ADMINISTRATION file (#601.84) will be"
^XMB(3.9,145937,2,379,0)="""RTN"",""YTQRQAD6"",34,0)"
^XMB(3.9,145937,2,380,0)=" ;          populated with the result."
^XMB(3.9,145937,2,381,0)="""RTN"",""YTQRQAD6"",35,0)"
^XMB(3.9,145937,2,382,0)=" N DATE,ADMID,YSFLAG,YS,SI,MULT,INSTIEN,YSLIM,YSCORE"
^XMB(3.9,145937,2,383,0)="""RTN"",""YTQRQAD6"",36,0)"
^XMB(3.9,145937,2,384,0)=" S SI=0"
^XMB(3.9,145937,2,385,0)="""RTN"",""YTQRQAD6"",37,0)"
^XMB(3.9,145937,2,386,0)=" I 'DFN D SETERROR^YTQRUTL(404,""Not Found: No patient passed. Cannot continue."") Q"
^XMB(3.9,145937,2,387,0)="""RTN"",""YTQRQAD6"",38,0)"
^XMB(3.9,145937,2,388,0)=" I INST="""" D SETERROR^YTQRUTL(404,""Not Found: No instrument passed. Cannot continue."") Q"
^XMB(3.9,145937,2,389,0)="""RTN"",""YTQRQAD6"",39,0)"
^XMB(3.9,145937,2,390,0)=" S YSFLAG=0"
^XMB(3.9,145937,2,391,0)="""RTN"",""YTQRQAD6"",40,0)"
^XMB(3.9,145937,2,392,0)=" S INSTIEN=$O(^YTT(601.71,""B"",INST,0)) Q:'$D(^PXRMINDX(601.84,""PI"",DFN,INSTIEN))"
^XMB(3.9,145937,2,393,0)="""RTN"",""YTQRQAD6"",41,0)"
^XMB(3.9,145937,2,394,0)=" S DATE="""""
^XMB(3.9,145937,2,395,0)="""RTN"",""YTQRQAD6"",42,0)"
^XMB(3.9,145937,2,396,0)=" ; Get date of administration most recent to oldest"
^XMB(3.9,145937,2,397,0)="""RTN"",""YTQRQAD6"",43,0)"
^XMB(3.9,145937,2,398,0)=" F  S DATE=$O(^PXRMINDX(601.84,""PI"",DFN,INSTIEN,DATE),-1) Q:DATE=""""  D FLAG2"
^XMB(3.9,145937,2,399,0)="""RTN"",""YTQRQAD6"",44,0)"
^XMB(3.9,145937,2,400,0)=" Q"
^XMB(3.9,145937,2,401,0)="""RTN"",""YTQRQAD6"",45,0)"
^XMB(3.9,145937,2,402,0)=" ;"
^XMB(3.9,145937,2,403,0)="""RTN"",""YTQRQAD6"",46,0)"
^XMB(3.9,145937,2,404,0)="FLAG2 ;"
^XMB(3.9,145937,2,405,0)="""RTN"",""YTQRQAD6"",47,0)"
^XMB(3.9,145937,2,406,0)=" N X,YSHRT,CURFLG,AGE"
^XMB(3.9,145937,2,407,0)="""RTN"",""YTQRQAD6"",48,0)"
^XMB(3.9,145937,2,408,0)=" S ADMID=$O(^PXRMINDX(601.84,""PI"",DFN,INSTIEN,DATE,"""")) ;IEN to file 601.84"
^XMB(3.9,145937,2,409,0)="""RTN"",""YTQRQAD6"",49,0)"
^XMB(3.9,145937,2,410,0)=" ; NOTE: The ARC index is only updated for completed administrations."
^XMB(3.9,145937,2,411,0)="""RTN"",""YTQRQAD6"",50,0)"
^XMB(3.9,145937,2,412,0)=" ; A separate check for Administration COMPLETE is not necessary"
^XMB(3.9,145937,2,413,0)="""RTN"",""YTQRQAD6"",51,0)"
^XMB(3.9,145937,2,414,0)=" S CURFLG=$P(^YTT(601.84,ADMID,0),U,14)"
^XMB(3.9,145937,2,415,0)="""RTN"",""YTQRQAD6"",52,0)"
^XMB(3.9,145937,2,416,0)=" I CURFLG=0!(CURFLG=9) Q  ;Flag already set to 'none' or 'expired'"
^XMB(3.9,145937,2,417,0)="""RTN"",""YTQRQAD6"",53,0)"
^XMB(3.9,145937,2,418,0)=" ;Any PR/HR flag older than 90 days should be set to 'expired'"
^XMB(3.9,145937,2,419,0)="""RTN"",""YTQRQAD6"",54,0)"
^XMB(3.9,145937,2,420,0)=" I $$FMDIFF^XLFDT($$HTFM^XLFDT($H),DATE)>90 D  Q"
^XMB(3.9,145937,2,421,0)="""RTN"",""YTQRQAD6"",55,0)"
^XMB(3.9,145937,2,422,0)=" . S YSFLAG=9 D SETFLAG"
^XMB(3.9,145937,2,423,0)="""RTN"",""YTQRQAD6"",56,0)"
^XMB(3.9,145937,2,424,0)=" I $P(^YTT(601.84,ADMID,0),U,14)'="""" Q  ; Flag already set don't recalculate"
^XMB(3.9,145937,2,425,0)="""RTN"",""YTQRQAD6"",57,0)"
^XMB(3.9,145937,2,426,0)=" D QUEST(ADMID,INST) ; Retrieve questions and patient answers and set them into ^TMP(""YSQA"",$J,INST,CNT)"
^XMB(3.9,145937,2,427,0)="""RTN"",""YTQRQAD6"",58,0)"
^XMB(3.9,145937,2,428,0)=" D SCORES ; Get scores for assessment"
^XMB(3.9,145937,2,429,0)="""RTN"",""YTQRQAD6"",59,0)"
^XMB(3.9,145937,2,430,0)=" S YSFLAG=0"
^XMB(3.9,145937,2,431,0)="""RTN"",""YTQRQAD6"",60,0)"
^XMB(3.9,145937,2,432,0)=" I PR,YSCORE>PR S YSFLAG=1 ; Evaluate Positive response "
^XMB(3.9,145937,2,433,0)="""RTN"",""YTQRQAD6"",61,0)"
^XMB(3.9,145937,2,434,0)=" S MULT=$L(HRR,""-"") ; Parse HRR for multiples"
^XMB(3.9,145937,2,435,0)="""RTN"",""YTQRQAD6"",62,0)"
^XMB(3.9,145937,2,436,0)=" F X=1:1:MULT Q:YSFLAG>1  D"
^XMB(3.9,145937,2,437,0)="""RTN"",""YTQRQAD6"",63,0)"
^XMB(3.9,145937,2,438,0)=" . S YSLIM=14600 ; 40 Yrs"
^XMB(3.9,145937,2,439,0)="""RTN"",""YTQRQAD6"",64,0)"
^XMB(3.9,145937,2,440,0)=" . S YSHRT=$P(HRR,""-"",X)"
^XMB(3.9,145937,2,441,0)="""RTN"",""YTQRQAD6"",65,0)"
^XMB(3.9,145937,2,442,0)=" . I YSHRT[""T"" S YSLIM=$$TIME(YSHRT) ; Check for T specific parameter "
^XMB(3.9,145937,2,443,0)="""RTN"",""YTQRQAD6"",66,0)"
^XMB(3.9,145937,2,444,0)=" . I $$FMDIFF^XLFDT($$NOW^XLFDT,DATE,1)>YSLIM Q  ;Assignment too old"
^XMB(3.9,145937,2,445,0)="""RTN"",""YTQRQAD6"",67,0)"
^XMB(3.9,145937,2,446,0)=" . I YSHRT?1N.E S SI=+YSHRT D HRSCR Q:YSFLAG>1  ; Test for HR based only on Total Raw score"
^XMB(3.9,145937,2,447,0)="""RTN"",""YTQRQAD6"",68,0)"
^XMB(3.9,145937,2,448,0)=" . I YSFLAG>1 Q  ; High Risk flag already set"
^XMB(3.9,145937,2,449,0)="""RTN"",""YTQRQAD6"",69,0)"
^XMB(3.9,145937,2,450,0)=" . I $E(YSHRT,1,2)=""YA"" D YATAG"
^XMB(3.9,145937,2,451,0)="""RTN"",""YTQRQAD6"",70,0)"
^XMB(3.9,145937,2,452,0)=" . I YSFLAG>1 Q  ; High Risk flag already set"
^XMB(3.9,145937,2,453,0)="""RTN"",""YTQRQAD6"",71,0)"
^XMB(3.9,145937,2,454,0)=" . I YSHRT?1""Y"".N.E D YTAG"
^XMB(3.9,145937,2,455,0)="""RTN"",""YTQRQAD6"",72,0)"
^XMB(3.9,145937,2,456,0)=" . I YSFLAG>1 Q  ; High Risk flag already set"
^XMB(3.9,145937,2,457,0)="""RTN"",""YTQRQAD6"",73,0)"
^XMB(3.9,145937,2,458,0)=" . I $E(YSHRT,1)=""A"" D ATAG"
^XMB(3.9,145937,2,459,0)="""RTN"",""YTQRQAD6"",74,0)"
^XMB(3.9,145937,2,460,0)=" . I YSFLAG>1 Q  ; High Risk flag already set"
^XMB(3.9,145937,2,461,0)="""RTN"",""YTQRQAD6"",75,0)"
^XMB(3.9,145937,2,462,0)=" . I $E(YSHRT,1,2)=""I9"" D I9TAG ;Check for HR solely on I9 question"
^XMB(3.9,145937,2,463,0)="""RTN"",""YTQRQAD6"",76,0)"
^XMB(3.9,145937,2,464,0)=" . I YSFLAG>1 Q  ;High Risk flag already set"
^XMB(3.9,145937,2,465,0)="""RTN"",""YTQRQAD6"",77,0)"
^XMB(3.9,145937,2,466,0)=" . I $E(YSHRT,1)=""G"" D GTTAG"
^XMB(3.9,145937,2,467,0)="""RTN"",""YTQRQAD6"",78,0)"
^XMB(3.9,145937,2,468,0)=" K ^TMP(""YSQA"",$J) ; Cleanup ^TMP file"
^XMB(3.9,145937,2,469,0)="""RTN"",""YTQRQAD6"",79,0)"
^XMB(3.9,145937,2,470,0)=" D SETFLAG Q"
^XMB(3.9,145937,2,471,0)="""RTN"",""YTQRQAD6"",80,0)"
^XMB(3.9,145937,2,472,0)=" ;"
^XMB(3.9,145937,2,473,0)="""RTN"",""YTQRQAD6"",81,0)"
^XMB(3.9,145937,2,474,0)="QUEST(ADMID,INST) ; Create core code to look at questions and answers"
^XMB(3.9,145937,2,475,0)="""RTN"",""YTQRQAD6"",82,0)"
^XMB(3.9,145937,2,476,0)=" ; Requires Administration ID (ADMID) and Instrument name (INST) as an pre-existing value. "
^XMB(3.9,145937,2,477,0)="""RTN"",""YTQRQAD6"",83,0)"
^XMB(3.9,145937,2,478,0)=" N TEMP,QNUM,ANSID,QST,CHOICE,CNT,LEG,I"
^XMB(3.9,145937,2,479,0)="""RTN"",""YTQRQAD6"",84,0)"
^XMB(3.9,145937,2,480,0)=" K ^TMP(""YSQA"",$J)"
^XMB(3.9,145937,2,481,0)="""RTN"",""YTQRQAD6"",85,0)"
^XMB(3.9,145937,2,482,0)=" S (QNUM,CNT)=0"
^XMB(3.9,145937,2,483,0)="""RTN"",""YTQRQAD6"",86,0)"
^XMB(3.9,145937,2,484,0)=" F  S QNUM=$O(^YTT(601.85,""AC"",ADMID,QNUM)) Q:QNUM=""""  D"
^XMB(3.9,145937,2,485,0)="""RTN"",""YTQRQAD6"",87,0)"
^XMB(3.9,145937,2,486,0)=" . S ANSID=$O(^YTT(601.85,""AC"",ADMID,QNUM,0))"
^XMB(3.9,145937,2,487,0)="""RTN"",""YTQRQAD6"",88,0)"
^XMB(3.9,145937,2,488,0)=" . S TEMP=^YTT(601.85,ANSID,0)"
^XMB(3.9,145937,2,489,0)="""RTN"",""YTQRQAD6"",89,0)"
^XMB(3.9,145937,2,490,0)=" . S QST="""",I=0,CNT=CNT+1"
^XMB(3.9,145937,2,491,0)="""RTN"",""YTQRQAD6"",90,0)"
^XMB(3.9,145937,2,492,0)=" . F  S I=$O(^YTT(601.72,$P(TEMP,U,3),1,I)) Q:I=""""  D"
^XMB(3.9,145937,2,493,0)="""RTN"",""YTQRQAD6"",91,0)"
^XMB(3.9,145937,2,494,0)=" . . I $E(QST,$L(QST))?1A S QST=QST_"" """
^XMB(3.9,145937,2,495,0)="""RTN"",""YTQRQAD6"",92,0)"
^XMB(3.9,145937,2,496,0)=" . . S QST=QST_^YTT(601.72,$P(TEMP,U,3),1,I,0)"
^XMB(3.9,145937,2,497,0)="""RTN"",""YTQRQAD6"",93,0)"
^XMB(3.9,145937,2,498,0)=" . I $P(TEMP,U,4)=""NOT ASKED"" S CHOICE=""NOT ASKED"",LEG="""""
^XMB(3.9,145937,2,499,0)="""RTN"",""YTQRQAD6"",94,0)"
^XMB(3.9,145937,2,500,0)=" . E  S CHOICE=$S($P(TEMP,U,4)="""":"""",1:$G(^YTT(601.75,$P(TEMP,U,4),1))),LEG=$S($P(TEMP,U,4)="""":"""",1:$P($G(^YTT(601.75,$P(TEMP,U,4),0)),U,2))"
^XMB(3.9,145937,2,501,0)="""RTN"",""YTQRQAD6"",95,0)"
^XMB(3.9,145937,2,502,0)=" . I CHOICE="""" S CHOICE=""Skipped"""
^XMB(3.9,145937,2,503,0)="""RTN"",""YTQRQAD6"",96,0)"
^XMB(3.9,145937,2,504,0)=" . S:'$D(LEG) LEG="""""
^XMB(3.9,145937,2,505,0)="""RTN"",""YTQRQAD6"",97,0)"
^XMB(3.9,145937,2,506,0)=" . S ^TMP(""YSQA"",$J,INST,CNT)=QST_U_CHOICE_U_LEG"
^XMB(3.9,145937,2,507,0)="""RTN"",""YTQRQAD6"",98,0)"
^XMB(3.9,145937,2,508,0)=" Q"
^XMB(3.9,145937,2,509,0)="""RTN"",""YTQRQAD6"",99,0)"
^XMB(3.9,145937,2,510,0)=" ;"
^XMB(3.9,145937,2,511,0)="""RTN"",""YTQRQAD6"",100,0)"
^XMB(3.9,145937,2,512,0)="SCORES ;"
^XMB(3.9,145937,2,513,0)="""RTN"",""YTQRQAD6"",101,0)"
^XMB(3.9,145937,2,514,0)=" ;Get total Raw score for administration"
^XMB(3.9,145937,2,515,0)="""RTN"",""YTQRQAD6"",102,0)"
^XMB(3.9,145937,2,516,0)=" N YSDATA"
^XMB(3.9,145937,2,517,0)="""RTN"",""YTQRQAD6"",103,0)"
^XMB(3.9,145937,2,518,0)=" S YS(""AD"")=ADMID"
^XMB(3.9,145937,2,519,0)="""RTN"",""YTQRQAD6"",104,0)"
^XMB(3.9,145937,2,520,0)=" S YS(""CODE"")=INST"
^XMB(3.9,145937,2,521,0)="""RTN"",""YTQRQAD6"",105,0)"
^XMB(3.9,145937,2,522,0)=" S YS(""ADATE"")=DATE ;$P(^YTT(601.84,ADMID,0),U,3)"
^XMB(3.9,145937,2,523,0)="""RTN"",""YTQRQAD6"",106,0)"
^XMB(3.9,145937,2,524,0)=" S YS(""DFN"")=DFN"
^XMB(3.9,145937,2,525,0)="""RTN"",""YTQRQAD6"",107,0)"
^XMB(3.9,145937,2,526,0)=" K ^TMP($J,""YSCOR""),^TMP($J,""YSG"")"
^XMB(3.9,145937,2,527,0)="""RTN"",""YTQRQAD6"",108,0)"
^XMB(3.9,145937,2,528,0)=" D GETSCORE^YTQAPI8(.YSDATA,.YS)"
^XMB(3.9,145937,2,529,0)="""RTN"",""YTQRQAD6"",109,0)"
^XMB(3.9,145937,2,530,0)=" S YSCORE=$P(^TMP($J,""YSCOR"",2),""="",2)"
^XMB(3.9,145937,2,531,0)="""RTN"",""YTQRQAD6"",110,0)"
^XMB(3.9,145937,2,532,0)=" Q"
^XMB(3.9,145937,2,533,0)="""RTN"",""YTQRQAD6"",111,0)"
^XMB(3.9,145937,2,534,0)=" ;"
^XMB(3.9,145937,2,535,0)="""RTN"",""YTQRQAD6"",112,0)"
^XMB(3.9,145937,2,536,0)="TIME(TPAR) ;"
