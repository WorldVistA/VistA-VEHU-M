^XMB(3.9,145946,2,5389,0)="""RTN"",""IBCNSU21"",54,0)"
^XMB(3.9,145946,2,5390,0)=" I '$D(^TMP(""IBCNSU21"",$J)) D"
^XMB(3.9,145946,2,5391,0)="""RTN"",""IBCNSU21"",55,0)"
^XMB(3.9,145946,2,5392,0)=" . S VALMCNT=2,^TMP(""IBCNSU21"",$J,1,0)="" """
^XMB(3.9,145946,2,5393,0)="""RTN"",""IBCNSU21"",56,0)"
