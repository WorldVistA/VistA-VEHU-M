^XMB(3.9,145984,2,2110,0)=" ;get the parent reference IEN TIU Document"
^XMB(3.9,145984,2,2111,0)="""RTN"",""PSOERXI1"",207,0)"
^XMB(3.9,145984,2,2112,0)=" S PSOTIUIEN=$$GET1^DIQ(52.49,CRERXIEN,320.1)"
^XMB(3.9,145984,2,2113,0)="""RTN"",""PSOERXI1"",208,0)"
^XMB(3.9,145984,2,2114,0)=" I '$G(PSOTIUIEN) D  Q"
^XMB(3.9,145984,2,2115,0)="""RTN"",""PSOERXI1"",209,0)"
^XMB(3.9,145984,2,2116,0)=" . N TIUTITLE S TIUTITLE=""PHARMACY ERX RX CHANGE REQUEST NOTE"""
^XMB(3.9,145984,2,2117,0)="""RTN"",""PSOERXI1"",210,0)"
^XMB(3.9,145984,2,2118,0)=" . I '+$$FIND1^DIC(8925.1,"""",""X"",TIUTITLE,""B"") S TIUTITLE=""ERX RX CHANGE REQUEST NOTE"""
^XMB(3.9,145984,2,2119,0)="""RTN"",""PSOERXI1"",211,0)"
^XMB(3.9,145984,2,2120,0)=" . D BLDCRMEDS(ERXHID,+$G(MTCHDRUG),TIUTITLE)"
^XMB(3.9,145984,2,2121,0)="""RTN"",""PSOERXI1"",212,0)"
^XMB(3.9,145984,2,2122,0)=" ;"
^XMB(3.9,145984,2,2123,0)="""RTN"",""PSOERXI1"",213,0)"
^XMB(3.9,145984,2,2124,0)=" S CXTARGET=$NA(^TMP(""TIUP"",$J)) K @CXTARGET"
^XMB(3.9,145984,2,2125,0)="""RTN"",""PSOERXI1"",214,0)"
^XMB(3.9,145984,2,2126,0)=" D BUILDLST^PSOERSE4(CXTARGET,EIEN)"
^XMB(3.9,145984,2,2127,0)="""RTN"",""PSOERXI1"",215,0)"
^XMB(3.9,145984,2,2128,0)=" Q:'$D(@CXTARGET)"
^XMB(3.9,145984,2,2129,0)="""RTN"",""PSOERXI1"",216,0)"
^XMB(3.9,145984,2,2130,0)=" K ERXTIUX M ERXTIUX(""TEXT"")=@CXTARGET"
^XMB(3.9,145984,2,2131,0)="""RTN"",""PSOERXI1"",217,0)"
^XMB(3.9,145984,2,2132,0)=" D MAKEADD^TIUSRVP2(.TIUDADD,PSOTIUIEN,.ERXTIUX) ;PSOTIUIEN is the parent IEN from The TIU Document Definition name in File #8925.1"
^XMB(3.9,145984,2,2133,0)="""RTN"",""PSOERXI1"",218,0)"
^XMB(3.9,145984,2,2134,0)=" D UPDATEPN^PSOERX1H(.TIUDADD,$G(ORGERXIEN)) ;TIUDADD is the Addendum IEN"
^XMB(3.9,145984,2,2135,0)="""RTN"",""PSOERXI1"",219,0)"
^XMB(3.9,145984,2,2136,0)=" Q"
^XMB(3.9,145984,2,2137,0)="""RTN"",""PSOERXI1"",220,0)"
^XMB(3.9,145984,2,2138,0)=" ;"
^XMB(3.9,145984,2,2139,0)="""RTN"",""PSOERXI1"",221,0)"
^XMB(3.9,145984,2,2140,0)="BLDCRMEDS(ERXHID,VDRUG,TIUTITLE) ;Build eRx Change Response Medication array"
^XMB(3.9,145984,2,2141,0)="""RTN"",""PSOERXI1"",222,0)"
^XMB(3.9,145984,2,2142,0)=" ;get the original eRx"
^XMB(3.9,145984,2,2143,0)="""RTN"",""PSOERXI1"",223,0)"
^XMB(3.9,145984,2,2144,0)=" Q:$G(ERXHID)="""""
^XMB(3.9,145984,2,2145,0)="""RTN"",""PSOERXI1"",224,0)"
^XMB(3.9,145984,2,2146,0)=" N CRERXIEN,ORGERXIEN,ERXDRUG,CRMEDS"
^XMB(3.9,145984,2,2147,0)="""RTN"",""PSOERXI1"",225,0)"
^XMB(3.9,145984,2,2148,0)=" ;"
^XMB(3.9,145984,2,2149,0)="""RTN"",""PSOERXI1"",226,0)"
^XMB(3.9,145984,2,2150,0)=" S CRERXIEN=$O(^PS(52.49,""B"",$P(ERXHID,""^"",3),0))"
^XMB(3.9,145984,2,2151,0)="""RTN"",""PSOERXI1"",227,0)"
^XMB(3.9,145984,2,2152,0)=" S ORGERXIEN=$P($G(^PS(52.49,CRERXIEN,0)),""^"",14)"
^XMB(3.9,145984,2,2153,0)="""RTN"",""PSOERXI1"",228,0)"
^XMB(3.9,145984,2,2154,0)=" S ORGERXIEN=$O(^PS(52.49,""B"",ORGERXIEN,0))"
^XMB(3.9,145984,2,2155,0)="""RTN"",""PSOERXI1"",229,0)"
^XMB(3.9,145984,2,2156,0)=" S CNT=0"
^XMB(3.9,145984,2,2157,0)="""RTN"",""PSOERXI1"",230,0)"
^XMB(3.9,145984,2,2158,0)=" I $G(VDRUG) D"
^XMB(3.9,145984,2,2159,0)="""RTN"",""PSOERXI1"",231,0)"
^XMB(3.9,145984,2,2160,0)=" . S ERXDRUG=$$GET1^DIQ(50,$G(VDRUG),.01)"
^XMB(3.9,145984,2,2161,0)="""RTN"",""PSOERXI1"",232,0)"
^XMB(3.9,145984,2,2162,0)=" . S CNT=CNT+1,CRMEDS(CNT)=""^""_ERXDRUG"
^XMB(3.9,145984,2,2163,0)="""RTN"",""PSOERXI1"",233,0)"
^XMB(3.9,145984,2,2164,0)=" ;"
^XMB(3.9,145984,2,2165,0)="""RTN"",""PSOERXI1"",234,0)"
^XMB(3.9,145984,2,2166,0)=" D CREATEPN^PSOERX1H(ORGERXIEN,EIEN,,.CRMEDS,TIUTITLE) ;create eRx Change Response PN"
^XMB(3.9,145984,2,2167,0)="""RTN"",""PSOERXI1"",235,0)"
^XMB(3.9,145984,2,2168,0)=" ;"
^XMB(3.9,145984,2,2169,0)="""RTN"",""PSOERXI1"",236,0)"
^XMB(3.9,145984,2,2170,0)=" Q"
^XMB(3.9,145984,2,2171,0)="""RTN"",""PSOERXI1"",237,0)"
^XMB(3.9,145984,2,2172,0)=" ; VAL - value to resolve"
^XMB(3.9,145984,2,2173,0)="""RTN"",""PSOERXI1"",238,0)"
^XMB(3.9,145984,2,2174,0)=" ; TYPE - This is the code type, which will tell which 'C' index type to get the code from"
^XMB(3.9,145984,2,2175,0)="""RTN"",""PSOERXI1"",239,0)"
^XMB(3.9,145984,2,2176,0)="PRESOLV(VAL,TYPE) ;"
^XMB(3.9,145984,2,2177,0)="""RTN"",""PSOERXI1"",240,0)"
^XMB(3.9,145984,2,2178,0)=" N MATCH"
^XMB(3.9,145984,2,2179,0)="""RTN"",""PSOERXI1"",241,0)"
^XMB(3.9,145984,2,2180,0)=" S MATCH="""""
^XMB(3.9,145984,2,2181,0)="""RTN"",""PSOERXI1"",242,0)"
^XMB(3.9,145984,2,2182,0)=" Q:'$L(TYPE)!('$L(VAL)) """" ; avoid null subscript"
^XMB(3.9,145984,2,2183,0)="""RTN"",""PSOERXI1"",243,0)"
^XMB(3.9,145984,2,2184,0)=" S MATCH=$O(^PS(52.45,""C"",TYPE,VAL,0))"
^XMB(3.9,145984,2,2185,0)="""RTN"",""PSOERXI1"",244,0)"
^XMB(3.9,145984,2,2186,0)=" ; return the match found, null if no match"
^XMB(3.9,145984,2,2187,0)="""RTN"",""PSOERXI1"",245,0)"
^XMB(3.9,145984,2,2188,0)=" Q MATCH"
^XMB(3.9,145984,2,2189,0)="""RTN"",""PSOERXI1"",246,0)"
^XMB(3.9,145984,2,2190,0)="CONVDTTM(VAL) ;"
^XMB(3.9,145984,2,2191,0)="""RTN"",""PSOERXI1"",247,0)"
^XMB(3.9,145984,2,2192,0)=" N EDATE,ETIME,X,ETZ,Y,%DT,%"
^XMB(3.9,145984,2,2193,0)="""RTN"",""PSOERXI1"",248,0)"
^XMB(3.9,145984,2,2194,0)=" I '$L(VAL) Q """""
^XMB(3.9,145984,2,2195,0)="""RTN"",""PSOERXI1"",249,0)"
^XMB(3.9,145984,2,2196,0)=" S EDATE=$P(VAL,""T""),ETIME=$P(VAL,""T"",2)"
^XMB(3.9,145984,2,2197,0)="""RTN"",""PSOERXI1"",250,0)"
^XMB(3.9,145984,2,2198,0)=" ; split off time zone"
^XMB(3.9,145984,2,2199,0)="""RTN"",""PSOERXI1"",251,0)"
^XMB(3.9,145984,2,2200,0)=" S ETZ=$P(ETIME,""."",2)"
^XMB(3.9,145984,2,2201,0)="""RTN"",""PSOERXI1"",252,0)"
^XMB(3.9,145984,2,2202,0)=" S ETIME=$P(ETIME,""."")"
^XMB(3.9,145984,2,2203,0)="""RTN"",""PSOERXI1"",253,0)"
^XMB(3.9,145984,2,2204,0)=" S X=EDATE D ^%DT I 'Y Q """""
^XMB(3.9,145984,2,2205,0)="""RTN"",""PSOERXI1"",254,0)"
^XMB(3.9,145984,2,2206,0)=" S VAL=Y_$S($L(ETIME):"".""_$TR(ETIME,"":"",""""),1:"""")"
^XMB(3.9,145984,2,2207,0)="""RTN"",""PSOERXI1"",255,0)"
^XMB(3.9,145984,2,2208,0)=" Q VAL"
^XMB(3.9,145984,2,2209,0)="""RTN"",""PSOERXI1"",256,0)"
^XMB(3.9,145984,2,2210,0)=" ;"
^XMB(3.9,145984,2,2211,0)="""RTN"",""PSOERXI1"",257,0)"
^XMB(3.9,145984,2,2212,0)="MTCHDRUG() ; Returns the Matched Dispensed Drug based on the NDF files"
^XMB(3.9,145984,2,2213,0)="""RTN"",""PSOERXI1"",258,0)"
^XMB(3.9,145984,2,2214,0)=" ;Output: MTCHDRUG - VistA Dispense Drug associated with the Name/NDC from outside (Pointer to file #50)"
^XMB(3.9,145984,2,2215,0)="""RTN"",""PSOERXI1"",259,0)"
^XMB(3.9,145984,2,2216,0)=" N MSGTYPE,MEDSEG,MTCHDRUG,PRDCODE,PRDCOQL,DRGNAME"
^XMB(3.9,145984,2,2217,0)="""RTN"",""PSOERXI1"",260,0)"
^XMB(3.9,145984,2,2218,0)=" S MTCHDRUG=0"
^XMB(3.9,145984,2,2219,0)="""RTN"",""PSOERXI1"",261,0)"
^XMB(3.9,145984,2,2220,0)=" S MSGTYPE=$O(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,"""")) I MSGTYPE="""" Q 0"
^XMB(3.9,145984,2,2221,0)="""RTN"",""PSOERXI1"",262,0)"
^XMB(3.9,145984,2,2222,0)=" S MEDSEG=""MedicationPrescribed"""
^XMB(3.9,145984,2,2223,0)="""RTN"",""PSOERXI1"",263,0)"
^XMB(3.9,145984,2,2224,0)=" I '$D(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,MEDSEG)) D"
^XMB(3.9,145984,2,2225,0)="""RTN"",""PSOERXI1"",264,0)"
^XMB(3.9,145984,2,2226,0)=" . S MEDSEG=""MedicationResponse"""
^XMB(3.9,145984,2,2227,0)="""RTN"",""PSOERXI1"",265,0)"
^XMB(3.9,145984,2,2228,0)=" S PRDCODE=$G(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,MEDSEG,0,""DrugCoded"",0,""ProductCode"",0,""Code"",0)) I PRDCODE="""" Q 0"
^XMB(3.9,145984,2,2229,0)="""RTN"",""PSOERXI1"",266,0)"
^XMB(3.9,145984,2,2230,0)=" S PRDCOQL=$E($G(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,MEDSEG,0,""DrugCoded"",0,""ProductCode"",0,""Qualifier"",0)),1)"
^XMB(3.9,145984,2,2231,0)="""RTN"",""PSOERXI1"",267,0)"
^XMB(3.9,145984,2,2232,0)=" I PRDCOQL'=""N"",PRDCOQL'=""U"" Q 0"
^XMB(3.9,145984,2,2233,0)="""RTN"",""PSOERXI1"",268,0)"
^XMB(3.9,145984,2,2234,0)=" S DRGNAME=$G(^TMP($J,""PSOERXO1"",""Message"",0,""Body"",0,MSGTYPE,0,MEDSEG,0,""DrugDescription"",0))"
^XMB(3.9,145984,2,2235,0)="""RTN"",""PSOERXI1"",269,0)"
^XMB(3.9,145984,2,2236,0)=" D DRGMTCH^PSOERXA0(.MTCHDRUG,PRDCOQL_""^""_PRDCODE,DRGNAME)"
^XMB(3.9,145984,2,2237,0)="""RTN"",""PSOERXI1"",270,0)"
^XMB(3.9,145984,2,2238,0)=" Q +$G(MTCHDRUG)"
^XMB(3.9,145984,2,2239,0)="""RTN"",""PSOERXI1"",271,0)"
^XMB(3.9,145984,2,2240,0)=" ;"
^XMB(3.9,145984,2,2241,0)="""RTN"",""PSOERXI1"",272,0)"
^XMB(3.9,145984,2,2242,0)="ERROR ; Error Handling"
^XMB(3.9,145984,2,2243,0)="""RTN"",""PSOERXI1"",273,0)"
^XMB(3.9,145984,2,2244,0)=" D ^%ZTER"
^XMB(3.9,145984,2,2245,0)="""RTN"",""PSOERXI1"",274,0)"
^XMB(3.9,145984,2,2246,0)=" S RES=""1^eRx received but there was an error. See error trap at ""_$P($TR($$SITE^VASITE(),""^"",""-""),""-"",1,2) Q"
^XMB(3.9,145984,2,2247,0)="""RTN"",""PSOERXI1"",275,0)"
^XMB(3.9,145984,2,2248,0)=" Q"
^XMB(3.9,145984,2,2249,0)="""VER"")"
^XMB(3.9,145984,2,2250,0)="8.0^22.2"
^XMB(3.9,145984,2,2251,0)="""^DD"",52.49,52.49,25,0)"
^XMB(3.9,145984,2,2252,0)="CH MESSAGE ID^F^^25;1^K:$L(X)>35!($L(X)<3) X"
^XMB(3.9,145984,2,2253,0)="""^DD"",52.49,52.49,25,3)"
^XMB(3.9,145984,2,2254,0)="Enter the Change Healthcare message identification value. Answer must be 3-35 characters in length."
^XMB(3.9,145984,2,2255,0)="""^DD"",52.49,52.49,25,21,0)"
^XMB(3.9,145984,2,2256,0)="^^3^3^3171229^"
^XMB(3.9,145984,2,2257,0)="""^DD"",52.49,52.49,25,21,1,0)"
^XMB(3.9,145984,2,2258,0)="This is the Change Healthcare message identifier. This number is not to "
^XMB(3.9,145984,2,2259,0)="""^DD"",52.49,52.49,25,21,2,0)"
^XMB(3.9,145984,2,2260,0)="be considered to be a unique identifier. It is possible that the same "
^XMB(3.9,145984,2,2261,0)="""^DD"",52.49,52.49,25,21,3,0)"
^XMB(3.9,145984,2,2262,0)="message ID could come from more than one provider."
^XMB(3.9,145984,2,2263,0)="""^DD"",52.49,52.49,25,""DT"")"
^XMB(3.9,145984,2,2264,0)=3180117
