^XMB(3.9,145946,2,6213,0)="""RTN"",""IBCOPP"",79,0)"
^XMB(3.9,145946,2,6214,0)=" . S IBAO=$$OUT^IBCOPP1                     ; Report or CSV output"
^XMB(3.9,145946,2,6215,0)="""RTN"",""IBCOPP"",80,0)"
