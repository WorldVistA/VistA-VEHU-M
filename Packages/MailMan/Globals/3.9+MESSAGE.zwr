^XMB(3.9,145960,2,368,0)=" ;"
^XMB(3.9,145960,2,369,0)="""RTN"",""MAGGTU4T"",58,0)"
^XMB(3.9,145960,2,370,0)=" ;***** ADDS A CLIENT-SPECIFIC WARNING (IF NECESSARY)"
^XMB(3.9,145960,2,371,0)="""RTN"",""MAGGTU4T"",59,0)"
^XMB(3.9,145960,2,372,0)=" ;"
^XMB(3.9,145960,2,373,0)="""RTN"",""MAGGTU4T"",60,0)"
^XMB(3.9,145960,2,374,0)=" ; .MAGBUF       Reference to a local array that the warning text"
^XMB(3.9,145960,2,375,0)="""RTN"",""MAGGTU4T"",61,0)"
^XMB(3.9,145960,2,376,0)=" ;               is returned to. It is appended to the RPC result"
^XMB(3.9,145960,2,377,0)="""RTN"",""MAGGTU4T"",62,0)"
^XMB(3.9,145960,2,378,0)=" ;               array by the caller (WARNING^MAGGTU41)."
^XMB(3.9,145960,2,379,0)="""RTN"",""MAGGTU4T"",63,0)"
^XMB(3.9,145960,2,380,0)=" ;"
^XMB(3.9,145960,2,381,0)="""RTN"",""MAGGTU4T"",64,0)"
^XMB(3.9,145960,2,382,0)=" ; CLVER         Client application version (Major.Minor.Patch.Build)"
^XMB(3.9,145960,2,383,0)="""RTN"",""MAGGTU4T"",65,0)"
^XMB(3.9,145960,2,384,0)=" ;"
^XMB(3.9,145960,2,385,0)="""RTN"",""MAGGTU4T"",66,0)"
^XMB(3.9,145960,2,386,0)=" ; CVRC          Version check code returned by the $$CHKVER1^MAGGTU41"
^XMB(3.9,145960,2,387,0)="""RTN"",""MAGGTU4T"",67,0)"
^XMB(3.9,145960,2,388,0)=" ;"
^XMB(3.9,145960,2,389,0)="""RTN"",""MAGGTU4T"",68,0)"
^XMB(3.9,145960,2,390,0)=" ; Notes"
^XMB(3.9,145960,2,391,0)="""RTN"",""MAGGTU4T"",69,0)"
^XMB(3.9,145960,2,392,0)=" ; ====="
^XMB(3.9,145960,2,393,0)="""RTN"",""MAGGTU4T"",70,0)"
^XMB(3.9,145960,2,394,0)=" ;"
^XMB(3.9,145960,2,395,0)="""RTN"",""MAGGTU4T"",71,0)"
^XMB(3.9,145960,2,396,0)=" ; If the RPC result array already contains an error message that"
^XMB(3.9,145960,2,397,0)="""RTN"",""MAGGTU4T"",72,0)"
^XMB(3.9,145960,2,398,0)=" ; will terminate the client, application, this procedure is not"
^XMB(3.9,145960,2,399,0)="""RTN"",""MAGGTU4T"",73,0)"
^XMB(3.9,145960,2,400,0)=" ; called."
^XMB(3.9,145960,2,401,0)="""RTN"",""MAGGTU4T"",74,0)"
^XMB(3.9,145960,2,402,0)=" ;"
^XMB(3.9,145960,2,403,0)="""RTN"",""MAGGTU4T"",75,0)"
^XMB(3.9,145960,2,404,0)="WARNING(MAGBUF,CLVER,CVRC) ;"
