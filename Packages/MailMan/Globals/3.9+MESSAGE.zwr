^XMB(3.9,145944,2,196,0)="^D DTA^XPDH"
^XMB(3.9,145944,2,197,0)="""QUES"",""XPF2"",""A"")"
^XMB(3.9,145944,2,198,0)="Want my data |FLAG| yours"
^XMB(3.9,145944,2,199,0)="""QUES"",""XPF2"",""B"")"
