^XMB(3.9,145986,2,2076,0)=" S F135=F135+1 I F135>22 S F135=0,DIR(0)=""E"" W ! D ^DIR K DIR S:$D(DUOUT)!($D(DTOUT)) FBOUT=1   ; pagination"
