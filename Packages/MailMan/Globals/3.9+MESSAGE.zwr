^XMB(3.9,145983,2,2025,0)="""RTN"",""RCRPU1"",128,0)"
^XMB(3.9,145983,2,2026,0)=" F  S RCLP=$O(^RCRP(340.5,RCIEN,6,RCLP)) Q:'RCLP  D"
^XMB(3.9,145983,2,2027,0)="""RTN"",""RCRPU1"",129,0)"
^XMB(3.9,145983,2,2028,0)=" .  S RCBLIEN=+$G(^RCRP(340.5,RCIEN,6,RCLP,0))"
^XMB(3.9,145983,2,2029,0)="""RTN"",""RCRPU1"",130,0)"
^XMB(3.9,145983,2,2030,0)=" .  K DLAYGO,DD,DO,DIC,DA,X,Y"
^XMB(3.9,145983,2,2031,0)="""RTN"",""RCRPU1"",131,0)"
^XMB(3.9,145983,2,2032,0)=" .  S RCD7=$G(^PRCA(430,RCBLIEN,7)),RCTOT=0"
^XMB(3.9,145983,2,2033,0)="""RTN"",""RCRPU1"",132,0)"
^XMB(3.9,145983,2,2034,0)=" .  F RCI=1:1:5 S RCTOT=RCTOT+$P(RCD7,U,RCI)"
^XMB(3.9,145983,2,2035,0)="""RTN"",""RCRPU1"",133,0)"
^XMB(3.9,145983,2,2036,0)=" .  D TRAN^RCRPU(RCBLIEN,RCTOT,67)"
^XMB(3.9,145983,2,2037,0)="""RTN"",""RCRPU1"",134,0)"
^XMB(3.9,145983,2,2038,0)=" Q"
^XMB(3.9,145983,2,2039,0)="""RTN"",""RCRPU1"",135,0)"
^XMB(3.9,145983,2,2040,0)=" ;"
^XMB(3.9,145983,2,2041,0)="""RTN"",""RCRPU1"",136,0)"
^XMB(3.9,145983,2,2042,0)="DBTCOM(RCTRANDA,RCTXTFLG) ;Add Transaction comments"
^XMB(3.9,145983,2,2043,0)="""RTN"",""RCRPU1"",137,0)"
^XMB(3.9,145983,2,2044,0)=" ; RCDBTR   - Referance to #433 - IEN^Name"
^XMB(3.9,145983,2,2045,0)="""RTN"",""RCRPU1"",138,0)"
^XMB(3.9,145983,2,2046,0)=" ; RCTXTFLG - Comment text"
^XMB(3.9,145983,2,2047,0)="""RTN"",""RCRPU1"",139,0)"
^XMB(3.9,145983,2,2048,0)=" ;"
^XMB(3.9,145983,2,2049,0)="""RTN"",""RCRPU1"",140,0)"
^XMB(3.9,145983,2,2050,0)=" N DIC,X,Y,RCTEXT"
^XMB(3.9,145983,2,2051,0)="""RTN"",""RCRPU1"",141,0)"
^XMB(3.9,145983,2,2052,0)=" ;"
^XMB(3.9,145983,2,2053,0)="""RTN"",""RCRPU1"",142,0)"
^XMB(3.9,145983,2,2054,0)=" S RCTEXT=""Supervisor Approval Obtained for ""_$S(RCTXTFLG=1:""<$25 payment."",1:"">36 months."")"
^XMB(3.9,145983,2,2055,0)="""RTN"",""RCRPU1"",143,0)"
^XMB(3.9,145983,2,2056,0)=" S DIC=""^PRCA(433,""_+RCTRANDA_"",7,"",DIC(0)=""L"",X=RCTEXT"
^XMB(3.9,145983,2,2057,0)="""RTN"",""RCRPU1"",144,0)"
^XMB(3.9,145983,2,2058,0)=" D FILE^DICN"
^XMB(3.9,145983,2,2059,0)="""RTN"",""RCRPU1"",145,0)"
^XMB(3.9,145983,2,2060,0)=" Q"
^XMB(3.9,145983,2,2061,0)="""RTN"",""RCRPU1"",146,0)"
^XMB(3.9,145983,2,2062,0)=" ;"
^XMB(3.9,145983,2,2063,0)="""RTN"",""RCRPU1"",147,0)"
^XMB(3.9,145983,2,2064,0)="SELRPP() ; select RPP to display"
^XMB(3.9,145983,2,2065,0)="""RTN"",""RCRPU1"",148,0)"
^XMB(3.9,145983,2,2066,0)=" ;"
^XMB(3.9,145983,2,2067,0)="""RTN"",""RCRPU1"",149,0)"
^XMB(3.9,145983,2,2068,0)=" ; returns selected ien in file 340.5 or -1 for user exit / timeout"
^XMB(3.9,145983,2,2069,0)="""RTN"",""RCRPU1"",150,0)"
^XMB(3.9,145983,2,2070,0)=" ;"
^XMB(3.9,145983,2,2071,0)="""RTN"",""RCRPU1"",151,0)"
^XMB(3.9,145983,2,2072,0)=" N DIC,DTOUT,DUOUT,X,Y"
^XMB(3.9,145983,2,2073,0)="""RTN"",""RCRPU1"",152,0)"
^XMB(3.9,145983,2,2074,0)=" S X=$G(X)"
^XMB(3.9,145983,2,2075,0)="""RTN"",""RCRPU1"",153,0)"
^XMB(3.9,145983,2,2076,0)=" S DIC=340.5,DIC(0)=""AEQM"""
^XMB(3.9,145983,2,2077,0)="""RTN"",""RCRPU1"",154,0)"
^XMB(3.9,145983,2,2078,0)=" S DIC(""W"")=""W $$CJ^XLFSTR($$EXTERNAL^DILFD(340.5,.07,,$P(^RCRP(340.5,Y,0),U,7)),15),$$CJ^XLFSTR($$FMTE^XLFDT($P(^RCRP(340.5,Y,0),U,3),""""5DZ""""),12)"""
^XMB(3.9,145983,2,2079,0)="""RTN"",""RCRPU1"",155,0)"
^XMB(3.9,145983,2,2080,0)=" S DIC(""A"")=""Select Repayment Plan: """
^XMB(3.9,145983,2,2081,0)="""RTN"",""RCRPU1"",156,0)"
^XMB(3.9,145983,2,2082,0)=" D ^DIC"
^XMB(3.9,145983,2,2083,0)="""RTN"",""RCRPU1"",157,0)"
^XMB(3.9,145983,2,2084,0)=" Q $S(+Y>0:+Y,1:-1)"
^XMB(3.9,145983,2,2085,0)="""RTN"",""RCRPU1"",158,0)"
^XMB(3.9,145983,2,2086,0)=" ;"
^XMB(3.9,145983,2,2087,0)="""RTN"",""RCRPU1"",159,0)"
^XMB(3.9,145983,2,2088,0)="UPDPAY(RCIEN,RCTRAN,RCAMT) ; Update the payment information, schedule, and status."
^XMB(3.9,145983,2,2089,0)="""RTN"",""RCRPU1"",160,0)"
^XMB(3.9,145983,2,2090,0)=" ;INPUT - RCIEN  - IEN of the repayment Plan to update"
^XMB(3.9,145983,2,2091,0)="""RTN"",""RCRPU1"",161,0)"
^XMB(3.9,145983,2,2092,0)=" ;        RCTRAN - AR Transaction file (#433) IEN to store)"
^XMB(3.9,145983,2,2093,0)="""RTN"",""RCRPU1"",162,0)"
^XMB(3.9,145983,2,2094,0)=" ;        RCAMT  - (Optional) Amount paid"
^XMB(3.9,145983,2,2095,0)="""RTN"",""RCRPU1"",163,0)"
^XMB(3.9,145983,2,2096,0)=" ;"
^XMB(3.9,145983,2,2097,0)="""RTN"",""RCRPU1"",164,0)"
^XMB(3.9,145983,2,2098,0)=" ;Update the Payment Node in the Plan"
^XMB(3.9,145983,2,2099,0)="""RTN"",""RCRPU1"",165,0)"
^XMB(3.9,145983,2,2100,0)=" N DA,DD,DIC,DLAYGO,DO,DR"
^XMB(3.9,145983,2,2101,0)="""RTN"",""RCRPU1"",166,0)"
^XMB(3.9,145983,2,2102,0)=" N RCCURST,RCSTAT"
^XMB(3.9,145983,2,2103,0)="""RTN"",""RCRPU1"",167,0)"
^XMB(3.9,145983,2,2104,0)=" ;"
^XMB(3.9,145983,2,2105,0)="""RTN"",""RCRPU1"",168,0)"
^XMB(3.9,145983,2,2106,0)=" Q:$G(RCIEN)=""""  ; No RPP IEN sent it."
^XMB(3.9,145983,2,2107,0)="""RTN"",""RCRPU1"",169,0)"
^XMB(3.9,145983,2,2108,0)=" ;"
^XMB(3.9,145983,2,2109,0)="""RTN"",""RCRPU1"",170,0)"
^XMB(3.9,145983,2,2110,0)=" S DLAYGO=340.5,DA(1)=RCIEN,DIC(0)=""L"",X=$$DT^XLFDT,DIC=""^RCRP(340.5,""_DA(1)_"",3,"""
^XMB(3.9,145983,2,2111,0)="""RTN"",""RCRPU1"",171,0)"
^XMB(3.9,145983,2,2112,0)=" S DIC(""DR"")=""1///""_RCAMT_"";2///""_RCTRAN"
^XMB(3.9,145983,2,2113,0)="""RTN"",""RCRPU1"",172,0)"
^XMB(3.9,145983,2,2114,0)=" D FILE^DICN"
^XMB(3.9,145983,2,2115,0)="""RTN"",""RCRPU1"",173,0)"
^XMB(3.9,145983,2,2116,0)=" ;"
^XMB(3.9,145983,2,2117,0)="""RTN"",""RCRPU1"",174,0)"
^XMB(3.9,145983,2,2118,0)=" ;Update the Paid status in the schedule, as appropriate"
^XMB(3.9,145983,2,2119,0)="""RTN"",""RCRPU1"",175,0)"
^XMB(3.9,145983,2,2120,0)=" D UPDPAYST^RCRPU(RCIEN)"
^XMB(3.9,145983,2,2121,0)="""RTN"",""RCRPU1"",176,0)"
^XMB(3.9,145983,2,2122,0)=" ;"
^XMB(3.9,145983,2,2123,0)="""RTN"",""RCRPU1"",177,0)"
^XMB(3.9,145983,2,2124,0)=" ;Calculate a new status and update if different."
^XMB(3.9,145983,2,2125,0)="""RTN"",""RCRPU1"",178,0)"
^XMB(3.9,145983,2,2126,0)=" S RCCURST=$$GET1^DIQ(340.5,RCIEN_"","",.07,""I"")  ; PRCA*4.5*389"
^XMB(3.9,145983,2,2127,0)="""RTN"",""RCRPU1"",179,0)"
^XMB(3.9,145983,2,2128,0)=" S RCSTAT=$$STATUS(RCIEN)"
^XMB(3.9,145983,2,2129,0)="""RTN"",""RCRPU1"",180,0)"
^XMB(3.9,145983,2,2130,0)=" D:RCCURST'=RCSTAT UPDSTAT(RCIEN,RCSTAT)"
^XMB(3.9,145983,2,2131,0)="""RTN"",""RCRPU1"",181,0)"
^XMB(3.9,145983,2,2132,0)=" Q"
^XMB(3.9,145983,2,2133,0)="""RTN"",""RCRPU1"",182,0)"
^XMB(3.9,145983,2,2134,0)=" ;"
^XMB(3.9,145983,2,2135,0)="""RTN"",""RCRPU1"",183,0)"
^XMB(3.9,145983,2,2136,0)="UPDPAID(RCIEN,RCCMP) ; Update the Paid flag in the payments."
^XMB(3.9,145983,2,2137,0)="""RTN"",""RCRPU1"",184,0)"
^XMB(3.9,145983,2,2138,0)=" ;INPUT: RCIEN - IEN of plan to update"
^XMB(3.9,145983,2,2139,0)="""RTN"",""RCRPU1"",185,0)"
^XMB(3.9,145983,2,2140,0)=" ;       RCCMP - # payments completed."
^XMB(3.9,145983,2,2141,0)="""RTN"",""RCRPU1"",186,0)"
^XMB(3.9,145983,2,2142,0)=" ;"
^XMB(3.9,145983,2,2143,0)="""RTN"",""RCRPU1"",187,0)"
^XMB(3.9,145983,2,2144,0)=" N DR,DIE,DA,X,Y"
^XMB(3.9,145983,2,2145,0)="""RTN"",""RCRPU1"",188,0)"
^XMB(3.9,145983,2,2146,0)=" N RCI,RCPD,RCPDFLG,RCFBFLG,RCCNT"
^XMB(3.9,145983,2,2147,0)="""RTN"",""RCRPU1"",189,0)"
^XMB(3.9,145983,2,2148,0)=" ;"
^XMB(3.9,145983,2,2149,0)="""RTN"",""RCRPU1"",190,0)"
^XMB(3.9,145983,2,2150,0)=" S RCCNT=0"
^XMB(3.9,145983,2,2151,0)="""RTN"",""RCRPU1"",191,0)"
^XMB(3.9,145983,2,2152,0)=" F RCI=0:1 Q:RCCNT>RCCMP  D"
^XMB(3.9,145983,2,2153,0)="""RTN"",""RCRPU1"",192,0)"
^XMB(3.9,145983,2,2154,0)=" . S RCPD=$G(^RCRP(340.5,RCIEN,2,RCI,0)),RCPDFLG=$P(RCPD,U,2),RCFBFLG=$P(RCPD,U,3)"
^XMB(3.9,145983,2,2155,0)="""RTN"",""RCRPU1"",193,0)"
^XMB(3.9,145983,2,2156,0)=" . I RCPDFLG S RCCNT=RCCNT+1 Q"
^XMB(3.9,145983,2,2157,0)="""RTN"",""RCRPU1"",194,0)"
^XMB(3.9,145983,2,2158,0)=" . I 'RCPDFLG,'RCFBFLG D"
^XMB(3.9,145983,2,2159,0)="""RTN"",""RCRPU1"",195,0)"
^XMB(3.9,145983,2,2160,0)=" . . S DR=""1////1"""
^XMB(3.9,145983,2,2161,0)="""RTN"",""RCRPU1"",196,0)"
^XMB(3.9,145983,2,2162,0)=" . . S DA(1)=RCIEN,DA=RCI"
^XMB(3.9,145983,2,2163,0)="""RTN"",""RCRPU1"",197,0)"
^XMB(3.9,145983,2,2164,0)=" . . S DIE=""^RCRP(340.5,""_DA(1)_"",2,"""
^XMB(3.9,145983,2,2165,0)="""RTN"",""RCRPU1"",198,0)"
^XMB(3.9,145983,2,2166,0)=" . . D ^DIE"
^XMB(3.9,145983,2,2167,0)="""RTN"",""RCRPU1"",199,0)"
^XMB(3.9,145983,2,2168,0)=" . . S RCCNT=RCCNT+1   ;Increment the # of months counter update"
^XMB(3.9,145983,2,2169,0)="""RTN"",""RCRPU1"",200,0)"
^XMB(3.9,145983,2,2170,0)=" Q"
^XMB(3.9,145983,2,2171,0)="""RTN"",""RCRPU1"",201,0)"
^XMB(3.9,145983,2,2172,0)=" ;"
^XMB(3.9,145983,2,2173,0)="""RTN"",""RCRPU1"",202,0)"
^XMB(3.9,145983,2,2174,0)="UPDBAL(RCBILLDA,RCTRANDA,RCSPFLG) ; Update the Plan Amount Owed (#.11) in the AR"
^XMB(3.9,145983,2,2175,0)="""RTN"",""RCRPU1"",203,0)"
^XMB(3.9,145983,2,2176,0)=" ; REPAYMENT PLAN file (#340.5)."
^XMB(3.9,145983,2,2177,0)="""RTN"",""RCRPU1"",204,0)"
^XMB(3.9,145983,2,2178,0)=" ;"
^XMB(3.9,145983,2,2179,0)="""RTN"",""RCRPU1"",205,0)"
^XMB(3.9,145983,2,2180,0)=" ;INPUT:  RCBILLDA - IEN to ACCOUNTS RECEIVABLE file (#430)"
^XMB(3.9,145983,2,2181,0)="""RTN"",""RCRPU1"",206,0)"
^XMB(3.9,145983,2,2182,0)=" ;        RCTRANDA - IEN to the AR TRANSACTION file (#433)"
^XMB(3.9,145983,2,2183,0)="""RTN"",""RCRPU1"",207,0)"
^XMB(3.9,145983,2,2184,0)=" ;        RCSPFLG  - (Optional) Is the update a result of a bill being suspended."
^XMB(3.9,145983,2,2185,0)="""RTN"",""RCRPU1"",208,0)"
^XMB(3.9,145983,2,2186,0)=" ;"
^XMB(3.9,145983,2,2187,0)="""RTN"",""RCRPU1"",209,0)"
^XMB(3.9,145983,2,2188,0)=" N RCIEN,RCTRTYPE,RCRPPFLG,RCAMT,RCPYMNTS,RCRMBAL,RCMNPY,RCNOMN,RCNWLN,RCNWMOD"
^XMB(3.9,145983,2,2189,0)="""RTN"",""RCRPU1"",210,0)"
^XMB(3.9,145983,2,2190,0)=" ;"
^XMB(3.9,145983,2,2191,0)="""RTN"",""RCRPU1"",211,0)"
^XMB(3.9,145983,2,2192,0)=" ;Initialize the RCSPFLG if not sent in"
^XMB(3.9,145983,2,2193,0)="""RTN"",""RCRPU1"",212,0)"
^XMB(3.9,145983,2,2194,0)=" S RCSPFLG=+$G(RCSPFLG)"
^XMB(3.9,145983,2,2195,0)="""RTN"",""RCRPU1"",213,0)"
^XMB(3.9,145983,2,2196,0)=" ;"
^XMB(3.9,145983,2,2197,0)="""RTN"",""RCRPU1"",214,0)"
^XMB(3.9,145983,2,2198,0)=" ; Check to see if Bill has an active Repayment Plan.  Exit if not"
^XMB(3.9,145983,2,2199,0)="""RTN"",""RCRPU1"",215,0)"
^XMB(3.9,145983,2,2200,0)=" S RCIEN=$$GET1^DIQ(430,RCBILLDA_"","",45,""I"")"
^XMB(3.9,145983,2,2201,0)="""RTN"",""RCRPU1"",216,0)"
^XMB(3.9,145983,2,2202,0)=" Q:RCIEN="""""
^XMB(3.9,145983,2,2203,0)="""RTN"",""RCRPU1"",217,0)"
^XMB(3.9,145983,2,2204,0)=" ;"
^XMB(3.9,145983,2,2205,0)="""RTN"",""RCRPU1"",218,0)"
^XMB(3.9,145983,2,2206,0)=" S RCTRTYPE=$$GET1^DIQ(433,RCTRANDA_"","",12,""I"")"
^XMB(3.9,145983,2,2207,0)="""RTN"",""RCRPU1"",219,0)"
^XMB(3.9,145983,2,2208,0)=" Q:RCTRTYPE="""""
^XMB(3.9,145983,2,2209,0)="""RTN"",""RCRPU1"",220,0)"
^XMB(3.9,145983,2,2210,0)=" ;"
^XMB(3.9,145983,2,2211,0)="""RTN"",""RCRPU1"",221,0)"
^XMB(3.9,145983,2,2212,0)=" ; remove bill from RPP if action caused by any write off transaction type (Termination/Suspension/et al)"
^XMB(3.9,145983,2,2213,0)="""RTN"",""RCRPU1"",222,0)"
^XMB(3.9,145983,2,2214,0)=" I RCSPFLG>0 D "
^XMB(3.9,145983,2,2215,0)="""RTN"",""RCRPU1"",223,0)"
^XMB(3.9,145983,2,2216,0)=" . D REMBILL^RCRPU(RCIEN,RCBILLDA)  ; REMOVE BILL FROM PLAN"
^XMB(3.9,145983,2,2217,0)="""RTN"",""RCRPU1"",224,0)"
^XMB(3.9,145983,2,2218,0)=" . D RMVPLN(RCBILLDA,0)               ; REMOVE PLAN FROM BILL,but don't file close transaction."
^XMB(3.9,145983,2,2219,0)="""RTN"",""RCRPU1"",225,0)"
^XMB(3.9,145983,2,2220,0)=" ;"
^XMB(3.9,145983,2,2221,0)="""RTN"",""RCRPU1"",226,0)"
^XMB(3.9,145983,2,2222,0)=" ; Check to see if the Transaction type has an affect on the Repayment Plan"
^XMB(3.9,145983,2,2223,0)="""RTN"",""RCRPU1"",227,0)"
^XMB(3.9,145983,2,2224,0)=" ; Exit if the Transaction will not affect it."
^XMB(3.9,145983,2,2225,0)="""RTN"",""RCRPU1"",228,0)"
^XMB(3.9,145983,2,2226,0)=" S RCRPPFLG=$$GET1^DIQ(430.3,RCTRTYPE_"","",6,""I"")"
^XMB(3.9,145983,2,2227,0)="""RTN"",""RCRPU1"",229,0)"
^XMB(3.9,145983,2,2228,0)=" Q:RCRPPFLG="""""
^XMB(3.9,145983,2,2229,0)="""RTN"",""RCRPU1"",230,0)"
^XMB(3.9,145983,2,2230,0)=" ;"
^XMB(3.9,145983,2,2231,0)="""RTN"",""RCRPU1"",231,0)"
^XMB(3.9,145983,2,2232,0)=" ; Extract the amount of the transaction.  Quit if no transaction amount filed."
^XMB(3.9,145983,2,2233,0)="""RTN"",""RCRPU1"",232,0)"
^XMB(3.9,145983,2,2234,0)=" S RCAMT=$$GET1^DIQ(433,RCTRANDA_"","",15,""I"")"
^XMB(3.9,145983,2,2235,0)="""RTN"",""RCRPU1"",233,0)"
^XMB(3.9,145983,2,2236,0)=" Q:+RCAMT=0"
^XMB(3.9,145983,2,2237,0)="""RTN"",""RCRPU1"",234,0)"
^XMB(3.9,145983,2,2238,0)=" ;"
^XMB(3.9,145983,2,2239,0)="""RTN"",""RCRPU1"",235,0)"
^XMB(3.9,145983,2,2240,0)=" ; If the Transaction Type Repayment Plan Processing flag is set to P"
^XMB(3.9,145983,2,2241,0)="""RTN"",""RCRPU1"",236,0)"
^XMB(3.9,145983,2,2242,0)=" ;  then process the Transaction Type as a Payment and exit."
^XMB(3.9,145983,2,2243,0)="""RTN"",""RCRPU1"",237,0)"
^XMB(3.9,145983,2,2244,0)=" I RCRPPFLG=""P"" D  Q"
^XMB(3.9,145983,2,2245,0)="""RTN"",""RCRPU1"",238,0)"
^XMB(3.9,145983,2,2246,0)=" . D UPDPAY(RCIEN,RCTRANDA,RCAMT)"
^XMB(3.9,145983,2,2247,0)="""RTN"",""RCRPU1"",239,0)"
^XMB(3.9,145983,2,2248,0)=" ;"
^XMB(3.9,145983,2,2249,0)="""RTN"",""RCRPU1"",240,0)"
^XMB(3.9,145983,2,2250,0)=" ; Retrieve the remaining Balance."
^XMB(3.9,145983,2,2251,0)="""RTN"",""RCRPU1"",241,0)"
^XMB(3.9,145983,2,2252,0)=" S RCRMBAL=$$GET1^DIQ(340.5,RCIEN_"","",.11,""I"")"
^XMB(3.9,145983,2,2253,0)="""RTN"",""RCRPU1"",242,0)"
^XMB(3.9,145983,2,2254,0)=" ;"
^XMB(3.9,145983,2,2255,0)="""RTN"",""RCRPU1"",243,0)"
^XMB(3.9,145983,2,2256,0)=" ; If the transaction is supposed to be a decrease, then make the"
^XMB(3.9,145983,2,2257,0)="""RTN"",""RCRPU1"",244,0)"
^XMB(3.9,145983,2,2258,0)=" ;  transaction amount negative"
^XMB(3.9,145983,2,2259,0)="""RTN"",""RCRPU1"",245,0)"
^XMB(3.9,145983,2,2260,0)=" S:RCRPPFLG=""D"" RCAMT=-RCAMT"
^XMB(3.9,145983,2,2261,0)="""RTN"",""RCRPU1"",246,0)"
^XMB(3.9,145983,2,2262,0)=" ;"
^XMB(3.9,145983,2,2263,0)="""RTN"",""RCRPU1"",247,0)"
^XMB(3.9,145983,2,2264,0)=" ; Add (subtract if it is a decrease) the amount to the remaining balance."
^XMB(3.9,145983,2,2265,0)="""RTN"",""RCRPU1"",248,0)"
^XMB(3.9,145983,2,2266,0)=" S RCRMBAL=RCRMBAL+RCAMT"
^XMB(3.9,145983,2,2267,0)="""RTN"",""RCRPU1"",249,0)"
^XMB(3.9,145983,2,2268,0)=" ;"
^XMB(3.9,145983,2,2269,0)="""RTN"",""RCRPU1"",250,0)"
^XMB(3.9,145983,2,2270,0)=" ; Store the new Balance."
^XMB(3.9,145983,2,2271,0)="""RTN"",""RCRPU1"",251,0)"
^XMB(3.9,145983,2,2272,0)=" D UPDPAO(RCIEN,RCRMBAL)"
^XMB(3.9,145983,2,2273,0)="""RTN"",""RCRPU1"",252,0)"
^XMB(3.9,145983,2,2274,0)=" ;"
^XMB(3.9,145983,2,2275,0)="""RTN"",""RCRPU1"",253,0)"
^XMB(3.9,145983,2,2276,0)=" ; Recalculate terms with the new balance"
^XMB(3.9,145983,2,2277,0)="""RTN"",""RCRPU1"",254,0)"
^XMB(3.9,145983,2,2278,0)=" S RCMNPY=$$GET1^DIQ(340.5,RCIEN_"","",.06,""I"")"
^XMB(3.9,145983,2,2279,0)="""RTN"",""RCRPU1"",255,0)"
^XMB(3.9,145983,2,2280,0)=" S RCNOMN=$$GET1^DIQ(340.5,RCIEN_"","",.05,""I"")"
^XMB(3.9,145983,2,2281,0)="""RTN"",""RCRPU1"",256,0)"
^XMB(3.9,145983,2,2282,0)=" S RCNWLN=RCRMBAL\RCMNPY,RCNWMOD=RCRMBAL#RCMNPY"
^XMB(3.9,145983,2,2283,0)="""RTN"",""RCRPU1"",257,0)"
^XMB(3.9,145983,2,2284,0)=" I RCNWMOD>0 S RCNWLN=RCNWLN+1"
^XMB(3.9,145983,2,2285,0)="""RTN"",""RCRPU1"",258,0)"
^XMB(3.9,145983,2,2286,0)=" ;"
^XMB(3.9,145983,2,2287,0)="""RTN"",""RCRPU1"",259,0)"
^XMB(3.9,145983,2,2288,0)=" ; If there is a change in term length, update the plan."
^XMB(3.9,145983,2,2289,0)="""RTN"",""RCRPU1"",260,0)"
^XMB(3.9,145983,2,2290,0)=" I RCNOMN'=RCNWLN D UPDTERMS(RCIEN,RCMNPY_U_RCNWLN),ADJSCHED^RCRPENTR(RCIEN,RCNOMN,RCNWLN)"
^XMB(3.9,145983,2,2291,0)="""RTN"",""RCRPU1"",261,0)"
^XMB(3.9,145983,2,2292,0)=" ;"
^XMB(3.9,145983,2,2293,0)="""RTN"",""RCRPU1"",262,0)"
^XMB(3.9,145983,2,2294,0)=" ;Check current balance.  If 0 or lower, close the plan as paid in full"
^XMB(3.9,145983,2,2295,0)="""RTN"",""RCRPU1"",263,0)"
^XMB(3.9,145983,2,2296,0)=" S RCPYMNTS=$$PMNTS^RCRPU3(RCIEN)"
^XMB(3.9,145983,2,2297,0)="""RTN"",""RCRPU1"",264,0)"
^XMB(3.9,145983,2,2298,0)=" I (RCRMBAL-RCPYMNTS)'>0 D"
^XMB(3.9,145983,2,2299,0)="""RTN"",""RCRPU1"",265,0)"
^XMB(3.9,145983,2,2300,0)=" . D PAID(RCIEN,RCSPFLG)"
^XMB(3.9,145983,2,2301,0)="""RTN"",""RCRPU1"",266,0)"
^XMB(3.9,145983,2,2302,0)=" . I RCSPFLG=1 D TRAN^RCRPU(RCBILLDA,0,68)      ; file transaction if the bill which closed the plan was suspended."
^XMB(3.9,145983,2,2303,0)="""RTN"",""RCRPU1"",267,0)"
^XMB(3.9,145983,2,2304,0)=" ;"
^XMB(3.9,145983,2,2305,0)="""RTN"",""RCRPU1"",268,0)"
^XMB(3.9,145983,2,2306,0)=" Q"
^XMB(3.9,145983,2,2307,0)="""RTN"",""RCRPU1"",269,0)"
^XMB(3.9,145983,2,2308,0)=" ;"
^XMB(3.9,145983,2,2309,0)="""RTN"",""RCRPU1"",270,0)"
^XMB(3.9,145983,2,2310,0)="UPDPAO(RCIEN,RCAMT) ; Update the PLAN AMOUNT OWE3D field"
^XMB(3.9,145983,2,2311,0)="""RTN"",""RCRPU1"",271,0)"
^XMB(3.9,145983,2,2312,0)=" ;"
^XMB(3.9,145983,2,2313,0)="""RTN"",""RCRPU1"",272,0)"
^XMB(3.9,145983,2,2314,0)=" N DR,DIE,DA,X,Y"
^XMB(3.9,145983,2,2315,0)="""RTN"",""RCRPU1"",273,0)"
^XMB(3.9,145983,2,2316,0)=" S DR="".11////""_RCAMT"
^XMB(3.9,145983,2,2317,0)="""RTN"",""RCRPU1"",274,0)"
^XMB(3.9,145983,2,2318,0)=" S DIE=""^RCRP(340.5,"",DA=RCIEN"
^XMB(3.9,145983,2,2319,0)="""RTN"",""RCRPU1"",275,0)"
^XMB(3.9,145983,2,2320,0)=" D ^DIE"
^XMB(3.9,145983,2,2321,0)="""RTN"",""RCRPU1"",276,0)"
^XMB(3.9,145983,2,2322,0)=" Q"
^XMB(3.9,145983,2,2323,0)="""RTN"",""RCRPU1"",277,0)"
^XMB(3.9,145983,2,2324,0)=" ;"
^XMB(3.9,145983,2,2325,0)="""RTN"",""RCRPU1"",278,0)"
^XMB(3.9,145983,2,2326,0)="PAID(RCIEN,RCSPFLG) ; Repayment Plan is paid in full, update the status to PAID IN FULL and attempt to remove plan information from bills in plan."
^XMB(3.9,145983,2,2327,0)="""RTN"",""RCRPU1"",279,0)"
^XMB(3.9,145983,2,2328,0)=" ;"
^XMB(3.9,145983,2,2329,0)="""RTN"",""RCRPU1"",280,0)"
^XMB(3.9,145983,2,2330,0)=" N RCI,RCBILLDA,RCSTAT,RCPYFLG"
^XMB(3.9,145983,2,2331,0)="""RTN"",""RCRPU1"",281,0)"
^XMB(3.9,145983,2,2332,0)=" ;"
^XMB(3.9,145983,2,2333,0)="""RTN"",""RCRPU1"",282,0)"
^XMB(3.9,145983,2,2334,0)=" ;Update the plan status to Paid in Full. If not suspended"
^XMB(3.9,145983,2,2335,0)="""RTN"",""RCRPU1"",283,0)"
^XMB(3.9,145983,2,2336,0)=" I '+RCSPFLG D"
^XMB(3.9,145983,2,2337,0)="""RTN"",""RCRPU1"",284,0)"
^XMB(3.9,145983,2,2338,0)=" . D UPDSTAT(RCIEN,8)"
^XMB(3.9,145983,2,2339,0)="""RTN"",""RCRPU1"",285,0)"
^XMB(3.9,145983,2,2340,0)=" . I '$D(ZTQUEUED) W !!,""This repayment plan has been closed and is PAID IN FULL."",!!"
^XMB(3.9,145983,2,2341,0)="""RTN"",""RCRPU1"",286,0)"
^XMB(3.9,145983,2,2342,0)=" ;"
^XMB(3.9,145983,2,2343,0)="""RTN"",""RCRPU1"",287,0)"
^XMB(3.9,145983,2,2344,0)=" ;Update the plan status to Closed because remaining bill(s) suspended AND exit."
^XMB(3.9,145983,2,2345,0)="""RTN"",""RCRPU1"",288,0)"
^XMB(3.9,145983,2,2346,0)=" I RCSPFLG=1 D  Q"
^XMB(3.9,145983,2,2347,0)="""RTN"",""RCRPU1"",289,0)"
^XMB(3.9,145983,2,2348,0)=" . D UPDSTAT(RCIEN,7)"
^XMB(3.9,145983,2,2349,0)="""RTN"",""RCRPU1"",290,0)"
^XMB(3.9,145983,2,2350,0)=" . D UPDAUDIT^RCRPU2(RCIEN,$$DT^XLFDT,""C"",""A"")   ; AUDIT LOG"
^XMB(3.9,145983,2,2351,0)="""RTN"",""RCRPU1"",291,0)"
^XMB(3.9,145983,2,2352,0)=" . I '$D(ZTQUEUED) W !!,""This repayment plan has been CLOSED."",!!"
^XMB(3.9,145983,2,2353,0)="""RTN"",""RCRPU1"",292,0)"
^XMB(3.9,145983,2,2354,0)=" ;"
^XMB(3.9,145983,2,2355,0)="""RTN"",""RCRPU1"",293,0)"
^XMB(3.9,145983,2,2356,0)=" ;Update the status caused by other types of Bill Termination"
^XMB(3.9,145983,2,2357,0)="""RTN"",""RCRPU1"",294,0)"
^XMB(3.9,145983,2,2358,0)=" I RCSPFLG=2 D"
^XMB(3.9,145983,2,2359,0)="""RTN"",""RCRPU1"",295,0)"
^XMB(3.9,145983,2,2360,0)=" . S RCPYFLG=$D(^RCRP(340.5,RCIEN,3))  ; check to see if any payments associated with the plan"
^XMB(3.9,145983,2,2361,0)="""RTN"",""RCRPU1"",296,0)"
^XMB(3.9,145983,2,2362,0)=" . S RCSTAT=7                          ; set the status to closed"
^XMB(3.9,145983,2,2363,0)="""RTN"",""RCRPU1"",297,0)"
^XMB(3.9,145983,2,2364,0)=" . S:RCPYFLG>9 RCSTAT=8                ; reset status to Paid in Full if any payments associated with the terminated transaction"
^XMB(3.9,145983,2,2365,0)="""RTN"",""RCRPU1"",298,0)"
^XMB(3.9,145983,2,2366,0)=" . D UPDSTAT(RCIEN,RCSTAT)"
^XMB(3.9,145983,2,2367,0)="""RTN"",""RCRPU1"",299,0)"
^XMB(3.9,145983,2,2368,0)=" . D:RCPYFLG>9 UPDAUDIT^RCRPU2(RCIEN,$$DT^XLFDT,""C"",""A"")   ; Update Audit Log with a close entry if plan is closed and not paid in full."
^XMB(3.9,145983,2,2369,0)="""RTN"",""RCRPU1"",300,0)"
^XMB(3.9,145983,2,2370,0)=" . I (RCPYFLG>9),'$D(ZTQUEUED) W !!,""This repayment plan has been CLOSED."",!! Q"
^XMB(3.9,145983,2,2371,0)="""RTN"",""RCRPU1"",301,0)"
^XMB(3.9,145983,2,2372,0)=" . I '$D(ZTQUEUED) W !!,""This repayment plan has been closed and is PAID IN FULL."",!!"
^XMB(3.9,145983,2,2373,0)="""RTN"",""RCRPU1"",302,0)"
^XMB(3.9,145983,2,2374,0)=" ;"
^XMB(3.9,145983,2,2375,0)="""RTN"",""RCRPU1"",303,0)"
^XMB(3.9,145983,2,2376,0)=" ;Remove the Plan info from the bills is the Bill is at a 0 balance, or is Suspended, Terminated or written off."
^XMB(3.9,145983,2,2377,0)="""RTN"",""RCRPU1"",304,0)"
^XMB(3.9,145983,2,2378,0)=" S RCI=0"
^XMB(3.9,145983,2,2379,0)="""RTN"",""RCRPU1"",305,0)"
^XMB(3.9,145983,2,2380,0)=" F  S RCI=$O(^RCRP(340.5,RCIEN,6,RCI)) Q:'RCI  D"
^XMB(3.9,145983,2,2381,0)="""RTN"",""RCRPU1"",306,0)"
^XMB(3.9,145983,2,2382,0)=" .  S RCBILLDA=$G(^RCRP(340.5,RCIEN,6,RCI,0))"
^XMB(3.9,145983,2,2383,0)="""RTN"",""RCRPU1"",307,0)"
^XMB(3.9,145983,2,2384,0)=" .  Q:'RCBILLDA"
^XMB(3.9,145983,2,2385,0)="""RTN"",""RCRPU1"",308,0)"
^XMB(3.9,145983,2,2386,0)=" .  D RMVPLN(RCBILLDA,1)"
^XMB(3.9,145983,2,2387,0)="""RTN"",""RCRPU1"",309,0)"
^XMB(3.9,145983,2,2388,0)=" Q"
^XMB(3.9,145983,2,2389,0)="""RTN"",""RCRPU1"",310,0)"
^XMB(3.9,145983,2,2390,0)=" ;"
^XMB(3.9,145983,2,2391,0)="""RTN"",""RCRPU1"",311,0)"
^XMB(3.9,145983,2,2392,0)="RMVPLN(RCBILLDA,RCNOCLS) ;Remove the Plan info from a bill and file a Close Plan Transaction file."
^XMB(3.9,145983,2,2393,0)="""RTN"",""RCRPU1"",312,0)"
^XMB(3.9,145983,2,2394,0)=" ; Input:  RCBILLDA - IEN of the AR Bill (from file #430) to remove "
^XMB(3.9,145983,2,2395,0)="""RTN"",""RCRPU1"",313,0)"
^XMB(3.9,145983,2,2396,0)=" ;         RCNOCLS  - (Optional) - Flag to indicate whether to file a close Repayment Plan transaction or not."
^XMB(3.9,145983,2,2397,0)="""RTN"",""RCRPU1"",314,0)"
^XMB(3.9,145983,2,2398,0)=" N X,Y,DIC,DIE,DR,RCAMT,PRCA"
^XMB(3.9,145983,2,2399,0)="""RTN"",""RCRPU1"",315,0)"
^XMB(3.9,145983,2,2400,0)=" ;"
^XMB(3.9,145983,2,2401,0)="""RTN"",""RCRPU1"",316,0)"
^XMB(3.9,145983,2,2402,0)=" ;Init RC NOCLS if necessary"
^XMB(3.9,145983,2,2403,0)="""RTN"",""RCRPU1"",317,0)"
^XMB(3.9,145983,2,2404,0)=" S RCNOCLS=+$G(RCNOCLS)"
^XMB(3.9,145983,2,2405,0)="""RTN"",""RCRPU1"",318,0)"
^XMB(3.9,145983,2,2406,0)=" ;"
^XMB(3.9,145983,2,2407,0)="""RTN"",""RCRPU1"",319,0)"
^XMB(3.9,145983,2,2408,0)=" ;Store the RPP IEN into the AR file (#430) AR Repayment Plan (#45) field. "
^XMB(3.9,145983,2,2409,0)="""RTN"",""RCRPU1"",320,0)"
^XMB(3.9,145983,2,2410,0)=" S (DIC,DIE)=""^PRCA(430,"",DA=RCBILLDA,DR=""41////@;45////@"""
^XMB(3.9,145983,2,2411,0)="""RTN"",""RCRPU1"",321,0)"
^XMB(3.9,145983,2,2412,0)=" S PRCA(""LOCK"")=0 D LOCKF^PRCAWO1 D:PRCA(""LOCK"")=0 ^DIE"
^XMB(3.9,145983,2,2413,0)="""RTN"",""RCRPU1"",322,0)"
^XMB(3.9,145983,2,2414,0)=" K DA,DIC,DIE,DR"
^XMB(3.9,145983,2,2415,0)="""RTN"",""RCRPU1"",323,0)"
^XMB(3.9,145983,2,2416,0)=" ;get the current amount owed."
^XMB(3.9,145983,2,2417,0)="""RTN"",""RCRPU1"",324,0)"
^XMB(3.9,145983,2,2418,0)=" ;File a Close Plan Transaction into the Transaction file."
^XMB(3.9,145983,2,2419,0)="""RTN"",""RCRPU1"",325,0)"
^XMB(3.9,145983,2,2420,0)=" D:RCNOCLS TRAN^RCRPU(RCBILLDA,0,68)"
^XMB(3.9,145983,2,2421,0)="""RTN"",""RCRPU1"",326,0)"
^XMB(3.9,145983,2,2422,0)=" Q"
^XMB(3.9,145983,2,2423,0)="""RTN"",""RCRPU1"",327,0)"
^XMB(3.9,145983,2,2424,0)=" ;"
^XMB(3.9,145983,2,2425,0)="""RTN"",""RCRPU1"",328,0)"
^XMB(3.9,145983,2,2426,0)="AUTOADD(DEF) ; display ""allow bills to be auto-added?"" prompt PRCA*4.5*378"
^XMB(3.9,145983,2,2427,0)="""RTN"",""RCRPU1"",329,0)"
^XMB(3.9,145983,2,2428,0)=" ;"
^XMB(3.9,145983,2,2429,0)="""RTN"",""RCRPU1"",330,0)"
^XMB(3.9,145983,2,2430,0)=" ; DEF - default value (1 = YES, 0 = NO, """" = no default)"
^XMB(3.9,145983,2,2431,0)="""RTN"",""RCRPU1"",331,0)"
^XMB(3.9,145983,2,2432,0)=" ;"
^XMB(3.9,145983,2,2433,0)="""RTN"",""RCRPU1"",332,0)"
^XMB(3.9,145983,2,2434,0)=" ; returns 1 for Yes, 0 for No, -1 for no selection"
^XMB(3.9,145983,2,2435,0)="""RTN"",""RCRPU1"",333,0)"
^XMB(3.9,145983,2,2436,0)=" ;"
^XMB(3.9,145983,2,2437,0)="""RTN"",""RCRPU1"",334,0)"
^XMB(3.9,145983,2,2438,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,X,Y"
^XMB(3.9,145983,2,2439,0)="""RTN"",""RCRPU1"",335,0)"
^XMB(3.9,145983,2,2440,0)=" S DIR(0)=""Y"" I $G(DEF)'="""" S DIR(""B"")=$S(DEF:""YES"",1:""NO"")"
^XMB(3.9,145983,2,2441,0)="""RTN"",""RCRPU1"",336,0)"
^XMB(3.9,145983,2,2442,0)=" S DIR(""A"")=""Allow bills to be auto-added to the repayment plan? (Y/N)"""
^XMB(3.9,145983,2,2443,0)="""RTN"",""RCRPU1"",337,0)"
^XMB(3.9,145983,2,2444,0)=" D ^DIR I $D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) Q -1"
^XMB(3.9,145983,2,2445,0)="""RTN"",""RCRPU1"",338,0)"
^XMB(3.9,145983,2,2446,0)=" Q Y"
^XMB(3.9,145983,2,2447,0)="""RTN"",""RCRPU1"",339,0)"
^XMB(3.9,145983,2,2448,0)=" ;"
^XMB(3.9,145983,2,2449,0)="""RTN"",""RCRPU1"",340,0)"
^XMB(3.9,145983,2,2450,0)="UPDAUTO(RCIEN,RCAUTO) ; Update ""auto-add bills"" flag. PRCA*4.5*378"
^XMB(3.9,145983,2,2451,0)="""RTN"",""RCRPU1"",341,0)"
^XMB(3.9,145983,2,2452,0)=" ;"
^XMB(3.9,145983,2,2453,0)="""RTN"",""RCRPU1"",342,0)"
^XMB(3.9,145983,2,2454,0)=" ; RCIEN - file 340.5 ien"
^XMB(3.9,145983,2,2455,0)="""RTN"",""RCRPU1"",343,0)"
^XMB(3.9,145983,2,2456,0)=" ; RCAUTO - new value for field 340.5/.12 (internal)"
^XMB(3.9,145983,2,2457,0)="""RTN"",""RCRPU1"",344,0)"
^XMB(3.9,145983,2,2458,0)=" ;"
^XMB(3.9,145983,2,2459,0)="""RTN"",""RCRPU1"",345,0)"
^XMB(3.9,145983,2,2460,0)=" N DR,DIE,DA,X,Y"
^XMB(3.9,145983,2,2461,0)="""RTN"",""RCRPU1"",346,0)"
^XMB(3.9,145983,2,2462,0)=" S DR="".12////""_RCAUTO,DIE=""^RCRP(340.5,"",DA=RCIEN"
^XMB(3.9,145983,2,2463,0)="""RTN"",""RCRPU1"",347,0)"
^XMB(3.9,145983,2,2464,0)=" D ^DIE"
^XMB(3.9,145983,2,2465,0)="""RTN"",""RCRPU1"",348,0)"
^XMB(3.9,145983,2,2466,0)=" ;"
^XMB(3.9,145983,2,2467,0)="""RTN"",""RCRPU1"",349,0)"
^XMB(3.9,145983,2,2468,0)=" ;Update the Audit Log"
^XMB(3.9,145983,2,2469,0)="""RTN"",""RCRPU1"",350,0)"
^XMB(3.9,145983,2,2470,0)=" D UPDAUDIT^RCRPU2(RCIEN,$$DT^XLFDT,""S"","""",""AUTO ADD"")"
^XMB(3.9,145983,2,2471,0)="""RTN"",""RCRPU1"",351,0)"
^XMB(3.9,145983,2,2472,0)=" Q"
^XMB(3.9,145983,2,2473,0)="""RTN"",""RCRPU1"",352,0)"
^XMB(3.9,145983,2,2474,0)=" ;"
^XMB(3.9,145983,2,2475,0)="""RTN"",""RCRPU1"",353,0)"
^XMB(3.9,145983,2,2476,0)="STATUS(RCRPIEN) ; Returns the current status of the plan."
^XMB(3.9,145983,2,2477,0)="""RTN"",""RCRPU1"",354,0)"
^XMB(3.9,145983,2,2478,0)=" ;"
^XMB(3.9,145983,2,2479,0)="""RTN"",""RCRPU1"",355,0)"
^XMB(3.9,145983,2,2480,0)=" N RCD0,RCFRDT,RCSTAT,RCLSTDT,RCSTATDT,RCCURDT,RCDIFF,RCOLDST"
^XMB(3.9,145983,2,2481,0)="""RTN"",""RCRPU1"",356,0)"
^XMB(3.9,145983,2,2482,0)=" ;"
^XMB(3.9,145983,2,2483,0)="""RTN"",""RCRPU1"",357,0)"
^XMB(3.9,145983,2,2484,0)=" S RCD0=$G(^RCRP(340.5,RCRPIEN,0))"
^XMB(3.9,145983,2,2485,0)="""RTN"",""RCRPU1"",358,0)"
^XMB(3.9,145983,2,2486,0)=" S RCFRDT=$P(RCD0,U,4)"
^XMB(3.9,145983,2,2487,0)="""RTN"",""RCRPU1"",359,0)"
^XMB(3.9,145983,2,2488,0)=" S (RCSTAT,RCOLDST)=$P(RCD0,U,7)"
^XMB(3.9,145983,2,2489,0)="""RTN"",""RCRPU1"",360,0)"
^XMB(3.9,145983,2,2490,0)=" S RCSTATDT=$P(RCD0,U,8)"
^XMB(3.9,145983,2,2491,0)="""RTN"",""RCRPU1"",361,0)"
^XMB(3.9,145983,2,2492,0)=" S RCCURDT=$$DT^XLFDT                  ;Get current date"
^XMB(3.9,145983,2,2493,0)="""RTN"",""RCRPU1"",362,0)"
^XMB(3.9,145983,2,2494,0)=" I RCSTAT=5,RCCURDT>RCSTATDT Q 6       ;plan is defaulted, set new status to terminate and exit."
^XMB(3.9,145983,2,2495,0)="""RTN"",""RCRPU1"",363,0)"
^XMB(3.9,145983,2,2496,0)=" I RCSTAT>5 Q RCSTAT                   ;Plan is closed"
^XMB(3.9,145983,2,2497,0)="""RTN"",""RCRPU1"",364,0)"
^XMB(3.9,145983,2,2498,0)=" I RCSTAT=1,RCCURDT<RCFRDT Q 1         ;Plan hasn't started yet.  Status stays New"
^XMB(3.9,145983,2,2499,0)="""RTN"",""RCRPU1"",365,0)"
^XMB(3.9,145983,2,2500,0)=" S RCLSTDT=$$GETNXTPY^RCRPU(RCRPIEN)   ;get the date of the next payment due"
^XMB(3.9,145983,2,2501,0)="""RTN"",""RCRPU1"",366,0)"
^XMB(3.9,145983,2,2502,0)=" I RCLSTDT="""" D  Q 8                   ;No payments left, plan is Paid in Full. Update Delinquent/Default flags if necessary."
^XMB(3.9,145983,2,2503,0)="""RTN"",""RCRPU1"",367,0)"
^XMB(3.9,145983,2,2504,0)=" . D UPDPRDL^RCRPNP(RCRPIEN,0)"
^XMB(3.9,145983,2,2505,0)="""RTN"",""RCRPU1"",368,0)"
^XMB(3.9,145983,2,2506,0)=" . D UPDPRDF^RCRPNP(RCRPIEN,0)"
^XMB(3.9,145983,2,2507,0)="""RTN"",""RCRPU1"",369,0)"
^XMB(3.9,145983,2,2508,0)=" ;"
^XMB(3.9,145983,2,2509,0)="""RTN"",""RCRPU1"",370,0)"
^XMB(3.9,145983,2,2510,0)=" S RCDIFF=$$FMDIFF^XLFDT(RCCURDT,RCLSTDT,1)"
^XMB(3.9,145983,2,2511,0)="""RTN"",""RCRPU1"",371,0)"
^XMB(3.9,145983,2,2512,0)=" S RCSTAT=$S(RCDIFF>90:5,RCDIFF>30:4,RCDIFF>0:3,1:2)"
^XMB(3.9,145983,2,2513,0)="""RTN"",""RCRPU1"",372,0)"
^XMB(3.9,145983,2,2514,0)=" I RCOLDST=4,RCSTAT'=4 D UPDPRDL^RCRPNP(RCRPIEN,0)"
^XMB(3.9,145983,2,2515,0)="""RTN"",""RCRPU1"",373,0)"
^XMB(3.9,145983,2,2516,0)=" I RCOLDST=5,RCSTAT<5 D UPDPRDF^RCRPNP(RCRPIEN,0)"
^XMB(3.9,145983,2,2517,0)="""RTN"",""RCRPU1"",374,0)"
^XMB(3.9,145983,2,2518,0)=" Q RCSTAT"
^XMB(3.9,145983,2,2519,0)="""RTN"",""RCRPU1"",375,0)"
^XMB(3.9,145983,2,2520,0)=" ;"
^XMB(3.9,145983,2,2521,0)="""VER"")"
^XMB(3.9,145983,2,2522,0)="8.0^22.2"
^XMB(3.9,145983,2,2523,0)="$END KID PRCA*4.5*442b"
