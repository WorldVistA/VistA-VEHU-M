^XMB(3.9,145950,2,365,0)="""RTN"",""PSAVERA"",65,0)"
^XMB(3.9,145950,2,366,0)="ASK R !!,""Are you sure about this ?  NO// "",AN:DTIME G NOCHNG:AN[""^""!(AN="""")"
^XMB(3.9,145950,2,367,0)="""RTN"",""PSAVERA"",66,0)"
^XMB(3.9,145950,2,368,0)=" S AN=$E(AN) I ""yYnN""'[AN W !,""Answer yes, and the data on file for the current drug will be transferred"",!,""to the new drug selection."",!,""That includes Order Unit, Dispense Unit, Dispense Units per Order Unit, etc."",!! G ASK"
