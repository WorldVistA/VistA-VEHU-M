^XMB(3.9,145983,2,1442,0)=" ;        RCFLG:  Value of the flag."
^XMB(3.9,145983,2,1443,0)="""RTN"",""RCRPNP"",175,0)"
^XMB(3.9,145983,2,1444,0)=" ;                1        : To appear on the Print Delinquent Report"
^XMB(3.9,145983,2,1445,0)="""RTN"",""RCRPNP"",176,0)"
^XMB(3.9,145983,2,1446,0)=" ;                0 or NULL: Does not appear on the Print Delinquent Report"
