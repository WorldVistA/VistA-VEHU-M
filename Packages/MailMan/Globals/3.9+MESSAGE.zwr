^XMB(3.9,145944,2,2109,0)="""RTN"",""IBJDF61"",120,0)"
^XMB(3.9,145944,2,2110,0)=" ;"
^XMB(3.9,145944,2,2111,0)="""RTN"",""IBJDF61"",121,0)"
^XMB(3.9,145944,2,2112,0)="PTDB(X) ; - Find Patient/Debtor and decide to include the AR."
^XMB(3.9,145944,2,2113,0)="""RTN"",""IBJDF61"",122,0)"
^XMB(3.9,145944,2,2114,0)=" ;    Input: X=Pointer to the AR in file #430 plus all IBS* variables"
^XMB(3.9,145944,2,2115,0)="""RTN"",""IBJDF61"",123,0)"
^XMB(3.9,145944,2,2116,0)=" ;   Output: Y=Sort key (name or last 4) and Patient/Debtor IEN(file #2) "
^XMB(3.9,145944,2,2117,0)="""RTN"",""IBJDF61"",124,0)"
^XMB(3.9,145944,2,2118,0)=" ;             ^ Patient/Debtor name (1st 25 chars) ^ Age ^ SSN"
^XMB(3.9,145944,2,2119,0)="""RTN"",""IBJDF61"",125,0)"
^XMB(3.9,145944,2,2120,0)=" ;             ^ Processed by (File #200) ^ Current VA Employee? (*=Yes)"
^XMB(3.9,145944,2,2121,0)="""RTN"",""IBJDF61"",126,0)"
^XMB(3.9,145944,2,2122,0)=" N AGE,ALL,ARZ,CAT,DEB,DA,DFN,DIC,DIQ,DR,END,IBZ,INI,KEY,NAME,PRC,SSN"
^XMB(3.9,145944,2,2123,0)="""RTN"",""IBJDF61"",127,0)"
^XMB(3.9,145944,2,2124,0)=" N VA,VADM,VAERR,Y,IBPTFLG"
^XMB(3.9,145944,2,2125,0)="""RTN"",""IBJDF61"",128,0)"
^XMB(3.9,145944,2,2126,0)=" ;"
^XMB(3.9,145944,2,2127,0)="""RTN"",""IBJDF61"",129,0)"
^XMB(3.9,145944,2,2128,0)=" S Y="""" I '$G(X) G PDQ"
^XMB(3.9,145944,2,2129,0)="""RTN"",""IBJDF61"",130,0)"
^XMB(3.9,145944,2,2130,0)=" S DFN=0,ARZ=$G(^PRCA(430,X,0)),CAT=$P(ARZ,""^"",2)"
^XMB(3.9,145944,2,2131,0)="""RTN"",""IBJDF61"",131,0)"
^XMB(3.9,145944,2,2132,0)=" S (NAME,AGE,SSN,PRC)="""""
^XMB(3.9,145944,2,2133,0)="""RTN"",""IBJDF61"",132,0)"
^XMB(3.9,145944,2,2134,0)=" ;"
^XMB(3.9,145944,2,2135,0)="""RTN"",""IBJDF61"",133,0)"
^XMB(3.9,145944,2,2136,0)=" ; - Look for Patient (Medicare,Tort Feasor,Work's Comp,No-Fault Auto Acc)"
^XMB(3.9,145944,2,2137,0)="""RTN"",""IBJDF61"",134,0)"
^XMB(3.9,145944,2,2138,0)=" S IBPTFLG=$$CATCHK(CAT)   ;IB*2.0*618"
^XMB(3.9,145944,2,2139,0)="""RTN"",""IBJDF61"",135,0)"
^XMB(3.9,145944,2,2140,0)=" I IBPTFLG D  I 'DFN S Y="""" G PDQ"
