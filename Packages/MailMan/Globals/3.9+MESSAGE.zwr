^XMB(3.9,145989,2,283,0)="""RTN"")"
^XMB(3.9,145989,2,284,0)=4
^XMB(3.9,145989,2,285,0)="""RTN"",""PSOASAP0"")"
^XMB(3.9,145989,2,286,0)="0^4^B167408199"
^XMB(3.9,145989,2,287,0)="""RTN"",""PSOASAP0"",1,0)"
^XMB(3.9,145989,2,288,0)="PSOASAP0 ;BIRM/MFR - American Society for Automation in Pharmacy (ASAP) Segments & Fields ;09/07/12"
^XMB(3.9,145989,2,289,0)="""RTN"",""PSOASAP0"",2,0)"
^XMB(3.9,145989,2,290,0)=" ;;7.0;OUTPATIENT PHARMACY;**408,451,496,504,625,630,659,705,772**;DEC 1997;Build 0"
^XMB(3.9,145989,2,291,0)="""RTN"",""PSOASAP0"",3,0)"
^XMB(3.9,145989,2,292,0)=" ;External reference to $$SITE^VASITE() supported by ICR 10112 "
^XMB(3.9,145989,2,293,0)="""RTN"",""PSOASAP0"",4,0)"
^XMB(3.9,145989,2,294,0)=" ;External reference to $$NATURE^ORUTL3 supported by ICR 5890"
^XMB(3.9,145989,2,295,0)="""RTN"",""PSOASAP0"",5,0)"
^XMB(3.9,145989,2,296,0)=" ;External reference to PATIENT file (#2) supported by DBIA 5597"
^XMB(3.9,145989,2,297,0)="""RTN"",""PSOASAP0"",6,0)"
^XMB(3.9,145989,2,298,0)=" ;External reference to VADM and VAPA array supported by ICR 10061"
^XMB(3.9,145989,2,299,0)="""RTN"",""PSOASAP0"",7,0)"
^XMB(3.9,145989,2,300,0)=" ;External reference to $$NPI^XUSNPI supported by ICR 4532"
^XMB(3.9,145989,2,301,0)="""RTN"",""PSOASAP0"",8,0)"
^XMB(3.9,145989,2,302,0)=" ;External reference to $$DIV4^XUSER supported by ICR 2533"
^XMB(3.9,145989,2,303,0)="""RTN"",""PSOASAP0"",9,0)"
^XMB(3.9,145989,2,304,0)=" ;External reference to $$RJ^XLFSTR supported by ICR 10104"
^XMB(3.9,145989,2,305,0)="""RTN"",""PSOASAP0"",10,0)"
^XMB(3.9,145989,2,306,0)=" ;            "
^XMB(3.9,145989,2,307,0)="""RTN"",""PSOASAP0"",11,0)"
^XMB(3.9,145989,2,308,0)=" ; ******************** ASAP 1995 Version ********************"
^XMB(3.9,145989,2,309,0)="""RTN"",""PSOASAP0"",12,0)"
^XMB(3.9,145989,2,310,0)="ASAP95(RXIEN,FILL) ;Returns the entire ASAP 1995 record for the Rx/Fill"
^XMB(3.9,145989,2,311,0)="""RTN"",""PSOASAP0"",13,0)"
^XMB(3.9,145989,2,312,0)=" ;Input: (r) RXIEN - Rx IEN (#52) "
^XMB(3.9,145989,2,313,0)="""RTN"",""PSOASAP0"",14,0)"
^XMB(3.9,145989,2,314,0)=" ;       (r) FILL  - Fill #"
^XMB(3.9,145989,2,315,0)="""RTN"",""PSOASAP0"",15,0)"
^XMB(3.9,145989,2,316,0)=" N ASAP95,RXNUM"
^XMB(3.9,145989,2,317,0)="""RTN"",""PSOASAP0"",16,0)"
^XMB(3.9,145989,2,318,0)=" S RXNUM=$E(RXIEN+10000000,$L(RXIEN+10000000)-6,$L(RXIEN+10000000))"
^XMB(3.9,145989,2,319,0)="""RTN"",""PSOASAP0"",17,0)"
^XMB(3.9,145989,2,320,0)=" S $E(ASAP95,1,3)=""ASB""                               ;Transmission Type Identifier"
^XMB(3.9,145989,2,321,0)="""RTN"",""PSOASAP0"",18,0)"
^XMB(3.9,145989,2,322,0)=" S $E(ASAP95,4,9)=""VA""_$E(10000+$$SITE^VASITE(),2,5)  ;Bank Identification Number"
^XMB(3.9,145989,2,323,0)="""RTN"",""PSOASAP0"",19,0)"
^XMB(3.9,145989,2,324,0)=" S $E(ASAP95,10,11)=""A2""                              ;ASAP Version (A2 = 1995)"
^XMB(3.9,145989,2,325,0)="""RTN"",""PSOASAP0"",20,0)"
^XMB(3.9,145989,2,326,0)=" S $E(ASAP95,12,13)=""01""                              ;Transaction Code (""01"" - Controlled Substance)"
^XMB(3.9,145989,2,327,0)="""RTN"",""PSOASAP0"",21,0)"
^XMB(3.9,145989,2,328,0)=" S $E(ASAP95,14,25)=$E($$PHA03^PSOASAP(),1,12)        ;Pharmacy DEA# Number"
^XMB(3.9,145989,2,329,0)="""RTN"",""PSOASAP0"",22,0)"
^XMB(3.9,145989,2,330,0)=" S $E(ASAP95,26,45)=$$PAT03^PSOASAP()                 ;Patient ID (SSN)"
^XMB(3.9,145989,2,331,0)="""RTN"",""PSOASAP0"",23,0)"
^XMB(3.9,145989,2,332,0)=" S $E(ASAP95,46,48)=$E($$PAT16^PSOASAP(),1,3)         ;Patient's Zip Code (first 3 digits)"
^XMB(3.9,145989,2,333,0)="""RTN"",""PSOASAP0"",24,0)"
^XMB(3.9,145989,2,334,0)=" S $E(ASAP95,49,56)=$$PAT18^PSOASAP()                 ;Patient's DOB  (Format: YYYYMMDD)"
^XMB(3.9,145989,2,335,0)="""RTN"",""PSOASAP0"",25,0)"
^XMB(3.9,145989,2,336,0)=" S $E(ASAP95,57,57)=$S($$PAT19^PSOASAP()=""M"":1,1:""2"") ;Patient's Gender"
^XMB(3.9,145989,2,337,0)="""RTN"",""PSOASAP0"",26,0)"
^XMB(3.9,145989,2,338,0)=" S $E(ASAP95,58,65)=$$DSP05^PSOASAP()                 ;Date Filled (Release/RTS Date) (Format: YYYYMMDD)"
^XMB(3.9,145989,2,339,0)="""RTN"",""PSOASAP0"",27,0)"
^XMB(3.9,145989,2,340,0)=" S $E(ASAP95,66,72)=RXNUM                             ;Prescription Number (IEN - Because it must be 7-digit numeric )"
^XMB(3.9,145989,2,341,0)="""RTN"",""PSOASAP0"",28,0)"
^XMB(3.9,145989,2,342,0)=" S $E(ASAP95,73,74)=$E(FILL+100,2,3)                  ;Fill Number"
^XMB(3.9,145989,2,343,0)="""RTN"",""PSOASAP0"",29,0)"
^XMB(3.9,145989,2,344,0)=" S $E(ASAP95,75,79)=$E(100000+$$DSP09^PSOASAP(),2,6)  ;Quantity"
^XMB(3.9,145989,2,345,0)="""RTN"",""PSOASAP0"",30,0)"
^XMB(3.9,145989,2,346,0)=" S $E(ASAP95,80,82)=$E(1000+$$DSP10^PSOASAP(),2,4)    ;Days Supply"
^XMB(3.9,145989,2,347,0)="""RTN"",""PSOASAP0"",31,0)"
^XMB(3.9,145989,2,348,0)=" S $E(ASAP95,83,83)=""1""                               ;Compound Flag (1=Not compound)"
^XMB(3.9,145989,2,349,0)="""RTN"",""PSOASAP0"",32,0)"
^XMB(3.9,145989,2,350,0)=" S $E(ASAP95,84,94)=$E($$DSP08^PSOASAP(),1,11)        ;NDC (Fomart: 99999999999)"
^XMB(3.9,145989,2,351,0)="""RTN"",""PSOASAP0"",33,0)"
^XMB(3.9,145989,2,352,0)=" S $E(ASAP95,95,104)=$E($$PRE02^PSOASAP(),1,10)       ;Prescriber's DEA #"
^XMB(3.9,145989,2,353,0)="""RTN"",""PSOASAP0"",34,0)"
^XMB(3.9,145989,2,354,0)=" S $E(ASAP95,105,108)=""""                              ;DEA Suffix"
^XMB(3.9,145989,2,355,0)="""RTN"",""PSOASAP0"",35,0)"
