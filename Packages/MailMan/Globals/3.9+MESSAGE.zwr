^XMB(3.9,145946,2,5655,0)="""RTN"",""IBCNSU21"",187,0)"
^XMB(3.9,145946,2,5656,0)=" . I '$D(^TMP(""IBCNSU21A"",$J,IIEN)) D  Q"
^XMB(3.9,145946,2,5657,0)="""RTN"",""IBCNSU21"",188,0)"
^XMB(3.9,145946,2,5658,0)=" . . W !,*7,"">>>> # "",LINE,"" is not currently selected. It cannot be deselected."""
^XMB(3.9,145946,2,5659,0)="""RTN"",""IBCNSU21"",189,0)"
^XMB(3.9,145946,2,5660,0)=" . . S ERROR=1"
^XMB(3.9,145946,2,5661,0)="""RTN"",""IBCNSU21"",190,0)"
^XMB(3.9,145946,2,5662,0)=" . D MARK(0,IIEN,LINE,.NUMSEL)              ; Deselect the entry"
^XMB(3.9,145946,2,5663,0)="""RTN"",""IBCNSU21"",191,0)"
^XMB(3.9,145946,2,5664,0)=" D HDR                                      ; Update the header"
^XMB(3.9,145946,2,5665,0)="""RTN"",""IBCNSU21"",192,0)"
^XMB(3.9,145946,2,5666,0)=" D:ERROR PAUSE^VALM1"
^XMB(3.9,145946,2,5667,0)="""RTN"",""IBCNSU21"",193,0)"
^XMB(3.9,145946,2,5668,0)=" Q"
^XMB(3.9,145946,2,5669,0)="""RTN"",""IBCNSU21"",194,0)"
^XMB(3.9,145946,2,5670,0)=" ;"
^XMB(3.9,145946,2,5671,0)="""RTN"",""IBCNSU21"",195,0)"
^XMB(3.9,145946,2,5672,0)="MARK(WHICH,IIEN,LINE,NUMSEL)   ;EP"
^XMB(3.9,145946,2,5673,0)="""RTN"",""IBCNSU21"",196,0)"
^XMB(3.9,145946,2,5674,0)=" ; Mark/Remove 'Selection' from a selected"
^XMB(3.9,145946,2,5675,0)="""RTN"",""IBCNSU21"",197,0)"
^XMB(3.9,145946,2,5676,0)=" ; Insurance Company line"
^XMB(3.9,145946,2,5677,0)="""RTN"",""IBCNSU21"",198,0)"
^XMB(3.9,145946,2,5678,0)=" ; Input:   WHICH   - 0 - Remove 'Selection' mark"
^XMB(3.9,145946,2,5679,0)="""RTN"",""IBCNSU21"",199,0)"
^XMB(3.9,145946,2,5680,0)=" ;                    1 - Set 'Selection' mark"
^XMB(3.9,145946,2,5681,0)="""RTN"",""IBCNSU21"",200,0)"
^XMB(3.9,145946,2,5682,0)=" ;          IENIN   - IEN of the entry to Mark/Remove 'In-Progress'"
^XMB(3.9,145946,2,5683,0)="""RTN"",""IBCNSU21"",201,0)"
^XMB(3.9,145946,2,5684,0)=" ;          LINE    - Line number being marked/unmarked"
^XMB(3.9,145946,2,5685,0)="""RTN"",""IBCNSU21"",202,0)"
^XMB(3.9,145946,2,5686,0)=" ;          WLIST   - Worklist, the user is selecting from."
^XMB(3.9,145946,2,5687,0)="""RTN"",""IBCNSU21"",203,0)"
^XMB(3.9,145946,2,5688,0)=" ;          NUMSEL  - Current # of selected policies"
^XMB(3.9,145946,2,5689,0)="""RTN"",""IBCNSU21"",204,0)"
^XMB(3.9,145946,2,5690,0)=" ;          ^TMP(""IBCNSU21A"",$J)- Current array of selected policies "
^XMB(3.9,145946,2,5691,0)="""RTN"",""IBCNSU21"",205,0)"
^XMB(3.9,145946,2,5692,0)=" ; Output:  Policy is marked or unmarked as selected"
^XMB(3.9,145946,2,5693,0)="""RTN"",""IBCNSU21"",206,0)"
^XMB(3.9,145946,2,5694,0)=" ;          NUMSEL  - Current # of selected policies"
^XMB(3.9,145946,2,5695,0)="""RTN"",""IBCNSU21"",207,0)"
^XMB(3.9,145946,2,5696,0)=" ;          ^TMP(""IBCNSU21A"",$J)- Updated array of selected policies "
^XMB(3.9,145946,2,5697,0)="""RTN"",""IBCNSU21"",208,0)"
^XMB(3.9,145946,2,5698,0)=" ;      "
^XMB(3.9,145946,2,5699,0)="""RTN"",""IBCNSU21"",209,0)"
^XMB(3.9,145946,2,5700,0)=" N TEXT"
^XMB(3.9,145946,2,5701,0)="""RTN"",""IBCNSU21"",210,0)"
^XMB(3.9,145946,2,5702,0)=" I WHICH D                                  ; Mark as selected"
^XMB(3.9,145946,2,5703,0)="""RTN"",""IBCNSU21"",211,0)"
^XMB(3.9,145946,2,5704,0)=" . S ^TMP(""IBCNSU21A"",$J,IIEN)="""""
^XMB(3.9,145946,2,5705,0)="""RTN"",""IBCNSU21"",212,0)"
^XMB(3.9,145946,2,5706,0)=" . S TEXT=LINE_"">"",NUMSEL=NUMSEL+1"
^XMB(3.9,145946,2,5707,0)="""RTN"",""IBCNSU21"",213,0)"
^XMB(3.9,145946,2,5708,0)=" E  D                                       ; Mark as unselected"
^XMB(3.9,145946,2,5709,0)="""RTN"",""IBCNSU21"",214,0)"
^XMB(3.9,145946,2,5710,0)=" . K ^TMP(""IBCNSU21A"",$J,IIEN)"
^XMB(3.9,145946,2,5711,0)="""RTN"",""IBCNSU21"",215,0)"
^XMB(3.9,145946,2,5712,0)=" . S TEXT=LINE,NUMSEL=NUMSEL-1"
^XMB(3.9,145946,2,5713,0)="""RTN"",""IBCNSU21"",216,0)"
^XMB(3.9,145946,2,5714,0)=" D FLDTEXT^VALM10(LINE,""CTR"",TEXT)          ; Update display"
^XMB(3.9,145946,2,5715,0)="""RTN"",""IBCNSU21"",217,0)"
^XMB(3.9,145946,2,5716,0)=" D WRITE^VALM10(LINE)                       ; Redisplay line"
^XMB(3.9,145946,2,5717,0)="""RTN"",""IBCNSU21"",218,0)"
^XMB(3.9,145946,2,5718,0)=" Q"
^XMB(3.9,145946,2,5719,0)="""RTN"",""IBCNSU21"",219,0)"
^XMB(3.9,145946,2,5720,0)=" ;"
^XMB(3.9,145946,2,5721,0)="""RTN"",""IBCNSU21"",220,0)"
^XMB(3.9,145946,2,5722,0)="SELPOL(FULL,DLINE,MULT,WLIST)    ;EP"
^XMB(3.9,145946,2,5723,0)="""RTN"",""IBCNSU21"",221,0)"
^XMB(3.9,145946,2,5724,0)=" ; Select Insurance Company(s) to on report"
^XMB(3.9,145946,2,5725,0)="""RTN"",""IBCNSU21"",222,0)"
^XMB(3.9,145946,2,5726,0)=" ; Also called from IBCNRDV1@UNSEL"
^XMB(3.9,145946,2,5727,0)="""RTN"",""IBCNSU21"",223,0)"
^XMB(3.9,145946,2,5728,0)=" ; Input:   FULL                    - 1 - full screen mode, 0 otherwise"
^XMB(3.9,145946,2,5729,0)="""RTN"",""IBCNSU21"",224,0)"
^XMB(3.9,145946,2,5730,0)=" ;          MULT                    - 1 to allow multiple entry selection"
^XMB(3.9,145946,2,5731,0)="""RTN"",""IBCNSU21"",225,0)"
^XMB(3.9,145946,2,5732,0)=" ;                                    0 to only allow single entry selection"
^XMB(3.9,145946,2,5733,0)="""RTN"",""IBCNSU21"",226,0)"
^XMB(3.9,145946,2,5734,0)=" ;                                    Optional, defaults to 0"
^XMB(3.9,145946,2,5735,0)="""RTN"",""IBCNSU21"",227,0)"
^XMB(3.9,145946,2,5736,0)=" ;          WLIST                   - Worklist, the user is selecting from"
^XMB(3.9,145946,2,5737,0)="""RTN"",""IBCNSU21"",228,0)"
^XMB(3.9,145946,2,5738,0)=" ;          ^TMP(""IBCNSU21IX"",$J)   - Index of displayed lines of the policy"
^XMB(3.9,145946,2,5739,0)="""RTN"",""IBCNSU21"",229,0)"
^XMB(3.9,145946,2,5740,0)=" ;                                    Selector Template. "
^XMB(3.9,145946,2,5741,0)="""RTN"",""IBCNSU21"",230,0)"
^XMB(3.9,145946,2,5742,0)=" ;                                    Only used when WLIST=""IBCNSU21IX"""
^XMB(3.9,145946,2,5743,0)="""RTN"",""IBCNSU21"",231,0)"
^XMB(3.9,145946,2,5744,0)=" ;          ^TMP(""IBCNSU21SIX"",$J)  - Index of displayed lines of the policy"
^XMB(3.9,145946,2,5745,0)="""RTN"",""IBCNSU21"",232,0)"
^XMB(3.9,145946,2,5746,0)=" ;                                    Selected Template"
^XMB(3.9,145946,2,5747,0)="""RTN"",""IBCNSU21"",233,0)"
^XMB(3.9,145946,2,5748,0)=" ;                                    Only used if WLIST is ""IBCNSU21SIX"""
^XMB(3.9,145946,2,5749,0)="""RTN"",""IBCNSU21"",234,0)"
^XMB(3.9,145946,2,5750,0)=" ; Output:  DLINE                   - Comma delimited list of Line #(s) of the "
^XMB(3.9,145946,2,5751,0)="""RTN"",""IBCNSU21"",235,0)"
^XMB(3.9,145946,2,5752,0)=" ;                                    selected Ins Cos"
^XMB(3.9,145946,2,5753,0)="""RTN"",""IBCNSU21"",236,0)"
^XMB(3.9,145946,2,5754,0)=" ; Returns: IIEN(s) - Comma delimited string or IENS for the selected policy(s)"
^XMB(3.9,145946,2,5755,0)="""RTN"",""IBCNSU21"",237,0)"
^XMB(3.9,145946,2,5756,0)=" ;          Error message and """" IENS if multi-selection and not allowed"
^XMB(3.9,145946,2,5757,0)="""RTN"",""IBCNSU21"",238,0)"
^XMB(3.9,145946,2,5758,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,IIEN,IIENS,IX,VALMY,X,Y"
^XMB(3.9,145946,2,5759,0)="""RTN"",""IBCNSU21"",239,0)"
^XMB(3.9,145946,2,5760,0)=" S:'$D(MULT) MULT=0"
^XMB(3.9,145946,2,5761,0)="""RTN"",""IBCNSU21"",240,0)"
^XMB(3.9,145946,2,5762,0)=" S:'$D(WLIST) WLIST=""IBCNSU21"""
^XMB(3.9,145946,2,5763,0)="""RTN"",""IBCNSU21"",241,0)"
^XMB(3.9,145946,2,5764,0)=" D:FULL FULL^VALM1"
^XMB(3.9,145946,2,5765,0)="""RTN"",""IBCNSU21"",242,0)"
^XMB(3.9,145946,2,5766,0)=" S DLINE=$P($P($G(XQORNOD(0)),""^"",4),""="",2)     ; User selection with action"
^XMB(3.9,145946,2,5767,0)="""RTN"",""IBCNSU21"",243,0)"
^XMB(3.9,145946,2,5768,0)=" S DLINE=$TR(DLINE,""/\; ."","",,,,,"")             ; Check for multi-selection"
^XMB(3.9,145946,2,5769,0)="""RTN"",""IBCNSU21"",244,0)"
^XMB(3.9,145946,2,5770,0)=" S IIENS="""""
^XMB(3.9,145946,2,5771,0)="""RTN"",""IBCNSU21"",245,0)"
^XMB(3.9,145946,2,5772,0)=" I 'MULT,DLINE["","" D  Q """"                      ; Invalid multi-selection"
^XMB(3.9,145946,2,5773,0)="""RTN"",""IBCNSU21"",246,0)"
^XMB(3.9,145946,2,5774,0)=" . W !,*7,"">>>> Only single entry selection is allowed"""
^XMB(3.9,145946,2,5775,0)="""RTN"",""IBCNSU21"",247,0)"
^XMB(3.9,145946,2,5776,0)=" . S DLINE="""""
^XMB(3.9,145946,2,5777,0)="""RTN"",""IBCNSU21"",248,0)"
^XMB(3.9,145946,2,5778,0)=" . K DIR"
^XMB(3.9,145946,2,5779,0)="""RTN"",""IBCNSU21"",249,0)"
^XMB(3.9,145946,2,5780,0)=" . D PAUSE^VALM1"
^XMB(3.9,145946,2,5781,0)="""RTN"",""IBCNSU21"",250,0)"
^XMB(3.9,145946,2,5782,0)=" ;"
^XMB(3.9,145946,2,5783,0)="""RTN"",""IBCNSU21"",251,0)"
^XMB(3.9,145946,2,5784,0)=" ; Let the user enter their selection(s)"
^XMB(3.9,145946,2,5785,0)="""RTN"",""IBCNSU21"",252,0)"
^XMB(3.9,145946,2,5786,0)=" D EN^VALM2($G(XQORNOD(0)),""O"")                 ; ListMan generic selector"
^XMB(3.9,145946,2,5787,0)="""RTN"",""IBCNSU21"",253,0)"
^XMB(3.9,145946,2,5788,0)=" I '$D(VALMY) Q """""
^XMB(3.9,145946,2,5789,0)="""RTN"",""IBCNSU21"",254,0)"
^XMB(3.9,145946,2,5790,0)=" S IX="""",DLINE="""""
^XMB(3.9,145946,2,5791,0)="""RTN"",""IBCNSU21"",255,0)"
^XMB(3.9,145946,2,5792,0)=" F  D  Q:IX="""""
^XMB(3.9,145946,2,5793,0)="""RTN"",""IBCNSU21"",256,0)"
^XMB(3.9,145946,2,5794,0)=" . S IX=$O(VALMY(IX))"
^XMB(3.9,145946,2,5795,0)="""RTN"",""IBCNSU21"",257,0)"
^XMB(3.9,145946,2,5796,0)=" . Q:IX="""""
^XMB(3.9,145946,2,5797,0)="""RTN"",""IBCNSU21"",258,0)"
^XMB(3.9,145946,2,5798,0)=" . S DLINE=$S(DLINE="""":IX,1:DLINE_"",""_IX)"
^XMB(3.9,145946,2,5799,0)="""RTN"",""IBCNSU21"",259,0)"
^XMB(3.9,145946,2,5800,0)=" . S IIEN=$G(^TMP(WLIST,$J,IX))"
^XMB(3.9,145946,2,5801,0)="""RTN"",""IBCNSU21"",260,0)"
^XMB(3.9,145946,2,5802,0)=" . S IIENS=$S(IIENS="""":IIEN,1:IIENS_"",""_IIEN)"
^XMB(3.9,145946,2,5803,0)="""RTN"",""IBCNSU21"",261,0)"
^XMB(3.9,145946,2,5804,0)=" Q IIENS"
^XMB(3.9,145946,2,5805,0)="""RTN"",""IBCNSU21"",262,0)"
^XMB(3.9,145946,2,5806,0)=" ;"
^XMB(3.9,145946,2,5807,0)="""RTN"",""IBCNSU21"",263,0)"
^XMB(3.9,145946,2,5808,0)="SHOWSEL ;EP"
^XMB(3.9,145946,2,5809,0)="""RTN"",""IBCNSU21"",264,0)"
^XMB(3.9,145946,2,5810,0)=" ; Protocol action used to display a listman template of the currently"
^XMB(3.9,145946,2,5811,0)="""RTN"",""IBCNSU21"",265,0)"
^XMB(3.9,145946,2,5812,0)=" ; selected policies"
^XMB(3.9,145946,2,5813,0)="""RTN"",""IBCNSU21"",266,0)"
^XMB(3.9,145946,2,5814,0)=" ; Input:   NUMSEL                      - Current number of selected policies"
^XMB(3.9,145946,2,5815,0)="""RTN"",""IBCNSU21"",267,0)"
^XMB(3.9,145946,2,5816,0)=" ;          ^TMP(""IBCNSU21A"",$J,IEN)    - Current Array of selected policies"
^XMB(3.9,145946,2,5817,0)="""RTN"",""IBCNSU21"",268,0)"
^XMB(3.9,145946,2,5818,0)=" ; Output:  NUMSEL                      - Updated number of selected policies"
^XMB(3.9,145946,2,5819,0)="""RTN"",""IBCNSU21"",269,0)"
^XMB(3.9,145946,2,5820,0)=" ;          ^TMP(""IBCNSU21A"",$J,IEN)    - Updated Array of selected policies"
^XMB(3.9,145946,2,5821,0)="""RTN"",""IBCNSU21"",270,0)"
^XMB(3.9,145946,2,5822,0)=" S VALMBCK=""R"",SELECTED=1"
^XMB(3.9,145946,2,5823,0)="""RTN"",""IBCNSU21"",271,0)"
^XMB(3.9,145946,2,5824,0)=" D EN^VALM(""IBCNS POLICIES SELECTED"")"
^XMB(3.9,145946,2,5825,0)="""RTN"",""IBCNSU21"",272,0)"
^XMB(3.9,145946,2,5826,0)=" I '$D(IBFASTXT) D HDR,INIT"
^XMB(3.9,145946,2,5827,0)="""RTN"",""IBCNSU21"",273,0)"
^XMB(3.9,145946,2,5828,0)=" Q"
^XMB(3.9,145946,2,5829,0)="""RTN"",""IBCNSU21"",274,0)"
^XMB(3.9,145946,2,5830,0)=" ;"
^XMB(3.9,145946,2,5831,0)="""RTN"",""IBCNSU21"",275,0)"
^XMB(3.9,145946,2,5832,0)="INIT2 ;EP for Show Selections"
^XMB(3.9,145946,2,5833,0)="""RTN"",""IBCNSU21"",276,0)"
^XMB(3.9,145946,2,5834,0)=" ; Initialize variables and list array"
^XMB(3.9,145946,2,5835,0)="""RTN"",""IBCNSU21"",277,0)"
^XMB(3.9,145946,2,5836,0)=" ; Input: None"
^XMB(3.9,145946,2,5837,0)="""RTN"",""IBCNSU21"",278,0)"
^XMB(3.9,145946,2,5838,0)=" ; Output:  ^TMP(""IBCNSU21S"",$J) - Body lines to display"
^XMB(3.9,145946,2,5839,0)="""RTN"",""IBCNSU21"",279,0)"
^XMB(3.9,145946,2,5840,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,5841,0)="""RTN"",""IBCNSU21"",280,0)"
^XMB(3.9,145946,2,5842,0)=" K ^TMP(""IBCNSU21S"",$J),^TMP(""IBCNSU21SIX"",$J)"
^XMB(3.9,145946,2,5843,0)="""RTN"",""IBCNSU21"",281,0)"
^XMB(3.9,145946,2,5844,0)=" D BLD2"
^XMB(3.9,145946,2,5845,0)="""RTN"",""IBCNSU21"",282,0)"
^XMB(3.9,145946,2,5846,0)=" Q"
^XMB(3.9,145946,2,5847,0)="""RTN"",""IBCNSU21"",283,0)"
^XMB(3.9,145946,2,5848,0)=" ;"
^XMB(3.9,145946,2,5849,0)="""RTN"",""IBCNSU21"",284,0)"
^XMB(3.9,145946,2,5850,0)="BLD2 ; Build listman body for Show Selections"
^XMB(3.9,145946,2,5851,0)="""RTN"",""IBCNSU21"",285,0)"
^XMB(3.9,145946,2,5852,0)=" ; Input:   None"
^XMB(3.9,145946,2,5853,0)="""RTN"",""IBCNSU21"",286,0)"
^XMB(3.9,145946,2,5854,0)=" ; Output:  VALMCNT   - Total number of lines displayed in the body"
^XMB(3.9,145946,2,5855,0)="""RTN"",""IBCNSU21"",287,0)"
^XMB(3.9,145946,2,5856,0)=" ;          ^TMP(""IBCNSU21S"",$J)   - Body lines to display"
^XMB(3.9,145946,2,5857,0)="""RTN"",""IBCNSU21"",288,0)"
^XMB(3.9,145946,2,5858,0)=" ;          ^TMP(""IBCNSU21SIX"",$J) - Index of Entry IENs by display line"
^XMB(3.9,145946,2,5859,0)="""RTN"",""IBCNSU21"",289,0)"
^XMB(3.9,145946,2,5860,0)=" N IIEN,LINE"
^XMB(3.9,145946,2,5861,0)="""RTN"",""IBCNSU21"",290,0)"
^XMB(3.9,145946,2,5862,0)=" ;"
^XMB(3.9,145946,2,5863,0)="""RTN"",""IBCNSU21"",291,0)"
^XMB(3.9,145946,2,5864,0)=" ; Build the lines to be displayed"
^XMB(3.9,145946,2,5865,0)="""RTN"",""IBCNSU21"",292,0)"
^XMB(3.9,145946,2,5866,0)=" S (IIEN,VALMCNT)=0"
^XMB(3.9,145946,2,5867,0)="""RTN"",""IBCNSU21"",293,0)"
^XMB(3.9,145946,2,5868,0)=" F  S IIEN=$O(^TMP(""IBCNSU21A"",$J,IIEN)) Q:'IIEN  D"
^XMB(3.9,145946,2,5869,0)="""RTN"",""IBCNSU21"",294,0)"
^XMB(3.9,145946,2,5870,0)=" . S VALMCNT=VALMCNT+1"
^XMB(3.9,145946,2,5871,0)="""RTN"",""IBCNSU21"",295,0)"
^XMB(3.9,145946,2,5872,0)=" . S LINE=$$BLDLN(VALMCNT,IIEN)"
^XMB(3.9,145946,2,5873,0)="""RTN"",""IBCNSU21"",296,0)"
^XMB(3.9,145946,2,5874,0)=" . D SET^VALM10(VALMCNT,LINE,LINE)"
^XMB(3.9,145946,2,5875,0)="""RTN"",""IBCNSU21"",297,0)"
^XMB(3.9,145946,2,5876,0)=" . S ^TMP(""IBCNSU21SIX"",$J,VALMCNT)=IIEN"
^XMB(3.9,145946,2,5877,0)="""RTN"",""IBCNSU21"",298,0)"
^XMB(3.9,145946,2,5878,0)=" ;"
^XMB(3.9,145946,2,5879,0)="""RTN"",""IBCNSU21"",299,0)"
^XMB(3.9,145946,2,5880,0)=" I VALMCNT=0 D"
^XMB(3.9,145946,2,5881,0)="""RTN"",""IBCNSU21"",300,0)"
^XMB(3.9,145946,2,5882,0)=" . S ^TMP(""IBCNSU21S"",$J,1,0)=""No Selected Policies were found."""
^XMB(3.9,145946,2,5883,0)="""RTN"",""IBCNSU21"",301,0)"
^XMB(3.9,145946,2,5884,0)=" Q"
^XMB(3.9,145946,2,5885,0)="""RTN"",""IBCNSU21"",302,0)"
^XMB(3.9,145946,2,5886,0)=" ;"
^XMB(3.9,145946,2,5887,0)="""RTN"",""IBCNSU21"",303,0)"
^XMB(3.9,145946,2,5888,0)="EXIT2 ;EP for Show Selections"
^XMB(3.9,145946,2,5889,0)="""RTN"",""IBCNSU21"",304,0)"
^XMB(3.9,145946,2,5890,0)=" ; Exit code"
^XMB(3.9,145946,2,5891,0)="""RTN"",""IBCNSU21"",305,0)"
^XMB(3.9,145946,2,5892,0)=" ; Input: None"
^XMB(3.9,145946,2,5893,0)="""RTN"",""IBCNSU21"",306,0)"
^XMB(3.9,145946,2,5894,0)=" K ^TMP(""IBCNSU21S"",$J),^TMP(""IBCNSU21SIX"",$J)"
^XMB(3.9,145946,2,5895,0)="""RTN"",""IBCNSU21"",307,0)"
^XMB(3.9,145946,2,5896,0)=" D CLEAR^VALM1"
^XMB(3.9,145946,2,5897,0)="""RTN"",""IBCNSU21"",308,0)"
^XMB(3.9,145946,2,5898,0)=" Q"
^XMB(3.9,145946,2,5899,0)="""RTN"",""IBCNSU21"",309,0)"
^XMB(3.9,145946,2,5900,0)=" ;"
^XMB(3.9,145946,2,5901,0)="""RTN"",""IBCNSU21"",310,0)"
^XMB(3.9,145946,2,5902,0)="HELP  ;"
^XMB(3.9,145946,2,5903,0)="""RTN"",""IBCNSU21"",311,0)"
^XMB(3.9,145946,2,5904,0)=" Q"
^XMB(3.9,145946,2,5905,0)="""RTN"",""IBCNSU21"",312,0)"
^XMB(3.9,145946,2,5906,0)=" ;"
^XMB(3.9,145946,2,5907,0)="""RTN"",""IBCNSU21"",313,0)"
^XMB(3.9,145946,2,5908,0)="PLANOK(DATA,IBACT,IBNANU,IBFLT) ;Check to see if plan qualifies"
^XMB(3.9,145946,2,5909,0)="""RTN"",""IBCNSU21"",314,0)"
^XMB(3.9,145946,2,5910,0)=" ;Input:"
^XMB(3.9,145946,2,5911,0)="""RTN"",""IBCNSU21"",315,0)"
^XMB(3.9,145946,2,5912,0)=" ;DATA   - This array is passed by reference.  It is constructed by the SETS^DIQ call:"
^XMB(3.9,145946,2,5913,0)="""RTN"",""IBCNSU21"",316,0)"
^XMB(3.9,145946,2,5914,0)=" ;           D GETS^DIQ(355.3,+IBP_"","","".02;.05;.06;.07;.08;.09;.11;2.01;2.02"",""EI"",""PLANDATA"")"
^XMB(3.9,145946,2,5915,0)="""RTN"",""IBCNSU21"",317,0)"
^XMB(3.9,145946,2,5916,0)=" ;         It must contain the following fields:"
^XMB(3.9,145946,2,5917,0)="""RTN"",""IBCNSU21"",318,0)"
^XMB(3.9,145946,2,5918,0)=" ;         .11 - INACTIVE"
^XMB(3.9,145946,2,5919,0)="""RTN"",""IBCNSU21"",319,0)"
^XMB(3.9,145946,2,5920,0)=" ;         2.01 - GROUP NAME"
^XMB(3.9,145946,2,5921,0)="""RTN"",""IBCNSU21"",320,0)"
^XMB(3.9,145946,2,5922,0)=" ;         2.02 - GROUP NUMBER"
^XMB(3.9,145946,2,5923,0)="""RTN"",""IBCNSU21"",321,0)"
^XMB(3.9,145946,2,5924,0)=" ;"
^XMB(3.9,145946,2,5925,0)="""RTN"",""IBCNSU21"",322,0)"
^XMB(3.9,145946,2,5926,0)=" ;IBACT  - 0 - INACTIVE Group Plans Only"
^XMB(3.9,145946,2,5927,0)="""RTN"",""IBCNSU21"",323,0)"
^XMB(3.9,145946,2,5928,0)=" ;         1 - ACTIVE Group Plans Only"
^XMB(3.9,145946,2,5929,0)="""RTN"",""IBCNSU21"",324,0)"
^XMB(3.9,145946,2,5930,0)=" ;         2 - Both ACTIVE and INACTIVE Group Plans"
^XMB(3.9,145946,2,5931,0)="""RTN"",""IBCNSU21"",325,0)"
^XMB(3.9,145946,2,5932,0)=" ;"
^XMB(3.9,145946,2,5933,0)="""RTN"",""IBCNSU21"",326,0)"
^XMB(3.9,145946,2,5934,0)=" ;IBNANU - 1 - Check GROUP NAME only"
^XMB(3.9,145946,2,5935,0)="""RTN"",""IBCNSU21"",327,0)"
^XMB(3.9,145946,2,5936,0)=" ;         2 - Check GROUP NUMBER only"
^XMB(3.9,145946,2,5937,0)="""RTN"",""IBCNSU21"",328,0)"
^XMB(3.9,145946,2,5938,0)=" ;         3 - Check BOTH"
^XMB(3.9,145946,2,5939,0)="""RTN"",""IBCNSU21"",329,0)"
^XMB(3.9,145946,2,5940,0)=" ;"
^XMB(3.9,145946,2,5941,0)="""RTN"",""IBCNSU21"",330,0)"
^XMB(3.9,145946,2,5942,0)=" N IBP,INACTIVE,OK"
^XMB(3.9,145946,2,5943,0)="""RTN"",""IBCNSU21"",331,0)"
^XMB(3.9,145946,2,5944,0)=" S OK=0"
^XMB(3.9,145946,2,5945,0)="""RTN"",""IBCNSU21"",332,0)"
^XMB(3.9,145946,2,5946,0)=" S IBP=$O(DATA(355.3,""""))"
^XMB(3.9,145946,2,5947,0)="""RTN"",""IBCNSU21"",333,0)"
^XMB(3.9,145946,2,5948,0)=" S INACTIVE=$G(DATA(355.3,IBP,.11,""I""))  ;1=Inactive, 0=Active"
^XMB(3.9,145946,2,5949,0)="""RTN"",""IBCNSU21"",334,0)"
^XMB(3.9,145946,2,5950,0)=" I 'INACTIVE,'IBACT G PLANOKX   ; Plan is Active and looking for Inactive only"
^XMB(3.9,145946,2,5951,0)="""RTN"",""IBCNSU21"",335,0)"
^XMB(3.9,145946,2,5952,0)=" I INACTIVE,(IBACT=1) G PLANOKX   ; Plan is Inactive and looking for Active only"
^XMB(3.9,145946,2,5953,0)="""RTN"",""IBCNSU21"",336,0)"
^XMB(3.9,145946,2,5954,0)=" ;"
^XMB(3.9,145946,2,5955,0)="""RTN"",""IBCNSU21"",337,0)"
^XMB(3.9,145946,2,5956,0)=" I 'IBFLT G PLANOKX  ;Exit if no filter defined."
^XMB(3.9,145946,2,5957,0)="""RTN"",""IBCNSU21"",338,0)"
^XMB(3.9,145946,2,5958,0)=" ;"
^XMB(3.9,145946,2,5959,0)="""RTN"",""IBCNSU21"",339,0)"
^XMB(3.9,145946,2,5960,0)=" I IBNANU=1!(IBNANU=3) D  I OK G PLANOKX  ;GROUP NAME only or Both"
^XMB(3.9,145946,2,5961,0)="""RTN"",""IBCNSU21"",340,0)"
^XMB(3.9,145946,2,5962,0)=" . S OK=$$FILTER($G(DATA(355.3,IBP,2.01,""E"")),IBFLT)"
^XMB(3.9,145946,2,5963,0)="""RTN"",""IBCNSU21"",341,0)"
^XMB(3.9,145946,2,5964,0)=" I IBNANU=2!(IBNANU=3) D  ;GROUP NUMNBER only or Both"
^XMB(3.9,145946,2,5965,0)="""RTN"",""IBCNSU21"",342,0)"
^XMB(3.9,145946,2,5966,0)=" . S OK=$$FILTER($G(DATA(355.3,IBP,2.02,""E"")),IBFLT)"
^XMB(3.9,145946,2,5967,0)="""RTN"",""IBCNSU21"",343,0)"
^XMB(3.9,145946,2,5968,0)="PLANOKX ;Exit"
^XMB(3.9,145946,2,5969,0)="""RTN"",""IBCNSU21"",344,0)"
^XMB(3.9,145946,2,5970,0)=" Q OK"
^XMB(3.9,145946,2,5971,0)="""RTN"",""IBCNSU21"",345,0)"
^XMB(3.9,145946,2,5972,0)=" ;"
^XMB(3.9,145946,2,5973,0)="""RTN"",""IBCNSU21"",346,0)"
^XMB(3.9,145946,2,5974,0)="FILTER(STR,FLT) ; Filter Group Name or Number"
^XMB(3.9,145946,2,5975,0)="""RTN"",""IBCNSU21"",347,0)"
^XMB(3.9,145946,2,5976,0)=" ;IBFLT A^B^C"
^XMB(3.9,145946,2,5977,0)="""RTN"",""IBCNSU21"",348,0)"
^XMB(3.9,145946,2,5978,0)=" ;         A - 1 - Search for Group(s) that begin with"
^XMB(3.9,145946,2,5979,0)="""RTN"",""IBCNSU21"",349,0)"
^XMB(3.9,145946,2,5980,0)=" ;                 the specified text (case insensitive)"
^XMB(3.9,145946,2,5981,0)="""RTN"",""IBCNSU21"",350,0)"
^XMB(3.9,145946,2,5982,0)=" ;             2 - Search for Group(s) that contain"
^XMB(3.9,145946,2,5983,0)="""RTN"",""IBCNSU21"",351,0)"
^XMB(3.9,145946,2,5984,0)=" ;                 the specified text (case insensitive)"
^XMB(3.9,145946,2,5985,0)="""RTN"",""IBCNSU21"",352,0)"
^XMB(3.9,145946,2,5986,0)=" ;             3 - Search for Group(s) in a specified"
^XMB(3.9,145946,2,5987,0)="""RTN"",""IBCNSU21"",353,0)"
^XMB(3.9,145946,2,5988,0)=" ;                 range (inclusive, case insensitive)"
^XMB(3.9,145946,2,5989,0)="""RTN"",""IBCNSU21"",354,0)"
^XMB(3.9,145946,2,5990,0)=" ;             4 - Search for Group(s) that are blank (null)"
^XMB(3.9,145946,2,5991,0)="""RTN"",""IBCNSU21"",355,0)"
^XMB(3.9,145946,2,5992,0)=" ;         B - Begin with text if A=1, Contains Text if A=2 or"
^XMB(3.9,145946,2,5993,0)="""RTN"",""IBCNSU21"",356,0)"
^XMB(3.9,145946,2,5994,0)=" ;             the range start if A=3"
^XMB(3.9,145946,2,5995,0)="""RTN"",""IBCNSU21"",357,0)"
^XMB(3.9,145946,2,5996,0)=" ;         C - Range End text (only present when A=3)"
^XMB(3.9,145946,2,5997,0)="""RTN"",""IBCNSU21"",358,0)"
^XMB(3.9,145946,2,5998,0)=" ;"
^XMB(3.9,145946,2,5999,0)="""RTN"",""IBCNSU21"",359,0)"
^XMB(3.9,145946,2,6000,0)=" N BEG,CHR,END,OK,TYPE"
^XMB(3.9,145946,2,6001,0)="""RTN"",""IBCNSU21"",360,0)"
^XMB(3.9,145946,2,6002,0)=" S STR=$$UP^XLFSTR(STR)"
^XMB(3.9,145946,2,6003,0)="""RTN"",""IBCNSU21"",361,0)"
^XMB(3.9,145946,2,6004,0)=" S TYPE=$P(FLT,U,1)"
^XMB(3.9,145946,2,6005,0)="""RTN"",""IBCNSU21"",362,0)"
^XMB(3.9,145946,2,6006,0)=" S BEG=$$UP^XLFSTR($P(FLT,U,2))"
^XMB(3.9,145946,2,6007,0)="""RTN"",""IBCNSU21"",363,0)"
^XMB(3.9,145946,2,6008,0)=" S END=$$UP^XLFSTR($P(FLT,U,3))"
^XMB(3.9,145946,2,6009,0)="""RTN"",""IBCNSU21"",364,0)"
^XMB(3.9,145946,2,6010,0)=" S OK=0"
^XMB(3.9,145946,2,6011,0)="""RTN"",""IBCNSU21"",365,0)"
^XMB(3.9,145946,2,6012,0)=" ;Blank"
^XMB(3.9,145946,2,6013,0)="""RTN"",""IBCNSU21"",366,0)"
^XMB(3.9,145946,2,6014,0)=" I TYPE=4 D  G FILTERX"
^XMB(3.9,145946,2,6015,0)="""RTN"",""IBCNSU21"",367,0)"
^XMB(3.9,145946,2,6016,0)=" . I STR="""" S OK=1"
^XMB(3.9,145946,2,6017,0)="""RTN"",""IBCNSU21"",368,0)"
^XMB(3.9,145946,2,6018,0)=" ;Test begins with"
^XMB(3.9,145946,2,6019,0)="""RTN"",""IBCNSU21"",369,0)"
^XMB(3.9,145946,2,6020,0)=" I TYPE=1 D  G FILTERX"
^XMB(3.9,145946,2,6021,0)="""RTN"",""IBCNSU21"",370,0)"
^XMB(3.9,145946,2,6022,0)=" . I ($E(STR,1,$L(BEG))=BEG) S OK=1"
^XMB(3.9,145946,2,6023,0)="""RTN"",""IBCNSU21"",371,0)"
^XMB(3.9,145946,2,6024,0)=" ;Test contains"
^XMB(3.9,145946,2,6025,0)="""RTN"",""IBCNSU21"",372,0)"
^XMB(3.9,145946,2,6026,0)=" I TYPE=2 D  G FILTERX"
^XMB(3.9,145946,2,6027,0)="""RTN"",""IBCNSU21"",373,0)"
^XMB(3.9,145946,2,6028,0)=" . I (STR[BEG) S OK=1"
^XMB(3.9,145946,2,6029,0)="""RTN"",""IBCNSU21"",374,0)"
^XMB(3.9,145946,2,6030,0)=" ;Test range"
^XMB(3.9,145946,2,6031,0)="""RTN"",""IBCNSU21"",375,0)"
^XMB(3.9,145946,2,6032,0)=" I TYPE=3 D  G FILTERX"
^XMB(3.9,145946,2,6033,0)="""RTN"",""IBCNSU21"",376,0)"
^XMB(3.9,145946,2,6034,0)=" . N XX"
^XMB(3.9,145946,2,6035,0)="""RTN"",""IBCNSU21"",377,0)"
^XMB(3.9,145946,2,6036,0)=" . S XX=$E(STR,1,$L(BEG))"
^XMB(3.9,145946,2,6037,0)="""RTN"",""IBCNSU21"",378,0)"
^XMB(3.9,145946,2,6038,0)=" . I XX=BEG S OK=1 Q   ;Matches begining characters of BEG - include"
^XMB(3.9,145946,2,6039,0)="""RTN"",""IBCNSU21"",379,0)"
^XMB(3.9,145946,2,6040,0)=" . I XX']BEG Q         ;Preceeds Beg search"
^XMB(3.9,145946,2,6041,0)="""RTN"",""IBCNSU21"",380,0)"
^XMB(3.9,145946,2,6042,0)=" . S XX=$E(STR,1,$L(END))"
^XMB(3.9,145946,2,6043,0)="""RTN"",""IBCNSU21"",381,0)"
^XMB(3.9,145946,2,6044,0)=" . I XX=END S OK=1 Q   ;Matches beginning characters of END - include"
^XMB(3.9,145946,2,6045,0)="""RTN"",""IBCNSU21"",382,0)"
^XMB(3.9,145946,2,6046,0)=" . I XX]END Q          ;Follows End search"
^XMB(3.9,145946,2,6047,0)="""RTN"",""IBCNSU21"",383,0)"
^XMB(3.9,145946,2,6048,0)=" . S OK=1"
^XMB(3.9,145946,2,6049,0)="""RTN"",""IBCNSU21"",384,0)"
^XMB(3.9,145946,2,6050,0)="FILTERX ; Exit"
^XMB(3.9,145946,2,6051,0)="""RTN"",""IBCNSU21"",385,0)"
^XMB(3.9,145946,2,6052,0)=" Q OK"
^XMB(3.9,145946,2,6053,0)="""RTN"",""IBCNSU21"",386,0)"
^XMB(3.9,145946,2,6054,0)=" ;"
^XMB(3.9,145946,2,6055,0)="""RTN"",""IBCOPP"")"
^XMB(3.9,145946,2,6056,0)="0^11^B31702280"
^XMB(3.9,145946,2,6057,0)="""RTN"",""IBCOPP"",1,0)"
^XMB(3.9,145946,2,6058,0)="IBCOPP ;ALB/NLR - LIST INS. PLANS BY CO. (DRIVER) ; 20-OCT-2015"
^XMB(3.9,145946,2,6059,0)="""RTN"",""IBCOPP"",2,0)"
^XMB(3.9,145946,2,6060,0)=" ;;2.0;INTEGRATED BILLING;**28,62,528,549**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,6061,0)="""RTN"",""IBCOPP"",3,0)"
^XMB(3.9,145946,2,6062,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,6063,0)="""RTN"",""IBCOPP"",4,0)"
^XMB(3.9,145946,2,6064,0)=" ;"
^XMB(3.9,145946,2,6065,0)="""RTN"",""IBCOPP"",5,0)"
^XMB(3.9,145946,2,6066,0)="EN ; Describe report"
^XMB(3.9,145946,2,6067,0)="""RTN"",""IBCOPP"",6,0)"
^XMB(3.9,145946,2,6068,0)=" ; IB*2.0*549 - reworded report description"
^XMB(3.9,145946,2,6069,0)="""RTN"",""IBCOPP"",7,0)"
^XMB(3.9,145946,2,6070,0)=" W !!?5,""This report will generate a list of insurance plans by company."""
^XMB(3.9,145946,2,6071,0)="""RTN"",""IBCOPP"",8,0)"
^XMB(3.9,145946,2,6072,0)=" W !?5,""It will help you identify duplicates.  You must select one, many"""
^XMB(3.9,145946,2,6073,0)="""RTN"",""IBCOPP"",9,0)"
^XMB(3.9,145946,2,6074,0)=" W !?5,""or all of the insurance companies; anywhere from one to all of the"""
^XMB(3.9,145946,2,6075,0)="""RTN"",""IBCOPP"",10,0)"
^XMB(3.9,145946,2,6076,0)=" W !?5,""plans under each company; and whether to include the patient policies"""
^XMB(3.9,145946,2,6077,0)="""RTN"",""IBCOPP"",11,0)"
^XMB(3.9,145946,2,6078,0)=" W !?5,""(subscribers) under each plan.  The number of plans you select is """
^XMB(3.9,145946,2,6079,0)="""RTN"",""IBCOPP"",12,0)"
^XMB(3.9,145946,2,6080,0)=" W !?5,""independent for each company you are including, but the subscriber"""
^XMB(3.9,145946,2,6081,0)="""RTN"",""IBCOPP"",13,0)"
^XMB(3.9,145946,2,6082,0)=" W !?5,""is the same (all or none) for all companies and plans within this report."""
^XMB(3.9,145946,2,6083,0)="""RTN"",""IBCOPP"",14,0)"
^XMB(3.9,145946,2,6084,0)=" W !?5,""Regardless of how you run the report, the number of group plans per"""
^XMB(3.9,145946,2,6085,0)="""RTN"",""IBCOPP"",15,0)"
^XMB(3.9,145946,2,6086,0)=" W !?5,""insurance company and the number of subscribers per plan will be"""
^XMB(3.9,145946,2,6087,0)="""RTN"",""IBCOPP"",16,0)"
^XMB(3.9,145946,2,6088,0)=" W !?5,""included."",!!"
^XMB(3.9,145946,2,6089,0)="""RTN"",""IBCOPP"",17,0)"
^XMB(3.9,145946,2,6090,0)=" ;"
^XMB(3.9,145946,2,6091,0)="""RTN"",""IBCOPP"",18,0)"
