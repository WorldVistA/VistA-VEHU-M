^XMB(3.9,145946,2,5424,0)=" S X2=$$GET1^DIQ(36,+IBCNS_"","",.133) I X2']"""" S X2=""<not filed>"""
^XMB(3.9,145946,2,5425,0)="""RTN"",""IBCNSU21"",72,0)"
^XMB(3.9,145946,2,5426,0)=" S X1=""Precerts: ""_X2"
^XMB(3.9,145946,2,5427,0)="""RTN"",""IBCNSU21"",73,0)"
^XMB(3.9,145946,2,5428,0)=" S X2=$$GET1^DIQ(36,+IBCNS_"","",.111) I X2']"""" S X2=""<no street address>"""
^XMB(3.9,145946,2,5429,0)="""RTN"",""IBCNSU21"",74,0)"
