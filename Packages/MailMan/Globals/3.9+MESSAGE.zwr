^XMB(3.9,145958,2,779,0)="""RTN"",""OCXOERR"",73,0)"
^XMB(3.9,145958,2,780,0)=" ;"
^XMB(3.9,145958,2,781,0)="""RTN"",""OCXOERR"",74,0)"
^XMB(3.9,145958,2,782,0)="PROC(OCXORD,OUTMSG) ;"
^XMB(3.9,145958,2,783,0)="""RTN"",""OCXOERR"",75,0)"
^XMB(3.9,145958,2,784,0)=" D SILENT(OCXORD,.OUTMSG)"
^XMB(3.9,145958,2,785,0)="""RTN"",""OCXOERR"",76,0)"
^XMB(3.9,145958,2,786,0)=" Q"
^XMB(3.9,145958,2,787,0)="""RTN"",""OCXOERR"",77,0)"
^XMB(3.9,145958,2,788,0)=" ;"
^XMB(3.9,145958,2,789,0)="""RTN"",""OCXOERR"",78,0)"
^XMB(3.9,145958,2,790,0)="EN(OCXORD) ;"
^XMB(3.9,145958,2,791,0)="""RTN"",""OCXOERR"",79,0)"
^XMB(3.9,145958,2,792,0)=" N OUTMSG S OUTMSG="""""
^XMB(3.9,145958,2,793,0)="""RTN"",""OCXOERR"",80,0)"
^XMB(3.9,145958,2,794,0)=" D SILENT(OCXORD,.OUTMSG) Q"
^XMB(3.9,145958,2,795,0)="""RTN"",""OCXOERR"",81,0)"
^XMB(3.9,145958,2,796,0)=" ;"
^XMB(3.9,145958,2,797,0)="""RTN"",""ORCFLAG"")"
^XMB(3.9,145958,2,798,0)="0^3^B21880963"
^XMB(3.9,145958,2,799,0)="""RTN"",""ORCFLAG"",1,0)"
^XMB(3.9,145958,2,800,0)="ORCFLAG ; SLC/MKB - Flag orders ;12/26/2006"
^XMB(3.9,145958,2,801,0)="""RTN"",""ORCFLAG"",2,0)"
^XMB(3.9,145958,2,802,0)=" ;;3.0;ORDER ENTRY/RESULTS REPORTING;**141,243**;Dec 17, 1997;Build 0"
^XMB(3.9,145958,2,803,0)="""RTN"",""ORCFLAG"",3,0)"
^XMB(3.9,145958,2,804,0)=" ;"
^XMB(3.9,145958,2,805,0)="""RTN"",""ORCFLAG"",4,0)"
^XMB(3.9,145958,2,806,0)="EN1(ORIFN) ; -- standalone entry point to un/flag order ORIFN"
^XMB(3.9,145958,2,807,0)="""RTN"",""ORCFLAG"",5,0)"
^XMB(3.9,145958,2,808,0)=" N ORLK,ORERR,VA,VADM,VAERR,DFN,ORVP,ORPNM,ORSSN,ORAGE,ORACTN,ORPS"
^XMB(3.9,145958,2,809,0)="""RTN"",""ORCFLAG"",6,0)"
^XMB(3.9,145958,2,810,0)=" Q:'$G(ORIFN)  S:'$P(ORIFN,"";"",2) ORIFN=+ORIFN_"";1"""
^XMB(3.9,145958,2,811,0)="""RTN"",""ORCFLAG"",7,0)"
^XMB(3.9,145958,2,812,0)=" S ORVP=$P($G(^OR(100,+ORIFN,0)),U,2),DFN=+ORVP I 'ORVP!'$D(^(8,+$P(ORIFN,"";"",2),0)) W !,""Missing or invalid order!"" H 1 Q"
^XMB(3.9,145958,2,813,0)="""RTN"",""ORCFLAG"",8,0)"
^XMB(3.9,145958,2,814,0)=" D DEM^VADPT S ORPNM=VADM(1),ORSSN=$P(VADM(2),U,2),ORAGE=VADM(4)"
^XMB(3.9,145958,2,815,0)="""RTN"",""ORCFLAG"",9,0)"
^XMB(3.9,145958,2,816,0)=" S ORACTN=$S($G(^OR(100,+ORIFN,8,+$P(ORIFN,"";"",2),3)):""UF"",1:""FL"")"
^XMB(3.9,145958,2,817,0)="""RTN"",""ORCFLAG"",10,0)"
^XMB(3.9,145958,2,818,0)=" I '$$VALID^ORCACT0(ORIFN,ORACTN,.ORERR) W !,ORERR H 1 Q"
^XMB(3.9,145958,2,819,0)="""RTN"",""ORCFLAG"",11,0)"
^XMB(3.9,145958,2,820,0)=" S ORLK=$$LOCK1^ORX2(+ORIFN) I 'ORLK W !,$P(ORLK,U,2) H 1 Q"
^XMB(3.9,145958,2,821,0)="""RTN"",""ORCFLAG"",12,0)"
^XMB(3.9,145958,2,822,0)=" S ORACTN=$S(ORACTN=""UF"":""UN"",1:""EN""),ORPS=1"
^XMB(3.9,145958,2,823,0)="""RTN"",""ORCFLAG"",13,0)"
^XMB(3.9,145958,2,824,0)=" D @ORACTN,UNLK1^ORX2(+ORIFN)"
^XMB(3.9,145958,2,825,0)="""RTN"",""ORCFLAG"",14,0)"
^XMB(3.9,145958,2,826,0)=" Q"
^XMB(3.9,145958,2,827,0)="""RTN"",""ORCFLAG"",15,0)"
^XMB(3.9,145958,2,828,0)=" ;"
^XMB(3.9,145958,2,829,0)="""RTN"",""ORCFLAG"",16,0)"
^XMB(3.9,145958,2,830,0)="EN ; -- Flag order ORIFN"
^XMB(3.9,145958,2,831,0)="""RTN"",""ORCFLAG"",17,0)"
^XMB(3.9,145958,2,832,0)=" N OREASON,DA,ORB,ORNP,ORNOW S ORNOW=+$E($$NOW^XLFDT,1,12)"
^XMB(3.9,145958,2,833,0)="""RTN"",""ORCFLAG"",18,0)"
^XMB(3.9,145958,2,834,0)=" S DA=$P(ORIFN,"";"",2) I 'DA W !,""Unable to flag!"" H 1 Q"
^XMB(3.9,145958,2,835,0)="""RTN"",""ORCFLAG"",19,0)"
^XMB(3.9,145958,2,836,0)=" S OREASON=$$REASON Q:OREASON=""^"""
^XMB(3.9,145958,2,837,0)="""RTN"",""ORCFLAG"",20,0)"
^XMB(3.9,145958,2,838,0)=" S ORNP=+$P($G(^OR(100,+ORIFN,8,DA,0)),U,3),ORNP=$$PROV(ORNP) Q:ORNP=""^"""
^XMB(3.9,145958,2,839,0)="""RTN"",""ORCFLAG"",21,0)"
^XMB(3.9,145958,2,840,0)=" D BULLETIN ;use ORNP?"
^XMB(3.9,145958,2,841,0)="""RTN"",""ORCFLAG"",22,0)"
^XMB(3.9,145958,2,842,0)=" K ^OR(100,+ORIFN,8,DA,3) S ^(3)=""1^""_$G(XMZ)_U_ORNOW_U_DUZ_U_OREASON_""^^^^""_ORNP"
^XMB(3.9,145958,2,843,0)="""RTN"",""ORCFLAG"",23,0)"
^XMB(3.9,145958,2,844,0)=" S $P(^OR(100,+ORIFN,3),U)=$$NOW^XLFDT,OREBUILD=1 ; Last Activity"
^XMB(3.9,145958,2,845,0)="""RTN"",""ORCFLAG"",24,0)"
^XMB(3.9,145958,2,846,0)=" S ORB=+ORVP_U_+ORIFN_U_ORNP_""^1"" D EN^OCXOERR(ORB) ; notification"
^XMB(3.9,145958,2,847,0)="""RTN"",""ORCFLAG"",25,0)"
^XMB(3.9,145958,2,848,0)=" W !?10,""... order flagged."" H 1 D KILL^XM,MSG(ORIFN)"
^XMB(3.9,145958,2,849,0)="""RTN"",""ORCFLAG"",26,0)"
^XMB(3.9,145958,2,850,0)=" Q"
^XMB(3.9,145958,2,851,0)="""RTN"",""ORCFLAG"",27,0)"
^XMB(3.9,145958,2,852,0)=" ;"
^XMB(3.9,145958,2,853,0)="""RTN"",""ORCFLAG"",28,0)"
^XMB(3.9,145958,2,854,0)="UN ; -- Unflag order ORIFN"
^XMB(3.9,145958,2,855,0)="""RTN"",""ORCFLAG"",29,0)"
^XMB(3.9,145958,2,856,0)=" N OREASON,DA,ORB,ORNP,ORNOW S ORNOW=+$E($$NOW^XLFDT,1,12)"
^XMB(3.9,145958,2,857,0)="""RTN"",""ORCFLAG"",30,0)"
^XMB(3.9,145958,2,858,0)=" S DA=$P(ORIFN,"";"",2) I 'DA W !,""Unable to unflag order!"" H 1 Q"
^XMB(3.9,145958,2,859,0)="""RTN"",""ORCFLAG"",31,0)"
^XMB(3.9,145958,2,860,0)=" D SHOWFLAG S OREASON=$$COMMENT Q:OREASON=""^"""
^XMB(3.9,145958,2,861,0)="""RTN"",""ORCFLAG"",32,0)"
^XMB(3.9,145958,2,862,0)=" S $P(^OR(100,+ORIFN,8,DA,3),U)=0,$P(^(3),U,6,8)=ORNOW_U_DUZ_U_OREASON"
^XMB(3.9,145958,2,863,0)="""RTN"",""ORCFLAG"",33,0)"
^XMB(3.9,145958,2,864,0)=" S ORNP=+$P(^OR(100,+ORIFN,8,DA,3),U,9) S:'ORNP ORNP=+$P($G(^(0)),U,3)"
^XMB(3.9,145958,2,865,0)="""RTN"",""ORCFLAG"",34,0)"
^XMB(3.9,145958,2,866,0)=" S ORB=+ORVP_U_+ORIFN_U_ORNP_""^0"" D EN^OCXOERR(ORB) ; notification"
^XMB(3.9,145958,2,867,0)="""RTN"",""ORCFLAG"",35,0)"
^XMB(3.9,145958,2,868,0)=" S $P(^OR(100,+ORIFN,3),U)=$$NOW^XLFDT,OREBUILD=1 ; Last Activity"
^XMB(3.9,145958,2,869,0)="""RTN"",""ORCFLAG"",36,0)"
^XMB(3.9,145958,2,870,0)=" W !?10,""... order unflagged."" H 1 D MSG(ORIFN)"
^XMB(3.9,145958,2,871,0)="""RTN"",""ORCFLAG"",37,0)"
^XMB(3.9,145958,2,872,0)=" Q"
^XMB(3.9,145958,2,873,0)="""RTN"",""ORCFLAG"",38,0)"
^XMB(3.9,145958,2,874,0)=" ;"
^XMB(3.9,145958,2,875,0)="""RTN"",""ORCFLAG"",39,0)"
^XMB(3.9,145958,2,876,0)="SHOWFLAG ; -- Display [last] flag for order ORIFN"
^XMB(3.9,145958,2,877,0)="""RTN"",""ORCFLAG"",40,0)"
^XMB(3.9,145958,2,878,0)=" N FLAG"
^XMB(3.9,145958,2,879,0)="""RTN"",""ORCFLAG"",41,0)"
^XMB(3.9,145958,2,880,0)=" S FLAG=$G(^OR(100,+ORIFN,8,DA,3))"
^XMB(3.9,145958,2,881,0)="""RTN"",""ORCFLAG"",42,0)"
^XMB(3.9,145958,2,882,0)=" W !,"" FLAGGED: ""_$$LTIM($P(FLAG,U,3))_"" by ""_$P($G(^VA(200,+$P(FLAG,U,4),0)),U)"
^XMB(3.9,145958,2,883,0)="""RTN"",""ORCFLAG"",43,0)"
^XMB(3.9,145958,2,884,0)=" W !?10,$P(FLAG,U,5) ; reason"
^XMB(3.9,145958,2,885,0)="""RTN"",""ORCFLAG"",44,0)"
^XMB(3.9,145958,2,886,0)=" Q"
^XMB(3.9,145958,2,887,0)="""RTN"",""ORCFLAG"",45,0)"
^XMB(3.9,145958,2,888,0)=" ;"
^XMB(3.9,145958,2,889,0)="""RTN"",""ORCFLAG"",46,0)"
^XMB(3.9,145958,2,890,0)="REASON() ; -- Reason for flag"
^XMB(3.9,145958,2,891,0)="""RTN"",""ORCFLAG"",47,0)"
^XMB(3.9,145958,2,892,0)=" N X,Y,DIR"
^XMB(3.9,145958,2,893,0)="""RTN"",""ORCFLAG"",48,0)"
^XMB(3.9,145958,2,894,0)=" S DIR(0)=""FA^1:80"",DIR(""A"")=""REASON FOR FLAG: "" ; ck E3R"
^XMB(3.9,145958,2,895,0)="""RTN"",""ORCFLAG"",49,0)"
^XMB(3.9,145958,2,896,0)=" S DIR(""?"")=""A reason must be entered to flag this order."""
^XMB(3.9,145958,2,897,0)="""RTN"",""ORCFLAG"",50,0)"
^XMB(3.9,145958,2,898,0)=" D ^DIR"
^XMB(3.9,145958,2,899,0)="""RTN"",""ORCFLAG"",51,0)"
^XMB(3.9,145958,2,900,0)=" Q Y"
^XMB(3.9,145958,2,901,0)="""RTN"",""ORCFLAG"",52,0)"
^XMB(3.9,145958,2,902,0)=" ;"
^XMB(3.9,145958,2,903,0)="""RTN"",""ORCFLAG"",53,0)"
^XMB(3.9,145958,2,904,0)="COMMENT() ; -- Comments on unflag"
^XMB(3.9,145958,2,905,0)="""RTN"",""ORCFLAG"",54,0)"
^XMB(3.9,145958,2,906,0)=" N X,Y,DIR"
^XMB(3.9,145958,2,907,0)="""RTN"",""ORCFLAG"",55,0)"
^XMB(3.9,145958,2,908,0)=" S DIR(0)=""FAO^1:80"",DIR(""A"")=""COMMENTS: """
^XMB(3.9,145958,2,909,0)="""RTN"",""ORCFLAG"",56,0)"
^XMB(3.9,145958,2,910,0)=" S DIR(""?"")=""A comment may be entered to clarify this order."""
^XMB(3.9,145958,2,911,0)="""RTN"",""ORCFLAG"",57,0)"
^XMB(3.9,145958,2,912,0)=" D ^DIR S:$D(DTOUT) Y=""^"""
^XMB(3.9,145958,2,913,0)="""RTN"",""ORCFLAG"",58,0)"
^XMB(3.9,145958,2,914,0)=" Q Y"
^XMB(3.9,145958,2,915,0)="""RTN"",""ORCFLAG"",59,0)"
^XMB(3.9,145958,2,916,0)=" ;"
^XMB(3.9,145958,2,917,0)="""RTN"",""ORCFLAG"",60,0)"
^XMB(3.9,145958,2,918,0)="PROV(ORDR) ; -- Get provider to alert"
^XMB(3.9,145958,2,919,0)="""RTN"",""ORCFLAG"",61,0)"
^XMB(3.9,145958,2,920,0)=" N X,Y,DIC"
^XMB(3.9,145958,2,921,0)="""RTN"",""ORCFLAG"",62,0)"
^XMB(3.9,145958,2,922,0)=" S DIC=200,DIC(0)=""AEQM"",DIC(""A"")=""Send alert to: """
^XMB(3.9,145958,2,923,0)="""RTN"",""ORCFLAG"",63,0)"
^XMB(3.9,145958,2,924,0)=" I $G(ORDR) S ORDR=$P($G(^VA(200,+ORDR,0)),U) S:$L(ORDR) DIC(""B"")=ORDR"
^XMB(3.9,145958,2,925,0)="""RTN"",""ORCFLAG"",64,0)"
^XMB(3.9,145958,2,926,0)=" S DIC(""S"")=""N ORT S ORT=$P(^(0),U,11) I 'ORT!(ORT>DT)"""
^XMB(3.9,145958,2,927,0)="""RTN"",""ORCFLAG"",65,0)"
^XMB(3.9,145958,2,928,0)=" D ^DIC S:Y>0 Y=+Y I Y'>0 S Y=""^"""
^XMB(3.9,145958,2,929,0)="""RTN"",""ORCFLAG"",66,0)"
^XMB(3.9,145958,2,930,0)=" Q Y"
^XMB(3.9,145958,2,931,0)="""RTN"",""ORCFLAG"",67,0)"
^XMB(3.9,145958,2,932,0)=" ;"
^XMB(3.9,145958,2,933,0)="""RTN"",""ORCFLAG"",68,0)"
^XMB(3.9,145958,2,934,0)="BULLETIN ; -- Send bulletin re: flag"
^XMB(3.9,145958,2,935,0)="""RTN"",""ORCFLAG"",69,0)"
^XMB(3.9,145958,2,936,0)=" N OR0,OR3,ORDTXT,XMB,XMY,XMDUZ,ORENT,BULL,ORSRV,ORUSR"
^XMB(3.9,145958,2,937,0)="""RTN"",""ORCFLAG"",70,0)"
^XMB(3.9,145958,2,938,0)=" S OR0=$G(^OR(100,+ORIFN,0)),OR3=$G(^(3)) ;ORUSR=+$P(OR0,U,4)"
^XMB(3.9,145958,2,939,0)="""RTN"",""ORCFLAG"",71,0)"
^XMB(3.9,145958,2,940,0)=" S ORUSR=+$G(ORNP),ORSRV=+$P($G(^VA(200,ORUSR,5)),U)"
^XMB(3.9,145958,2,941,0)="""RTN"",""ORCFLAG"",72,0)"
^XMB(3.9,145958,2,942,0)=" S ORENT=""USR.`""_ORUSR_""^SRV.`""_ORSRV_""^DIV^SYS^PKG"""
^XMB(3.9,145958,2,943,0)="""RTN"",""ORCFLAG"",73,0)"
^XMB(3.9,145958,2,944,0)=" S BULL=$$GET^XPAR(ORENT,""ORB FLAGGED ORDERS BULLETIN"",1,""Q"")"
^XMB(3.9,145958,2,945,0)="""RTN"",""ORCFLAG"",74,0)"
^XMB(3.9,145958,2,946,0)=" Q:$G(BULL)'=""Y""   ;quit if parameter value is not 'Y'es"
^XMB(3.9,145958,2,947,0)="""RTN"",""ORCFLAG"",75,0)"
^XMB(3.9,145958,2,948,0)=" ;"
^XMB(3.9,145958,2,949,0)="""RTN"",""ORCFLAG"",76,0)"
^XMB(3.9,145958,2,950,0)=" W !,""Sending bulletin to ""_$P($G(^VA(200,ORUSR,0)),U)_""..."""
^XMB(3.9,145958,2,951,0)="""RTN"",""ORCFLAG"",77,0)"
^XMB(3.9,145958,2,952,0)=" S XMB=""OR FLAGGED ORDER"",XMDUZ=DUZ,XMY(ORUSR)="""""
^XMB(3.9,145958,2,953,0)="""RTN"",""ORCFLAG"",78,0)"
^XMB(3.9,145958,2,954,0)=" S XMB(1)=ORPNM,XMB(2)=ORSSN,XMB(3)=ORAGE,XMB(4)=$$LTIM($P(OR0,U,7))"
^XMB(3.9,145958,2,955,0)="""RTN"",""ORCFLAG"",79,0)"
^XMB(3.9,145958,2,956,0)=" D TEXT^ORQ12(.ORDTXT,+ORIFN,80)"
^XMB(3.9,145958,2,957,0)="""RTN"",""ORCFLAG"",80,0)"
^XMB(3.9,145958,2,958,0)=" S XMB(5)=$G(ORDTXT(1)),XMB(6)=$G(ORDTXT(2)),XMB(7)=$G(ORDTXT(3))"
^XMB(3.9,145958,2,959,0)="""RTN"",""ORCFLAG"",81,0)"
^XMB(3.9,145958,2,960,0)=" S XMB(8)=$$LTIM($P(OR0,U,8)),XMB(9)=$$LTIM($P(OR0,U,9)),XMB(10)=OREASON"
^XMB(3.9,145958,2,961,0)="""RTN"",""ORCFLAG"",82,0)"
^XMB(3.9,145958,2,962,0)=" S XMB(11)=$P($G(^ORD(100.01,+$P(OR3,U,3),0)),U)"
^XMB(3.9,145958,2,963,0)="""RTN"",""ORCFLAG"",83,0)"
^XMB(3.9,145958,2,964,0)=" D EN^XMB"
^XMB(3.9,145958,2,965,0)="""RTN"",""ORCFLAG"",84,0)"
^XMB(3.9,145958,2,966,0)=" Q"
^XMB(3.9,145958,2,967,0)="""RTN"",""ORCFLAG"",85,0)"
^XMB(3.9,145958,2,968,0)=" ;"
^XMB(3.9,145958,2,969,0)="""RTN"",""ORCFLAG"",86,0)"
^XMB(3.9,145958,2,970,0)="LTIM(X) ; -- format FM date/time into MM/DD HH:MM"
^XMB(3.9,145958,2,971,0)="""RTN"",""ORCFLAG"",87,0)"
^XMB(3.9,145958,2,972,0)=" N Y S Y="""""
^XMB(3.9,145958,2,973,0)="""RTN"",""ORCFLAG"",88,0)"
^XMB(3.9,145958,2,974,0)=" S:X Y=$E(X,4,5)_""/""_$E(X,6,7)"
^XMB(3.9,145958,2,975,0)="""RTN"",""ORCFLAG"",89,0)"
^XMB(3.9,145958,2,976,0)=" S:X[""."" Y=Y_"" ""_$E(X_""0"",9,10)_"":""_$E(X_""000"",11,12)"
^XMB(3.9,145958,2,977,0)="""RTN"",""ORCFLAG"",90,0)"
^XMB(3.9,145958,2,978,0)=" Q Y"
^XMB(3.9,145958,2,979,0)="""RTN"",""ORCFLAG"",91,0)"
^XMB(3.9,145958,2,980,0)=" ;"
^XMB(3.9,145958,2,981,0)="""RTN"",""ORCFLAG"",92,0)"
^XMB(3.9,145958,2,982,0)="MSG(ORDER)      ; -- Sends HL7 message to Pharmacy when order is un/flagged"
^XMB(3.9,145958,2,983,0)="""RTN"",""ORCFLAG"",93,0)"
^XMB(3.9,145958,2,984,0)=" Q:'$L($T(OBR^PSJHL4))  ;needs PSJ*5*85"
^XMB(3.9,145958,2,985,0)="""RTN"",""ORCFLAG"",94,0)"
^XMB(3.9,145958,2,986,0)=" Q:'$G(ORDER)  Q:'$D(^OR(100,+ORDER,0))  Q:'$P(ORDER,"";"",2)"
^XMB(3.9,145958,2,987,0)="""RTN"",""ORCFLAG"",95,0)"
^XMB(3.9,145958,2,988,0)=" N OR0,OR3,ORMSG,ORVP,ORX,ORFLAG"
^XMB(3.9,145958,2,989,0)="""RTN"",""ORCFLAG"",96,0)"
^XMB(3.9,145958,2,990,0)=" S OR0=$G(^OR(100,+ORDER,0)),OR3=$G(^(8,+$P(ORDER,"";"",2),3))"
^XMB(3.9,145958,2,991,0)="""RTN"",""ORCFLAG"",97,0)"
^XMB(3.9,145958,2,992,0)=" Q:""^PSJ^PSIV^PSO^""'[(U_$$GET1^DIQ(9.4,+$P(OR0,U,14)_"","",1)_U)  ;Inpt or IV"
^XMB(3.9,145958,2,993,0)="""RTN"",""ORCFLAG"",98,0)"
^XMB(3.9,145958,2,994,0)=" S ORMSG(1)=$$MSH^ORMBLD(""ORU"",""PS"")"
^XMB(3.9,145958,2,995,0)="""RTN"",""ORCFLAG"",99,0)"
^XMB(3.9,145958,2,996,0)=" S ORVP=$P(OR0,U,2),ORMSG(2)=$$PID^ORMBLD(ORVP)"
^XMB(3.9,145958,2,997,0)="""RTN"",""ORCFLAG"",100,0)"
^XMB(3.9,145958,2,998,0)=" S ORMSG(3)=$$PV1^ORMBLD(ORVP,$P(OR0,U,12),+$P(OR0,U,10))"
^XMB(3.9,145958,2,999,0)="""RTN"",""ORCFLAG"",101,0)"
^XMB(3.9,145958,2,1000,0)=" S ORX=$S(OR3:$P(OR3,U,3,5),1:$P(OR3,U,6,8))"
^XMB(3.9,145958,2,1001,0)="""RTN"",""ORCFLAG"",102,0)"
^XMB(3.9,145958,2,1002,0)=" S ORFLAG=$S(OR3:""FL"",1:""UF"")_""|||""_$$HL7DATE^ORMBLD($P(ORX,U))_""||||||""_$P(ORX,U,3)_""|||""_+$P(ORX,U,2)"
^XMB(3.9,145958,2,1003,0)="""RTN"",""ORCFLAG"",103,0)"
^XMB(3.9,145958,2,1004,0)=" S:$G(ORPS) ORFLAG=ORFLAG_""||||||||PHR"" ;action taken by pharmacist"
^XMB(3.9,145958,2,1005,0)="""RTN"",""ORCFLAG"",104,0)"
^XMB(3.9,145958,2,1006,0)=" S ORMSG(4)=""OBR|1|""_ORDER_""^OR|""_$G(^OR(100,+ORDER,4))_""^PS|""_ORFLAG"
^XMB(3.9,145958,2,1007,0)="""RTN"",""ORCFLAG"",105,0)"
^XMB(3.9,145958,2,1008,0)=" D MSG^XQOR(""OR EVSEND PS"",.ORMSG)"
^XMB(3.9,145958,2,1009,0)="""RTN"",""ORCFLAG"",106,0)"
^XMB(3.9,145958,2,1010,0)=" Q"
^XMB(3.9,145958,2,1011,0)="""RTN"",""ORWDXA"")"
^XMB(3.9,145958,2,1012,0)="0^1^B147530043"
^XMB(3.9,145958,2,1013,0)="""RTN"",""ORWDXA"",1,0)"
^XMB(3.9,145958,2,1014,0)="ORWDXA ; SLC/KCM/JLI - Utilities for Order Actions ; May 20, 2024@11:05"
^XMB(3.9,145958,2,1015,0)="""RTN"",""ORWDXA"",2,0)"
^XMB(3.9,145958,2,1016,0)=" ;;3.0;ORDER ENTRY/RESULTS REPORTING;**10,85,116,132,148,141,149,187,213,195,215,243,280,306,390,421,436,434,397,377,539,405,577,466**;Dec 17, 1997;Build 0"
^XMB(3.9,145958,2,1017,0)="""RTN"",""ORWDXA"",3,0)"
^XMB(3.9,145958,2,1018,0)=" ;"
^XMB(3.9,145958,2,1019,0)="""RTN"",""ORWDXA"",4,0)"
^XMB(3.9,145958,2,1020,0)=" ;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145958,2,1021,0)="""RTN"",""ORWDXA"",5,0)"
^XMB(3.9,145958,2,1022,0)=" ;"
^XMB(3.9,145958,2,1023,0)="""RTN"",""ORWDXA"",6,0)"
