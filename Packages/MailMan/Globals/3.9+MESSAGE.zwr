^XMB(3.9,145946,2,5024,0)=" ;          IENIN   - IEN of the entry to Mark/Remove 'In-Progress'"
^XMB(3.9,145946,2,5025,0)="""RTN"",""IBCNILK"",344,0)"
^XMB(3.9,145946,2,5026,0)=" ;          LINE    - Line number being marked/unmarked"
^XMB(3.9,145946,2,5027,0)="""RTN"",""IBCNILK"",345,0)"
^XMB(3.9,145946,2,5028,0)=" ;          WLIST   - Worklist, the user is selecting from."
^XMB(3.9,145946,2,5029,0)="""RTN"",""IBCNILK"",346,0)"
^XMB(3.9,145946,2,5030,0)=" ;          NUMSEL  - Current # of selected Insurance Companies"
^XMB(3.9,145946,2,5031,0)="""RTN"",""IBCNILK"",347,0)"
^XMB(3.9,145946,2,5032,0)=" ;          ^TMP(""IBCNILKA"",$J)- Current array of selected Insurance Companies "
^XMB(3.9,145946,2,5033,0)="""RTN"",""IBCNILK"",348,0)"
^XMB(3.9,145946,2,5034,0)=" ; Output:  Insurance  Company is marked or unmarked as selected"
^XMB(3.9,145946,2,5035,0)="""RTN"",""IBCNILK"",349,0)"
^XMB(3.9,145946,2,5036,0)=" ;          NUMSEL  - Current # of selected Insurance Companies"
^XMB(3.9,145946,2,5037,0)="""RTN"",""IBCNILK"",350,0)"
^XMB(3.9,145946,2,5038,0)=" ;          ^TMP(""IBCNILKA"",$J)- Updated array of selected Insurance Companies "
^XMB(3.9,145946,2,5039,0)="""RTN"",""IBCNILK"",351,0)"
^XMB(3.9,145946,2,5040,0)=" ;      "
^XMB(3.9,145946,2,5041,0)="""RTN"",""IBCNILK"",352,0)"
^XMB(3.9,145946,2,5042,0)=" N TEXT"
^XMB(3.9,145946,2,5043,0)="""RTN"",""IBCNILK"",353,0)"
^XMB(3.9,145946,2,5044,0)=" I WHICH D                                  ; Mark as selected"
^XMB(3.9,145946,2,5045,0)="""RTN"",""IBCNILK"",354,0)"
^XMB(3.9,145946,2,5046,0)=" . S ^TMP(""IBCNILKA"",$J,IIEN)="""""
^XMB(3.9,145946,2,5047,0)="""RTN"",""IBCNILK"",355,0)"
^XMB(3.9,145946,2,5048,0)=" . S TEXT=LINE_"">"",NUMSEL=NUMSEL+1"
^XMB(3.9,145946,2,5049,0)="""RTN"",""IBCNILK"",356,0)"
^XMB(3.9,145946,2,5050,0)=" E  D                                       ; Mark as selected"
^XMB(3.9,145946,2,5051,0)="""RTN"",""IBCNILK"",357,0)"
^XMB(3.9,145946,2,5052,0)=" . K ^TMP(""IBCNILKA"",$J,IIEN)"
^XMB(3.9,145946,2,5053,0)="""RTN"",""IBCNILK"",358,0)"
^XMB(3.9,145946,2,5054,0)=" . S TEXT=LINE,NUMSEL=NUMSEL-1"
^XMB(3.9,145946,2,5055,0)="""RTN"",""IBCNILK"",359,0)"
^XMB(3.9,145946,2,5056,0)=" D FLDTEXT^VALM10(LINE,""CTR"",TEXT)          ; Update display"
^XMB(3.9,145946,2,5057,0)="""RTN"",""IBCNILK"",360,0)"
^XMB(3.9,145946,2,5058,0)=" D WRITE^VALM10(LINE)                       ; Redisplay line"
^XMB(3.9,145946,2,5059,0)="""RTN"",""IBCNILK"",361,0)"
^XMB(3.9,145946,2,5060,0)=" Q"
^XMB(3.9,145946,2,5061,0)="""RTN"",""IBCNILK"",362,0)"
^XMB(3.9,145946,2,5062,0)=" ;"
^XMB(3.9,145946,2,5063,0)="""RTN"",""IBCNILK"",363,0)"
^XMB(3.9,145946,2,5064,0)="SHOWSEL ;EP"
^XMB(3.9,145946,2,5065,0)="""RTN"",""IBCNILK"",364,0)"
^XMB(3.9,145946,2,5066,0)=" ; Protocol action used to display a listman template of the currently"
^XMB(3.9,145946,2,5067,0)="""RTN"",""IBCNILK"",365,0)"
^XMB(3.9,145946,2,5068,0)=" ; selected Insurance companies"
^XMB(3.9,145946,2,5069,0)="""RTN"",""IBCNILK"",366,0)"
^XMB(3.9,145946,2,5070,0)=" ; Input:   NUMSEL                      - Current number of selected insurance"
^XMB(3.9,145946,2,5071,0)="""RTN"",""IBCNILK"",367,0)"
^XMB(3.9,145946,2,5072,0)=" ;                                        companies"
^XMB(3.9,145946,2,5073,0)="""RTN"",""IBCNILK"",368,0)"
^XMB(3.9,145946,2,5074,0)=" ;          ^TMP(""IBCNILKA"",$J,IEN)    - Current Array of selected insurance"
^XMB(3.9,145946,2,5075,0)="""RTN"",""IBCNILK"",369,0)"
^XMB(3.9,145946,2,5076,0)=" ;                                        companies"
^XMB(3.9,145946,2,5077,0)="""RTN"",""IBCNILK"",370,0)"
^XMB(3.9,145946,2,5078,0)=" ; Output:  NUMSEL                      - Updated number of selected insurance companies"
^XMB(3.9,145946,2,5079,0)="""RTN"",""IBCNILK"",371,0)"
^XMB(3.9,145946,2,5080,0)=" ;          ^TMP(""IBCNILKA"",$J,IEN)    - Updated Array of selected insurance"
^XMB(3.9,145946,2,5081,0)="""RTN"",""IBCNILK"",372,0)"
^XMB(3.9,145946,2,5082,0)=" ;                                        companies"
^XMB(3.9,145946,2,5083,0)="""RTN"",""IBCNILK"",373,0)"
^XMB(3.9,145946,2,5084,0)=" S VALMBCK=""R"""
^XMB(3.9,145946,2,5085,0)="""RTN"",""IBCNILK"",374,0)"
^XMB(3.9,145946,2,5086,0)=" D EN^VALM(""IBCN INS CO SELECTED"")"
^XMB(3.9,145946,2,5087,0)="""RTN"",""IBCNILK"",375,0)"
^XMB(3.9,145946,2,5088,0)=" D HDR,BLD"
^XMB(3.9,145946,2,5089,0)="""RTN"",""IBCNILK"",376,0)"
^XMB(3.9,145946,2,5090,0)=" Q"
^XMB(3.9,145946,2,5091,0)="""RTN"",""IBCNILK"",377,0)"
^XMB(3.9,145946,2,5092,0)=" ;"
^XMB(3.9,145946,2,5093,0)="""RTN"",""IBCNILK"",378,0)"
^XMB(3.9,145946,2,5094,0)="SELINS(FULL,PROMPT,DLINE,MULT,WLIST)    ;EP"
^XMB(3.9,145946,2,5095,0)="""RTN"",""IBCNILK"",379,0)"
^XMB(3.9,145946,2,5096,0)=" ; Select Insurance Company(s) to perform an action upon"
^XMB(3.9,145946,2,5097,0)="""RTN"",""IBCNILK"",380,0)"
^XMB(3.9,145946,2,5098,0)=" ; Also called from IBCNILK@UNSEL"
^XMB(3.9,145946,2,5099,0)="""RTN"",""IBCNILK"",381,0)"
^XMB(3.9,145946,2,5100,0)=" ; Input:   FULL                    - 1 - full screen mode, 0 otherwise"
^XMB(3.9,145946,2,5101,0)="""RTN"",""IBCNILK"",382,0)"
^XMB(3.9,145946,2,5102,0)=" ;          PROMPT                  - Prompt to be displayed to the user"
^XMB(3.9,145946,2,5103,0)="""RTN"",""IBCNILK"",383,0)"
^XMB(3.9,145946,2,5104,0)=" ;          MULT                    - 1 to allow multiple entry selection"
^XMB(3.9,145946,2,5105,0)="""RTN"",""IBCNILK"",384,0)"
^XMB(3.9,145946,2,5106,0)=" ;                                    0 to only allow single entry selection"
^XMB(3.9,145946,2,5107,0)="""RTN"",""IBCNILK"",385,0)"
^XMB(3.9,145946,2,5108,0)=" ;                                    Optional, defaults to 0"
^XMB(3.9,145946,2,5109,0)="""RTN"",""IBCNILK"",386,0)"
^XMB(3.9,145946,2,5110,0)=" ;          WLIST                   - Worklist, the user is selecting from"
^XMB(3.9,145946,2,5111,0)="""RTN"",""IBCNILK"",387,0)"
^XMB(3.9,145946,2,5112,0)=" ;          ^TMP(""IBCNILKIX"",$J)   - Index of displayed lines of the Ins Co"
^XMB(3.9,145946,2,5113,0)="""RTN"",""IBCNILK"",388,0)"
^XMB(3.9,145946,2,5114,0)=" ;                                    Selector Template. "
^XMB(3.9,145946,2,5115,0)="""RTN"",""IBCNILK"",389,0)"
^XMB(3.9,145946,2,5116,0)=" ;                                    Only used when WLIST=""IBCNILKIX"""
^XMB(3.9,145946,2,5117,0)="""RTN"",""IBCNILK"",390,0)"
^XMB(3.9,145946,2,5118,0)=" ;          ^TMP(""IBCNILKSIX"",$J)  - Index of displayed lines of the Ins Cos"
^XMB(3.9,145946,2,5119,0)="""RTN"",""IBCNILK"",391,0)"
^XMB(3.9,145946,2,5120,0)=" ;                                    Selected Template"
^XMB(3.9,145946,2,5121,0)="""RTN"",""IBCNILK"",392,0)"
^XMB(3.9,145946,2,5122,0)=" ;                                    Only used if WLIST is ""IBCNILKSIX"""
^XMB(3.9,145946,2,5123,0)="""RTN"",""IBCNILK"",393,0)"
^XMB(3.9,145946,2,5124,0)=" ; Output:  DLINE                   - Comma delimited list of Line #(s) of the "
^XMB(3.9,145946,2,5125,0)="""RTN"",""IBCNILK"",394,0)"
^XMB(3.9,145946,2,5126,0)=" ;                                    selected Ins Cos"
^XMB(3.9,145946,2,5127,0)="""RTN"",""IBCNILK"",395,0)"
^XMB(3.9,145946,2,5128,0)=" ; Returns: IIEN(s) - Comma delimited string or IENS for the selected Ins Co(s)"
^XMB(3.9,145946,2,5129,0)="""RTN"",""IBCNILK"",396,0)"
^XMB(3.9,145946,2,5130,0)=" ;          Error message and """" IENS if multi-selection and not allowed"
^XMB(3.9,145946,2,5131,0)="""RTN"",""IBCNILK"",397,0)"
^XMB(3.9,145946,2,5132,0)=" N DIR,DIROUT,DIRUT,DTOUT,DUOUT,IIEN,IIENS,IX,VALMY,X,Y"
^XMB(3.9,145946,2,5133,0)="""RTN"",""IBCNILK"",398,0)"
^XMB(3.9,145946,2,5134,0)=" S:'$D(MULT) MULT=0"
^XMB(3.9,145946,2,5135,0)="""RTN"",""IBCNILK"",399,0)"
^XMB(3.9,145946,2,5136,0)=" S:'$D(WLIST) WLIST=""IBCNILK"""
^XMB(3.9,145946,2,5137,0)="""RTN"",""IBCNILK"",400,0)"
^XMB(3.9,145946,2,5138,0)=" D:FULL FULL^VALM1"
^XMB(3.9,145946,2,5139,0)="""RTN"",""IBCNILK"",401,0)"
^XMB(3.9,145946,2,5140,0)=" S DLINE=$P($P($G(XQORNOD(0)),""^"",4),""="",2)     ; User selection with action"
^XMB(3.9,145946,2,5141,0)="""RTN"",""IBCNILK"",402,0)"
^XMB(3.9,145946,2,5142,0)=" S DLINE=$TR(DLINE,""/\; ."","",,,,,"")             ; Check for multi-selection"
^XMB(3.9,145946,2,5143,0)="""RTN"",""IBCNILK"",403,0)"
^XMB(3.9,145946,2,5144,0)=" S IIENS="""""
^XMB(3.9,145946,2,5145,0)="""RTN"",""IBCNILK"",404,0)"
^XMB(3.9,145946,2,5146,0)=" I 'MULT,DLINE["","" D  Q """"                      ; Invalid multi-selection"
^XMB(3.9,145946,2,5147,0)="""RTN"",""IBCNILK"",405,0)"
^XMB(3.9,145946,2,5148,0)=" . W !,*7,"">>>> Only single entry selection is allowed"""
^XMB(3.9,145946,2,5149,0)="""RTN"",""IBCNILK"",406,0)"
^XMB(3.9,145946,2,5150,0)=" . S DLINE="""""
^XMB(3.9,145946,2,5151,0)="""RTN"",""IBCNILK"",407,0)"
^XMB(3.9,145946,2,5152,0)=" . K DIR"
^XMB(3.9,145946,2,5153,0)="""RTN"",""IBCNILK"",408,0)"
^XMB(3.9,145946,2,5154,0)=" . D PAUSE^VALM1"
^XMB(3.9,145946,2,5155,0)="""RTN"",""IBCNILK"",409,0)"
^XMB(3.9,145946,2,5156,0)=" ;"
^XMB(3.9,145946,2,5157,0)="""RTN"",""IBCNILK"",410,0)"
^XMB(3.9,145946,2,5158,0)=" ; Let the user enter their selection(s)"
^XMB(3.9,145946,2,5159,0)="""RTN"",""IBCNILK"",411,0)"
^XMB(3.9,145946,2,5160,0)=" D EN^VALM2($G(XQORNOD(0)),""O"")                 ; ListMan generic selector"
^XMB(3.9,145946,2,5161,0)="""RTN"",""IBCNILK"",412,0)"
^XMB(3.9,145946,2,5162,0)=" I '$D(VALMY) Q """""
^XMB(3.9,145946,2,5163,0)="""RTN"",""IBCNILK"",413,0)"
^XMB(3.9,145946,2,5164,0)=" S IX="""",DLINE="""""
^XMB(3.9,145946,2,5165,0)="""RTN"",""IBCNILK"",414,0)"
^XMB(3.9,145946,2,5166,0)=" F  D  Q:IX="""""
^XMB(3.9,145946,2,5167,0)="""RTN"",""IBCNILK"",415,0)"
^XMB(3.9,145946,2,5168,0)=" . S IX=$O(VALMY(IX))"
^XMB(3.9,145946,2,5169,0)="""RTN"",""IBCNILK"",416,0)"
^XMB(3.9,145946,2,5170,0)=" . Q:IX="""""
^XMB(3.9,145946,2,5171,0)="""RTN"",""IBCNILK"",417,0)"
^XMB(3.9,145946,2,5172,0)=" . S DLINE=$S(DLINE="""":IX,1:DLINE_"",""_IX)"
^XMB(3.9,145946,2,5173,0)="""RTN"",""IBCNILK"",418,0)"
^XMB(3.9,145946,2,5174,0)=" . S IIEN=$G(^TMP(WLIST,$J,IX))"
^XMB(3.9,145946,2,5175,0)="""RTN"",""IBCNILK"",419,0)"
^XMB(3.9,145946,2,5176,0)=" . S IIENS=$S(IIENS="""":IIEN,1:IIENS_"",""_IIEN)"
^XMB(3.9,145946,2,5177,0)="""RTN"",""IBCNILK"",420,0)"
^XMB(3.9,145946,2,5178,0)=" Q IIENS"
^XMB(3.9,145946,2,5179,0)="""RTN"",""IBCNILK"",421,0)"
^XMB(3.9,145946,2,5180,0)=" ;"
^XMB(3.9,145946,2,5181,0)="""RTN"",""IBCNILK"",422,0)"
^XMB(3.9,145946,2,5182,0)="INIT2 ;EP for Show Selections"
^XMB(3.9,145946,2,5183,0)="""RTN"",""IBCNILK"",423,0)"
^XMB(3.9,145946,2,5184,0)=" ; Initialize variables and list array"
^XMB(3.9,145946,2,5185,0)="""RTN"",""IBCNILK"",424,0)"
^XMB(3.9,145946,2,5186,0)=" ; Input: None"
^XMB(3.9,145946,2,5187,0)="""RTN"",""IBCNILK"",425,0)"
^XMB(3.9,145946,2,5188,0)=" ; Output:  ^TMP(""IBCNILK"",$J) - Body lines to display"
^XMB(3.9,145946,2,5189,0)="""RTN"",""IBCNILK"",426,0)"
^XMB(3.9,145946,2,5190,0)=" K ^TMP(""IBCNILKS"",$J),^TMP(""IBCNILKSIX"",$J)"
^XMB(3.9,145946,2,5191,0)="""RTN"",""IBCNILK"",427,0)"
^XMB(3.9,145946,2,5192,0)=" D BLD2"
^XMB(3.9,145946,2,5193,0)="""RTN"",""IBCNILK"",428,0)"
^XMB(3.9,145946,2,5194,0)=" Q"
^XMB(3.9,145946,2,5195,0)="""RTN"",""IBCNILK"",429,0)"
^XMB(3.9,145946,2,5196,0)=" ;"
^XMB(3.9,145946,2,5197,0)="""RTN"",""IBCNILK"",430,0)"
^XMB(3.9,145946,2,5198,0)="BLD2 ; Build listman body for Show Selections"
^XMB(3.9,145946,2,5199,0)="""RTN"",""IBCNILK"",431,0)"
^XMB(3.9,145946,2,5200,0)=" ; Input:   None"
^XMB(3.9,145946,2,5201,0)="""RTN"",""IBCNILK"",432,0)"
^XMB(3.9,145946,2,5202,0)=" ; Output:  VALMCNT   - Total number of lines displayed in the body"
^XMB(3.9,145946,2,5203,0)="""RTN"",""IBCNILK"",433,0)"
^XMB(3.9,145946,2,5204,0)=" ;          ^TMP(""IBCNILKS"",$J)   - Body lines to display"
^XMB(3.9,145946,2,5205,0)="""RTN"",""IBCNILK"",434,0)"
^XMB(3.9,145946,2,5206,0)=" ;          ^TMP(""IBCNILKSIX"",$J) - Index of Entry IENs by display line"
^XMB(3.9,145946,2,5207,0)="""RTN"",""IBCNILK"",435,0)"
^XMB(3.9,145946,2,5208,0)=" N IIEN,LINE,NM,SORTED"
^XMB(3.9,145946,2,5209,0)="""RTN"",""IBCNILK"",436,0)"
^XMB(3.9,145946,2,5210,0)=" ;"
^XMB(3.9,145946,2,5211,0)="""RTN"",""IBCNILK"",437,0)"
^XMB(3.9,145946,2,5212,0)=" ; First sort the currently selected insurance companies into name order"
^XMB(3.9,145946,2,5213,0)="""RTN"",""IBCNILK"",438,0)"
^XMB(3.9,145946,2,5214,0)=" S IIEN="""""
^XMB(3.9,145946,2,5215,0)="""RTN"",""IBCNILK"",439,0)"
^XMB(3.9,145946,2,5216,0)=" F  D  Q:IIEN="""""
^XMB(3.9,145946,2,5217,0)="""RTN"",""IBCNILK"",440,0)"
^XMB(3.9,145946,2,5218,0)=" . S IIEN=$O(^TMP(""IBCNILKA"",$J,IIEN))"
^XMB(3.9,145946,2,5219,0)="""RTN"",""IBCNILK"",441,0)"
^XMB(3.9,145946,2,5220,0)=" . Q:IIEN="""""
^XMB(3.9,145946,2,5221,0)="""RTN"",""IBCNILK"",442,0)"
^XMB(3.9,145946,2,5222,0)=" . S NM=$$GET1^DIQ(36,IIEN_"","",.01)"
^XMB(3.9,145946,2,5223,0)="""RTN"",""IBCNILK"",443,0)"
^XMB(3.9,145946,2,5224,0)=" . S SORTED(NM,IIEN)="""""
^XMB(3.9,145946,2,5225,0)="""RTN"",""IBCNILK"",444,0)"
^XMB(3.9,145946,2,5226,0)=" ;"
^XMB(3.9,145946,2,5227,0)="""RTN"",""IBCNILK"",445,0)"
^XMB(3.9,145946,2,5228,0)=" ; Now build the lines to be displayed"
^XMB(3.9,145946,2,5229,0)="""RTN"",""IBCNILK"",446,0)"
^XMB(3.9,145946,2,5230,0)=" S (ICTR,VALMCNT)=0,NM="""""
^XMB(3.9,145946,2,5231,0)="""RTN"",""IBCNILK"",447,0)"
^XMB(3.9,145946,2,5232,0)=" F  D  Q:NM="""""
^XMB(3.9,145946,2,5233,0)="""RTN"",""IBCNILK"",448,0)"
^XMB(3.9,145946,2,5234,0)=" . S NM=$O(SORTED(NM))"
^XMB(3.9,145946,2,5235,0)="""RTN"",""IBCNILK"",449,0)"
^XMB(3.9,145946,2,5236,0)=" . Q:NM="""""
^XMB(3.9,145946,2,5237,0)="""RTN"",""IBCNILK"",450,0)"
^XMB(3.9,145946,2,5238,0)=" . S IIEN="""""
^XMB(3.9,145946,2,5239,0)="""RTN"",""IBCNILK"",451,0)"
^XMB(3.9,145946,2,5240,0)=" . F  D  Q:IIEN="""""
^XMB(3.9,145946,2,5241,0)="""RTN"",""IBCNILK"",452,0)"
^XMB(3.9,145946,2,5242,0)=" . . S IIEN=$O(SORTED(NM,IIEN))"
^XMB(3.9,145946,2,5243,0)="""RTN"",""IBCNILK"",453,0)"
^XMB(3.9,145946,2,5244,0)=" . . Q:IIEN="""""
^XMB(3.9,145946,2,5245,0)="""RTN"",""IBCNILK"",454,0)"
^XMB(3.9,145946,2,5246,0)=" . . S ICTR=ICTR+1"
^XMB(3.9,145946,2,5247,0)="""RTN"",""IBCNILK"",455,0)"
^XMB(3.9,145946,2,5248,0)=" . . S LINE=$$BLDLN(ICTR,IIEN)"
^XMB(3.9,145946,2,5249,0)="""RTN"",""IBCNILK"",456,0)"
^XMB(3.9,145946,2,5250,0)=" . . S VALMCNT=VALMCNT+1"
