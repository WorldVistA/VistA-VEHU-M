^XMB(3.9,145980,2,5539,0)="""RTN"",""SDES2CRTCLNAVAL2"",36,0)"
^XMB(3.9,145980,2,5540,0)=" ..I $G(SCHEDULEDDAYS)[$P($G(INPUTS(""TIMESLOT"",TIMESLOTCNT,""START DATE TIME"",CNT)),""T"") Q"
