^XMB(3.9,145949,2,477,0)="""RTN"",""PSXMISC1"",119,0)"
^XMB(3.9,145949,2,478,0)="MAILOK(TRX) ; return 1 if patient still in mail status & ok to CMOP"
^XMB(3.9,145949,2,479,0)="""RTN"",""PSXMISC1"",120,0)"
^XMB(3.9,145949,2,480,0)=" N PSOMDT,PSOMC,DFN"
^XMB(3.9,145949,2,481,0)="""RTN"",""PSXMISC1"",121,0)"
^XMB(3.9,145949,2,482,0)=" S DFN=$P(^PSRX(TRX,0),""^"",2),PSOMDT=$P($G(^PS(55,DFN,0)),""^"",5),PSOMC=$P($G(^PS(55,DFN,0)),""^"",3)"
^XMB(3.9,145949,2,483,0)="""RTN"",""PSXMISC1"",122,0)"
^XMB(3.9,145949,2,484,0)=" I $$GET1^DIQ(52,TRX,100.2,""I"")]"""" S PSOMC=$$GET1^DIQ(52,TRX,100.2,""I""),PSOMDT="""" ;p98"
^XMB(3.9,145949,2,485,0)="""RTN"",""PSXMISC1"",123,0)"
^XMB(3.9,145949,2,486,0)=" I (PSOMC>1&(PSOMDT>DT))!(PSOMC>1&(PSOMDT<1)) Q 0"
