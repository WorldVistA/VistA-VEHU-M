^XMB(3.9,145983,2,1588,0)="EN ; entry point"
^XMB(3.9,145983,2,1589,0)="""RTN"",""RCRPTLR"",8,0)"
^XMB(3.9,145983,2,1590,0)=" N EXCEL,POP,SORT,ZTDESC,ZTRTN,ZTSAVE,ZTSK,%ZIS"
^XMB(3.9,145983,2,1591,0)="""RTN"",""RCRPTLR"",9,0)"
^XMB(3.9,145983,2,1592,0)=" K ^TMP(""RCRPTLR"",$J)"
^XMB(3.9,145983,2,1593,0)="""RTN"",""RCRPTLR"",10,0)"
^XMB(3.9,145983,2,1594,0)=" W !!,""Repayment Plan Term Length Exceeded Report"",!"
^XMB(3.9,145983,2,1595,0)="""RTN"",""RCRPTLR"",11,0)"
^XMB(3.9,145983,2,1596,0)=" ; sort by?"
