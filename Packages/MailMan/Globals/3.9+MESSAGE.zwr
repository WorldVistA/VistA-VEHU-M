^XMB(3.9,145945,2,244,0)=" ;;2.0;GCS;**2,41**;MAR 14, 1995;Build 0"
^XMB(3.9,145945,2,245,0)="""RTN"",""GECSUSEL"",3,0)"
^XMB(3.9,145945,2,246,0)=" Q"
^XMB(3.9,145945,2,247,0)="""RTN"",""GECSUSEL"",4,0)"
^XMB(3.9,145945,2,248,0)=" ;"
^XMB(3.9,145945,2,249,0)="""RTN"",""GECSUSEL"",5,0)"
^XMB(3.9,145945,2,250,0)=" ;"
^XMB(3.9,145945,2,251,0)="""RTN"",""GECSUSEL"",6,0)"
^XMB(3.9,145945,2,252,0)="CODESHET(BATCH) ;  select an existing code sheet"
^XMB(3.9,145945,2,253,0)="""RTN"",""GECSUSEL"",7,0)"
^XMB(3.9,145945,2,254,0)=" ;  batch = only select code sheets for batch"
^XMB(3.9,145945,2,255,0)="""RTN"",""GECSUSEL"",8,0)"
^XMB(3.9,145945,2,256,0)=" N %,%Y,DIC,GECSBADA,GECSSUPR,X,Y"
^XMB(3.9,145945,2,257,0)="""RTN"",""GECSUSEL"",9,0)"
^XMB(3.9,145945,2,258,0)=" I $L(BATCH) S GECSBADA=+$O(^GECS(2101.1,""B"",BATCH,0)) I 'GECSBADA W !,""BATCH "",BATCH,"" CANNOT BE FOUND IN FILE 2101.1."" Q 0"
^XMB(3.9,145945,2,259,0)="""RTN"",""GECSUSEL"",10,0)"
^XMB(3.9,145945,2,260,0)=" W !!,$S($D(^XUSEC(""GECS SUPER EDITOR"",+$G(DUZ))):""-- You can select all code sheets created for this batch type --"",1:""-- You may only select code sheets which you have created --"")"
^XMB(3.9,145945,2,261,0)="""RTN"",""GECSUSEL"",11,0)"
^XMB(3.9,145945,2,262,0)=" I $D(^XUSEC(""GECS SUPER EDITOR"",DUZ)) S GECSSUPR=1"
^XMB(3.9,145945,2,263,0)="""RTN"",""GECSUSEL"",12,0)"
^XMB(3.9,145945,2,264,0)=" S DIC(""S"")=""I $P(^(0),U,4)=""""""""!($P(^(0),U,4)=""_DUZ_"")!($G(GECSSUPR))"""
^XMB(3.9,145945,2,265,0)="""RTN"",""GECSUSEL"",13,0)"
^XMB(3.9,145945,2,266,0)=" I $G(GECSBADA) S DIC(""S"")=DIC(""S"")_"",$P(^(0),U,3)=""_GECSBADA"
^XMB(3.9,145945,2,267,0)="""RTN"",""GECSUSEL"",14,0)"
^XMB(3.9,145945,2,268,0)=" S DIC=""^GECS(2100,"",DIC(0)=""QEAM"",DIC(""A"")=""Select CODE SHEET ID Number: "" D ^DIC"
^XMB(3.9,145945,2,269,0)="""RTN"",""GECSUSEL"",15,0)"
^XMB(3.9,145945,2,270,0)=" I Y'>0 Q 0"
^XMB(3.9,145945,2,271,0)="""RTN"",""GECSUSEL"",16,0)"
^XMB(3.9,145945,2,272,0)=" Q +Y"
^XMB(3.9,145945,2,273,0)="""RTN"",""GECSUSEL"",17,0)"
^XMB(3.9,145945,2,274,0)=" ;"
^XMB(3.9,145945,2,275,0)="""RTN"",""GECSUSEL"",18,0)"
^XMB(3.9,145945,2,276,0)=" ;"
^XMB(3.9,145945,2,277,0)="""RTN"",""GECSUSEL"",19,0)"
^XMB(3.9,145945,2,278,0)="BATTYPE(DEFAULT,DONTASK) ;  select batch type parameters"
^XMB(3.9,145945,2,279,0)="""RTN"",""GECSUSEL"",20,0)"
^XMB(3.9,145945,2,280,0)=" ;  default set to batch default in lookup, if set to '- GECO' it"
^XMB(3.9,145945,2,281,0)="""RTN"",""GECSUSEL"",21,0)"
^XMB(3.9,145945,2,282,0)=" ;          will ask to select a batch name containing '- GECO'"
^XMB(3.9,145945,2,283,0)="""RTN"",""GECSUSEL"",22,0)"
^XMB(3.9,145945,2,284,0)=" ;  dontask set to lookup on batch without asking"
^XMB(3.9,145945,2,285,0)="""RTN"",""GECSUSEL"",23,0)"
^XMB(3.9,145945,2,286,0)=" ;  return gecs(""batch"")=batch name"
^XMB(3.9,145945,2,287,0)="""RTN"",""GECSUSEL"",24,0)"
^XMB(3.9,145945,2,288,0)=" ;         gecs(""batda"")=batch da number"
^XMB(3.9,145945,2,289,0)="""RTN"",""GECSUSEL"",25,0)"
^XMB(3.9,145945,2,290,0)=" ;         gecs(""sysid"")=system identidier (ams, etc)"
^XMB(3.9,145945,2,291,0)="""RTN"",""GECSUSEL"",26,0)"
^XMB(3.9,145945,2,292,0)=" N %,%Y,DIC,X,Y"
^XMB(3.9,145945,2,293,0)="""RTN"",""GECSUSEL"",27,0)"
^XMB(3.9,145945,2,294,0)=" ;"
^XMB(3.9,145945,2,295,0)="""RTN"",""GECSUSEL"",28,0)"
^XMB(3.9,145945,2,296,0)=" K GECS(""BATCH""),GECS(""BATDA""),GECS(""SYSID"")"
^XMB(3.9,145945,2,297,0)="""RTN"",""GECSUSEL"",29,0)"
^XMB(3.9,145945,2,298,0)=" S DIC=""^GECS(2101.1,"""
^XMB(3.9,145945,2,299,0)="""RTN"",""GECSUSEL"",30,0)"
^XMB(3.9,145945,2,300,0)=" ;"
^XMB(3.9,145945,2,301,0)="""RTN"",""GECSUSEL"",31,0)"
^XMB(3.9,145945,2,302,0)=" ;  default is set (not null), lookup batch type, do not ask"
^XMB(3.9,145945,2,303,0)="""RTN"",""GECSUSEL"",32,0)"
^XMB(3.9,145945,2,304,0)=" I $G(DONTASK),$L(DEFAULT),DEFAULT'=""- GECO"" D  Q"
^XMB(3.9,145945,2,305,0)="""RTN"",""GECSUSEL"",33,0)"
^XMB(3.9,145945,2,306,0)=" .   S DIC(0)=""MNZ"",X=DEFAULT D ^DIC I Y'>0 Q"
^XMB(3.9,145945,2,307,0)="""RTN"",""GECSUSEL"",34,0)"
^XMB(3.9,145945,2,308,0)=" .   D BATCHECK"
^XMB(3.9,145945,2,309,0)="""RTN"",""GECSUSEL"",35,0)"
^XMB(3.9,145945,2,310,0)=" .   I '$G(GECS(""BATDA"")) K GECS(""BATDA""),GECS(""BATCH""),GECS(""SYSID"") Q"
^XMB(3.9,145945,2,311,0)="""RTN"",""GECSUSEL"",36,0)"
^XMB(3.9,145945,2,312,0)=" .   W !,""Batch Type: "",GECS(""BATCH"")"
^XMB(3.9,145945,2,313,0)="""RTN"",""GECSUSEL"",37,0)"
^XMB(3.9,145945,2,314,0)=" ;"
^XMB(3.9,145945,2,315,0)="""RTN"",""GECSUSEL"",38,0)"
^XMB(3.9,145945,2,316,0)=" ;  ask batch type"
^XMB(3.9,145945,2,317,0)="""RTN"",""GECSUSEL"",39,0)"
^XMB(3.9,145945,2,318,0)=" I DEFAULT=""- GECO"" S DIC(""S"")=""I $P(^(0),U)[""""- GECO"""""",DEFAULT="""""
^XMB(3.9,145945,2,319,0)="""RTN"",""GECSUSEL"",40,0)"
^XMB(3.9,145945,2,320,0)=" I $L(DEFAULT) S DIC(""B"")=DEFAULT"
^XMB(3.9,145945,2,321,0)="""RTN"",""GECSUSEL"",41,0)"
^XMB(3.9,145945,2,322,0)=" S DIC(0)=""AEQMZ"" D ^DIC I Y'>0 Q"
^XMB(3.9,145945,2,323,0)="""RTN"",""GECSUSEL"",42,0)"
^XMB(3.9,145945,2,324,0)=" D BATCHECK"
^XMB(3.9,145945,2,325,0)="""RTN"",""GECSUSEL"",43,0)"
^XMB(3.9,145945,2,326,0)=" I '$G(GECS(""BATDA"")) K GECS(""BATDA""),GECS(""BATCH""),GECS(""SYSID"") Q"
^XMB(3.9,145945,2,327,0)="""RTN"",""GECSUSEL"",44,0)"
^XMB(3.9,145945,2,328,0)=" W !,""Batch Type: "",GECS(""BATCH"")"
^XMB(3.9,145945,2,329,0)="""RTN"",""GECSUSEL"",45,0)"
^XMB(3.9,145945,2,330,0)=" D GEC2P41 ;GEC*2*41 - WARNING FOR BATCHES TO BE DISABLED IN THE FUTURE"
^XMB(3.9,145945,2,331,0)="""RTN"",""GECSUSEL"",46,0)"
^XMB(3.9,145945,2,332,0)=" Q"
^XMB(3.9,145945,2,333,0)="""RTN"",""GECSUSEL"",47,0)"
^XMB(3.9,145945,2,334,0)=" ;"
^XMB(3.9,145945,2,335,0)="""RTN"",""GECSUSEL"",48,0)"
^XMB(3.9,145945,2,336,0)=" ;"
^XMB(3.9,145945,2,337,0)="""RTN"",""GECSUSEL"",49,0)"
^XMB(3.9,145945,2,338,0)="BATNOFMS ;  select batch except for fms"
^XMB(3.9,145945,2,339,0)="""RTN"",""GECSUSEL"",50,0)"
^XMB(3.9,145945,2,340,0)=" N DONTASK"
^XMB(3.9,145945,2,341,0)="""RTN"",""GECSUSEL"",51,0)"
^XMB(3.9,145945,2,342,0)=" K GECS(""BATCH""),GECS(""BATDA""),GECS(""SYSID"")"
^XMB(3.9,145945,2,343,0)="""RTN"",""GECSUSEL"",52,0)"
^XMB(3.9,145945,2,344,0)=" I $L($G(GECSSYS)) S DONTASK=1"
^XMB(3.9,145945,2,345,0)="""RTN"",""GECSUSEL"",53,0)"
^XMB(3.9,145945,2,346,0)=" F  W ! D BATTYPE($G(GECSSYS),$G(DONTASK)) Q:'$G(GECS(""BATDA""))  D  Q:$G(GECS(""BATDA""))"
^XMB(3.9,145945,2,347,0)="""RTN"",""GECSUSEL"",54,0)"
^XMB(3.9,145945,2,348,0)=" .   I GECS(""SYSID"")=""FMS"" W !,""*** FMS DOCUMENTS CANNOT BE SELECTED ***"" K GECS(""BATDA"")"
^XMB(3.9,145945,2,349,0)="""RTN"",""GECSUSEL"",55,0)"
^XMB(3.9,145945,2,350,0)=" I '$G(GECS(""BATDA"")) K GECS(""BATCH""),GECS(""BATDA""),GECS(""SYSID"")"
^XMB(3.9,145945,2,351,0)="""RTN"",""GECSUSEL"",56,0)"
^XMB(3.9,145945,2,352,0)=" Q"
^XMB(3.9,145945,2,353,0)="""RTN"",""GECSUSEL"",57,0)"
^XMB(3.9,145945,2,354,0)=" ;"
^XMB(3.9,145945,2,355,0)="""RTN"",""GECSUSEL"",58,0)"
^XMB(3.9,145945,2,356,0)=" ;"
^XMB(3.9,145945,2,357,0)="""RTN"",""GECSUSEL"",59,0)"
^XMB(3.9,145945,2,358,0)="BATCHECK ;  check selected batch and set up variables"
^XMB(3.9,145945,2,359,0)="""RTN"",""GECSUSEL"",60,0)"
^XMB(3.9,145945,2,360,0)=" ;  y=selected batch;  y(0)=data for selected batch"
^XMB(3.9,145945,2,361,0)="""RTN"",""GECSUSEL"",61,0)"
^XMB(3.9,145945,2,362,0)=" I $P(Y(0),""^"",4)="""" W !,""SYSTEM ID FOR BATCH TYPE "",$P(Y,""^"",2),"" HAS NOT BEEN ENTERED."" Q"
^XMB(3.9,145945,2,363,0)="""RTN"",""GECSUSEL"",62,0)"
^XMB(3.9,145945,2,364,0)=" S GECS(""BATDA"")=+Y,GECS(""BATCH"")=$P(Y,""^"",2),GECS(""SYSID"")=$P(Y(0),""^"",4)"
^XMB(3.9,145945,2,365,0)="""RTN"",""GECSUSEL"",63,0)"
^XMB(3.9,145945,2,366,0)=" Q"
^XMB(3.9,145945,2,367,0)="""RTN"",""GECSUSEL"",64,0)"
^XMB(3.9,145945,2,368,0)=" ;"
^XMB(3.9,145945,2,369,0)="""RTN"",""GECSUSEL"",65,0)"
^XMB(3.9,145945,2,370,0)=" ;"
^XMB(3.9,145945,2,371,0)="""RTN"",""GECSUSEL"",66,0)"
^XMB(3.9,145945,2,372,0)="TRANTYPE(DEFAULT,DONTASK) ;  ask transaction type-segment"
^XMB(3.9,145945,2,373,0)="""RTN"",""GECSUSEL"",67,0)"
^XMB(3.9,145945,2,374,0)=" ;  default set to segment default in lookup"
^XMB(3.9,145945,2,375,0)="""RTN"",""GECSUSEL"",68,0)"
^XMB(3.9,145945,2,376,0)=" ;  dontask set to lookup on segment without asking"
^XMB(3.9,145945,2,377,0)="""RTN"",""GECSUSEL"",69,0)"
^XMB(3.9,145945,2,378,0)=" ;  gecs(""batda"")=batch da (from file 2101.1)"
^XMB(3.9,145945,2,379,0)="""RTN"",""GECSUSEL"",70,0)"
^XMB(3.9,145945,2,380,0)=" ;  gecs(""sysid"")=system id (AMS)"
^XMB(3.9,145945,2,381,0)="""RTN"",""GECSUSEL"",71,0)"
^XMB(3.9,145945,2,382,0)=" ;  return gecs(""tt"")=segment name"
^XMB(3.9,145945,2,383,0)="""RTN"",""GECSUSEL"",72,0)"
^XMB(3.9,145945,2,384,0)=" ;         gecs(""ttda"")=segment da number"
^XMB(3.9,145945,2,385,0)="""RTN"",""GECSUSEL"",73,0)"
^XMB(3.9,145945,2,386,0)=" ;         gecs(""edit"")=edit template name"
^XMB(3.9,145945,2,387,0)="""RTN"",""GECSUSEL"",74,0)"
^XMB(3.9,145945,2,388,0)=" ;         gecsflag=1 to exit application"
^XMB(3.9,145945,2,389,0)="""RTN"",""GECSUSEL"",75,0)"
^XMB(3.9,145945,2,390,0)=" N %,%Y,DIC,X,Y"
^XMB(3.9,145945,2,391,0)="""RTN"",""GECSUSEL"",76,0)"
^XMB(3.9,145945,2,392,0)=" ;"
^XMB(3.9,145945,2,393,0)="""RTN"",""GECSUSEL"",77,0)"
^XMB(3.9,145945,2,394,0)=" K GECS(""TT""),GECS(""TTDA""),GECS(""EDIT""),GECSFLAG"
^XMB(3.9,145945,2,395,0)="""RTN"",""GECSUSEL"",78,0)"
^XMB(3.9,145945,2,396,0)=" S DIC=""^GECS(2101.2,"",DIC(""S"")=""I $P(^(0),U,4)=""_GECS(""BATDA"")"
^XMB(3.9,145945,2,397,0)="""RTN"",""GECSUSEL"",79,0)"
^XMB(3.9,145945,2,398,0)=" ;"
^XMB(3.9,145945,2,399,0)="""RTN"",""GECSUSEL"",80,0)"
^XMB(3.9,145945,2,400,0)=" ;  segment defined, look it up and quit"
^XMB(3.9,145945,2,401,0)="""RTN"",""GECSUSEL"",81,0)"
^XMB(3.9,145945,2,402,0)=" I $G(DONTASK),$L(DEFAULT) D  Q"
^XMB(3.9,145945,2,403,0)="""RTN"",""GECSUSEL"",82,0)"
^XMB(3.9,145945,2,404,0)=" .   S DIC(0)=""MNZ"",X=DEFAULT D ^DIC I Y'>0 S GECSFLAG=1 Q"
^XMB(3.9,145945,2,405,0)="""RTN"",""GECSUSEL"",83,0)"
^XMB(3.9,145945,2,406,0)=" .   D TTCHECK"
^XMB(3.9,145945,2,407,0)="""RTN"",""GECSUSEL"",84,0)"
^XMB(3.9,145945,2,408,0)=" .   I '$G(GECS(""SEGDA"")) S GECSFLAG=1"
^XMB(3.9,145945,2,409,0)="""RTN"",""GECSUSEL"",85,0)"
^XMB(3.9,145945,2,410,0)=" ;"
^XMB(3.9,145945,2,411,0)="""RTN"",""GECSUSEL"",86,0)"
^XMB(3.9,145945,2,412,0)=" ;  ask for segment entry"
^XMB(3.9,145945,2,413,0)="""RTN"",""GECSUSEL"",87,0)"
^XMB(3.9,145945,2,414,0)=" I $L($G(SEGMENT)),$G(GECS(""SYSID""))=""AMS"" S DIC(""B"")=DEFAULT"
^XMB(3.9,145945,2,415,0)="""RTN"",""GECSUSEL"",88,0)"
^XMB(3.9,145945,2,416,0)=" S DIC(0)=""AEQMZ"" D ^DIC I Y'>0 S GECSFLAG=1 Q"
^XMB(3.9,145945,2,417,0)="""RTN"",""GECSUSEL"",89,0)"
^XMB(3.9,145945,2,418,0)=" D TTCHECK"
^XMB(3.9,145945,2,419,0)="""RTN"",""GECSUSEL"",90,0)"
^XMB(3.9,145945,2,420,0)=" Q"
^XMB(3.9,145945,2,421,0)="""RTN"",""GECSUSEL"",91,0)"
^XMB(3.9,145945,2,422,0)=" ;"
^XMB(3.9,145945,2,423,0)="""RTN"",""GECSUSEL"",92,0)"
^XMB(3.9,145945,2,424,0)=" ;"
^XMB(3.9,145945,2,425,0)="""RTN"",""GECSUSEL"",93,0)"
^XMB(3.9,145945,2,426,0)="TTCHECK ;  check selected transaction type and set up variables"
^XMB(3.9,145945,2,427,0)="""RTN"",""GECSUSEL"",94,0)"
^XMB(3.9,145945,2,428,0)=" ;  y=selected entry;  y(0)=data for selected entry"
^XMB(3.9,145945,2,429,0)="""RTN"",""GECSUSEL"",95,0)"
^XMB(3.9,145945,2,430,0)=" I $P(Y(0),""^"",3)=""""!($P(Y(0),""^"",5)'=""Y"") W !,""THIS TRANSACTION TYPE "",$P(Y,""^"",2),""  IS NOT YET "",$S($P(Y(0),""^"",5)'=""Y"":""ACTIVATED"",1:""AVAILABLE"") Q"
^XMB(3.9,145945,2,431,0)="""RTN"",""GECSUSEL"",96,0)"
^XMB(3.9,145945,2,432,0)=" I $P(Y(0),""^"",4)="""" W !,""THE BATCH TYPE FOR THIS TRANSACTION TYPE "",$P(Y,""^"",2),"" HAS NOT BEEN ENTERED."" Q"
^XMB(3.9,145945,2,433,0)="""RTN"",""GECSUSEL"",97,0)"
^XMB(3.9,145945,2,434,0)=" I $P(Y(0),""^"",2)="""" W !,""THE INPUT TEMPLATE FOR THIS TRANSACTION TYPE "",$P(Y,""^"",2),"" IS MISSING."" Q"
^XMB(3.9,145945,2,435,0)="""RTN"",""GECSUSEL"",98,0)"
^XMB(3.9,145945,2,436,0)=" S GECS(""TTDA"")=+Y,GECS(""TT"")=$P(Y,""^"",2),GECS(""EDIT"")=$P(Y(0),""^"",3)"
^XMB(3.9,145945,2,437,0)="""RTN"",""GECSUSEL"",99,0)"
