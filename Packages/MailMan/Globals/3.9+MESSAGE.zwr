^XMB(3.9,145944,2,204,0)="YO"
^XMB(3.9,145944,2,205,0)="""QUES"",""XPI1"",""??"")"
^XMB(3.9,145944,2,206,0)="^D INHIBIT^XPDH"
^XMB(3.9,145944,2,207,0)="""QUES"",""XPI1"",""A"")"
^XMB(3.9,145944,2,208,0)="Want KIDS to INHIBIT LOGONs during the install"
