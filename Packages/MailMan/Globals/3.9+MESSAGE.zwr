^XMB(3.9,145999,2,0)="^^53^53^3260722"
^XMB(3.9,145999,2,1,0)="PPS-N Update File: PPS_224PRV_225NEW.DATs"
^XMB(3.9,145999,2,2,0)=""
^XMB(3.9,145999,2,3,0)=" "
^XMB(3.9,145999,2,4,0)="The following active entries in your DRUG file (#50) have been unmatched from"
^XMB(3.9,145999,2,5,0)="the National Drug File (NDF).  The VA Product name and CMOP ID corresponding"
^XMB(3.9,145999,2,6,0)="to the unmatched local drug file name are listed on the indented line beneath"
^XMB(3.9,145999,2,7,0)="each entry.  An Inactivation Date may be listed for entries when this reason "
^XMB(3.9,145999,2,8,0)="applies.  Until you rematch these entries to NDF, they will not transmit to"
^XMB(3.9,145999,2,9,0)="CMOP and drug-drug interaction checks will not check for these products.  It"
^XMB(3.9,145999,2,10,0)="is critical that you rematch these products immediately.  You may also need"
^XMB(3.9,145999,2,11,0)="to match a new orderable item.  Any possible dosages and local possible "
^XMB(3.9,145999,2,12,0)="dosages for these unmatched products have been deleted. Therefore, the"
^XMB(3.9,145999,2,13,0)="dosages for each unmatched product should be reviewed after the rematch or"
^XMB(3.9,145999,2,14,0)="recreated if the product can not be rematched to a VA Product through the NDF "
^XMB(3.9,145999,2,15,0)="matching process.  "
^XMB(3.9,145999,2,16,0)=" "
^XMB(3.9,145999,2,17,0)=""
^XMB(3.9,145999,2,18,0)=" "
^XMB(3.9,145999,2,19,0)="  NONE"
^XMB(3.9,145999,2,20,0)=" "
^XMB(3.9,145999,2,21,0)="The following investigational entries in your DRUG file (#50) have been "
^XMB(3.9,145999,2,22,0)="unmatched from the National Drug File (NDF).  The VA Product name and CMOP ID"
^XMB(3.9,145999,2,23,0)="corresponding to the unmatched local drug file name are listed on the"
^XMB(3.9,145999,2,24,0)="indented line beneath each entry.  An Inactivation Date may be listed for"
^XMB(3.9,145999,2,25,0)="entries when this reason applies.  Until you rematch these entries to NDF,"
^XMB(3.9,145999,2,26,0)="they will not transmit to CMOP and drug-drug interaction checks will not"
^XMB(3.9,145999,2,27,0)="check for these products.  It is critical that you rematch these products"
^XMB(3.9,145999,2,28,0)="immediately.  You may also need to match a new orderable item.  Any possible"
^XMB(3.9,145999,2,29,0)="dosages and local possible dosages for these unmatched products have been"
^XMB(3.9,145999,2,30,0)="deleted. Therefore, the dosages for each unmatched product should be reviewed"
^XMB(3.9,145999,2,31,0)="after the rematch or recreated if the product can not be rematched to a VA"
^XMB(3.9,145999,2,32,0)="Product through the NDF matching process.  "
^XMB(3.9,145999,2,33,0)=" "
^XMB(3.9,145999,2,34,0)=""
^XMB(3.9,145999,2,35,0)=" "
^XMB(3.9,145999,2,36,0)="  NONE"
^XMB(3.9,145999,2,37,0)=" "
^XMB(3.9,145999,2,38,0)="The following inactive entries in your DRUG file (#50) have been unmatched"
^XMB(3.9,145999,2,39,0)="from the National Drug File (NDF).  The VA Product name and CMOP ID"
^XMB(3.9,145999,2,40,0)="corresponding to the unmatched local drug file name are listed on the"
^XMB(3.9,145999,2,41,0)="indented line beneath each entry.  An Inactivation Date may be listed for"
^XMB(3.9,145999,2,42,0)="entries when this reason applies.  Until you rematch these entries to NDF,"
^XMB(3.9,145999,2,43,0)="they will not transmit to CMOP and drug-drug interaction checks will not"
^XMB(3.9,145999,2,44,0)="check for these products.  It is critical that you rematch these products"
^XMB(3.9,145999,2,45,0)="immediately.  You may also need to match a new orderable item.  Any possible"
^XMB(3.9,145999,2,46,0)="dosages and local possible dosages for these unmatched products have been"
^XMB(3.9,145999,2,47,0)="deleted. Therefore, the dosages for each unmatched product should be reviewed"
^XMB(3.9,145999,2,48,0)="after the rematch or recreated if the product can not be rematched to a VA"
^XMB(3.9,145999,2,49,0)="Product through the NDF matching process.  "
