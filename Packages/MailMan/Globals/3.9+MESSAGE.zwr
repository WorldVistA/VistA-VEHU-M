^XMB(3.9,145945,2,442,0)=" ;"
^XMB(3.9,145945,2,443,0)="""RTN"",""GECSUSEL"",102,0)"
^XMB(3.9,145945,2,444,0)="BATCHSEL(GECSDICS) ;  select batch number from file 2101.3"
