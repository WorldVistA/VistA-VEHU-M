^XMB(3.9,145985,2,242,0)=2
^XMB(3.9,145985,2,243,0)="""RTN"",""PSOBKDE1"")"
^XMB(3.9,145985,2,244,0)="0^2^B8511579"
^XMB(3.9,145985,2,245,0)="""RTN"",""PSOBKDE1"",1,0)"
^XMB(3.9,145985,2,246,0)="PSOBKDE1 ;BIR/MR-Sub-routines for Backdoor Rx Order Edit ;11/25/02"
^XMB(3.9,145985,2,247,0)="""RTN"",""PSOBKDE1"",2,0)"
^XMB(3.9,145985,2,248,0)=" ;;7.0;OUTPATIENT PHARMACY;**117,133,372,402,500,518**;DEC 1997;Build 0"
^XMB(3.9,145985,2,249,0)="""RTN"",""PSOBKDE1"",3,0)"
^XMB(3.9,145985,2,250,0)=" ;"
^XMB(3.9,145985,2,251,0)="""RTN"",""PSOBKDE1"",4,0)"
^XMB(3.9,145985,2,252,0)="LST1 ;"
^XMB(3.9,145985,2,253,0)="""RTN"",""PSOBKDE1"",5,0)"
^XMB(3.9,145985,2,254,0)=" W @IOF"
^XMB(3.9,145985,2,255,0)="""RTN"",""PSOBKDE1"",6,0)"
^XMB(3.9,145985,2,256,0)=" N PSOLCNT,DIRUT,DTOUT,DUOUT,I,PSODOSCT,PSODOSFL,PSOBKDF1"
^XMB(3.9,145985,2,257,0)="""RTN"",""PSOBKDE1"",7,0)"
^XMB(3.9,145985,2,258,0)=" W !,""This is the amount of medication the patient is to receive as one dose"""
^XMB(3.9,145985,2,259,0)="""RTN"",""PSOBKDE1"",8,0)"
^XMB(3.9,145985,2,260,0)=" W !,""for this order. This can be a numeric value, such as 325 or 650 or an"""
^XMB(3.9,145985,2,261,0)="""RTN"",""PSOBKDE1"",9,0)"
^XMB(3.9,145985,2,262,0)=" W !,""amount with a unit of measure such as 325MG or 650MG. You may also enter"""
^XMB(3.9,145985,2,263,0)="""RTN"",""PSOBKDE1"",10,0)"
^XMB(3.9,145985,2,264,0)=" W !,""a free text dosage, such as 1 Tablet or 2 Tablets"",!"
^XMB(3.9,145985,2,265,0)="""RTN"",""PSOBKDE1"",11,0)"
^XMB(3.9,145985,2,266,0)=" S PSOLCNT=5,PSOBKDF1=1"
^XMB(3.9,145985,2,267,0)="""RTN"",""PSOBKDE1"",12,0)"
^XMB(3.9,145985,2,268,0)=" ;"
^XMB(3.9,145985,2,269,0)="""RTN"",""PSOBKDE1"",13,0)"
^XMB(3.9,145985,2,270,0)="LST ;"
^XMB(3.9,145985,2,271,0)="""RTN"",""PSOBKDE1"",14,0)"
^XMB(3.9,145985,2,272,0)=" I '$G(PSOBKDF1) W @IOF S PSOBKDF1=1"
^XMB(3.9,145985,2,273,0)="""RTN"",""PSOBKDE1"",15,0)"
^XMB(3.9,145985,2,274,0)=" N DIR I '$D(DOSE(""DD"")) D  Q"
^XMB(3.9,145985,2,275,0)="""RTN"",""PSOBKDE1"",16,0)"
^XMB(3.9,145985,2,276,0)=" . W !,"" No dosages are available"""
^XMB(3.9,145985,2,277,0)="""RTN"",""PSOBKDE1"",17,0)"
^XMB(3.9,145985,2,278,0)=" . N X S X=$$GET1^DIQ(50,PSODRUG(""IEN""),100,""I"")"
^XMB(3.9,145985,2,279,0)="""RTN"",""PSOBKDE1"",18,0)"
^XMB(3.9,145985,2,280,0)=" . W $S(X'=""""&(DT>X):"" because the Drug is now Inactive."",1:""!"")"
^XMB(3.9,145985,2,281,0)="""RTN"",""PSOBKDE1"",19,0)"
^XMB(3.9,145985,2,282,0)=" . W !,"" Please, enter a free text dosage, or You may select a New"""
^XMB(3.9,145985,2,283,0)="""RTN"",""PSOBKDE1"",20,0)"
^XMB(3.9,145985,2,284,0)=" . W !,"" Orderable Item and Dispense Drug for this order, or you can"""
^XMB(3.9,145985,2,285,0)="""RTN"",""PSOBKDE1"",21,0)"
^XMB(3.9,145985,2,286,0)=" . W !,"" enter a New Order with an Active Drug."""
^XMB(3.9,145985,2,287,0)="""RTN"",""PSOBKDE1"",22,0)"
^XMB(3.9,145985,2,288,0)=" . S PSOLCNT=$G(PSOLCNT)+4"
^XMB(3.9,145985,2,289,0)="""RTN"",""PSOBKDE1"",23,0)"
