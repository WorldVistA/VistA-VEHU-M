^XMB(3.9,145983,2,966,0)=" ; Confirm that the user wishes to close the plan "
^XMB(3.9,145983,2,967,0)="""RTN"",""RCRPENTR"",189,0)"
^XMB(3.9,145983,2,968,0)=" Q:'$$CORRECT^RCRPU(3) -1"
^XMB(3.9,145983,2,969,0)="""RTN"",""RCRPENTR"",190,0)"
^XMB(3.9,145983,2,970,0)=" ; Enter the reason for closing the plan (defaulting for non-payment or administrative)"
^XMB(3.9,145983,2,971,0)="""RTN"",""RCRPENTR"",191,0)"
^XMB(3.9,145983,2,972,0)=" S RCREASON=$$GETRSN^RCRPU1"
^XMB(3.9,145983,2,973,0)="""RTN"",""RCRPENTR"",192,0)"
^XMB(3.9,145983,2,974,0)=" Q:RCREASON=-1 -1"
^XMB(3.9,145983,2,975,0)="""RTN"",""RCRPENTR"",193,0)"
^XMB(3.9,145983,2,976,0)=" ; Confirm that the reason and closure is correct"
^XMB(3.9,145983,2,977,0)="""RTN"",""RCRPENTR"",194,0)"
^XMB(3.9,145983,2,978,0)=" Q:'$$CORRECT^RCRPU -1"
^XMB(3.9,145983,2,979,0)="""RTN"",""RCRPENTR"",195,0)"
^XMB(3.9,145983,2,980,0)=" ; Close the plan"
^XMB(3.9,145983,2,981,0)="""RTN"",""RCRPENTR"",196,0)"
^XMB(3.9,145983,2,982,0)=" D CLSPLAN^RCRPU3(RCIEN,RCREASON)"
^XMB(3.9,145983,2,983,0)="""RTN"",""RCRPENTR"",197,0)"
^XMB(3.9,145983,2,984,0)=" ;"
^XMB(3.9,145983,2,985,0)="""RTN"",""RCRPENTR"",198,0)"
^XMB(3.9,145983,2,986,0)=" W !,""Plan Closed.  "" D PAUSE^RCRPU"
^XMB(3.9,145983,2,987,0)="""RTN"",""RCRPENTR"",199,0)"
^XMB(3.9,145983,2,988,0)=" ;"
^XMB(3.9,145983,2,989,0)="""RTN"",""RCRPENTR"",200,0)"
^XMB(3.9,145983,2,990,0)=" Q 1"
^XMB(3.9,145983,2,991,0)="""RTN"",""RCRPENTR"",201,0)"
^XMB(3.9,145983,2,992,0)=" ;"
^XMB(3.9,145983,2,993,0)="""RTN"",""RCRPENTR"",202,0)"
^XMB(3.9,145983,2,994,0)="ADJSCHED(RCIEN,RCORLN,RCNEWLN) ; Add or subtract payments from a plan's Schedule."
^XMB(3.9,145983,2,995,0)="""RTN"",""RCRPENTR"",203,0)"
^XMB(3.9,145983,2,996,0)=" ;INPUT - RCIEN - IEN of the Repayment Plan being adjusted"
^XMB(3.9,145983,2,997,0)="""RTN"",""RCRPENTR"",204,0)"
^XMB(3.9,145983,2,998,0)=" ;        RCORLN - Original Term Length of the payments"
^XMB(3.9,145983,2,999,0)="""RTN"",""RCRPENTR"",205,0)"
^XMB(3.9,145983,2,1000,0)=" ;        RCNEWLN - New Term Length"
^XMB(3.9,145983,2,1001,0)="""RTN"",""RCRPENTR"",206,0)"
^XMB(3.9,145983,2,1002,0)=" ;"
^XMB(3.9,145983,2,1003,0)="""RTN"",""RCRPENTR"",207,0)"
^XMB(3.9,145983,2,1004,0)=" N RCFBFLG,RCLP,RCLP1,RCPD,RCSTDT,RCSUB,RCFB,RCFBCT,RCORIEN"
^XMB(3.9,145983,2,1005,0)="""RTN"",""RCRPENTR"",208,0)"
^XMB(3.9,145983,2,1006,0)=" ;"
^XMB(3.9,145983,2,1007,0)="""RTN"",""RCRPENTR"",209,0)"
^XMB(3.9,145983,2,1008,0)=" ;Clear RPP Temp array"
^XMB(3.9,145983,2,1009,0)="""RTN"",""RCRPENTR"",210,0)"
^XMB(3.9,145983,2,1010,0)=" K ^TMP(""RCRPP"",$J)"
^XMB(3.9,145983,2,1011,0)="""RTN"",""RCRPENTR"",211,0)"
^XMB(3.9,145983,2,1012,0)=" ;"
^XMB(3.9,145983,2,1013,0)="""RTN"",""RCRPENTR"",212,0)"
^XMB(3.9,145983,2,1014,0)=" I RCORLN>RCNEWLN D  Q"
^XMB(3.9,145983,2,1015,0)="""RTN"",""RCRPENTR"",213,0)"
^XMB(3.9,145983,2,1016,0)=" .  ;Count the # of payments forborne"
^XMB(3.9,145983,2,1017,0)="""RTN"",""RCRPENTR"",214,0)"
^XMB(3.9,145983,2,1018,0)=" .  S RCFBCT=0,RCLP=0"
^XMB(3.9,145983,2,1019,0)="""RTN"",""RCRPENTR"",215,0)"
^XMB(3.9,145983,2,1020,0)=" .  F  S RCLP=$O(^RCRP(340.5,RCIEN,2,RCLP)) Q:'RCLP  D"
^XMB(3.9,145983,2,1021,0)="""RTN"",""RCRPENTR"",216,0)"
^XMB(3.9,145983,2,1022,0)=" .  .  S RCFB=$P($G(^RCRP(340.5,RCIEN,2,RCLP,0)),U,3)"
^XMB(3.9,145983,2,1023,0)="""RTN"",""RCRPENTR"",217,0)"
^XMB(3.9,145983,2,1024,0)=" .  .  I RCFB S RCFBCT=RCFBCT+1"
^XMB(3.9,145983,2,1025,0)="""RTN"",""RCRPENTR"",218,0)"
^XMB(3.9,145983,2,1026,0)=" .  ;"
^XMB(3.9,145983,2,1027,0)="""RTN"",""RCRPENTR"",219,0)"
^XMB(3.9,145983,2,1028,0)=" .  ;find all of the payments paid, stop on the first unpaid."
^XMB(3.9,145983,2,1029,0)="""RTN"",""RCRPENTR"",220,0)"
^XMB(3.9,145983,2,1030,0)=" .  S RCLP=0 F  S RCLP=$O(^RCRP(340.5,RCIEN,2,RCLP)) Q:'RCLP  S RCPD=$P($G(^RCRP(340.5,RCIEN,2,RCLP,0)),U,2) Q:'RCPD "
^XMB(3.9,145983,2,1031,0)="""RTN"",""RCRPENTR"",221,0)"
^XMB(3.9,145983,2,1032,0)=" .  ;"
^XMB(3.9,145983,2,1033,0)="""RTN"",""RCRPENTR"",222,0)"
^XMB(3.9,145983,2,1034,0)=" .  ; Count the new remaining payment out."
^XMB(3.9,145983,2,1035,0)="""RTN"",""RCRPENTR"",223,0)"
^XMB(3.9,145983,2,1036,0)=" .  S RCLP1=RCLP+RCFBCT+RCNEWLN-1   ;first missing payment + # Forborne months + new length of payment - 1 for the first missing payment)"
^XMB(3.9,145983,2,1037,0)="""RTN"",""RCRPENTR"",224,0)"
^XMB(3.9,145983,2,1038,0)=" .  ;"
^XMB(3.9,145983,2,1039,0)="""RTN"",""RCRPENTR"",225,0)"
^XMB(3.9,145983,2,1040,0)=" .  ; remove the remaining payments from schedule"
^XMB(3.9,145983,2,1041,0)="""RTN"",""RCRPENTR"",226,0)"
^XMB(3.9,145983,2,1042,0)=" .  F  S RCLP1=$O(^RCRP(340.5,RCIEN,2,RCLP1)) Q:'RCLP1  D"
^XMB(3.9,145983,2,1043,0)="""RTN"",""RCRPENTR"",227,0)"
^XMB(3.9,145983,2,1044,0)=" .  .  ;Do not remove payments forborne"
^XMB(3.9,145983,2,1045,0)="""RTN"",""RCRPENTR"",228,0)"
^XMB(3.9,145983,2,1046,0)=" .  .  S RCFBFLG=+$P($G(^RCRP(340.5,RCIEN,2,RCLP1,0)),U,3)"
^XMB(3.9,145983,2,1047,0)="""RTN"",""RCRPENTR"",229,0)"
^XMB(3.9,145983,2,1048,0)=" .  .  Q:RCFBFLG"
^XMB(3.9,145983,2,1049,0)="""RTN"",""RCRPENTR"",230,0)"
^XMB(3.9,145983,2,1050,0)=" .  .  ;"
^XMB(3.9,145983,2,1051,0)="""RTN"",""RCRPENTR"",231,0)"
^XMB(3.9,145983,2,1052,0)=" .  .  ; Remove the month from the schedule."
^XMB(3.9,145983,2,1053,0)="""RTN"",""RCRPENTR"",232,0)"
^XMB(3.9,145983,2,1054,0)=" .  .  S DA(1)=RCIEN,DA=RCLP1,DIK=""^RCRP(340.5,""_DA(1)_"",2,"""
^XMB(3.9,145983,2,1055,0)="""RTN"",""RCRPENTR"",233,0)"
^XMB(3.9,145983,2,1056,0)=" .  .  D ^DIK"
^XMB(3.9,145983,2,1057,0)="""RTN"",""RCRPENTR"",234,0)"
^XMB(3.9,145983,2,1058,0)=" .  .  K DA,DIK"
^XMB(3.9,145983,2,1059,0)="""RTN"",""RCRPENTR"",235,0)"
^XMB(3.9,145983,2,1060,0)=" ;"
^XMB(3.9,145983,2,1061,0)="""RTN"",""RCRPENTR"",236,0)"
^XMB(3.9,145983,2,1062,0)=" ;Otherwise, add new payments to schedule."
^XMB(3.9,145983,2,1063,0)="""RTN"",""RCRPENTR"",237,0)"
^XMB(3.9,145983,2,1064,0)=" ;Find the last date by looking for the last entry and grabbing the first piece."
^XMB(3.9,145983,2,1065,0)="""RTN"",""RCRPENTR"",238,0)"
^XMB(3.9,145983,2,1066,0)=" S RCORIEN=$O(^RCRP(340.5,RCIEN,2,""A""),-1)"
^XMB(3.9,145983,2,1067,0)="""RTN"",""RCRPENTR"",239,0)"
^XMB(3.9,145983,2,1068,0)=" S RCSTDT=$P($G(^RCRP(340.5,RCIEN,2,RCORIEN,0)),U,1)"
^XMB(3.9,145983,2,1069,0)="""RTN"",""RCRPENTR"",240,0)"
^XMB(3.9,145983,2,1070,0)=" D BLDPLN^RCRPU2(RCSTDT,(RCNEWLN-RCORLN),1,RCIEN)"
^XMB(3.9,145983,2,1071,0)="""RTN"",""RCRPENTR"",241,0)"
^XMB(3.9,145983,2,1072,0)=" ;"
^XMB(3.9,145983,2,1073,0)="""RTN"",""RCRPENTR"",242,0)"
^XMB(3.9,145983,2,1074,0)=" ; Add the new months to the Schedule"
^XMB(3.9,145983,2,1075,0)="""RTN"",""RCRPENTR"",243,0)"
^XMB(3.9,145983,2,1076,0)=" ; Update the Schedule Node"
^XMB(3.9,145983,2,1077,0)="""RTN"",""RCRPENTR"",244,0)"
^XMB(3.9,145983,2,1078,0)=" S RCSUB=0"
^XMB(3.9,145983,2,1079,0)="""RTN"",""RCRPENTR"",245,0)"
^XMB(3.9,145983,2,1080,0)=" F  S RCSUB=$O(^TMP(""RCRPP"",$J,""PLAN"",RCSUB)) Q:'RCSUB  D UPDSCHED^RCRPU(RCIEN,RCSUB)"
^XMB(3.9,145983,2,1081,0)="""RTN"",""RCRPENTR"",246,0)"
^XMB(3.9,145983,2,1082,0)=" ;"
^XMB(3.9,145983,2,1083,0)="""RTN"",""RCRPENTR"",247,0)"
^XMB(3.9,145983,2,1084,0)=" ;Clear temp array"
^XMB(3.9,145983,2,1085,0)="""RTN"",""RCRPENTR"",248,0)"
^XMB(3.9,145983,2,1086,0)=" K ^TMP(""RCRPP"",$J)"
^XMB(3.9,145983,2,1087,0)="""RTN"",""RCRPENTR"",249,0)"
^XMB(3.9,145983,2,1088,0)=" ;"
^XMB(3.9,145983,2,1089,0)="""RTN"",""RCRPENTR"",250,0)"
^XMB(3.9,145983,2,1090,0)=" Q"
^XMB(3.9,145983,2,1091,0)="""RTN"",""RCRPENTR"",251,0)"
^XMB(3.9,145983,2,1092,0)=" ;"
^XMB(3.9,145983,2,1093,0)="""RTN"",""RCRPNP"")"
^XMB(3.9,145983,2,1094,0)="0^1^B78689978"
^XMB(3.9,145983,2,1095,0)="""RTN"",""RCRPNP"",1,0)"
^XMB(3.9,145983,2,1096,0)="RCRPNP ;EDE/SAB - REPAYMENT PLAN UTILITIES;12/31/2020  8:40 AM"
^XMB(3.9,145983,2,1097,0)="""RTN"",""RCRPNP"",2,0)"
^XMB(3.9,145983,2,1098,0)=" ;;4.5;Accounts Receivable;**378,389,423,422**;Mar 20, 1995;Build 0"
^XMB(3.9,145983,2,1099,0)="""RTN"",""RCRPNP"",3,0)"
^XMB(3.9,145983,2,1100,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145983,2,1101,0)="""RTN"",""RCRPNP"",4,0)"
^XMB(3.9,145983,2,1102,0)=" ;"
^XMB(3.9,145983,2,1103,0)="""RTN"",""RCRPNP"",5,0)"
^XMB(3.9,145983,2,1104,0)=" Q"
^XMB(3.9,145983,2,1105,0)="""RTN"",""RCRPNP"",6,0)"
^XMB(3.9,145983,2,1106,0)=" ;"
^XMB(3.9,145983,2,1107,0)="""RTN"",""RCRPNP"",7,0)"
^XMB(3.9,145983,2,1108,0)="MAIN ; Entry Point for the nightly process"
^XMB(3.9,145983,2,1109,0)="""RTN"",""RCRPNP"",8,0)"
^XMB(3.9,145983,2,1110,0)=" ;"
^XMB(3.9,145983,2,1111,0)="""RTN"",""RCRPNP"",9,0)"
^XMB(3.9,145983,2,1112,0)=" D UPDSTAT"
^XMB(3.9,145983,2,1113,0)="""RTN"",""RCRPNP"",10,0)"
^XMB(3.9,145983,2,1114,0)=" D ADDBILLS"
^XMB(3.9,145983,2,1115,0)="""RTN"",""RCRPNP"",11,0)"
^XMB(3.9,145983,2,1116,0)=" D UPDCS"
^XMB(3.9,145983,2,1117,0)="""RTN"",""RCRPNP"",12,0)"
^XMB(3.9,145983,2,1118,0)=" Q"
^XMB(3.9,145983,2,1119,0)="""RTN"",""RCRPNP"",13,0)"
^XMB(3.9,145983,2,1120,0)=" ;"
^XMB(3.9,145983,2,1121,0)="""RTN"",""RCRPNP"",14,0)"
^XMB(3.9,145983,2,1122,0)="UPDSTAT ;Review all active plans to determine their current status."
^XMB(3.9,145983,2,1123,0)="""RTN"",""RCRPNP"",15,0)"
^XMB(3.9,145983,2,1124,0)=" ;"
^XMB(3.9,145983,2,1125,0)="""RTN"",""RCRPNP"",16,0)"
^XMB(3.9,145983,2,1126,0)=" N RCFLG36,RCFLG60,RCI,RCIENS,RCD0,RCCURST,RCNEWST,RCSTSTRT,RCSTEND"
^XMB(3.9,145983,2,1127,0)="""RTN"",""RCRPNP"",17,0)"
^XMB(3.9,145983,2,1128,0)=" ;Loop through the Repayment Plan file"
^XMB(3.9,145983,2,1129,0)="""RTN"",""RCRPNP"",18,0)"
^XMB(3.9,145983,2,1130,0)=" ;"
^XMB(3.9,145983,2,1131,0)="""RTN"",""RCRPNP"",19,0)"
^XMB(3.9,145983,2,1132,0)=" ; Start calculating execution time"
^XMB(3.9,145983,2,1133,0)="""RTN"",""RCRPNP"",20,0)"
^XMB(3.9,145983,2,1134,0)=" S RCSTSTRT=$H"
^XMB(3.9,145983,2,1135,0)="""RTN"",""RCRPNP"",21,0)"
^XMB(3.9,145983,2,1136,0)=" ;"
^XMB(3.9,145983,2,1137,0)="""RTN"",""RCRPNP"",22,0)"
^XMB(3.9,145983,2,1138,0)=" S RCI=0 F  S RCI=$O(^RCRP(340.5,RCI)) Q:'RCI  D"
^XMB(3.9,145983,2,1139,0)="""RTN"",""RCRPNP"",23,0)"
^XMB(3.9,145983,2,1140,0)=" .S RCD0=$G(^RCRP(340.5,RCI,0)) Q:'RCD0"
^XMB(3.9,145983,2,1141,0)="""RTN"",""RCRPNP"",24,0)"
^XMB(3.9,145983,2,1142,0)=" .; Extract current status."
^XMB(3.9,145983,2,1143,0)="""RTN"",""RCRPNP"",25,0)"
^XMB(3.9,145983,2,1144,0)=" .S RCCURST=$P(RCD0,U,7)"
^XMB(3.9,145983,2,1145,0)="""RTN"",""RCRPNP"",26,0)"
^XMB(3.9,145983,2,1146,0)=" .; Recalculate the status"
^XMB(3.9,145983,2,1147,0)="""RTN"",""RCRPNP"",27,0)"
^XMB(3.9,145983,2,1148,0)=" .S RCNEWST=$$STATUS^RCRPU1(RCI)"
^XMB(3.9,145983,2,1149,0)="""RTN"",""RCRPNP"",28,0)"
^XMB(3.9,145983,2,1150,0)=" .; If the status is different"
^XMB(3.9,145983,2,1151,0)="""RTN"",""RCRPNP"",29,0)"
^XMB(3.9,145983,2,1152,0)=" .I RCCURST'=RCNEWST D"
^XMB(3.9,145983,2,1153,0)="""RTN"",""RCRPNP"",30,0)"
^XMB(3.9,145983,2,1154,0)=" ..; Update the status to the New Status"
^XMB(3.9,145983,2,1155,0)="""RTN"",""RCRPNP"",31,0)"
^XMB(3.9,145983,2,1156,0)=" ..D UPDSTAT^RCRPU1(RCI,RCNEWST)"
^XMB(3.9,145983,2,1157,0)="""RTN"",""RCRPNP"",32,0)"
^XMB(3.9,145983,2,1158,0)=" ..; If the new status is Defaulted (5), update the PRINT DEFAULTED flag (1.02)"
^XMB(3.9,145983,2,1159,0)="""RTN"",""RCRPNP"",33,0)"
^XMB(3.9,145983,2,1160,0)=" ..I RCNEWST=5 D UPDPRDF(RCI,1)"
^XMB(3.9,145983,2,1161,0)="""RTN"",""RCRPNP"",34,0)"
^XMB(3.9,145983,2,1162,0)=" ..; If the new status is Delinquent (4), update the PRINT DEFAULTED flag (1.03)"
^XMB(3.9,145983,2,1163,0)="""RTN"",""RCRPNP"",35,0)"
^XMB(3.9,145983,2,1164,0)=" ..I RCNEWST=4 D UPDPRDL(RCI,1)"
^XMB(3.9,145983,2,1165,0)="""RTN"",""RCRPNP"",36,0)"
^XMB(3.9,145983,2,1166,0)=" ..; If going from ""new"" to a diff. status, check review flags"
^XMB(3.9,145983,2,1167,0)="""RTN"",""RCRPNP"",37,0)"
^XMB(3.9,145983,2,1168,0)=" ..I RCCURST=1 D  ; PRCA*4.5*422"
^XMB(3.9,145983,2,1169,0)="""RTN"",""RCRPNP"",38,0)"
^XMB(3.9,145983,2,1170,0)=" ...S RCIENS=RCI_"","""
^XMB(3.9,145983,2,1171,0)="""RTN"",""RCRPNP"",39,0)"
^XMB(3.9,145983,2,1172,0)=" ...S RCFLG36=$$GET1^DIQ(340.5,RCIENS,1.06,""I"")"
^XMB(3.9,145983,2,1173,0)="""RTN"",""RCRPNP"",40,0)"
^XMB(3.9,145983,2,1174,0)=" ...S RCFLG60=+$$GET1^DIQ(340.5,RCIENS,1.01,""I"")"
^XMB(3.9,145983,2,1175,0)="""RTN"",""RCRPNP"",41,0)"
^XMB(3.9,145983,2,1176,0)=" ...D CHKFLGS^RCRPU1(RCI,$$REMPMNTS^RCRPU3(RCI,$$GET1^DIQ(340.5,RCIENS,.06,""I"")),RCFLG36,RCFLG60)"
^XMB(3.9,145983,2,1177,0)="""RTN"",""RCRPNP"",42,0)"
^XMB(3.9,145983,2,1178,0)=" ...I $$GET1^DIQ(340.5,RCIENS,1.06,""I"")=0 D MSGREV^RCRPWLUT"
^XMB(3.9,145983,2,1179,0)="""RTN"",""RCRPNP"",43,0)"
^XMB(3.9,145983,2,1180,0)=" ...Q"
^XMB(3.9,145983,2,1181,0)="""RTN"",""RCRPNP"",44,0)"
^XMB(3.9,145983,2,1182,0)=" ..Q"
^XMB(3.9,145983,2,1183,0)="""RTN"",""RCRPNP"",45,0)"
^XMB(3.9,145983,2,1184,0)=" .Q"
^XMB(3.9,145983,2,1185,0)="""RTN"",""RCRPNP"",46,0)"
^XMB(3.9,145983,2,1186,0)=" ;"
^XMB(3.9,145983,2,1187,0)="""RTN"",""RCRPNP"",47,0)"
^XMB(3.9,145983,2,1188,0)=" ; Update Processing time metrics"
^XMB(3.9,145983,2,1189,0)="""RTN"",""RCRPNP"",48,0)"
^XMB(3.9,145983,2,1190,0)=" S RCSTEND=$H"
^XMB(3.9,145983,2,1191,0)="""RTN"",""RCRPNP"",49,0)"
^XMB(3.9,145983,2,1192,0)=" D UPDMET^RCSTATU(2.03,$$HDIFF^XLFDT(RCSTEND,RCSTSTRT,2))"
^XMB(3.9,145983,2,1193,0)="""RTN"",""RCRPNP"",50,0)"
^XMB(3.9,145983,2,1194,0)=" Q"
^XMB(3.9,145983,2,1195,0)="""RTN"",""RCRPNP"",51,0)"
^XMB(3.9,145983,2,1196,0)=" ;"
^XMB(3.9,145983,2,1197,0)="""RTN"",""RCRPNP"",52,0)"
^XMB(3.9,145983,2,1198,0)="ADDBILLS ;Review a debtor and all non referred, Active bills to the plan."
^XMB(3.9,145983,2,1199,0)="""RTN"",""RCRPNP"",53,0)"
^XMB(3.9,145983,2,1200,0)=" ;"
^XMB(3.9,145983,2,1201,0)="""RTN"",""RCRPNP"",54,0)"
^XMB(3.9,145983,2,1202,0)=" N RCACTDT,RCBILLDA,RCRPIEN,RCSTAT,RCACTIVE,RCDBTR,RCSTP,RCD0,RCRPSTAT,RCD7,RCAMT,RCMNPY,RCNOMN,RCNWLN,RCRPD0"
^XMB(3.9,145983,2,1203,0)="""RTN"",""RCRPNP"",55,0)"
^XMB(3.9,145983,2,1204,0)=" N RCNWMN,RCNWMOD,RCPLNBL,RCRMLN,RCSTSTRT,RCSTEND,RCREV36"
^XMB(3.9,145983,2,1205,0)="""RTN"",""RCRPNP"",56,0)"
^XMB(3.9,145983,2,1206,0)=" N RCFLG36,RCFLG60,RCIENS,RCQUIT"
^XMB(3.9,145983,2,1207,0)="""RTN"",""RCRPNP"",57,0)"
^XMB(3.9,145983,2,1208,0)=" ;"
^XMB(3.9,145983,2,1209,0)="""RTN"",""RCRPNP"",58,0)"
^XMB(3.9,145983,2,1210,0)=" ; Start calculating execution time"
^XMB(3.9,145983,2,1211,0)="""RTN"",""RCRPNP"",59,0)"
^XMB(3.9,145983,2,1212,0)=" S RCSTSTRT=$H"
^XMB(3.9,145983,2,1213,0)="""RTN"",""RCRPNP"",60,0)"
^XMB(3.9,145983,2,1214,0)=" ;"
^XMB(3.9,145983,2,1215,0)="""RTN"",""RCRPNP"",61,0)"
^XMB(3.9,145983,2,1216,0)=" S RCACTDT=$$DT^XLFDT"
^XMB(3.9,145983,2,1217,0)="""RTN"",""RCRPNP"",62,0)"
^XMB(3.9,145983,2,1218,0)=" S (RCREV36,RCRPIEN)=0  ; PRCA*4.5*389"
^XMB(3.9,145983,2,1219,0)="""RTN"",""RCRPNP"",63,0)"
^XMB(3.9,145983,2,1220,0)=" F  S RCRPIEN=$O(^RCRP(340.5,RCRPIEN)) Q:'RCRPIEN  D"
^XMB(3.9,145983,2,1221,0)="""RTN"",""RCRPNP"",64,0)"
^XMB(3.9,145983,2,1222,0)=" .; Check to see if the plan is active.  If not, skip it and grab the next"
^XMB(3.9,145983,2,1223,0)="""RTN"",""RCRPNP"",65,0)"
^XMB(3.9,145983,2,1224,0)=" .S RCRPD0=$G(^RCRP(340.5,RCRPIEN,0)) Q:RCRPD0="""""
^XMB(3.9,145983,2,1225,0)="""RTN"",""RCRPNP"",66,0)"
^XMB(3.9,145983,2,1226,0)=" .Q:'+$P(RCRPD0,U,12)  ; Quit if the Repayment Plan's AUTO ADD field is not set to Yes (it is No or NULL)"
^XMB(3.9,145983,2,1227,0)="""RTN"",""RCRPNP"",67,0)"
^XMB(3.9,145983,2,1228,0)=" .S RCRPSTAT=$P(RCRPD0,U,7)"
^XMB(3.9,145983,2,1229,0)="""RTN"",""RCRPNP"",68,0)"
^XMB(3.9,145983,2,1230,0)=" .Q:RCRPSTAT>5   ;Plan is TERMINATED, CLOSED or PAID IN FULL."
^XMB(3.9,145983,2,1231,0)="""RTN"",""RCRPNP"",69,0)"
^XMB(3.9,145983,2,1232,0)=" .; If the plan is under review, don't attempt to add bills"
^XMB(3.9,145983,2,1233,0)="""RTN"",""RCRPNP"",70,0)"
^XMB(3.9,145983,2,1234,0)=" .S RCIENS=RCRPIEN_"","""
^XMB(3.9,145983,2,1235,0)="""RTN"",""RCRPNP"",71,0)"
^XMB(3.9,145983,2,1236,0)=" .S RCFLG60=+$$GET1^DIQ(340.5,RCIENS,1.01,""I"")"
^XMB(3.9,145983,2,1237,0)="""RTN"",""RCRPNP"",72,0)"
^XMB(3.9,145983,2,1238,0)=" .S RCFLG36=$$GET1^DIQ(340.5,RCIENS,1.06,""I"")"
^XMB(3.9,145983,2,1239,0)="""RTN"",""RCRPNP"",73,0)"
^XMB(3.9,145983,2,1240,0)=" .S RCRMLN=$$REMPMNTS^RCRPU3(RCRPIEN,$$GET1^DIQ(340.5,RCIENS,.06,""I""))"
^XMB(3.9,145983,2,1241,0)="""RTN"",""RCRPNP"",74,0)"
^XMB(3.9,145983,2,1242,0)=" .D:RCRPSTAT'=1 CHKFLGS^RCRPU1(RCRPIEN,RCRMLN,RCFLG36,RCFLG60)"
^XMB(3.9,145983,2,1243,0)="""RTN"",""RCRPNP"",75,0)"
^XMB(3.9,145983,2,1244,0)=" .I RCFLG60 Q  ; don't add bills if plan length > 57 months PRCA*4.5*423"
^XMB(3.9,145983,2,1245,0)="""RTN"",""RCRPNP"",76,0)"
^XMB(3.9,145983,2,1246,0)=" .; Find the Debtor."
^XMB(3.9,145983,2,1247,0)="""RTN"",""RCRPNP"",77,0)"
^XMB(3.9,145983,2,1248,0)=" .S RCDBTR=$$GET1^DIQ(340.5,RCIENS,.02,""I"")"
^XMB(3.9,145983,2,1249,0)="""RTN"",""RCRPNP"",78,0)"
^XMB(3.9,145983,2,1250,0)=" .; Loop through the Active Bills for the Debtor"
^XMB(3.9,145983,2,1251,0)="""RTN"",""RCRPNP"",79,0)"
^XMB(3.9,145983,2,1252,0)=" .S RCACTIVE=$O(^PRCA(430.3,""B"",""ACTIVE"",""""))  ; Get the Active Status IEN"
^XMB(3.9,145983,2,1253,0)="""RTN"",""RCRPNP"",80,0)"
^XMB(3.9,145983,2,1254,0)=" .S (RCQUIT,RCBILLDA)=0 ;  PRCA*4.5*423"
^XMB(3.9,145983,2,1255,0)="""RTN"",""RCRPNP"",81,0)"
^XMB(3.9,145983,2,1256,0)=" .; Loop through all bills or until plan is flagged for review."
^XMB(3.9,145983,2,1257,0)="""RTN"",""RCRPNP"",82,0)"
^XMB(3.9,145983,2,1258,0)=" .F  S RCBILLDA=$O(^PRCA(430,""AS"",RCDBTR,RCACTIVE,RCBILLDA)) Q:'RCBILLDA  Q:RCQUIT  D"
^XMB(3.9,145983,2,1259,0)="""RTN"",""RCRPNP"",83,0)"
^XMB(3.9,145983,2,1260,0)=" ..; Only look at First Party Bills"
^XMB(3.9,145983,2,1261,0)="""RTN"",""RCRPNP"",84,0)"
^XMB(3.9,145983,2,1262,0)=" ..Q:'$$FIRSTPAR(+RCBILLDA)"
^XMB(3.9,145983,2,1263,0)="""RTN"",""RCRPNP"",85,0)"
^XMB(3.9,145983,2,1264,0)=" ..; Skip if bill already in plan."
^XMB(3.9,145983,2,1265,0)="""RTN"",""RCRPNP"",86,0)"
^XMB(3.9,145983,2,1266,0)=" ..Q:+$$GET1^DIQ(430,RCBILLDA_"","",45,""I"")"
^XMB(3.9,145983,2,1267,0)="""RTN"",""RCRPNP"",87,0)"
^XMB(3.9,145983,2,1268,0)=" ..; Exclude bills referred to CS, TOP, or DMC"
^XMB(3.9,145983,2,1269,0)="""RTN"",""RCRPNP"",88,0)"
^XMB(3.9,145983,2,1270,0)=" ..S RCCSDT=+$$GET1^DIQ(430,RCBILLDA_"","",151,""I"")    ; get CS Date referral date"
^XMB(3.9,145983,2,1271,0)="""RTN"",""RCRPNP"",89,0)"
^XMB(3.9,145983,2,1272,0)=" ..S RCCSRCDT=+$$GET1^DIQ(430,RCBILLDA_"","",153,""I"")  ; get CS Recall date"
^XMB(3.9,145983,2,1273,0)="""RTN"",""RCRPNP"",90,0)"
^XMB(3.9,145983,2,1274,0)=" ..I RCCSDT,'RCCSRCDT Q    ;If still at Cross Servicing, the don't add bill to plan."
^XMB(3.9,145983,2,1275,0)="""RTN"",""RCRPNP"",91,0)"
^XMB(3.9,145983,2,1276,0)=" ..Q:+$$GET1^DIQ(430,RCBILLDA_"","",121,""I"")    ; Bill at DMC, quit, don't add bill to plan"
^XMB(3.9,145983,2,1277,0)="""RTN"",""RCRPNP"",92,0)"
^XMB(3.9,145983,2,1278,0)=" ..I +$$GET1^DIQ(430,RCBILLDA_"","",141,""I""),'+$$GET1^DIQ(340,RCDBTR_"","",6.02,""I"") Q    ; Bill still at TOP, quit, don't add bill to plan  PRCA*4.5*422"
^XMB(3.9,145983,2,1279,0)="""RTN"",""RCRPNP"",93,0)"
^XMB(3.9,145983,2,1280,0)=" ..; Add the Bill to the plan."
^XMB(3.9,145983,2,1281,0)="""RTN"",""RCRPNP"",94,0)"
^XMB(3.9,145983,2,1282,0)=" ..D UPDBILL^RCRPU(RCRPIEN,RCBILLDA)"
^XMB(3.9,145983,2,1283,0)="""RTN"",""RCRPNP"",95,0)"
^XMB(3.9,145983,2,1284,0)=" ..; Add Plan to the Bill"
^XMB(3.9,145983,2,1285,0)="""RTN"",""RCRPNP"",96,0)"
^XMB(3.9,145983,2,1286,0)=" ..D ADDPLAN^RCRPU(RCRPIEN,RCBILLDA,RCACTDT)"
^XMB(3.9,145983,2,1287,0)="""RTN"",""RCRPNP"",97,0)"
^XMB(3.9,145983,2,1288,0)=" ..; Update the Total balance Owed."
^XMB(3.9,145983,2,1289,0)="""RTN"",""RCRPNP"",98,0)"
^XMB(3.9,145983,2,1290,0)=" ..S RCD7=$G(^PRCA(430,RCBILLDA,7))"
^XMB(3.9,145983,2,1291,0)="""RTN"",""RCRPNP"",99,0)"
^XMB(3.9,145983,2,1292,0)=" ..S RCD0=$G(^PRCA(430,RCBILLDA,0))"
^XMB(3.9,145983,2,1293,0)="""RTN"",""RCRPNP"",100,0)"
^XMB(3.9,145983,2,1294,0)=" ..S RCAMT=$S(+RCD7:$P(RCD7,U,1)+$P(RCD7,U,2)+$P(RCD7,U,3)+$P(RCD7,U,4)+$P(RCD7,U,5),1:$P(RCD0,U,3))"
^XMB(3.9,145983,2,1295,0)="""RTN"",""RCRPNP"",101,0)"
^XMB(3.9,145983,2,1296,0)=" ..S RCPLNBL=$$GET1^DIQ(340.5,RCIENS,.11,""I"")  ;get the current Plan amount Owed value."
^XMB(3.9,145983,2,1297,0)="""RTN"",""RCRPNP"",102,0)"
^XMB(3.9,145983,2,1298,0)=" ..D UPDPAO^RCRPU1(RCRPIEN,RCAMT+RCPLNBL)"
^XMB(3.9,145983,2,1299,0)="""RTN"",""RCRPNP"",103,0)"
^XMB(3.9,145983,2,1300,0)=" ..;Calculate the new remaining balance"
^XMB(3.9,145983,2,1301,0)="""RTN"",""RCRPNP"",104,0)"
^XMB(3.9,145983,2,1302,0)=" ..S RCPLNBL=$$GET1^DIQ(340.5,RCIENS,.11,""I"")  ;get the new Plan amount Owed value."
^XMB(3.9,145983,2,1303,0)="""RTN"",""RCRPNP"",105,0)"
^XMB(3.9,145983,2,1304,0)=" ..; Recalculate the total # payments."
^XMB(3.9,145983,2,1305,0)="""RTN"",""RCRPNP"",106,0)"
^XMB(3.9,145983,2,1306,0)=" ..S RCMNPY=$$GET1^DIQ(340.5,RCIENS,.06,""I"")"
^XMB(3.9,145983,2,1307,0)="""RTN"",""RCRPNP"",107,0)"
^XMB(3.9,145983,2,1308,0)=" ..S RCNOMN=$$GET1^DIQ(340.5,RCIENS,.05,""I"")"
^XMB(3.9,145983,2,1309,0)="""RTN"",""RCRPNP"",108,0)"
^XMB(3.9,145983,2,1310,0)=" ..S RCNWMN=RCPLNBL\RCMNPY,RCNWMOD=RCPLNBL#RCMNPY"
^XMB(3.9,145983,2,1311,0)="""RTN"",""RCRPNP"",109,0)"
^XMB(3.9,145983,2,1312,0)=" ..I RCNWMOD>0 S RCNWMN=RCNWMN+1"
^XMB(3.9,145983,2,1313,0)="""RTN"",""RCRPNP"",110,0)"
^XMB(3.9,145983,2,1314,0)=" ..; Calculate the # payments remaining"
^XMB(3.9,145983,2,1315,0)="""RTN"",""RCRPNP"",111,0)"
^XMB(3.9,145983,2,1316,0)=" ..S RCRMLN=$$REMPMNTS^RCRPU3(RCRPIEN,RCMNPY)  ; PRCA*4.5*389"
^XMB(3.9,145983,2,1317,0)="""RTN"",""RCRPNP"",112,0)"
^XMB(3.9,145983,2,1318,0)=" ..; If there is a change in term length, update the plan and the schedule."
^XMB(3.9,145983,2,1319,0)="""RTN"",""RCRPNP"",113,0)"
^XMB(3.9,145983,2,1320,0)=" ..I RCNOMN'=RCNWMN D"
^XMB(3.9,145983,2,1321,0)="""RTN"",""RCRPNP"",114,0)"
^XMB(3.9,145983,2,1322,0)=" ...D UPDTERMS^RCRPU1(RCRPIEN,RCMNPY_""^""_RCNWMN)"
^XMB(3.9,145983,2,1323,0)="""RTN"",""RCRPNP"",115,0)"
^XMB(3.9,145983,2,1324,0)=" ...D ADJSCHED^RCRPENTR(RCRPIEN,RCNOMN,RCNWMN)"
^XMB(3.9,145983,2,1325,0)="""RTN"",""RCRPNP"",116,0)"
^XMB(3.9,145983,2,1326,0)=" ...I RCRPSTAT'=1,RCRMLN>36,RCFLG36'=1 S RCREV36=1  ; PRCA*4.5*422"
^XMB(3.9,145983,2,1327,0)="""RTN"",""RCRPNP"",117,0)"
^XMB(3.9,145983,2,1328,0)=" ...Q"
^XMB(3.9,145983,2,1329,0)="""RTN"",""RCRPNP"",118,0)"
^XMB(3.9,145983,2,1330,0)=" ..D:RCRPSTAT'=1 CHKFLGS^RCRPU1(RCRPIEN,RCRMLN,RCFLG36,RCFLG60)  ; PRCA*4.5*422"
^XMB(3.9,145983,2,1331,0)="""RTN"",""RCRPNP"",119,0)"
^XMB(3.9,145983,2,1332,0)=" ..I RCRPSTAT'=1,+$$GET1^DIQ(340.5,RCIENS,1.01,""I"") S RCQUIT=1 ;  PRCA*4.5*422"
^XMB(3.9,145983,2,1333,0)="""RTN"",""RCRPNP"",120,0)"
^XMB(3.9,145983,2,1334,0)=" ..;"
^XMB(3.9,145983,2,1335,0)="""RTN"",""RCRPNP"",121,0)"
^XMB(3.9,145983,2,1336,0)=" ..;Update Audit Log"
^XMB(3.9,145983,2,1337,0)="""RTN"",""RCRPNP"",122,0)"
^XMB(3.9,145983,2,1338,0)=" ..D UPDAUDIT^RCRPU2(RCRPIEN,$$DT^XLFDT,""A"","""")"
^XMB(3.9,145983,2,1339,0)="""RTN"",""RCRPNP"",123,0)"
^XMB(3.9,145983,2,1340,0)=" ..;"
^XMB(3.9,145983,2,1341,0)="""RTN"",""RCRPNP"",124,0)"
^XMB(3.9,145983,2,1342,0)=" ..;Update the AR Metrics File with activity"
^XMB(3.9,145983,2,1343,0)="""RTN"",""RCRPNP"",125,0)"
^XMB(3.9,145983,2,1344,0)=" ..D UPDMET^RCSTATU(1.02,1)"
^XMB(3.9,145983,2,1345,0)="""RTN"",""RCRPNP"",126,0)"
^XMB(3.9,145983,2,1346,0)=" ..Q"
^XMB(3.9,145983,2,1347,0)="""RTN"",""RCRPNP"",127,0)"
^XMB(3.9,145983,2,1348,0)=" .Q"
^XMB(3.9,145983,2,1349,0)="""RTN"",""RCRPNP"",128,0)"
^XMB(3.9,145983,2,1350,0)=" I RCREV36 D MSGREV^RCRPWLUT  ; send Mailman notification for plans that need 36 months review  PRCA*4.5*422"
^XMB(3.9,145983,2,1351,0)="""RTN"",""RCRPNP"",129,0)"
^XMB(3.9,145983,2,1352,0)=" ; Update Processing time metrics"
^XMB(3.9,145983,2,1353,0)="""RTN"",""RCRPNP"",130,0)"
^XMB(3.9,145983,2,1354,0)=" S RCSTEND=$H"
^XMB(3.9,145983,2,1355,0)="""RTN"",""RCRPNP"",131,0)"
^XMB(3.9,145983,2,1356,0)=" D UPDMET^RCSTATU(2.02,$$HDIFF^XLFDT(RCSTEND,RCSTSTRT,2))"
^XMB(3.9,145983,2,1357,0)="""RTN"",""RCRPNP"",132,0)"
^XMB(3.9,145983,2,1358,0)=" Q"
^XMB(3.9,145983,2,1359,0)="""RTN"",""RCRPNP"",133,0)"
^XMB(3.9,145983,2,1360,0)=" ;"
^XMB(3.9,145983,2,1361,0)="""RTN"",""RCRPNP"",134,0)"
^XMB(3.9,145983,2,1362,0)="UPDCS ;Review all bills for the Debtor to see if any are still in Cross Service Debt Referral"
^XMB(3.9,145983,2,1363,0)="""RTN"",""RCRPNP"",135,0)"
^XMB(3.9,145983,2,1364,0)=" ;"
^XMB(3.9,145983,2,1365,0)="""RTN"",""RCRPNP"",136,0)"
^XMB(3.9,145983,2,1366,0)=" N RCIEN,RCD0,RCD1,RCSTAT,RCDBTR,RCOLDCS,RCNEWCS,RCBILL,RCBLSTAT,RCCSDT,RCCSRCDT"
^XMB(3.9,145983,2,1367,0)="""RTN"",""RCRPNP"",137,0)"
^XMB(3.9,145983,2,1368,0)=" ;"
^XMB(3.9,145983,2,1369,0)="""RTN"",""RCRPNP"",138,0)"
^XMB(3.9,145983,2,1370,0)=" ; Start calculating execution time"
^XMB(3.9,145983,2,1371,0)="""RTN"",""RCRPNP"",139,0)"
^XMB(3.9,145983,2,1372,0)=" S RCSTSTRT=$H"
^XMB(3.9,145983,2,1373,0)="""RTN"",""RCRPNP"",140,0)"
^XMB(3.9,145983,2,1374,0)=" ;"
^XMB(3.9,145983,2,1375,0)="""RTN"",""RCRPNP"",141,0)"
^XMB(3.9,145983,2,1376,0)=" ;Loop through all active Repayment Plans"
^XMB(3.9,145983,2,1377,0)="""RTN"",""RCRPNP"",142,0)"
^XMB(3.9,145983,2,1378,0)=" S RCIEN=0"
^XMB(3.9,145983,2,1379,0)="""RTN"",""RCRPNP"",143,0)"
^XMB(3.9,145983,2,1380,0)=" F  S RCIEN=$O(^RCRP(340.5,RCIEN)) Q:'RCIEN  D"
^XMB(3.9,145983,2,1381,0)="""RTN"",""RCRPNP"",144,0)"
^XMB(3.9,145983,2,1382,0)=" . S RCD0=$G(^RCRP(340.5,RCIEN,0)),RCD1=$G(^RCRP(340.5,RCIEN,1))"
^XMB(3.9,145983,2,1383,0)="""RTN"",""RCRPNP"",145,0)"
^XMB(3.9,145983,2,1384,0)=" . S RCSTAT=$P(RCD0,U,7)"
^XMB(3.9,145983,2,1385,0)="""RTN"",""RCRPNP"",146,0)"
^XMB(3.9,145983,2,1386,0)=" . Q:RCSTAT>5"
^XMB(3.9,145983,2,1387,0)="""RTN"",""RCRPNP"",147,0)"
^XMB(3.9,145983,2,1388,0)=" . ; extract the debtor, and the AT CS flag"
^XMB(3.9,145983,2,1389,0)="""RTN"",""RCRPNP"",148,0)"
^XMB(3.9,145983,2,1390,0)=" . S RCDBTR=$P(RCD0,U,2),RCOLDCS=$P(RCD1,U,4)"
^XMB(3.9,145983,2,1391,0)="""RTN"",""RCRPNP"",149,0)"
^XMB(3.9,145983,2,1392,0)=" . ; find all of the bills associated with that debtor"
^XMB(3.9,145983,2,1393,0)="""RTN"",""RCRPNP"",150,0)"
^XMB(3.9,145983,2,1394,0)=" . ; Initialize new AT CS flag to NULL"
^XMB(3.9,145983,2,1395,0)="""RTN"",""RCRPNP"",151,0)"
^XMB(3.9,145983,2,1396,0)=" . S RCNEWCS=0,RCBILL=0"
^XMB(3.9,145983,2,1397,0)="""RTN"",""RCRPNP"",152,0)"
^XMB(3.9,145983,2,1398,0)=" . F  S RCBILL=$O(^PRCA(430,""C"",RCDBTR,RCBILL)) Q:'RCBILL  D  Q:RCNEWCS=1"
^XMB(3.9,145983,2,1399,0)="""RTN"",""RCRPNP"",153,0)"
^XMB(3.9,145983,2,1400,0)=" . . ; for each active bill"
^XMB(3.9,145983,2,1401,0)="""RTN"",""RCRPNP"",154,0)"
^XMB(3.9,145983,2,1402,0)=" . . S RCBLSTAT=$$GET1^DIQ(430,RCBILL_"","",8,""I"")"
^XMB(3.9,145983,2,1403,0)="""RTN"",""RCRPNP"",155,0)"
^XMB(3.9,145983,2,1404,0)=" . . Q:RCBLSTAT'=16"
^XMB(3.9,145983,2,1405,0)="""RTN"",""RCRPNP"",156,0)"
^XMB(3.9,145983,2,1406,0)=" . . ; Check to see if it is at cross servicing"
^XMB(3.9,145983,2,1407,0)="""RTN"",""RCRPNP"",157,0)"
^XMB(3.9,145983,2,1408,0)=" . . S RCCSDT=$$GET1^DIQ(430,RCBILL_"","",151,""I"")"
^XMB(3.9,145983,2,1409,0)="""RTN"",""RCRPNP"",158,0)"
^XMB(3.9,145983,2,1410,0)=" . . Q:'+RCCSDT           ;quit if not at Cross Servicing"
^XMB(3.9,145983,2,1411,0)="""RTN"",""RCRPNP"",159,0)"
^XMB(3.9,145983,2,1412,0)=" . . ;If at cross servicing (field 151 with data and 153 with no data), then set new AT CS flag = 1 and quit loop"
^XMB(3.9,145983,2,1413,0)="""RTN"",""RCRPNP"",160,0)"
^XMB(3.9,145983,2,1414,0)=" . . S RCCSRCDT=$$GET1^DIQ(430,RCBILL_"","",153,""I"")"
^XMB(3.9,145983,2,1415,0)="""RTN"",""RCRPNP"",161,0)"
^XMB(3.9,145983,2,1416,0)=" . . S:'+RCCSRCDT RCNEWCS=1"
^XMB(3.9,145983,2,1417,0)="""RTN"",""RCRPNP"",162,0)"
^XMB(3.9,145983,2,1418,0)=" . ; If the current AT CS flag matches the new AT CS flag get the next debtor"
^XMB(3.9,145983,2,1419,0)="""RTN"",""RCRPNP"",163,0)"
^XMB(3.9,145983,2,1420,0)=" . I +RCOLDCS'=+RCNEWCS D UPDATCS^RCRPU2(RCIEN,RCNEWCS)"
^XMB(3.9,145983,2,1421,0)="""RTN"",""RCRPNP"",164,0)"
^XMB(3.9,145983,2,1422,0)=" . ;If a bill has been newly referred to CS, send an alert to investigate"
^XMB(3.9,145983,2,1423,0)="""RTN"",""RCRPNP"",165,0)"
^XMB(3.9,145983,2,1424,0)=" . I '+RCOLDCS,+RCNEWCS D CSALERT^RCSTATU(RCBILL,RCIEN)"
^XMB(3.9,145983,2,1425,0)="""RTN"",""RCRPNP"",166,0)"
^XMB(3.9,145983,2,1426,0)=" ;"
^XMB(3.9,145983,2,1427,0)="""RTN"",""RCRPNP"",167,0)"
^XMB(3.9,145983,2,1428,0)=" ; Update Processing time metrics"
^XMB(3.9,145983,2,1429,0)="""RTN"",""RCRPNP"",168,0)"
^XMB(3.9,145983,2,1430,0)=" S RCSTEND=$H"
^XMB(3.9,145983,2,1431,0)="""RTN"",""RCRPNP"",169,0)"
^XMB(3.9,145983,2,1432,0)=" D UPDMET^RCSTATU(2.01,$$HDIFF^XLFDT(RCSTEND,RCSTSTRT,2))"
^XMB(3.9,145983,2,1433,0)="""RTN"",""RCRPNP"",170,0)"
^XMB(3.9,145983,2,1434,0)=" Q"
^XMB(3.9,145983,2,1435,0)="""RTN"",""RCRPNP"",171,0)"
^XMB(3.9,145983,2,1436,0)=" ;"
^XMB(3.9,145983,2,1437,0)="""RTN"",""RCRPNP"",172,0)"
^XMB(3.9,145983,2,1438,0)="UPDPRDL(RCIEN,RCFLG) ; Update the Print Deliquent Flag"
^XMB(3.9,145983,2,1439,0)="""RTN"",""RCRPNP"",173,0)"
^XMB(3.9,145983,2,1440,0)=" ;INPUT - RCIEN:  IEN of the Repayment Plan"
