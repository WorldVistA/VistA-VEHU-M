^XMB(3.9,145958,2,287,0)="""RTN"",""OCXOCMP4"")"
^XMB(3.9,145958,2,288,0)="0^4^B53572931"
^XMB(3.9,145958,2,289,0)="""RTN"",""OCXOCMP4"",1,0)"
^XMB(3.9,145958,2,290,0)="OCXOCMP4 ;SLC/RJS,CLA - ORDER CHECK CODE COMPILER (Sort Code Segments) ;1/05/04  14:38"
^XMB(3.9,145958,2,291,0)="""RTN"",""OCXOCMP4"",2,0)"
^XMB(3.9,145958,2,292,0)=" ;;3.0;ORDER ENTRY/RESULTS REPORTING;**32,221**;Dec 17,1997;Build 0"
^XMB(3.9,145958,2,293,0)="""RTN"",""OCXOCMP4"",3,0)"
^XMB(3.9,145958,2,294,0)=" ;;  ;;ORDER CHECK EXPERT version 1.01 released OCT 29,1998"
^XMB(3.9,145958,2,295,0)="""RTN"",""OCXOCMP4"",4,0)"
^XMB(3.9,145958,2,296,0)=" ;"
^XMB(3.9,145958,2,297,0)="""RTN"",""OCXOCMP4"",5,0)"
^XMB(3.9,145958,2,298,0)="EN() ;"
^XMB(3.9,145958,2,299,0)="""RTN"",""OCXOCMP4"",6,0)"
^XMB(3.9,145958,2,300,0)=" ;"
^XMB(3.9,145958,2,301,0)="""RTN"",""OCXOCMP4"",7,0)"
^XMB(3.9,145958,2,302,0)=" Q:$G(OCXWARN) OCXWARN"
^XMB(3.9,145958,2,303,0)="""RTN"",""OCXOCMP4"",8,0)"
^XMB(3.9,145958,2,304,0)=" N OCXD0,OCXD1,OCXD2,OCXD3,OCXD4,OCXU"
^XMB(3.9,145958,2,305,0)="""RTN"",""OCXOCMP4"",9,0)"
^XMB(3.9,145958,2,306,0)=" S OCXU=""UPDATE"""
^XMB(3.9,145958,2,307,0)="""RTN"",""OCXOCMP4"",10,0)"
^XMB(3.9,145958,2,308,0)=" Q:'$$LINE(""LOG"",""-"") 1"
^XMB(3.9,145958,2,309,0)="""RTN"",""OCXOCMP4"",11,0)"
^XMB(3.9,145958,2,310,0)=" Q:'$$LINE(""CDATA"",""-"") 1"
^XMB(3.9,145958,2,311,0)="""RTN"",""OCXOCMP4"",12,0)"
^XMB(3.9,145958,2,312,0)=" Q:'$$LINE(OCXU,""DFN"",""OCXSRC"",""OUTMSG"") 1"
^XMB(3.9,145958,2,313,0)="""RTN"",""OCXOCMP4"",13,0)"
^XMB(3.9,145958,2,314,0)=" Q:'$$LINE(""SCAN"") 1"
^XMB(3.9,145958,2,315,0)="""RTN"",""OCXOCMP4"",14,0)"
^XMB(3.9,145958,2,316,0)=" Q:'$$LINE(""TERM"",""OCXTERM"",""OCXLIST"") 1"
^XMB(3.9,145958,2,317,0)="""RTN"",""OCXOCMP4"",15,0)"
^XMB(3.9,145958,2,318,0)=" ;"
^XMB(3.9,145958,2,319,0)="""RTN"",""OCXOCMP4"",16,0)"
^XMB(3.9,145958,2,320,0)=" D SWAP^OCXOCMPH"
^XMB(3.9,145958,2,321,0)="""RTN"",""OCXOCMP4"",17,0)"
^XMB(3.9,145958,2,322,0)=" ;"
^XMB(3.9,145958,2,323,0)="""RTN"",""OCXOCMP4"",18,0)"
^XMB(3.9,145958,2,324,0)=" D TERM^OCXOCMPU"
^XMB(3.9,145958,2,325,0)="""RTN"",""OCXOCMP4"",19,0)"
^XMB(3.9,145958,2,326,0)=" ;"
^XMB(3.9,145958,2,327,0)="""RTN"",""OCXOCMP4"",20,0)"
^XMB(3.9,145958,2,328,0)=" D IN(""LOG"","" Q ""_(+OCXDLOG))"
^XMB(3.9,145958,2,329,0)="""RTN"",""OCXOCMP4"",21,0)"
^XMB(3.9,145958,2,330,0)=" D IN(""CDATA"","" Q """"""_(+OCXTRACE)_U_(+OCXTLOG)_U_(+OCXDLOG)_"""""""")"
^XMB(3.9,145958,2,331,0)="""RTN"",""OCXOCMP4"",22,0)"
^XMB(3.9,145958,2,332,0)=" ;"
^XMB(3.9,145958,2,333,0)="""RTN"",""OCXOCMP4"",23,0)"
^XMB(3.9,145958,2,334,0)=" I OCXTLOG D"
^XMB(3.9,145958,2,335,0)="""RTN"",""OCXOCMP4"",24,0)"
^XMB(3.9,145958,2,336,0)=" .D IN(OCXU,"" S OCXOTIME=$$TIMELOG(""""O"""",""""UPDATE^OCXOZ01"""")"")"
^XMB(3.9,145958,2,337,0)="""RTN"",""OCXOCMP4"",25,0)"
^XMB(3.9,145958,2,338,0)=" .D IN(OCXU,"" ;"")"
^XMB(3.9,145958,2,339,0)="""RTN"",""OCXOCMP4"",26,0)"
^XMB(3.9,145958,2,340,0)=" ;"
^XMB(3.9,145958,2,341,0)="""RTN"",""OCXOCMP4"",27,0)"
^XMB(3.9,145958,2,342,0)=" D IN(OCXU,"" K ^TMP(""""OCXCHK"""",$J)"")"
^XMB(3.9,145958,2,343,0)="""RTN"",""OCXOCMP4"",28,0)"
^XMB(3.9,145958,2,344,0)=" D IN(OCXU,"" S ^TMP(""""OCXCHK"""",$J)=($P($H,"""","""",2)+($H*86400)+(2*60))_"""" <- ^TMP ENTRY EXPIRATION DATE FOR ^OCXOPURG"""""")"
^XMB(3.9,145958,2,345,0)="""RTN"",""OCXOCMP4"",29,0)"
^XMB(3.9,145958,2,346,0)=" I '(OCXTLOG) D IN(OCXU,"" N OCXOERR,OCXOCMSG,OCXNDX,OCXDF,OCXX,OCXTSPI"")"
^XMB(3.9,145958,2,347,0)="""RTN"",""OCXOCMP4"",30,0)"
^XMB(3.9,145958,2,348,0)=" I (OCXTLOG) D IN(OCXU,"" N OCXOERR,OCXOCMSG,OCXNDX,OCXDF,OCXX,OCXTSPI,OCXBOOLV"")"
^XMB(3.9,145958,2,349,0)="""RTN"",""OCXOCMP4"",31,0)"
^XMB(3.9,145958,2,350,0)=" D IN(OCXU,"" S OCXTSPI=""_+$G(OCXTSPI))"
^XMB(3.9,145958,2,351,0)="""RTN"",""OCXOCMP4"",32,0)"
^XMB(3.9,145958,2,352,0)=" I $G(OCXTRACE) D"
^XMB(3.9,145958,2,353,0)="""RTN"",""OCXOCMP4"",33,0)"
^XMB(3.9,145958,2,354,0)=" .D IN(OCXU,"" I $G(OCXTRACE),'$G(DFN) W !,""""Patient not defined !"""""")"
^XMB(3.9,145958,2,355,0)="""RTN"",""OCXOCMP4"",34,0)"
^XMB(3.9,145958,2,356,0)=" .D IN(OCXU,"" I $G(OCXTRACE),$G(DFN) W !,||LNTAG||,?30,""""Data Field: Patient: ("""",DFN,"""") """",$P($G(^DPT(DFN,0)),""""^"""",1),"""" !"""""")"
^XMB(3.9,145958,2,357,0)="""RTN"",""OCXOCMP4"",35,0)"
^XMB(3.9,145958,2,358,0)=" I 'OCXTLOG D IN(OCXU,"" Q:'$G(DFN)"")"
^XMB(3.9,145958,2,359,0)="""RTN"",""OCXOCMP4"",36,0)"
^XMB(3.9,145958,2,360,0)=" I OCXTLOG D IN(OCXU,"" I '$G(DFN) S OCXOTIME=$$TIMELOG(""""I"""",""""UPDATE^OCXOZ01"""") Q"")"
^XMB(3.9,145958,2,361,0)="""RTN"",""OCXOCMP4"",37,0)"
^XMB(3.9,145958,2,362,0)=" D IN(""SCAN"","" ;"")"
^XMB(3.9,145958,2,363,0)="""RTN"",""OCXOCMP4"",38,0)"
^XMB(3.9,145958,2,364,0)=" D IN(""SCAN"","" N OCXD0,OCXRULE S OCXD0=0 F  S OCXD0=$O(^TMP(""""OCXCHK"""",$J,DFN,OCXD0)) Q:'OCXD0  D"")"
^XMB(3.9,145958,2,365,0)="""RTN"",""OCXOCMP4"",39,0)"
^XMB(3.9,145958,2,366,0)=" D IN(""SCAN"","" .Q:'($G(^TMP(""""OCXCHK"""",$J,DFN,OCXD0))=1)"")"
^XMB(3.9,145958,2,367,0)="""RTN"",""OCXOCMP4"",40,0)"
