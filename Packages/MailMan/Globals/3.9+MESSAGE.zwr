^XMB(3.9,145984,2,1930,0)=" . S VPRVIEN=PRCHK(""IEN"") I '$$CHKPRV2^PSOERX1A(VPRVIEN) Q"
^XMB(3.9,145984,2,1931,0)="""RTN"",""PSOERXI1"",117,0)"
^XMB(3.9,145984,2,1932,0)=" . S VPRVNAM=$$UP^XLFSTR($TR($$GET1^DIQ(200,VPRVIEN,.01),"" ""))"
^XMB(3.9,145984,2,1933,0)="""RTN"",""PSOERXI1"",118,0)"
^XMB(3.9,145984,2,1934,0)=" . S VPRVZC=$P($$GET1^DIQ(200,VPRVIEN,.116),""-"")"
^XMB(3.9,145984,2,1935,0)="""RTN"",""PSOERXI1"",119,0)"
^XMB(3.9,145984,2,1936,0)=" . I $E(EPRVNAM,1,$F(EPRVNAM,"",""))'=$E(VPRVNAM,1,$F(VPRVNAM,"","")) Q"
^XMB(3.9,145984,2,1937,0)="""RTN"",""PSOERXI1"",120,0)"
^XMB(3.9,145984,2,1938,0)=" . I $E(EPRVZC,1,5)'=$E(VPRVZC,1,5) Q"
^XMB(3.9,145984,2,1939,0)="""RTN"",""PSOERXI1"",121,0)"
^XMB(3.9,145984,2,1940,0)=" . I $$GET1^DIQ(52.49,+CURREC,95.1,""I""),'$$DEAFOUND^PSOERXU8(EPRVDEA,VPRVIEN) Q"
^XMB(3.9,145984,2,1941,0)="""RTN"",""PSOERXI1"",122,0)"
^XMB(3.9,145984,2,1942,0)=" . S FDA(52.49,CURREC,1.3)=1"
^XMB(3.9,145984,2,1943,0)="""RTN"",""PSOERXI1"",123,0)"
^XMB(3.9,145984,2,1944,0)=" . S FDA(52.49,CURREC,1.8)=$$PROXYDUZ^PSOERXUT()"
^XMB(3.9,145984,2,1945,0)="""RTN"",""PSOERXI1"",124,0)"
^XMB(3.9,145984,2,1946,0)=" . S FDA(52.49,CURREC,1.9)=$$NOW^XLFDT()"
^XMB(3.9,145984,2,1947,0)="""RTN"",""PSOERXI1"",125,0)"
^XMB(3.9,145984,2,1948,0)=" . S FDA(52.49,CURREC,2.7)=1"
^XMB(3.9,145984,2,1949,0)="""RTN"",""PSOERXI1"",126,0)"
^XMB(3.9,145984,2,1950,0)=" . S PRVAUTOV=1"
^XMB(3.9,145984,2,1951,0)="""RTN"",""PSOERXI1"",127,0)"
^XMB(3.9,145984,2,1952,0)=" I $G(PRCHK(""success""))=""true"",$G(PRCHK(""IEN"")) D"
^XMB(3.9,145984,2,1953,0)="""RTN"",""PSOERXI1"",128,0)"
^XMB(3.9,145984,2,1954,0)=" . ;Saving the eRx Audit Log for the Auto-Matched Provider"
^XMB(3.9,145984,2,1955,0)="""RTN"",""PSOERXI1"",129,0)"
^XMB(3.9,145984,2,1956,0)=" . S NEWVAL(1)=$$GET1^DIQ(200,PRCHK(""IEN""),.01)_"" (DEA#: ""_$P($$VADEA^PSOERXU8(PRCHK(""IEN""),+CURREC),""^"",2)_"")""_$S($G(PRVAUTOV):"" - AUTO-VALIDATED"",1:"""")"
^XMB(3.9,145984,2,1957,0)="""RTN"",""PSOERXI1"",130,0)"
^XMB(3.9,145984,2,1958,0)=" . D AUDLOG^PSOERXUT(+CURREC,""PROVIDER"",$$PROXYDUZ^PSOERXUT(),.NEWVAL)"
