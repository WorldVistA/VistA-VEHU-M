^XMB(3.9,145982,2,592,0)="DEBTOR ADDR UPDATED BY"
^XMB(3.9,145982,2,593,0)="""^DD"",340,340,1.01,3)"
^XMB(3.9,145982,2,594,0)="Answer must be 1-40 characters in length."
^XMB(3.9,145982,2,595,0)="""^DD"",340,340,1.01,21,0)"
^XMB(3.9,145982,2,596,0)="^^9^9^2931028^^^^"
^XMB(3.9,145982,2,597,0)="""^DD"",340,340,1.01,21,1,0)"
^XMB(3.9,145982,2,598,0)="For patients, the MCCR/Fiscal staff can enter a 'billing address' that"
^XMB(3.9,145982,2,599,0)="""^DD"",340,340,1.01,21,2,0)"
^XMB(3.9,145982,2,600,0)="will over-ride the address fields in the patient file.  This is necessary"
^XMB(3.9,145982,2,601,0)="""^DD"",340,340,1.01,21,3,0)"
^XMB(3.9,145982,2,602,0)="for patients that may be incompetent and may need to have a separate"
^XMB(3.9,145982,2,603,0)="""^DD"",340,340,1.01,21,4,0)"
^XMB(3.9,145982,2,604,0)="billing address from their home address.  Once the MAS package supports"
^XMB(3.9,145982,2,605,0)="""^DD"",340,340,1.01,21,5,0)"
^XMB(3.9,145982,2,606,0)="'billing addresses', then the AR software will incorporate this"
^XMB(3.9,145982,2,607,0)="""^DD"",340,340,1.01,21,6,0)"
^XMB(3.9,145982,2,608,0)="functionality from the MAS package."
