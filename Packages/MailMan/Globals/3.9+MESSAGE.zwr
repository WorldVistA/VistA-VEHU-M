^XMB(3.9,145986,2,3560,0)=" ;"
^XMB(3.9,145986,2,3561,0)="""RTN"",""FBPCR"",31,0)"
^XMB(3.9,145986,2,3562,0)=" ;include patients if their insurance informations is unavailable?"
^XMB(3.9,145986,2,3563,0)="""RTN"",""FBPCR"",32,0)"
^XMB(3.9,145986,2,3564,0)=" S FBINCUNK=0"
^XMB(3.9,145986,2,3565,0)="""RTN"",""FBPCR"",33,0)"
^XMB(3.9,145986,2,3566,0)=" I FBPARTY=2!(FBPARTY=3) D"
^XMB(3.9,145986,2,3567,0)="""RTN"",""FBPCR"",34,0)"
^XMB(3.9,145986,2,3568,0)=" . S FBINCUNK=1"
^XMB(3.9,145986,2,3569,0)="""RTN"",""FBPCR"",35,0)"
^XMB(3.9,145986,2,3570,0)=" . N Y,X"
^XMB(3.9,145986,2,3571,0)="""RTN"",""FBPCR"",36,0)"
^XMB(3.9,145986,2,3572,0)=" . W !!"
^XMB(3.9,145986,2,3573,0)="""RTN"",""FBPCR"",37,0)"
^XMB(3.9,145986,2,3574,0)=" . S DIR(""A"")=""Do you want to include patients whose insurance status is unavailable? """
^XMB(3.9,145986,2,3575,0)="""RTN"",""FBPCR"",38,0)"
^XMB(3.9,145986,2,3576,0)=" . S DIR(""?"")=""Please answer Yes or No."""
^XMB(3.9,145986,2,3577,0)="""RTN"",""FBPCR"",39,0)"
