^XMB(3.9,145949,2,456,0)="TSTSIG ; include testing for BAD characters in SIG"
^XMB(3.9,145949,2,457,0)="""RTN"",""PSXMISC1"",109,0)"
^XMB(3.9,145949,2,458,0)=" I $P(^PSRX(RXN,""SIG""),""^"",2)'>0 S SIG=$P(^PSRX(RXN,""SIG""),""^"") D TSTCHAR"
