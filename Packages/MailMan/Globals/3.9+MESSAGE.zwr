^XMB(3.9,145989,2,2354,0)=" . . S VALMSG=$P($$SPOK^PSOSPMUT(STATEIEN),""^"",2) W $C(7)"
^XMB(3.9,145989,2,2355,0)="""RTN"",""PSOSPML4"",197,0)"
^XMB(3.9,145989,2,2356,0)=" . . I $D(VALMSG) W !!!,VALMSG,""...NO BATCH SENT!"",!"
