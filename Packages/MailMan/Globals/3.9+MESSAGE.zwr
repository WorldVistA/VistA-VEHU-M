^XMB(3.9,145980,2,3905,0)="""RTN"",""SDES2CANCELAPPT2"",109,0)"
^XMB(3.9,145980,2,3906,0)=" D CANCEL2(.SDERRORS,DFN,APPTSTARTTIME,CANBYCLINORPAT,CANCELREASON,$G(NOTE),APPTIEN,CLINICIEN,IENS44,.ROLLBACK)"
^XMB(3.9,145980,2,3907,0)="""RTN"",""SDES2CANCELAPPT2"",110,0)"
