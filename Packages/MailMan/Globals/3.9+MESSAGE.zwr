^XMB(3.9,145989,2,2350,0)=" . . S VALMSG=""No State on file for Division ""_$$GET1^DIQ(59,$$RXSITE^PSOBPSUT(RXIEN,0),.01) W $C(7)"
^XMB(3.9,145989,2,2351,0)="""RTN"",""PSOSPML4"",195,0)"
^XMB(3.9,145989,2,2352,0)=" . I $P($$SPOK^PSOSPMUT(STATEIEN),""^"")=-1 D  Q      ;P659"
