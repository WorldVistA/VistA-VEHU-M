^XMB(3.9,145986,2,3494,0)=" Q"
^XMB(3.9,145986,2,3495,0)="""RTN"",""FBPAY671"",132,0)"
^XMB(3.9,145986,2,3496,0)="TRCK I ($Y+5)>IOSL D:FBCRT CR Q:FBOUT  D HDR^FBPAY21"
^XMB(3.9,145986,2,3497,0)="""RTN"",""FBPAY671"",133,0)"
^XMB(3.9,145986,2,3498,0)=" Q"
^XMB(3.9,145986,2,3499,0)="""RTN"",""FBPCR"")"
^XMB(3.9,145986,2,3500,0)="0^10^B129969114"
^XMB(3.9,145986,2,3501,0)="""RTN"",""FBPCR"",1,0)"
^XMB(3.9,145986,2,3502,0)="FBPCR ;AISC/DMK,GRR,TET-POTENTIAL COST RECOVERY OUTPUT DRIVER ;5/23/2006"
^XMB(3.9,145986,2,3503,0)="""RTN"",""FBPCR"",2,0)"
^XMB(3.9,145986,2,3504,0)=" ;;3.5;FEE BASIS;**12,48,76,98,103,135,163**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,3505,0)="""RTN"",""FBPCR"",3,0)"
^XMB(3.9,145986,2,3506,0)=" ;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,3507,0)="""RTN"",""FBPCR"",4,0)"
^XMB(3.9,145986,2,3508,0)=" ; DBIA SUPPORTED REF $$NPI^XUSNPI = 4532"
^XMB(3.9,145986,2,3509,0)="""RTN"",""FBPCR"",5,0)"
^XMB(3.9,145986,2,3510,0)="DOC ;Refer to fbdoc, tag fbpcr, for documentation of fbpcr* routines "
^XMB(3.9,145986,2,3511,0)="""RTN"",""FBPCR"",6,0)"
^XMB(3.9,145986,2,3512,0)="PSF ;select one/many/all primary service failities "
^XMB(3.9,145986,2,3513,0)="""RTN"",""FBPCR"",7,0)"
^XMB(3.9,145986,2,3514,0)=" K FBBILL,FBNPB,FBADJ,FBADJR,FBPVL133,FBINV,FBPVLIST,Y  ;FB*3.5*163"
^XMB(3.9,145986,2,3515,0)="""RTN"",""FBPCR"",8,0)"
^XMB(3.9,145986,2,3516,0)=" S FBARRLTC="""""
^XMB(3.9,145986,2,3517,0)="""RTN"",""FBPCR"",9,0)"
^XMB(3.9,145986,2,3518,0)=" W !! S DIC=""^DIC(4,"",VAUTSTR=""Primary Service Facility"",VAUTNI=2,VAUTVB=""FBPSV"" D FIRST^VAUTOMA K DIC I Y=-1 G EXIT"
^XMB(3.9,145986,2,3519,0)="""RTN"",""FBPCR"",10,0)"
^XMB(3.9,145986,2,3520,0)="ARRAY ;set fee program array for all programs"
^XMB(3.9,145986,2,3521,0)="""RTN"",""FBPCR"",11,0)"
^XMB(3.9,145986,2,3522,0)=" S FBPI=0 F  S FBPI=$O(^FBAA(161.8,FBPI)) Q:'FBPI  S FBPIN=$G(^(FBPI,0)) I $P(FBPIN,U,3) S FBPROG(FBPI)=$P(FBPIN,U)"
^XMB(3.9,145986,2,3523,0)="""RTN"",""FBPCR"",12,0)"
^XMB(3.9,145986,2,3524,0)=" I '$D(FBPROG) G EXIT"
^XMB(3.9,145986,2,3525,0)="""RTN"",""FBPCR"",13,0)"
^XMB(3.9,145986,2,3526,0)=" ;prepare array with LTC POV codes"
^XMB(3.9,145986,2,3527,0)="""RTN"",""FBPCR"",14,0)"
^XMB(3.9,145986,2,3528,0)=" D MKARRLTC^FBPCR4"
^XMB(3.9,145986,2,3529,0)="""RTN"",""FBPCR"",15,0)"
^XMB(3.9,145986,2,3530,0)=" ;what party to include"
^XMB(3.9,145986,2,3531,0)="""RTN"",""FBPCR"",16,0)"
^XMB(3.9,145986,2,3532,0)=" K DIR"
^XMB(3.9,145986,2,3533,0)="""RTN"",""FBPCR"",17,0)"
^XMB(3.9,145986,2,3534,0)=" S DIR(0)=""SO^P:Patient;I:Insurance;B:Both"",DIR(""A"")=""Include (P)atient Co-pays / (I)nsurance / (B)oth"",DIR(""B"")=""Both"""
^XMB(3.9,145986,2,3535,0)="""RTN"",""FBPCR"",18,0)"
^XMB(3.9,145986,2,3536,0)=" S DIR(""?"")="" Select type of recover to include"",DIR(""?"",1)="" P - include only recover from patient copays"",DIR(""?"",2)="" I - include only recover from insurance"",DIR(""?"",3)="" B - include both"",DIR(""L"")="""""
^XMB(3.9,145986,2,3537,0)="""RTN"",""FBPCR"",19,0)"
^XMB(3.9,145986,2,3538,0)=" D ^DIR S FBPARTY=$S($G(Y(0))=""Patient"":1,$G(Y(0))=""Insurance"":2,$G(Y(0))=""Both"":3,X=""Both"":3,1:0)"
^XMB(3.9,145986,2,3539,0)="""RTN"",""FBPCR"",20,0)"
^XMB(3.9,145986,2,3540,0)=" K DIR"
^XMB(3.9,145986,2,3541,0)="""RTN"",""FBPCR"",21,0)"
^XMB(3.9,145986,2,3542,0)=" G:FBPARTY=0 EXIT"
^XMB(3.9,145986,2,3543,0)="""RTN"",""FBPCR"",22,0)"
^XMB(3.9,145986,2,3544,0)=" ;what type of copay to include"
^XMB(3.9,145986,2,3545,0)="""RTN"",""FBPCR"",23,0)"
^XMB(3.9,145986,2,3546,0)=" S FBCOPAY=3"
^XMB(3.9,145986,2,3547,0)="""RTN"",""FBPCR"",24,0)"
^XMB(3.9,145986,2,3548,0)=" I FBPARTY'=2 D"
^XMB(3.9,145986,2,3549,0)="""RTN"",""FBPCR"",25,0)"
^XMB(3.9,145986,2,3550,0)=" . S DIR(0)=""SO^M:MeansTest;L:LTC;B:Both"",DIR(""A"")=""Include (M)eans Test Co-pays /(L)TC Co-pays /(B)oth"",DIR(""B"")=""Both"""
^XMB(3.9,145986,2,3551,0)="""RTN"",""FBPCR"",26,0)"
^XMB(3.9,145986,2,3552,0)=" . S DIR(""?"")="" Select services to include"",DIR(""?"",1)="" M - include only Means Test copays"",DIR(""?"",2)="" L - include only LTC copays"",DIR(""?"",3)="" B - include both"",DIR(""L"")="""""
^XMB(3.9,145986,2,3553,0)="""RTN"",""FBPCR"",27,0)"
^XMB(3.9,145986,2,3554,0)=" . D ^DIR S FBCOPAY=$S($G(Y(0))=""LTC"":1,$G(Y(0))=""MeansTest"":2,$G(Y(0))=""Both"":3,X=""Both"":3,1:0)"
^XMB(3.9,145986,2,3555,0)="""RTN"",""FBPCR"",28,0)"
^XMB(3.9,145986,2,3556,0)=" . K DIR"
^XMB(3.9,145986,2,3557,0)="""RTN"",""FBPCR"",29,0)"
^XMB(3.9,145986,2,3558,0)=" G:FBCOPAY=0 EXIT"
