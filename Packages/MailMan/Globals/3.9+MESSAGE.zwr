^XMB(3.9,145983,2,1522,0)=" ;"
^XMB(3.9,145983,2,1523,0)="""RTN"",""RCRPNP"",215,0)"
^XMB(3.9,145983,2,1524,0)=" ;Clear any potential older arrays"
^XMB(3.9,145983,2,1525,0)="""RTN"",""RCRPNP"",216,0)"
^XMB(3.9,145983,2,1526,0)=" K ^TMP($J,""RPPFLDNO"")"
^XMB(3.9,145983,2,1527,0)="""RTN"",""RCRPNP"",217,0)"
^XMB(3.9,145983,2,1528,0)=" ;"
