^XMB(3.9,145946,2,6204,0)=" S:'IBAPL IBAIPA=$$SELPA^IBCOPP1"
^XMB(3.9,145946,2,6205,0)="""RTN"",""IBCOPP"",75,0)"
^XMB(3.9,145946,2,6206,0)=" I IBAIPA<0 D ENQ Q"
^XMB(3.9,145946,2,6207,0)="""RTN"",""IBCOPP"",76,0)"
^XMB(3.9,145946,2,6208,0)=" ;"
^XMB(3.9,145946,2,6209,0)="""RTN"",""IBCOPP"",77,0)"
^XMB(3.9,145946,2,6210,0)=" ; All Insurance Companies, All Plans, skip to device prompt"
^XMB(3.9,145946,2,6211,0)="""RTN"",""IBCOPP"",78,0)"
