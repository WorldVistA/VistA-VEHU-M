^XMB(3.9,145981,2,329,0)="""RTN"",""IBECECX1"",45,0)"
^XMB(3.9,145981,2,330,0)=" .. I IBECLDT,(IBECLDT<IBECADM) D NOCLOCK Q            ;Quit if billing clock closed at time of admission"
^XMB(3.9,145981,2,331,0)="""RTN"",""IBECECX1"",46,0)"
^XMB(3.9,145981,2,332,0)=" .. I IBECLDT,(IBECLDT<DT) D NOCLOCK D  Q               ;Quit if future clock is closed"
