^XMB(3.9,145980,2,5524,0)="CREATEAVAIL(AVAILABILITY,SDCONTEXT,SLOTSTOCANCEL,CLINICIEN,CLINICSTARTHOUR,SDDISPPERHR,SDCLINSTARTHR,NUMBEROFENTRIES,INPUTS,INDEFINITEUNTIL,RETURNAVAIL,ERRORS) ;"
^XMB(3.9,145980,2,5525,0)="""RTN"",""SDES2CRTCLNAVAL2"",29,0)"
^XMB(3.9,145980,2,5526,0)=" N TIMESLOTCNT,CNT,ENDDATE,DATES,TIMES,NUMBEROFSLOTS,SCHEDULEDDAYS,DATENEXTTIMESLOT,CANSLOTSENDDATE,DONE,SDRETURN,SDONE,J,SDSAV,SDST1,SM,SS,SEQ,%H,ENDATE,SB"
^XMB(3.9,145980,2,5527,0)="""RTN"",""SDES2CRTCLNAVAL2"",30,0)"
