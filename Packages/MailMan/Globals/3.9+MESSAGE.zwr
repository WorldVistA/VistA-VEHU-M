^XMB(3.9,145980,2,5553,0)="""RTN"",""SDES2CRTCLNAVAL2"",43,0)"
^XMB(3.9,145980,2,5554,0)=" ..;"
^XMB(3.9,145980,2,5555,0)="""RTN"",""SDES2CRTCLNAVAL2"",44,0)"
^XMB(3.9,145980,2,5556,0)=" ..S RETURNAVAIL(""clinicAvailability"",CNT,""Pattern"")=""Pattern Filed"""
