^XMB(3.9,145946,2,793,0)="""RTN"",""IBCMDT"",75,0)"
^XMB(3.9,145946,2,794,0)=" ; Filter on Missing Type of Plan"
^XMB(3.9,145946,2,795,0)="""RTN"",""IBCMDT"",76,0)"
^XMB(3.9,145946,2,796,0)="F20 D SLPTY^IBCMDT1"
^XMB(3.9,145946,2,797,0)="""RTN"",""IBCMDT"",77,0)"
^XMB(3.9,145946,2,798,0)=" I STOP G:$$STOP EXIT G F10"
^XMB(3.9,145946,2,799,0)="""RTN"",""IBCMDT"",78,0)"
^XMB(3.9,145946,2,800,0)=" I +IBMDTSPC(""IBPTY"") D"
^XMB(3.9,145946,2,801,0)="""RTN"",""IBCMDT"",79,0)"
^XMB(3.9,145946,2,802,0)=" . S IBMDTSPC(""SUBHD"")=$G(IBMDTSPC(""SUBHD""))_$S(+IBMDTSPC(""FLTRS""):"", "",1:"""")_""Plan Type"""
^XMB(3.9,145946,2,803,0)="""RTN"",""IBCMDT"",80,0)"
^XMB(3.9,145946,2,804,0)=" . S IBMDTSPC(""FLTRS"")=IBMDTSPC(""FLTRS"")+1"
^XMB(3.9,145946,2,805,0)="""RTN"",""IBCMDT"",81,0)"
