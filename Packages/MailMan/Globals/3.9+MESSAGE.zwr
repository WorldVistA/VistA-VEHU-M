^XMB(3.9,145986,2,2156,0)=" I $L($P(FBPRI,U,1,3))>3 W !?3,""ATTENDING PROV NAME: ""_$P(FBPRI,U),!?3,""ATTENDING PROV NPI: ""_$P(FBPRI,U,2),?35,""ATTENDING PROV TAXONOMY CODE: ""_$P(FBPRI,U,3)"
