^XMB(3.9,145986,2,3837,0)="""RTN"",""FBPCR"",169,0)"
^XMB(3.9,145986,2,3838,0)="HDR ;general header for potential recoveries"
^XMB(3.9,145986,2,3839,0)="""RTN"",""FBPCR"",170,0)"
^XMB(3.9,145986,2,3840,0)=" D PAGE Q:FBOUT"
^XMB(3.9,145986,2,3841,0)="""RTN"",""FBPCR"",171,0)"
^XMB(3.9,145986,2,3842,0)=" W !?(IOM-30/2),""POTENTIAL COST RECOVERY REPORT"""
^XMB(3.9,145986,2,3843,0)="""RTN"",""FBPCR"",172,0)"
^XMB(3.9,145986,2,3844,0)=" W !?(IOM-(11+$L($G(FBPSFNAM))+$L($G(FBPSFNUM)))/2),""Division/Station: "",$G(FBPSFNUM),"" "",$G(FBPSFNAM) ;FB*3.5*163"
^XMB(3.9,145986,2,3845,0)="""RTN"",""FBPCR"",173,0)"
^XMB(3.9,145986,2,3846,0)=" W !?(IOM-14/2),""NPI: "",$S($G(FBSTANPI)="""":"""",$G(FBSTANPI)<1:"""",1:$G(FBSTANPI))"
^XMB(3.9,145986,2,3847,0)="""RTN"",""FBPCR"",174,0)"
^XMB(3.9,145986,2,3848,0)=" W !?(IOM-19/2),$$DATX^FBAAUTL(FBBDATE),"" - "",$$DATX^FBAAUTL(FBEDATE)"
^XMB(3.9,145986,2,3849,0)="""RTN"",""FBPCR"",175,0)"
