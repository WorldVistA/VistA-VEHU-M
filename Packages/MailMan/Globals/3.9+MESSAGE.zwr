^XMB(3.9,145989,2,2238,0)=" N STATE"
^XMB(3.9,145989,2,2239,0)="""RTN"",""PSOSPML4"",139,0)"
^XMB(3.9,145989,2,2240,0)=" S STATE=$$RXSTATE^PSOBPSUT(RXIEN,0)"
^XMB(3.9,145989,2,2241,0)="""RTN"",""PSOSPML4"",140,0)"
^XMB(3.9,145989,2,2242,0)=" S PSOASVER=$$GET1^DIQ(58.41,STATE,1,""I"") S:PSOASVER="""" PSOASVER=""4.2"""
^XMB(3.9,145989,2,2243,0)="""RTN"",""PSOSPML4"",141,0)"
^XMB(3.9,145989,2,2244,0)=" D FULL^VALM1 W !"
^XMB(3.9,145989,2,2245,0)="""RTN"",""PSOSPML4"",142,0)"
^XMB(3.9,145989,2,2246,0)=" D EN^PSOSPML3(PSOASVER,1),INIT S VALMBCK=""R"""
^XMB(3.9,145989,2,2247,0)="""RTN"",""PSOSPML4"",143,0)"
^XMB(3.9,145989,2,2248,0)=" Q"
^XMB(3.9,145989,2,2249,0)="""RTN"",""PSOSPML4"",144,0)"
^XMB(3.9,145989,2,2250,0)=" ;"
^XMB(3.9,145989,2,2251,0)="""RTN"",""PSOSPML4"",145,0)"
^XMB(3.9,145989,2,2252,0)="EXPORT ; - Export Rx"
^XMB(3.9,145989,2,2253,0)="""RTN"",""PSOSPML4"",146,0)"
^XMB(3.9,145989,2,2254,0)=" N STATEIEN,PSOASVER,PSOTXRTS,BATIEN,DIR,X,Y,DIRUT,DUOUT,RECTYPE,SCREEN,DFN,PSOSECK,STATELST,LST,MBMST"
^XMB(3.9,145989,2,2255,0)="""RTN"",""PSOSPML4"",147,0)"
^XMB(3.9,145989,2,2256,0)=" S VALMBCK=""R"""
^XMB(3.9,145989,2,2257,0)="""RTN"",""PSOSPML4"",148,0)"
^XMB(3.9,145989,2,2258,0)=" ;"
^XMB(3.9,145989,2,2259,0)="""RTN"",""PSOSPML4"",149,0)"
^XMB(3.9,145989,2,2260,0)=" D FULL^VALM1"
^XMB(3.9,145989,2,2261,0)="""RTN"",""PSOSPML4"",150,0)"
^XMB(3.9,145989,2,2262,0)=" S SCREEN=$$SCREEN^PSOSPMUT(RXIEN,FILLNUM)"
^XMB(3.9,145989,2,2263,0)="""RTN"",""PSOSPML4"",151,0)"
^XMB(3.9,145989,2,2264,0)=" I +SCREEN D  Q:$P(SCREEN,""^"",3)=""E"""
^XMB(3.9,145989,2,2265,0)="""RTN"",""PSOSPML4"",152,0)"
^XMB(3.9,145989,2,2266,0)=" . W $C(7) I $P(SCREEN,""^"",3)=""E"" S VALMSG=$P(SCREEN,""^"",2) Q"
^XMB(3.9,145989,2,2267,0)="""RTN"",""PSOSPML4"",153,0)"
^XMB(3.9,145989,2,2268,0)=" . W !!,""WARNING: "",$P(SCREEN,""^"",2)"
^XMB(3.9,145989,2,2269,0)="""RTN"",""PSOSPML4"",154,0)"
^XMB(3.9,145989,2,2270,0)=" ;"
^XMB(3.9,145989,2,2271,0)="""RTN"",""PSOSPML4"",155,0)"
^XMB(3.9,145989,2,2272,0)=" K DIR S DIR(""A"")=""Record Type"""
^XMB(3.9,145989,2,2273,0)="""RTN"",""PSOSPML4"",156,0)"
^XMB(3.9,145989,2,2274,0)=" S DIR(""L"",1)=""Enter the type of record to be sent for this prescription fill:"""
^XMB(3.9,145989,2,2275,0)="""RTN"",""PSOSPML4"",157,0)"
^XMB(3.9,145989,2,2276,0)=" S DIR(""L"",2)="" """
^XMB(3.9,145989,2,2277,0)="""RTN"",""PSOSPML4"",158,0)"
^XMB(3.9,145989,2,2278,0)=" ; PSO*7*625: PSU-14 Begin"
^XMB(3.9,145989,2,2279,0)="""RTN"",""PSOSPML4"",159,0)"
^XMB(3.9,145989,2,2280,0)=" S PSOSECK=$$SECKEY^PSOSPMA3()"
^XMB(3.9,145989,2,2281,0)="""RTN"",""PSOSPML4"",160,0)"
^XMB(3.9,145989,2,2282,0)=" S DIR(""??"")=""^D ASAPHELP^PSOSPMU2(PSOASVER,""""DSP"""",1)"""
^XMB(3.9,145989,2,2283,0)="""RTN"",""PSOSPML4"",161,0)"
^XMB(3.9,145989,2,2284,0)=" I $$RXRLDT^PSOBPSUT(RXIEN,FILLNUM) D"
^XMB(3.9,145989,2,2285,0)="""RTN"",""PSOSPML4"",162,0)"
^XMB(3.9,145989,2,2286,0)=" . S DIR(""PRE"")=""D VRECMSG^PSOSPML4(X,RXIEN,FILLNUM,PSOSECK)"""
^XMB(3.9,145989,2,2287,0)="""RTN"",""PSOSPML4"",163,0)"
^XMB(3.9,145989,2,2288,0)=" . S DIR(0)=""S^N:NEW;R:REVISE""_$S($G(PSOSECK):"";V:VOID"",1:"""")"
^XMB(3.9,145989,2,2289,0)="""RTN"",""PSOSPML4"",164,0)"
^XMB(3.9,145989,2,2290,0)=" . S DIR(""L"",3)=""  N     NEW"""
^XMB(3.9,145989,2,2291,0)="""RTN"",""PSOSPML4"",165,0)"
^XMB(3.9,145989,2,2292,0)=" . S DIR(""L"",4)=""  R     REVISE"""
^XMB(3.9,145989,2,2293,0)="""RTN"",""PSOSPML4"",166,0)"
^XMB(3.9,145989,2,2294,0)=" . S DIR(""L"")=$S($G(PSOSECK):""  V     VOID"",1:"" (V)    VOID"")"
^XMB(3.9,145989,2,2295,0)="""RTN"",""PSOSPML4"",167,0)"
^XMB(3.9,145989,2,2296,0)=" . ; PSO*7*625: PSU-14 End "
^XMB(3.9,145989,2,2297,0)="""RTN"",""PSOSPML4"",168,0)"
^XMB(3.9,145989,2,2298,0)=" . S DIR(""B"")=""NEW"""
^XMB(3.9,145989,2,2299,0)="""RTN"",""PSOSPML4"",169,0)"
^XMB(3.9,145989,2,2300,0)=" E  D"
^XMB(3.9,145989,2,2301,0)="""RTN"",""PSOSPML4"",170,0)"
^XMB(3.9,145989,2,2302,0)=" . S DIR(0)=""S^V:VOID"""
^XMB(3.9,145989,2,2303,0)="""RTN"",""PSOSPML4"",171,0)"
^XMB(3.9,145989,2,2304,0)=" . S DIR(""L"")=""  V     VOID RECORD"""
^XMB(3.9,145989,2,2305,0)="""RTN"",""PSOSPML4"",172,0)"
^XMB(3.9,145989,2,2306,0)=" . S DIR(""B"")=""VOID"""
^XMB(3.9,145989,2,2307,0)="""RTN"",""PSOSPML4"",173,0)"
^XMB(3.9,145989,2,2308,0)=" D ^DIR I $D(DUOUT)!($D(DIRUT)) K DIRUT,DUOUT,DIR Q"
^XMB(3.9,145989,2,2309,0)="""RTN"",""PSOSPML4"",174,0)"
^XMB(3.9,145989,2,2310,0)=" S RECTYPE=Y"
^XMB(3.9,145989,2,2311,0)="""RTN"",""PSOSPML4"",175,0)"
^XMB(3.9,145989,2,2312,0)=" ;"
^XMB(3.9,145989,2,2313,0)="""RTN"",""PSOSPML4"",176,0)"
^XMB(3.9,145989,2,2314,0)=" W ! K DIR,DTOUT,DUOUT"
^XMB(3.9,145989,2,2315,0)="""RTN"",""PSOSPML4"",177,0)"
^XMB(3.9,145989,2,2316,0)=" I (RECTYPE'=""V"") D"
^XMB(3.9,145989,2,2317,0)="""RTN"",""PSOSPML4"",178,0)"
^XMB(3.9,145989,2,2318,0)=" . S DIR(""A"",1)=""The Prescription Fill will be transmitted to the State(s)"",DIR(""A"",2)="""""
^XMB(3.9,145989,2,2319,0)="""RTN"",""PSOSPML4"",179,0)"
^XMB(3.9,145989,2,2320,0)=" S DIR(""A"")=""Confirm"",DIR(0)=""Y"",DIR(""B"")=""N"""
^XMB(3.9,145989,2,2321,0)="""RTN"",""PSOSPML4"",180,0)"
^XMB(3.9,145989,2,2322,0)=" D ^DIR I $G(DTOUT)!$G(DUOUT)!'Y Q"
^XMB(3.9,145989,2,2323,0)="""RTN"",""PSOSPML4"",181,0)"
^XMB(3.9,145989,2,2324,0)=" W ?40,""Please wait..."""
^XMB(3.9,145989,2,2325,0)="""RTN"",""PSOSPML4"",182,0)"
^XMB(3.9,145989,2,2326,0)=" ;"
^XMB(3.9,145989,2,2327,0)="""RTN"",""PSOSPML4"",183,0)"
^XMB(3.9,145989,2,2328,0)=" S STATE=$$RXSTATE^PSOBPSUT(RXIEN,0)     ;P662"
^XMB(3.9,145989,2,2329,0)="""RTN"",""PSOSPML4"",184,0)"
^XMB(3.9,145989,2,2330,0)=" S STATELST=$$RXSTATEP^PSOBPSUT(RXIEN,0,STATE)"
^XMB(3.9,145989,2,2331,0)="""RTN"",""PSOSPML4"",185,0)"
^XMB(3.9,145989,2,2332,0)=" S DFN=$$GET1^DIQ(52,RXIEN,2,""I"") D ADD^VADPT I +VAPA(5)]"""" D"
^XMB(3.9,145989,2,2333,0)="""RTN"",""PSOSPML4"",186,0)"
^XMB(3.9,145989,2,2334,0)=" . S MBMST=$$GET1^DIQ(58.41,+VAPA(5),21,""I"")"
^XMB(3.9,145989,2,2335,0)="""RTN"",""PSOSPML4"",187,0)"
^XMB(3.9,145989,2,2336,0)=" . I (+MBMST=2),(STATELST'[(""^""_+VAPA(5)_""^"")) S STATELST=STATELST_+VAPA(5)_""^"""
^XMB(3.9,145989,2,2337,0)="""RTN"",""PSOSPML4"",188,0)"
^XMB(3.9,145989,2,2338,0)=" F LST=1:1:$L(STATELST,""^"") D"
^XMB(3.9,145989,2,2339,0)="""RTN"",""PSOSPML4"",189,0)"
^XMB(3.9,145989,2,2340,0)=" . S STATEIEN=$P(STATELST,""^"",LST) Q:STATEIEN="""""
^XMB(3.9,145989,2,2341,0)="""RTN"",""PSOSPML4"",190,0)"
^XMB(3.9,145989,2,2342,0)=" . S PSOASVER=$$GET1^DIQ(58.41,STATEIEN,1,""I"")"
^XMB(3.9,145989,2,2343,0)="""RTN"",""PSOSPML4"",191,0)"
^XMB(3.9,145989,2,2344,0)=" . S PSOTXRTS=+$$GET1^DIQ(58.41,STATEIEN,12,""I"")"
