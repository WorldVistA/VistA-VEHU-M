^XMB(3.9,145986,2,3461,0)="""RTN"",""FBPAY671"",115,0)"
^XMB(3.9,145986,2,3462,0)=" Q"
^XMB(3.9,145986,2,3463,0)="""RTN"",""FBPAY671"",116,0)"
^XMB(3.9,145986,2,3464,0)="WRTPC ; inputs"
^XMB(3.9,145986,2,3465,0)="""RTN"",""FBPAY671"",117,0)"
^XMB(3.9,145986,2,3466,0)=" ; FBDATA contains node from ^TMP"
^XMB(3.9,145986,2,3467,0)="""RTN"",""FBPAY671"",118,0)"
^XMB(3.9,145986,2,3468,0)=" ; I contains piece to be written"
^XMB(3.9,145986,2,3469,0)="""RTN"",""FBPAY671"",119,0)"
^XMB(3.9,145986,2,3470,0)=" I I=1!($X+$L($P(FBDATA,""^"",I))+2>IOM) W !,?4,""PROC: """
^XMB(3.9,145986,2,3471,0)="""RTN"",""FBPAY671"",120,0)"
