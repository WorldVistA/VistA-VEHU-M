^XMB(3.9,145957,2,290,0)=3
^XMB(3.9,145957,2,291,0)="""RTN"",""GMRCIMSG"")"
^XMB(3.9,145957,2,292,0)="0^2^B88371386"
^XMB(3.9,145957,2,293,0)="""RTN"",""GMRCIMSG"",1,0)"
^XMB(3.9,145957,2,294,0)="GMRCIMSG ;SLC/JFR - IFC MESSAGE HANDLING ROUTINE; 09/26/02 00:23 ; Jan 27, 2025@06:03:38"
^XMB(3.9,145957,2,295,0)="""RTN"",""GMRCIMSG"",2,0)"
^XMB(3.9,145957,2,296,0)=" ;;3.0;CONSULT/REQUEST TRACKING;**22,28,51,44,154,184,189,205**;DEC 27, 1997;Build 0"
^XMB(3.9,145957,2,297,0)="""RTN"",""GMRCIMSG"",3,0)"
^XMB(3.9,145957,2,298,0)=" ;"
^XMB(3.9,145957,2,299,0)="""RTN"",""GMRCIMSG"",4,0)"
^XMB(3.9,145957,2,300,0)=" ; Reference to EN^RMPRFC3 supported by #4661"
^XMB(3.9,145957,2,301,0)="""RTN"",""GMRCIMSG"",5,0)"
^XMB(3.9,145957,2,302,0)=" ; #2053 DIE, #4838 MAGDTR01, #2165 HLMA1, #10103 XLFDT, #2263 XPAR, #2171 XUAF4, #2541 XUPARAM"
^XMB(3.9,145957,2,303,0)="""RTN"",""GMRCIMSG"",6,0)"
^XMB(3.9,145957,2,304,0)=" ;  Reference to SAVEHL7^EHMHL7 supported by ICR #7424"
^XMB(3.9,145957,2,305,0)="""RTN"",""GMRCIMSG"",7,0)"
^XMB(3.9,145957,2,306,0)=" ;"
^XMB(3.9,145957,2,307,0)="""RTN"",""GMRCIMSG"",8,0)"
^XMB(3.9,145957,2,308,0)=" Q  ;don't start at the top"
^XMB(3.9,145957,2,309,0)="""RTN"",""GMRCIMSG"",9,0)"
^XMB(3.9,145957,2,310,0)="IN ;process incoming message and save segments to ^TMP("
^XMB(3.9,145957,2,311,0)="""RTN"",""GMRCIMSG"",10,0)"
^XMB(3.9,145957,2,312,0)=" K ^TMP(""GMRCIF"",$J)"
^XMB(3.9,145957,2,313,0)="""RTN"",""GMRCIMSG"",11,0)"
^XMB(3.9,145957,2,314,0)=" N GMRCCRNR,GMRCMSGD,GMRCMSGI,GMRCVALM,HLNODE,SEG,I,GMRCIER  ;production code ;MKN GMRC*3*154 added GMRCCRNR, GMRCMSGI, GMRCVALM"
^XMB(3.9,145957,2,315,0)="""RTN"",""GMRCIMSG"",12,0)"
^XMB(3.9,145957,2,316,0)=" N GMRCI,TCH,TEXTIN,TEXTOUT,TEXTRM,GMRCFRM ;MKN GMRC*3*154"
^XMB(3.9,145957,2,317,0)="""RTN"",""GMRCIMSG"",13,0)"
^XMB(3.9,145957,2,318,0)=" S GMRCCRNR=0,GMRCMSGI="""" ;MKN GMRC*3*154"
^XMB(3.9,145957,2,319,0)="""RTN"",""GMRCIMSG"",14,0)"
^XMB(3.9,145957,2,320,0)=" F I=1:1 X HLNEXT Q:HLQUIT'>0  D"
^XMB(3.9,145957,2,321,0)="""RTN"",""GMRCIMSG"",15,0)"
^XMB(3.9,145957,2,322,0)=" . I $P(HLNODE,""|"",8)=""CRNR"" S GMRCCRNR=1 ;MKN GMRC*3*154"
^XMB(3.9,145957,2,323,0)="""RTN"",""GMRCIMSG"",16,0)"
^XMB(3.9,145957,2,324,0)=" . I $P(HLNODE,""|"")=""MSH"" D"
^XMB(3.9,145957,2,325,0)="""RTN"",""GMRCIMSG"",17,0)"
^XMB(3.9,145957,2,326,0)=" .. S GMRCMSGD=$$HL7TFM^XLFDT($P(HLNODE,""|"",7),""L""),GMRCMSGD=$$FMTE^XLFDT(GMRCMSGD,""P"")"
^XMB(3.9,145957,2,327,0)="""RTN"",""GMRCIMSG"",18,0)"
^XMB(3.9,145957,2,328,0)=" .. S GMRCMSGI=$P(HLNODE,""|"",10)_""^""_GMRCMSGD"
^XMB(3.9,145957,2,329,0)="""RTN"",""GMRCIMSG"",19,0)"
^XMB(3.9,145957,2,330,0)=" . I $P(HLNODE,""|"")=""ORC"" D"
^XMB(3.9,145957,2,331,0)="""RTN"",""GMRCIMSG"",20,0)"
^XMB(3.9,145957,2,332,0)=" .. I $G(GMRCCRNR)=1 S ^TMP(""GMRCIF"",$J,""GMRCCRCR"")=1,GMRCFRM=$P($P(HLNODE,""|"",3),U,2),^TMP(""GMRCIF"",$J,""GMRCCRNR"")=1_U_$P(GMRCFRM,U,1)  ;WTC GMRC*3.0*184"
^XMB(3.9,145957,2,333,0)="""RTN"",""GMRCIMSG"",21,0)"
^XMB(3.9,145957,2,334,0)=" . I $P(HLNODE,""|"")=""OBX"" D  ;multiple segs for OBX"
^XMB(3.9,145957,2,335,0)="""RTN"",""GMRCIMSG"",22,0)"
^XMB(3.9,145957,2,336,0)=" .. ;MKN GMRC*3.0*154 start of mods"
^XMB(3.9,145957,2,337,0)="""RTN"",""GMRCIMSG"",23,0)"
^XMB(3.9,145957,2,338,0)=" .. I $P(HLNODE,""|"",3)=""TX"" D  Q"
^XMB(3.9,145957,2,339,0)="""RTN"",""GMRCIMSG"",24,0)"
^XMB(3.9,145957,2,340,0)=" ... D SETTCH"
^XMB(3.9,145957,2,341,0)="""RTN"",""GMRCIMSG"",25,0)"
^XMB(3.9,145957,2,342,0)=" ... S TEXTIN=$E(HLNODE,5,999),TEXTRM="""",TEXTOUT="""""
^XMB(3.9,145957,2,343,0)="""RTN"",""GMRCIMSG"",26,0)"
^XMB(3.9,145957,2,344,0)=" ... D DECODE^GMRCHL7E(TEXTIN,.TCH,.TEXTOUT,TEXTRM)"
^XMB(3.9,145957,2,345,0)="""RTN"",""GMRCIMSG"",27,0)"
^XMB(3.9,145957,2,346,0)=" ... S ^TMP(""GMRCIF"",$J,""OBX"",$P(HLNODE,""|"",2),$P(HLNODE,""|"",5))=TEXTOUT_TEXTRM"
^XMB(3.9,145957,2,347,0)="""RTN"",""GMRCIMSG"",28,0)"
^XMB(3.9,145957,2,348,0)=" .. ;MKN GMRC*3.0*154 end of mods"
^XMB(3.9,145957,2,349,0)="""RTN"",""GMRCIMSG"",29,0)"
^XMB(3.9,145957,2,350,0)=" .. S ^TMP(""GMRCIF"",$J,""OBX"",$P(HLNODE,""|"",2),$P(HLNODE,""|"",5))=$E(HLNODE,5,999)"
^XMB(3.9,145957,2,351,0)="""RTN"",""GMRCIMSG"",30,0)"
^XMB(3.9,145957,2,352,0)=" . I $P(HLNODE,""|"")=""NTE"" D  ; may be multiple NTE's"
^XMB(3.9,145957,2,353,0)="""RTN"",""GMRCIMSG"",31,0)"
^XMB(3.9,145957,2,354,0)=" .. ;MKN GMRC*3.0*154 start of mods"
^XMB(3.9,145957,2,355,0)="""RTN"",""GMRCIMSG"",32,0)"
^XMB(3.9,145957,2,356,0)=" .. D SETTCH"
^XMB(3.9,145957,2,357,0)="""RTN"",""GMRCIMSG"",33,0)"
^XMB(3.9,145957,2,358,0)=" .. S TEXTIN=$E(HLNODE,5,999),TEXTRM="""",TEXTOUT="""""
^XMB(3.9,145957,2,359,0)="""RTN"",""GMRCIMSG"",34,0)"
^XMB(3.9,145957,2,360,0)=" .. D DECODE^GMRCHL7E(TEXTIN,.TCH,.TEXTOUT,TEXTRM)"
^XMB(3.9,145957,2,361,0)="""RTN"",""GMRCIMSG"",35,0)"
^XMB(3.9,145957,2,362,0)=" .. S ^TMP(""GMRCIF"",$J,""NTE"",$P(HLNODE,""|"",2))=TEXTOUT"
^XMB(3.9,145957,2,363,0)="""RTN"",""GMRCIMSG"",36,0)"
^XMB(3.9,145957,2,364,0)=" .. ;S ^TMP(""GMRCIF"",$J,""NTE"",$P(HLNODE,""|"",2))=$E(HLNODE,5,999)"
^XMB(3.9,145957,2,365,0)="""RTN"",""GMRCIMSG"",37,0)"
^XMB(3.9,145957,2,366,0)=" .. ;MKN GMRC*3.0*154 end of mods"
^XMB(3.9,145957,2,367,0)="""RTN"",""GMRCIMSG"",38,0)"
^XMB(3.9,145957,2,368,0)=" . I ""OBXNTE""'[$P(HLNODE,""|"") D  ;all other segs are single"
^XMB(3.9,145957,2,369,0)="""RTN"",""GMRCIMSG"",39,0)"
^XMB(3.9,145957,2,370,0)=" .. S ^TMP(""GMRCIF"",$J,$P(HLNODE,""|""))=$E(HLNODE,5,999)"
^XMB(3.9,145957,2,371,0)="""RTN"",""GMRCIMSG"",40,0)"
^XMB(3.9,145957,2,372,0)=" . Q"
^XMB(3.9,145957,2,373,0)="""RTN"",""GMRCIMSG"",41,0)"
^XMB(3.9,145957,2,374,0)=" ;"
^XMB(3.9,145957,2,375,0)="""RTN"",""GMRCIMSG"",42,0)"
^XMB(3.9,145957,2,376,0)=" ;  If Cerner order number missing from Consult file, extract it and patient account number from HL7 message and store them.  p205 wtc 9/17/24"
^XMB(3.9,145957,2,377,0)="""RTN"",""GMRCIMSG"",43,0)"
^XMB(3.9,145957,2,378,0)=" ;"
^XMB(3.9,145957,2,379,0)="""RTN"",""GMRCIMSG"",44,0)"
^XMB(3.9,145957,2,380,0)=" I GMRCCRNR,$P(^TMP(""GMRCIF"",$J,""ORC""),""|"")'=""NW"" D  ;"
^XMB(3.9,145957,2,381,0)="""RTN"",""GMRCIMSG"",45,0)"
^XMB(3.9,145957,2,382,0)=" . ;"
^XMB(3.9,145957,2,383,0)="""RTN"",""GMRCIMSG"",46,0)"
^XMB(3.9,145957,2,384,0)=" . N GMRCDA,GMRCORDN,GMRCFIN ;"
^XMB(3.9,145957,2,385,0)="""RTN"",""GMRCIMSG"",47,0)"
^XMB(3.9,145957,2,386,0)=" . S GMRCDA=$P($P(^TMP(""GMRCIF"",$J,""ORC""),""|"",2),U,1) Q:'GMRCDA  Q:'$D(^GMR(123,GMRCDA))  S GMRCORDN=$P($P(^TMP(""GMRCIF"",$J,""ORC""),""|"",3),U,1) Q:'GMRCORDN  ;"
^XMB(3.9,145957,2,387,0)="""RTN"",""GMRCIMSG"",48,0)"
^XMB(3.9,145957,2,388,0)=" . S GMRCFIN=$P($G(^TMP(""GMRCIF"",$J,""PID"")),""|"",18) ;"
^XMB(3.9,145957,2,389,0)="""RTN"",""GMRCIMSG"",49,0)"
^XMB(3.9,145957,2,390,0)=" . I $P(^GMR(123,GMRCDA,0),U,22)'="""" Q  ;"
^XMB(3.9,145957,2,391,0)="""RTN"",""GMRCIMSG"",50,0)"
^XMB(3.9,145957,2,392,0)=" . ;"
^XMB(3.9,145957,2,393,0)="""RTN"",""GMRCIMSG"",51,0)"
^XMB(3.9,145957,2,394,0)=" . N FDA,GMRCERR ;"
^XMB(3.9,145957,2,395,0)="""RTN"",""GMRCIMSG"",52,0)"
^XMB(3.9,145957,2,396,0)=" . S FDA(1,123,GMRCDA_"","",.06)=GMRCORDN ;"
^XMB(3.9,145957,2,397,0)="""RTN"",""GMRCIMSG"",53,0)"
^XMB(3.9,145957,2,398,0)=" . S FDA(1,123,GMRCDA_"","",502)=GMRCFIN ;"
^XMB(3.9,145957,2,399,0)="""RTN"",""GMRCIMSG"",54,0)"
^XMB(3.9,145957,2,400,0)=" . D UPDATE^DIE("""",""FDA(1)"",,""GMRCERR"") ;"
^XMB(3.9,145957,2,401,0)="""RTN"",""GMRCIMSG"",55,0)"
^XMB(3.9,145957,2,402,0)=" ;"
^XMB(3.9,145957,2,403,0)="""RTN"",""GMRCIMSG"",56,0)"
^XMB(3.9,145957,2,404,0)=" S GMRCVALM=$$VALMSG(^TMP(""GMRCIF"",$J,""ORC""),GMRCCRNR,$NA(^TMP(""GMRCIF"",$J))) ; MKN GMRC*3.0*154, P205 WTC 8/21/24"
^XMB(3.9,145957,2,405,0)="""RTN"",""GMRCIMSG"",57,0)"
^XMB(3.9,145957,2,406,0)=" I 'GMRCVALM,'GMRCCRNR D EX Q  ;chk msg for valid cslt #'s ; MKN GMRC*3.0*154 added GMRCCRNR"
^XMB(3.9,145957,2,407,0)="""RTN"",""GMRCIMSG"",58,0)"
^XMB(3.9,145957,2,408,0)=" I 'GMRCVALM,GMRCCRNR D MGMSG^GMRCIAC2(101,GMRCMSGI),EX Q  ; send app. ACK ;MKN GMRC*3*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,409,0)="""RTN"",""GMRCIMSG"",59,0)"
^XMB(3.9,145957,2,410,0)=" ;"
^XMB(3.9,145957,2,411,0)="""RTN"",""GMRCIMSG"",60,0)"
^XMB(3.9,145957,2,412,0)=" I $P(^TMP(""GMRCIF"",$J,""ORC""),""|"")=""NW"" D  D EX Q"
^XMB(3.9,145957,2,413,0)="""RTN"",""GMRCIMSG"",61,0)"
^XMB(3.9,145957,2,414,0)=" . I $P(^TMP(""GMRCIF"",$J,""ORC""),""|"",2)[""TST1234"" D  D EX Q  ;testing impl"
^XMB(3.9,145957,2,415,0)="""RTN"",""GMRCIMSG"",62,0)"
^XMB(3.9,145957,2,416,0)=" .. D TST^GMRCIAC2($NA(^TMP(""GMRCIF"",$J)))"
^XMB(3.9,145957,2,417,0)="""RTN"",""GMRCIMSG"",63,0)"
^XMB(3.9,145957,2,418,0)=" . D NW^GMRCIACT($NA(^TMP(""GMRCIF"",$J)))"
^XMB(3.9,145957,2,419,0)="""RTN"",""GMRCIMSG"",64,0)"
^XMB(3.9,145957,2,420,0)=" I $P(^TMP(""GMRCIF"",$J,""ORC""),""|"")=""XO"" D  D EX Q"
^XMB(3.9,145957,2,421,0)="""RTN"",""GMRCIMSG"",65,0)"
^XMB(3.9,145957,2,422,0)=" . D RESUB^GMRCIAC1($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,423,0)="""RTN"",""GMRCIMSG"",66,0)"
^XMB(3.9,145957,2,424,0)=" I $P(^TMP(""GMRCIF"",$J,""ORC""),""|"")=""XX"" D  D EX Q"
^XMB(3.9,145957,2,425,0)="""RTN"",""GMRCIMSG"",67,0)"
^XMB(3.9,145957,2,426,0)=" . D FWD^GMRCIAC1($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,427,0)="""RTN"",""GMRCIMSG"",68,0)"
^XMB(3.9,145957,2,428,0)=" I $P(^TMP(""GMRCIF"",$J,""ORC""),""|"")=""RE"" D  D EX Q"
^XMB(3.9,145957,2,429,0)="""RTN"",""GMRCIMSG"",69,0)"
^XMB(3.9,145957,2,430,0)=" . I $P($G(^TMP(""GMRCIF"",$J,""OBX"",4,1)),""|"",11)=""D"" D  Q"
^XMB(3.9,145957,2,431,0)="""RTN"",""GMRCIMSG"",70,0)"
^XMB(3.9,145957,2,432,0)=" .. D DIS^GMRCIACT($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; dis-assoc. result ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,433,0)="""RTN"",""GMRCIMSG"",71,0)"
^XMB(3.9,145957,2,434,0)=" . I $P($P(^TMP(""GMRCIF"",$J,""ORC""),""|"",16),U)=""S"" D  Q"
^XMB(3.9,145957,2,435,0)="""RTN"",""GMRCIMSG"",72,0)"
^XMB(3.9,145957,2,436,0)=" .. D SF^GMRCIAC1($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; significant findings ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,437,0)="""RTN"",""GMRCIMSG"",73,0)"
^XMB(3.9,145957,2,438,0)=" . D COMP^GMRCIAC1($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,439,0)="""RTN"",""GMRCIMSG"",74,0)"
^XMB(3.9,145957,2,440,0)=" D OTHER^GMRCIACT($NA(^TMP(""GMRCIF"",$J)),GMRCCRNR,GMRCMSGI) ; MKN GMRC*3.0*154 added GMRCCRNR and GMRCMSGI"
^XMB(3.9,145957,2,441,0)="""RTN"",""GMRCIMSG"",75,0)"
^XMB(3.9,145957,2,442,0)=" D EX"
^XMB(3.9,145957,2,443,0)="""RTN"",""GMRCIMSG"",76,0)"
^XMB(3.9,145957,2,444,0)=" Q"
^XMB(3.9,145957,2,445,0)="""RTN"",""GMRCIMSG"",77,0)"
^XMB(3.9,145957,2,446,0)=" ;"
^XMB(3.9,145957,2,447,0)="""RTN"",""GMRCIMSG"",78,0)"
^XMB(3.9,145957,2,448,0)="EX ; clean up"
^XMB(3.9,145957,2,449,0)="""RTN"",""GMRCIMSG"",79,0)"
^XMB(3.9,145957,2,450,0)=" ;"
^XMB(3.9,145957,2,451,0)="""RTN"",""GMRCIMSG"",80,0)"
^XMB(3.9,145957,2,452,0)=" ;  If from Cerner, save HL7 message in file #1609.  - P189"
^XMB(3.9,145957,2,453,0)="""RTN"",""GMRCIMSG"",81,0)"
^XMB(3.9,145957,2,454,0)=" ;"
^XMB(3.9,145957,2,455,0)="""RTN"",""GMRCIMSG"",82,0)"
^XMB(3.9,145957,2,456,0)=" I $G(GMRCCRNR) D SAVEHL7^EHMHL7(""IFC"",""CERNER-""_$P($P($G(^TMP(""GMRCIF"",$J,""OBR"")),""|"",2),""^"",2),""VISTA-""_$$STA^XUAF4($$KSP^XUPARAM(""INST"")),""|"",""^"",""~"") ;"
^XMB(3.9,145957,2,457,0)="""RTN"",""GMRCIMSG"",83,0)"
^XMB(3.9,145957,2,458,0)=" ; "
^XMB(3.9,145957,2,459,0)="""RTN"",""GMRCIMSG"",84,0)"
^XMB(3.9,145957,2,460,0)=" ; EHRM Prosthetics"
^XMB(3.9,145957,2,461,0)="""RTN"",""GMRCIMSG"",85,0)"
^XMB(3.9,145957,2,462,0)=" N GMRCEHRM"
^XMB(3.9,145957,2,463,0)="""RTN"",""GMRCIMSG"",86,0)"
^XMB(3.9,145957,2,464,0)=" S GMRCEHRM=$$EHRMCHK($G(^TMP(""GMRCIF"",$J,""ORC"")),$G(^TMP(""GMRCIF"",$J,""OBR"")))"
^XMB(3.9,145957,2,465,0)="""RTN"",""GMRCIMSG"",87,0)"
^XMB(3.9,145957,2,466,0)=" K ^TMP(""GMRCIF"",$J)"
^XMB(3.9,145957,2,467,0)="""RTN"",""GMRCIMSG"",88,0)"
^XMB(3.9,145957,2,468,0)=" ; Call EHRM Prosthetics routine - added for GMRC*3*154"
^XMB(3.9,145957,2,469,0)="""RTN"",""GMRCIMSG"",89,0)"
^XMB(3.9,145957,2,470,0)=" I GMRCEHRM=1,$T(EN^GMRCRFC0)'="""" D  Q  ; invoke EHRM Prosthetics if tag^routine exists and this is EHRM message. Otherwise, invoke legacy routine EN^RMPRFC3"
^XMB(3.9,145957,2,471,0)="""RTN"",""GMRCIMSG"",90,0)"
^XMB(3.9,145957,2,472,0)=" .D EN^GMRCRFC0(HLNEXT,HLQUIT)"
^XMB(3.9,145957,2,473,0)="""RTN"",""GMRCIMSG"",91,0)"
^XMB(3.9,145957,2,474,0)=" ;"
^XMB(3.9,145957,2,475,0)="""RTN"",""GMRCIMSG"",92,0)"
^XMB(3.9,145957,2,476,0)=" ;call Prosthetics routine - added for RMPR*3*83"
^XMB(3.9,145957,2,477,0)="""RTN"",""GMRCIMSG"",93,0)"
^XMB(3.9,145957,2,478,0)=" I $T(EN^RMPRFC3)'="""" D  ;invoke prosthetics code if tag^routine exists"
^XMB(3.9,145957,2,479,0)="""RTN"",""GMRCIMSG"",94,0)"
^XMB(3.9,145957,2,480,0)=" . D EN^RMPRFC3"
^XMB(3.9,145957,2,481,0)="""RTN"",""GMRCIMSG"",95,0)"
^XMB(3.9,145957,2,482,0)=" Q"
^XMB(3.9,145957,2,483,0)="""RTN"",""GMRCIMSG"",96,0)"
^XMB(3.9,145957,2,484,0)=" ;"
^XMB(3.9,145957,2,485,0)="""RTN"",""GMRCIMSG"",97,0)"
^XMB(3.9,145957,2,486,0)="EHRMCHK(ORCSEG,OBRSEG) ; Check for EHRM"
^XMB(3.9,145957,2,487,0)="""RTN"",""GMRCIMSG"",98,0)"
^XMB(3.9,145957,2,488,0)=" N GMRCORC,GMRCORC2,GMRCORC3,GMRCORC5,GMRCSTAT,GMRCOBR4"
^XMB(3.9,145957,2,489,0)="""RTN"",""GMRCIMSG"",99,0)"
^XMB(3.9,145957,2,490,0)=" S GMRCORC2=$P($P(ORCSEG,""|"",2),""^"",2)          ; Placer Facility"
^XMB(3.9,145957,2,491,0)="""RTN"",""GMRCIMSG"",100,0)"
^XMB(3.9,145957,2,492,0)=" S GMRCORC3=$P($P(ORCSEG,""|"",3),""^"",2)          ; Filler Facility"
^XMB(3.9,145957,2,493,0)="""RTN"",""GMRCIMSG"",101,0)"
^XMB(3.9,145957,2,494,0)=" S GMRCOBR4=$P($P(OBRSEG,""|"",4),""^"",2)          ; Text (string) component of the Universal Identifier "
^XMB(3.9,145957,2,495,0)="""RTN"",""GMRCIMSG"",102,0)"
^XMB(3.9,145957,2,496,0)=" S GMRCSTAT=$P(ORCSEG,""|"")                      ; Control Code"
^XMB(3.9,145957,2,497,0)="""RTN"",""GMRCIMSG"",103,0)"
^XMB(3.9,145957,2,498,0)=" I GMRCSTAT=""OD"" S GMRCSTAT=$P(ORCSEG,""|"",5)    ; Status"
^XMB(3.9,145957,2,499,0)="""RTN"",""GMRCIMSG"",104,0)"
^XMB(3.9,145957,2,500,0)=" I (GMRCSTAT'=""NW"")&(GMRCSTAT'=""DC"") Q 0        ; Only process NW and DC"
^XMB(3.9,145957,2,501,0)="""RTN"",""GMRCIMSG"",105,0)"
^XMB(3.9,145957,2,502,0)=" ; EHRM Prosthetics NW requires incoming Placer Facility = Local Facility, Universal Service ID contains PROSTHETICS IFC or PSAS"
^XMB(3.9,145957,2,503,0)="""RTN"",""GMRCIMSG"",106,0)"
^XMB(3.9,145957,2,504,0)=" I GMRCSTAT=""NW"" I ($$IEN^XUAF4(GMRCORC2)=$$KSP^XUPARAM(""INST"")),((GMRCOBR4[""PROSTHETICS IFC"")!(GMRCOBR4[""PSAS"")) Q 1"
^XMB(3.9,145957,2,505,0)="""RTN"",""GMRCIMSG"",107,0)"
^XMB(3.9,145957,2,506,0)=" ; EHRM Prosthetics DC requires incoming Placer Facility = Local Facility, Placer Facility = Filler Facility, Universal Service ID contains PROSTHETICS IFC or PSAS"
^XMB(3.9,145957,2,507,0)="""RTN"",""GMRCIMSG"",108,0)"
^XMB(3.9,145957,2,508,0)=" I GMRCSTAT=""DC"" I ($$IEN^XUAF4(GMRCORC2)=$$KSP^XUPARAM(""INST"")),(GMRCORC2=GMRCORC3),((GMRCOBR4[""PROSTHETICS IFC"")!(GMRCOBR4[""PSAS"")) Q 1"
^XMB(3.9,145957,2,509,0)="""RTN"",""GMRCIMSG"",109,0)"
^XMB(3.9,145957,2,510,0)=" Q 0"
^XMB(3.9,145957,2,511,0)="""RTN"",""GMRCIMSG"",110,0)"
^XMB(3.9,145957,2,512,0)=" ;"
^XMB(3.9,145957,2,513,0)="""RTN"",""GMRCIMSG"",111,0)"
^XMB(3.9,145957,2,514,0)="ORRIN ;process IFC responses"
^XMB(3.9,145957,2,515,0)="""RTN"",""GMRCIMSG"",112,0)"
^XMB(3.9,145957,2,516,0)=" K ^TMP(""GMRCIF"",$J)"
^XMB(3.9,145957,2,517,0)="""RTN"",""GMRCIMSG"",113,0)"
^XMB(3.9,145957,2,518,0)=" N HLNODE,SEG,I,PTACCTNO ;production code"
^XMB(3.9,145957,2,519,0)="""RTN"",""GMRCIMSG"",114,0)"
^XMB(3.9,145957,2,520,0)=" F I=1:1 X HLNEXT Q:HLQUIT'>0  D"
^XMB(3.9,145957,2,521,0)="""RTN"",""GMRCIMSG"",115,0)"
^XMB(3.9,145957,2,522,0)=" .S ^TMP(""GMRCIF"",$J,$P(HLNODE,""|""))=$E(HLNODE,5,999)"
^XMB(3.9,145957,2,523,0)="""RTN"",""GMRCIMSG"",116,0)"
^XMB(3.9,145957,2,524,0)=" ;"
^XMB(3.9,145957,2,525,0)="""RTN"",""GMRCIMSG"",117,0)"
^XMB(3.9,145957,2,526,0)=" I $D(^TMP(""GMRCIF"",$J,""ORC"")),$P(^(""ORC""),""|"")=""OK"" D"
