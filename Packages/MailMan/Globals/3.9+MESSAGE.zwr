^XMB(3.9,145946,2,5385,0)="""RTN"",""IBCNSU21"",52,0)"
^XMB(3.9,145946,2,5386,0)=" . S ^TMP(""IBCNSU21IX"",$J,VALMCNT)=IBP"
^XMB(3.9,145946,2,5387,0)="""RTN"",""IBCNSU21"",53,0)"
