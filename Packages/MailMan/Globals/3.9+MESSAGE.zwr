^XMB(3.9,145946,2,4988,0)=" F IX=1:1:$L(IIENS,"","") D"
^XMB(3.9,145946,2,4989,0)="""RTN"",""IBCNILK"",326,0)"
^XMB(3.9,145946,2,4990,0)=" . S IIEN=$P(IIENS,"","",IX)"
^XMB(3.9,145946,2,4991,0)="""RTN"",""IBCNILK"",327,0)"
