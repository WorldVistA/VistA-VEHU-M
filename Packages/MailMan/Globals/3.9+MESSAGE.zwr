^XMB(3.9,145944,2,620,0)=" ; IB*2.0*694"
^XMB(3.9,145944,2,621,0)="""RTN"",""IBJDF41"",183,0)"
^XMB(3.9,145944,2,622,0)=" S RPIEN=$P($G(^PRCA(430,X,4)),U,5)  ; file 340.5 ien"
^XMB(3.9,145944,2,623,0)="""RTN"",""IBJDF41"",184,0)"
^XMB(3.9,145944,2,624,0)=" S Z=$$REPDATA(RPIEN,1) I Z="""" Q 0"
^XMB(3.9,145944,2,625,0)="""RTN"",""IBJDF41"",185,0)"
^XMB(3.9,145944,2,626,0)=" I $P(Z,U,9)=5 Q (""2^""_$P(Z,U))  ; IB*2.0*694"
^XMB(3.9,145944,2,627,0)="""RTN"",""IBJDF41"",186,0)"
^XMB(3.9,145944,2,628,0)=" ;"
^XMB(3.9,145944,2,629,0)="""RTN"",""IBJDF41"",187,0)"
^XMB(3.9,145944,2,630,0)=" Q (""1^""_$P(Z,U))  ; IB*2.0*694"
^XMB(3.9,145944,2,631,0)="""RTN"",""IBJDF41"",188,0)"
^XMB(3.9,145944,2,632,0)=" ;"
^XMB(3.9,145944,2,633,0)="""RTN"",""IBJDF41"",189,0)"
^XMB(3.9,145944,2,634,0)="MTRX(X) ; - Return patient's means test and/or RX copay status and most recent"
^XMB(3.9,145944,2,635,0)="""RTN"",""IBJDF41"",190,0)"
^XMB(3.9,145944,2,636,0)=" ;   test dates for both."
^XMB(3.9,145944,2,637,0)="""RTN"",""IBJDF41"",191,0)"
^XMB(3.9,145944,2,638,0)=" ;    Input: X=Patient pointer to file #2 and opt. variable IBEXCEL"
^XMB(3.9,145944,2,639,0)="""RTN"",""IBJDF41"",192,0)"
^XMB(3.9,145944,2,640,0)=" ;   Output: Y=Means test status ^ Date ^ RX copay status ^ Date "
^XMB(3.9,145944,2,641,0)="""RTN"",""IBJDF41"",193,0)"
^XMB(3.9,145944,2,642,0)=" N MTST,RXST,Y"
^XMB(3.9,145944,2,643,0)="""RTN"",""IBJDF41"",194,0)"
^XMB(3.9,145944,2,644,0)=" S Y=""^^^"",MTST=$$LST^DGMTU(X),RXST=$$RXST^IBARXEU(X)"
^XMB(3.9,145944,2,645,0)="""RTN"",""IBJDF41"",195,0)"
^XMB(3.9,145944,2,646,0)=" I '$G(IBEXCEL) D"
^XMB(3.9,145944,2,647,0)="""RTN"",""IBJDF41"",196,0)"
^XMB(3.9,145944,2,648,0)=" . S $P(Y,""^"",1,2)=$P(MTST,""^"",3)_""^""_$$DAT1^IBOUTL($P(MTST,""^"",2))"
^XMB(3.9,145944,2,649,0)="""RTN"",""IBJDF41"",197,0)"
^XMB(3.9,145944,2,650,0)=" . S $P(Y,""^"",3)=$S('RXST:""NON-EXEMPT"",+RXST=1:""EXEMPT"",1:"""")"
^XMB(3.9,145944,2,651,0)="""RTN"",""IBJDF41"",198,0)"
^XMB(3.9,145944,2,652,0)=" . I $P(Y,""^"",3)'="""" S $P(Y,""^"",4)=$$DAT1^IBOUTL($P(RXST,""^"",5))"
^XMB(3.9,145944,2,653,0)="""RTN"",""IBJDF41"",199,0)"
^XMB(3.9,145944,2,654,0)=" I $G(IBEXCEL) D"
^XMB(3.9,145944,2,655,0)="""RTN"",""IBJDF41"",200,0)"
^XMB(3.9,145944,2,656,0)=" . S $P(Y,""^"",1,2)=$P(MTST,""^"",4)_""^""_$$DT^IBJD($P(MTST,""^"",2),1)"
^XMB(3.9,145944,2,657,0)="""RTN"",""IBJDF41"",201,0)"
^XMB(3.9,145944,2,658,0)=" . S $P(Y,""^"",3)=$S('RXST:""M"",+RXST=1:""E"",1:"""")"
^XMB(3.9,145944,2,659,0)="""RTN"",""IBJDF41"",202,0)"
^XMB(3.9,145944,2,660,0)=" . I $P(Y,""^"",3)'="""" S $P(Y,""^"",4)=$$DT^IBJD($P(RXST,""^"",5),1)"
^XMB(3.9,145944,2,661,0)="""RTN"",""IBJDF41"",203,0)"
^XMB(3.9,145944,2,662,0)=" Q Y"
^XMB(3.9,145944,2,663,0)="""RTN"",""IBJDF41"",204,0)"
^XMB(3.9,145944,2,664,0)=" ;"
^XMB(3.9,145944,2,665,0)="""RTN"",""IBJDF41"",205,0)"
^XMB(3.9,145944,2,666,0)="SREF(RFT,DAT,STS,DEF,IDX) ; Set the ""referred to"" information on the "
^XMB(3.9,145944,2,667,0)="""RTN"",""IBJDF41"",206,0)"
^XMB(3.9,145944,2,668,0)=" ;                         temporary global ^TMP"
^XMB(3.9,145944,2,669,0)="""RTN"",""IBJDF41"",207,0)"
^XMB(3.9,145944,2,670,0)=" ;Input: RFT: ""R"": RC, ""D"": DMC, ""T"": TOP, ""C"": CROSS SERVICING, ""P"": REPAYMENT PLAN"
^XMB(3.9,145944,2,671,0)="""RTN"",""IBJDF41"",208,0)"
^XMB(3.9,145944,2,672,0)=" ;       DAT: Date it was referred/established"
^XMB(3.9,145944,2,673,0)="""RTN"",""IBJDF41"",209,0)"
^XMB(3.9,145944,2,674,0)=" ;       STS: Receivable status (16-Active,19-Suspended)"
^XMB(3.9,145944,2,675,0)="""RTN"",""IBJDF41"",210,0)"
^XMB(3.9,145944,2,676,0)=" ;       DEF: Repayment Plan in Default? (1 - YES, 0 - NO)"
^XMB(3.9,145944,2,677,0)="""RTN"",""IBJDF41"",211,0)"
^XMB(3.9,145944,2,678,0)=" ;       IDX: Subscript to be set in the Temporary global ^TMP"
^XMB(3.9,145944,2,679,0)="""RTN"",""IBJDF41"",212,0)"
^XMB(3.9,145944,2,680,0)=" ;Output: IDX: Subscript set in the Temporary global ^TMP"
^XMB(3.9,145944,2,681,0)="""RTN"",""IBJDF41"",213,0)"
^XMB(3.9,145944,2,682,0)=" ;"
^XMB(3.9,145944,2,683,0)="""RTN"",""IBJDF41"",214,0)"
^XMB(3.9,145944,2,684,0)=" N SREF,IDX1"
^XMB(3.9,145944,2,685,0)="""RTN"",""IBJDF41"",215,0)"
^XMB(3.9,145944,2,686,0)=" S DEF=+$G(DEF),IDX=+$G(IDX)"
^XMB(3.9,145944,2,687,0)="""RTN"",""IBJDF41"",216,0)"
^XMB(3.9,145944,2,688,0)=" I RFT=""R"" S SREF=""REFERRED TO RC"""
^XMB(3.9,145944,2,689,0)="""RTN"",""IBJDF41"",217,0)"
^XMB(3.9,145944,2,690,0)=" I RFT=""D"" S SREF=""REFERRED TO DMC"""
^XMB(3.9,145944,2,691,0)="""RTN"",""IBJDF41"",218,0)"
^XMB(3.9,145944,2,692,0)=" I RFT=""T"" S SREF=""REFERRED TO TOP"""
^XMB(3.9,145944,2,693,0)="""RTN"",""IBJDF41"",219,0)"
^XMB(3.9,145944,2,694,0)=" I RFT=""C"" S SREF=""REFERRED TO CS"" ; PRCA*4.5*338"
^XMB(3.9,145944,2,695,0)="""RTN"",""IBJDF41"",220,0)"
^XMB(3.9,145944,2,696,0)=" I RFT=""P"" D"
^XMB(3.9,145944,2,697,0)="""RTN"",""IBJDF41"",221,0)"
^XMB(3.9,145944,2,698,0)=" . S SREF=""REPAYMENT PLAN ESTABLISHED"""
^XMB(3.9,145944,2,699,0)="""RTN"",""IBJDF41"",222,0)"
^XMB(3.9,145944,2,700,0)=" . I $G(DEF) S SREF=SREF_"" (CURRENTLY IN DEFAULT)"""
^XMB(3.9,145944,2,701,0)="""RTN"",""IBJDF41"",223,0)"
^XMB(3.9,145944,2,702,0)=" ;"
^XMB(3.9,145944,2,703,0)="""RTN"",""IBJDF41"",224,0)"
^XMB(3.9,145944,2,704,0)=" I 'IDX S IDX=$O(^TMP(""IBJDF4"",$J,IBPAT,0,""C"",STS,""""),-1)+1"
^XMB(3.9,145944,2,705,0)="""RTN"",""IBJDF41"",225,0)"
^XMB(3.9,145944,2,706,0)=" S IDX1=$O(^TMP(""IBJDF4"",$J,IBPAT,0,""C"",STS,IDX,""""),-1)+1"
^XMB(3.9,145944,2,707,0)="""RTN"",""IBJDF41"",226,0)"
^XMB(3.9,145944,2,708,0)=" S ^TMP(""IBJDF4"",$J,IBPAT,0,""C"",STS,IDX,IDX1)=DAT"
^XMB(3.9,145944,2,709,0)="""RTN"",""IBJDF41"",227,0)"
^XMB(3.9,145944,2,710,0)=" S ^TMP(""IBJDF4"",$J,IBPAT,0,""C"",STS,IDX,IDX1,1)=SREF"
^XMB(3.9,145944,2,711,0)="""RTN"",""IBJDF41"",228,0)"
^XMB(3.9,145944,2,712,0)=" Q"
^XMB(3.9,145944,2,713,0)="""RTN"",""IBJDF41"",229,0)"
^XMB(3.9,145944,2,714,0)=" ;"
^XMB(3.9,145944,2,715,0)="""RTN"",""IBJDF41"",230,0)"
^XMB(3.9,145944,2,716,0)="COM ; - Get bill comments."
^XMB(3.9,145944,2,717,0)="""RTN"",""IBJDF41"",231,0)"
^XMB(3.9,145944,2,718,0)=" I 'IBIDX,'$G(IBEXCEL) D"
^XMB(3.9,145944,2,719,0)="""RTN"",""IBJDF41"",232,0)"
^XMB(3.9,145944,2,720,0)=" . S IBFLG=0,IBIDX=$O(^TMP(""IBJDF4"",$J,IBPAT,0,""C"",IB0,""""),-1)+1"
^XMB(3.9,145944,2,721,0)="""RTN"",""IBJDF41"",233,0)"
^XMB(3.9,145944,2,722,0)=" ;"
^XMB(3.9,145944,2,723,0)="""RTN"",""IBJDF41"",234,0)"
^XMB(3.9,145944,2,724,0)=" S DAT=0,IBA1=$S(IBSH1=""M"":999999999,1:0)"
^XMB(3.9,145944,2,725,0)="""RTN"",""IBJDF41"",235,0)"
^XMB(3.9,145944,2,726,0)=" F  S IBA1=$S(IBSH1=""M"":$O(^PRCA(433,""C"",IBA,IBA1),-1),1:$O(^PRCA(433,""C"",IBA,IBA1))) Q:'IBA1  D  I IBSH1=""M"",DAT Q"
^XMB(3.9,145944,2,727,0)="""RTN"",""IBJDF41"",236,0)"
^XMB(3.9,145944,2,728,0)=" . S IBC=$G(^PRCA(433,IBA1,1)) Q:'IBC"
^XMB(3.9,145944,2,729,0)="""RTN"",""IBJDF41"",237,0)"
^XMB(3.9,145944,2,730,0)=" . I $G(IBSH2),$$FMDIFF^XLFDT(DT,+IBC)>IBSH2 Q  ; Comment age not minimum."
^XMB(3.9,145944,2,731,0)="""RTN"",""IBJDF41"",238,0)"
^XMB(3.9,145944,2,732,0)=" . I $P(IBC,U,2)'=35,$P(IBC,U,2)'=45 Q  ;   Not decrease/comment transact."
^XMB(3.9,145944,2,733,0)="""RTN"",""IBJDF41"",239,0)"
^XMB(3.9,145944,2,734,0)=" . S DAT=$S(IBC:+IBC\1,1:+$P(IBC,U,9)\1)"
^XMB(3.9,145944,2,735,0)="""RTN"",""IBJDF41"",240,0)"
^XMB(3.9,145944,2,736,0)=" . I $G(IBEXCEL),IBSH1=""M"" S IBEXCEL1=IBEXCEL1_$$DT^IBJD(DAT,1) Q"
^XMB(3.9,145944,2,737,0)="""RTN"",""IBJDF41"",241,0)"
^XMB(3.9,145944,2,738,0)=" . ;"
^XMB(3.9,145944,2,739,0)="""RTN"",""IBJDF41"",242,0)"
^XMB(3.9,145944,2,740,0)=" . ; - Append brief and transaction comments."
^XMB(3.9,145944,2,741,0)="""RTN"",""IBJDF41"",243,0)"
^XMB(3.9,145944,2,742,0)=" . K COM,COM1 S COM(0)=DAT,X1=0"
^XMB(3.9,145944,2,743,0)="""RTN"",""IBJDF41"",244,0)"
^XMB(3.9,145944,2,744,0)=" . S COM1(1)=$P($G(^PRCA(433,IBA1,5)),U,2)"
^XMB(3.9,145944,2,745,0)="""RTN"",""IBJDF41"",245,0)"
^XMB(3.9,145944,2,746,0)=" . S COM1(2)=$E($P($G(^PRCA(433,IBA1,8)),U,6),1,70)"
^XMB(3.9,145944,2,747,0)="""RTN"",""IBJDF41"",246,0)"
^XMB(3.9,145944,2,748,0)=" . S COM(1)=COM1(1)_$S(COM1(1)]""""&(COM1(2)]""""):""|"",1:"""")_COM1(2)"
^XMB(3.9,145944,2,749,0)="""RTN"",""IBJDF41"",247,0)"
^XMB(3.9,145944,2,750,0)=" . I COM(1)]"""" S COM(1)=""**""_COM(1)_""**"",X1=1"
^XMB(3.9,145944,2,751,0)="""RTN"",""IBJDF41"",248,0)"
^XMB(3.9,145944,2,752,0)=" . ;"
^XMB(3.9,145944,2,753,0)="""RTN"",""IBJDF41"",249,0)"
^XMB(3.9,145944,2,754,0)=" . ; - Get main comments."
^XMB(3.9,145944,2,755,0)="""RTN"",""IBJDF41"",250,0)"
^XMB(3.9,145944,2,756,0)=" . S X2=0"
^XMB(3.9,145944,2,757,0)="""RTN"",""IBJDF41"",251,0)"
^XMB(3.9,145944,2,758,0)=" . F  S X2=$O(^PRCA(433,IBA1,7,X2)) Q:'X2  D"
^XMB(3.9,145944,2,759,0)="""RTN"",""IBJDF41"",252,0)"
^XMB(3.9,145944,2,760,0)=" . . S COM($S(X1:X2+1,1:X2))=^PRCA(433,IBA1,7,X2,0)"
^XMB(3.9,145944,2,761,0)="""RTN"",""IBJDF41"",253,0)"
^XMB(3.9,145944,2,762,0)=" . ;"
^XMB(3.9,145944,2,763,0)="""RTN"",""IBJDF41"",254,0)"
^XMB(3.9,145944,2,764,0)=" . I $G(IBEXCEL) Q"
^XMB(3.9,145944,2,765,0)="""RTN"",""IBJDF41"",255,0)"
^XMB(3.9,145944,2,766,0)=" . ;"
^XMB(3.9,145944,2,767,0)="""RTN"",""IBJDF41"",256,0)"
^XMB(3.9,145944,2,768,0)=" . S IBFLG=1,^TMP(""IBJDF4"",$J,IBPAT,0,""C"",IB0,IBIDX,IBA1)=$G(COM(0)),X1=0"
^XMB(3.9,145944,2,769,0)="""RTN"",""IBJDF41"",257,0)"
^XMB(3.9,145944,2,770,0)=" . F  S X1=$O(COM(X1)) Q:X1=""""  D"
^XMB(3.9,145944,2,771,0)="""RTN"",""IBJDF41"",258,0)"
^XMB(3.9,145944,2,772,0)=" . . S ^TMP(""IBJDF4"",$J,IBPAT,0,""C"",IB0,IBIDX,IBA1,X1)=COM(X1)"
^XMB(3.9,145944,2,773,0)="""RTN"",""IBJDF41"",259,0)"
^XMB(3.9,145944,2,774,0)=" ;"
^XMB(3.9,145944,2,775,0)="""RTN"",""IBJDF41"",260,0)"
^XMB(3.9,145944,2,776,0)=" I '$G(IBEXCEL),IBFLG D"
^XMB(3.9,145944,2,777,0)="""RTN"",""IBJDF41"",261,0)"
^XMB(3.9,145944,2,778,0)=" . S $P(^TMP(""IBJDF4"",$J,IBPAT,IB0,IBCAT,IBBN),""^"",6)=IBIDX"
^XMB(3.9,145944,2,779,0)="""RTN"",""IBJDF41"",262,0)"
^XMB(3.9,145944,2,780,0)=" Q"
^XMB(3.9,145944,2,781,0)="""RTN"",""IBJDF41"",263,0)"
^XMB(3.9,145944,2,782,0)=" ; IB*2.0*451 -  Use Event Date to find an associated 3rd Party bill with an associated EEOB"
^XMB(3.9,145944,2,783,0)="""RTN"",""IBJDF41"",264,0)"
^XMB(3.9,145944,2,784,0)="IBEEOBCK(IBBN,DFN) ; Passed AR Bill, Patient ID"
^XMB(3.9,145944,2,785,0)="""RTN"",""IBJDF41"",265,0)"
^XMB(3.9,145944,2,786,0)=" ; Function will quit as soon as a 3rd party bill is located that has an associated EEOB"
^XMB(3.9,145944,2,787,0)="""RTN"",""IBJDF41"",266,0)"
^XMB(3.9,145944,2,788,0)=" ;"
^XMB(3.9,145944,2,789,0)="""RTN"",""IBJDF41"",267,0)"
^XMB(3.9,145944,2,790,0)=" ; Find 3rd Party Bills with an Event Date"
^XMB(3.9,145944,2,791,0)="""RTN"",""IBJDF41"",268,0)"
^XMB(3.9,145944,2,792,0)=" N IBREF,IBEEOB,IBDT"
^XMB(3.9,145944,2,793,0)="""RTN"",""IBJDF41"",269,0)"
^XMB(3.9,145944,2,794,0)=" S IBEEOB="""""
^XMB(3.9,145944,2,795,0)="""RTN"",""IBJDF41"",270,0)"
^XMB(3.9,145944,2,796,0)=" ; Loop through Xref of ARbill (#430) to Action file (#350)"
^XMB(3.9,145944,2,797,0)="""RTN"",""IBJDF41"",271,0)"
^XMB(3.9,145944,2,798,0)=" I +$G(IBBN) S IBREF=0 F  S IBREF=$O(^IB(""ABIL"",IBBN,IBREF)) Q:'IBREF  D  Q:IBEEOB=""%"""
^XMB(3.9,145944,2,799,0)="""RTN"",""IBJDF41"",272,0)"
^XMB(3.9,145944,2,800,0)=" . S IBDT=$P($G(^IB(IBREF,0)),""^"",17) ;Get event Date"
^XMB(3.9,145944,2,801,0)="""RTN"",""IBJDF41"",273,0)"
^XMB(3.9,145944,2,802,0)=" . I IBDT S IBEEOB=$$TPEVDT(DFN,IBDT)"
^XMB(3.9,145944,2,803,0)="""RTN"",""IBJDF41"",274,0)"
^XMB(3.9,145944,2,804,0)=" . I IBDT S IBEEOB=$$TPOPV(DFN,IBDT)"
^XMB(3.9,145944,2,805,0)="""RTN"",""IBJDF41"",275,0)"
^XMB(3.9,145944,2,806,0)=" ;"
^XMB(3.9,145944,2,807,0)="""RTN"",""IBJDF41"",276,0)"
^XMB(3.9,145944,2,808,0)=" Q IBEEOB"
^XMB(3.9,145944,2,809,0)="""RTN"",""IBJDF41"",277,0)"
^XMB(3.9,145944,2,810,0)=" ;"
^XMB(3.9,145944,2,811,0)="""RTN"",""IBJDF41"",278,0)"
^XMB(3.9,145944,2,812,0)=" ; IB*2.0*451 - Traverse all THIRD PARTY bills for a patient with a specific Event Date (399,.03)"
^XMB(3.9,145944,2,813,0)="""RTN"",""IBJDF41"",279,0)"
^XMB(3.9,145944,2,814,0)="TPEVDT(DFN,EVDT) ;"
^XMB(3.9,145944,2,815,0)="""RTN"",""IBJDF41"",280,0)"
^XMB(3.9,145944,2,816,0)=" ; Function will quit as soon as a 3rd party bill is located that has an associated EEOB"
^XMB(3.9,145944,2,817,0)="""RTN"",""IBJDF41"",281,0)"
^XMB(3.9,145944,2,818,0)=" ; IB*2.0*473 - Use the 399,""APDT"" (by patient) index instead of the 399,""D"" index for efficiency"
^XMB(3.9,145944,2,819,0)="""RTN"",""IBJDF41"",282,0)"
^XMB(3.9,145944,2,820,0)=" I '$G(DFN)!'$G(EVDT) Q """""
^XMB(3.9,145944,2,821,0)="""RTN"",""IBJDF41"",283,0)"
^XMB(3.9,145944,2,822,0)=" N IBIFN,IBEEOB"
^XMB(3.9,145944,2,823,0)="""RTN"",""IBJDF41"",284,0)"
^XMB(3.9,145944,2,824,0)=" S IBEEOB="""",IBIFN="""""
^XMB(3.9,145944,2,825,0)="""RTN"",""IBJDF41"",285,0)"
^XMB(3.9,145944,2,826,0)=" F  S IBIFN=$O(^DGCR(399,""APDT"",DFN,IBIFN),-1) Q:'IBIFN  D  Q:IBEEOB=""%"""
^XMB(3.9,145944,2,827,0)="""RTN"",""IBJDF41"",286,0)"
^XMB(3.9,145944,2,828,0)=" . I $D(^DGCR(399,""APDT"",DFN,IBIFN,9999999-EVDT)) S IBEEOB=$$EEOBCK(IBIFN)"
^XMB(3.9,145944,2,829,0)="""RTN"",""IBJDF41"",287,0)"
^XMB(3.9,145944,2,830,0)=" Q IBEEOB"
^XMB(3.9,145944,2,831,0)="""RTN"",""IBJDF41"",288,0)"
^XMB(3.9,145944,2,832,0)=" ; "
^XMB(3.9,145944,2,833,0)="""RTN"",""IBJDF41"",289,0)"
^XMB(3.9,145944,2,834,0)=" ; IB*2.0*451 - Traverse all THIRD PARTY bills for a patient with any Opt Visit Dates same as Event Date (399,43)"
^XMB(3.9,145944,2,835,0)="""RTN"",""IBJDF41"",290,0)"
^XMB(3.9,145944,2,836,0)="TPOPV(DFN,EVDT) ;"
^XMB(3.9,145944,2,837,0)="""RTN"",""IBJDF41"",291,0)"
^XMB(3.9,145944,2,838,0)=" ; Function will quit as soon as a 3rd party bill is located that has an associated EEOB"
^XMB(3.9,145944,2,839,0)="""RTN"",""IBJDF41"",292,0)"
^XMB(3.9,145944,2,840,0)=" N IBIFN,IBEEOB"
^XMB(3.9,145944,2,841,0)="""RTN"",""IBJDF41"",293,0)"
^XMB(3.9,145944,2,842,0)=" S IBEEOB="""""
^XMB(3.9,145944,2,843,0)="""RTN"",""IBJDF41"",294,0)"
^XMB(3.9,145944,2,844,0)=" I +$G(DFN),+$G(EVDT) S IBIFN=0 F  S IBIFN=$O(^DGCR(399,""AOPV"",DFN,EVDT,IBIFN)) Q:'IBIFN  D  Q:IBEEOB=""%"""
^XMB(3.9,145944,2,845,0)="""RTN"",""IBJDF41"",295,0)"
^XMB(3.9,145944,2,846,0)=" . ; attach EOB indicator '%' to bill # when applicable"
^XMB(3.9,145944,2,847,0)="""RTN"",""IBJDF41"",296,0)"
^XMB(3.9,145944,2,848,0)=" . S IBEEOB=$$EEOBCK(IBIFN)"
^XMB(3.9,145944,2,849,0)="""RTN"",""IBJDF41"",297,0)"
^XMB(3.9,145944,2,850,0)=" Q IBEEOB"
^XMB(3.9,145944,2,851,0)="""RTN"",""IBJDF41"",298,0)"
^XMB(3.9,145944,2,852,0)=" ;"
^XMB(3.9,145944,2,853,0)="""RTN"",""IBJDF41"",299,0)"
^XMB(3.9,145944,2,854,0)=" ; IB*2.0*451 - Check for EEOB indicator"
^XMB(3.9,145944,2,855,0)="""RTN"",""IBJDF41"",300,0)"
^XMB(3.9,145944,2,856,0)="EEOBCK(IBBILL)  ;"
^XMB(3.9,145944,2,857,0)="""RTN"",""IBJDF41"",301,0)"
^XMB(3.9,145944,2,858,0)=" ; Check for 1st and 3rd party payment activity on bill"
^XMB(3.9,145944,2,859,0)="""RTN"",""IBJDF41"",302,0)"
^XMB(3.9,145944,2,860,0)=" ; IBBILL is the IEN for the bill # in files #399/#430 and must be valid,"
^XMB(3.9,145944,2,861,0)="""RTN"",""IBJDF41"",303,0)"
^XMB(3.9,145944,2,862,0)=" ; check the EOB type and exclude it if it is an MRA. Otherwise,"
^XMB(3.9,145944,2,863,0)="""RTN"",""IBJDF41"",304,0)"
^XMB(3.9,145944,2,864,0)=" ; returns the EEOB indicator '%' if payment activity was found."
^XMB(3.9,145944,2,865,0)="""RTN"",""IBJDF41"",305,0)"
^XMB(3.9,145944,2,866,0)=" ; Access to file #361.1 covered by IA #4051."
^XMB(3.9,145944,2,867,0)="""RTN"",""IBJDF41"",306,0)"
^XMB(3.9,145944,2,868,0)=" ; Access to file #399 covered by IA #3820."
^XMB(3.9,145944,2,869,0)="""RTN"",""IBJDF41"",307,0)"
^XMB(3.9,145944,2,870,0)=" N IBOUT,IBVAL,Z"
^XMB(3.9,145944,2,871,0)="""RTN"",""IBJDF41"",308,0)"
^XMB(3.9,145944,2,872,0)=" I $G(IBBILL)=0 Q """""
^XMB(3.9,145944,2,873,0)="""RTN"",""IBJDF41"",309,0)"
^XMB(3.9,145944,2,874,0)=" I '$O(^IBM(361.1,""B"",IBBILL,0)) Q """"  ; no entry here"
^XMB(3.9,145944,2,875,0)="""RTN"",""IBJDF41"",310,0)"
^XMB(3.9,145944,2,876,0)=" I $P($G(^DGCR(399,IBBILL,0)),""^"",13)=1 Q """"  ;avoid 'ENTERED/NOT REVIEWED' status"
^XMB(3.9,145944,2,877,0)="""RTN"",""IBJDF41"",311,0)"
^XMB(3.9,145944,2,878,0)=" ; handle both single and multiple bill entries in file #361.1"
^XMB(3.9,145944,2,879,0)="""RTN"",""IBJDF41"",312,0)"
^XMB(3.9,145944,2,880,0)=" S Z=0 F  S Z=$O(^IBM(361.1,""B"",IBBILL,Z)) Q:'Z  D  Q:$G(IBOUT)=""%"""
^XMB(3.9,145944,2,881,0)="""RTN"",""IBJDF41"",313,0)"
^XMB(3.9,145944,2,882,0)=" . S IBVAL=$G(^IBM(361.1,Z,0))"
^XMB(3.9,145944,2,883,0)="""RTN"",""IBJDF41"",314,0)"
^XMB(3.9,145944,2,884,0)=" . S IBOUT=$S($P(IBVAL,""^"",4)=1:"""",$P(IBVAL,""^"",4)=0:""%"",1:"""")"
^XMB(3.9,145944,2,885,0)="""RTN"",""IBJDF41"",315,0)"
^XMB(3.9,145944,2,886,0)=" Q IBOUT  ; EOB indicator for either 1st or 3rd party payment on bill"
^XMB(3.9,145944,2,887,0)="""RTN"",""IBJDF41"",316,0)"
^XMB(3.9,145944,2,888,0)=" ;"
^XMB(3.9,145944,2,889,0)="""RTN"",""IBJDF41"",317,0)"
^XMB(3.9,145944,2,890,0)=" ;"
^XMB(3.9,145944,2,891,0)="""RTN"",""IBJDF41"",318,0)"
^XMB(3.9,145944,2,892,0)="SUST(IBA) ;Look for suspended type for a suspended bill IB*2*568/DRF"
^XMB(3.9,145944,2,893,0)="""RTN"",""IBJDF41"",319,0)"
^XMB(3.9,145944,2,894,0)=" N TRANS,ST,STIEN"
^XMB(3.9,145944,2,895,0)="""RTN"",""IBJDF41"",320,0)"
^XMB(3.9,145944,2,896,0)=" S IBA=$G(IBA) I IBA="""" Q """""
^XMB(3.9,145944,2,897,0)="""RTN"",""IBJDF41"",321,0)"
^XMB(3.9,145944,2,898,0)=" S ST="""""
^XMB(3.9,145944,2,899,0)="""RTN"",""IBJDF41"",322,0)"
^XMB(3.9,145944,2,900,0)=" ; IB*2.0*715"
^XMB(3.9,145944,2,901,0)="""RTN"",""IBJDF41"",323,0)"
^XMB(3.9,145944,2,902,0)=" S TRANS="""" F  S TRANS=$O(^PRCA(433,""C"",IBA,TRANS),-1) Q:'TRANS  Q:$$GET1^DIQ(433,TRANS_"","",12)=""CHARGE SUSPENDED"""
^XMB(3.9,145944,2,903,0)="""RTN"",""IBJDF41"",324,0)"
^XMB(3.9,145944,2,904,0)=" I TRANS>0 S STIEN=$P($G(^PRCA(433,TRANS,1)),U,12) S:STIEN ST=$$GET1^DIQ(433.001,STIEN_"","",.01)"
^XMB(3.9,145944,2,905,0)="""RTN"",""IBJDF41"",325,0)"
^XMB(3.9,145944,2,906,0)=" I ST="""" S ST=$P($G(^PRCA(433,TRANS,1)),U,11)  ; if no type, try to get it from the old field 433/90"
^XMB(3.9,145944,2,907,0)="""RTN"",""IBJDF41"",326,0)"
^XMB(3.9,145944,2,908,0)=" I ST="""" S ST=14  ; if still no type, set it to NONE"
^XMB(3.9,145944,2,909,0)="""RTN"",""IBJDF41"",327,0)"
^XMB(3.9,145944,2,910,0)=" ;"
^XMB(3.9,145944,2,911,0)="""RTN"",""IBJDF41"",328,0)"
^XMB(3.9,145944,2,912,0)=" Q ST"
^XMB(3.9,145944,2,913,0)="""RTN"",""IBJDF41"",329,0)"
^XMB(3.9,145944,2,914,0)=" ;"
^XMB(3.9,145944,2,915,0)="""RTN"",""IBJDF41"",330,0)"
^XMB(3.9,145944,2,916,0)=" ;"
^XMB(3.9,145944,2,917,0)="""RTN"",""IBJDF41"",331,0)"
^XMB(3.9,145944,2,918,0)="ABBR(SUSP) ;Return abbreviation for suspended bill types IB*2*568/DRF"
^XMB(3.9,145944,2,919,0)="""RTN"",""IBJDF41"",332,0)"
^XMB(3.9,145944,2,920,0)=" S SUSP=$G(SUSP)"
^XMB(3.9,145944,2,921,0)="""RTN"",""IBJDF41"",333,0)"
^XMB(3.9,145944,2,922,0)=" I SUSP=0 Q ""NonCoS"""
^XMB(3.9,145944,2,923,0)="""RTN"",""IBJDF41"",334,0)"
^XMB(3.9,145944,2,924,0)=" I SUSP=1 Q ""IniCoS"""
^XMB(3.9,145944,2,925,0)="""RTN"",""IBJDF41"",335,0)"
^XMB(3.9,145944,2,926,0)=" I SUSP=2 Q ""AplCoW"""
^XMB(3.9,145944,2,927,0)="""RTN"",""IBJDF41"",336,0)"
^XMB(3.9,145944,2,928,0)=" I SUSP=3 Q ""AdminS"""
^XMB(3.9,145944,2,929,0)="""RTN"",""IBJDF41"",337,0)"
^XMB(3.9,145944,2,930,0)=" I SUSP=4 Q ""Compro"""
^XMB(3.9,145944,2,931,0)="""RTN"",""IBJDF41"",338,0)"
^XMB(3.9,145944,2,932,0)=" I SUSP=5 Q ""Termin"""
^XMB(3.9,145944,2,933,0)="""RTN"",""IBJDF41"",339,0)"
^XMB(3.9,145944,2,934,0)=" I SUSP=6 Q ""BnkCh7"""
^XMB(3.9,145944,2,935,0)="""RTN"",""IBJDF41"",340,0)"
^XMB(3.9,145944,2,936,0)=" I SUSP=7 Q ""BnkC13"""
^XMB(3.9,145944,2,937,0)="""RTN"",""IBJDF41"",341,0)"
^XMB(3.9,145944,2,938,0)=" I SUSP=8 Q ""BnkOth"""
^XMB(3.9,145944,2,939,0)="""RTN"",""IBJDF41"",342,0)"
^XMB(3.9,145944,2,940,0)=" I SUSP=9 Q ""Probat"""
^XMB(3.9,145944,2,941,0)="""RTN"",""IBJDF41"",343,0)"
^XMB(3.9,145944,2,942,0)=" I SUSP=10 Q ""Choice"""
^XMB(3.9,145944,2,943,0)="""RTN"",""IBJDF41"",344,0)"
^XMB(3.9,145944,2,944,0)=" I SUSP=11 Q ""Disput"""
^XMB(3.9,145944,2,945,0)="""RTN"",""IBJDF41"",345,0)"
^XMB(3.9,145944,2,946,0)=" ; IB*2.0*715"
^XMB(3.9,145944,2,947,0)="""RTN"",""IBJDF41"",346,0)"
^XMB(3.9,145944,2,948,0)=" I SUSP=12 Q ""IndAtt"""
^XMB(3.9,145944,2,949,0)="""RTN"",""IBJDF41"",347,0)"
^XMB(3.9,145944,2,950,0)=" I SUSP=13 Q ""Compct"""
^XMB(3.9,145944,2,951,0)="""RTN"",""IBJDF41"",348,0)"
^XMB(3.9,145944,2,952,0)=" I SUSP=14 Q ""None"""
^XMB(3.9,145944,2,953,0)="""RTN"",""IBJDF41"",349,0)"
^XMB(3.9,145944,2,954,0)=" ;"
^XMB(3.9,145944,2,955,0)="""RTN"",""IBJDF41"",350,0)"
^XMB(3.9,145944,2,956,0)=" Q """""
^XMB(3.9,145944,2,957,0)="""RTN"",""IBJDF41"",351,0)"
^XMB(3.9,145944,2,958,0)=" ;"
^XMB(3.9,145944,2,959,0)="""RTN"",""IBJDF41"",352,0)"
^XMB(3.9,145944,2,960,0)="REPDATA(RPIEN,DAYS) ; - Return Repayment Plan information IB*2.0*694"
^XMB(3.9,145944,2,961,0)="""RTN"",""IBJDF41"",353,0)"
^XMB(3.9,145944,2,962,0)=" ;"
^XMB(3.9,145944,2,963,0)="""RTN"",""IBJDF41"",354,0)"
^XMB(3.9,145944,2,964,0)=" ; RPIEN - file 340.5 ien"
^XMB(3.9,145944,2,965,0)="""RTN"",""IBJDF41"",355,0)"
^XMB(3.9,145944,2,966,0)=" ; DAYS  - Number of days over the due date for a payment not "
^XMB(3.9,145944,2,967,0)="""RTN"",""IBJDF41"",356,0)"
^XMB(3.9,145944,2,968,0)=" ;         received to be considered defaulted."
^XMB(3.9,145944,2,969,0)="""RTN"",""IBJDF41"",357,0)"
^XMB(3.9,145944,2,970,0)=" ;"
^XMB(3.9,145944,2,971,0)="""RTN"",""IBJDF41"",358,0)"
^XMB(3.9,145944,2,972,0)=" ; Output: String with the following ""^"" (up-arrow) pieces:"
^XMB(3.9,145944,2,973,0)="""RTN"",""IBJDF41"",359,0)"
^XMB(3.9,145944,2,974,0)=" ;              1. Repayment Plan Start Date (FM Format)"
^XMB(3.9,145944,2,975,0)="""RTN"",""IBJDF41"",360,0)"
^XMB(3.9,145944,2,976,0)=" ;              2. Balance (Repayment Plan)"
^XMB(3.9,145944,2,977,0)="""RTN"",""IBJDF41"",361,0)"
^XMB(3.9,145944,2,978,0)=" ;              3. Monthly Payment Amount"
^XMB(3.9,145944,2,979,0)="""RTN"",""IBJDF41"",362,0)"
^XMB(3.9,145944,2,980,0)=" ;              4. Due Date (day of the month)"
^XMB(3.9,145944,2,981,0)="""RTN"",""IBJDF41"",363,0)"
^XMB(3.9,145944,2,982,0)=" ;              5. Last Payment Date"
^XMB(3.9,145944,2,983,0)="""RTN"",""IBJDF41"",364,0)"
^XMB(3.9,145944,2,984,0)=" ;              6. Last Payment Amount"
^XMB(3.9,145944,2,985,0)="""RTN"",""IBJDF41"",365,0)"
^XMB(3.9,145944,2,986,0)=" ;              7. Number of Payments Due"
^XMB(3.9,145944,2,987,0)="""RTN"",""IBJDF41"",366,0)"
^XMB(3.9,145944,2,988,0)=" ;              8. Number of Payments Defaulted"
^XMB(3.9,145944,2,989,0)="""RTN"",""IBJDF41"",367,0)"
^XMB(3.9,145944,2,990,0)=" ;              9. Plan status (internal)"
^XMB(3.9,145944,2,991,0)="""RTN"",""IBJDF41"",368,0)"
^XMB(3.9,145944,2,992,0)=" ;         or NULL if either no RPP data was found or plan was paid in full"
^XMB(3.9,145944,2,993,0)="""RTN"",""IBJDF41"",369,0)"
^XMB(3.9,145944,2,994,0)=" ;"
^XMB(3.9,145944,2,995,0)="""RTN"",""IBJDF41"",370,0)"
^XMB(3.9,145944,2,996,0)=" N DATA,IENS,LPAMT,LPDT,PDEF,PDUE,RES,STATUS,TMPDT,Z"
^XMB(3.9,145944,2,997,0)="""RTN"",""IBJDF41"",371,0)"
^XMB(3.9,145944,2,998,0)=" S RES="""",IENS=RPIEN_"","""
^XMB(3.9,145944,2,999,0)="""RTN"",""IBJDF41"",372,0)"
^XMB(3.9,145944,2,1000,0)=" D GETS^DIQ(340.5,IENS,"".04;.06;.07;.11;2*;3*"",""I"",""DATA"") I '$D(DATA) Q RES"
^XMB(3.9,145944,2,1001,0)="""RTN"",""IBJDF41"",373,0)"
^XMB(3.9,145944,2,1002,0)=" S RES=$G(DATA(340.5,IENS,.04,""I""))          ; start date - 340.5/.04"
^XMB(3.9,145944,2,1003,0)="""RTN"",""IBJDF41"",374,0)"
^XMB(3.9,145944,2,1004,0)=" S $P(RES,U,2)=$G(DATA(340.5,IENS,.11,""I""))  ; amount owed - 340.5/.11"
^XMB(3.9,145944,2,1005,0)="""RTN"",""IBJDF41"",375,0)"
^XMB(3.9,145944,2,1006,0)=" S $P(RES,U,3)=$G(DATA(340.5,IENS,.06,""I""))  ; monthly amount - 340.5/.06"
^XMB(3.9,145944,2,1007,0)="""RTN"",""IBJDF41"",376,0)"
^XMB(3.9,145944,2,1008,0)=" S STATUS=$G(DATA(340.5,IENS,.07,""I""))       ; plan status - 340.5/.07"
^XMB(3.9,145944,2,1009,0)="""RTN"",""IBJDF41"",377,0)"
^XMB(3.9,145944,2,1010,0)=" S $P(RES,U,4)=28                            ; due date"
^XMB(3.9,145944,2,1011,0)="""RTN"",""IBJDF41"",378,0)"
^XMB(3.9,145944,2,1012,0)=" S (LPAMT,LPDT)=0,Z="""" F  S Z=$O(DATA(340.53,Z)) Q:Z=""""  S TMPDT=+$G(DATA(340.53,Z,.01,""I"")) S:TMPDT>LPDT LPDT=TMPDT,LPAMT=+$G(DATA(340.53,Z,1,""I""))"
^XMB(3.9,145944,2,1013,0)="""RTN"",""IBJDF41"",379,0)"
^XMB(3.9,145944,2,1014,0)=" I LPDT>0 S $P(RES,U,5)=LPDT,$P(RES,U,6)=LPAMT  ; last payment date & amount"
^XMB(3.9,145944,2,1015,0)="""RTN"",""IBJDF41"",380,0)"
^XMB(3.9,145944,2,1016,0)=" S (PDEF,PDUE)=0,Z="""" F  S Z=$O(DATA(340.52,Z)) Q:Z=""""  D"
^XMB(3.9,145944,2,1017,0)="""RTN"",""IBJDF41"",381,0)"
^XMB(3.9,145944,2,1018,0)=" .I +$G(DATA(340.52,Z,1,""I""))=1 Q  ; payment was made"
^XMB(3.9,145944,2,1019,0)="""RTN"",""IBJDF41"",382,0)"
^XMB(3.9,145944,2,1020,0)=" .S PDUE=PDUE+1  ; inc. # of payments due"
^XMB(3.9,145944,2,1021,0)="""RTN"",""IBJDF41"",383,0)"
^XMB(3.9,145944,2,1022,0)=" .I +$G(DATA(340.52,Z,2,""I""))=1 Q  ; payment forborne"
^XMB(3.9,145944,2,1023,0)="""RTN"",""IBJDF41"",384,0)"
^XMB(3.9,145944,2,1024,0)=" .I $$FMDIFF^XLFDT(DT,+$G(DATA(340.52,Z,.01,""I"")))'<DAYS S PDEF=PDEF+1  ; inc. # of defaulted payments"
^XMB(3.9,145944,2,1025,0)="""RTN"",""IBJDF41"",385,0)"
^XMB(3.9,145944,2,1026,0)=" .Q"
^XMB(3.9,145944,2,1027,0)="""RTN"",""IBJDF41"",386,0)"
^XMB(3.9,145944,2,1028,0)=" I PDUE=0 Q """"  ; plan was paid in full"
^XMB(3.9,145944,2,1029,0)="""RTN"",""IBJDF41"",387,0)"
^XMB(3.9,145944,2,1030,0)=" S $P(RES,U,7)=PDUE,$P(RES,U,8)=PDEF,$P(RES,U,9)=STATUS  ; #of payments due, # of defaulted payments, & plan status"
^XMB(3.9,145944,2,1031,0)="""RTN"",""IBJDF41"",388,0)"
^XMB(3.9,145944,2,1032,0)=" Q RES"
