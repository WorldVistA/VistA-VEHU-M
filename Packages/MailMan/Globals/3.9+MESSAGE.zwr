^XMB(3.9,145986,2,1910,0)=" F FBM=FBBEG-.1:0 S FBM=$O(^FBAAI(""AF"",IFN,FBM)) Q:FBM'>0!(FBM>FBEND)  F FBI=0:0 S FBI=$O(^FBAAI(""AF"",IFN,FBM,FBI)) Q:FBI'>0!(FBAAOUT)  I $D(^FBAAI(FBI,0)),$P(^(0),""^"",12)=FBPROG,'$D(^(""FBREJ"")) D GETINV"
^XMB(3.9,145986,2,1911,0)="""RTN"",""FBCHVH"",10,0)"
^XMB(3.9,145986,2,1912,0)=" G:$D(FBAANQ) GETVEN"
^XMB(3.9,145986,2,1913,0)="""RTN"",""FBCHVH"",11,0)"
^XMB(3.9,145986,2,1914,0)="END K DA,BEGDATE,ENDDATE,FBBEG,FBEND,DIC,FBAANQ,FBAAOUT,FBDX,FBI,FBIN,FBPROC,FBVEN,FBVID,IFN,J,K,L,PGM,Q,VADM,VAERR,VAL,VAR,X,Y,VA,ZZ,FBM,FBHEAD,FBPROG,FBPG,FBVINDT"
^XMB(3.9,145986,2,1915,0)="""RTN"",""FBCHVH"",12,0)"
