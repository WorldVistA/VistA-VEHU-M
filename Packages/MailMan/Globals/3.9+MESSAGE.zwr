^XMB(3.9,145950,2,235,0)="""RTN"",""PSAVERA"")"
^XMB(3.9,145950,2,236,0)="0^1^B75199708"
^XMB(3.9,145950,2,237,0)="""RTN"",""PSAVERA"",1,0)"
^XMB(3.9,145950,2,238,0)="PSAVERA ;BHM/DBM - Change verified invoice data;16AUG05"
^XMB(3.9,145950,2,239,0)="""RTN"",""PSAVERA"",2,0)"
^XMB(3.9,145950,2,240,0)=" ;;3.0;DRUG ACCOUNTABILITY/INVENTORY INTERFACE;**21,36,40,53,63,70,80**; 10/24/97;Build 0"
^XMB(3.9,145950,2,241,0)="""RTN"",""PSAVERA"",3,0)"
^XMB(3.9,145950,2,242,0)=" ;"
^XMB(3.9,145950,2,243,0)="""RTN"",""PSAVERA"",4,0)"
^XMB(3.9,145950,2,244,0)=" ;References to ^DIC(51.5 are covered by IA #1931"
^XMB(3.9,145950,2,245,0)="""RTN"",""PSAVERA"",5,0)"
^XMB(3.9,145950,2,246,0)=" ;References to ^PSDRUG( are covered by IA #2095"
^XMB(3.9,145950,2,247,0)="""RTN"",""PSAVERA"",6,0)"
^XMB(3.9,145950,2,248,0)=" D Q"
^XMB(3.9,145950,2,249,0)="""RTN"",""PSAVERA"",7,0)"
^XMB(3.9,145950,2,250,0)=" D HOME^%ZIS S XX=""VERIFIED INVOICE ALTERATION SCREEN"" W @IOF,!!,?((IOM/2)-($L(XX)/2)),XX,!!"
^XMB(3.9,145950,2,251,0)="""RTN"",""PSAVERA"",8,0)"
^XMB(3.9,145950,2,252,0)="ORDR ;Get Order Number"
^XMB(3.9,145950,2,253,0)="""RTN"",""PSAVERA"",9,0)"
^XMB(3.9,145950,2,254,0)=" S DIC(0)=""AEQMZ"",DIC(""A"")=""Select Order Number: "",DIC=""^PSD(58.811,"" D ^DIC K DIC G Q:+Y'>0 S PSAIEN=+Y,PSAORD=$P(Y,U,2)"
^XMB(3.9,145950,2,255,0)="""RTN"",""PSAVERA"",10,0)"
^XMB(3.9,145950,2,256,0)=" ;"
^XMB(3.9,145950,2,257,0)="""RTN"",""PSAVERA"",11,0)"
^XMB(3.9,145950,2,258,0)="INV ;Get Invoice Number"
^XMB(3.9,145950,2,259,0)="""RTN"",""PSAVERA"",12,0)"
^XMB(3.9,145950,2,260,0)=" S DIC(0)=""AEQMZ"",DIC(""A"")=""Select Invoice Number: "",DIC=""^PSD(58.811,""_PSAIEN_"",1,"",D=""ASTAT"" D ^DIC K DIC G Q:+Y'>0 S PSAIEN1=+Y,PSAINV=$P(Y,U,2)"
^XMB(3.9,145950,2,261,0)="""RTN"",""PSAVERA"",13,0)"
^XMB(3.9,145950,2,262,0)=" S DATA=$G(^PSD(58.811,PSAIEN,1,PSAIEN1,0))"
^XMB(3.9,145950,2,263,0)="""RTN"",""PSAVERA"",14,0)"
^XMB(3.9,145950,2,264,0)=" S PSALOC=$S($P(DATA,""^"",12)'="""":$P(DATA,""^"",12),1:$P(DATA,""^"",5)) I $G(PSALOC)="""" S PSALOC=""No Location identified"""
^XMB(3.9,145950,2,265,0)="""RTN"",""PSAVERA"",15,0)"
^XMB(3.9,145950,2,266,0)=" D ^PSAVERA1"
^XMB(3.9,145950,2,267,0)="""RTN"",""PSAVERA"",16,0)"
^XMB(3.9,145950,2,268,0)=" K DATA,PSAITM,LINENUM,PSALIDAT,X,X1,X2,X3,DIC,DA,DR D HDR"
^XMB(3.9,145950,2,269,0)="""RTN"",""PSAVERA"",17,0)"
^XMB(3.9,145950,2,270,0)="DISP S PSAITM=$S('$D(PSAITM):$O(INVARRAY(PSAORD,PSAINV,0)),1:$O(INVARRAY(PSAORD,PSAINV,PSAITM))) G LINEASK:PSAITM'>0 S LINENUM=$G(LINENUM)+1"
^XMB(3.9,145950,2,271,0)="""RTN"",""PSAVERA"",18,0)"
^XMB(3.9,145950,2,272,0)=" S DATA=$G(INVARRAY(PSAORD,PSAINV,PSAITM)),PSAOU=$P(DATA,""^"",4) I $G(PSAOU) S PSAOU(1)=$P($G(^DIC(51.5,$P(DATA,""^"",4),0)),""^"") ;Current Order Unit  ;; <*63 RJS"
^XMB(3.9,145950,2,273,0)="""RTN"",""PSAVERA"",19,0)"
^XMB(3.9,145950,2,274,0)=" W !,PSAITM,?6,$S($P($P(DATA,""^"",1),""~"",1)'>0:$P($P(DATA,""^"",1),""~"",1),1:$P($P(DATA,""^"",1),""~"",2)),?45,$S($G(PSAOU)="""":""none"",$G(PSAOU(1))'="""":$G(PSAOU(1)),1:$G(PSAAOU)),?55,$J($P($G(DATA),""^"",2),4),?61,$P(DATA,""^"",5)  ;;<PSA*3*70 RJS"
^XMB(3.9,145950,2,275,0)="""RTN"",""PSAVERA"",20,0)"
^XMB(3.9,145950,2,276,0)=" I IOST[""C-"",$Y>(IOSL-5) S DIR(0)=""E"" D ^DIR G Q:$G(DUOUT)=1 D HDR"
^XMB(3.9,145950,2,277,0)="""RTN"",""PSAVERA"",21,0)"
^XMB(3.9,145950,2,278,0)=" G DISP"
^XMB(3.9,145950,2,279,0)="""RTN"",""PSAVERA"",22,0)"
^XMB(3.9,145950,2,280,0)="LINEASK ;ask for line number"
^XMB(3.9,145950,2,281,0)="""RTN"",""PSAVERA"",23,0)"
^XMB(3.9,145950,2,282,0)=" W !,""Enter the corresponding item number to edit: "" R AN:DTIME I AN[""^""!(AN="""") G Q"
^XMB(3.9,145950,2,283,0)="""RTN"",""PSAVERA"",24,0)"
^XMB(3.9,145950,2,284,0)=" I AN<1!(AN>LINENUM) W !,""Enter a number between 1 & "",LINENUM,! G LINEASK"
^XMB(3.9,145950,2,285,0)="""RTN"",""PSAVERA"",25,0)"
^XMB(3.9,145950,2,286,0)=" I ""?""[AN W !,""Select the number that corresponds to the line item that needs editing"",! K AN G LINEASK"
^XMB(3.9,145950,2,287,0)="""RTN"",""PSAVERA"",26,0)"
^XMB(3.9,145950,2,288,0)=" S DATA=$G(INVARRAY(PSAORD,PSAINV,AN))"
^XMB(3.9,145950,2,289,0)="""RTN"",""PSAVERA"",27,0)"
^XMB(3.9,145950,2,290,0)=" S PSALINE=AN,PSAIN=""NADA"" I '$D(^PSD(58.811,PSAIEN,1,PSAIEN1,1,PSALINE,0)) W !,""Invalid line selection."" G LINEASK"
^XMB(3.9,145950,2,291,0)="""RTN"",""PSAVERA"",28,0)"
^XMB(3.9,145950,2,292,0)=" S PSADATA=^PSD(58.811,PSAIEN,1,PSAIEN1,1,PSALINE,0),PSASUP=0"
^XMB(3.9,145950,2,293,0)="""RTN"",""PSAVERA"",29,0)"
^XMB(3.9,145950,2,294,0)=" S PSALIDAT=$G(^PSD(58.811,PSAIEN,1,PSAIEN1,0))"
^XMB(3.9,145950,2,295,0)="""RTN"",""PSAVERA"",30,0)"
^XMB(3.9,145950,2,296,0)=" S PSACS=0 S:+$P(PSADATA,""^"",10) PSACS=$G(PSACS)+1"
^XMB(3.9,145950,2,297,0)="""RTN"",""PSAVERA"",31,0)"
^XMB(3.9,145950,2,298,0)=" S PSANDC=$P(PSADATA,""^"",11)"
^XMB(3.9,145950,2,299,0)="""RTN"",""PSAVERA"",32,0)"
^XMB(3.9,145950,2,300,0)=" S PSALINEN="""" D VERDISP^PSAUTL4 W !,PSASLN,!"
^XMB(3.9,145950,2,301,0)="""RTN"",""PSAVERA"",33,0)"
^XMB(3.9,145950,2,302,0)=" S PSAVEND=$P(^PSD(58.811,PSAIEN,0),""^"",2)"
^XMB(3.9,145950,2,303,0)="""RTN"",""PSAVERA"",34,0)"
^XMB(3.9,145950,2,304,0)=" S PSAODUOU=PSADUOU"
^XMB(3.9,145950,2,305,0)="""RTN"",""PSAVERA"",35,0)"
^XMB(3.9,145950,2,306,0)=" ;; *63"
^XMB(3.9,145950,2,307,0)="""RTN"",""PSAVERA"",36,0)"
^XMB(3.9,145950,2,308,0)=" S PSA581="""" F  S PSA581=$O(^PSD(58.81,""PV"",PSAINV,PSA581)) Q:'PSA581  I $P(^PSD(58.81,PSA581,0),U,5)=PSADRG S PSABFR(581)=$G(^PSD(58.81,PSA581,0))"
^XMB(3.9,145950,2,309,0)="""RTN"",""PSAVERA"",37,0)"
^XMB(3.9,145950,2,310,0)=" S:$G(PSABFR(581)) PSDTRN=$P(PSABFR(581),U,1),PSABFR(""Q"")=$S($G(^PSD(58.81,PSDTRN,4)):$P(^PSD(58.81,PSDTRN,4),""^"",3),1:$P(^PSD(58.81,PSDTRN,0),""^"",6)) ; <*63 RJS >"
^XMB(3.9,145950,2,311,0)="""RTN"",""PSAVERA"",38,0)"
^XMB(3.9,145950,2,312,0)="DRG W !,""Select (D)rug or (O)rder Unit "" R AN:DTIME G Q:AN[""^""!(AN="""") W $S(""Dd""[AN:""rug"",""oO""[AN:""rder Unit"",1:""??"") I ""DdOo""'[AN W !,""Enter a 'D' to edit the Drug, or 'O' to edit the order unit"",! K AN G DRG"
^XMB(3.9,145950,2,313,0)="""RTN"",""PSAVERA"",39,0)"
^XMB(3.9,145950,2,314,0)=" I ""Dd""'[AN D ^PSAVERA3 G Q  ;;*63"
^XMB(3.9,145950,2,315,0)="""RTN"",""PSAVERA"",40,0)"
^XMB(3.9,145950,2,316,0)=" ;Get either new name of drug or supply item description"
^XMB(3.9,145950,2,317,0)="""RTN"",""PSAVERA"",41,0)"
^XMB(3.9,145950,2,318,0)=" S PSABFR=$P(DATA,""~"",1),PSABFR(1)=$S(PSABFR'?.N:PSABFR,1:$P($P(DATA,""^""),""~"",2)),PSABFR(""NDC"")=$P(PSADATA,""^"",11)  ;;*63"
^XMB(3.9,145950,2,319,0)="""RTN"",""PSAVERA"",42,0)"
^XMB(3.9,145950,2,320,0)="DRGAGN D"
^XMB(3.9,145950,2,321,0)="""RTN"",""PSAVERA"",43,0)"
^XMB(3.9,145950,2,322,0)=" .S X1=0 F  S X1=$O(^PSDRUG(PSABFR,1,X1)) Q:X1'>0  S DATA=$G(^PSDRUG(PSABFR,1,X1,0)) I $P(DATA,""^"",2)=PSABFR(""NDC"") S PSABFR(""SYNNODE"")=X1  ;;*63"
^XMB(3.9,145950,2,323,0)="""RTN"",""PSAVERA"",44,0)"
^XMB(3.9,145950,2,324,0)=" D PSANDC1^PSAHELP S PSADASH=PSANDCX K PSANDCX"
^XMB(3.9,145950,2,325,0)="""RTN"",""PSAVERA"",45,0)"
^XMB(3.9,145950,2,326,0)=" I $G(PSABFR(""SYNNODE""))="""",$E(PSABFR(""NDC""))'=""S"" S PSABFR(""NDC"")=""S""_PSABFR(""NDC"") G DRGAGN ;may be supply, try again"
^XMB(3.9,145950,2,327,0)="""RTN"",""PSAVERA"",46,0)"
^XMB(3.9,145950,2,328,0)=" I $G(PSABFR(""SYNNODE""))'="""" S PSASUB=PSABFR(""SYNNODE"") D"
^XMB(3.9,145950,2,329,0)="""RTN"",""PSAVERA"",47,0)"
^XMB(3.9,145950,2,330,0)=" .S DATA=$G(^PSDRUG(PSABFR,1,PSASUB,0)),PSAOU=$P(DATA,""^"",5),PSAPOU=$P(DATA,""^"",6),PSADUOU=$P(DATA,""^"",7),PSAPDUOU=$P(DATA,""^"",8)"
^XMB(3.9,145950,2,331,0)="""RTN"",""PSAVERA"",48,0)"
^XMB(3.9,145950,2,332,0)=" .S PSADU=$P($G(^PSDRUG(PSABFR,660)),""^"",8)"
^XMB(3.9,145950,2,333,0)="""RTN"",""PSAVERA"",49,0)"
^XMB(3.9,145950,2,334,0)=" I ($G(PSAOU)=""""!$G(PSAPOU)=""""!$G(PSADUOU)=""""!$G(PSAPDUOU)="""") W !!,""Sorry, I could not find the necessary information to change the drug selection."",! G Q"
^XMB(3.9,145950,2,335,0)="""RTN"",""PSAVERA"",50,0)"
^XMB(3.9,145950,2,336,0)=" W !,""Current Drug : "",PSABFR(1)"
^XMB(3.9,145950,2,337,0)="""RTN"",""PSAVERA"",51,0)"
^XMB(3.9,145950,2,338,0)="DRG1 S PSAGAIN=0,DIC(""A"")=""Select name of Correct Drug: "",PSABFR=PSADRG,DIC(0)=""AEQMZ"",DIC=""^PSDRUG("" D ^DIC K DIC G Q:PSAOUT"
^XMB(3.9,145950,2,339,0)="""RTN"",""PSAVERA"",52,0)"
^XMB(3.9,145950,2,340,0)=" I $G(DTOUT)!($G(DUOT))!(Y<0) S PSAOUT=1 Q"
^XMB(3.9,145950,2,341,0)="""RTN"",""PSAVERA"",53,0)"
^XMB(3.9,145950,2,342,0)=" S (PSADJ,PSADRG)=+Y"
^XMB(3.9,145950,2,343,0)="""RTN"",""PSAVERA"",54,0)"
^XMB(3.9,145950,2,344,0)=" W !!,""Comparing drug file data..."""
^XMB(3.9,145950,2,345,0)="""RTN"",""PSAVERA"",55,0)"
^XMB(3.9,145950,2,346,0)=" S PSAODU=$P($G(^PSDRUG(PSADRG,660)),""^"",8),PSAXDUOU=$P($G(^PSDRUG(PSADRG,660)),""^"",5)"
^XMB(3.9,145950,2,347,0)="""RTN"",""PSAVERA"",56,0)"
^XMB(3.9,145950,2,348,0)=" I $P($G(^PSDRUG(PSADRG,660)),""^"",2)'=$G(PSAOU) W !,""The Order Units are different between these two drugs."""
^XMB(3.9,145950,2,349,0)="""RTN"",""PSAVERA"",57,0)"
^XMB(3.9,145950,2,350,0)=" I $P($G(^PSDRUG(PSADRG,660)),""^"",8)'=$G(PSADU) W !,""Please Enter an appropriate Dispense Unit"" S DIE=""^PSDRUG("",DA=PSADRG,DR=""14.5"" D ^DIE S PSADU=$P(^PSDRUG(PSADRG,660),""^"",8)"
