^XMB(3.9,145942,2,245,0)="""RTN"")"
^XMB(3.9,145942,2,246,0)=2
^XMB(3.9,145942,2,247,0)="""RTN"",""RCDMCR6B"")"
^XMB(3.9,145942,2,248,0)="0^2^B28938665"
^XMB(3.9,145942,2,249,0)="""RTN"",""RCDMCR6B"",1,0)"
^XMB(3.9,145942,2,250,0)="RCDMCR6B ;ALB/YG - 50-100 Percent SC Exempt Charge Reconciliation Report - Input/output; Apr 9, 2019@21:06"
^XMB(3.9,145942,2,251,0)="""RTN"",""RCDMCR6B"",2,0)"
^XMB(3.9,145942,2,252,0)=" ;;4.5;Accounts Receivable;**347,454**;Mar 20, 1995;Build 0"
^XMB(3.9,145942,2,253,0)="""RTN"",""RCDMCR6B"",3,0)"
^XMB(3.9,145942,2,254,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145942,2,255,0)="""RTN"",""RCDMCR6B"",4,0)"
^XMB(3.9,145942,2,256,0)=" ;"
^XMB(3.9,145942,2,257,0)="""RTN"",""RCDMCR6B"",5,0)"
^XMB(3.9,145942,2,258,0)=" ; See RCDMCR6A for detailed description"
^XMB(3.9,145942,2,259,0)="""RTN"",""RCDMCR6B"",6,0)"
^XMB(3.9,145942,2,260,0)=" ;"
^XMB(3.9,145942,2,261,0)="""RTN"",""RCDMCR6B"",7,0)"
^XMB(3.9,145942,2,262,0)="COLLECT(STOPIT,ARTYPE) ; Get the report data"
^XMB(3.9,145942,2,263,0)="""RTN"",""RCDMCR6B"",8,0)"
^XMB(3.9,145942,2,264,0)=" ;Input"
^XMB(3.9,145942,2,265,0)="""RTN"",""RCDMCR6B"",9,0)"
^XMB(3.9,145942,2,266,0)=" ;   STOPIT - Passed Variable to determine if process is to be terminated"
^XMB(3.9,145942,2,267,0)="""RTN"",""RCDMCR6B"",10,0)"
^XMB(3.9,145942,2,268,0)=" ;   ARTYPE - AR Type  1:Active;2:Open;3:Suspended;4:Collected/Closed;5:On-Hold;6:Write Off;7:All"
^XMB(3.9,145942,2,269,0)="""RTN"",""RCDMCR6B"",11,0)"
^XMB(3.9,145942,2,270,0)=" ;Output"
^XMB(3.9,145942,2,271,0)="""RTN"",""RCDMCR6B"",12,0)"
^XMB(3.9,145942,2,272,0)=" ;   STOPIT - Passed Variable set to 1 if process is to be terminated"
^XMB(3.9,145942,2,273,0)="""RTN"",""RCDMCR6B"",13,0)"
^XMB(3.9,145942,2,274,0)=" ;   ^TMP($J,""RCDMCR6"") with report data and summary data"
^XMB(3.9,145942,2,275,0)="""RTN"",""RCDMCR6B"",14,0)"
^XMB(3.9,145942,2,276,0)=" ;N RCDFN,DEBTOR,ARIEN,IBIEN,CTR,EOCOK,IBCNT,EOCDT,DFN,DMCELIG,EFFDT,NAME,SSN"
^XMB(3.9,145942,2,277,0)="""RTN"",""RCDMCR6B"",15,0)"
^XMB(3.9,145942,2,278,0)=" ;N STATUS,OPTDT,DISCHDT,RXDT,OPTDT,RXDT,CHGAMT,OCC,BILLNO,RXNUM,RXNAM,DSTATUS,IBDATA"
^XMB(3.9,145942,2,279,0)="""RTN"",""RCDMCR6B"",16,0)"
^XMB(3.9,145942,2,280,0)=" ;Get Rated Disability Data within passed RD change time frame"
^XMB(3.9,145942,2,281,0)="""RTN"",""RCDMCR6B"",17,0)"
^XMB(3.9,145942,2,282,0)=" ;*** call API to get all RD change data for given date period"
^XMB(3.9,145942,2,283,0)="""RTN"",""RCDMCR6B"",18,0)"
^XMB(3.9,145942,2,284,0)=" N ZR,DEBTPT,WZH,DEBTCNT,DEBTOR,RCDFN,DFN,DMCELIG,ELIG,EXEMPTDT,SZH,VAERR,VADM,ARIEN,CTR"
^XMB(3.9,145942,2,285,0)="""RTN"",""RCDMCR6B"",19,0)"
^XMB(3.9,145942,2,286,0)=" N BILLNO,IBDATA,IBCNT,IBIEN,NAME,SSN,OUT,STATUS"
^XMB(3.9,145942,2,287,0)="""RTN"",""RCDMCR6B"",20,0)"
^XMB(3.9,145942,2,288,0)=" S DEBTPT=0,WZH=$H*86400+$P($H,"","",2)+60,SZH=WZH W !"
^XMB(3.9,145942,2,289,0)="""RTN"",""RCDMCR6B"",21,0)"
^XMB(3.9,145942,2,290,0)=" F DEBTCNT=0:1 S DEBTPT=$O(^RCD(340,""B"",DEBTPT)) Q:DEBTPT=""""  I DEBTPT["";DPT("" D"
^XMB(3.9,145942,2,291,0)="""RTN"",""RCDMCR6B"",22,0)"
^XMB(3.9,145942,2,292,0)=" . ;Get AR Debtor info from file 340"
^XMB(3.9,145942,2,293,0)="""RTN"",""RCDMCR6B"",23,0)"
^XMB(3.9,145942,2,294,0)=" . S DEBTOR=0,RCDFN=$P(DEBTPT,"";"")"
^XMB(3.9,145942,2,295,0)="""RTN"",""RCDMCR6B"",24,0)"
^XMB(3.9,145942,2,296,0)=" . F  S DEBTOR=$O(^RCD(340,""B"",DEBTPT,DEBTOR)) Q:DEBTOR'>0  D  Q:$G(STOPIT)>0"
^XMB(3.9,145942,2,297,0)="""RTN"",""RCDMCR6B"",25,0)"
^XMB(3.9,145942,2,298,0)=" . . S DFN=RCDFN"
^XMB(3.9,145942,2,299,0)="""RTN"",""RCDMCR6B"",26,0)"
^XMB(3.9,145942,2,300,0)=" . . S DMCELIG=$$DMCELIG^RCDMCUT1(RCDFN)"
^XMB(3.9,145942,2,301,0)="""RTN"",""RCDMCR6B"",27,0)"
^XMB(3.9,145942,2,302,0)=" . . Q:'DMCELIG"
^XMB(3.9,145942,2,303,0)="""RTN"",""RCDMCR6B"",28,0)"
^XMB(3.9,145942,2,304,0)=" . . S ELIG=$S($P(DMCELIG,U,2)'="""":""SC""_$P(DMCELIG,U,2),$P(DMCELIG,U,3)'="""":""Pension"",$P(DMCELIG,U,4)'="""":""A&A"",$P(DMCELIG,U,5)'="""":""HouseBnd"",1:"""")"
^XMB(3.9,145942,2,305,0)="""RTN"",""RCDMCR6B"",29,0)"
^XMB(3.9,145942,2,306,0)=" . . ; business decision for now is to only show SC%.  A&A, Pension and HB are off the report."
^XMB(3.9,145942,2,307,0)="""RTN"",""RCDMCR6B"",30,0)"
^XMB(3.9,145942,2,308,0)=" . . Q:ELIG'?1""SC"".E"
^XMB(3.9,145942,2,309,0)="""RTN"",""RCDMCR6B"",31,0)"
^XMB(3.9,145942,2,310,0)=" . . ; business decision is to change from .3012 (SC AWARD DATE) to .3014 (EFF. DATE COMBINED SC% EVAL.)"
^XMB(3.9,145942,2,311,0)="""RTN"",""RCDMCR6B"",32,0)"
^XMB(3.9,145942,2,312,0)=" . . S EXEMPTDT=$$GET1^DIQ(2,DFN_"","",.3014,""I"")"
^XMB(3.9,145942,2,313,0)="""RTN"",""RCDMCR6B"",33,0)"
^XMB(3.9,145942,2,314,0)=" . . I DFN'>0 D KVAR^VADPT Q"
^XMB(3.9,145942,2,315,0)="""RTN"",""RCDMCR6B"",34,0)"
^XMB(3.9,145942,2,316,0)=" . . D DEM^VADPT"
^XMB(3.9,145942,2,317,0)="""RTN"",""RCDMCR6B"",35,0)"
^XMB(3.9,145942,2,318,0)=" . . I $G(VAERR)>0 D KVAR^VADPT Q"
^XMB(3.9,145942,2,319,0)="""RTN"",""RCDMCR6B"",36,0)"
^XMB(3.9,145942,2,320,0)=" . . S NAME=$G(VADM(1))"
^XMB(3.9,145942,2,321,0)="""RTN"",""RCDMCR6B"",37,0)"
^XMB(3.9,145942,2,322,0)=" . . I NAME']"""" D KVAR^VADPT Q"
^XMB(3.9,145942,2,323,0)="""RTN"",""RCDMCR6B"",38,0)"
^XMB(3.9,145942,2,324,0)=" . . S SSN=$P(VADM(2),U,1)"
^XMB(3.9,145942,2,325,0)="""RTN"",""RCDMCR6B"",39,0)"
^XMB(3.9,145942,2,326,0)=" . . D KVAR^VADPT"
^XMB(3.9,145942,2,327,0)="""RTN"",""RCDMCR6B"",40,0)"
^XMB(3.9,145942,2,328,0)=" . . ;I EXEMPTDT="""" S ^TMP($J,""RCDMCR6"",""DETAIL"",NAME,SSN,"" "",1)=U_U_U_""NODATE"" Q"
^XMB(3.9,145942,2,329,0)="""RTN"",""RCDMCR6B"",41,0)"
^XMB(3.9,145942,2,330,0)=" . . ;Get AR Bill Data that is within the last BEGDT time period"
^XMB(3.9,145942,2,331,0)="""RTN"",""RCDMCR6B"",42,0)"
^XMB(3.9,145942,2,332,0)=" . . ;for Bill's with a current status of ACTIVE, OPEN, SUSPENDED, WRITE-OFF, COLLECTED/CLOSED, CANCELLATION or IB Status of ON-HOLD"
^XMB(3.9,145942,2,333,0)="""RTN"",""RCDMCR6B"",43,0)"
^XMB(3.9,145942,2,334,0)=" . . K ^TMP($J,""RCDMCR6"",""ARIB"")"
^XMB(3.9,145942,2,335,0)="""RTN"",""RCDMCR6B"",44,0)"
^XMB(3.9,145942,2,336,0)=" . . I $H*86400+$P($H,"","",2)>WZH S WZH=$H*86400+$P($H,"","",2)+30,$X=0 W *13,$FN(DEBTCNT*100/$P(^RCD(340,0),U,4),"","",2),""% done in "",WZH-SZH,"" seconds"""
^XMB(3.9,145942,2,337,0)="""RTN"",""RCDMCR6B"",45,0)"
^XMB(3.9,145942,2,338,0)=" . . S ARIEN=0"
^XMB(3.9,145942,2,339,0)="""RTN"",""RCDMCR6B"",46,0)"
^XMB(3.9,145942,2,340,0)=" . . I ARTYPE'=5 F  S ARIEN=$O(^PRCA(430,""C"",DEBTOR,ARIEN)) Q:ARIEN'>0  D  Q:$G(STOPIT)>0"
^XMB(3.9,145942,2,341,0)="""RTN"",""RCDMCR6B"",47,0)"
^XMB(3.9,145942,2,342,0)=" . . . S CTR=$G(CTR)+1 ;Counter"
^XMB(3.9,145942,2,343,0)="""RTN"",""RCDMCR6B"",48,0)"
^XMB(3.9,145942,2,344,0)=" . . . I CTR#500=0 S STOPIT=$$STOPIT^RCDMCUT2() Q:STOPIT"
^XMB(3.9,145942,2,345,0)="""RTN"",""RCDMCR6B"",49,0)"
^XMB(3.9,145942,2,346,0)=" . . . ; only look at 1st party bills - TBD"
^XMB(3.9,145942,2,347,0)="""RTN"",""RCDMCR6B"",50,0)"
^XMB(3.9,145942,2,348,0)=" . . . I '$$FIRSTPAR^RCDMCUT1(ARIEN) Q"
^XMB(3.9,145942,2,349,0)="""RTN"",""RCDMCR6B"",51,0)"
^XMB(3.9,145942,2,350,0)=" . . . ;IEN is from calling routine (for file 430)"
^XMB(3.9,145942,2,351,0)="""RTN"",""RCDMCR6B"",52,0)"
^XMB(3.9,145942,2,352,0)=" . . . ;Bill Number"
^XMB(3.9,145942,2,353,0)="""RTN"",""RCDMCR6B"",53,0)"
^XMB(3.9,145942,2,354,0)=" . . . S BILLNO=$$GET1^DIQ(430,ARIEN_"","",.01)"
^XMB(3.9,145942,2,355,0)="""RTN"",""RCDMCR6B"",54,0)"
^XMB(3.9,145942,2,356,0)=" . . . I BILLNO']"""" Q"
^XMB(3.9,145942,2,357,0)="""RTN"",""RCDMCR6B"",55,0)"
^XMB(3.9,145942,2,358,0)=" . . . S STATUS=$$GET1^DIQ(430,ARIEN_"","",8,""E"")"
^XMB(3.9,145942,2,359,0)="""RTN"",""RCDMCR6B"",56,0)"
^XMB(3.9,145942,2,360,0)=" . . . I ARTYPE=1,STATUS'=""ACTIVE"" Q"
^XMB(3.9,145942,2,361,0)="""RTN"",""RCDMCR6B"",57,0)"
^XMB(3.9,145942,2,362,0)=" . . . I ARTYPE=2,STATUS'=""OPEN"" Q"
^XMB(3.9,145942,2,363,0)="""RTN"",""RCDMCR6B"",58,0)"
^XMB(3.9,145942,2,364,0)=" . . . I ARTYPE=3,STATUS'=""SUSPENDED"" Q"
^XMB(3.9,145942,2,365,0)="""RTN"",""RCDMCR6B"",59,0)"
^XMB(3.9,145942,2,366,0)=" . . . I ARTYPE=4,STATUS'=""COLLECTED/CLOSED"" Q"
^XMB(3.9,145942,2,367,0)="""RTN"",""RCDMCR6B"",60,0)"
^XMB(3.9,145942,2,368,0)=" . . . I ARTYPE=6,STATUS'=""WRITE-OFF"" Q"
^XMB(3.9,145942,2,369,0)="""RTN"",""RCDMCR6B"",61,0)"
^XMB(3.9,145942,2,370,0)=" . . . I ARTYPE=7,""^ACTIVE^OPEN^SUSPENDED^WRITE-OFF^COLLECTED/CLOSED^CANCELLATION^""'[(U_STATUS_U) Q"
^XMB(3.9,145942,2,371,0)="""RTN"",""RCDMCR6B"",62,0)"
^XMB(3.9,145942,2,372,0)=" . . . K IBDATA S IBDATA=0"
^XMB(3.9,145942,2,373,0)="""RTN"",""RCDMCR6B"",63,0)"
^XMB(3.9,145942,2,374,0)=" . . . S IBIEN="""""
^XMB(3.9,145942,2,375,0)="""RTN"",""RCDMCR6B"",64,0)"
^XMB(3.9,145942,2,376,0)=" . . . F  S IBIEN=$O(^IB(""ABIL"",BILLNO,IBIEN)) Q:'IBIEN  D  ; PRCA*4.5*454"
^XMB(3.9,145942,2,377,0)="""RTN"",""RCDMCR6B"",65,0)"
^XMB(3.9,145942,2,378,0)=" . . . .I ""^6^7^""[(U_$$GET1^DIQ(350,IBIEN,"".03:.11"",""I"")_U) Q  ; skip billing groups 6 and 7 (TRICARE/CHAMPVA), ICR #4541"
^XMB(3.9,145942,2,379,0)="""RTN"",""RCDMCR6B"",66,0)"
^XMB(3.9,145942,2,380,0)=" . . . .S OUT=$$GETIB^RCDMCR4B(IBIEN,0)"
^XMB(3.9,145942,2,381,0)="""RTN"",""RCDMCR6B"",67,0)"
^XMB(3.9,145942,2,382,0)=" . . . .I OUT,$P(OUT,U,5)'=10 S IBDATA=IBDATA+1,IBDATA(IBDATA)=OUT"
^XMB(3.9,145942,2,383,0)="""RTN"",""RCDMCR6B"",68,0)"
^XMB(3.9,145942,2,384,0)=" . . . .Q"
^XMB(3.9,145942,2,385,0)="""RTN"",""RCDMCR6B"",69,0)"
^XMB(3.9,145942,2,386,0)=" . . . ;"
^XMB(3.9,145942,2,387,0)="""RTN"",""RCDMCR6B"",70,0)"
^XMB(3.9,145942,2,388,0)=" . . . I 'IBDATA Q"
^XMB(3.9,145942,2,389,0)="""RTN"",""RCDMCR6B"",71,0)"
^XMB(3.9,145942,2,390,0)=" . . . M ^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""IBDATA"")=IBDATA"
^XMB(3.9,145942,2,391,0)="""RTN"",""RCDMCR6B"",72,0)"
^XMB(3.9,145942,2,392,0)=" . . . S ^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""STATUS"")=STATUS"
^XMB(3.9,145942,2,393,0)="""RTN"",""RCDMCR6B"",73,0)"
^XMB(3.9,145942,2,394,0)=" . . S IBIEN="""""
^XMB(3.9,145942,2,395,0)="""RTN"",""RCDMCR6B"",74,0)"
^XMB(3.9,145942,2,396,0)=" . . I ARTYPE=5!(ARTYPE=7) F  S IBIEN=$O(^IB(""AH"",RCDFN,IBIEN)) Q:IBIEN=""""  D  Q:$G(STOPIT)>0"
^XMB(3.9,145942,2,397,0)="""RTN"",""RCDMCR6B"",75,0)"
^XMB(3.9,145942,2,398,0)=" . . . K IBDATA S IBDATA=0"
^XMB(3.9,145942,2,399,0)="""RTN"",""RCDMCR6B"",76,0)"
^XMB(3.9,145942,2,400,0)=" . . . S CTR=$G(CTR)+1 ;Counter"
^XMB(3.9,145942,2,401,0)="""RTN"",""RCDMCR6B"",77,0)"
^XMB(3.9,145942,2,402,0)=" . . . I CTR#500=0 S STOPIT=$$STOPIT^RCDMCUT2() Q:STOPIT"
^XMB(3.9,145942,2,403,0)="""RTN"",""RCDMCR6B"",78,0)"
^XMB(3.9,145942,2,404,0)=" . . . S BILLNO=""/""_IBIEN"
^XMB(3.9,145942,2,405,0)="""RTN"",""RCDMCR6B"",79,0)"
^XMB(3.9,145942,2,406,0)=" . . . S OUT=$$GETIB^RCDMCR4B(IBIEN,1) Q:'OUT"
^XMB(3.9,145942,2,407,0)="""RTN"",""RCDMCR6B"",80,0)"
^XMB(3.9,145942,2,408,0)=" . . . S IBDATA=1,IBDATA(1)=OUT"
^XMB(3.9,145942,2,409,0)="""RTN"",""RCDMCR6B"",81,0)"
^XMB(3.9,145942,2,410,0)=" . . . M ^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""IBDATA"")=IBDATA"
^XMB(3.9,145942,2,411,0)="""RTN"",""RCDMCR6B"",82,0)"
^XMB(3.9,145942,2,412,0)=" . . . S ^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""STATUS"")=""ON HOLD"""
^XMB(3.9,145942,2,413,0)="""RTN"",""RCDMCR6B"",83,0)"
^XMB(3.9,145942,2,414,0)=" . . S BILLNO="""""
^XMB(3.9,145942,2,415,0)="""RTN"",""RCDMCR6B"",84,0)"
^XMB(3.9,145942,2,416,0)=" . . F  S BILLNO=$O(^TMP($J,""RCDMCR6"",""ARIB"",BILLNO)) Q:BILLNO=""""  D"
^XMB(3.9,145942,2,417,0)="""RTN"",""RCDMCR6B"",85,0)"
^XMB(3.9,145942,2,418,0)=" . . . K IBDATA M IBDATA=^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""IBDATA"")"
^XMB(3.9,145942,2,419,0)="""RTN"",""RCDMCR6B"",86,0)"
^XMB(3.9,145942,2,420,0)=" . . . S STATUS=^TMP($J,""RCDMCR6"",""ARIB"",BILLNO,""STATUS"")"
^XMB(3.9,145942,2,421,0)="""RTN"",""RCDMCR6B"",87,0)"
^XMB(3.9,145942,2,422,0)=" . . . F IBCNT=1:1:IBDATA D"
^XMB(3.9,145942,2,423,0)="""RTN"",""RCDMCR6B"",88,0)"
^XMB(3.9,145942,2,424,0)=" . . . . N OPTDT,DISCHDT,SERVDT,RXDT,RXNUM,RXNAM,DSTATUS,EOCDT"
^XMB(3.9,145942,2,425,0)="""RTN"",""RCDMCR6B"",89,0)"
^XMB(3.9,145942,2,426,0)=" . . . . ;IBDATA - Array of 1 ^ Outpatient Date ^ Discharge Date ^ RX/Refill Date ^ IB Status ^ RX NUM ^ RX Name ^ CHGAMT"
^XMB(3.9,145942,2,427,0)="""RTN"",""RCDMCR6B"",90,0)"
^XMB(3.9,145942,2,428,0)=" . . . . S OPTDT=$P(IBDATA(IBCNT),U,2)"
^XMB(3.9,145942,2,429,0)="""RTN"",""RCDMCR6B"",91,0)"
^XMB(3.9,145942,2,430,0)=" . . . . S DISCHDT=$P(IBDATA(IBCNT),U,3)"
^XMB(3.9,145942,2,431,0)="""RTN"",""RCDMCR6B"",92,0)"
^XMB(3.9,145942,2,432,0)=" . . . . S SERVDT=$S(OPTDT>DISCHDT:OPTDT,DISCHDT>OPTDT:DISCHDT,1:"""")"
^XMB(3.9,145942,2,433,0)="""RTN"",""RCDMCR6B"",93,0)"
^XMB(3.9,145942,2,434,0)=" . . . . S RXDT=$P(IBDATA(IBCNT),U,4)"
^XMB(3.9,145942,2,435,0)="""RTN"",""RCDMCR6B"",94,0)"
^XMB(3.9,145942,2,436,0)=" . . . . ;S IBSTATUS=$P(IBDATA(IBCNT),U,5)"
^XMB(3.9,145942,2,437,0)="""RTN"",""RCDMCR6B"",95,0)"
^XMB(3.9,145942,2,438,0)=" . . . . S RXNUM=$P(IBDATA(IBCNT),U,6)"
^XMB(3.9,145942,2,439,0)="""RTN"",""RCDMCR6B"",96,0)"
^XMB(3.9,145942,2,440,0)=" . . . . S RXNAM=$P(IBDATA(IBCNT),U,7)"
^XMB(3.9,145942,2,441,0)="""RTN"",""RCDMCR6B"",97,0)"
^XMB(3.9,145942,2,442,0)=" . . . . S DSTATUS=STATUS"
^XMB(3.9,145942,2,443,0)="""RTN"",""RCDMCR6B"",98,0)"
^XMB(3.9,145942,2,444,0)=" . . . . ; Get EOC date and verify that it is later than Patient Effective Date"
^XMB(3.9,145942,2,445,0)="""RTN"",""RCDMCR6B"",99,0)"
^XMB(3.9,145942,2,446,0)=" . . . . S EOCDT="""""
^XMB(3.9,145942,2,447,0)="""RTN"",""RCDMCR6B"",100,0)"
^XMB(3.9,145942,2,448,0)=" . . . . I OPTDT>EOCDT S EOCDT=OPTDT"
^XMB(3.9,145942,2,449,0)="""RTN"",""RCDMCR6B"",101,0)"
^XMB(3.9,145942,2,450,0)=" . . . . I DISCHDT>EOCDT S EOCDT=DISCHDT"
^XMB(3.9,145942,2,451,0)="""RTN"",""RCDMCR6B"",102,0)"
^XMB(3.9,145942,2,452,0)=" . . . . I RXDT>EOCDT S EOCDT=RXDT"
^XMB(3.9,145942,2,453,0)="""RTN"",""RCDMCR6B"",103,0)"
^XMB(3.9,145942,2,454,0)=" . . . . I EXEMPTDT="""" S ^TMP($J,""RCDMCR6"",""DETAIL"",NAME,SSN,"" "",1)=U_U_ELIG_U_""NODATE"" Q"
^XMB(3.9,145942,2,455,0)="""RTN"",""RCDMCR6B"",104,0)"
^XMB(3.9,145942,2,456,0)=" . . . . I EOCDT'>EXEMPTDT Q"
^XMB(3.9,145942,2,457,0)="""RTN"",""RCDMCR6B"",105,0)"
^XMB(3.9,145942,2,458,0)=" . . . . S DSTATUS=$S(DSTATUS=""CANCELLATION"":""ARCXLD"",DSTATUS=""COLLECTED/CLOSED"":""C/C"",1:DSTATUS)"
^XMB(3.9,145942,2,459,0)="""RTN"",""RCDMCR6B"",106,0)"
^XMB(3.9,145942,2,460,0)=" . . . . S ^TMP($J,""RCDMCR6"",""DETAIL"",NAME,SSN,BILLNO,IBCNT)=SERVDT_U_RXDT_U_ELIG_U_EXEMPTDT_U_RXNUM_U_RXNAM_U_DSTATUS"
^XMB(3.9,145942,2,461,0)="""RTN"",""RCDMCR6B"",107,0)"
^XMB(3.9,145942,2,462,0)=" K ^TMP($J,""RCDMCR6"",""ARIB"")"
^XMB(3.9,145942,2,463,0)="""RTN"",""RCDMCR6B"",108,0)"
^XMB(3.9,145942,2,464,0)=" Q"
^XMB(3.9,145942,2,465,0)="""RTN"",""RCDMCRUT"")"
^XMB(3.9,145942,2,466,0)="1^1"
^XMB(3.9,145942,2,467,0)="""VER"")"
^XMB(3.9,145942,2,468,0)="8.0^22.2"
