^XMB(3.9,145957,2,1090,0)=" ;"
^XMB(3.9,145957,2,1091,0)="""RTN"",""GMRCIUT1"",176,0)"
^XMB(3.9,145957,2,1092,0)=" N ERR ;"
^XMB(3.9,145957,2,1093,0)="""RTN"",""GMRCIUT1"",177,0)"
^XMB(3.9,145957,2,1094,0)=" K ^TMP(""GMRCIUT1"",$J) F IDX=1:1 Q:'$D(^TMP(""HLS"",$J,IDX))  S ^TMP(""GMRCIUT1"",$J,IDX,0)=^TMP(""HLS"",$J,IDX) ;"
^XMB(3.9,145957,2,1095,0)="""RTN"",""GMRCIUT1"",178,0)"
^XMB(3.9,145957,2,1096,0)=" S ERR=$$SAVEHL7X^EHMHL7(""GMRCIUT1"",""IFC"",""VISTA-""_$$STA^XUAF4($$KSP^XUPARAM(""INST"")),""CERNER-""_$P($P(OBR,""|"",3),""^"",2),""|"",""^"",$E(HL(""ECH""),2)) ;"
^XMB(3.9,145957,2,1097,0)="""RTN"",""GMRCIUT1"",179,0)"
^XMB(3.9,145957,2,1098,0)=" ;"
^XMB(3.9,145957,2,1099,0)="""RTN"",""GMRCIUT1"",180,0)"
^XMB(3.9,145957,2,1100,0)=" K ^TMP(""GMRCIUT1"",$J) ;"
^XMB(3.9,145957,2,1101,0)="""RTN"",""GMRCIUT1"",181,0)"
