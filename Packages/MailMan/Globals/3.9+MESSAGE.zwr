^XMB(3.9,145987,2,2344,0)=" ; set initial status value ; non-count clinic?"
^XMB(3.9,145987,2,2345,0)="""RTN"",""SDES2SETCHECKOUT"",448,0)"
^XMB(3.9,145987,2,2346,0)=" S S=$S($P(SDATA,""^"",2)]"""":$P($P($P(^DD(2.98,3,0),""^"",3),$P(SDATA,""^"",2)_"":"",2),"";""),$P($G(^SC(SDCL,0)),U,17)=""Y"":""NON-COUNT"",1:"""")"
^XMB(3.9,145987,2,2347,0)="""RTN"",""SDES2SETCHECKOUT"",449,0)"
^XMB(3.9,145987,2,2348,0)=" I SDSCE&(S=""NO ACTION TAKEN"") S S="""""
^XMB(3.9,145987,2,2349,0)="""RTN"",""SDES2SETCHECKOUT"",450,0)"
^XMB(3.9,145987,2,2350,0)=" ;"
^XMB(3.9,145987,2,2351,0)="""RTN"",""SDES2SETCHECKOUT"",451,0)"
^XMB(3.9,145987,2,2352,0)=" ; inpatient?"
^XMB(3.9,145987,2,2353,0)="""RTN"",""SDES2SETCHECKOUT"",452,0)"
^XMB(3.9,145987,2,2354,0)=" S VAINDT=SDT D ADM^VADPT2"
^XMB(3.9,145987,2,2355,0)="""RTN"",""SDES2SETCHECKOUT"",453,0)"
^XMB(3.9,145987,2,2356,0)=" I S[""INPATIENT"",$S('VADMVT:1,'$P(^DG(43,1,0),U,21):0,1:$P($G(^DIC(42,+$P($G(^DGPM(VADMVT,0)),U,6),0)),U,3)=""D"") S S="""""
^XMB(3.9,145987,2,2357,0)="""RTN"",""SDES2SETCHECKOUT"",454,0)"
^XMB(3.9,145987,2,2358,0)=" ;"
^XMB(3.9,145987,2,2359,0)="""RTN"",""SDES2SETCHECKOUT"",455,0)"
^XMB(3.9,145987,2,2360,0)=" ; determine ci/co indicator"
^XMB(3.9,145987,2,2361,0)="""RTN"",""SDES2SETCHECKOUT"",456,0)"
^XMB(3.9,145987,2,2362,0)=" S C=$S(CHKOUTDT:""CHECKED OUT"",CHKINDT:""CHECKED IN"",S]"""":"""",SDT>(DT+.2359):""FUTURE"",1:""NO ACTION TAKEN"") S:S="""" S=C"
^XMB(3.9,145987,2,2363,0)="""RTN"",""SDES2SETCHECKOUT"",457,0)"
^XMB(3.9,145987,2,2364,0)=" ;"
^XMB(3.9,145987,2,2365,0)="""RTN"",""SDES2SETCHECKOUT"",458,0)"
^XMB(3.9,145987,2,2366,0)=" I S=""NO ACTION TAKEN"",$P(SDT,""."")=DT,C'[""CHECKED"" S C=""TODAY"""
^XMB(3.9,145987,2,2367,0)="""RTN"",""SDES2SETCHECKOUT"",459,0)"
^XMB(3.9,145987,2,2368,0)=" ; $$REQ & $$COCMP in SDM1A not used for speed"
^XMB(3.9,145987,2,2369,0)="""RTN"",""SDES2SETCHECKOUT"",460,0)"
^XMB(3.9,145987,2,2370,0)=" I S=""CHECKED OUT""!(S=""CHECKED IN""),SDT'<$P(^DG(43,1,""SCLR""),U,23),'$P(SDATA,U,20) S S=""NO ACTION TAKEN"""
^XMB(3.9,145987,2,2371,0)="""RTN"",""SDES2SETCHECKOUT"",461,0)"
^XMB(3.9,145987,2,2372,0)=" ;"
^XMB(3.9,145987,2,2373,0)="""RTN"",""SDES2SETCHECKOUT"",462,0)"
^XMB(3.9,145987,2,2374,0)=" ; determine print status"
^XMB(3.9,145987,2,2375,0)="""RTN"",""SDES2SETCHECKOUT"",463,0)"
^XMB(3.9,145987,2,2376,0)=" S P=$S(S=C!(C=""""):S,1:"""")"
^XMB(3.9,145987,2,2377,0)="""RTN"",""SDES2SETCHECKOUT"",464,0)"
^XMB(3.9,145987,2,2378,0)=" I P="""" D"
^XMB(3.9,145987,2,2379,0)="""RTN"",""SDES2SETCHECKOUT"",465,0)"
^XMB(3.9,145987,2,2380,0)=" .I S[""INPATIENT"",$P($G(^SC(SDCL,0)),U,17)'=""Y"",$P($G(^SCE(+$P(SDATA,U,20),0)),U,7)="""" S P=$P(S,"" "")_""/ACT REQ"" Q"
^XMB(3.9,145987,2,2381,0)="""RTN"",""SDES2SETCHECKOUT"",466,0)"
^XMB(3.9,145987,2,2382,0)=" .I S=""NO ACTION TAKEN"",C=""CHECKED OUT""!(C=""CHECKED IN"") S P=""ACT REQ/""_C D  Q"
^XMB(3.9,145987,2,2383,0)="""RTN"",""SDES2SETCHECKOUT"",467,0)"
^XMB(3.9,145987,2,2384,0)=" ..I SDSCE I $P($G(^SCE(SDSCE,0)),U,7) S P=""CHECKED OUT"""
^XMB(3.9,145987,2,2385,0)="""RTN"",""SDES2SETCHECKOUT"",468,0)"
^XMB(3.9,145987,2,2386,0)=" .S P=$S(S=""NO ACTION TAKEN"":S,1:$P(S,"" ""))_""/""_C"
^XMB(3.9,145987,2,2387,0)="""RTN"",""SDES2SETCHECKOUT"",469,0)"
^XMB(3.9,145987,2,2388,0)=" I S[""INPATIENT"",C="""" D"
^XMB(3.9,145987,2,2389,0)="""RTN"",""SDES2SETCHECKOUT"",470,0)"
^XMB(3.9,145987,2,2390,0)=" .I SDT>(DT+.2359) S P=$P(S,"" "")_""/FUTURE"" Q"
^XMB(3.9,145987,2,2391,0)="""RTN"",""SDES2SETCHECKOUT"",471,0)"
^XMB(3.9,145987,2,2392,0)=" .S P=$P(S,"" "")_""/NO ACT TAKN"""
^XMB(3.9,145987,2,2393,0)="""RTN"",""SDES2SETCHECKOUT"",472,0)"
^XMB(3.9,145987,2,2394,0)=" I S[""INPATIENT"" Q +$O(^SD(409.63,""AC"",S,0))_"";""_S_"";""_P_"";""_CHKINDT_"";""_CHKOUTDT_"";""_+VADMVT"
^XMB(3.9,145987,2,2395,0)="""RTN"",""SDES2SETCHECKOUT"",473,0)"
^XMB(3.9,145987,2,2396,0)=" I S[""NO-SHOW"" Q +$O(^SD(409.63,""AC"",S,0))_"";""_S_"";""_P_"";""_CHKINDT_"";""_CHKOUTDT_"";""_+VADMVT"
^XMB(3.9,145987,2,2397,0)="""RTN"",""SDES2SETCHECKOUT"",474,0)"
^XMB(3.9,145987,2,2398,0)=" I $G(SDSCE) I $D(^SCE(SDSCE,0)) D"
^XMB(3.9,145987,2,2399,0)="""RTN"",""SDES2SETCHECKOUT"",475,0)"
^XMB(3.9,145987,2,2400,0)=" .I $G(STATUS)=""NON-COUNT"" D  Q"
^XMB(3.9,145987,2,2401,0)="""RTN"",""SDES2SETCHECKOUT"",476,0)"
^XMB(3.9,145987,2,2402,0)=" ..I CHKOUTDT S P=""NON-COUNT/CHECKED OUT"" Q"
^XMB(3.9,145987,2,2403,0)="""RTN"",""SDES2SETCHECKOUT"",477,0)"
^XMB(3.9,145987,2,2404,0)=" ..I CHKINDT S P=""NON-COUNT/CHECKED IN"""
^XMB(3.9,145987,2,2405,0)="""RTN"",""SDES2SETCHECKOUT"",478,0)"
^XMB(3.9,145987,2,2406,0)=" .I $G(STATUS)=""CHECKED OUT"" S P=""CHECKED OUT"" Q"
^XMB(3.9,145987,2,2407,0)="""RTN"",""SDES2SETCHECKOUT"",479,0)"
^XMB(3.9,145987,2,2408,0)=" .I CHKOUTDT S P=""ACT REQ/CHECKED OUT"" D  Q"
^XMB(3.9,145987,2,2409,0)="""RTN"",""SDES2SETCHECKOUT"",480,0)"
^XMB(3.9,145987,2,2410,0)=" ..I $G(STATUS)=""ACTION REQUIRED"" S S=""NO ACTION TAKEN"" Q"
^XMB(3.9,145987,2,2411,0)="""RTN"",""SDES2SETCHECKOUT"",481,0)"
^XMB(3.9,145987,2,2412,0)=" ..I $G(STATUS)="""" I $P($G(^SCE(SDSCE,0)),U,7) S P=""CHECKED OUT"""
^XMB(3.9,145987,2,2413,0)="""RTN"",""SDES2SETCHECKOUT"",482,0)"
^XMB(3.9,145987,2,2414,0)=" .I CHKINDT S P=""ACT REQ/CHECKED IN"" D"
^XMB(3.9,145987,2,2415,0)="""RTN"",""SDES2SETCHECKOUT"",483,0)"
^XMB(3.9,145987,2,2416,0)=" ..I $G(STATUS)=""ACTION REQUIRED"" S S=""NO ACTION TAKEN"""
^XMB(3.9,145987,2,2417,0)="""RTN"",""SDES2SETCHECKOUT"",484,0)"
^XMB(3.9,145987,2,2418,0)=" Q +$O(^SD(409.63,""AC"",S,0))_"";""_S_"";""_P_"";""_CHKINDT_"";""_CHKOUTDT_"";""_+VADMVT"
^XMB(3.9,145987,2,2419,0)="""RTN"",""SDES2SETCHKOUT2"")"
^XMB(3.9,145987,2,2420,0)="1^7"
^XMB(3.9,145987,2,2421,0)="""RTN"",""SDES2UNDOCHKOUT"")"
^XMB(3.9,145987,2,2422,0)="0^5^B22468137"
^XMB(3.9,145987,2,2423,0)="""RTN"",""SDES2UNDOCHKOUT"",1,0)"
^XMB(3.9,145987,2,2424,0)="SDES2UNDOCHKOUT ;ALB/ANU/TJB,MCB,MCB,AGW - VISTA SCHEDULING RPCS - SDES2 UNDO CHECKOUT ;APR 7,2026 "
^XMB(3.9,145987,2,2425,0)="""RTN"",""SDES2UNDOCHKOUT"",2,0)"
^XMB(3.9,145987,2,2426,0)=" ;;5.3;Scheduling;**877,919,909,942**;Aug 13, 1993;Build 0"
^XMB(3.9,145987,2,2427,0)="""RTN"",""SDES2UNDOCHKOUT"",3,0)"
^XMB(3.9,145987,2,2428,0)=" ;;Per VHA Directive 6402, this routine should not be modified;"
^XMB(3.9,145987,2,2429,0)="""RTN"",""SDES2UNDOCHKOUT"",4,0)"
^XMB(3.9,145987,2,2430,0)=" ;"
^XMB(3.9,145987,2,2431,0)="""RTN"",""SDES2UNDOCHKOUT"",5,0)"
^XMB(3.9,145987,2,2432,0)=" ; Reference to DUZ^XUP is supported by IA #7487"
^XMB(3.9,145987,2,2433,0)="""RTN"",""SDES2UNDOCHKOUT"",6,0)"
^XMB(3.9,145987,2,2434,0)=" ;"
^XMB(3.9,145987,2,2435,0)="""RTN"",""SDES2UNDOCHKOUT"",7,0)"
^XMB(3.9,145987,2,2436,0)=" ; Reference to MAS PARAMETERS in ICR #483"
^XMB(3.9,145987,2,2437,0)="""RTN"",""SDES2UNDOCHKOUT"",8,0)"
^XMB(3.9,145987,2,2438,0)=" ; Reference to WARD LOCATION in ICR #1377"
^XMB(3.9,145987,2,2439,0)="""RTN"",""SDES2UNDOCHKOUT"",9,0)"
^XMB(3.9,145987,2,2440,0)=" ; Reference to MAS PARAMETERS in ICR #2296"
^XMB(3.9,145987,2,2441,0)="""RTN"",""SDES2UNDOCHKOUT"",10,0)"
^XMB(3.9,145987,2,2442,0)=" ; Reference to VISIT in ICR #2028"
^XMB(3.9,145987,2,2443,0)="""RTN"",""SDES2UNDOCHKOUT"",11,0)"
^XMB(3.9,145987,2,2444,0)=" ;"
^XMB(3.9,145987,2,2445,0)="""RTN"",""SDES2UNDOCHKOUT"",12,0)"
^XMB(3.9,145987,2,2446,0)=" Q"
^XMB(3.9,145987,2,2447,0)="""RTN"",""SDES2UNDOCHKOUT"",13,0)"
^XMB(3.9,145987,2,2448,0)=" ; INPUT"
^XMB(3.9,145987,2,2449,0)="""RTN"",""SDES2UNDOCHKOUT"",14,0)"
^XMB(3.9,145987,2,2450,0)=" ;"
^XMB(3.9,145987,2,2451,0)="""RTN"",""SDES2UNDOCHKOUT"",15,0)"
^XMB(3.9,145987,2,2452,0)=" ; SDCONTEXT(""ACHERON AUDIT ID"") = Up to 40 Character unique ID number. Ex: 11d9dcc6-c6a2-4785-8031-8261576fca37"
^XMB(3.9,145987,2,2453,0)="""RTN"",""SDES2UNDOCHKOUT"",16,0)"
^XMB(3.9,145987,2,2454,0)=" ; SDCONTEXT(""USER DUZ"") = The DUZ of the user taking action in the calling application."
^XMB(3.9,145987,2,2455,0)="""RTN"",""SDES2UNDOCHKOUT"",17,0)"
^XMB(3.9,145987,2,2456,0)=" ; SDCONTEXT(""USER SECID"") = The SECID of the user taking action in the calling application."
^XMB(3.9,145987,2,2457,0)="""RTN"",""SDES2UNDOCHKOUT"",18,0)"
^XMB(3.9,145987,2,2458,0)=" ; SDCONTEXT(""PATIENT DFN"") = The DFN/IEN of the target patient from the calling application."
^XMB(3.9,145987,2,2459,0)="""RTN"",""SDES2UNDOCHKOUT"",19,0)"
^XMB(3.9,145987,2,2460,0)=" ; SDCONTEXT(""PATIENT ICN"") = The ICN of the target patient from the calling application."
^XMB(3.9,145987,2,2461,0)="""RTN"",""SDES2UNDOCHKOUT"",20,0)"
^XMB(3.9,145987,2,2462,0)=" ; SDINPUT(""APPOINTMENT IEN"") = (Required) Appointment IEN"
^XMB(3.9,145987,2,2463,0)="""RTN"",""SDES2UNDOCHKOUT"",21,0)"
^XMB(3.9,145987,2,2464,0)=" ;"
^XMB(3.9,145987,2,2465,0)="""RTN"",""SDES2UNDOCHKOUT"",22,0)"
^XMB(3.9,145987,2,2466,0)="UNDOCHECKOUT(JSONRETURN,SDCONTEXT,SDINPUT) ;"
^XMB(3.9,145987,2,2467,0)="""RTN"",""SDES2UNDOCHKOUT"",23,0)"
^XMB(3.9,145987,2,2468,0)=" N ERRORS,SDRETURN,PARAMETERS,Y"
^XMB(3.9,145987,2,2469,0)="""RTN"",""SDES2UNDOCHKOUT"",24,0)"
^XMB(3.9,145987,2,2470,0)=" ; Newed Y due to it leaking"
^XMB(3.9,145987,2,2471,0)="""RTN"",""SDES2UNDOCHKOUT"",25,0)"
^XMB(3.9,145987,2,2472,0)=" D VALCONTEXT^SDES2VALCONTEXT(.ERRORS,.SDCONTEXT)"
^XMB(3.9,145987,2,2473,0)="""RTN"",""SDES2UNDOCHKOUT"",26,0)"
^XMB(3.9,145987,2,2474,0)=" I $D(ERRORS) S ERRORS(""UndoCheckOut"",1)="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.ERRORS) Q"
^XMB(3.9,145987,2,2475,0)="""RTN"",""SDES2UNDOCHKOUT"",27,0)"
^XMB(3.9,145987,2,2476,0)=" I $G(SDCONTEXT(""USER DUZ""))'="""" N DUZ D DUZ^XUP(SDCONTEXT(""USER DUZ""))"
^XMB(3.9,145987,2,2477,0)="""RTN"",""SDES2UNDOCHKOUT"",28,0)"
^XMB(3.9,145987,2,2478,0)=" ;"
^XMB(3.9,145987,2,2479,0)="""RTN"",""SDES2UNDOCHKOUT"",29,0)"
^XMB(3.9,145987,2,2480,0)=" S PARAMETERS=$$VALPARAMS(.SDINPUT,.ERRORS)"
^XMB(3.9,145987,2,2481,0)="""RTN"",""SDES2UNDOCHKOUT"",30,0)"
^XMB(3.9,145987,2,2482,0)=" I $D(ERRORS) S ERRORS(""UndoCheckOut"",1)="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.ERRORS) Q"
^XMB(3.9,145987,2,2483,0)="""RTN"",""SDES2UNDOCHKOUT"",31,0)"
^XMB(3.9,145987,2,2484,0)=" ;"
^XMB(3.9,145987,2,2485,0)="""RTN"",""SDES2UNDOCHKOUT"",32,0)"
^XMB(3.9,145987,2,2486,0)=" D UNDOCKOUT(.SDRETURN,PARAMETERS)"
^XMB(3.9,145987,2,2487,0)="""RTN"",""SDES2UNDOCHKOUT"",33,0)"
^XMB(3.9,145987,2,2488,0)=" I '$D(SDRETURN) S SDRETURN(""UndoCheckOut"",1)="""""
^XMB(3.9,145987,2,2489,0)="""RTN"",""SDES2UNDOCHKOUT"",34,0)"
^XMB(3.9,145987,2,2490,0)=" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,2491,0)="""RTN"",""SDES2UNDOCHKOUT"",35,0)"
^XMB(3.9,145987,2,2492,0)=" Q"
^XMB(3.9,145987,2,2493,0)="""RTN"",""SDES2UNDOCHKOUT"",36,0)"
^XMB(3.9,145987,2,2494,0)=" ;"
^XMB(3.9,145987,2,2495,0)="""RTN"",""SDES2UNDOCHKOUT"",37,0)"
^XMB(3.9,145987,2,2496,0)="VALPARAMS(PARAMS,SDERRORS) ; Validate"
^XMB(3.9,145987,2,2497,0)="""RTN"",""SDES2UNDOCHKOUT"",38,0)"
^XMB(3.9,145987,2,2498,0)=" N SDIEN,SDCHECKDT"
^XMB(3.9,145987,2,2499,0)="""RTN"",""SDES2UNDOCHKOUT"",39,0)"
^XMB(3.9,145987,2,2500,0)=" ;"
^XMB(3.9,145987,2,2501,0)="""RTN"",""SDES2UNDOCHKOUT"",40,0)"
^XMB(3.9,145987,2,2502,0)=" ; Validate Appointment IEN"
^XMB(3.9,145987,2,2503,0)="""RTN"",""SDES2UNDOCHKOUT"",41,0)"
^XMB(3.9,145987,2,2504,0)=" S SDIEN=$G(PARAMS(""APPOINTMENT IEN""))"
^XMB(3.9,145987,2,2505,0)="""RTN"",""SDES2UNDOCHKOUT"",42,0)"
^XMB(3.9,145987,2,2506,0)=" I '$G(SDIEN) D ERRLOG^SDES2JSON(.SDERRORS,14) Q 0"
^XMB(3.9,145987,2,2507,0)="""RTN"",""SDES2UNDOCHKOUT"",43,0)"
^XMB(3.9,145987,2,2508,0)=" I '$D(^SDEC(409.84,SDIEN,0)) D ERRLOG^SDES2JSON(.SDERRORS,15) Q 0 ;invalid appt IEN"
^XMB(3.9,145987,2,2509,0)="""RTN"",""SDES2UNDOCHKOUT"",44,0)"
^XMB(3.9,145987,2,2510,0)=" S SDCHECKDT=$$GET1^DIQ(409.84,SDIEN,.14,""I"")"
^XMB(3.9,145987,2,2511,0)="""RTN"",""SDES2UNDOCHKOUT"",45,0)"
^XMB(3.9,145987,2,2512,0)=" I 'SDCHECKDT D ERRLOG^SDES2JSON(.SDERRORS,377) Q 0"
^XMB(3.9,145987,2,2513,0)="""RTN"",""SDES2UNDOCHKOUT"",46,0)"
^XMB(3.9,145987,2,2514,0)=" I $$FMDIFF^XLFDT(DT,SDCHECKDT,1)'=0 D ERRLOG^SDES2JSON(.SDERRORS,47,""Undo Checkout must be performed same calendar day as checkout"") Q 0"
^XMB(3.9,145987,2,2515,0)="""RTN"",""SDES2UNDOCHKOUT"",47,0)"
^XMB(3.9,145987,2,2516,0)=" ;"
^XMB(3.9,145987,2,2517,0)="""RTN"",""SDES2UNDOCHKOUT"",48,0)"
^XMB(3.9,145987,2,2518,0)=" Q:$D(SDERRORS) 0"
^XMB(3.9,145987,2,2519,0)="""RTN"",""SDES2UNDOCHKOUT"",49,0)"
^XMB(3.9,145987,2,2520,0)=" Q SDIEN"
^XMB(3.9,145987,2,2521,0)="""RTN"",""SDES2UNDOCHKOUT"",50,0)"
^XMB(3.9,145987,2,2522,0)=" ;"
^XMB(3.9,145987,2,2523,0)="""RTN"",""SDES2UNDOCHKOUT"",51,0)"
^XMB(3.9,145987,2,2524,0)="UNDOCKOUT(SDRETURN,APPTIEN) ;"
^XMB(3.9,145987,2,2525,0)="""RTN"",""SDES2UNDOCHKOUT"",52,0)"
^XMB(3.9,145987,2,2526,0)=" N ERRORS,APPTSUBIEN44,APPTSTARTTIME,DFN,CLINICIEN,RESOURCEIEN,SDATA,SDCIHDL"
^XMB(3.9,145987,2,2527,0)="""RTN"",""SDES2UNDOCHKOUT"",53,0)"
^XMB(3.9,145987,2,2528,0)=" ;"
^XMB(3.9,145987,2,2529,0)="""RTN"",""SDES2UNDOCHKOUT"",54,0)"
^XMB(3.9,145987,2,2530,0)=" S APPTSTARTTIME=$$GET1^DIQ(409.84,APPTIEN,.01,""I"")"
^XMB(3.9,145987,2,2531,0)="""RTN"",""SDES2UNDOCHKOUT"",55,0)"
^XMB(3.9,145987,2,2532,0)=" S DFN=$$GET1^DIQ(409.84,APPTIEN,.05,""I"")"
^XMB(3.9,145987,2,2533,0)="""RTN"",""SDES2UNDOCHKOUT"",56,0)"
