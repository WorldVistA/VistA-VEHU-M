^XMB(3.9,145946,2,6217,0)="""RTN"",""IBCOPP"",81,0)"
^XMB(3.9,145946,2,6218,0)=" . D DEVICE"
^XMB(3.9,145946,2,6219,0)="""RTN"",""IBCOPP"",82,0)"
^XMB(3.9,145946,2,6220,0)=" ;"
^XMB(3.9,145946,2,6221,0)="""RTN"",""IBCOPP"",83,0)"
^XMB(3.9,145946,2,6222,0)=" ; Obtain Plans for selected or All Insurance Companies"
^XMB(3.9,145946,2,6223,0)="""RTN"",""IBCOPP"",84,0)"
^XMB(3.9,145946,2,6224,0)=" D START"
