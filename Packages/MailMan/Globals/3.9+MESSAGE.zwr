^XMB(3.9,145948,2,235,0)="""RTN"",""IBOMHC"")"
^XMB(3.9,145948,2,236,0)="0^1^B149999738"
^XMB(3.9,145948,2,237,0)="""RTN"",""IBOMHC"",1,0)"
^XMB(3.9,145948,2,238,0)="IBOMHC ;SAB/EDE -  COMPACT ACT COPAY Review Report ;JUL 12 2021"
^XMB(3.9,145948,2,239,0)="""RTN"",""IBOMHC"",2,0)"
^XMB(3.9,145948,2,240,0)=" ;;2.0;INTEGRATED BILLING;**709,720,736,772**;21-MAR-94;Build 0"
^XMB(3.9,145948,2,241,0)="""RTN"",""IBOMHC"",3,0)"
^XMB(3.9,145948,2,242,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145948,2,243,0)="""RTN"",""IBOMHC"",4,0)"
^XMB(3.9,145948,2,244,0)=" ;"
^XMB(3.9,145948,2,245,0)="""RTN"",""IBOMHC"",5,0)"
^XMB(3.9,145948,2,246,0)=" ; Reference to $$CODEC^ICDEX in ICR #5747"
^XMB(3.9,145948,2,247,0)="""RTN"",""IBOMHC"",6,0)"
^XMB(3.9,145948,2,248,0)=" ; Reference to $$RX^PSO52API in ICR #4820"
^XMB(3.9,145948,2,249,0)="""RTN"",""IBOMHC"",7,0)"
^XMB(3.9,145948,2,250,0)=" ; Reference to $$GETCPT^SDOE in ICR #2546"
^XMB(3.9,145948,2,251,0)="""RTN"",""IBOMHC"",8,0)"
^XMB(3.9,145948,2,252,0)=" ; Reference to $$RXSITE^PSOBPSUT in ICR #4701"
^XMB(3.9,145948,2,253,0)="""RTN"",""IBOMHC"",9,0)"
^XMB(3.9,145948,2,254,0)=" ; Reference to FILE #405 in ICR #419"
^XMB(3.9,145948,2,255,0)="""RTN"",""IBOMHC"",10,0)"
^XMB(3.9,145948,2,256,0)=" ; Reference to FILE #40.8 in ICR #417"
^XMB(3.9,145948,2,257,0)="""RTN"",""IBOMHC"",11,0)"
^XMB(3.9,145948,2,258,0)=" ;"
^XMB(3.9,145948,2,259,0)="""RTN"",""IBOMHC"",12,0)"
^XMB(3.9,145948,2,260,0)="EN ;"
^XMB(3.9,145948,2,261,0)="""RTN"",""IBOMHC"",13,0)"
^XMB(3.9,145948,2,262,0)=" ;"
^XMB(3.9,145948,2,263,0)="""RTN"",""IBOMHC"",14,0)"
^XMB(3.9,145948,2,264,0)=" N IBSTART,IBEND,IBEXCEL,IBSTOP,IBSD,VAUTD"
^XMB(3.9,145948,2,265,0)="""RTN"",""IBOMHC"",15,0)"
^XMB(3.9,145948,2,266,0)=" N POP,ZTDESC,ZTRTN,ZTSAVE,ZTSK,%ZIS"
^XMB(3.9,145948,2,267,0)="""RTN"",""IBOMHC"",16,0)"
^XMB(3.9,145948,2,268,0)=" ;Initialze Date fields "
^XMB(3.9,145948,2,269,0)="""RTN"",""IBOMHC"",17,0)"
^XMB(3.9,145948,2,270,0)=" S (IBSTART,IBEND)="""",IBSTOP=0"
^XMB(3.9,145948,2,271,0)="""RTN"",""IBOMHC"",18,0)"
^XMB(3.9,145948,2,272,0)=" ;Get the start and end dates."
^XMB(3.9,145948,2,273,0)="""RTN"",""IBOMHC"",19,0)"
^XMB(3.9,145948,2,274,0)=" D DATESEL(.IBSTART,.IBEND,""Date Copay Billed"")"
^XMB(3.9,145948,2,275,0)="""RTN"",""IBOMHC"",20,0)"
^XMB(3.9,145948,2,276,0)=" Q:IBSTOP"
^XMB(3.9,145948,2,277,0)="""RTN"",""IBOMHC"",21,0)"
^XMB(3.9,145948,2,278,0)=" ;Ask to sort by Division or not"
^XMB(3.9,145948,2,279,0)="""RTN"",""IBOMHC"",22,0)"
^XMB(3.9,145948,2,280,0)=" S IBSD=$$GETDIV()"
^XMB(3.9,145948,2,281,0)="""RTN"",""IBOMHC"",23,0)"
^XMB(3.9,145948,2,282,0)=" Q:IBSD<0   ;User requested an exit"
^XMB(3.9,145948,2,283,0)="""RTN"",""IBOMHC"",24,0)"
^XMB(3.9,145948,2,284,0)=" ;"
^XMB(3.9,145948,2,285,0)="""RTN"",""IBOMHC"",25,0)"
^XMB(3.9,145948,2,286,0)=" W !!,""** This report can take a while to run and may be queued to run after hours. **"",!"
^XMB(3.9,145948,2,287,0)="""RTN"",""IBOMHC"",26,0)"
^XMB(3.9,145948,2,288,0)=" W !,""Note: Copay displays only if at least one COMPACT diagnosis is hit."",!"
^XMB(3.9,145948,2,289,0)="""RTN"",""IBOMHC"",27,0)"
^XMB(3.9,145948,2,290,0)=" ; export to Excel?"
^XMB(3.9,145948,2,291,0)="""RTN"",""IBOMHC"",28,0)"
^XMB(3.9,145948,2,292,0)=" S IBEXCEL=$$GETEXCEL^IBUCMM() I IBEXCEL<0 Q"
^XMB(3.9,145948,2,293,0)="""RTN"",""IBOMHC"",29,0)"
^XMB(3.9,145948,2,294,0)=" I IBEXCEL D PRTEXCEL^IBUCMM()"
^XMB(3.9,145948,2,295,0)="""RTN"",""IBOMHC"",30,0)"
^XMB(3.9,145948,2,296,0)=" W:'IBEXCEL !!,""Report requires 132 columns."",!  ; IB*2.0*720"
^XMB(3.9,145948,2,297,0)="""RTN"",""IBOMHC"",31,0)"
^XMB(3.9,145948,2,298,0)=" ;"
^XMB(3.9,145948,2,299,0)="""RTN"",""IBOMHC"",32,0)"
^XMB(3.9,145948,2,300,0)=" ; ask for device"
^XMB(3.9,145948,2,301,0)="""RTN"",""IBOMHC"",33,0)"
^XMB(3.9,145948,2,302,0)=" K IOP,IO(""Q"")"
^XMB(3.9,145948,2,303,0)="""RTN"",""IBOMHC"",34,0)"
^XMB(3.9,145948,2,304,0)=" S %ZIS=""MQ"",%ZIS(""B"")="""",POP=0 D ^%ZIS Q:POP"
^XMB(3.9,145948,2,305,0)="""RTN"",""IBOMHC"",35,0)"
^XMB(3.9,145948,2,306,0)=" I $D(IO(""Q"")) D  Q  ; queued report: ask if print queue should be cleared, then queue task"
^XMB(3.9,145948,2,307,0)="""RTN"",""IBOMHC"",36,0)"
^XMB(3.9,145948,2,308,0)=" .S ZTDESC=""COMPACT ACT Copay Review Report Report"""
^XMB(3.9,145948,2,309,0)="""RTN"",""IBOMHC"",37,0)"
^XMB(3.9,145948,2,310,0)=" .S ZTRTN=""MAIN^IBOMHC"""
^XMB(3.9,145948,2,311,0)="""RTN"",""IBOMHC"",38,0)"
^XMB(3.9,145948,2,312,0)=" .S ZTSAVE(""IBSTART"")=IBSTART,ZTSAVE(""IBEXCEL"")=IBEXCEL,ZTSAVE(""IBEND"")=IBEND,ZTSAVE(""VAUTD"")="""",ZTSAVE(""VAUTD("")="""",ZTSAVE(""ZTREQ"")=""@"""
^XMB(3.9,145948,2,313,0)="""RTN"",""IBOMHC"",39,0)"
^XMB(3.9,145948,2,314,0)=" .S ZTSAVE(""IBSD"")=IBSD"
^XMB(3.9,145948,2,315,0)="""RTN"",""IBOMHC"",40,0)"
^XMB(3.9,145948,2,316,0)=" .D ^%ZTLOAD,HOME^%ZIS"
^XMB(3.9,145948,2,317,0)="""RTN"",""IBOMHC"",41,0)"
^XMB(3.9,145948,2,318,0)=" .I $G(ZTSK) W !!,""Report compilation has started with task# "",ZTSK,""."",!"
^XMB(3.9,145948,2,319,0)="""RTN"",""IBOMHC"",42,0)"
^XMB(3.9,145948,2,320,0)=" .Q"
^XMB(3.9,145948,2,321,0)="""RTN"",""IBOMHC"",43,0)"
^XMB(3.9,145948,2,322,0)=" ;"
^XMB(3.9,145948,2,323,0)="""RTN"",""IBOMHC"",44,0)"
^XMB(3.9,145948,2,324,0)=" D MAIN"
^XMB(3.9,145948,2,325,0)="""RTN"",""IBOMHC"",45,0)"
^XMB(3.9,145948,2,326,0)=" Q"
^XMB(3.9,145948,2,327,0)="""RTN"",""IBOMHC"",46,0)"
^XMB(3.9,145948,2,328,0)=" ;"
^XMB(3.9,145948,2,329,0)="""RTN"",""IBOMHC"",47,0)"
^XMB(3.9,145948,2,330,0)="MAIN ; Main routine to gather and print the report "
^XMB(3.9,145948,2,331,0)="""RTN"",""IBOMHC"",48,0)"
^XMB(3.9,145948,2,332,0)=" ;"
^XMB(3.9,145948,2,333,0)="""RTN"",""IBOMHC"",49,0)"
^XMB(3.9,145948,2,334,0)=" K ^TMP($J,""IBOMHC""),^TMP($J,""IBOMHCDX"")"
^XMB(3.9,145948,2,335,0)="""RTN"",""IBOMHC"",50,0)"
^XMB(3.9,145948,2,336,0)=" D COLLECT"
^XMB(3.9,145948,2,337,0)="""RTN"",""IBOMHC"",51,0)"
^XMB(3.9,145948,2,338,0)=" D PRINT(IBSTART,IBEND)"
^XMB(3.9,145948,2,339,0)="""RTN"",""IBOMHC"",52,0)"
^XMB(3.9,145948,2,340,0)=" Q"
^XMB(3.9,145948,2,341,0)="""RTN"",""IBOMHC"",53,0)"
^XMB(3.9,145948,2,342,0)=" ;"
^XMB(3.9,145948,2,343,0)="""RTN"",""IBOMHC"",54,0)"
^XMB(3.9,145948,2,344,0)="DATESEL(DATESTRT,DATEEND,DESCR) ; prompt for start and end dates"
^XMB(3.9,145948,2,345,0)="""RTN"",""IBOMHC"",55,0)"
^XMB(3.9,145948,2,346,0)=" ;"
^XMB(3.9,145948,2,347,0)="""RTN"",""IBOMHC"",56,0)"
^XMB(3.9,145948,2,348,0)=" ; sets DATESTRT and DATEEND vars to start date and end date respectively, sets IBSTOP=1 on user exit"
^XMB(3.9,145948,2,349,0)="""RTN"",""IBOMHC"",57,0)"
^XMB(3.9,145948,2,350,0)=" ;"
^XMB(3.9,145948,2,351,0)="""RTN"",""IBOMHC"",58,0)"
^XMB(3.9,145948,2,352,0)=" N DIR,DUOUT,DTOUT,DIRUT,X,Y"
^XMB(3.9,145948,2,353,0)="""RTN"",""IBOMHC"",59,0)"
^XMB(3.9,145948,2,354,0)=" N CADT,DT7"
^XMB(3.9,145948,2,355,0)="""RTN"",""IBOMHC"",60,0)"
^XMB(3.9,145948,2,356,0)=" S CADT=$P($G(^IBE(350.9,1,71)),U,2)  ; COMPACT ACT Benefit start date from 350.9/71.02"
^XMB(3.9,145948,2,357,0)="""RTN"",""IBOMHC"",61,0)"
^XMB(3.9,145948,2,358,0)=" S DT7=$$FMADD^XLFDT(DT,-7)  ; today's date - 7 days"
^XMB(3.9,145948,2,359,0)="""RTN"",""IBOMHC"",62,0)"
^XMB(3.9,145948,2,360,0)=" S DIR(0)=""DA^""_CADT_"":""_DT_"":EX"""
^XMB(3.9,145948,2,361,0)="""RTN"",""IBOMHC"",63,0)"
^XMB(3.9,145948,2,362,0)=" S DIR(""A"")=""Start with ""_$S($G(DESCR)'="""":DESCR_"" "",1:"""")_"": """
^XMB(3.9,145948,2,363,0)="""RTN"",""IBOMHC"",64,0)"
^XMB(3.9,145948,2,364,0)=" S DIR(""B"")=$$FMTE^XLFDT($S(DT7<CADT:CADT,1:DT7),""1D"")"
^XMB(3.9,145948,2,365,0)="""RTN"",""IBOMHC"",65,0)"
^XMB(3.9,145948,2,366,0)=" S DIR(""?"",1)=""   Please enter a valid start date."""
^XMB(3.9,145948,2,367,0)="""RTN"",""IBOMHC"",66,0)"
^XMB(3.9,145948,2,368,0)=" S DIR(""?"",2)=""   This date must not be in the future."""
^XMB(3.9,145948,2,369,0)="""RTN"",""IBOMHC"",67,0)"
^XMB(3.9,145948,2,370,0)=" S DIR(""?"")=""   It also may not precede COMPACT ACT Benefit start date (""_$$FMTE^XLFDT(CADT)_"")"""
^XMB(3.9,145948,2,371,0)="""RTN"",""IBOMHC"",68,0)"
^XMB(3.9,145948,2,372,0)=" D ^DIR"
^XMB(3.9,145948,2,373,0)="""RTN"",""IBOMHC"",69,0)"
^XMB(3.9,145948,2,374,0)=" I $D(DIRUT) S IBSTOP=1 G DATESELX"
^XMB(3.9,145948,2,375,0)="""RTN"",""IBOMHC"",70,0)"
^XMB(3.9,145948,2,376,0)=" S DATESTRT=Y"
^XMB(3.9,145948,2,377,0)="""RTN"",""IBOMHC"",71,0)"
^XMB(3.9,145948,2,378,0)=" ; End date"
^XMB(3.9,145948,2,379,0)="""RTN"",""IBOMHC"",72,0)"
^XMB(3.9,145948,2,380,0)="DATESEL1 ;"
^XMB(3.9,145948,2,381,0)="""RTN"",""IBOMHC"",73,0)"
^XMB(3.9,145948,2,382,0)=" S DIR(""A"")=""  End with ""_$S($G(DESCR)'="""":DESCR_"" "",1:"""")_"": """
^XMB(3.9,145948,2,383,0)="""RTN"",""IBOMHC"",74,0)"
^XMB(3.9,145948,2,384,0)=" S DIR(""B"")=$$FMTE^XLFDT($$FMADD^XLFDT(DT),""1D"")"
^XMB(3.9,145948,2,385,0)="""RTN"",""IBOMHC"",75,0)"
^XMB(3.9,145948,2,386,0)=" S DIR(""?"",1)=""   Please enter a valid end date."""
^XMB(3.9,145948,2,387,0)="""RTN"",""IBOMHC"",76,0)"
^XMB(3.9,145948,2,388,0)=" S DIR(""?"")=""   This date must not precede the start date entered above."""
^XMB(3.9,145948,2,389,0)="""RTN"",""IBOMHC"",77,0)"
^XMB(3.9,145948,2,390,0)=" D ^DIR"
^XMB(3.9,145948,2,391,0)="""RTN"",""IBOMHC"",78,0)"
^XMB(3.9,145948,2,392,0)=" I $D(DIRUT) S IBSTOP=1 G DATESELX"
^XMB(3.9,145948,2,393,0)="""RTN"",""IBOMHC"",79,0)"
^XMB(3.9,145948,2,394,0)=" I Y<DATESTRT W !,""     End Date must not precede the Start Date."" G DATESEL1"
^XMB(3.9,145948,2,395,0)="""RTN"",""IBOMHC"",80,0)"
^XMB(3.9,145948,2,396,0)=" S DATEEND=Y"
^XMB(3.9,145948,2,397,0)="""RTN"",""IBOMHC"",81,0)"
^XMB(3.9,145948,2,398,0)=" W !?5,""***  Selected date range from "",$$FMTE^XLFDT(DATESTRT),"" to "",$$FMTE^XLFDT(DATEEND),""  ***"""
^XMB(3.9,145948,2,399,0)="""RTN"",""IBOMHC"",82,0)"
^XMB(3.9,145948,2,400,0)=" ;"
^XMB(3.9,145948,2,401,0)="""RTN"",""IBOMHC"",83,0)"
^XMB(3.9,145948,2,402,0)="DATESELX ; dates prompt exit point"
^XMB(3.9,145948,2,403,0)="""RTN"",""IBOMHC"",84,0)"
^XMB(3.9,145948,2,404,0)=" Q"
^XMB(3.9,145948,2,405,0)="""RTN"",""IBOMHC"",85,0)"
^XMB(3.9,145948,2,406,0)=" ;"
^XMB(3.9,145948,2,407,0)="""RTN"",""IBOMHC"",86,0)"
^XMB(3.9,145948,2,408,0)="COLLECT ; review the copays in the specified period for possible COMPACT Act related copays to review"
^XMB(3.9,145948,2,409,0)="""RTN"",""IBOMHC"",87,0)"
^XMB(3.9,145948,2,410,0)=" ;"
^XMB(3.9,145948,2,411,0)="""RTN"",""IBOMHC"",88,0)"
^XMB(3.9,145948,2,412,0)=" N IBERROR,IBN,IBDXARY,IBPTF,IBDATA,IBLP,IBBLNO,IBCT,VADM,IBPM,IBPCE,IBRX,IBVADM,I,IBCPT,IBDIV,IBADM  ; IB*2.0*720"
^XMB(3.9,145948,2,413,0)="""RTN"",""IBOMHC"",89,0)"
^XMB(3.9,145948,2,414,0)=" N DFN,DONE,IBBDSC,IBCHTYPE,IBCHRG,IBDOS,IBNM,IBRF,IBRFFL,IBDATA1,IBLPDT,IBSTATNM,IBSTAT,IBSTABR"
^XMB(3.9,145948,2,415,0)="""RTN"",""IBOMHC"",90,0)"
^XMB(3.9,145948,2,416,0)=" S IBCT=0"
^XMB(3.9,145948,2,417,0)="""RTN"",""IBOMHC"",91,0)"
^XMB(3.9,145948,2,418,0)=" S IBLPDT=IBSTART-.001,IBEND=IBEND+.999999"
^XMB(3.9,145948,2,419,0)="""RTN"",""IBOMHC"",92,0)"
^XMB(3.9,145948,2,420,0)=" ;Load list of possible DXs into a TMP array"
^XMB(3.9,145948,2,421,0)="""RTN"",""IBOMHC"",93,0)"
^XMB(3.9,145948,2,422,0)=" D GETDX"
^XMB(3.9,145948,2,423,0)="""RTN"",""IBOMHC"",94,0)"
^XMB(3.9,145948,2,424,0)=" F  S IBLPDT=$O(^IB(""D"",IBLPDT)) Q:'IBLPDT  Q:IBLPDT>IBEND  D"
^XMB(3.9,145948,2,425,0)="""RTN"",""IBOMHC"",95,0)"
^XMB(3.9,145948,2,426,0)=" .S IBLP=0"
^XMB(3.9,145948,2,427,0)="""RTN"",""IBOMHC"",96,0)"
^XMB(3.9,145948,2,428,0)=" .;Loop through file #350 using the Date Billed field within the Start and end Period"
^XMB(3.9,145948,2,429,0)="""RTN"",""IBOMHC"",97,0)"
^XMB(3.9,145948,2,430,0)=" .F  S IBLP=$O(^IB(""D"",IBLPDT,IBLP)) Q:'IBLP  D"
^XMB(3.9,145948,2,431,0)="""RTN"",""IBOMHC"",98,0)"
^XMB(3.9,145948,2,432,0)=" ..;kill and re-init arrays"
^XMB(3.9,145948,2,433,0)="""RTN"",""IBOMHC"",99,0)"
^XMB(3.9,145948,2,434,0)=" ..K IBDXARY,IBCPTARY,VADM"
^XMB(3.9,145948,2,435,0)="""RTN"",""IBOMHC"",100,0)"
^XMB(3.9,145948,2,436,0)=" ..S IBDXARY="""",IBCPTARY="""""
^XMB(3.9,145948,2,437,0)="""RTN"",""IBOMHC"",101,0)"
^XMB(3.9,145948,2,438,0)=" ..; Get Copay Data"
^XMB(3.9,145948,2,439,0)="""RTN"",""IBOMHC"",102,0)"
^XMB(3.9,145948,2,440,0)=" ..S IBDATA=$G(^IB(IBLP,0)),IBDATA1=$G(^IB(IBLP,1))"
^XMB(3.9,145948,2,441,0)="""RTN"",""IBOMHC"",103,0)"
^XMB(3.9,145948,2,442,0)=" ..S IBSTATNM=$$GET1^DIQ(350,IBLP_"","",.05,""E"") I ""^BILLED^HOLD - RATE^HOLD - REVIEW^ON HOLD^""'[(U_IBSTATNM_U) Q"
^XMB(3.9,145948,2,443,0)="""RTN"",""IBOMHC"",104,0)"
^XMB(3.9,145948,2,444,0)=" ..S DFN=$P(IBDATA,U,2) I '$$ISELIG(DFN) Q"
^XMB(3.9,145948,2,445,0)="""RTN"",""IBOMHC"",105,0)"
^XMB(3.9,145948,2,446,0)=" ..;Extract field (.04)[RESULTING FROM]"
^XMB(3.9,145948,2,447,0)="""RTN"",""IBOMHC"",106,0)"
^XMB(3.9,145948,2,448,0)=" ..S IBRF=$P(IBDATA,U,4)"
^XMB(3.9,145948,2,449,0)="""RTN"",""IBOMHC"",107,0)"
^XMB(3.9,145948,2,450,0)=" ..;If no file number or "":"" in field, skip and go to the next."
^XMB(3.9,145948,2,451,0)="""RTN"",""IBOMHC"",108,0)"
^XMB(3.9,145948,2,452,0)=" ..Q:IBRF'["":"""
^XMB(3.9,145948,2,453,0)="""RTN"",""IBOMHC"",109,0)"
^XMB(3.9,145948,2,454,0)=" ..;Extract the file from the 1st "":"" piece"
^XMB(3.9,145948,2,455,0)="""RTN"",""IBOMHC"",110,0)"
^XMB(3.9,145948,2,456,0)=" ..S IBRFFL=$P(IBRF,"":"")"
^XMB(3.9,145948,2,457,0)="""RTN"",""IBOMHC"",111,0)"
^XMB(3.9,145948,2,458,0)=" ..;If the copay is a RX copay, quit."
^XMB(3.9,145948,2,459,0)="""RTN"",""IBOMHC"",112,0)"
^XMB(3.9,145948,2,460,0)=" ..Q:$$GET1^DIQ(350.1,$P(IBDATA,U,3)_"","",.11,""I"")=5"
^XMB(3.9,145948,2,461,0)="""RTN"",""IBOMHC"",113,0)"
^XMB(3.9,145948,2,462,0)=" ..;Extract date of service"
^XMB(3.9,145948,2,463,0)="""RTN"",""IBOMHC"",114,0)"
^XMB(3.9,145948,2,464,0)=" ..S IBDOS="""" S:IBRFFL'=52 IBDOS=$P(IBDATA,U,14)  ; IB*2.0*772"
^XMB(3.9,145948,2,465,0)="""RTN"",""IBOMHC"",115,0)"
^XMB(3.9,145948,2,466,0)=" ..Q:'IBDOS"
^XMB(3.9,145948,2,467,0)="""RTN"",""IBOMHC"",116,0)"
^XMB(3.9,145948,2,468,0)=" ..; Check division  IB*2.0*720"
^XMB(3.9,145948,2,469,0)="""RTN"",""IBOMHC"",117,0)"
^XMB(3.9,145948,2,470,0)=" ..S IBDIV="""""
^XMB(3.9,145948,2,471,0)="""RTN"",""IBOMHC"",118,0)"
^XMB(3.9,145948,2,472,0)=" ..I IBRFFL=405 S IBDIV=$$INP^IBJDF2($P(IBRF,"":"",2))"
^XMB(3.9,145948,2,473,0)="""RTN"",""IBOMHC"",119,0)"
^XMB(3.9,145948,2,474,0)=" ..I IBRFFL=45 S IBADM=$O(^DGPM(""APTF"",$P(IBRF,"":"",2),0)) S:IBADM IBDIV=$$INP^IBJDF2(IBADM)"
^XMB(3.9,145948,2,475,0)="""RTN"",""IBOMHC"",120,0)"
^XMB(3.9,145948,2,476,0)=" ..I IBRFFL=409.68 S IBDIV=$$OPT^IBJDF2(IBDOS,DFN)"
^XMB(3.9,145948,2,477,0)="""RTN"",""IBOMHC"",121,0)"
^XMB(3.9,145948,2,478,0)=" ..S:IBDIV="""" IBDIV=+$$PRIM^VASITE()"
^XMB(3.9,145948,2,479,0)="""RTN"",""IBOMHC"",122,0)"
^XMB(3.9,145948,2,480,0)=" ..I IBSD,'VAUTD Q:'$D(VAUTD(IBDIV))  ;  quit if not a selected division."
^XMB(3.9,145948,2,481,0)="""RTN"",""IBOMHC"",123,0)"
^XMB(3.9,145948,2,482,0)=" ..;"
^XMB(3.9,145948,2,483,0)="""RTN"",""IBOMHC"",124,0)"
^XMB(3.9,145948,2,484,0)=" ..D DEM^VADPT M IBVADM=VADM  ; IB*2.0*720 moved line from above"
^XMB(3.9,145948,2,485,0)="""RTN"",""IBOMHC"",125,0)"
^XMB(3.9,145948,2,486,0)=" ..S IBNM=IBVADM(1),IBCHTYPE=$P(IBDATA,U,3) Q:IBCHTYPE=""""  Q:$D(^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBCHTYPE))  ; IB*2.0*720"
^XMB(3.9,145948,2,487,0)="""RTN"",""IBOMHC"",126,0)"
^XMB(3.9,145948,2,488,0)=" ..Q:$$GET1^DIQ(350.1,IBCHTYPE,.05,""E"")'=""NEW"""
^XMB(3.9,145948,2,489,0)="""RTN"",""IBOMHC"",127,0)"
^XMB(3.9,145948,2,490,0)=" ..;If file is 45 (PTF), lookup the primary and Secondary diagnoses"
^XMB(3.9,145948,2,491,0)="""RTN"",""IBOMHC"",128,0)"
^XMB(3.9,145948,2,492,0)=" ..I IBRFFL=45 S IBPTF=$P(IBRF,"":"",2) D GETPTFDX(IBPTF,.IBDXARY)"
^XMB(3.9,145948,2,493,0)="""RTN"",""IBOMHC"",129,0)"
^XMB(3.9,145948,2,494,0)=" ..;If file is 409.68, lookup the diagnoses using OPTDX^IBCSC4D"
^XMB(3.9,145948,2,495,0)="""RTN"",""IBOMHC"",130,0)"
^XMB(3.9,145948,2,496,0)=" ..I IBRFFL=409.68 S IBPCE=$P(IBRF,"":"",2) D GETPCEDX(IBPCE,.IBDXARY),GETPCECP(IBPCE,.IBCPTARY)"
^XMB(3.9,145948,2,497,0)="""RTN"",""IBOMHC"",131,0)"
^XMB(3.9,145948,2,498,0)=" ..;If file is 405, grab the PTF or Diagnoses Text Strings."
^XMB(3.9,145948,2,499,0)="""RTN"",""IBOMHC"",132,0)"
^XMB(3.9,145948,2,500,0)=" ..I IBRFFL=405 S IBPM=$P(IBRF,"":"",2) D GETPMDX(IBPM,.IBDXARY)"
^XMB(3.9,145948,2,501,0)="""RTN"",""IBOMHC"",133,0)"
^XMB(3.9,145948,2,502,0)=" ..;If file is 52, look the prescription to get the diagnosis associated with it"
^XMB(3.9,145948,2,503,0)="""RTN"",""IBOMHC"",134,0)"
^XMB(3.9,145948,2,504,0)=" ..S IBID=$E(IBVADM(1),1)_$P($P(IBVADM(2),U,2),""-"",3)"
^XMB(3.9,145948,2,505,0)="""RTN"",""IBOMHC"",135,0)"
^XMB(3.9,145948,2,506,0)=" ..S IBSTAT=$P(IBDATA,U,5)"
^XMB(3.9,145948,2,507,0)="""RTN"",""IBOMHC"",136,0)"
^XMB(3.9,145948,2,508,0)=" ..I IBSTATNM[""HOLD"" S IBSTABR=""HOLD"""
^XMB(3.9,145948,2,509,0)="""RTN"",""IBOMHC"",137,0)"
^XMB(3.9,145948,2,510,0)=" ..I IBSTATNM'[""HOLD"" S IBSTABR=$E($$GET1^DIQ(350.21,IBSTAT_"","",.03,""E""),1,4)"
^XMB(3.9,145948,2,511,0)="""RTN"",""IBOMHC"",138,0)"
^XMB(3.9,145948,2,512,0)=" ..S IBBDSC=$E($$GET1^DIQ(350.1,IBCHTYPE,.01,""E""),1,12)"
^XMB(3.9,145948,2,513,0)="""RTN"",""IBOMHC"",139,0)"
^XMB(3.9,145948,2,514,0)=" ..S IBCHRG=$P(IBDATA,U,7),IBBLNO=$P(IBDATA,U,11)"
^XMB(3.9,145948,2,515,0)="""RTN"",""IBOMHC"",140,0)"
^XMB(3.9,145948,2,516,0)=" ..S DONE=0,I="""" F  S I=$O(IBDXARY(I)) Q:I=""""  D  Q:DONE"
^XMB(3.9,145948,2,517,0)="""RTN"",""IBOMHC"",141,0)"
^XMB(3.9,145948,2,518,0)=" ...I I'=""UNK"",'$$CMPDX(I,.IBCPTARY),'$D(IBCPTARY(""T2034"")) Q"
^XMB(3.9,145948,2,519,0)="""RTN"",""IBOMHC"",142,0)"
^XMB(3.9,145948,2,520,0)=" ...S DONE=1"
^XMB(3.9,145948,2,521,0)="""RTN"",""IBOMHC"",143,0)"
^XMB(3.9,145948,2,522,0)=" ...I $D(IBCPTARY)<10!(I'=""R45.851"") D   ;No CPT Codes Extracted or Dx is not R45.851  IB*2.0*720"
^XMB(3.9,145948,2,523,0)="""RTN"",""IBOMHC"",144,0)"
^XMB(3.9,145948,2,524,0)=" ....Q:'$$CMPDX(I,.IBCPTARY)    ;T2034 visit only, so process this below."
^XMB(3.9,145948,2,525,0)="""RTN"",""IBOMHC"",145,0)"
^XMB(3.9,145948,2,526,0)=" ....S IBCT=IBCT+1"
^XMB(3.9,145948,2,527,0)="""RTN"",""IBOMHC"",146,0)"
^XMB(3.9,145948,2,528,0)=" ....S ^TMP($J,""IBOMHC"",IBCT)=IBNM_U_IBID_U_IBBLNO_U_IBSTABR_U_IBBDSC_U_$$FMTE^XLFDT(IBDOS,9)_U_$S(I=""UNK"":"""",1:I)_U_U_IBCHRG_U_$$GET1^DIQ(389.9,IBDIV_"","",.04,""E"")  ; IB*2.0*720"
^XMB(3.9,145948,2,529,0)="""RTN"",""IBOMHC"",147,0)"
^XMB(3.9,145948,2,530,0)=" ....S ^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBCHTYPE,0)=IBCT,^TMP($J,""IBOMHC"",""IDX1"",DFN,IBDOS)=""""  ; IB*2.0*720"
^XMB(3.9,145948,2,531,0)="""RTN"",""IBOMHC"",148,0)"
^XMB(3.9,145948,2,532,0)=" ...I $D(IBCPTARY)>9,I=""R45.851"" D    ;CPT codes extracted and Dx is R45.851  IB*2.0*720"
^XMB(3.9,145948,2,533,0)="""RTN"",""IBOMHC"",149,0)"
^XMB(3.9,145948,2,534,0)=" ....S IBCPT="""" F  S IBCPT=$O(IBCPTARY(IBCPT)) Q:IBCPT=""""  D"
^XMB(3.9,145948,2,535,0)="""RTN"",""IBOMHC"",150,0)"
^XMB(3.9,145948,2,536,0)=" .....S IBCT=IBCT+1"
^XMB(3.9,145948,2,537,0)="""RTN"",""IBOMHC"",151,0)"
^XMB(3.9,145948,2,538,0)=" .....S ^TMP($J,""IBOMHC"",IBCT)=IBNM_U_IBID_U_IBBLNO_U_IBSTABR_U_IBBDSC_U_$$FMTE^XLFDT(IBDOS,9)_U_$S(I=""UNK"":"""",1:I)_U_IBCPT_U_IBCHRG_U_$$GET1^DIQ(389.9,IBDIV_"","",.04,""E"")  ; IB*2.0*720"
^XMB(3.9,145948,2,539,0)="""RTN"",""IBOMHC"",152,0)"
^XMB(3.9,145948,2,540,0)=" .....S ^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBCHTYPE,IBCPT)=IBCT,^TMP($J,""IBOMHC"",""IDX1"",DFN,IBDOS)=""""  ; IB*2.0*720"
^XMB(3.9,145948,2,541,0)="""RTN"",""IBOMHC"",153,0)"
^XMB(3.9,145948,2,542,0)=" ... ;Check to see if the HCPCS code T2034 assigned to the copay."
^XMB(3.9,145948,2,543,0)="""RTN"",""IBOMHC"",154,0)"
^XMB(3.9,145948,2,544,0)=" ...I $D(IBCPTARY(""T2034"")) D"
^XMB(3.9,145948,2,545,0)="""RTN"",""IBOMHC"",155,0)"
^XMB(3.9,145948,2,546,0)=" ....S IBCPT="""" F  S IBCPT=$O(IBCPTARY(IBCPT)) Q:IBCPT=""""  D"
^XMB(3.9,145948,2,547,0)="""RTN"",""IBOMHC"",156,0)"
^XMB(3.9,145948,2,548,0)=" .....S IBCT=IBCT+1"
^XMB(3.9,145948,2,549,0)="""RTN"",""IBOMHC"",157,0)"
^XMB(3.9,145948,2,550,0)=" .....S ^TMP($J,""IBOMHC"",IBCT)=IBNM_U_IBID_U_IBBLNO_U_IBSTABR_U_IBBDSC_U_$$FMTE^XLFDT(IBDOS,9)_U_$S(I=""UNK"":"""",1:I)_U_IBCPT_U_IBCHRG_U_$$GET1^DIQ(389.9,IBDIV_"","",.04,""E"")  ; IB*2.0*720"
^XMB(3.9,145948,2,551,0)="""RTN"",""IBOMHC"",158,0)"
^XMB(3.9,145948,2,552,0)=" .....S ^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBCHTYPE,IBCPT)=IBCT,^TMP($J,""IBOMHC"",""IDX1"",DFN,IBDOS)=""""  ; IB*2.0*720"
^XMB(3.9,145948,2,553,0)="""RTN"",""IBOMHC"",159,0)"
^XMB(3.9,145948,2,554,0)=" ...Q"
^XMB(3.9,145948,2,555,0)="""RTN"",""IBOMHC"",160,0)"
^XMB(3.9,145948,2,556,0)=" ..Q"
^XMB(3.9,145948,2,557,0)="""RTN"",""IBOMHC"",161,0)"
^XMB(3.9,145948,2,558,0)=" .Q"
^XMB(3.9,145948,2,559,0)="""RTN"",""IBOMHC"",162,0)"
^XMB(3.9,145948,2,560,0)=" ;"
^XMB(3.9,145948,2,561,0)="""RTN"",""IBOMHC"",163,0)"
^XMB(3.9,145948,2,562,0)=" Q"
^XMB(3.9,145948,2,563,0)="""RTN"",""IBOMHC"",164,0)"
^XMB(3.9,145948,2,564,0)=" ;"
^XMB(3.9,145948,2,565,0)="""RTN"",""IBOMHC"",165,0)"
^XMB(3.9,145948,2,566,0)="ISELIG(DFN) ; check if given patient is COMPACT Act eligible"
^XMB(3.9,145948,2,567,0)="""RTN"",""IBOMHC"",166,0)"
^XMB(3.9,145948,2,568,0)=" ;"
^XMB(3.9,145948,2,569,0)="""RTN"",""IBOMHC"",167,0)"
^XMB(3.9,145948,2,570,0)=" ; DFN - patient's DFN"
^XMB(3.9,145948,2,571,0)="""RTN"",""IBOMHC"",168,0)"
^XMB(3.9,145948,2,572,0)=" ;"
^XMB(3.9,145948,2,573,0)="""RTN"",""IBOMHC"",169,0)"
^XMB(3.9,145948,2,574,0)=" ; returns 1 if patient is COMPACT Act eligible, 0 otherwise"
^XMB(3.9,145948,2,575,0)="""RTN"",""IBOMHC"",170,0)"
^XMB(3.9,145948,2,576,0)=" ;"
^XMB(3.9,145948,2,577,0)="""RTN"",""IBOMHC"",171,0)"
^XMB(3.9,145948,2,578,0)=" N RES,VACOM"
^XMB(3.9,145948,2,579,0)="""RTN"",""IBOMHC"",172,0)"
^XMB(3.9,145948,2,580,0)=" S RES=0 I +$G(DFN)>0 D CAI^VADPT S RES=+$G(VACOM(""CAI""))"
^XMB(3.9,145948,2,581,0)="""RTN"",""IBOMHC"",173,0)"
^XMB(3.9,145948,2,582,0)=" Q RES"
^XMB(3.9,145948,2,583,0)="""RTN"",""IBOMHC"",174,0)"
^XMB(3.9,145948,2,584,0)=" ;"
^XMB(3.9,145948,2,585,0)="""RTN"",""IBOMHC"",175,0)"
^XMB(3.9,145948,2,586,0)="GETPMDX(IBPM,IBDXARY) ;Retrieve Dx's from the PTF file via the Patient Movement file."
^XMB(3.9,145948,2,587,0)="""RTN"",""IBOMHC"",176,0)"
^XMB(3.9,145948,2,588,0)=" ;"
^XMB(3.9,145948,2,589,0)="""RTN"",""IBOMHC"",177,0)"
^XMB(3.9,145948,2,590,0)=" N IBADPM,IBPTF"
^XMB(3.9,145948,2,591,0)="""RTN"",""IBOMHC"",178,0)"
^XMB(3.9,145948,2,592,0)=" ;"
^XMB(3.9,145948,2,593,0)="""RTN"",""IBOMHC"",179,0)"
^XMB(3.9,145948,2,594,0)=" S IBADPM=$$GET1^DIQ(405,IBPM_"","",.14,""I"")"
^XMB(3.9,145948,2,595,0)="""RTN"",""IBOMHC"",180,0)"
^XMB(3.9,145948,2,596,0)=" S IBPTF=$$GET1^DIQ(405,$S(IBADPM=IBPM:IBPM,1:IBADPM)_"","",.16,""I"")"
^XMB(3.9,145948,2,597,0)="""RTN"",""IBOMHC"",181,0)"
^XMB(3.9,145948,2,598,0)=" Q:IBPTF="""""
^XMB(3.9,145948,2,599,0)="""RTN"",""IBOMHC"",182,0)"
^XMB(3.9,145948,2,600,0)=" D GETPTFDX(IBPTF,.IBDXARY)"
^XMB(3.9,145948,2,601,0)="""RTN"",""IBOMHC"",183,0)"
^XMB(3.9,145948,2,602,0)=" Q"
^XMB(3.9,145948,2,603,0)="""RTN"",""IBOMHC"",184,0)"
^XMB(3.9,145948,2,604,0)=" ;"
^XMB(3.9,145948,2,605,0)="""RTN"",""IBOMHC"",185,0)"
^XMB(3.9,145948,2,606,0)="GETPTFDX(IBPTF,IBDXARY) ; Retrieve all of the DX codes assigned during an outpatient visit"
^XMB(3.9,145948,2,607,0)="""RTN"",""IBOMHC"",186,0)"
^XMB(3.9,145948,2,608,0)=" ;"
^XMB(3.9,145948,2,609,0)="""RTN"",""IBOMHC"",187,0)"
^XMB(3.9,145948,2,610,0)=" ;INPUT:   IBPTF   - IEN of PTF record in File 45"
^XMB(3.9,145948,2,611,0)="""RTN"",""IBOMHC"",188,0)"
^XMB(3.9,145948,2,612,0)=" ;OUTPUT:  IBDXARY - Array of Diagnoses for the PTF record passed in"
^XMB(3.9,145948,2,613,0)="""RTN"",""IBOMHC"",189,0)"
^XMB(3.9,145948,2,614,0)=" ;       "
^XMB(3.9,145948,2,615,0)="""RTN"",""IBOMHC"",190,0)"
^XMB(3.9,145948,2,616,0)=" N IBCT,IBLP,IBMVTYP,IBDT,IBDXIEN,IBDX,IBPTFD"
^XMB(3.9,145948,2,617,0)="""RTN"",""IBOMHC"",191,0)"
^XMB(3.9,145948,2,618,0)=" ;"
^XMB(3.9,145948,2,619,0)="""RTN"",""IBOMHC"",192,0)"
^XMB(3.9,145948,2,620,0)=" K ^TMP($J,""IBDX"")"
^XMB(3.9,145948,2,621,0)="""RTN"",""IBOMHC"",193,0)"
^XMB(3.9,145948,2,622,0)=" ;"
^XMB(3.9,145948,2,623,0)="""RTN"",""IBOMHC"",194,0)"
^XMB(3.9,145948,2,624,0)=" S IBCT=0"
^XMB(3.9,145948,2,625,0)="""RTN"",""IBOMHC"",195,0)"
^XMB(3.9,145948,2,626,0)=" D PTFDX^IBCSC4F(IBPTF)"
^XMB(3.9,145948,2,627,0)="""RTN"",""IBOMHC"",196,0)"
^XMB(3.9,145948,2,628,0)=" S IBMVTYP="""""
^XMB(3.9,145948,2,629,0)="""RTN"",""IBOMHC"",197,0)"
^XMB(3.9,145948,2,630,0)=" F  S IBMVTYP=$O(^TMP($J,""IBDX"",IBMVTYP)) Q:IBMVTYP=""""  D"
^XMB(3.9,145948,2,631,0)="""RTN"",""IBOMHC"",198,0)"
^XMB(3.9,145948,2,632,0)=" . S IBDT=0"
^XMB(3.9,145948,2,633,0)="""RTN"",""IBOMHC"",199,0)"
^XMB(3.9,145948,2,634,0)=" . F  S IBDT=$O(^TMP($J,""IBDX"",IBMVTYP,IBDT)) Q:'IBDT  D"
^XMB(3.9,145948,2,635,0)="""RTN"",""IBOMHC"",200,0)"
^XMB(3.9,145948,2,636,0)=" . . S IBLP=0"
^XMB(3.9,145948,2,637,0)="""RTN"",""IBOMHC"",201,0)"
^XMB(3.9,145948,2,638,0)=" . . F  S IBLP=$O(^TMP($J,""IBDX"",IBMVTYP,IBDT,IBLP)) Q:'IBLP  D"
^XMB(3.9,145948,2,639,0)="""RTN"",""IBOMHC"",202,0)"
^XMB(3.9,145948,2,640,0)=" . . . S IBPTFD=$G(^TMP($J,""IBDX"",IBMVTYP,IBDT,IBLP))"
^XMB(3.9,145948,2,641,0)="""RTN"",""IBOMHC"",203,0)"
^XMB(3.9,145948,2,642,0)=" . . . S IBDXIEN=$P(IBPTFD,U),IBDX=$$CODEC^ICDEX(80,IBDXIEN)"
^XMB(3.9,145948,2,643,0)="""RTN"",""IBOMHC"",204,0)"
^XMB(3.9,145948,2,644,0)=" . . . I IBDX'="""",'$D(IBDXARY(IBDX)) S IBDXARY(IBDX)="""""
^XMB(3.9,145948,2,645,0)="""RTN"",""IBOMHC"",205,0)"
^XMB(3.9,145948,2,646,0)=" ;"
^XMB(3.9,145948,2,647,0)="""RTN"",""IBOMHC"",206,0)"
^XMB(3.9,145948,2,648,0)=" K ^TMP($J,""IBDX"")"
^XMB(3.9,145948,2,649,0)="""RTN"",""IBOMHC"",207,0)"
^XMB(3.9,145948,2,650,0)=" Q"
^XMB(3.9,145948,2,651,0)="""RTN"",""IBOMHC"",208,0)"
^XMB(3.9,145948,2,652,0)=" ;"
^XMB(3.9,145948,2,653,0)="""RTN"",""IBOMHC"",209,0)"
^XMB(3.9,145948,2,654,0)="GETPCEDX(IBPCE,IBDXARY)  ; Retrieve the list of diagnoses associated with an Outpatient Encounter"
^XMB(3.9,145948,2,655,0)="""RTN"",""IBOMHC"",210,0)"
^XMB(3.9,145948,2,656,0)=" ;"
^XMB(3.9,145948,2,657,0)="""RTN"",""IBOMHC"",211,0)"
^XMB(3.9,145948,2,658,0)=" N IBDX,IBDXB,IBDXC,IBI,IBPCD,K,IBDT,IBID,IBIFN"
^XMB(3.9,145948,2,659,0)="""RTN"",""IBOMHC"",212,0)"
^XMB(3.9,145948,2,660,0)=" S (IBDX,IBDXB)="""""
^XMB(3.9,145948,2,661,0)="""RTN"",""IBOMHC"",213,0)"
^XMB(3.9,145948,2,662,0)=" ;"
^XMB(3.9,145948,2,663,0)="""RTN"",""IBOMHC"",214,0)"
^XMB(3.9,145948,2,664,0)=" ;Extract the Diagnosis info from the encounter"
^XMB(3.9,145948,2,665,0)="""RTN"",""IBOMHC"",215,0)"
^XMB(3.9,145948,2,666,0)=" D OEDX^IBCU81(IBPCE,.IBDX,.IBDXB)"
^XMB(3.9,145948,2,667,0)="""RTN"",""IBOMHC"",216,0)"
^XMB(3.9,145948,2,668,0)=" ;Loop through the Billable diagnoses and store in IBDXARY for further review"
^XMB(3.9,145948,2,669,0)="""RTN"",""IBOMHC"",217,0)"
^XMB(3.9,145948,2,670,0)=" S IBI=0"
^XMB(3.9,145948,2,671,0)="""RTN"",""IBOMHC"",218,0)"
^XMB(3.9,145948,2,672,0)=" F  S IBI=$O(IBDXB(IBI)) Q:'IBI  D"
^XMB(3.9,145948,2,673,0)="""RTN"",""IBOMHC"",219,0)"
^XMB(3.9,145948,2,674,0)=" .S IBDXC=$$CODEC^ICDEX(80,IBI)"
^XMB(3.9,145948,2,675,0)="""RTN"",""IBOMHC"",220,0)"
^XMB(3.9,145948,2,676,0)=" .I IBDXC'="""",'$D(IBDXARY(IBDXC)) S IBDXARY(IBDXC)="""""
^XMB(3.9,145948,2,677,0)="""RTN"",""IBOMHC"",221,0)"
^XMB(3.9,145948,2,678,0)=" .Q"
^XMB(3.9,145948,2,679,0)="""RTN"",""IBOMHC"",222,0)"
^XMB(3.9,145948,2,680,0)=" ;"
^XMB(3.9,145948,2,681,0)="""RTN"",""IBOMHC"",223,0)"
^XMB(3.9,145948,2,682,0)=" Q"
^XMB(3.9,145948,2,683,0)="""RTN"",""IBOMHC"",224,0)"
^XMB(3.9,145948,2,684,0)=" ;"
^XMB(3.9,145948,2,685,0)="""RTN"",""IBOMHC"",225,0)"
^XMB(3.9,145948,2,686,0)="GETPCECP(IBPCE,IBCPTARY)  ; Retrieve the list of CPT Codes associated with an Outpatient Encounter"
^XMB(3.9,145948,2,687,0)="""RTN"",""IBOMHC"",226,0)"
^XMB(3.9,145948,2,688,0)=" ;"
^XMB(3.9,145948,2,689,0)="""RTN"",""IBOMHC"",227,0)"
^XMB(3.9,145948,2,690,0)=" N IBCPT,IBCPTRET,IBERR,IBLP"
^XMB(3.9,145948,2,691,0)="""RTN"",""IBOMHC"",228,0)"
^XMB(3.9,145948,2,692,0)=" S IBCPT=""IBCPTRET"""
^XMB(3.9,145948,2,693,0)="""RTN"",""IBOMHC"",229,0)"
^XMB(3.9,145948,2,694,0)=" ;"
^XMB(3.9,145948,2,695,0)="""RTN"",""IBOMHC"",230,0)"
^XMB(3.9,145948,2,696,0)=" ; Call the PCE software to retrieve the CPT code info for the visit in array IBCPTARR via indirection."
^XMB(3.9,145948,2,697,0)="""RTN"",""IBOMHC"",231,0)"
^XMB(3.9,145948,2,698,0)=" D GETCPT^SDOE(IBPCE,.IBCPT,.IBERR)"
^XMB(3.9,145948,2,699,0)="""RTN"",""IBOMHC"",232,0)"
^XMB(3.9,145948,2,700,0)=" S IBLP=0 F  S IBLP=$O(IBCPTRET(IBLP)) Q:'IBLP  S IBCPTARY($$GET1^DIQ(81,$P(IBCPTRET(IBLP),U)_"","",.01,""E""))="""""
^XMB(3.9,145948,2,701,0)="""RTN"",""IBOMHC"",233,0)"
^XMB(3.9,145948,2,702,0)=" Q"
^XMB(3.9,145948,2,703,0)="""RTN"",""IBOMHC"",234,0)"
^XMB(3.9,145948,2,704,0)=" ;"
^XMB(3.9,145948,2,705,0)="""RTN"",""IBOMHC"",235,0)"
^XMB(3.9,145948,2,706,0)="PRINT(IBSTRT,IBEND) ; Print the results"
^XMB(3.9,145948,2,707,0)="""RTN"",""IBOMHC"",236,0)"
^XMB(3.9,145948,2,708,0)=" N IBI,IBX,IBPAGE,IBLN,QUIT,IBDOS,IBNM,IBDIV,IBDIVIEN,IBCT"
^XMB(3.9,145948,2,709,0)="""RTN"",""IBOMHC"",237,0)"
^XMB(3.9,145948,2,710,0)=" I $E(IOST,1,2)[""C-"",'$D(ZTQUEUED) W @IOF"
^XMB(3.9,145948,2,711,0)="""RTN"",""IBOMHC"",238,0)"
^XMB(3.9,145948,2,712,0)=" I IBEXCEL D"
^XMB(3.9,145948,2,713,0)="""RTN"",""IBOMHC"",239,0)"
^XMB(3.9,145948,2,714,0)=" .W @IOF"
^XMB(3.9,145948,2,715,0)="""RTN"",""IBOMHC"",240,0)"
^XMB(3.9,145948,2,716,0)=" .W !,""COMPACT ACT Copay Review Report from "",$$FMTE^XLFDT(IBSTRT),"" to "",$$FMTE^XLFDT($P(IBEND,""."")),""   Date of Report: "",$$FMTE^XLFDT($$DT^XLFDT())"
^XMB(3.9,145948,2,717,0)="""RTN"",""IBOMHC"",241,0)"
^XMB(3.9,145948,2,718,0)=" .W !,""Patient Name"",U,""ID"",U,""Bill Number"",U,""Stat"",U,""Descr."",U,""Dt of Serv."",U,""DX"",U,""Proc."",U,""Amount ($)"",U,""Division"""
^XMB(3.9,145948,2,719,0)="""RTN"",""IBOMHC"",242,0)"
^XMB(3.9,145948,2,720,0)=" .Q"
^XMB(3.9,145948,2,721,0)="""RTN"",""IBOMHC"",243,0)"
^XMB(3.9,145948,2,722,0)=" I 'IBEXCEL D"
^XMB(3.9,145948,2,723,0)="""RTN"",""IBOMHC"",244,0)"
^XMB(3.9,145948,2,724,0)=" .S IBPAGE=0 D HDR(IBSTRT,IBEND)"
^XMB(3.9,145948,2,725,0)="""RTN"",""IBOMHC"",245,0)"
^XMB(3.9,145948,2,726,0)=" .I '$D(^TMP($J,""IBOMHC"")) W !!!,""   There were no copayments within the specified date range that were potentially COMPACT ACT eligible"",!!!"
^XMB(3.9,145948,2,727,0)="""RTN"",""IBOMHC"",246,0)"
^XMB(3.9,145948,2,728,0)=" .Q"
^XMB(3.9,145948,2,729,0)="""RTN"",""IBOMHC"",247,0)"
^XMB(3.9,145948,2,730,0)=" S IBNM="""" F  S IBNM=$O(^TMP($J,""IBOMHC"",""IDX"",IBNM)) Q:IBNM=""""  D  Q:$G(QUIT)"
^XMB(3.9,145948,2,731,0)="""RTN"",""IBOMHC"",248,0)"
^XMB(3.9,145948,2,732,0)=" .S IBDOS=0 F  S IBDOS=$O(^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS)) Q:'IBDOS  D  Q:$G(QUIT)"
^XMB(3.9,145948,2,733,0)="""RTN"",""IBOMHC"",249,0)"
^XMB(3.9,145948,2,734,0)=" ..S IBI=0 F  S IBI=$O(^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBI)) Q:'IBI  D  Q:$G(QUIT)"
^XMB(3.9,145948,2,735,0)="""RTN"",""IBOMHC"",250,0)"
^XMB(3.9,145948,2,736,0)=" ...S IBX="""" F  S IBX=$O(^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBI,IBX)) Q:IBX=""""  D  Q:$G(QUIT)"
^XMB(3.9,145948,2,737,0)="""RTN"",""IBOMHC"",251,0)"
^XMB(3.9,145948,2,738,0)=" ....S IBCT=^TMP($J,""IBOMHC"",""IDX"",IBNM,IBDOS,IBI,IBX),IBDATA=$G(^TMP($J,""IBOMHC"",IBCT))"
^XMB(3.9,145948,2,739,0)="""RTN"",""IBOMHC"",252,0)"
^XMB(3.9,145948,2,740,0)=" ....I IBEXCEL W !,$E(IBNM,1,18),U,$P(IBDATA,U,2,10) Q"
^XMB(3.9,145948,2,741,0)="""RTN"",""IBOMHC"",253,0)"
^XMB(3.9,145948,2,742,0)=" ....W !,$E(IBNM,1,18),?20,$P(IBDATA,U,2),?26,$P(IBDATA,U,3),?39,$P(IBDATA,U,4),?44,$P(IBDATA,U,5),?58,$P(IBDATA,U,6),?71,$P(IBDATA,U,7)"
^XMB(3.9,145948,2,743,0)="""RTN"",""IBOMHC"",254,0)"
^XMB(3.9,145948,2,744,0)=" ....W ?80,$P(IBDATA,U,8),?89,$$RJ^XLFSTR($J($P(IBDATA,U,9),10,2),11),?108,$P(IBDATA,U,10)"
^XMB(3.9,145948,2,745,0)="""RTN"",""IBOMHC"",255,0)"
^XMB(3.9,145948,2,746,0)=" ....S IBLN=IBLN+1"
^XMB(3.9,145948,2,747,0)="""RTN"",""IBOMHC"",256,0)"
^XMB(3.9,145948,2,748,0)=" ....I IBLN>(IOSL-3) D HDR(IBSTRT,IBEND)"
^XMB(3.9,145948,2,749,0)="""RTN"",""IBOMHC"",257,0)"
^XMB(3.9,145948,2,750,0)=" ....Q"
^XMB(3.9,145948,2,751,0)="""RTN"",""IBOMHC"",258,0)"
^XMB(3.9,145948,2,752,0)=" ...Q"
^XMB(3.9,145948,2,753,0)="""RTN"",""IBOMHC"",259,0)"
^XMB(3.9,145948,2,754,0)=" ..Q"
^XMB(3.9,145948,2,755,0)="""RTN"",""IBOMHC"",260,0)"
^XMB(3.9,145948,2,756,0)=" .Q"
^XMB(3.9,145948,2,757,0)="""RTN"",""IBOMHC"",261,0)"
^XMB(3.9,145948,2,758,0)=" I 'IBEXCEL Q:$G(QUIT)  I IBPAGE>0,'$D(ZTQUEUED) D PAUSE W @IOF"
^XMB(3.9,145948,2,759,0)="""RTN"",""IBOMHC"",262,0)"
^XMB(3.9,145948,2,760,0)=" Q"
^XMB(3.9,145948,2,761,0)="""RTN"",""IBOMHC"",263,0)"
^XMB(3.9,145948,2,762,0)=" ;"
^XMB(3.9,145948,2,763,0)="""RTN"",""IBOMHC"",264,0)"
^XMB(3.9,145948,2,764,0)="HDR(IBSTRT,IBEND) ; print header"
^XMB(3.9,145948,2,765,0)="""RTN"",""IBOMHC"",265,0)"
^XMB(3.9,145948,2,766,0)=" ;"
^XMB(3.9,145948,2,767,0)="""RTN"",""IBOMHC"",266,0)"
^XMB(3.9,145948,2,768,0)=" N IBX,I,IBCT"
^XMB(3.9,145948,2,769,0)="""RTN"",""IBOMHC"",267,0)"
^XMB(3.9,145948,2,770,0)=" I IBPAGE>0,'$D(ZTQUEUED) D PAUSE W @IOF I $G(QUIT) Q"
^XMB(3.9,145948,2,771,0)="""RTN"",""IBOMHC"",268,0)"
^XMB(3.9,145948,2,772,0)=" S IBPAGE=IBPAGE+1"
^XMB(3.9,145948,2,773,0)="""RTN"",""IBOMHC"",269,0)"
^XMB(3.9,145948,2,774,0)=" W !,""COMPACT ACT Copay Review Report from "",$$FMTE^XLFDT(IBSTRT),"" to "",$$FMTE^XLFDT($P(IBEND,""."")),?80,""Date of Report: "",?96,$$FMTE^XLFDT($$DT^XLFDT()),?120,""Page: "",IBPAGE"
^XMB(3.9,145948,2,775,0)="""RTN"",""IBOMHC"",270,0)"
^XMB(3.9,145948,2,776,0)=" I 'IBSD!$G(VAUTD)=1 W !,""For All Divisions"""
^XMB(3.9,145948,2,777,0)="""RTN"",""IBOMHC"",271,0)"
^XMB(3.9,145948,2,778,0)=" E  W !,""For Division(s) - "" S (I,IBCT)=0 F  S I=$O(VAUTD(I)) Q:'I  W:IBCT>0 "","" W $G(VAUTD(I)) S IBCT=IBCT+1"
^XMB(3.9,145948,2,779,0)="""RTN"",""IBOMHC"",272,0)"
^XMB(3.9,145948,2,780,0)=" W !!,""Patient Name"",?22,""ID"",?26,""Bill Number"",?39,""Stat"",?44,""Descr."",?58,""Dt of Serv."",?71,""DX"",?80,""Proc."",?90,""Amount ($)"",?105,""Division""  ; IB*2.0*720"
^XMB(3.9,145948,2,781,0)="""RTN"",""IBOMHC"",273,0)"
^XMB(3.9,145948,2,782,0)=" W ! F IBX=1:1:132 W ""-""  ; IB*2.0*720"
^XMB(3.9,145948,2,783,0)="""RTN"",""IBOMHC"",274,0)"
^XMB(3.9,145948,2,784,0)=" S IBLN=6"
^XMB(3.9,145948,2,785,0)="""RTN"",""IBOMHC"",275,0)"
^XMB(3.9,145948,2,786,0)=" Q"
^XMB(3.9,145948,2,787,0)="""RTN"",""IBOMHC"",276,0)"
^XMB(3.9,145948,2,788,0)=" ;"
^XMB(3.9,145948,2,789,0)="""RTN"",""IBOMHC"",277,0)"
^XMB(3.9,145948,2,790,0)="PAUSE    ;Press Return to Continue"
^XMB(3.9,145948,2,791,0)="""RTN"",""IBOMHC"",278,0)"
^XMB(3.9,145948,2,792,0)=" N DIR,DUOUT,DTOUT,DIRUT"
^XMB(3.9,145948,2,793,0)="""RTN"",""IBOMHC"",279,0)"
^XMB(3.9,145948,2,794,0)=" S DIR(0)=""E"" D ^DIR"
^XMB(3.9,145948,2,795,0)="""RTN"",""IBOMHC"",280,0)"
^XMB(3.9,145948,2,796,0)=" I $D(DIRUT) S QUIT=1"
^XMB(3.9,145948,2,797,0)="""RTN"",""IBOMHC"",281,0)"
^XMB(3.9,145948,2,798,0)=" W !"
^XMB(3.9,145948,2,799,0)="""RTN"",""IBOMHC"",282,0)"
^XMB(3.9,145948,2,800,0)=" Q"
^XMB(3.9,145948,2,801,0)="""RTN"",""IBOMHC"",283,0)"
^XMB(3.9,145948,2,802,0)=" ;"
^XMB(3.9,145948,2,803,0)="""RTN"",""IBOMHC"",284,0)"
^XMB(3.9,145948,2,804,0)="GETDX() ; Populate the list of DX codes"
^XMB(3.9,145948,2,805,0)="""RTN"",""IBOMHC"",285,0)"
^XMB(3.9,145948,2,806,0)=" ;"
^XMB(3.9,145948,2,807,0)="""RTN"",""IBOMHC"",286,0)"
^XMB(3.9,145948,2,808,0)=" N IBDXD"
^XMB(3.9,145948,2,809,0)="""RTN"",""IBOMHC"",287,0)"
^XMB(3.9,145948,2,810,0)=" ;"
^XMB(3.9,145948,2,811,0)="""RTN"",""IBOMHC"",288,0)"
^XMB(3.9,145948,2,812,0)=" ;Retrieve Specific Diagnosis codes"
^XMB(3.9,145948,2,813,0)="""RTN"",""IBOMHC"",289,0)"
^XMB(3.9,145948,2,814,0)=" F I=1:1 S IBDATA=$T(DXSLIST+I) S IBDXD=$P(IBDATA,"";"",3) Q:IBDXD=""EXIT""  S ^TMP($J,""IBOMHCDX"",""IBDXS"",IBDXD)=+$P(IBDATA,"";"",4)"
^XMB(3.9,145948,2,815,0)="""RTN"",""IBOMHC"",290,0)"
^XMB(3.9,145948,2,816,0)=" ;"
^XMB(3.9,145948,2,817,0)="""RTN"",""IBOMHC"",291,0)"
^XMB(3.9,145948,2,818,0)=" Q"
^XMB(3.9,145948,2,819,0)="""RTN"",""IBOMHC"",292,0)"
^XMB(3.9,145948,2,820,0)=" ;"
^XMB(3.9,145948,2,821,0)="""RTN"",""IBOMHC"",293,0)"
^XMB(3.9,145948,2,822,0)="CMPDX(IBDX,IBCPTARY) ; Check to see if the diagnosis is a Compact Act related Diagnosis."
^XMB(3.9,145948,2,823,0)="""RTN"",""IBOMHC"",294,0)"
^XMB(3.9,145948,2,824,0)=" ;"
^XMB(3.9,145948,2,825,0)="""RTN"",""IBOMHC"",295,0)"
^XMB(3.9,145948,2,826,0)=" ; INPUT:  IBDX - ICD-10 DIAGNOSIS CODE"
^XMB(3.9,145948,2,827,0)="""RTN"",""IBOMHC"",296,0)"
^XMB(3.9,145948,2,828,0)=" ; Returns:  0 - Not related  1 COMPACT Act related diagnosis"
^XMB(3.9,145948,2,829,0)="""RTN"",""IBOMHC"",297,0)"
^XMB(3.9,145948,2,830,0)=" ;"
^XMB(3.9,145948,2,831,0)="""RTN"",""IBOMHC"",298,0)"
^XMB(3.9,145948,2,832,0)=" N IBDXGRP,IBFOUND,IBLP,IBCPTN"
^XMB(3.9,145948,2,833,0)="""RTN"",""IBOMHC"",299,0)"
^XMB(3.9,145948,2,834,0)=" ;"
^XMB(3.9,145948,2,835,0)="""RTN"",""IBOMHC"",300,0)"
^XMB(3.9,145948,2,836,0)=" S IBFOUND=0"
^XMB(3.9,145948,2,837,0)="""RTN"",""IBOMHC"",301,0)"
^XMB(3.9,145948,2,838,0)=" ;"
^XMB(3.9,145948,2,839,0)="""RTN"",""IBOMHC"",302,0)"
^XMB(3.9,145948,2,840,0)=" ;If the code matches a specific code related to COMPACT"
^XMB(3.9,145948,2,841,0)="""RTN"",""IBOMHC"",303,0)"
^XMB(3.9,145948,2,842,0)=" I $D(^TMP($J,""IBOMHCDX"",""IBDXS"",IBDX)) D  Q IBFOUND"
^XMB(3.9,145948,2,843,0)="""RTN"",""IBOMHC"",304,0)"
^XMB(3.9,145948,2,844,0)=" .S IBCPTN=+$G(^TMP($J,""IBOMHCDX"",""IBDXS"",IBDX))"
^XMB(3.9,145948,2,845,0)="""RTN"",""IBOMHC"",305,0)"
^XMB(3.9,145948,2,846,0)=" .I 'IBCPTN!($D(IBCPTARY)<10) S IBFOUND=1 Q     ;No CPT Code needed to confirm COMPACT related Diagnosis"
^XMB(3.9,145948,2,847,0)="""RTN"",""IBOMHC"",306,0)"
^XMB(3.9,145948,2,848,0)=" .; Check the CPT temporary array to see if the CPT code associated with the Diagnosis is present in the encounter."
^XMB(3.9,145948,2,849,0)="""RTN"",""IBOMHC"",307,0)"
^XMB(3.9,145948,2,850,0)=" .I $D(IBCPTARY(IBCPTN)) S IBFOUND=1"
^XMB(3.9,145948,2,851,0)="""RTN"",""IBOMHC"",308,0)"
^XMB(3.9,145948,2,852,0)=" .Q"
^XMB(3.9,145948,2,853,0)="""RTN"",""IBOMHC"",309,0)"
^XMB(3.9,145948,2,854,0)=" ;"
^XMB(3.9,145948,2,855,0)="""RTN"",""IBOMHC"",310,0)"
^XMB(3.9,145948,2,856,0)=" ;Dx code not potentially related to COMPACT Act."
^XMB(3.9,145948,2,857,0)="""RTN"",""IBOMHC"",311,0)"
^XMB(3.9,145948,2,858,0)=" Q IBFOUND"
^XMB(3.9,145948,2,859,0)="""RTN"",""IBOMHC"",312,0)"
^XMB(3.9,145948,2,860,0)=" ;"
^XMB(3.9,145948,2,861,0)="""RTN"",""IBOMHC"",313,0)"
^XMB(3.9,145948,2,862,0)="DXSLIST ; List of Specific Compact Act Related Diagnosis codes"
^XMB(3.9,145948,2,863,0)="""RTN"",""IBOMHC"",314,0)"
^XMB(3.9,145948,2,864,0)=" ;;T14.91XA;0"
^XMB(3.9,145948,2,865,0)="""RTN"",""IBOMHC"",315,0)"
^XMB(3.9,145948,2,866,0)=" ;;T14.91XD;0"
^XMB(3.9,145948,2,867,0)="""RTN"",""IBOMHC"",316,0)"
^XMB(3.9,145948,2,868,0)=" ;;T14.91XS;0"
^XMB(3.9,145948,2,869,0)="""RTN"",""IBOMHC"",317,0)"
^XMB(3.9,145948,2,870,0)=" ;;R45.851;0"
^XMB(3.9,145948,2,871,0)="""RTN"",""IBOMHC"",318,0)"
^XMB(3.9,145948,2,872,0)=" ;;EXIT"
^XMB(3.9,145948,2,873,0)="""RTN"",""IBOMHC"",319,0)"
^XMB(3.9,145948,2,874,0)=" Q"
^XMB(3.9,145948,2,875,0)="""RTN"",""IBOMHC"",320,0)"
^XMB(3.9,145948,2,876,0)=" ;"
^XMB(3.9,145948,2,877,0)="""RTN"",""IBOMHC"",321,0)"
^XMB(3.9,145948,2,878,0)="GETDIV() ; Ask to filter by Division.  If so, select the division."
^XMB(3.9,145948,2,879,0)="""RTN"",""IBOMHC"",322,0)"
^XMB(3.9,145948,2,880,0)=" ;"
^XMB(3.9,145948,2,881,0)="""RTN"",""IBOMHC"",323,0)"
^XMB(3.9,145948,2,882,0)=" N DIROUT,DTOUT,DUOUT,DIRUT,X,Y"
^XMB(3.9,145948,2,883,0)="""RTN"",""IBOMHC"",324,0)"
^XMB(3.9,145948,2,884,0)=" ; Ask to filter by division."
^XMB(3.9,145948,2,885,0)="""RTN"",""IBOMHC"",325,0)"
^XMB(3.9,145948,2,886,0)=" S DIR(0)=""Y"",DIR(""B"")=""NO"""
^XMB(3.9,145948,2,887,0)="""RTN"",""IBOMHC"",326,0)"
^XMB(3.9,145948,2,888,0)=" S DIR(""A"")=""Do you wish to filter this report by division"""
^XMB(3.9,145948,2,889,0)="""RTN"",""IBOMHC"",327,0)"
^XMB(3.9,145948,2,890,0)=" S DIR(""?"")=""^S IBOFF=1 D HELP^IBJDF1H"""
^XMB(3.9,145948,2,891,0)="""RTN"",""IBOMHC"",328,0)"
^XMB(3.9,145948,2,892,0)=" D ^DIR K DIR I $D(DIRUT)!$D(DTOUT)!$D(DUOUT)!$D(DIROUT) Q -1  ; Escape command given"
^XMB(3.9,145948,2,893,0)="""RTN"",""IBOMHC"",329,0)"
^XMB(3.9,145948,2,894,0)=" S IBSD=+Y K DIROUT,DTOUT,DUOUT,DIRUT"
^XMB(3.9,145948,2,895,0)="""RTN"",""IBOMHC"",330,0)"
^XMB(3.9,145948,2,896,0)=" ;"
^XMB(3.9,145948,2,897,0)="""RTN"",""IBOMHC"",331,0)"
^XMB(3.9,145948,2,898,0)=" Q:'IBSD 0"
^XMB(3.9,145948,2,899,0)="""RTN"",""IBOMHC"",332,0)"
^XMB(3.9,145948,2,900,0)=" ;"
^XMB(3.9,145948,2,901,0)="""RTN"",""IBOMHC"",333,0)"
^XMB(3.9,145948,2,902,0)=" ;Sort/filter by division selected Ask for division"
^XMB(3.9,145948,2,903,0)="""RTN"",""IBOMHC"",334,0)"
^XMB(3.9,145948,2,904,0)=" ; - Issue prompt for division."
^XMB(3.9,145948,2,905,0)="""RTN"",""IBOMHC"",335,0)"
^XMB(3.9,145948,2,906,0)=" K X,Y N X,Y   ;Clear and reset X and Y for the next prompt"
^XMB(3.9,145948,2,907,0)="""RTN"",""IBOMHC"",336,0)"
^XMB(3.9,145948,2,908,0)=" ;"
^XMB(3.9,145948,2,909,0)="""RTN"",""IBOMHC"",337,0)"
^XMB(3.9,145948,2,910,0)=" ;Prompt for Division to filter on."
^XMB(3.9,145948,2,911,0)="""RTN"",""IBOMHC"",338,0)"
^XMB(3.9,145948,2,912,0)=" I IBSD D PSDR^IBODIV I Y<0 Q -1       ;Escape command given"
^XMB(3.9,145948,2,913,0)="""RTN"",""IBOMHC"",339,0)"
^XMB(3.9,145948,2,914,0)=" ;"
^XMB(3.9,145948,2,915,0)="""RTN"",""IBOMHC"",340,0)"
^XMB(3.9,145948,2,916,0)=" Q 1"
^XMB(3.9,145948,2,917,0)="""VER"")"
^XMB(3.9,145948,2,918,0)="8.0^22.2"
^XMB(3.9,145948,2,919,0)="$END KID IB*2.0*790b"
