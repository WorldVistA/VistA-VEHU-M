^XMB(3.9,145936,2,241,0)="""RTN"",""PSBOMH1"",1,0)"
^XMB(3.9,145936,2,242,0)="PSBOMH1 ;BIRMINGHAM/EFC-MAH ;Sep 01, 2020@15:11:32"
^XMB(3.9,145936,2,243,0)="""RTN"",""PSBOMH1"",2,0)"
^XMB(3.9,145936,2,244,0)=" ;;3.0;BAR CODE MED ADMIN;**6,3,9,11,26,38,45,51,50,57,67,64,72,83,97,112,116,120,82**;Mar 2004;Build 0"
^XMB(3.9,145936,2,245,0)="""RTN"",""PSBOMH1"",3,0)"
^XMB(3.9,145936,2,246,0)=" ;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145936,2,247,0)="""RTN"",""PSBOMH1"",4,0)"
^XMB(3.9,145936,2,248,0)=" ;"
^XMB(3.9,145936,2,249,0)="""RTN"",""PSBOMH1"",5,0)"
^XMB(3.9,145936,2,250,0)=" ; Reference/IA"
^XMB(3.9,145936,2,251,0)="""RTN"",""PSBOMH1"",6,0)"
^XMB(3.9,145936,2,252,0)=" ; ^DILF/2054"
^XMB(3.9,145936,2,253,0)="""RTN"",""PSBOMH1"",7,0)"
^XMB(3.9,145936,2,254,0)=" ; File 200/10060"
^XMB(3.9,145936,2,255,0)="""RTN"",""PSBOMH1"",8,0)"
^XMB(3.9,145936,2,256,0)=" ;"
^XMB(3.9,145936,2,257,0)="""RTN"",""PSBOMH1"",9,0)"
^XMB(3.9,145936,2,258,0)=" ;*83 - add Remove events per Give events when occurred."
^XMB(3.9,145936,2,259,0)="""RTN"",""PSBOMH1"",10,0)"
^XMB(3.9,145936,2,260,0)=" ;"
^XMB(3.9,145936,2,261,0)="""RTN"",""PSBOMH1"",11,0)"
^XMB(3.9,145936,2,262,0)="EN ;"
^XMB(3.9,145936,2,263,0)="""RTN"",""PSBOMH1"",12,0)"
^XMB(3.9,145936,2,264,0)=" ; Load administrations"
^XMB(3.9,145936,2,265,0)="""RTN"",""PSBOMH1"",13,0)"
^XMB(3.9,145936,2,266,0)=" N PSBDT,PSBADMDT,X,Y,I,S,PSBINIT,PSBNAME,PRELINE1,PSBORD,PSBIEN,PSBR1,PSBADIEN,PSBABR,PSBLINE1,PSBLINE2,PSBRTXTW,PSBS,PSBTAR"
^XMB(3.9,145936,2,267,0)="""RTN"",""PSBOMH1"",14,0)"
^XMB(3.9,145936,2,268,0)=" S (PSBORD,PSBIEN,PSBR1,PSBADIEN,PSBABR)="""",PSBDT=PSBSTRT"
^XMB(3.9,145936,2,269,0)="""RTN"",""PSBOMH1"",15,0)"
^XMB(3.9,145936,2,270,0)=" ;ERROR"
^XMB(3.9,145936,2,271,0)="""RTN"",""PSBOMH1"",16,0)"
^XMB(3.9,145936,2,272,0)=" F  S PSBDT=$O(^PSB(53.79,""AADT"",DFN,PSBDT)) Q:'PSBDT  D"
^XMB(3.9,145936,2,273,0)="""RTN"",""PSBOMH1"",17,0)"
^XMB(3.9,145936,2,274,0)=" .F  S PSBIEN=$O(^PSB(53.79,""AADT"",DFN,PSBDT,PSBIEN)) Q:'PSBIEN  Q:'$D(^PSB(53.79,PSBIEN))  I $P(^PSB(53.79,PSBIEN,0),U,9)]"""" D  ;Remove Lock as file is only read, PSB*3*64"
^XMB(3.9,145936,2,275,0)="""RTN"",""PSBOMH1"",18,0)"
^XMB(3.9,145936,2,276,0)=" ..Q:'$P($G(^PSB(53.79,PSBIEN,0)),U,6)  ; Bad IEN -no evnt dt"
^XMB(3.9,145936,2,277,0)="""RTN"",""PSBOMH1"",19,0)"
^XMB(3.9,145936,2,278,0)=" ..Q:$P(^PSB(53.79,PSBIEN,0),U,9)=""N""  ;NGiven"
^XMB(3.9,145936,2,279,0)="""RTN"",""PSBOMH1"",20,0)"
^XMB(3.9,145936,2,280,0)=" ..S PSBADMDT=PSBDT I $P(^PSB(53.79,PSBIEN,0),U,9)=""RM"" S:(PSBDT>PSBSTOP) PSBADMDT=+$$FINDGIVE^PSBUTL(PSBIEN) I ((PSBADMDT<PSBSTRT)!(PSBADMDT>PSBSTOP))&(PSBDT>PSBSTOP) Q"
^XMB(3.9,145936,2,281,0)="""RTN"",""PSBOMH1"",21,0)"
^XMB(3.9,145936,2,282,0)=" ..I $P(^PSB(53.79,PSBIEN,0),U,9)'=""RM"",PSBDT>PSBSTOP Q"
^XMB(3.9,145936,2,283,0)="""RTN"",""PSBOMH1"",22,0)"
^XMB(3.9,145936,2,284,0)=" ..S PSBORD=$P($G(^PSB(53.79,PSBIEN,.1)),U,1)"
^XMB(3.9,145936,2,285,0)="""RTN"",""PSBOMH1"",23,0)"
^XMB(3.9,145936,2,286,0)=" ..;PSB*3*45 Anyone on the audit log should be in the legend"
^XMB(3.9,145936,2,287,0)="""RTN"",""PSBOMH1"",24,0)"
^XMB(3.9,145936,2,288,0)=" ..N TMPCT S TMPCT=0 F  S TMPCT=$O(^PSB(53.79,PSBIEN,.9,TMPCT)) Q:'TMPCT  D"
^XMB(3.9,145936,2,289,0)="""RTN"",""PSBOMH1"",25,0)"
^XMB(3.9,145936,2,290,0)=" ...S PSBINIT=$$GET1^DIQ(53.799,TMPCT_"",""_PSBIEN,""USER:INITIAL""),PSBNAME=$$GET1^DIQ(53.799,TMPCT_"",""_PSBIEN_"","",""USER"")"
^XMB(3.9,145936,2,291,0)="""RTN"",""PSBOMH1"",26,0)"
^XMB(3.9,145936,2,292,0)=" ...S:PSBINIT="""" PSBINIT=99"
^XMB(3.9,145936,2,293,0)="""RTN"",""PSBOMH1"",27,0)"
^XMB(3.9,145936,2,294,0)=" ...S ^TMP(""PSB"",$J,""LEGEND"",PSBINIT,PSBNAME)="""""
^XMB(3.9,145936,2,295,0)="""RTN"",""PSBOMH1"",28,0)"
^XMB(3.9,145936,2,296,0)=" ..; Continuous"
^XMB(3.9,145936,2,297,0)="""RTN"",""PSBOMH1"",29,0)"
^XMB(3.9,145936,2,298,0)=" ..D:$P($G(^PSB(53.79,PSBIEN,.1)),U,2)=""C"""
^XMB(3.9,145936,2,299,0)="""RTN"",""PSBOMH1"",30,0)"
^XMB(3.9,145936,2,300,0)=" ...S X=PSBADMDT D H^%DTC S PSBWEEK=+$G(PSBAR(%H)) D CLEAN^PSBVT,PSJ1^PSBVT($P(^PSB(53.79,PSBIEN,0),U,1),$P(^PSB(53.79,PSBIEN,.1),U,1))"
^XMB(3.9,145936,2,301,0)="""RTN"",""PSBOMH1"",31,0)"
^XMB(3.9,145936,2,302,0)=" ...I $P(^PSB(53.79,PSBIEN,0),U,6)'=PSBDT,'$$IVPTAB^PSBVDLU3(PSBOTYP,PSBIVT,PSBISYR,PSBCHEMT,PSBIVPSH) D  D CLEAN^PSBVT Q  ;chck IV audit"
^XMB(3.9,145936,2,303,0)="""RTN"",""PSBOMH1"",32,0)"
^XMB(3.9,145936,2,304,0)=" ....S PSBSIEN=PSBIEN"
^XMB(3.9,145936,2,305,0)="""RTN"",""PSBOMH1"",33,0)"
^XMB(3.9,145936,2,306,0)=" ....I $P(^PSB(53.79,PSBIEN,0),""^"",10)]"""" D BAGDTL^PSBRPC2(.PSBAUD,$P(^PSB(53.79,PSBIEN,0),U,10),$P(^PSB(53.79,PSBIEN,.1),U,1))"
^XMB(3.9,145936,2,307,0)="""RTN"",""PSBOMH1"",34,0)"
^XMB(3.9,145936,2,308,0)=" ....S PSBIEN=PSBSIEN K PSBSIEN"
^XMB(3.9,145936,2,309,0)="""RTN"",""PSBOMH1"",35,0)"
^XMB(3.9,145936,2,310,0)=" ....S X=0 F  S X=$O(PSBAUD(X)) Q:X=""""  I $P(PSBAUD(X),U,3)="""" K PSBAUD(X)"
^XMB(3.9,145936,2,311,0)="""RTN"",""PSBOMH1"",36,0)"
^XMB(3.9,145936,2,312,0)=" ....S X=0 F  S X=$O(PSBAUD(X)) Q:X=""""  Q:$P(PSBAUD(X),U,1)=PSBDT"
^XMB(3.9,145936,2,313,0)="""RTN"",""PSBOMH1"",37,0)"
^XMB(3.9,145936,2,314,0)=" ....I X="""" K PSBAUD Q"
^XMB(3.9,145936,2,315,0)="""RTN"",""PSBOMH1"",38,0)"
^XMB(3.9,145936,2,316,0)=" ....I '$D(PSBAUD(X)) K PSBAUD Q"
^XMB(3.9,145936,2,317,0)="""RTN"",""PSBOMH1"",39,0)"
^XMB(3.9,145936,2,318,0)=" ....S PSBS=$P(PSBAUD(X),U,3)"
^XMB(3.9,145936,2,319,0)="""RTN"",""PSBOMH1"",40,0)"
^XMB(3.9,145936,2,320,0)=" ....I PSBS=""GIVEN"",$P($G(PSBAUD(X-1)),U,3)=""NOT GIVEN"" Q"
^XMB(3.9,145936,2,321,0)="""RTN"",""PSBOMH1"",41,0)"
^XMB(3.9,145936,2,322,0)=" ....I PSBS=""NOT GIVEN"" Q"
^XMB(3.9,145936,2,323,0)="""RTN"",""PSBOMH1"",42,0)"
^XMB(3.9,145936,2,324,0)=" ....S PSBS=$S(PSBS=""INFUSING"":""I"",PSBS=""GIVEN"":""G"",PSBS=""COMPLETED"":""C"",PSBS=""HELD"":""H"",PSBS=""REFUSED"":""R"",PSBS=""REMOVED"":""RM"",PSBS=""STOPPED"":""S"",PSBS[""MISSING"":""M"",1:""NOACTION"")"
^XMB(3.9,145936,2,325,0)="""RTN"",""PSBOMH1"",43,0)"
^XMB(3.9,145936,2,326,0)=" ....D PSBSTIV^PSBOMH2"
^XMB(3.9,145936,2,327,0)="""RTN"",""PSBOMH1"",44,0)"
^XMB(3.9,145936,2,328,0)=" ....S X=PSBDT_U_$P(PSBAUD(X),U,2)_U_PSBS_U_PSBIEN"
^XMB(3.9,145936,2,329,0)="""RTN"",""PSBOMH1"",45,0)"
^XMB(3.9,145936,2,330,0)=" ....S Y=$O(^TMP(""PSB"",$J,PSBWEEK,PSBORD,PSBDT\1,""""),-1)+1"
^XMB(3.9,145936,2,331,0)="""RTN"",""PSBOMH1"",46,0)"
^XMB(3.9,145936,2,332,0)=" ....S ^TMP(""PSB"",$J,PSBWEEK,PSBORD,PSBDT\1,Y)=X ;PSB*3*67"
^XMB(3.9,145936,2,333,0)="""RTN"",""PSBOMH1"",47,0)"
^XMB(3.9,145936,2,334,0)=" ....S ^TMP(""PSB"",$J,PSBWEEK,PSBORD,PSBDT\1,0)=Y"
^XMB(3.9,145936,2,335,0)="""RTN"",""PSBOMH1"",48,0)"
^XMB(3.9,145936,2,336,0)=" ....D PSBOUT($P((X),""^"",1),$P((X),""^"",2))"
^XMB(3.9,145936,2,337,0)="""RTN"",""PSBOMH1"",49,0)"
^XMB(3.9,145936,2,338,0)=" ....K PSBAUD"
^XMB(3.9,145936,2,339,0)="""RTN"",""PSBOMH1"",50,0)"
^XMB(3.9,145936,2,340,0)=" ...S PSBINIT=$$GETINIT^PSBCSUTX(PSBIEN,""I"") ;Get initials of who took action, PSB*3*72"
^XMB(3.9,145936,2,341,0)="""RTN"",""PSBOMH1"",51,0)"
^XMB(3.9,145936,2,342,0)=" ...S PSBNAME=$$GETINIT^PSBCSUTX(PSBIEN,""N"") ;Get name of who took action, PSB*3*72"
^XMB(3.9,145936,2,343,0)="""RTN"",""PSBOMH1"",52,0)"
^XMB(3.9,145936,2,344,0)=" ...I PSBINIT="""" S PSBINIT=99"
^XMB(3.9,145936,2,345,0)="""RTN"",""PSBOMH1"",53,0)"
^XMB(3.9,145936,2,346,0)=" ...;get instrc info - audt log"
^XMB(3.9,145936,2,347,0)="""RTN"",""PSBOMH1"",54,0)"
^XMB(3.9,145936,2,348,0)=" ...I $D(^PSB(53.79,PSBIEN,.9,$P(PSBDT,"".""))) D"
^XMB(3.9,145936,2,349,0)="""RTN"",""PSBOMH1"",55,0)"
^XMB(3.9,145936,2,350,0)=" ....D INSTR^PSBOMH"
^XMB(3.9,145936,2,351,0)="""RTN"",""PSBOMH1"",56,0)"
^XMB(3.9,145936,2,352,0)=" ....S ^TMP(""PSB"",$J,""LEGEND"",PSBINIT,PSBNAME)="""""
^XMB(3.9,145936,2,353,0)="""RTN"",""PSBOMH1"",57,0)"
