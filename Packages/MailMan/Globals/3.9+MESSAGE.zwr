^XMB(3.9,145983,2,1782,0)=" ;"
^XMB(3.9,145983,2,1783,0)="""RTN"",""RCRPU1"",7,0)"
^XMB(3.9,145983,2,1784,0)="UPDTERMS(RCRPIEN,RCPLNS,RCRVW) ; Update the terms of the plan.  PRCA*4.5*389"
^XMB(3.9,145983,2,1785,0)="""RTN"",""RCRPU1"",8,0)"
