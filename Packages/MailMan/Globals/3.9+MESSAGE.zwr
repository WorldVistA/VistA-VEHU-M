^XMB(3.9,145989,2,1806,0)=" Q"
^XMB(3.9,145989,2,1807,0)="""RTN"",""PSOSPML3"",103,0)"
^XMB(3.9,145989,2,1808,0)=" ;"
^XMB(3.9,145989,2,1809,0)="""RTN"",""PSOSPML3"",104,0)"
^XMB(3.9,145989,2,1810,0)="HELP ; Listman Help"
^XMB(3.9,145989,2,1811,0)="""RTN"",""PSOSPML3"",105,0)"
^XMB(3.9,145989,2,1812,0)=" Q"
^XMB(3.9,145989,2,1813,0)="""RTN"",""PSOSPML3"",106,0)"
^XMB(3.9,145989,2,1814,0)=" ;"
^XMB(3.9,145989,2,1815,0)="""RTN"",""PSOSPML3"",107,0)"
^XMB(3.9,145989,2,1816,0)="EXIT ;"
^XMB(3.9,145989,2,1817,0)="""RTN"",""PSOSPML3"",108,0)"
^XMB(3.9,145989,2,1818,0)=" K ^TMP(""PSOSPML3"",$J)"
^XMB(3.9,145989,2,1819,0)="""RTN"",""PSOSPML3"",109,0)"
^XMB(3.9,145989,2,1820,0)=" Q"
^XMB(3.9,145989,2,1821,0)="""RTN"",""PSOSPML3"",110,0)"
^XMB(3.9,145989,2,1822,0)=" ;"
^XMB(3.9,145989,2,1823,0)="""RTN"",""PSOSPML3"",111,0)"
^XMB(3.9,145989,2,1824,0)="MEXPRHLP(LEVEL,ELMID) ;MUMPS Expression Help Text"
^XMB(3.9,145989,2,1825,0)="""RTN"",""PSOSPML3"",112,0)"
^XMB(3.9,145989,2,1826,0)=" ;Input: (r) LEVEL - Level of the Segment where the Data Element is located"
^XMB(3.9,145989,2,1827,0)="""RTN"",""PSOSPML3"",113,0)"
^XMB(3.9,145989,2,1828,0)=" ;       (r) ELMID  - Data Element ID (""PHA01"", ""DSP02"", etc.)"
^XMB(3.9,145989,2,1829,0)="""RTN"",""PSOSPML3"",114,0)"
^XMB(3.9,145989,2,1830,0)=" N LEVNAM,DIR,X,Y,DIRUT,DTOUT"
^XMB(3.9,145989,2,1831,0)="""RTN"",""PSOSPML3"",115,0)"
^XMB(3.9,145989,2,1832,0)=" W !,""This is the argument of a MUMPS SET command that will be used to retrieve the"""
^XMB(3.9,145989,2,1833,0)="""RTN"",""PSOSPML3"",116,0)"
^XMB(3.9,145989,2,1834,0)=" W !,""value for the Data Element '"",ELMID,""'."""
^XMB(3.9,145989,2,1835,0)="""RTN"",""PSOSPML3"",117,0)"
^XMB(3.9,145989,2,1836,0)=" W !,"""""
^XMB(3.9,145989,2,1837,0)="""RTN"",""PSOSPML3"",118,0)"
^XMB(3.9,145989,2,1838,0)=" W !,""Below are some examples of valid values for this field:"""
^XMB(3.9,145989,2,1839,0)="""RTN"",""PSOSPML3"",119,0)"
^XMB(3.9,145989,2,1840,0)=" W !,"""""
^XMB(3.9,145989,2,1841,0)="""RTN"",""PSOSPML3"",120,0)"
^XMB(3.9,145989,2,1842,0)=" W !,""Null/Blank : Use """""""" (two quotes) to force a blank value. Another option to"""
^XMB(3.9,145989,2,1843,0)="""RTN"",""PSOSPML3"",121,0)"
^XMB(3.9,145989,2,1844,0)=" W !,""-----------  force a blank value is to set the Data Element REQUIREMENT field"""
^XMB(3.9,145989,2,1845,0)="""RTN"",""PSOSPML3"",122,0)"
^XMB(3.9,145989,2,1846,0)=" W !,""             to 'N' (NOT USED)."""
^XMB(3.9,145989,2,1847,0)="""RTN"",""PSOSPML3"",123,0)"
^XMB(3.9,145989,2,1848,0)=" W !,"""""
^XMB(3.9,145989,2,1849,0)="""RTN"",""PSOSPML3"",124,0)"
^XMB(3.9,145989,2,1850,0)=" W !,""Fixed Value: Use quotes to force a fixed value for this Data Element."""
^XMB(3.9,145989,2,1851,0)="""RTN"",""PSOSPML3"",125,0)"
^XMB(3.9,145989,2,1852,0)=" W !,""-----------  Examples: """"AF290303"""", """"SMITH"""", """"12345"""", etc."""
^XMB(3.9,145989,2,1853,0)="""RTN"",""PSOSPML3"",126,0)"
^XMB(3.9,145989,2,1854,0)=" W !,"""""
^XMB(3.9,145989,2,1855,0)="""RTN"",""PSOSPML3"",127,0)"
^XMB(3.9,145989,2,1856,0)=" W !,""MUMPS Code : Use a Mumps expression that can be used as the argument of a SET"""
^XMB(3.9,145989,2,1857,0)="""RTN"",""PSOSPML3"",128,0)"
^XMB(3.9,145989,2,1858,0)=" W !,""-----------  command. Examples:  $P($$SITE^VASITE(),""""^"""",2)"""
^XMB(3.9,145989,2,1859,0)="""RTN"",""PSOSPML3"",129,0)"
^XMB(3.9,145989,2,1860,0)=" W !,""                                 $E($$GET1^DIQ(52,RXIEN,.01),1,30)"""
^XMB(3.9,145989,2,1861,0)="""RTN"",""PSOSPML3"",130,0)"
^XMB(3.9,145989,2,1862,0)=" W !,""                                 $S(FILLIEN>0:""""REFILL"""",1:""""ORIGINAL"""")"""
^XMB(3.9,145989,2,1863,0)="""RTN"",""PSOSPML3"",131,0)"
^XMB(3.9,145989,2,1864,0)=" W !,""                                 $$PHA03^PSOASAP()_""""B"""""""
^XMB(3.9,145989,2,1865,0)="""RTN"",""PSOSPML3"",132,0)"
^XMB(3.9,145989,2,1866,0)=" W !,"""""
^XMB(3.9,145989,2,1867,0)="""RTN"",""PSOSPML3"",133,0)"
^XMB(3.9,145989,2,1868,0)=" W !,""NOTE: The value for a Standard Definition Data Element is returned by a"""
^XMB(3.9,145989,2,1869,0)="""RTN"",""PSOSPML3"",134,0)"
^XMB(3.9,145989,2,1870,0)=" W !,""      function in the format $$SEGNN^PSOASAP(), where 'SEG' is the 2 or"""
^XMB(3.9,145989,2,1871,0)="""RTN"",""PSOSPML3"",135,0)"
^XMB(3.9,145989,2,1872,0)=" W !,""      3-character segment identifier and 'NN' is the 2-digit element"""
^XMB(3.9,145989,2,1873,0)="""RTN"",""PSOSPML3"",136,0)"
^XMB(3.9,145989,2,1874,0)=" W !,""      identifier. Examples: $$IS01^PSOASAP(), $$PRE08^PSOASAP(), etc."""
^XMB(3.9,145989,2,1875,0)="""RTN"",""PSOSPML3"",137,0)"
^XMB(3.9,145989,2,1876,0)=" ;"
^XMB(3.9,145989,2,1877,0)="""RTN"",""PSOSPML3"",138,0)"
^XMB(3.9,145989,2,1878,0)=" K DIR S DIR(""A"")=""Press Return to continue"",DIR(0)=""E"" D ^DIR"
^XMB(3.9,145989,2,1879,0)="""RTN"",""PSOSPML3"",139,0)"
^XMB(3.9,145989,2,1880,0)=" W !,"""""
^XMB(3.9,145989,2,1881,0)="""RTN"",""PSOSPML3"",140,0)"
^XMB(3.9,145989,2,1882,0)=" S LEVNAM=$P(""^PHARMACY HEADER^PATIENT DETAIL^PRESCRIPTION DETAIL^PHARMACY TRAILER^"",""^"",LEVEL)"
^XMB(3.9,145989,2,1883,0)="""RTN"",""PSOSPML3"",141,0)"
^XMB(3.9,145989,2,1884,0)=" W !,""The following variables are available at the "",LEVNAM,"" level for"""
^XMB(3.9,145989,2,1885,0)="""RTN"",""PSOSPML3"",142,0)"
^XMB(3.9,145989,2,1886,0)=" W !,""customizing this Data Element:"""
^XMB(3.9,145989,2,1887,0)="""RTN"",""PSOSPML3"",143,0)"
^XMB(3.9,145989,2,1888,0)=" W !,"""""
^XMB(3.9,145989,2,1889,0)="""RTN"",""PSOSPML3"",144,0)"
^XMB(3.9,145989,2,1890,0)=" W !,""   STATEIEN - State IEN. Pointer to STATE file (#5)."""
^XMB(3.9,145989,2,1891,0)="""RTN"",""PSOSPML3"",145,0)"
^XMB(3.9,145989,2,1892,0)=" I LEVEL=1!(LEVEL=6) Q"
^XMB(3.9,145989,2,1893,0)="""RTN"",""PSOSPML3"",146,0)"
^XMB(3.9,145989,2,1894,0)=" W !,""   SITEIEN  - Pharmacy Division IEN. Pointer to OUTPATIENT SITE file (#59)."""
^XMB(3.9,145989,2,1895,0)="""RTN"",""PSOSPML3"",147,0)"
^XMB(3.9,145989,2,1896,0)=" I LEVEL=2!(LEVEL=5) Q"
^XMB(3.9,145989,2,1897,0)="""RTN"",""PSOSPML3"",148,0)"
^XMB(3.9,145989,2,1898,0)=" W !,""   PATIEN   - Patient IEN. Pointer to the PATIENT file (#2)."""
^XMB(3.9,145989,2,1899,0)="""RTN"",""PSOSPML3"",149,0)"
^XMB(3.9,145989,2,1900,0)=" I LEVEL=3 Q"
^XMB(3.9,145989,2,1901,0)="""RTN"",""PSOSPML3"",150,0)"
^XMB(3.9,145989,2,1902,0)=" W !,""   RXIEN    - Prescription IEN. Pointer to the PRESCRIPTION file (#52)."""
^XMB(3.9,145989,2,1903,0)="""RTN"",""PSOSPML3"",151,0)"
^XMB(3.9,145989,2,1904,0)=" W !,""   DRUGIEN  - Drug IEN. Pointer to the DRUG File (#50)"""
^XMB(3.9,145989,2,1905,0)="""RTN"",""PSOSPML3"",152,0)"
^XMB(3.9,145989,2,1906,0)=" W !,""   FILLNUM  - Fill Number ('0': Original Fill,'1': Refill #1,'2': Refill #2,"""
^XMB(3.9,145989,2,1907,0)="""RTN"",""PSOSPML3"",153,0)"
^XMB(3.9,145989,2,1908,0)=" W !,""              'P1': Partial #1,'P2': Partial Fill #2, etc.)"""
^XMB(3.9,145989,2,1909,0)="""RTN"",""PSOSPML3"",154,0)"
^XMB(3.9,145989,2,1910,0)=" W !,""   FILLIEN  - Pointer to the REFILL sub-file (#52.1) or PARTIAL sub-file (#52.2)"""
^XMB(3.9,145989,2,1911,0)="""RTN"",""PSOSPML3"",155,0)"
^XMB(3.9,145989,2,1912,0)=" W !,""              ('0': Original, N: Pointer to Refill or Partial fill)"""
^XMB(3.9,145989,2,1913,0)="""RTN"",""PSOSPML3"",156,0)"
^XMB(3.9,145989,2,1914,0)=" W !,""   RPHIEN   - Pharmacist IEN. Pointer to NEW PERSON file (#200)."""
^XMB(3.9,145989,2,1915,0)="""RTN"",""PSOSPML3"",157,0)"
^XMB(3.9,145989,2,1916,0)=" W !,""   PREIEN   - Prescriber IEN.  Pointer to NEW PERSON file (#200)."""
^XMB(3.9,145989,2,1917,0)="""RTN"",""PSOSPML3"",158,0)"
^XMB(3.9,145989,2,1918,0)=" W !,""   RTSREC   - Return To Stock Record? ('1': YES / '0': NO)"""
^XMB(3.9,145989,2,1919,0)="""RTN"",""PSOSPML3"",159,0)"
^XMB(3.9,145989,2,1920,0)=" Q"
^XMB(3.9,145989,2,1921,0)="""RTN"",""PSOSPML3"",160,0)"
^XMB(3.9,145989,2,1922,0)=" ;pso*7*772"
^XMB(3.9,145989,2,1923,0)="""RTN"",""PSOSPML3"",161,0)"
^XMB(3.9,145989,2,1924,0)="ACTIONS() ;screen actions on view/edit asap definitions"
^XMB(3.9,145989,2,1925,0)="""RTN"",""PSOSPML3"",162,0)"
