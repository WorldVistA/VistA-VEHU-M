^XMB(3.9,145980,2,6509,0)="""RTN"",""SDESRECALLREQ"",1,0)"
^XMB(3.9,145980,2,6510,0)="SDESRECALLREQ ;ALB/BWF/BLB,BLB/JAS,JHC - VISTA SCHEDULING RECALL/APPT REQUEST RPCS ; DEC 22, 2025"
^XMB(3.9,145980,2,6511,0)="""RTN"",""SDESRECALLREQ"",2,0)"
^XMB(3.9,145980,2,6512,0)=" ;;5.3;Scheduling;**835,847,853,875,877,909**;Aug 13, 1993;Build 0"
^XMB(3.9,145980,2,6513,0)="""RTN"",""SDESRECALLREQ"",3,0)"
^XMB(3.9,145980,2,6514,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
