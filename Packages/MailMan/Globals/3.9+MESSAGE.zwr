^XMB(3.9,145984,2,2016,0)=" ;"
^XMB(3.9,145984,2,2017,0)="""RTN"",""PSOERXI1"",160,0)"
^XMB(3.9,145984,2,2018,0)=" ;Saving the eRx Audit Log For Auto-Matched Patient"
^XMB(3.9,145984,2,2019,0)="""RTN"",""PSOERXI1"",161,0)"
^XMB(3.9,145984,2,2020,0)=" S DFN=+$G(FDA(52.49,CURREC,.05))"
^XMB(3.9,145984,2,2021,0)="""RTN"",""PSOERXI1"",162,0)"
^XMB(3.9,145984,2,2022,0)=" I DFN  D"
^XMB(3.9,145984,2,2023,0)="""RTN"",""PSOERXI1"",163,0)"
^XMB(3.9,145984,2,2024,0)=" . N VADM D DEM^VADPT"
^XMB(3.9,145984,2,2025,0)="""RTN"",""PSOERXI1"",164,0)"
^XMB(3.9,145984,2,2026,0)=" . S NEWVAL(1)=$$GET1^DIQ(2,DFN,.01)_"" (L4SSN: ""_$P($P(VADM(2),""^"",2),""-"",3)_"" | DOB: ""_$P(VADM(3),""^"",2)_"")"""
^XMB(3.9,145984,2,2027,0)="""RTN"",""PSOERXI1"",165,0)"
