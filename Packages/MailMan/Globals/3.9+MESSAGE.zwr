^XMB(3.9,145946,2,4895,0)="""RTN"",""IBCNILK"",279,0)"
^XMB(3.9,145946,2,4896,0)=" N DIR,DIROUT,DIRUT,DLINE,DTOUT,DUOUT,ERROR,IEN,IIENS,IX,LINE,PROMPT"
^XMB(3.9,145946,2,4897,0)="""RTN"",""IBCNILK"",280,0)"
^XMB(3.9,145946,2,4898,0)=" S VALMBCK=""R"",ERROR=0"
^XMB(3.9,145946,2,4899,0)="""RTN"",""IBCNILK"",281,0)"
^XMB(3.9,145946,2,4900,0)=" ; "
^XMB(3.9,145946,2,4901,0)="""RTN"",""IBCNILK"",282,0)"
^XMB(3.9,145946,2,4902,0)=" ; First select the Insurance Company(s) to be selected"
^XMB(3.9,145946,2,4903,0)="""RTN"",""IBCNILK"",283,0)"
^XMB(3.9,145946,2,4904,0)=" S PROMPT=""SELECT Insurance Company(s)""     ;IB*763/CKB"
