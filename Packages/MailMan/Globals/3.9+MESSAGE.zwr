^XMB(3.9,145981,2,334,0)=" ... S IBERROR=""Billing Clock found at site #""_(DUZ(2))_"" but manual review is needed"""
^XMB(3.9,145981,2,335,0)="""RTN"",""IBECECX1"",48,0)"
