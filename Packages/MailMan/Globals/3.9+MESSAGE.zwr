^XMB(3.9,145986,2,3457,0)="""RTN"",""FBPAY671"",113,0)"
^XMB(3.9,145986,2,3458,0)=" I I=1!($X+$L($P(FBDATA,""^"",I))+2>IOM) W !,?4,""DX/POA: """
