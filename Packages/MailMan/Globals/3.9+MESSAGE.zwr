^XMB(3.9,145983,2,1532,0)=" S ^TMP($J,""RPPFLDNO"",1,2)=1.11    ;New to Current"
^XMB(3.9,145983,2,1533,0)="""RTN"",""RCRPNP"",220,0)"
^XMB(3.9,145983,2,1534,0)=" S ^TMP($J,""RPPFLDNO"",2,3)=1.12    ;Current to Late"
^XMB(3.9,145983,2,1535,0)="""RTN"",""RCRPNP"",221,0)"
