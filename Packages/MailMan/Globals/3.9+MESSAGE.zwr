^XMB(3.9,145946,2,2731,0)="""RTN"",""IBCNEDE3"",104,0)"
^XMB(3.9,145946,2,2732,0)=" ; -- Output:"
^XMB(3.9,145946,2,2733,0)="""RTN"",""IBCNEDE3"",105,0)"
^XMB(3.9,145946,2,2734,0)=" ; EVAL 1 = Evaluation for inclusion"
^XMB(3.9,145946,2,2735,0)="""RTN"",""IBCNEDE3"",106,0)"
^XMB(3.9,145946,2,2736,0)=" ;      0 = DO NOT Evaluate"
^XMB(3.9,145946,2,2737,0)="""RTN"",""IBCNEDE3"",107,0)"
^XMB(3.9,145946,2,2738,0)=" ;"
^XMB(3.9,145946,2,2739,0)="""RTN"",""IBCNEDE3"",108,0)"
^XMB(3.9,145946,2,2740,0)=" N GRP,EFFDT,EVAL,EXPDT,INSIEN"
^XMB(3.9,145946,2,2741,0)="""RTN"",""IBCNEDE3"",109,0)"
^XMB(3.9,145946,2,2742,0)=" ;Initialize variables"
^XMB(3.9,145946,2,2743,0)="""RTN"",""IBCNEDE3"",110,0)"
^XMB(3.9,145946,2,2744,0)=" S EVAL=0"
^XMB(3.9,145946,2,2745,0)="""RTN"",""IBCNEDE3"",111,0)"
^XMB(3.9,145946,2,2746,0)=" S EFFDT=$$GET1^DIQ(2.312,PINS_"",""_PIEN_"","",8,""I"")"
^XMB(3.9,145946,2,2747,0)="""RTN"",""IBCNEDE3"",112,0)"
^XMB(3.9,145946,2,2748,0)=" S EXPDT=$$GET1^DIQ(2.312,PINS_"",""_PIEN_"","",3,""I"")"
^XMB(3.9,145946,2,2749,0)="""RTN"",""IBCNEDE3"",113,0)"
^XMB(3.9,145946,2,2750,0)=" S GRP=$$GET1^DIQ(2.312,PINS_"",""_PIEN_"","",.18,""I"")"
^XMB(3.9,145946,2,2751,0)="""RTN"",""IBCNEDE3"",114,0)"
^XMB(3.9,145946,2,2752,0)=" ;"
^XMB(3.9,145946,2,2753,0)="""RTN"",""IBCNEDE3"",115,0)"
^XMB(3.9,145946,2,2754,0)=" ;Insurance Company entry doesn't exist"
^XMB(3.9,145946,2,2755,0)="""RTN"",""IBCNEDE3"",116,0)"
^XMB(3.9,145946,2,2756,0)=" S INSIEN=+X ;insurance company internal entry (#36)"
^XMB(3.9,145946,2,2757,0)="""RTN"",""IBCNEDE3"",117,0)"
^XMB(3.9,145946,2,2758,0)=" I $G(^DIC(36,INSIEN,0))="""" G CHKQ"
^XMB(3.9,145946,2,2759,0)="""RTN"",""IBCNEDE3"",118,0)"
^XMB(3.9,145946,2,2760,0)=" ;Insurance Company Inactive"
^XMB(3.9,145946,2,2761,0)="""RTN"",""IBCNEDE3"",119,0)"
^XMB(3.9,145946,2,2762,0)=" I $$GET1^DIQ(36,INSIEN_"","",.05,""I"") G CHKQ"
^XMB(3.9,145946,2,2763,0)="""RTN"",""IBCNEDE3"",120,0)"
^XMB(3.9,145946,2,2764,0)=" ;Group Plan is Inactive"
^XMB(3.9,145946,2,2765,0)="""RTN"",""IBCNEDE3"",121,0)"
^XMB(3.9,145946,2,2766,0)=" I $$GET1^DIQ(355.3,GRP_"","",.11,""I"") G CHKQ"
^XMB(3.9,145946,2,2767,0)="""RTN"",""IBCNEDE3"",122,0)"
^XMB(3.9,145946,2,2768,0)=" ;"
^XMB(3.9,145946,2,2769,0)="""RTN"",""IBCNEDE3"",123,0)"
^XMB(3.9,145946,2,2770,0)=" ; - DO NOT Evaluate for inclusion"
^XMB(3.9,145946,2,2771,0)="""RTN"",""IBCNEDE3"",124,0)"
^XMB(3.9,145946,2,2772,0)=" ;Effective Date is in the future"
^XMB(3.9,145946,2,2773,0)="""RTN"",""IBCNEDE3"",125,0)"
^XMB(3.9,145946,2,2774,0)=" I EFFDT>Z S EVAL=0"
^XMB(3.9,145946,2,2775,0)="""RTN"",""IBCNEDE3"",126,0)"
^XMB(3.9,145946,2,2776,0)=" ;Expiration Date prior to today "
^XMB(3.9,145946,2,2777,0)="""RTN"",""IBCNEDE3"",127,0)"
^XMB(3.9,145946,2,2778,0)=" I EXPDT<Z S EVAL=0"
^XMB(3.9,145946,2,2779,0)="""RTN"",""IBCNEDE3"",128,0)"
^XMB(3.9,145946,2,2780,0)=" ;Effective Date is in the future ;Expiration Date is in the future"
^XMB(3.9,145946,2,2781,0)="""RTN"",""IBCNEDE3"",129,0)"
^XMB(3.9,145946,2,2782,0)=" I EFFDT>Z I EXPDT>Z S EVAL=0"
^XMB(3.9,145946,2,2783,0)="""RTN"",""IBCNEDE3"",130,0)"
^XMB(3.9,145946,2,2784,0)=" ;"
^XMB(3.9,145946,2,2785,0)="""RTN"",""IBCNEDE3"",131,0)"
^XMB(3.9,145946,2,2786,0)=" ; - Evaluate for inclusion"
^XMB(3.9,145946,2,2787,0)="""RTN"",""IBCNEDE3"",132,0)"
^XMB(3.9,145946,2,2788,0)=" ;Effective Date is today or past ;Expiration Date is today or null or future "
^XMB(3.9,145946,2,2789,0)="""RTN"",""IBCNEDE3"",133,0)"
^XMB(3.9,145946,2,2790,0)=" I EFFDT=Z!(EFFDT<Z) I ((EXPDT=Z)!(EXPDT>Z)!(EXPDT="""")) S EVAL=1"
^XMB(3.9,145946,2,2791,0)="""RTN"",""IBCNEDE3"",134,0)"
^XMB(3.9,145946,2,2792,0)=" ;BAD Effective Date     ;BLANK Expiration Date"
^XMB(3.9,145946,2,2793,0)="""RTN"",""IBCNEDE3"",135,0)"
^XMB(3.9,145946,2,2794,0)=" I $$VALIDDT^IBCNINSU(EFFDT)<0 I EXPDT="""" S EVAL=1"
^XMB(3.9,145946,2,2795,0)="""RTN"",""IBCNEDE3"",136,0)"
^XMB(3.9,145946,2,2796,0)=" ;BLANK Effective Date   ;BLANK Expiration Date"
^XMB(3.9,145946,2,2797,0)="""RTN"",""IBCNEDE3"",137,0)"
^XMB(3.9,145946,2,2798,0)=" I EFFDT="""" I EXPDT="""" S EVAL=1"
^XMB(3.9,145946,2,2799,0)="""RTN"",""IBCNEDE3"",138,0)"
^XMB(3.9,145946,2,2800,0)=" ;BLANK Effective Date   ;Expiration Date in the future"
^XMB(3.9,145946,2,2801,0)="""RTN"",""IBCNEDE3"",139,0)"
^XMB(3.9,145946,2,2802,0)=" I EFFDT="""" I EXPDT>Z S EVAL=1"
^XMB(3.9,145946,2,2803,0)="""RTN"",""IBCNEDE3"",140,0)"
^XMB(3.9,145946,2,2804,0)=" ;BAD Effective Date     ;BAD Expiration Date"
^XMB(3.9,145946,2,2805,0)="""RTN"",""IBCNEDE3"",141,0)"
^XMB(3.9,145946,2,2806,0)=" I $$VALIDDT^IBCNINSU(EFFDT)<0 I $$VALIDDT^IBCNINSU(EXPDT)<0 S EVAL=1"
^XMB(3.9,145946,2,2807,0)="""RTN"",""IBCNEDE3"",142,0)"
^XMB(3.9,145946,2,2808,0)=" ;Effective Date is today or past ;BAD Expiration Date"
^XMB(3.9,145946,2,2809,0)="""RTN"",""IBCNEDE3"",143,0)"
^XMB(3.9,145946,2,2810,0)=" I EFFDT=Z!(EFFDT>Z) I $$VALIDDT^IBCNINSU(EXPDT)<0 S EVAL=1"
^XMB(3.9,145946,2,2811,0)="""RTN"",""IBCNEDE3"",144,0)"
^XMB(3.9,145946,2,2812,0)="CHKQ ;"
^XMB(3.9,145946,2,2813,0)="""RTN"",""IBCNEDE3"",145,0)"
^XMB(3.9,145946,2,2814,0)=" Q EVAL"
^XMB(3.9,145946,2,2815,0)="""RTN"",""IBCNEDE3"",146,0)"
^XMB(3.9,145946,2,2816,0)=" ;"
^XMB(3.9,145946,2,2817,0)="""RTN"",""IBCNEDE3"",147,0)"
^XMB(3.9,145946,2,2818,0)="TQUPDSV(DFN,PAYER,SRVDT,SUBID,GRPNUM) ; Update TQ service date for entries to be transmitted"
^XMB(3.9,145946,2,2819,0)="""RTN"",""IBCNEDE3"",148,0)"
^XMB(3.9,145946,2,2820,0)=" ; used by the Appointment Extract - logic from TQUPDSV^IBCNEUT5"
^XMB(3.9,145946,2,2821,0)="""RTN"",""IBCNEDE3"",149,0)"
^XMB(3.9,145946,2,2822,0)=" ;"
^XMB(3.9,145946,2,2823,0)="""RTN"",""IBCNEDE3"",150,0)"
^XMB(3.9,145946,2,2824,0)=" N CSPAN,CSRVDT,DA,SPAN,STS,SVDT,TQSUBID"
^XMB(3.9,145946,2,2825,0)="""RTN"",""IBCNEDE3"",151,0)"
^XMB(3.9,145946,2,2826,0)=" ;"
^XMB(3.9,145946,2,2827,0)="""RTN"",""IBCNEDE3"",152,0)"
^XMB(3.9,145946,2,2828,0)=" I ($G(DFN)="""")!($G(PAYER)="""")!($G(SRVDT)="""") G TQUPDSVX"
^XMB(3.9,145946,2,2829,0)="""RTN"",""IBCNEDE3"",153,0)"
^XMB(3.9,145946,2,2830,0)=" ;"
^XMB(3.9,145946,2,2831,0)="""RTN"",""IBCNEDE3"",154,0)"
^XMB(3.9,145946,2,2832,0)=" ; Loop thru all entries in the TQ file (DO NOT CHANGE to DT-1 as SVDT)"
^XMB(3.9,145946,2,2833,0)="""RTN"",""IBCNEDE3"",155,0)"
^XMB(3.9,145946,2,2834,0)=" S SVDT="""""
^XMB(3.9,145946,2,2835,0)="""RTN"",""IBCNEDE3"",156,0)"
^XMB(3.9,145946,2,2836,0)=" F  S SVDT=$O(^IBCN(365.1,""AD"",DFN,PAYER,SVDT)) Q:'SVDT  D"
^XMB(3.9,145946,2,2837,0)="""RTN"",""IBCNEDE3"",157,0)"
^XMB(3.9,145946,2,2838,0)=" . S DA=0"
^XMB(3.9,145946,2,2839,0)="""RTN"",""IBCNEDE3"",158,0)"
^XMB(3.9,145946,2,2840,0)=" . F  S DA=$O(^IBCN(365.1,""AD"",DFN,PAYER,SVDT,DA)) Q:'DA!($G(TQFOUND))  D"
^XMB(3.9,145946,2,2841,0)="""RTN"",""IBCNEDE3"",159,0)"
^XMB(3.9,145946,2,2842,0)=" .. ;Find entries for the same patient/payer/subscriber ID/group number combo"
^XMB(3.9,145946,2,2843,0)="""RTN"",""IBCNEDE3"",160,0)"
^XMB(3.9,145946,2,2844,0)=" .. ; Compare SUBID against the HL7 SUBSCRIBER ID FIELD stored in the TQ file"
^XMB(3.9,145946,2,2845,0)="""RTN"",""IBCNEDE3"",161,0)"
^XMB(3.9,145946,2,2846,0)=" .. ;Strip/remove any non-alph char's from the Subscriber ID in the TQ file"
^XMB(3.9,145946,2,2847,0)="""RTN"",""IBCNEDE3"",162,0)"
^XMB(3.9,145946,2,2848,0)=" .. S TQSUBID=$$STRIP^IBCNEDE3($$GET1^DIQ(365.1,DA_"","",.16))"
^XMB(3.9,145946,2,2849,0)="""RTN"",""IBCNEDE3"",163,0)"
^XMB(3.9,145946,2,2850,0)=" .. I SUBID'=TQSUBID Q"
^XMB(3.9,145946,2,2851,0)="""RTN"",""IBCNEDE3"",164,0)"
^XMB(3.9,145946,2,2852,0)=" .. ; Compare GRPNUM against the GROUP NUMBER stored in the TQ file"
^XMB(3.9,145946,2,2853,0)="""RTN"",""IBCNEDE3"",165,0)"
^XMB(3.9,145946,2,2854,0)=" .. I GRPNUM'=$$GET1^DIQ(365.1,DA_"","",1.03) Q"
^XMB(3.9,145946,2,2855,0)="""RTN"",""IBCNEDE3"",166,0)"
^XMB(3.9,145946,2,2856,0)=" .. ;"
^XMB(3.9,145946,2,2857,0)="""RTN"",""IBCNEDE3"",167,0)"
^XMB(3.9,145946,2,2858,0)=" .. S STS=$P($G(^IBCN(365.1,DA,0)),U,4)  ; Get TQ Status"
^XMB(3.9,145946,2,2859,0)="""RTN"",""IBCNEDE3"",168,0)"
^XMB(3.9,145946,2,2860,0)=" .. ; If record is (1)Ready to Transmit or (6)Retry - update service date"
^XMB(3.9,145946,2,2861,0)="""RTN"",""IBCNEDE3"",169,0)"
^XMB(3.9,145946,2,2862,0)=" .. I (STS=1)!(STS=6) D  Q"
^XMB(3.9,145946,2,2863,0)="""RTN"",""IBCNEDE3"",170,0)"
^XMB(3.9,145946,2,2864,0)=" ... ; Initialize variables"
^XMB(3.9,145946,2,2865,0)="""RTN"",""IBCNEDE3"",171,0)"
^XMB(3.9,145946,2,2866,0)=" ... I STS=1 S FSCSEND=1   ; (1)Ready to Transmit, send to FSC now"
^XMB(3.9,145946,2,2867,0)="""RTN"",""IBCNEDE3"",172,0)"
^XMB(3.9,145946,2,2868,0)=" ... I STS=6 S FSCSEND=0   ; (6)Retry, DO NOT send to FSC now"
^XMB(3.9,145946,2,2869,0)="""RTN"",""IBCNEDE3"",173,0)"
^XMB(3.9,145946,2,2870,0)=" ... S TQFOUND=1           ; valid entry found in the TQ file"
^XMB(3.9,145946,2,2871,0)="""RTN"",""IBCNEDE3"",174,0)"
^XMB(3.9,145946,2,2872,0)=" ... S TQENT=DA            ; existing IEN in the TQ (need to send to FSC)"
^XMB(3.9,145946,2,2873,0)="""RTN"",""IBCNEDE3"",175,0)"
^XMB(3.9,145946,2,2874,0)=" ... ;    SRVDT - new service date (from the appointment)"
^XMB(3.9,145946,2,2875,0)="""RTN"",""IBCNEDE3"",176,0)"
^XMB(3.9,145946,2,2876,0)=" ... ;   CSRVDT - current service date for the existing TQ entry"
^XMB(3.9,145946,2,2877,0)="""RTN"",""IBCNEDE3"",177,0)"
^XMB(3.9,145946,2,2878,0)=" ... ;       DT - today"
^XMB(3.9,145946,2,2879,0)="""RTN"",""IBCNEDE3"",178,0)"
^XMB(3.9,145946,2,2880,0)=" ... S CSRVDT=$P($G(^IBCN(365.1,DA,0)),U,12)"
^XMB(3.9,145946,2,2881,0)="""RTN"",""IBCNEDE3"",179,0)"
^XMB(3.9,145946,2,2882,0)=" ... ; If current service date is TODAY, do not update"
^XMB(3.9,145946,2,2883,0)="""RTN"",""IBCNEDE3"",180,0)"
^XMB(3.9,145946,2,2884,0)=" ... I CSRVDT=DT Q"
^XMB(3.9,145946,2,2885,0)="""RTN"",""IBCNEDE3"",181,0)"
^XMB(3.9,145946,2,2886,0)=" ... ; If the new service date is TODAY, update the current service date (date in TQ entry) to TODAY"
^XMB(3.9,145946,2,2887,0)="""RTN"",""IBCNEDE3"",182,0)"
^XMB(3.9,145946,2,2888,0)=" ... I SRVDT=DT S CSRVDT=DT D SAVETQ^IBCNEUT2(DA,CSRVDT) Q"
^XMB(3.9,145946,2,2889,0)="""RTN"",""IBCNEDE3"",183,0)"
^XMB(3.9,145946,2,2890,0)=" ... ; If the current service day is in the past, update it to the new service date"
^XMB(3.9,145946,2,2891,0)="""RTN"",""IBCNEDE3"",184,0)"
^XMB(3.9,145946,2,2892,0)=" ... I CSRVDT<DT S CSRVDT=SRVDT D SAVETQ^IBCNEUT2(DA,CSRVDT) Q"
^XMB(3.9,145946,2,2893,0)="""RTN"",""IBCNEDE3"",185,0)"
^XMB(3.9,145946,2,2894,0)=" ... ; If both the current and new service dates are in the future, update the current"
^XMB(3.9,145946,2,2895,0)="""RTN"",""IBCNEDE3"",186,0)"
^XMB(3.9,145946,2,2896,0)=" ... ; service date to whichever date is closest to TODAY"
^XMB(3.9,145946,2,2897,0)="""RTN"",""IBCNEDE3"",187,0)"
^XMB(3.9,145946,2,2898,0)=" ... I (CSRVDT>DT)&(SRVDT>DT) D  Q"
^XMB(3.9,145946,2,2899,0)="""RTN"",""IBCNEDE3"",188,0)"
^XMB(3.9,145946,2,2900,0)=" .... S CSPAN=$$FMDIFF^XLFDT(CSRVDT,DT,1),SPAN=$$FMDIFF^XLFDT(SRVDT,DT,1)"
^XMB(3.9,145946,2,2901,0)="""RTN"",""IBCNEDE3"",189,0)"
^XMB(3.9,145946,2,2902,0)=" .... I CSPAN<SPAN D SAVETQ^IBCNEUT2(DA,CSRVDT) Q"
^XMB(3.9,145946,2,2903,0)="""RTN"",""IBCNEDE3"",190,0)"
^XMB(3.9,145946,2,2904,0)=" .... I SPAN<CSPAN D SAVETQ^IBCNEUT2(DA,SRVDT) Q"
^XMB(3.9,145946,2,2905,0)="""RTN"",""IBCNEDE3"",191,0)"
^XMB(3.9,145946,2,2906,0)="TQUPDSVX ;TQUPDSV exit"
^XMB(3.9,145946,2,2907,0)="""RTN"",""IBCNEDE3"",192,0)"
^XMB(3.9,145946,2,2908,0)=" Q"
^XMB(3.9,145946,2,2909,0)="""RTN"",""IBCNEDE3"",193,0)"
^XMB(3.9,145946,2,2910,0)=" ;"
^XMB(3.9,145946,2,2911,0)="""RTN"",""IBCNEDE3"",194,0)"
^XMB(3.9,145946,2,2912,0)="TQCHKS(DFN,PAYER,SRVDT,SUBID,GRPNUM,FRESHNESS) ; Looks at the TQ file for an existing entry"
^XMB(3.9,145946,2,2913,0)="""RTN"",""IBCNEDE3"",195,0)"
^XMB(3.9,145946,2,2914,0)=" ; checks to see if a new entry can be added to the TQ - used by the Appointment Extract"
^XMB(3.9,145946,2,2915,0)="""RTN"",""IBCNEDE3"",196,0)"
^XMB(3.9,145946,2,2916,0)=" ;"
^XMB(3.9,145946,2,2917,0)="""RTN"",""IBCNEDE3"",197,0)"
^XMB(3.9,145946,2,2918,0)=" N DA,STS,SVDT,TQSUBID"
^XMB(3.9,145946,2,2919,0)="""RTN"",""IBCNEDE3"",198,0)"
^XMB(3.9,145946,2,2920,0)=" ;"
^XMB(3.9,145946,2,2921,0)="""RTN"",""IBCNEDE3"",199,0)"
^XMB(3.9,145946,2,2922,0)=" I ($G(DFN)="""")!($G(PAYER)="""")!($G(SRVDT)="""") G TQCHKSX"
^XMB(3.9,145946,2,2923,0)="""RTN"",""IBCNEDE3"",200,0)"
^XMB(3.9,145946,2,2924,0)=" ;"
^XMB(3.9,145946,2,2925,0)="""RTN"",""IBCNEDE3"",201,0)"
^XMB(3.9,145946,2,2926,0)=" ; Loop thru ALL entries in the TQ file"
^XMB(3.9,145946,2,2927,0)="""RTN"",""IBCNEDE3"",202,0)"
^XMB(3.9,145946,2,2928,0)=" S SVDT="""""
^XMB(3.9,145946,2,2929,0)="""RTN"",""IBCNEDE3"",203,0)"
^XMB(3.9,145946,2,2930,0)=" F  S SVDT=$O(^IBCN(365.1,""AD"",DFN,PAYER,SVDT)) Q:'SVDT  D"
^XMB(3.9,145946,2,2931,0)="""RTN"",""IBCNEDE3"",204,0)"
^XMB(3.9,145946,2,2932,0)=" . S DA=0"
^XMB(3.9,145946,2,2933,0)="""RTN"",""IBCNEDE3"",205,0)"
^XMB(3.9,145946,2,2934,0)=" . F  S DA=$O(^IBCN(365.1,""AD"",DFN,PAYER,SVDT,DA)) Q:'DA  D"
^XMB(3.9,145946,2,2935,0)="""RTN"",""IBCNEDE3"",206,0)"
^XMB(3.9,145946,2,2936,0)=" .. ;Find entries for the same patient/payer/subscriber ID/group number combo"
^XMB(3.9,145946,2,2937,0)="""RTN"",""IBCNEDE3"",207,0)"
^XMB(3.9,145946,2,2938,0)=" .. ; Compare SUBID against the HL7 SUBSCRIBER ID FIELD stored in the TQ file"
^XMB(3.9,145946,2,2939,0)="""RTN"",""IBCNEDE3"",208,0)"
^XMB(3.9,145946,2,2940,0)=" .. ;Strip/remove any non-alph char's from the Subscriber ID in the TQ file"
^XMB(3.9,145946,2,2941,0)="""RTN"",""IBCNEDE3"",209,0)"
^XMB(3.9,145946,2,2942,0)=" .. S TQSUBID=$$STRIP^IBCNEDE3($$GET1^DIQ(365.1,DA_"","",.16))"
^XMB(3.9,145946,2,2943,0)="""RTN"",""IBCNEDE3"",210,0)"
^XMB(3.9,145946,2,2944,0)=" .. I SUBID'=TQSUBID Q"
^XMB(3.9,145946,2,2945,0)="""RTN"",""IBCNEDE3"",211,0)"
^XMB(3.9,145946,2,2946,0)=" .. ; Compare GRPNUM against the GROUP NUMBER stored in the TQ file"
^XMB(3.9,145946,2,2947,0)="""RTN"",""IBCNEDE3"",212,0)"
^XMB(3.9,145946,2,2948,0)=" .. I GRPNUM'=$$GET1^DIQ(365.1,DA_"","",1.03) Q"
^XMB(3.9,145946,2,2949,0)="""RTN"",""IBCNEDE3"",213,0)"
^XMB(3.9,145946,2,2950,0)=" .. S STS=$P($G(^IBCN(365.1,DA,0)),U,4)  ; Get TQ Status"
^XMB(3.9,145946,2,2951,0)="""RTN"",""IBCNEDE3"",214,0)"
^XMB(3.9,145946,2,2952,0)=" .. ; If entry is (2)Transmitted or (3)Response Received - check freshness days"
^XMB(3.9,145946,2,2953,0)="""RTN"",""IBCNEDE3"",215,0)"
^XMB(3.9,145946,2,2954,0)=" .. I (STS=2)!(STS=3) D"
^XMB(3.9,145946,2,2955,0)="""RTN"",""IBCNEDE3"",216,0)"
^XMB(3.9,145946,2,2956,0)=" ... ;    ADDTQ = 0-do not add to TQ / 1-add to TQ file"
^XMB(3.9,145946,2,2957,0)="""RTN"",""IBCNEDE3"",217,0)"
^XMB(3.9,145946,2,2958,0)=" ... S ADDTQ=$$ADDTQ(DFN,PAYER,SUBID,GRPNUM,SRVICEDT,FRESHNESS) ; within freshness days"
^XMB(3.9,145946,2,2959,0)="""RTN"",""IBCNEDE3"",218,0)"
^XMB(3.9,145946,2,2960,0)=" ... Q"
^XMB(3.9,145946,2,2961,0)="""RTN"",""IBCNEDE3"",219,0)"
^XMB(3.9,145946,2,2962,0)=" ;"
^XMB(3.9,145946,2,2963,0)="""RTN"",""IBCNEDE3"",220,0)"
^XMB(3.9,145946,2,2964,0)="TQCHKSX ;TQCHKS exit"
^XMB(3.9,145946,2,2965,0)="""RTN"",""IBCNEDE3"",221,0)"
^XMB(3.9,145946,2,2966,0)=" Q"
^XMB(3.9,145946,2,2967,0)="""RTN"",""IBCNEDE3"",222,0)"
^XMB(3.9,145946,2,2968,0)=" ;"
^XMB(3.9,145946,2,2969,0)="""RTN"",""IBCNEDE3"",223,0)"
^XMB(3.9,145946,2,2970,0)="ADDTQ(DFN,PAYER,SUBID,GRPNUM,SRVDT,FDAYS) ; Function  - Returns flag (0/1)"
^XMB(3.9,145946,2,2971,0)="""RTN"",""IBCNEDE3"",224,0)"
^XMB(3.9,145946,2,2972,0)=" ; used by the Appointment Extract - logic from ADDTQ^IBCNEUT5"
^XMB(3.9,145946,2,2973,0)="""RTN"",""IBCNEDE3"",225,0)"
^XMB(3.9,145946,2,2974,0)=" ;   1 - TQ File entry can be added as the service date for the patient "
^XMB(3.9,145946,2,2975,0)="""RTN"",""IBCNEDE3"",226,0)"
^XMB(3.9,145946,2,2976,0)=" ;       and payer >= MAX TQ service date + Freshness Days"
^XMB(3.9,145946,2,2977,0)="""RTN"",""IBCNEDE3"",227,0)"
^XMB(3.9,145946,2,2978,0)=" ;   0 - otherwise"
^XMB(3.9,145946,2,2979,0)="""RTN"",""IBCNEDE3"",228,0)"
^XMB(3.9,145946,2,2980,0)=" ;"
^XMB(3.9,145946,2,2981,0)="""RTN"",""IBCNEDE3"",229,0)"
^XMB(3.9,145946,2,2982,0)=" ; Input:"
^XMB(3.9,145946,2,2983,0)="""RTN"",""IBCNEDE3"",230,0)"
^XMB(3.9,145946,2,2984,0)=" ;  DFN    - Patient DFN (File #2)"
^XMB(3.9,145946,2,2985,0)="""RTN"",""IBCNEDE3"",231,0)"
^XMB(3.9,145946,2,2986,0)=" ;  PAYER  - Payer IEN (File #365.12)"
^XMB(3.9,145946,2,2987,0)="""RTN"",""IBCNEDE3"",232,0)"
^XMB(3.9,145946,2,2988,0)=" ;  SUBID  - Subscriber ID"
^XMB(3.9,145946,2,2989,0)="""RTN"",""IBCNEDE3"",233,0)"
^XMB(3.9,145946,2,2990,0)=" ;  GRPNUM - Group Number"
^XMB(3.9,145946,2,2991,0)="""RTN"",""IBCNEDE3"",234,0)"
^XMB(3.9,145946,2,2992,0)=" ;  SRVDT  - Service Date for potential TQ entry"
^XMB(3.9,145946,2,2993,0)="""RTN"",""IBCNEDE3"",235,0)"
^XMB(3.9,145946,2,2994,0)=" ;  FDAYS  - Freshness Days param (by extract type)"
^XMB(3.9,145946,2,2995,0)="""RTN"",""IBCNEDE3"",236,0)"
^XMB(3.9,145946,2,2996,0)=" ;"
^XMB(3.9,145946,2,2997,0)="""RTN"",""IBCNEDE3"",237,0)"
^XMB(3.9,145946,2,2998,0)=" N MAXDT"
^XMB(3.9,145946,2,2999,0)="""RTN"",""IBCNEDE3"",238,0)"
^XMB(3.9,145946,2,3000,0)=" S ADDTQ=1"
^XMB(3.9,145946,2,3001,0)="""RTN"",""IBCNEDE3"",239,0)"
^XMB(3.9,145946,2,3002,0)=" ;"
^XMB(3.9,145946,2,3003,0)="""RTN"",""IBCNEDE3"",240,0)"
^XMB(3.9,145946,2,3004,0)=" I ($G(DFN)="""")!($G(SRVDT)="""")!($G(FDAYS)="""")!($G(PAYER)="""") S ADDTQ=0 G ADDTQX"
^XMB(3.9,145946,2,3005,0)="""RTN"",""IBCNEDE3"",241,0)"
^XMB(3.9,145946,2,3006,0)=" ;"
^XMB(3.9,145946,2,3007,0)="""RTN"",""IBCNEDE3"",242,0)"
^XMB(3.9,145946,2,3008,0)=" ; MAX TQ Service Date"
^XMB(3.9,145946,2,3009,0)="""RTN"",""IBCNEDE3"",243,0)"
^XMB(3.9,145946,2,3010,0)=" S MAXDT=$$TQMAXSV(DFN,PAYER,SUBID,GRPNUM)"
^XMB(3.9,145946,2,3011,0)="""RTN"",""IBCNEDE3"",244,0)"
^XMB(3.9,145946,2,3012,0)=" I MAXDT="""" G ADDTQX"
^XMB(3.9,145946,2,3013,0)="""RTN"",""IBCNEDE3"",245,0)"
^XMB(3.9,145946,2,3014,0)=" ; If Service Date < Max Service Date + Freshness Days, do not add"
^XMB(3.9,145946,2,3015,0)="""RTN"",""IBCNEDE3"",246,0)"
^XMB(3.9,145946,2,3016,0)=" I SRVDT'>$$FMADD^XLFDT(MAXDT,FDAYS) S ADDTQ=0"
^XMB(3.9,145946,2,3017,0)="""RTN"",""IBCNEDE3"",247,0)"
^XMB(3.9,145946,2,3018,0)=" ;"
^XMB(3.9,145946,2,3019,0)="""RTN"",""IBCNEDE3"",248,0)"
^XMB(3.9,145946,2,3020,0)="ADDTQX ; ADDTQ exit pt"
^XMB(3.9,145946,2,3021,0)="""RTN"",""IBCNEDE3"",249,0)"
^XMB(3.9,145946,2,3022,0)=" Q ADDTQ"
^XMB(3.9,145946,2,3023,0)="""RTN"",""IBCNEDE3"",250,0)"
^XMB(3.9,145946,2,3024,0)=" ;"
^XMB(3.9,145946,2,3025,0)="""RTN"",""IBCNEDE3"",251,0)"
^XMB(3.9,145946,2,3026,0)="TQMAXSV(DFN,PAYER,SUBID,GRPNUM) ; Returns MAX(TQ Service Date) for Patient & Payer"
^XMB(3.9,145946,2,3027,0)="""RTN"",""IBCNEDE3"",252,0)"
^XMB(3.9,145946,2,3028,0)=" ;used by the Appointment Extract - logic from TQMAXSV^IBCNEUT5"
^XMB(3.9,145946,2,3029,0)="""RTN"",""IBCNEDE3"",253,0)"
^XMB(3.9,145946,2,3030,0)=" ; Input: "
^XMB(3.9,145946,2,3031,0)="""RTN"",""IBCNEDE3"",254,0)"
^XMB(3.9,145946,2,3032,0)=" ;  DFN     - Patient DFN (#2)"
^XMB(3.9,145946,2,3033,0)="""RTN"",""IBCNEDE3"",255,0)"
^XMB(3.9,145946,2,3034,0)=" ;  PAYER   - Payer IEN (#365.12)"
^XMB(3.9,145946,2,3035,0)="""RTN"",""IBCNEDE3"",256,0)"
^XMB(3.9,145946,2,3036,0)=" ;  SUBID   - Subscriber ID"
^XMB(3.9,145946,2,3037,0)="""RTN"",""IBCNEDE3"",257,0)"
^XMB(3.9,145946,2,3038,0)=" ;  GRPNUM  - Group Number"
^XMB(3.9,145946,2,3039,0)="""RTN"",""IBCNEDE3"",258,0)"
^XMB(3.9,145946,2,3040,0)=" ;"
^XMB(3.9,145946,2,3041,0)="""RTN"",""IBCNEDE3"",259,0)"
^XMB(3.9,145946,2,3042,0)=" ; Output:"
^XMB(3.9,145946,2,3043,0)="""RTN"",""IBCNEDE3"",260,0)"
^XMB(3.9,145946,2,3044,0)=" ;  TQMAXSV - MAX (most recent) service date from TQ entry for Patient & Payer"
^XMB(3.9,145946,2,3045,0)="""RTN"",""IBCNEDE3"",261,0)"
^XMB(3.9,145946,2,3046,0)=" ;"
^XMB(3.9,145946,2,3047,0)="""RTN"",""IBCNEDE3"",262,0)"
^XMB(3.9,145946,2,3048,0)=" N TQMAXSV"
^XMB(3.9,145946,2,3049,0)="""RTN"",""IBCNEDE3"",263,0)"
^XMB(3.9,145946,2,3050,0)=" S TQMAXSV="""""
^XMB(3.9,145946,2,3051,0)="""RTN"",""IBCNEDE3"",264,0)"
^XMB(3.9,145946,2,3052,0)=" I ($G(DFN)="""")!'$G(PAYER) G TQMAXSVX"
^XMB(3.9,145946,2,3053,0)="""RTN"",""IBCNEDE3"",265,0)"
^XMB(3.9,145946,2,3054,0)=" ;"
^XMB(3.9,145946,2,3055,0)="""RTN"",""IBCNEDE3"",266,0)"
^XMB(3.9,145946,2,3056,0)=" N IBTQS,IENS,LASTBYP,STATLIST,TQIEN,TQSUBID"
^XMB(3.9,145946,2,3057,0)="""RTN"",""IBCNEDE3"",267,0)"
^XMB(3.9,145946,2,3058,0)=" ; This is the list of transmission statuses that are to be ignored:"
^XMB(3.9,145946,2,3059,0)="""RTN"",""IBCNEDE3"",268,0)"
^XMB(3.9,145946,2,3060,0)=" ;  4=Hold (IB*506 removed this status from occurring) / 5=Communication Failure / 7=Cancelled"
^XMB(3.9,145946,2,3061,0)="""RTN"",""IBCNEDE3"",269,0)"
^XMB(3.9,145946,2,3062,0)=" S STATLIST="",4,5,7,"""
^XMB(3.9,145946,2,3063,0)="""RTN"",""IBCNEDE3"",270,0)"
^XMB(3.9,145946,2,3064,0)=" ;"
^XMB(3.9,145946,2,3065,0)="""RTN"",""IBCNEDE3"",271,0)"
^XMB(3.9,145946,2,3066,0)=" S LASTBYP="""""
^XMB(3.9,145946,2,3067,0)="""RTN"",""IBCNEDE3"",272,0)"
^XMB(3.9,145946,2,3068,0)=" F  S LASTBYP=$O(^IBCN(365.1,""AD"",DFN,PAYER,LASTBYP)) Q:LASTBYP=""""  D"
^XMB(3.9,145946,2,3069,0)="""RTN"",""IBCNEDE3"",273,0)"
^XMB(3.9,145946,2,3070,0)=" . S TQIEN="""""
^XMB(3.9,145946,2,3071,0)="""RTN"",""IBCNEDE3"",274,0)"
^XMB(3.9,145946,2,3072,0)=" . F  S TQIEN=$O(^IBCN(365.1,""AD"",DFN,PAYER,LASTBYP,TQIEN)) Q:TQIEN=""""  D"
^XMB(3.9,145946,2,3073,0)="""RTN"",""IBCNEDE3"",275,0)"
^XMB(3.9,145946,2,3074,0)=" .. ;Find entries for the same patient/payer/subscriber ID/group number combo"
^XMB(3.9,145946,2,3075,0)="""RTN"",""IBCNEDE3"",276,0)"
^XMB(3.9,145946,2,3076,0)=" .. ; Compare SUBID against the HL7 SUBSCRIBER ID FIELD stored in the TQ file"
^XMB(3.9,145946,2,3077,0)="""RTN"",""IBCNEDE3"",277,0)"
^XMB(3.9,145946,2,3078,0)=" .. ;Strip/remove any non-alph char's from the Subscriber ID in the TQ file"
^XMB(3.9,145946,2,3079,0)="""RTN"",""IBCNEDE3"",278,0)"
^XMB(3.9,145946,2,3080,0)=" .. S TQSUBID=$$STRIP^IBCNEDE3($$GET1^DIQ(365.1,TQIEN_"","",.16))"
^XMB(3.9,145946,2,3081,0)="""RTN"",""IBCNEDE3"",279,0)"
^XMB(3.9,145946,2,3082,0)=" .. I SUBID'=TQSUBID Q"
^XMB(3.9,145946,2,3083,0)="""RTN"",""IBCNEDE3"",280,0)"
^XMB(3.9,145946,2,3084,0)=" .. ; Compare GRPNUM against the GROUP NUMBER stored in the TQ file"
^XMB(3.9,145946,2,3085,0)="""RTN"",""IBCNEDE3"",281,0)"
^XMB(3.9,145946,2,3086,0)=" .. I GRPNUM'=$$GET1^DIQ(365.1,TQIEN_"","",1.03) Q"
^XMB(3.9,145946,2,3087,0)="""RTN"",""IBCNEDE3"",282,0)"
^XMB(3.9,145946,2,3088,0)=" .. S IBTQS=+$$GET1^DIQ(365.1,TQIEN_"","",.04,""I"")    ; TQ STATUS"
^XMB(3.9,145946,2,3089,0)="""RTN"",""IBCNEDE3"",283,0)"
^XMB(3.9,145946,2,3090,0)=" .. I IBTQS,($F(STATLIST,"",""_IBTQS_"","")) Q          ; If TQ STATUS is contained in STATLIST, quit"
^XMB(3.9,145946,2,3091,0)="""RTN"",""IBCNEDE3"",284,0)"
^XMB(3.9,145946,2,3092,0)=" .. I LASTBYP>TQMAXSV S TQMAXSV=LASTBYP"
^XMB(3.9,145946,2,3093,0)="""RTN"",""IBCNEDE3"",285,0)"
^XMB(3.9,145946,2,3094,0)=" ;"
^XMB(3.9,145946,2,3095,0)="""RTN"",""IBCNEDE3"",286,0)"
^XMB(3.9,145946,2,3096,0)="TQMAXSVX ;TQMAXSV exit"
^XMB(3.9,145946,2,3097,0)="""RTN"",""IBCNEDE3"",287,0)"
^XMB(3.9,145946,2,3098,0)=" Q TQMAXSV"
^XMB(3.9,145946,2,3099,0)="""RTN"",""IBCNEDE3"",288,0)"
^XMB(3.9,145946,2,3100,0)=" ;"
^XMB(3.9,145946,2,3101,0)="""RTN"",""IBCNEDE3"",289,0)"
^XMB(3.9,145946,2,3102,0)="BFEXIST(DFN,INSNAME,SUBID,GRPNUM) ;Checks for the existence in the Buffer"
^XMB(3.9,145946,2,3103,0)="""RTN"",""IBCNEDE3"",290,0)"
^XMB(3.9,145946,2,3104,0)=" ;used by the Appointment Extract - logic from BFEXIST^IBCNEUT5"
^XMB(3.9,145946,2,3105,0)="""RTN"",""IBCNEDE3"",291,0)"
^XMB(3.9,145946,2,3106,0)=" ;INPUT:"
^XMB(3.9,145946,2,3107,0)="""RTN"",""IBCNEDE3"",292,0)"
^XMB(3.9,145946,2,3108,0)=" ;     DFN - Patient DFN"
^XMB(3.9,145946,2,3109,0)="""RTN"",""IBCNEDE3"",293,0)"
^XMB(3.9,145946,2,3110,0)=" ; INSNAME - Insurance Company Name File 36 - Field .01"
^XMB(3.9,145946,2,3111,0)="""RTN"",""IBCNEDE3"",294,0)"
^XMB(3.9,145946,2,3112,0)=" ;   SUBID - Subscriber ID"
^XMB(3.9,145946,2,3113,0)="""RTN"",""IBCNEDE3"",295,0)"
^XMB(3.9,145946,2,3114,0)=" ;  GRPNUM - Group Number"
^XMB(3.9,145946,2,3115,0)="""RTN"",""IBCNEDE3"",296,0)"
^XMB(3.9,145946,2,3116,0)=" ;"
^XMB(3.9,145946,2,3117,0)="""RTN"",""IBCNEDE3"",297,0)"
^XMB(3.9,145946,2,3118,0)=" ;OUTPUT:"
^XMB(3.9,145946,2,3119,0)="""RTN"",""IBCNEDE3"",298,0)"
^XMB(3.9,145946,2,3120,0)=" ; 1 - if an entry exists in the Buffer with the same DFN/INSNAME/SUBID/GRPNUM"
^XMB(3.9,145946,2,3121,0)="""RTN"",""IBCNEDE3"",299,0)"
^XMB(3.9,145946,2,3122,0)=" ; 0 - if not found in the Buffer"
^XMB(3.9,145946,2,3123,0)="""RTN"",""IBCNEDE3"",300,0)"
^XMB(3.9,145946,2,3124,0)=" ;"
^XMB(3.9,145946,2,3125,0)="""RTN"",""IBCNEDE3"",301,0)"
^XMB(3.9,145946,2,3126,0)=" ; This tag is being used by the Appointment Extract"
^XMB(3.9,145946,2,3127,0)="""RTN"",""IBCNEDE3"",302,0)"
^XMB(3.9,145946,2,3128,0)=" ;"
^XMB(3.9,145946,2,3129,0)="""RTN"",""IBCNEDE3"",303,0)"
^XMB(3.9,145946,2,3130,0)=" N BSUBID,BUFFNAME,EXIST,IEN"
^XMB(3.9,145946,2,3131,0)="""RTN"",""IBCNEDE3"",304,0)"
^XMB(3.9,145946,2,3132,0)=" S EXIST=0"
^XMB(3.9,145946,2,3133,0)="""RTN"",""IBCNEDE3"",305,0)"
^XMB(3.9,145946,2,3134,0)=" S INSNAME=$$UP^XLFSTR(INSNAME),INSNAME=$$TRIM^XLFSTR(INSNAME)"
^XMB(3.9,145946,2,3135,0)="""RTN"",""IBCNEDE3"",306,0)"
^XMB(3.9,145946,2,3136,0)=" I ('DFN)!(INSNAME="""") G BFEXIT"
^XMB(3.9,145946,2,3137,0)="""RTN"",""IBCNEDE3"",307,0)"
^XMB(3.9,145946,2,3138,0)=" ;"
^XMB(3.9,145946,2,3139,0)="""RTN"",""IBCNEDE3"",308,0)"
^XMB(3.9,145946,2,3140,0)=" S IEN=0"
^XMB(3.9,145946,2,3141,0)="""RTN"",""IBCNEDE3"",309,0)"
^XMB(3.9,145946,2,3142,0)=" F  S IEN=$O(^IBA(355.33,""C"",DFN,IEN)) Q:'IEN!EXIST  D"
^XMB(3.9,145946,2,3143,0)="""RTN"",""IBCNEDE3"",310,0)"
^XMB(3.9,145946,2,3144,0)=" .  ; Quit if status is NOT 'Entered'"
^XMB(3.9,145946,2,3145,0)="""RTN"",""IBCNEDE3"",311,0)"
^XMB(3.9,145946,2,3146,0)=" .  I $P($G(^IBA(355.33,IEN,0)),U,4)'=""E"" Q"
^XMB(3.9,145946,2,3147,0)="""RTN"",""IBCNEDE3"",312,0)"
^XMB(3.9,145946,2,3148,0)=" .  ; Quit if Ins Buffer Ins Co Name (trimmed) is NOT EQUAL to "
^XMB(3.9,145946,2,3149,0)="""RTN"",""IBCNEDE3"",313,0)"
^XMB(3.9,145946,2,3150,0)=" .  ;  the Ins Co Name parameter (trimmed)"
^XMB(3.9,145946,2,3151,0)="""RTN"",""IBCNEDE3"",314,0)"
^XMB(3.9,145946,2,3152,0)=" .  S BUFFNAME=$$TRIM^XLFSTR($P($G(^IBA(355.33,IEN,20)),U))"
^XMB(3.9,145946,2,3153,0)="""RTN"",""IBCNEDE3"",315,0)"
^XMB(3.9,145946,2,3154,0)=" .  I $$UP^XLFSTR(BUFFNAME)'=INSNAME Q"
^XMB(3.9,145946,2,3155,0)="""RTN"",""IBCNEDE3"",316,0)"
^XMB(3.9,145946,2,3156,0)=" .  ; Does the SUBID and GRPNUM match what's stored in the Buffer"
^XMB(3.9,145946,2,3157,0)="""RTN"",""IBCNEDE3"",317,0)"
^XMB(3.9,145946,2,3158,0)=" .  ;Strip/remove any non-alph char's from the Subscriber ID in the Buffer"
^XMB(3.9,145946,2,3159,0)="""RTN"",""IBCNEDE3"",318,0)"
^XMB(3.9,145946,2,3160,0)=" .  S BSUBID=$$STRIP^IBCNEDE3($P($G(^IBA(355.33,IEN,90)),U,3))"
^XMB(3.9,145946,2,3161,0)="""RTN"",""IBCNEDE3"",319,0)"
^XMB(3.9,145946,2,3162,0)=" .  I SUBID'="""",BSUBID'=SUBID Q"
^XMB(3.9,145946,2,3163,0)="""RTN"",""IBCNEDE3"",320,0)"
^XMB(3.9,145946,2,3164,0)=" .  I GRPNUM'="""",($P($G(^IBA(355.33,IEN,90)),U,2))'=GRPNUM Q"
^XMB(3.9,145946,2,3165,0)="""RTN"",""IBCNEDE3"",321,0)"
^XMB(3.9,145946,2,3166,0)=" .  ; Match found"
^XMB(3.9,145946,2,3167,0)="""RTN"",""IBCNEDE3"",322,0)"
^XMB(3.9,145946,2,3168,0)=" .  S EXIST=1"
^XMB(3.9,145946,2,3169,0)="""RTN"",""IBCNEDE3"",323,0)"
^XMB(3.9,145946,2,3170,0)=" .  Q"
^XMB(3.9,145946,2,3171,0)="""RTN"",""IBCNEDE3"",324,0)"
^XMB(3.9,145946,2,3172,0)="BFEXIT ;BFEXIST exit"
^XMB(3.9,145946,2,3173,0)="""RTN"",""IBCNEDE3"",325,0)"
^XMB(3.9,145946,2,3174,0)=" Q EXIST"
^XMB(3.9,145946,2,3175,0)="""RTN"",""IBCNEHL1A"")"
^XMB(3.9,145946,2,3176,0)="0^12^B41271830"
^XMB(3.9,145946,2,3177,0)="""RTN"",""IBCNEHL1A"",1,0)"
^XMB(3.9,145946,2,3178,0)="IBCNEHL1A ;AITC/DJW - HL7 Process Incoming RPI Messages (Cont.) ; 10-JAN-2025"
^XMB(3.9,145946,2,3179,0)="""RTN"",""IBCNEHL1A"",2,0)"
^XMB(3.9,145946,2,3180,0)=" ;;2.0;INTEGRATED BILLING;**806**;21-MAR-94;Build 0"
^XMB(3.9,145946,2,3181,0)="""RTN"",""IBCNEHL1A"",3,0)"
^XMB(3.9,145946,2,3182,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145946,2,3183,0)="""RTN"",""IBCNEHL1A"",4,0)"
^XMB(3.9,145946,2,3184,0)=" ;"
^XMB(3.9,145946,2,3185,0)="""RTN"",""IBCNEHL1A"",5,0)"
^XMB(3.9,145946,2,3186,0)=" Q  ; No direct calls allowed"
^XMB(3.9,145946,2,3187,0)="""RTN"",""IBCNEHL1A"",6,0)"
^XMB(3.9,145946,2,3188,0)=" ;"
^XMB(3.9,145946,2,3189,0)="""RTN"",""IBCNEHL1A"",7,0)"
^XMB(3.9,145946,2,3190,0)="AUTOUPD(RIEN) ;"
^XMB(3.9,145946,2,3191,0)="""RTN"",""IBCNEHL1A"",8,0)"
^XMB(3.9,145946,2,3192,0)=" ;DTG - Rewrote tag to split logic between Medicare policies and commercial policies"
^XMB(3.9,145946,2,3193,0)="""RTN"",""IBCNEHL1A"",9,0)"
^XMB(3.9,145946,2,3194,0)=" ;"
^XMB(3.9,145946,2,3195,0)="""RTN"",""IBCNEHL1A"",10,0)"
^XMB(3.9,145946,2,3196,0)=" ;Returns ""1^file 2 ien^file 2.312 ien^2nd file 2.312 ien^Medicare flag^subscriber flag"", if entry"
^XMB(3.9,145946,2,3197,0)="""RTN"",""IBCNEHL1A"",11,0)"
^XMB(3.9,145946,2,3198,0)=" ; in file 365 is eligible for auto-update, returns 0 otherwise."
^XMB(3.9,145946,2,3199,0)="""RTN"",""IBCNEHL1A"",12,0)"
^XMB(3.9,145946,2,3200,0)=" ;"
^XMB(3.9,145946,2,3201,0)="""RTN"",""IBCNEHL1A"",13,0)"
^XMB(3.9,145946,2,3202,0)=" ;Medicare flag: 1 for Medicare, 0 otherwise"
^XMB(3.9,145946,2,3203,0)="""RTN"",""IBCNEHL1A"",14,0)"
^XMB(3.9,145946,2,3204,0)=" ;Subscriber flag: 1 if patient is the subscriber, 0 otherwise"
^XMB(3.9,145946,2,3205,0)="""RTN"",""IBCNEHL1A"",15,0)"
^XMB(3.9,145946,2,3206,0)=" ;"
^XMB(3.9,145946,2,3207,0)="""RTN"",""IBCNEHL1A"",16,0)"
^XMB(3.9,145946,2,3208,0)=" ;For non-Medicare response: 1st file 2.312 ien is set, 2nd file 2.312 ien is empty, pieces 5-7 are empty"
^XMB(3.9,145946,2,3209,0)="""RTN"",""IBCNEHL1A"",17,0)"
^XMB(3.9,145946,2,3210,0)=" ;For Medicare response: 1st file 2.312 ien contains ien for Medicare Part A, 2nd file 2.312 ien contains ien for Medicare Part B,"
^XMB(3.9,145946,2,3211,0)="""RTN"",""IBCNEHL1A"",18,0)"
^XMB(3.9,145946,2,3212,0)=" ;                       either one may be empty, but at least one of them is set if entry is eligible."
^XMB(3.9,145946,2,3213,0)="""RTN"",""IBCNEHL1A"",19,0)"
^XMB(3.9,145946,2,3214,0)=" ;"
^XMB(3.9,145946,2,3215,0)="""RTN"",""IBCNEHL1A"",20,0)"
^XMB(3.9,145946,2,3216,0)=" ;RIEN - ien in file 365"
^XMB(3.9,145946,2,3217,0)="""RTN"",""IBCNEHL1A"",21,0)"
^XMB(3.9,145946,2,3218,0)=" ;"
^XMB(3.9,145946,2,3219,0)="""RTN"",""IBCNEHL1A"",22,0)"
^XMB(3.9,145946,2,3220,0)=" N APPIEN,GDATA,GIEN,GNAME,GNUM,GNUM1,GOK,IEN2,IEN312,IEN36,IDATA0,IDATA3,ISSUB,MWNRA,MWNRB,MWNRIEN,MWNRTYP"
^XMB(3.9,145946,2,3221,0)="""RTN"",""IBCNEHL1A"",23,0)"
^XMB(3.9,145946,2,3222,0)=" N ONEPOL,PIEN,RDATA0,RDATA1,RES,TQIEN,IDATA7,RDATA13,RDATA14,ISBLUE"
^XMB(3.9,145946,2,3223,0)="""RTN"",""IBCNEHL1A"",24,0)"
^XMB(3.9,145946,2,3224,0)=" N IBGETTQ,IBGETWE,IBGETSTC,IBGETDEF,IBGETNOK"
^XMB(3.9,145946,2,3225,0)="""RTN"",""IBCNEHL1A"",25,0)"
^XMB(3.9,145946,2,3226,0)=" S RES=0"
^XMB(3.9,145946,2,3227,0)="""RTN"",""IBCNEHL1A"",26,0)"
^XMB(3.9,145946,2,3228,0)=" I +$G(RIEN)'>0 Q RES          ;Invalid ien for file 365"
^XMB(3.9,145946,2,3229,0)="""RTN"",""IBCNEHL1A"",27,0)"
^XMB(3.9,145946,2,3230,0)=" ; - if entry is missing from #200, file in buffer"
^XMB(3.9,145946,2,3231,0)="""RTN"",""IBCNEHL1A"",28,0)"
^XMB(3.9,145946,2,3232,0)=" I '$$FIND1^DIC(200,,""M"",IBEIVUSR) Q RES  ;use variable for name"
^XMB(3.9,145946,2,3233,0)="""RTN"",""IBCNEHL1A"",29,0)"
^XMB(3.9,145946,2,3234,0)=" ;"
^XMB(3.9,145946,2,3235,0)="""RTN"",""IBCNEHL1A"",30,0)"
^XMB(3.9,145946,2,3236,0)=" ; - Moved up the next 5 lines."
^XMB(3.9,145946,2,3237,0)="""RTN"",""IBCNEHL1A"",31,0)"
^XMB(3.9,145946,2,3238,0)=" S RDATA0=$G(^IBCN(365,RIEN,0)),RDATA1=$G(^IBCN(365,RIEN,1))"
^XMB(3.9,145946,2,3239,0)="""RTN"",""IBCNEHL1A"",32,0)"
^XMB(3.9,145946,2,3240,0)=" ;"
^XMB(3.9,145946,2,3241,0)="""RTN"",""IBCNEHL1A"",33,0)"
^XMB(3.9,145946,2,3242,0)=" ;Longer fields for GROUP NAME, GROUP NUMBER, NAME OF INSURED, & SUBSCRIBER ID"
^XMB(3.9,145946,2,3243,0)="""RTN"",""IBCNEHL1A"",34,0)"
^XMB(3.9,145946,2,3244,0)=" S RDATA13=$G(^IBCN(365,RIEN,13)),RDATA14=$G(^IBCN(365,RIEN,14))"
^XMB(3.9,145946,2,3245,0)="""RTN"",""IBCNEHL1A"",35,0)"
^XMB(3.9,145946,2,3246,0)=" S PIEN=$P(RDATA0,U,3)"
^XMB(3.9,145946,2,3247,0)="""RTN"",""IBCNEHL1A"",36,0)"
^XMB(3.9,145946,2,3248,0)=" S ISBLUE=$$GET1^DIQ(365.12,PIEN_"","",.09,""I"")"
^XMB(3.9,145946,2,3249,0)="""RTN"",""IBCNEHL1A"",37,0)"
^XMB(3.9,145946,2,3250,0)=" ;"
^XMB(3.9,145946,2,3251,0)="""RTN"",""IBCNEHL1A"",38,0)"
^XMB(3.9,145946,2,3252,0)=" ; - Moved up the next 2 lines."
^XMB(3.9,145946,2,3253,0)="""RTN"",""IBCNEHL1A"",39,0)"
^XMB(3.9,145946,2,3254,0)=" S MWNRIEN=$P($G(^IBE(350.9,1,51)),U,25),MWNRTYP=0,(MWNRA,MWNRB)="""""
^XMB(3.9,145946,2,3255,0)="""RTN"",""IBCNEHL1A"",40,0)"
^XMB(3.9,145946,2,3256,0)=" I PIEN=MWNRIEN S MWNRTYP=$$ISMCR^IBCNEHLU(RIEN)"
^XMB(3.9,145946,2,3257,0)="""RTN"",""IBCNEHL1A"",41,0)"
^XMB(3.9,145946,2,3258,0)=" ;"
^XMB(3.9,145946,2,3259,0)="""RTN"",""IBCNEHL1A"",42,0)"
^XMB(3.9,145946,2,3260,0)=" I +MWNRTYP D CHKMCR Q RES  ; call CHKMCR for Medicare policies"
^XMB(3.9,145946,2,3261,0)="""RTN"",""IBCNEHL1A"",43,0)"
^XMB(3.9,145946,2,3262,0)=" ;"
^XMB(3.9,145946,2,3263,0)="""RTN"",""IBCNEHL1A"",44,0)"
^XMB(3.9,145946,2,3264,0)=" ;Only auto-update 'active policy' responses"
^XMB(3.9,145946,2,3265,0)="""RTN"",""IBCNEHL1A"",45,0)"
^XMB(3.9,145946,2,3266,0)=" I $G(IIVSTAT)'=1 Q RES"
^XMB(3.9,145946,2,3267,0)="""RTN"",""IBCNEHL1A"",46,0)"
^XMB(3.9,145946,2,3268,0)=" ; Changed app to EIV from IIV"
^XMB(3.9,145946,2,3269,0)="""RTN"",""IBCNEHL1A"",47,0)"
^XMB(3.9,145946,2,3270,0)=" I +PIEN>0 S APPIEN=$$PYRAPP^IBCNEUT5(""EIV"",PIEN)"
^XMB(3.9,145946,2,3271,0)="""RTN"",""IBCNEHL1A"",48,0)"
^XMB(3.9,145946,2,3272,0)=" I +$G(APPIEN)'>0 Q RES  ;couldn't find eIV application entry"
^XMB(3.9,145946,2,3273,0)="""RTN"",""IBCNEHL1A"",49,0)"
^XMB(3.9,145946,2,3274,0)=" ;"
^XMB(3.9,145946,2,3275,0)="""RTN"",""IBCNEHL1A"",50,0)"
^XMB(3.9,145946,2,3276,0)=" ; Don't allow any entry with HMS SOI to auto-update"
^XMB(3.9,145946,2,3277,0)="""RTN"",""IBCNEHL1A"",51,0)"
^XMB(3.9,145946,2,3278,0)=" ; Don't allow any entry with Contract Services SOI to auto-update"
^XMB(3.9,145946,2,3279,0)="""RTN"",""IBCNEHL1A"",52,0)"
^XMB(3.9,145946,2,3280,0)=" I $P(RDATA0,U,5)'="""" I ""^HMS^CONTRACT SERVICES^""[(""^""_$$GET1^DIQ(365.1,$P(RDATA0,U,5)_"","",""SOURCE OF INFORMATION"",""E"")_""^"") Q RES  ; HAN IB*621"
^XMB(3.9,145946,2,3281,0)="""RTN"",""IBCNEHL1A"",53,0)"
^XMB(3.9,145946,2,3282,0)=" ;"
^XMB(3.9,145946,2,3283,0)="""RTN"",""IBCNEHL1A"",54,0)"
^XMB(3.9,145946,2,3284,0)=" ; Start, allow auto update for some ""Request Electronic Insurance Inquiry"" requests"
^XMB(3.9,145946,2,3285,0)="""RTN"",""IBCNEHL1A"",55,0)"
^XMB(3.9,145946,2,3286,0)=" ;"
^XMB(3.9,145946,2,3287,0)="""RTN"",""IBCNEHL1A"",56,0)"
^XMB(3.9,145946,2,3288,0)=" ;Check dictionary 365.1 MANUAL REQUEST DATE/TIME Flag, Quit if Set."
^XMB(3.9,145946,2,3289,0)="""RTN"",""IBCNEHL1A"",57,0)"
^XMB(3.9,145946,2,3290,0)=" ;I $P(RDATA0,U,5)'="""",$P($G(^IBCN(365.1,$P(RDATA0,U,5),3)),U,1)'="""" Q RES"
^XMB(3.9,145946,2,3291,0)="""RTN"",""IBCNEHL1A"",58,0)"
^XMB(3.9,145946,2,3292,0)=" ;"
^XMB(3.9,145946,2,3293,0)="""RTN"",""IBCNEHL1A"",59,0)"
^XMB(3.9,145946,2,3294,0)=" ; get values"
^XMB(3.9,145946,2,3295,0)="""RTN"",""IBCNEHL1A"",60,0)"
^XMB(3.9,145946,2,3296,0)=" S (IBGETTQ,IBGETDEF,IBGETWE,IBGETSTC)="""""
^XMB(3.9,145946,2,3297,0)="""RTN"",""IBCNEHL1A"",61,0)"
^XMB(3.9,145946,2,3298,0)=" ; Get 365.1 transmission queue number"
^XMB(3.9,145946,2,3299,0)="""RTN"",""IBCNEHL1A"",62,0)"
^XMB(3.9,145946,2,3300,0)=" S IBGETTQ=$$GET1^DIQ(365,RIEN_"","",.05,""I"") I IBGETTQ="""" Q RES"
^XMB(3.9,145946,2,3301,0)="""RTN"",""IBCNEHL1A"",63,0)"
^XMB(3.9,145946,2,3302,0)=" ; Get 365.1 which extract"
^XMB(3.9,145946,2,3303,0)="""RTN"",""IBCNEHL1A"",64,0)"
^XMB(3.9,145946,2,3304,0)=" S IBGETNOK=0"
^XMB(3.9,145946,2,3305,0)="""RTN"",""IBCNEHL1A"",65,0)"
^XMB(3.9,145946,2,3306,0)=" S IBGETWE=$$GET1^DIQ(365.1,IBGETTQ_"","",.1,""I"") I IBGETWE=5 D  I IBGETNOK Q RES"
^XMB(3.9,145946,2,3307,0)="""RTN"",""IBCNEHL1A"",66,0)"
^XMB(3.9,145946,2,3308,0)=" . ; Get 350.9 default service type code"
^XMB(3.9,145946,2,3309,0)="""RTN"",""IBCNEHL1A"",67,0)"
^XMB(3.9,145946,2,3310,0)=" . S IBGETDEF=$$GET1^DIQ(350.9,1_"","",60.01,""I"") I IBGETDEF="""" S IBGETNOK=1 Q"
^XMB(3.9,145946,2,3311,0)="""RTN"",""IBCNEHL1A"",68,0)"
^XMB(3.9,145946,2,3312,0)=" . ; Get 365 requested service type code"
^XMB(3.9,145946,2,3313,0)="""RTN"",""IBCNEHL1A"",69,0)"
^XMB(3.9,145946,2,3314,0)=" . S IBGETSTC=$$GET1^DIQ(365,RIEN_"","",.15,""I"") I IBGETSTC'=IBGETDEF S IBGETNOK=1 Q"
^XMB(3.9,145946,2,3315,0)="""RTN"",""IBCNEHL1A"",70,0)"
^XMB(3.9,145946,2,3316,0)=" ;"
^XMB(3.9,145946,2,3317,0)="""RTN"",""IBCNEHL1A"",71,0)"
^XMB(3.9,145946,2,3318,0)=" ; End, allow auto update for some ""Request Electronic Insurance Inquiry"" requests"
^XMB(3.9,145946,2,3319,0)="""RTN"",""IBCNEHL1A"",72,0)"
^XMB(3.9,145946,2,3320,0)=" ;"
^XMB(3.9,145946,2,3321,0)="""RTN"",""IBCNEHL1A"",73,0)"
^XMB(3.9,145946,2,3322,0)=" ; Changed to new field location"
^XMB(3.9,145946,2,3323,0)="""RTN"",""IBCNEHL1A"",74,0)"
^XMB(3.9,145946,2,3324,0)=" I '$$GET1^DIQ(365.121,APPIEN_"",""_PIEN_"","",4.01,""I"") Q RES  ; auto-update is OFF"
^XMB(3.9,145946,2,3325,0)="""RTN"",""IBCNEHL1A"",75,0)"
^XMB(3.9,145946,2,3326,0)=" S IEN2=$P(RDATA0,U,2) I +IEN2'>0 Q RES  ; couldn't find patient"
^XMB(3.9,145946,2,3327,0)="""RTN"",""IBCNEHL1A"",76,0)"
^XMB(3.9,145946,2,3328,0)=" S ONEPOL=$$ONEPOL^IBCNEHLU(PIEN,IEN2)"
^XMB(3.9,145946,2,3329,0)="""RTN"",""IBCNEHL1A"",77,0)"
^XMB(3.9,145946,2,3330,0)=" ;try to find a matching pat. insurance"
^XMB(3.9,145946,2,3331,0)="""RTN"",""IBCNEHL1A"",78,0)"
^XMB(3.9,145946,2,3332,0)=" ; - Modify next two lines to check for ISBLUE"
^XMB(3.9,145946,2,3333,0)="""RTN"",""IBCNEHL1A"",79,0)"
^XMB(3.9,145946,2,3334,0)=" ; - Remove the check for ISBLUE and RES"
^XMB(3.9,145946,2,3335,0)="""RTN"",""IBCNEHL1A"",80,0)"
^XMB(3.9,145946,2,3336,0)=" ;S IEN36="""" F  S IEN36=$O(^DIC(36,""AC"",PIEN,IEN36)) Q:IEN36=""""  D  I 'ISBLUE&(RES>0) Q"
^XMB(3.9,145946,2,3337,0)="""RTN"",""IBCNEHL1A"",81,0)"
^XMB(3.9,145946,2,3338,0)=" ;.S IEN312="""" F  S IEN312=$O(^DPT(IEN2,.312,""B"",IEN36,IEN312)) Q:IEN312=""""  D  I ('ISBLUE)&(RES>0&('+MWNRTYP)) Q"
^XMB(3.9,145946,2,3339,0)="""RTN"",""IBCNEHL1A"",82,0)"
^XMB(3.9,145946,2,3340,0)=" S IEN36="""" F  S IEN36=$O(^DIC(36,""AC"",PIEN,IEN36)) Q:IEN36=""""  D"
^XMB(3.9,145946,2,3341,0)="""RTN"",""IBCNEHL1A"",83,0)"
^XMB(3.9,145946,2,3342,0)=" .S IEN312="""" F  S IEN312=$O(^DPT(IEN2,.312,""B"",IEN36,IEN312)) Q:IEN312=""""  D"
^XMB(3.9,145946,2,3343,0)="""RTN"",""IBCNEHL1A"",84,0)"
^XMB(3.9,145946,2,3344,0)=" ..S IDATA0=$G(^DPT(IEN2,.312,IEN312,0)),IDATA3=$G(^DPT(IEN2,.312,IEN312,3))"
^XMB(3.9,145946,2,3345,0)="""RTN"",""IBCNEHL1A"",85,0)"
^XMB(3.9,145946,2,3346,0)=" ..S IDATA7=$G(^DPT(IEN2,.312,IEN312,7))"
^XMB(3.9,145946,2,3347,0)="""RTN"",""IBCNEHL1A"",86,0)"
^XMB(3.9,145946,2,3348,0)=" .. ; $$EXPIRED was moved from IBCNEDE2 to IBCNEHL1"
^XMB(3.9,145946,2,3349,0)="""RTN"",""IBCNEHL1A"",87,0)"
^XMB(3.9,145946,2,3350,0)=" ..I $$EXPIRED^IBCNEHL1($P(IDATA0,U,4)) Q  ;Insurance policy has expired"
^XMB(3.9,145946,2,3351,0)="""RTN"",""IBCNEHL1A"",88,0)"
^XMB(3.9,145946,2,3352,0)=" ..S ISSUB=$$PATISSUB^IBCNEHLU(IDATA0)"
^XMB(3.9,145946,2,3353,0)="""RTN"",""IBCNEHL1A"",89,0)"
^XMB(3.9,145946,2,3354,0)=" ..;Patient is the subscriber"
^XMB(3.9,145946,2,3355,0)="""RTN"",""IBCNEHL1A"",90,0)"
^XMB(3.9,145946,2,3356,0)=" ..I ISSUB,'$$CHK1^IBCNEHL3 Q"
^XMB(3.9,145946,2,3357,0)="""RTN"",""IBCNEHL1A"",91,0)"
^XMB(3.9,145946,2,3358,0)=" ..;Patient is the dependent"
^XMB(3.9,145946,2,3359,0)="""RTN"",""IBCNEHL1A"",92,0)"
^XMB(3.9,145946,2,3360,0)=" ..; Sub call needs to know this is not Medicare"
^XMB(3.9,145946,2,3361,0)="""RTN"",""IBCNEHL1A"",93,0)"
^XMB(3.9,145946,2,3362,0)=" ..;I 'ISSUB,'$$CHK2^IBCNEHL3(MWNRTYP) Q"
^XMB(3.9,145946,2,3363,0)="""RTN"",""IBCNEHL1A"",94,0)"
^XMB(3.9,145946,2,3364,0)=" ..I 'ISSUB,'$$CHK2^IBCNEHL3(0) Q"
^XMB(3.9,145946,2,3365,0)="""RTN"",""IBCNEHL1A"",95,0)"
^XMB(3.9,145946,2,3366,0)=" ..;check group #"
^XMB(3.9,145946,2,3367,0)="""RTN"",""IBCNEHL1A"",96,0)"
^XMB(3.9,145946,2,3368,0)=" ..S GNUM=$P(RDATA14,U,2),GIEN=+$P(IDATA0,U,18),GOK=1  ;IB*497 - group # needs to be retrieved from new field"
^XMB(3.9,145946,2,3369,0)="""RTN"",""IBCNEHL1A"",97,0)"
^XMB(3.9,145946,2,3370,0)=" ..; Remove check for non Medicare group # ;I '+MWNRTYP D  Q:'GOK"
^XMB(3.9,145946,2,3371,0)="""RTN"",""IBCNEHL1A"",98,0)"
^XMB(3.9,145946,2,3372,0)=" ..D  Q:'GOK  ;Group # doesn't match"
^XMB(3.9,145946,2,3373,0)="""RTN"",""IBCNEHL1A"",99,0)"
^XMB(3.9,145946,2,3374,0)=" ...I 'ONEPOL D"
^XMB(3.9,145946,2,3375,0)="""RTN"",""IBCNEHL1A"",100,0)"
^XMB(3.9,145946,2,3376,0)=" ... .I GIEN'>0 S GOK=0 Q"
^XMB(3.9,145946,2,3377,0)="""RTN"",""IBCNEHL1A"",101,0)"
^XMB(3.9,145946,2,3378,0)=" ... .S GNUM1=$P($G(^IBA(355.3,GIEN,2)),U,2)   ;IB*497 (vd)"
^XMB(3.9,145946,2,3379,0)="""RTN"",""IBCNEHL1A"",102,0)"
^XMB(3.9,145946,2,3380,0)=" ... .I GNUM=""""!(GNUM1="""")!(GNUM'=GNUM1) S GOK=0"
^XMB(3.9,145946,2,3381,0)="""RTN"",""IBCNEHL1A"",103,0)"
^XMB(3.9,145946,2,3382,0)=" ...I ONEPOL D"
^XMB(3.9,145946,2,3383,0)="""RTN"",""IBCNEHL1A"",104,0)"
^XMB(3.9,145946,2,3384,0)=" ... .I GNUM'="""",GIEN'="""" S GNUM1=$P($G(^IBA(355.3,GIEN,2)),U,2) I GNUM1'="""",GNUM'=GNUM1 S GOK=0  ;IB*497 (vd)"
^XMB(3.9,145946,2,3385,0)="""RTN"",""IBCNEHL1A"",105,0)"
^XMB(3.9,145946,2,3386,0)=" ..; Process Blues and non-MWNR"
^XMB(3.9,145946,2,3387,0)="""RTN"",""IBCNEHL1A"",106,0)"
^XMB(3.9,145946,2,3388,0)=" .. D   ;Not Medicare"
^XMB(3.9,145946,2,3389,0)="""RTN"",""IBCNEHL1A"",107,0)"
^XMB(3.9,145946,2,3390,0)=" ... S P3=$P(RES,U,3),P3=P3_$S($L(P3):""~"",1:"""")_IEN312"
^XMB(3.9,145946,2,3391,0)="""RTN"",""IBCNEHL1A"",108,0)"
^XMB(3.9,145946,2,3392,0)=" ... S RES=1_U_IEN2_U_P3_U_U_0_U_ISSUB ;Process Blues and non-MWNR "
^XMB(3.9,145946,2,3393,0)="""RTN"",""IBCNEHL1A"",109,0)"
^XMB(3.9,145946,2,3394,0)=" Q RES"
^XMB(3.9,145946,2,3395,0)="""RTN"",""IBCNEHL1A"",110,0)"
^XMB(3.9,145946,2,3396,0)=" ;"
^XMB(3.9,145946,2,3397,0)="""RTN"",""IBCNEHL1A"",111,0)"
^XMB(3.9,145946,2,3398,0)=" ; -----------------------------------------------"
^XMB(3.9,145946,2,3399,0)="""RTN"",""IBCNEHL1A"",112,0)"
^XMB(3.9,145946,2,3400,0)="CHKMCR ; Medicare checks to determine if we can auto-load new policy"
^XMB(3.9,145946,2,3401,0)="""RTN"",""IBCNEHL1A"",113,0)"
^XMB(3.9,145946,2,3402,0)=" ;       or auto-update existing policy"
^XMB(3.9,145946,2,3403,0)="""RTN"",""IBCNEHL1A"",114,0)"
^XMB(3.9,145946,2,3404,0)=" ;"
^XMB(3.9,145946,2,3405,0)="""RTN"",""IBCNEHL1A"",115,0)"
^XMB(3.9,145946,2,3406,0)=" ;Changed app to EIV from IIV"
^XMB(3.9,145946,2,3407,0)="""RTN"",""IBCNEHL1A"",116,0)"
^XMB(3.9,145946,2,3408,0)=" I +PIEN>0 S APPIEN=$$PYRAPP^IBCNEUT5(""EIV"",PIEN)"
^XMB(3.9,145946,2,3409,0)="""RTN"",""IBCNEHL1A"",117,0)"
^XMB(3.9,145946,2,3410,0)=" I +$G(APPIEN)'>0 Q  ;couldn't find eIV application entry"
^XMB(3.9,145946,2,3411,0)="""RTN"",""IBCNEHL1A"",118,0)"
^XMB(3.9,145946,2,3412,0)=" ;"
^XMB(3.9,145946,2,3413,0)="""RTN"",""IBCNEHL1A"",119,0)"
^XMB(3.9,145946,2,3414,0)=" S LOAD=$$LOAD^IBCNEHL5A(RIEN) I LOAD Q  ; LOADING the Medicare policy if allowed"
^XMB(3.9,145946,2,3415,0)="""RTN"",""IBCNEHL1A"",120,0)"
^XMB(3.9,145946,2,3416,0)=" ;"
^XMB(3.9,145946,2,3417,0)="""RTN"",""IBCNEHL1A"",121,0)"
^XMB(3.9,145946,2,3418,0)=" ;"
^XMB(3.9,145946,2,3419,0)="""RTN"",""IBCNEHL1A"",122,0)"
^XMB(3.9,145946,2,3420,0)=" ; Only continue if we didn't load the active policy to patient's record as a new policy"
^XMB(3.9,145946,2,3421,0)="""RTN"",""IBCNEHL1A"",123,0)"
^XMB(3.9,145946,2,3422,0)=" ;"
^XMB(3.9,145946,2,3423,0)="""RTN"",""IBCNEHL1A"",124,0)"
^XMB(3.9,145946,2,3424,0)=" ;Don't allow any entry with HMS SOI to auto-update"
^XMB(3.9,145946,2,3425,0)="""RTN"",""IBCNEHL1A"",125,0)"
^XMB(3.9,145946,2,3426,0)=" ;Don't allow any entry with Contract Services SOI to auto-update"
^XMB(3.9,145946,2,3427,0)="""RTN"",""IBCNEHL1A"",126,0)"
^XMB(3.9,145946,2,3428,0)=" I $P(RDATA0,U,5)'="""" I ""^HMS^CONTRACT SERVICES^""[(""^""_$$GET1^DIQ(365.1,$P(RDATA0,U,5)_"","",""SOURCE OF INFORMATION"",""E"")_""^"") Q RES"
^XMB(3.9,145946,2,3429,0)="""RTN"",""IBCNEHL1A"",127,0)"
^XMB(3.9,145946,2,3430,0)=" ;"
^XMB(3.9,145946,2,3431,0)="""RTN"",""IBCNEHL1A"",128,0)"
^XMB(3.9,145946,2,3432,0)=" ; allow auto update for some ""Request Electronic Insurance Inquiry"" requests"
^XMB(3.9,145946,2,3433,0)="""RTN"",""IBCNEHL1A"",129,0)"
^XMB(3.9,145946,2,3434,0)=" ;"
^XMB(3.9,145946,2,3435,0)="""RTN"",""IBCNEHL1A"",130,0)"
^XMB(3.9,145946,2,3436,0)=" ; get values"
^XMB(3.9,145946,2,3437,0)="""RTN"",""IBCNEHL1A"",131,0)"
^XMB(3.9,145946,2,3438,0)=" S (IBGETTQ,IBGETDEF,IBGETWE,IBGETSTC)="""""
^XMB(3.9,145946,2,3439,0)="""RTN"",""IBCNEHL1A"",132,0)"
^XMB(3.9,145946,2,3440,0)=" ; Get 365.1 transmission queue number"
^XMB(3.9,145946,2,3441,0)="""RTN"",""IBCNEHL1A"",133,0)"
^XMB(3.9,145946,2,3442,0)=" S IBGETTQ=$$GET1^DIQ(365,RIEN_"","",.05,""I"") I IBGETTQ="""" Q"
^XMB(3.9,145946,2,3443,0)="""RTN"",""IBCNEHL1A"",134,0)"
^XMB(3.9,145946,2,3444,0)=" ; Get 365.1 which extract"
^XMB(3.9,145946,2,3445,0)="""RTN"",""IBCNEHL1A"",135,0)"
^XMB(3.9,145946,2,3446,0)=" S IBGETNOK=0"
^XMB(3.9,145946,2,3447,0)="""RTN"",""IBCNEHL1A"",136,0)"
^XMB(3.9,145946,2,3448,0)=" S IBGETWE=$$GET1^DIQ(365.1,IBGETTQ_"","",.1,""I"") I IBGETWE=5 D  I IBGETNOK Q"
^XMB(3.9,145946,2,3449,0)="""RTN"",""IBCNEHL1A"",137,0)"
^XMB(3.9,145946,2,3450,0)=" . ; Get 350.9 default service type code"
^XMB(3.9,145946,2,3451,0)="""RTN"",""IBCNEHL1A"",138,0)"
^XMB(3.9,145946,2,3452,0)=" . S IBGETDEF=$$GET1^DIQ(350.9,1_"","",60.01,""I"") I IBGETDEF="""" S IBGETNOK=1 Q"
^XMB(3.9,145946,2,3453,0)="""RTN"",""IBCNEHL1A"",139,0)"
^XMB(3.9,145946,2,3454,0)=" . ; Get 365 requested service type code"
^XMB(3.9,145946,2,3455,0)="""RTN"",""IBCNEHL1A"",140,0)"
^XMB(3.9,145946,2,3456,0)=" . S IBGETSTC=$$GET1^DIQ(365,RIEN_"","",.15,""I"") I IBGETSTC'=IBGETDEF S IBGETNOK=1 Q"
^XMB(3.9,145946,2,3457,0)="""RTN"",""IBCNEHL1A"",141,0)"
^XMB(3.9,145946,2,3458,0)=" ;"
^XMB(3.9,145946,2,3459,0)="""RTN"",""IBCNEHL1A"",142,0)"
^XMB(3.9,145946,2,3460,0)=" I '$$GET1^DIQ(365.121,APPIEN_"",""_PIEN_"","",4.01,""I"") Q  ; auto-update is OFF"
^XMB(3.9,145946,2,3461,0)="""RTN"",""IBCNEHL1A"",143,0)"
^XMB(3.9,145946,2,3462,0)=" ;"
^XMB(3.9,145946,2,3463,0)="""RTN"",""IBCNEHL1A"",144,0)"
^XMB(3.9,145946,2,3464,0)=" S IEN2=$P(RDATA0,U,2) I +IEN2'>0 Q  ; couldn't find patient"
^XMB(3.9,145946,2,3465,0)="""RTN"",""IBCNEHL1A"",145,0)"
^XMB(3.9,145946,2,3466,0)=" ;"
^XMB(3.9,145946,2,3467,0)="""RTN"",""IBCNEHL1A"",146,0)"
^XMB(3.9,145946,2,3468,0)=" ;try to find a matching pat. insurance"
^XMB(3.9,145946,2,3469,0)="""RTN"",""IBCNEHL1A"",147,0)"
^XMB(3.9,145946,2,3470,0)=" S IEN36="""" F  S IEN36=$O(^DIC(36,""AC"",PIEN,IEN36)) Q:IEN36=""""  D"
^XMB(3.9,145946,2,3471,0)="""RTN"",""IBCNEHL1A"",148,0)"
^XMB(3.9,145946,2,3472,0)=" .S IEN312="""" F  S IEN312=$O(^DPT(IEN2,.312,""B"",IEN36,IEN312)) Q:IEN312=""""  D"
^XMB(3.9,145946,2,3473,0)="""RTN"",""IBCNEHL1A"",149,0)"
^XMB(3.9,145946,2,3474,0)=" ..S IDATA0=$G(^DPT(IEN2,.312,IEN312,0)),IDATA3=$G(^DPT(IEN2,.312,IEN312,3))"
^XMB(3.9,145946,2,3475,0)="""RTN"",""IBCNEHL1A"",150,0)"
^XMB(3.9,145946,2,3476,0)=" ..S IDATA7=$G(^DPT(IEN2,.312,IEN312,7))"
^XMB(3.9,145946,2,3477,0)="""RTN"",""IBCNEHL1A"",151,0)"
^XMB(3.9,145946,2,3478,0)=" ..I $$EXPIRED^IBCNEHL1($P(IDATA0,U,4)) Q       ;Insurance policy has expired"
^XMB(3.9,145946,2,3479,0)="""RTN"",""IBCNEHL1A"",152,0)"
^XMB(3.9,145946,2,3480,0)=" ..S ISSUB=$$PATISSUB^IBCNEHLU(IDATA0)"
^XMB(3.9,145946,2,3481,0)="""RTN"",""IBCNEHL1A"",153,0)"
^XMB(3.9,145946,2,3482,0)=" ..;Patient is the subscriber"
^XMB(3.9,145946,2,3483,0)="""RTN"",""IBCNEHL1A"",154,0)"
^XMB(3.9,145946,2,3484,0)=" ..I ISSUB,'$$CHK1^IBCNEHL3 Q"
^XMB(3.9,145946,2,3485,0)="""RTN"",""IBCNEHL1A"",155,0)"
^XMB(3.9,145946,2,3486,0)=" ..;Patient is the dependent"
^XMB(3.9,145946,2,3487,0)="""RTN"",""IBCNEHL1A"",156,0)"
^XMB(3.9,145946,2,3488,0)=" ..I 'ISSUB,'$$CHK2^IBCNEHL3(MWNRTYP) Q"
^XMB(3.9,145946,2,3489,0)="""RTN"",""IBCNEHL1A"",157,0)"
^XMB(3.9,145946,2,3490,0)=" ..;check group #"
^XMB(3.9,145946,2,3491,0)="""RTN"",""IBCNEHL1A"",158,0)"
^XMB(3.9,145946,2,3492,0)=" ..S GNUM=$P(RDATA14,U,2),GIEN=+$P(IDATA0,U,18),GOK=1"
^XMB(3.9,145946,2,3493,0)="""RTN"",""IBCNEHL1A"",159,0)"
^XMB(3.9,145946,2,3494,0)=" ..D  Q:'GOK  ;Group # doesn't match"
^XMB(3.9,145946,2,3495,0)="""RTN"",""IBCNEHL1A"",160,0)"
^XMB(3.9,145946,2,3496,0)=" ...I GIEN'>0 S GOK=0 Q"
^XMB(3.9,145946,2,3497,0)="""RTN"",""IBCNEHL1A"",161,0)"
^XMB(3.9,145946,2,3498,0)=" ...S GDATA=$G(^IBA(355.3,GIEN,0))"
^XMB(3.9,145946,2,3499,0)="""RTN"",""IBCNEHL1A"",162,0)"
^XMB(3.9,145946,2,3500,0)=" ...I $P(GDATA,U,14)=""A"" D"
^XMB(3.9,145946,2,3501,0)="""RTN"",""IBCNEHL1A"",163,0)"
^XMB(3.9,145946,2,3502,0)=" ....I $P(MWNRTYP,U,5)=""MA""!($P(MWNRTYP,U,5)=""B"") S MWNRA=IEN312 Q"
^XMB(3.9,145946,2,3503,0)="""RTN"",""IBCNEHL1A"",164,0)"
^XMB(3.9,145946,2,3504,0)=" ....S GOK=0"
^XMB(3.9,145946,2,3505,0)="""RTN"",""IBCNEHL1A"",165,0)"
^XMB(3.9,145946,2,3506,0)=" ...I $P(GDATA,U,14)=""B"" D"
^XMB(3.9,145946,2,3507,0)="""RTN"",""IBCNEHL1A"",166,0)"
^XMB(3.9,145946,2,3508,0)=" ... .I $P(MWNRTYP,U,5)=""MB""!($P(MWNRTYP,U,5)=""B"") S MWNRB=IEN312 Q"
^XMB(3.9,145946,2,3509,0)="""RTN"",""IBCNEHL1A"",167,0)"
^XMB(3.9,145946,2,3510,0)=" ... .S GOK=0"
^XMB(3.9,145946,2,3511,0)="""RTN"",""IBCNEHL1A"",168,0)"
^XMB(3.9,145946,2,3512,0)=" ..S RES=1_U_IEN2_U_MWNRA_U_MWNRB_U_1_U_ISSUB Q   ;Process MWNR"
^XMB(3.9,145946,2,3513,0)="""RTN"",""IBCNEHL1A"",169,0)"
^XMB(3.9,145946,2,3514,0)=" Q"
^XMB(3.9,145946,2,3515,0)="""RTN"",""IBCNEHL1A"",170,0)"
^XMB(3.9,145946,2,3516,0)=" ;"
^XMB(3.9,145946,2,3517,0)="""RTN"",""IBCNEQU"")"
