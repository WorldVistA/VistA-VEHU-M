^XMB(3.9,145946,2,5407,0)="""RTN"",""IBCNSU21"",63,0)"
^XMB(3.9,145946,2,5408,0)=" ;"
^XMB(3.9,145946,2,5409,0)="""RTN"",""IBCNSU21"",64,0)"
^XMB(3.9,145946,2,5410,0)=" S X2=$S('IBACT:""Inactive "",IBACT=2:"""",1:""Active "")"
^XMB(3.9,145946,2,5411,0)="""RTN"",""IBCNSU21"",65,0)"
