^XMB(3.9,145946,2,5435,0)="""RTN"",""IBCNSU21"",77,0)"
^XMB(3.9,145946,2,5436,0)=" S X=$$GET1^DIQ(36,+IBCNS_"","",.114) I X']"""" S X=""<no city>""_"", """
^XMB(3.9,145946,2,5437,0)="""RTN"",""IBCNSU21"",78,0)"
