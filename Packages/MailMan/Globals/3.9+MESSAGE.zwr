^XMB(3.9,145989,2,777,0)="""RTN"",""PSOASAP0"",246,0)"
^XMB(3.9,145989,2,778,0)=" N DSP05"
^XMB(3.9,145989,2,779,0)="""RTN"",""PSOASAP0"",247,0)"
^XMB(3.9,145989,2,780,0)=" I $G(BATCHIEN),$$GET1^DIQ(58.42,BATCHIEN,2,""I"")=""ZR"" S DSP05=$$GET1^DIQ(58.42,BATCHIEN,8,""I"") Q $$FMTHL7^XLFDT((DSP05)\1)"
