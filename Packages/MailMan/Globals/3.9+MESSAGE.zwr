^XMB(3.9,145946,2,4819,0)="""RTN"",""IBCNILK"",241,0)"
^XMB(3.9,145946,2,4820,0)=" S LINE=$$SETSTR^VALM1(XX,LINE,46,35)               ; Street Address"
