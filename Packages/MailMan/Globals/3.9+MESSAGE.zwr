^XMB(3.9,145944,2,2255,0)="""RTN"",""IBJDF61"",193,0)"
^XMB(3.9,145944,2,2256,0)=" F  S IBA1=$S(IBSH1=""M"":$O(^PRCA(433,""C"",IBA,IBA1),-1),1:$O(^PRCA(433,""C"",IBA,IBA1))) Q:'IBA1  D  I IBSH1=""M"",DAT Q"
^XMB(3.9,145944,2,2257,0)="""RTN"",""IBJDF61"",194,0)"
^XMB(3.9,145944,2,2258,0)=" . S IBC=$G(^PRCA(433,IBA1,1)) Q:'IBC"
^XMB(3.9,145944,2,2259,0)="""RTN"",""IBJDF61"",195,0)"
^XMB(3.9,145944,2,2260,0)=" . I $G(IBSH2),$$FMDIFF^XLFDT(DT,+IBC)<IBSH2 Q  ; Comment age not minimum."
^XMB(3.9,145944,2,2261,0)="""RTN"",""IBJDF61"",196,0)"
^XMB(3.9,145944,2,2262,0)=" . I $P(IBC,U,2)'=35,$P(IBC,U,2)'=45 Q  ;   Not decrease/comment transact."
^XMB(3.9,145944,2,2263,0)="""RTN"",""IBJDF61"",197,0)"
^XMB(3.9,145944,2,2264,0)=" . S DAT=$S(IBC:+IBC\1,1:+$P(IBC,U,9)\1)"
^XMB(3.9,145944,2,2265,0)="""RTN"",""IBJDF61"",198,0)"
^XMB(3.9,145944,2,2266,0)=" . I $G(IBEXCEL),IBSH1=""M"" S IBEXCEL1=IBEXCEL1_$$DT^IBJD(DAT,1) Q"
^XMB(3.9,145944,2,2267,0)="""RTN"",""IBJDF61"",199,0)"
^XMB(3.9,145944,2,2268,0)=" . ;"
^XMB(3.9,145944,2,2269,0)="""RTN"",""IBJDF61"",200,0)"
^XMB(3.9,145944,2,2270,0)=" . ; - Append brief and transaction comments."
^XMB(3.9,145944,2,2271,0)="""RTN"",""IBJDF61"",201,0)"
^XMB(3.9,145944,2,2272,0)=" . K COM,COM1 S COM(0)=DAT,X1=0"
^XMB(3.9,145944,2,2273,0)="""RTN"",""IBJDF61"",202,0)"
^XMB(3.9,145944,2,2274,0)=" . S COM1(1)=$P($G(^PRCA(433,IBA1,5)),U,2)"
^XMB(3.9,145944,2,2275,0)="""RTN"",""IBJDF61"",203,0)"
^XMB(3.9,145944,2,2276,0)=" . S COM1(2)=$E($P($G(^PRCA(433,IBA1,8)),U,6),1,70)"
^XMB(3.9,145944,2,2277,0)="""RTN"",""IBJDF61"",204,0)"
^XMB(3.9,145944,2,2278,0)=" . S COM(1)=COM1(1)_$S(COM1(1)]""""&(COM1(2)]""""):""|"",1:"""")_COM1(2)"
^XMB(3.9,145944,2,2279,0)="""RTN"",""IBJDF61"",205,0)"
^XMB(3.9,145944,2,2280,0)=" . I COM(1)]"""" S COM(1)=""**""_COM(1)_""**"",X1=1"
^XMB(3.9,145944,2,2281,0)="""RTN"",""IBJDF61"",206,0)"
^XMB(3.9,145944,2,2282,0)=" . ;"
^XMB(3.9,145944,2,2283,0)="""RTN"",""IBJDF61"",207,0)"
^XMB(3.9,145944,2,2284,0)=" . ; - Get main comments."
^XMB(3.9,145944,2,2285,0)="""RTN"",""IBJDF61"",208,0)"
^XMB(3.9,145944,2,2286,0)=" . S X2=0 F  S X2=$O(^PRCA(433,IBA1,7,X2)) Q:'X2  S COM($S(X1:X2+1,1:X2))=^(X2,0)"
^XMB(3.9,145944,2,2287,0)="""RTN"",""IBJDF61"",209,0)"
^XMB(3.9,145944,2,2288,0)=" . ;"
^XMB(3.9,145944,2,2289,0)="""RTN"",""IBJDF61"",210,0)"
^XMB(3.9,145944,2,2290,0)=" . S X1="""" F  S X1=$O(COM(X1)) Q:X1=""""  D"
^XMB(3.9,145944,2,2291,0)="""RTN"",""IBJDF61"",211,0)"
^XMB(3.9,145944,2,2292,0)=" . . S IBGLB=$S(IBCAT1<8:""IBJDF6P"",1:""IBJDF6D"")    ;IB*2.0*618"
^XMB(3.9,145944,2,2293,0)="""RTN"",""IBJDF61"",212,0)"
^XMB(3.9,145944,2,2294,0)=" . . S ^TMP(IBGLB,$J,IBDIV,IBCAT,IBIN,$P(IBPTDB,U),IBBN,IBA1,X1)=COM(X1)"
^XMB(3.9,145944,2,2295,0)="""RTN"",""IBJDF61"",213,0)"
^XMB(3.9,145944,2,2296,0)=" ;"
^XMB(3.9,145944,2,2297,0)="""RTN"",""IBJDF61"",214,0)"
^XMB(3.9,145944,2,2298,0)=" Q"
^XMB(3.9,145944,2,2299,0)="""RTN"",""IBJDF61"",215,0)"
^XMB(3.9,145944,2,2300,0)="CATCHK(IBCAT) ; Check to see if the AR Category should be a patient or Debtor Category"
^XMB(3.9,145944,2,2301,0)="""RTN"",""IBJDF61"",216,0)"
^XMB(3.9,145944,2,2302,0)=" ; Output: 1 - Patient, 0 - Debtor (default)"
^XMB(3.9,145944,2,2303,0)="""RTN"",""IBJDF61"",217,0)"
^XMB(3.9,145944,2,2304,0)=" Q:IBCAT=6 1    ;Worker's Comp"
^XMB(3.9,145944,2,2305,0)="""RTN"",""IBJDF61"",218,0)"
^XMB(3.9,145944,2,2306,0)=" Q:IBCAT=7 1    ;No Fault"
^XMB(3.9,145944,2,2307,0)="""RTN"",""IBJDF61"",219,0)"
^XMB(3.9,145944,2,2308,0)=" Q:IBCAT=10 1   ;Tort"
^XMB(3.9,145944,2,2309,0)="""RTN"",""IBJDF61"",220,0)"
^XMB(3.9,145944,2,2310,0)=" Q:IBCAT=21 1   ;Medicare"
^XMB(3.9,145944,2,2311,0)="""RTN"",""IBJDF61"",221,0)"
^XMB(3.9,145944,2,2312,0)=" I (IBCAT>51),(IBCAT<61) Q 1  ; a WC, TORT or NF category for Community Care"
^XMB(3.9,145944,2,2313,0)="""RTN"",""IBJDF61"",222,0)"
^XMB(3.9,145944,2,2314,0)=" Q 0"
^XMB(3.9,145944,2,2315,0)="""RTN"",""IBJDF62"")"
^XMB(3.9,145944,2,2316,0)="0^3^B35799175"
^XMB(3.9,145944,2,2317,0)="""RTN"",""IBJDF62"",1,0)"
^XMB(3.9,145944,2,2318,0)="IBJDF62 ;ALB/RB - MISC. BILLS FOLLOW-UP REPORT (PRINT) ;15-APR-00"
^XMB(3.9,145944,2,2319,0)="""RTN"",""IBJDF62"",2,0)"
^XMB(3.9,145944,2,2320,0)=" ;;2.0;INTEGRATED BILLING;**123,159,618**;21-MAR-94;Build 0"
^XMB(3.9,145944,2,2321,0)="""RTN"",""IBJDF62"",3,0)"
^XMB(3.9,145944,2,2322,0)=" ;;Per VHA Directive 6402, this routine should not be modified."
^XMB(3.9,145944,2,2323,0)="""RTN"",""IBJDF62"",4,0)"
^XMB(3.9,145944,2,2324,0)=" ;"
^XMB(3.9,145944,2,2325,0)="""RTN"",""IBJDF62"",5,0)"
^XMB(3.9,145944,2,2326,0)=" ;Read ^PRCA(430.2) via Private IA 594"
^XMB(3.9,145944,2,2327,0)="""RTN"",""IBJDF62"",6,0)"
^XMB(3.9,145944,2,2328,0)=" ;"
^XMB(3.9,145944,2,2329,0)="""RTN"",""IBJDF62"",7,0)"
^XMB(3.9,145944,2,2330,0)="EN ; - Print the Follow-up report."
^XMB(3.9,145944,2,2331,0)="""RTN"",""IBJDF62"",8,0)"
^XMB(3.9,145944,2,2332,0)=" S IBQ=0 D NOW^%DTC S IBRUN=$$DAT2^IBOUTL(%) G:IBRPT=""S"" SUM"
^XMB(3.9,145944,2,2333,0)="""RTN"",""IBJDF62"",9,0)"
^XMB(3.9,145944,2,2334,0)=" I 'IBSDV D DET(0) G SUM"
^XMB(3.9,145944,2,2335,0)="""RTN"",""IBJDF62"",10,0)"
^XMB(3.9,145944,2,2336,0)=" S IBDIV="""""
^XMB(3.9,145944,2,2337,0)="""RTN"",""IBJDF62"",11,0)"
^XMB(3.9,145944,2,2338,0)=" F  S IBDIV=$O(VAUTD(IBDIV)) Q:IBDIV=""""  D  Q:IBQ"
^XMB(3.9,145944,2,2339,0)="""RTN"",""IBJDF62"",12,0)"
^XMB(3.9,145944,2,2340,0)=" . D DET(IBDIV)"
^XMB(3.9,145944,2,2341,0)="""RTN"",""IBJDF62"",13,0)"
^XMB(3.9,145944,2,2342,0)=" ;"
^XMB(3.9,145944,2,2343,0)="""RTN"",""IBJDF62"",14,0)"
^XMB(3.9,145944,2,2344,0)="SUM I 'IBQ D PRT^IBJDF63 ; Print summary."
^XMB(3.9,145944,2,2345,0)="""RTN"",""IBJDF62"",15,0)"
^XMB(3.9,145944,2,2346,0)="ENQ K IBN,IBIN,IBC,IBCD,IBC1,IBC2,IBCAT1,IBD,IBDIV,IBGBL,IBPAG,IBP,IBPD,IBPTD,IBQ,IBRUN,%"
^XMB(3.9,145944,2,2347,0)="""RTN"",""IBJDF62"",16,0)"
^XMB(3.9,145944,2,2348,0)=" Q"
^XMB(3.9,145944,2,2349,0)="""RTN"",""IBJDF62"",17,0)"
^XMB(3.9,145944,2,2350,0)=" ;"
^XMB(3.9,145944,2,2351,0)="""RTN"",""IBJDF62"",18,0)"
^XMB(3.9,145944,2,2352,0)="DET(IBDIV) ; - Print report for a specific division."
^XMB(3.9,145944,2,2353,0)="""RTN"",""IBJDF62"",19,0)"
^XMB(3.9,145944,2,2354,0)=" ; Input: IBDIV=Pointer to the division in file #40.8"
^XMB(3.9,145944,2,2355,0)="""RTN"",""IBJDF62"",20,0)"
^XMB(3.9,145944,2,2356,0)=" S IBCAT=0"
^XMB(3.9,145944,2,2357,0)="""RTN"",""IBJDF62"",21,0)"
^XMB(3.9,145944,2,2358,0)=" F  S IBCAT=$O(IBCAT(IBCAT)) Q:'IBCAT  D  Q:IBQ"
^XMB(3.9,145944,2,2359,0)="""RTN"",""IBJDF62"",22,0)"
^XMB(3.9,145944,2,2360,0)=" . S IBCAT1=IBCAT(IBCAT),IBGBL=$S(IBCAT1<8:""IBJDF6P"",1:""IBJDF6D"")   ;IB*2.0*618"
^XMB(3.9,145944,2,2361,0)="""RTN"",""IBJDF62"",23,0)"
^XMB(3.9,145944,2,2362,0)=" . I IBDIV,IBCAT1'<8 Q    ;IB*2.0*618"
^XMB(3.9,145944,2,2363,0)="""RTN"",""IBJDF62"",24,0)"
^XMB(3.9,145944,2,2364,0)=" . I IBSDV,'IBDIV,IBCAT1<8 Q   ;IB*2.0*618"
^XMB(3.9,145944,2,2365,0)="""RTN"",""IBJDF62"",25,0)"
^XMB(3.9,145944,2,2366,0)=" . I '$D(^TMP(IBGBL,$J,IBDIV,IBCAT)) D HDR1 Q:IBQ  D NAR,PAUSE Q"
^XMB(3.9,145944,2,2367,0)="""RTN"",""IBJDF62"",26,0)"
^XMB(3.9,145944,2,2368,0)=" . D HDR1 Q:IBQ"
^XMB(3.9,145944,2,2369,0)="""RTN"",""IBJDF62"",27,0)"
^XMB(3.9,145944,2,2370,0)=" . S IBIN="""" F  S IBIN=$O(^TMP(IBGBL,$J,IBDIV,IBCAT,IBIN)) Q:IBIN=""""  D  Q:IBQ"
^XMB(3.9,145944,2,2371,0)="""RTN"",""IBJDF62"",28,0)"
^XMB(3.9,145944,2,2372,0)=" . . I $Y>(IOSL-5) D PAUSE Q:IBQ  D HDR1 Q:IBQ"
^XMB(3.9,145944,2,2373,0)="""RTN"",""IBJDF62"",29,0)"
^XMB(3.9,145944,2,2374,0)=" . . D HDR2"
^XMB(3.9,145944,2,2375,0)="""RTN"",""IBJDF62"",30,0)"
^XMB(3.9,145944,2,2376,0)=" . . S (IBPTD,IB0,IBD)="""""
^XMB(3.9,145944,2,2377,0)="""RTN"",""IBJDF62"",31,0)"
^XMB(3.9,145944,2,2378,0)=" . . F  S IBPTD=$O(^TMP(IBGBL,$J,IBDIV,IBCAT,IBIN,IBPTD)) Q:IBPTD=""""  D  Q:IBQ"
^XMB(3.9,145944,2,2379,0)="""RTN"",""IBJDF62"",32,0)"
^XMB(3.9,145944,2,2380,0)=" . . . I $Y>(IOSL-5) D PAUSE Q:IBQ  D HDR1,HDR2 Q:IBQ"
^XMB(3.9,145944,2,2381,0)="""RTN"",""IBJDF62"",33,0)"
^XMB(3.9,145944,2,2382,0)=" . . . S IBPD=$G(^TMP(IBGBL,$J,IBDIV,IBCAT,IBIN,IBPTD))"
^XMB(3.9,145944,2,2383,0)="""RTN"",""IBJDF62"",34,0)"
^XMB(3.9,145944,2,2384,0)=" . . . D WPAT"
^XMB(3.9,145944,2,2385,0)="""RTN"",""IBJDF62"",35,0)"
^XMB(3.9,145944,2,2386,0)=" . . . F  S IB0=$O(^TMP(IBGBL,$J,IBDIV,IBCAT,IBIN,IBPTD,IB0)) Q:IB0=""""  D  Q:IBQ"
^XMB(3.9,145944,2,2387,0)="""RTN"",""IBJDF62"",36,0)"
^XMB(3.9,145944,2,2388,0)=" . . . . S IBN=$G(^TMP(IBGBL,$J,IBDIV,IBCAT,IBIN,IBPTD,IB0))"
^XMB(3.9,145944,2,2389,0)="""RTN"",""IBJDF62"",37,0)"
^XMB(3.9,145944,2,2390,0)=" . . . . I $Y>(IOSL-3) D PAUSE Q:IBQ  D HDR1,HDR2 Q:IBQ  D WPAT"
^XMB(3.9,145944,2,2391,0)="""RTN"",""IBJDF62"",38,0)"
^XMB(3.9,145944,2,2392,0)=" . . . . I IBCAT1<8 D      ;IB*2.0*618"
^XMB(3.9,145944,2,2393,0)="""RTN"",""IBJDF62"",39,0)"
^XMB(3.9,145944,2,2394,0)=" . . . . . W ?71,IB0,?84,$$DAT1^IBOUTL(+IBN),?94,$$DAT1^IBOUTL($P(IBN,U,2))"
^XMB(3.9,145944,2,2395,0)="""RTN"",""IBJDF62"",40,0)"
^XMB(3.9,145944,2,2396,0)=" . . . . . W ?104,$$DAT1^IBOUTL($P(IBN,U,3)),?114,$J($P(IBN,U,4),8,2)"
^XMB(3.9,145944,2,2397,0)="""RTN"",""IBJDF62"",41,0)"
^XMB(3.9,145944,2,2398,0)=" . . . . . W ?124,$J($P(IBN,U,5),8,2),!"
^XMB(3.9,145944,2,2399,0)="""RTN"",""IBJDF62"",42,0)"
^XMB(3.9,145944,2,2400,0)=" . . . . E   D"
^XMB(3.9,145944,2,2401,0)="""RTN"",""IBJDF62"",43,0)"
^XMB(3.9,145944,2,2402,0)=" . . . . . W ?33,IB0,?47,$$DAT1^IBOUTL(+IBN),?59,$P($P(IBN,U,2),""@@"")"
^XMB(3.9,145944,2,2403,0)="""RTN"",""IBJDF62"",44,0)"
^XMB(3.9,145944,2,2404,0)=" . . . . . W ?92,$J($P(IBN,U,3),8,2),?103,$J($P(IBN,U,4),8,2)"
^XMB(3.9,145944,2,2405,0)="""RTN"",""IBJDF62"",45,0)"
^XMB(3.9,145944,2,2406,0)=" . . . . . W ?114,$J($P(IBN,U,5),8,2),!"
^XMB(3.9,145944,2,2407,0)="""RTN"",""IBJDF62"",46,0)"
^XMB(3.9,145944,2,2408,0)=" . . . . ; "
^XMB(3.9,145944,2,2409,0)="""RTN"",""IBJDF62"",47,0)"
^XMB(3.9,145944,2,2410,0)=" . . . . ; - Display bill comment history, if necessary."
^XMB(3.9,145944,2,2411,0)="""RTN"",""IBJDF62"",48,0)"
^XMB(3.9,145944,2,2412,0)=" . . . . I IBSH D COM"
^XMB(3.9,145944,2,2413,0)="""RTN"",""IBJDF62"",49,0)"
^XMB(3.9,145944,2,2414,0)=" . ;"
^XMB(3.9,145944,2,2415,0)="""RTN"",""IBJDF62"",50,0)"
^XMB(3.9,145944,2,2416,0)=" . I 'IBQ D PAUSE"
^XMB(3.9,145944,2,2417,0)="""RTN"",""IBJDF62"",51,0)"
^XMB(3.9,145944,2,2418,0)=" ;"
^XMB(3.9,145944,2,2419,0)="""RTN"",""IBJDF62"",52,0)"
^XMB(3.9,145944,2,2420,0)="DETQ Q"
^XMB(3.9,145944,2,2421,0)="""RTN"",""IBJDF62"",53,0)"
^XMB(3.9,145944,2,2422,0)=" ;"
^XMB(3.9,145944,2,2423,0)="""RTN"",""IBJDF62"",54,0)"
^XMB(3.9,145944,2,2424,0)="DASH(X) ; - Return a dashed line."
^XMB(3.9,145944,2,2425,0)="""RTN"",""IBJDF62"",55,0)"
^XMB(3.9,145944,2,2426,0)=" Q $TR($J("""",X),"" "",""="")"
^XMB(3.9,145944,2,2427,0)="""RTN"",""IBJDF62"",56,0)"
^XMB(3.9,145944,2,2428,0)=" ;"
^XMB(3.9,145944,2,2429,0)="""RTN"",""IBJDF62"",57,0)"
^XMB(3.9,145944,2,2430,0)="PAUSE ; - Page break."
^XMB(3.9,145944,2,2431,0)="""RTN"",""IBJDF62"",58,0)"
^XMB(3.9,145944,2,2432,0)=" I $E(IOST,1,2)'=""C-"" Q"
^XMB(3.9,145944,2,2433,0)="""RTN"",""IBJDF62"",59,0)"
^XMB(3.9,145944,2,2434,0)=" N IBX,DIR,DIRUT,DUOUT,DTOUT,DIROUT,X,Y"
^XMB(3.9,145944,2,2435,0)="""RTN"",""IBJDF62"",60,0)"
^XMB(3.9,145944,2,2436,0)=" F IBX=$Y:1:(IOSL-3) W !"
^XMB(3.9,145944,2,2437,0)="""RTN"",""IBJDF62"",61,0)"
^XMB(3.9,145944,2,2438,0)=" S DIR(0)=""E"" D ^DIR S:$D(DIRUT)!($D(DUOUT)) IBQ=1"
^XMB(3.9,145944,2,2439,0)="""RTN"",""IBJDF62"",62,0)"
^XMB(3.9,145944,2,2440,0)=" Q"
^XMB(3.9,145944,2,2441,0)="""RTN"",""IBJDF62"",63,0)"
^XMB(3.9,145944,2,2442,0)=" ;"
^XMB(3.9,145944,2,2443,0)="""RTN"",""IBJDF62"",64,0)"
^XMB(3.9,145944,2,2444,0)="HDR1 ; - Write the primary report header. "
^XMB(3.9,145944,2,2445,0)="""RTN"",""IBJDF62"",65,0)"
^XMB(3.9,145944,2,2446,0)=" N IBCATNM"
^XMB(3.9,145944,2,2447,0)="""RTN"",""IBJDF62"",66,0)"
^XMB(3.9,145944,2,2448,0)=" I $E(IOST,1,2)=""C-""!$G(IBPAG) W @IOF,*13"
^XMB(3.9,145944,2,2449,0)="""RTN"",""IBJDF62"",67,0)"
