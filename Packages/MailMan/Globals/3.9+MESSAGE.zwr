^XMB(3.9,145946,2,839,0)="""RTN"",""IBCMDT"",98,0)"
^XMB(3.9,145946,2,840,0)=" I STOP G:$$STOP EXIT G F40"
^XMB(3.9,145946,2,841,0)="""RTN"",""IBCMDT"",99,0)"
