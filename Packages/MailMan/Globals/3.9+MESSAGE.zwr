^XMB(3.9,145946,2,4975,0)="""RTN"",""IBCNILK"",319,0)"
^XMB(3.9,145946,2,4976,0)=" S VALMBCK=""R"",ERROR=0"
^XMB(3.9,145946,2,4977,0)="""RTN"",""IBCNILK"",320,0)"
^XMB(3.9,145946,2,4978,0)=" ; "
^XMB(3.9,145946,2,4979,0)="""RTN"",""IBCNILK"",321,0)"
^XMB(3.9,145946,2,4980,0)=" ; First select the Insurance Company(s) to be deselected"
^XMB(3.9,145946,2,4981,0)="""RTN"",""IBCNILK"",322,0)"
^XMB(3.9,145946,2,4982,0)=" S PROMPT=""DESELECT Insurance Company(s)""   ;IB*763/CKB"
^XMB(3.9,145946,2,4983,0)="""RTN"",""IBCNILK"",323,0)"
^XMB(3.9,145946,2,4984,0)=" S IIENS=$$SELINS(1,PROMPT,.DLINE,1,WARRAY)"
^XMB(3.9,145946,2,4985,0)="""RTN"",""IBCNILK"",324,0)"
^XMB(3.9,145946,2,4986,0)=" I IIENS="""" S VALMBCK=""R"" Q                 ; None Selected"
