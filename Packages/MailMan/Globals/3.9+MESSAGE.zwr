^XMB(3.9,145980,2,3811,0)="""RTN"",""SDES2CANCELAPPT2"",62,0)"
^XMB(3.9,145980,2,3812,0)=" ;"
^XMB(3.9,145980,2,3813,0)="""RTN"",""SDES2CANCELAPPT2"",63,0)"
^XMB(3.9,145980,2,3814,0)=" I $G(PARAMS(""NEW PID""))'="""" D  Q:$D(SDERRORS) 0"
^XMB(3.9,145980,2,3815,0)="""RTN"",""SDES2CANCELAPPT2"",64,0)"
^XMB(3.9,145980,2,3816,0)=" . S PID=$$ISOTFM^SDAMUTDT(PARAMS(""NEW PID""))"
^XMB(3.9,145980,2,3817,0)="""RTN"",""SDES2CANCELAPPT2"",65,0)"
^XMB(3.9,145980,2,3818,0)=" . I PID=-1!($P(PID,""."",2)) D ERRLOG^SDES2JSON(.SDERRORS,160) Q"
^XMB(3.9,145980,2,3819,0)="""RTN"",""SDES2CANCELAPPT2"",66,0)"
