^XMB(3.9,145989,2,697,0)="""RTN"",""PSOASAP0"",206,0)"
^XMB(3.9,145989,2,698,0)=" ;"
^XMB(3.9,145989,2,699,0)="""RTN"",""PSOASAP0"",207,0)"
^XMB(3.9,145989,2,700,0)="RX14() ;Product ID (NDC - National Drug Code)"
^XMB(3.9,145989,2,701,0)="""RTN"",""PSOASAP0"",208,0)"
^XMB(3.9,145989,2,702,0)=" N RX14 S RX14="""""
^XMB(3.9,145989,2,703,0)="""RTN"",""PSOASAP0"",209,0)"
