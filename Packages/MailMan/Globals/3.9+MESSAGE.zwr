^XMB(3.9,145944,2,1142,0)=" D HDR1 G:IBQ DETQ"
^XMB(3.9,145944,2,1143,0)="""RTN"",""IBJDF42"",55,0)"
^XMB(3.9,145944,2,1144,0)=" S (IBPT,IB,IBCAT,IB0)="""""
