^XMB(3.9,145953,2,1715,0)="""RTN"",""SDESPATRPC"",120,0)"
^XMB(3.9,145953,2,1716,0)=" .;Check the Date Last Verified"
^XMB(3.9,145953,2,1717,0)="""RTN"",""SDESPATRPC"",121,0)"
^XMB(3.9,145953,2,1718,0)=" .S TMPDT=$P(PATDATA(2.312,IENS,1.03,""I""),""."")"
^XMB(3.9,145953,2,1719,0)="""RTN"",""SDESPATRPC"",122,0)"
^XMB(3.9,145953,2,1720,0)=" .S TMPDT=$G(TMPDT)"
^XMB(3.9,145953,2,1721,0)="""RTN"",""SDESPATRPC"",123,0)"
^XMB(3.9,145953,2,1722,0)=" .I TMPDT D"
^XMB(3.9,145953,2,1723,0)="""RTN"",""SDESPATRPC"",124,0)"
^XMB(3.9,145953,2,1724,0)=" ..S XDT=$$FMADD^XLFDT(DT,-LASTVERFWINDOW)"
^XMB(3.9,145953,2,1725,0)="""RTN"",""SDESPATRPC"",125,0)"
^XMB(3.9,145953,2,1726,0)=" ..S XDT=$G(XDT)"
^XMB(3.9,145953,2,1727,0)="""RTN"",""SDESPATRPC"",126,0)"
^XMB(3.9,145953,2,1728,0)=" ..I XDT<TMPDT S NEEDVERIFY=0"
^XMB(3.9,145953,2,1729,0)="""RTN"",""SDESPATRPC"",127,0)"
^XMB(3.9,145953,2,1730,0)=" I $G(NEEDVERIFY)=0 Q  ;Verification not needed"
^XMB(3.9,145953,2,1731,0)="""RTN"",""SDESPATRPC"",128,0)"
^XMB(3.9,145953,2,1732,0)=" ;"
^XMB(3.9,145953,2,1733,0)="""RTN"",""SDESPATRPC"",129,0)"
^XMB(3.9,145953,2,1734,0)=" ;If no insurance or unknown on file then check the Covered by Health Insurance date"
^XMB(3.9,145953,2,1735,0)="""RTN"",""SDESPATRPC"",130,0)"
^XMB(3.9,145953,2,1736,0)=" D GETS^DIQ(2,DFN,"".3192"",""I"",""PATDATA"",""SDMSG"")"
^XMB(3.9,145953,2,1737,0)="""RTN"",""SDESPATRPC"",131,0)"
^XMB(3.9,145953,2,1738,0)=" S COVBYHI=PATDATA(2,DFN_"","",.3192,""I"")"
^XMB(3.9,145953,2,1739,0)="""RTN"",""SDESPATRPC"",132,0)"
^XMB(3.9,145953,2,1740,0)=" S COVBYHI=$G(COVBYHI)"
^XMB(3.9,145953,2,1741,0)="""RTN"",""SDESPATRPC"",133,0)"
^XMB(3.9,145953,2,1742,0)=" I COVBYHI=""N""!(COVBYHI=""U"") D"
^XMB(3.9,145953,2,1743,0)="""RTN"",""SDESPATRPC"",134,0)"
^XMB(3.9,145953,2,1744,0)=" .D GETS^DIQ(354,DFN,""60"",""I"",""BILLPATDATA"",""SDMSG"")"
^XMB(3.9,145953,2,1745,0)="""RTN"",""SDESPATRPC"",135,0)"
^XMB(3.9,145953,2,1746,0)=" .S NOCOVDT=$G(BILLPATDATA(354,DFN_"","",60,""I""))"
^XMB(3.9,145953,2,1747,0)="""RTN"",""SDESPATRPC"",136,0)"
^XMB(3.9,145953,2,1748,0)=" .S NOCOVDT=$G(NOCOVDT)"
^XMB(3.9,145953,2,1749,0)="""RTN"",""SDESPATRPC"",137,0)"
^XMB(3.9,145953,2,1750,0)=" .I NOCOVDT D"
^XMB(3.9,145953,2,1751,0)="""RTN"",""SDESPATRPC"",138,0)"
^XMB(3.9,145953,2,1752,0)=" ..S XDT=$$FMADD^XLFDT(DT,-NOCOVWINDOW)"
^XMB(3.9,145953,2,1753,0)="""RTN"",""SDESPATRPC"",139,0)"
^XMB(3.9,145953,2,1754,0)=" ..I $G(XDT)<NOCOVDT S NEEDVERIFY=0"
