^XMB(3.9,145946,2,5373,0)="""RTN"",""IBCNSU21"",46,0)"
^XMB(3.9,145946,2,5374,0)=" . S VALMCNT=VALMCNT+1"
^XMB(3.9,145946,2,5375,0)="""RTN"",""IBCNSU21"",47,0)"
^XMB(3.9,145946,2,5376,0)=" . S X=$$BLDLN(VALMCNT,IBP)"
^XMB(3.9,145946,2,5377,0)="""RTN"",""IBCNSU21"",48,0)"
^XMB(3.9,145946,2,5378,0)=" . ;"
^XMB(3.9,145946,2,5379,0)="""RTN"",""IBCNSU21"",49,0)"
