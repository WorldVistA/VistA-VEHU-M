^XMB(3.9,145980,2,5529,0)="""RTN"",""SDES2CRTCLNAVAL2"",31,0)"
^XMB(3.9,145980,2,5530,0)=" S TIMESLOTCNT=0,DONE=0"
^XMB(3.9,145980,2,5531,0)="""RTN"",""SDES2CRTCLNAVAL2"",32,0)"
