^XMB(3.9,145987,2,1137,0)="""RTN"",""SDES2EDITPREREG"",14,0)"
^XMB(3.9,145987,2,1138,0)=" ; SDCONTEXT(""PATIENT DFN"")      = The DFN of the Veteran/user taking action on the calling application."
^XMB(3.9,145987,2,1139,0)="""RTN"",""SDES2EDITPREREG"",15,0)"
^XMB(3.9,145987,2,1140,0)=" ; SDCONTEXT(""PATIENT ICN"")      = The ICN of the Veteran/user taking action on the calling application."
^XMB(3.9,145987,2,1141,0)="""RTN"",""SDES2EDITPREREG"",16,0)"
^XMB(3.9,145987,2,1142,0)=" ;"
^XMB(3.9,145987,2,1143,0)="""RTN"",""SDES2EDITPREREG"",17,0)"
^XMB(3.9,145987,2,1144,0)=" ; PARAMS(""STATUS CODE"")         = The code that represents the outcome of the pre-registration interview"
^XMB(3.9,145987,2,1145,0)="""RTN"",""SDES2EDITPREREG"",18,0)"
^XMB(3.9,145987,2,1146,0)=" ;                                 with the patient (Required)"
^XMB(3.9,145987,2,1147,0)="""RTN"",""SDES2EDITPREREG"",19,0)"
^XMB(3.9,145987,2,1148,0)=" ; PARAMS(""DFN"")                 = The DFN of the pre-registration patient"
^XMB(3.9,145987,2,1149,0)="""RTN"",""SDES2EDITPREREG"",20,0)"
^XMB(3.9,145987,2,1150,0)=" ;"
^XMB(3.9,145987,2,1151,0)="""RTN"",""SDES2EDITPREREG"",21,0)"
^XMB(3.9,145987,2,1152,0)="EDITPREREG(JSONRETURN,SDCONTEXT,PARAMS) ; Edit Patient's Pre-Registration"
^XMB(3.9,145987,2,1153,0)="""RTN"",""SDES2EDITPREREG"",22,0)"
^XMB(3.9,145987,2,1154,0)=" ;"
^XMB(3.9,145987,2,1155,0)="""RTN"",""SDES2EDITPREREG"",23,0)"
^XMB(3.9,145987,2,1156,0)=" N SDERRORS,SDRESULT,SDRETURN,VALCHK"
^XMB(3.9,145987,2,1157,0)="""RTN"",""SDES2EDITPREREG"",24,0)"
^XMB(3.9,145987,2,1158,0)=" ;"
^XMB(3.9,145987,2,1159,0)="""RTN"",""SDES2EDITPREREG"",25,0)"
^XMB(3.9,145987,2,1160,0)=" ; Validate SDCONTEXT"
^XMB(3.9,145987,2,1161,0)="""RTN"",""SDES2EDITPREREG"",26,0)"
^XMB(3.9,145987,2,1162,0)=" D VALCONTEXT^SDES2VALCONTEXT(.SDERRORS,.SDCONTEXT)"
^XMB(3.9,145987,2,1163,0)="""RTN"",""SDES2EDITPREREG"",27,0)"
^XMB(3.9,145987,2,1164,0)=" I $D(SDERRORS) S SDERRORS(""Pre-Registration"")="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDERRORS) Q"
^XMB(3.9,145987,2,1165,0)="""RTN"",""SDES2EDITPREREG"",28,0)"
^XMB(3.9,145987,2,1166,0)=" I $G(SDCONTEXT(""USER DUZ""))'="""" N DUZ D DUZ^XUP(SDCONTEXT(""USER DUZ""))"
^XMB(3.9,145987,2,1167,0)="""RTN"",""SDES2EDITPREREG"",29,0)"
^XMB(3.9,145987,2,1168,0)=" ;"
^XMB(3.9,145987,2,1169,0)="""RTN"",""SDES2EDITPREREG"",30,0)"
^XMB(3.9,145987,2,1170,0)=" ; Validate PARAMS"
^XMB(3.9,145987,2,1171,0)="""RTN"",""SDES2EDITPREREG"",31,0)"
^XMB(3.9,145987,2,1172,0)=" ;"
^XMB(3.9,145987,2,1173,0)="""RTN"",""SDES2EDITPREREG"",32,0)"
^XMB(3.9,145987,2,1174,0)=" S VALCHK=$$VALPARAMS(.PARAMS,.SDERRORS)"
^XMB(3.9,145987,2,1175,0)="""RTN"",""SDES2EDITPREREG"",33,0)"
^XMB(3.9,145987,2,1176,0)=" I 'VALCHK M SDRETURN=SDERRORS S SDRETURN(""Pre-Registration"",1)="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN) Q"
^XMB(3.9,145987,2,1177,0)="""RTN"",""SDES2EDITPREREG"",34,0)"
^XMB(3.9,145987,2,1178,0)=" ;"
^XMB(3.9,145987,2,1179,0)="""RTN"",""SDES2EDITPREREG"",35,0)"
^XMB(3.9,145987,2,1180,0)=" ; Call PREREG^VPSRPC3"
^XMB(3.9,145987,2,1181,0)="""RTN"",""SDES2EDITPREREG"",36,0)"
^XMB(3.9,145987,2,1182,0)=" ;"
^XMB(3.9,145987,2,1183,0)="""RTN"",""SDES2EDITPREREG"",37,0)"
^XMB(3.9,145987,2,1184,0)=" D PREREG^VPSRPC3(.SDRESULT,PARAMS(""DFN""),PARAMS(""STATUS CODE""))"
^XMB(3.9,145987,2,1185,0)="""RTN"",""SDES2EDITPREREG"",38,0)"
^XMB(3.9,145987,2,1186,0)=" ;"
^XMB(3.9,145987,2,1187,0)="""RTN"",""SDES2EDITPREREG"",39,0)"
^XMB(3.9,145987,2,1188,0)=" K Y  ; Kill leaking variable from PREREG^VPSRPC3"
^XMB(3.9,145987,2,1189,0)="""RTN"",""SDES2EDITPREREG"",40,0)"
^XMB(3.9,145987,2,1190,0)=" ;"
^XMB(3.9,145987,2,1191,0)="""RTN"",""SDES2EDITPREREG"",41,0)"
^XMB(3.9,145987,2,1192,0)=" I '+(SDRESULT) D"
^XMB(3.9,145987,2,1193,0)="""RTN"",""SDES2EDITPREREG"",42,0)"
^XMB(3.9,145987,2,1194,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,52,""An unspecified filing error occurred in the PREREG^VPSRPC3 API"")"
^XMB(3.9,145987,2,1195,0)="""RTN"",""SDES2EDITPREREG"",43,0)"
^XMB(3.9,145987,2,1196,0)=" . S SDRETURN(""Pre-Registration"",1)="""" M SDRETURN=SDERRORS"
^XMB(3.9,145987,2,1197,0)="""RTN"",""SDES2EDITPREREG"",44,0)"
^XMB(3.9,145987,2,1198,0)=" I +(SDRESULT) S SDRETURN(""Pre-Registration"",""Success"")=$P(SDRESULT,"","",2)"
^XMB(3.9,145987,2,1199,0)="""RTN"",""SDES2EDITPREREG"",45,0)"
^XMB(3.9,145987,2,1200,0)=" ;"
^XMB(3.9,145987,2,1201,0)="""RTN"",""SDES2EDITPREREG"",46,0)"
^XMB(3.9,145987,2,1202,0)=" ; Build JSON return"
^XMB(3.9,145987,2,1203,0)="""RTN"",""SDES2EDITPREREG"",47,0)"
^XMB(3.9,145987,2,1204,0)=" ;"
^XMB(3.9,145987,2,1205,0)="""RTN"",""SDES2EDITPREREG"",48,0)"
^XMB(3.9,145987,2,1206,0)=" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN)"
^XMB(3.9,145987,2,1207,0)="""RTN"",""SDES2EDITPREREG"",49,0)"
^XMB(3.9,145987,2,1208,0)=" Q"
^XMB(3.9,145987,2,1209,0)="""RTN"",""SDES2EDITPREREG"",50,0)"
^XMB(3.9,145987,2,1210,0)=" ;"
^XMB(3.9,145987,2,1211,0)="""RTN"",""SDES2EDITPREREG"",51,0)"
^XMB(3.9,145987,2,1212,0)="VALPARAMS(PARAMS,SDERRORS) ; Validate PARAMS array (DFN & Status Code)"
^XMB(3.9,145987,2,1213,0)="""RTN"",""SDES2EDITPREREG"",52,0)"
^XMB(3.9,145987,2,1214,0)=" ;"
^XMB(3.9,145987,2,1215,0)="""RTN"",""SDES2EDITPREREG"",53,0)"
^XMB(3.9,145987,2,1216,0)=" ; Validate DFN"
^XMB(3.9,145987,2,1217,0)="""RTN"",""SDES2EDITPREREG"",54,0)"
^XMB(3.9,145987,2,1218,0)=" ;"
^XMB(3.9,145987,2,1219,0)="""RTN"",""SDES2EDITPREREG"",55,0)"
^XMB(3.9,145987,2,1220,0)=" N VALRET"
^XMB(3.9,145987,2,1221,0)="""RTN"",""SDES2EDITPREREG"",56,0)"
^XMB(3.9,145987,2,1222,0)=" D VALFILEIEN^SDES2VALUTIL(.VALRET,.SDERRORS,2,$G(PARAMS(""DFN"")),1,0,1,2)"
^XMB(3.9,145987,2,1223,0)="""RTN"",""SDES2EDITPREREG"",57,0)"
^XMB(3.9,145987,2,1224,0)=" I 'VALRET,$D(SDERRORS) Q 0"
^XMB(3.9,145987,2,1225,0)="""RTN"",""SDES2EDITPREREG"",58,0)"
^XMB(3.9,145987,2,1226,0)=" ;"
^XMB(3.9,145987,2,1227,0)="""RTN"",""SDES2EDITPREREG"",59,0)"
^XMB(3.9,145987,2,1228,0)=" ; Validate Status Code"
^XMB(3.9,145987,2,1229,0)="""RTN"",""SDES2EDITPREREG"",60,0)"
^XMB(3.9,145987,2,1230,0)=" ;"
^XMB(3.9,145987,2,1231,0)="""RTN"",""SDES2EDITPREREG"",61,0)"
^XMB(3.9,145987,2,1232,0)=" I $G(PARAMS(""STATUS CODE""))="""" D  Q 0"
^XMB(3.9,145987,2,1233,0)="""RTN"",""SDES2EDITPREREG"",62,0)"
^XMB(3.9,145987,2,1234,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,514)"
^XMB(3.9,145987,2,1235,0)="""RTN"",""SDES2EDITPREREG"",63,0)"
^XMB(3.9,145987,2,1236,0)=" I $L(PARAMS(""STATUS CODE""))>1 D  Q 0"
^XMB(3.9,145987,2,1237,0)="""RTN"",""SDES2EDITPREREG"",64,0)"
^XMB(3.9,145987,2,1238,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,515)"
^XMB(3.9,145987,2,1239,0)="""RTN"",""SDES2EDITPREREG"",65,0)"
^XMB(3.9,145987,2,1240,0)=" I ""^B^C^D^K^M^N^P^T^U^V^W^X^""'[(""^""_$G(PARAMS(""STATUS CODE""))_""^"") D  Q 0"
^XMB(3.9,145987,2,1241,0)="""RTN"",""SDES2EDITPREREG"",66,0)"
^XMB(3.9,145987,2,1242,0)=" . D ERRLOG^SDES2JSON(.SDERRORS,515)"
^XMB(3.9,145987,2,1243,0)="""RTN"",""SDES2EDITPREREG"",67,0)"
^XMB(3.9,145987,2,1244,0)=" Q 1"
^XMB(3.9,145987,2,1245,0)="""RTN"",""SDES2GETDEVICES"")"
^XMB(3.9,145987,2,1246,0)="0^1^B27342289"
^XMB(3.9,145987,2,1247,0)="""RTN"",""SDES2GETDEVICES"",1,0)"
^XMB(3.9,145987,2,1248,0)="SDES2GETDEVICES ;ALB/JHC,MCB - VISTA SCHEDULING RPCS - DEVICE RETRIEVAL ; JUNE 16,2025"
^XMB(3.9,145987,2,1249,0)="""RTN"",""SDES2GETDEVICES"",2,0)"
^XMB(3.9,145987,2,1250,0)=" ;;5.3;Scheduling;**907,909**;Aug 13, 1993;Build 0"
^XMB(3.9,145987,2,1251,0)="""RTN"",""SDES2GETDEVICES"",3,0)"
^XMB(3.9,145987,2,1252,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145987,2,1253,0)="""RTN"",""SDES2GETDEVICES"",4,0)"
^XMB(3.9,145987,2,1254,0)=" ;"
^XMB(3.9,145987,2,1255,0)="""RTN"",""SDES2GETDEVICES"",5,0)"
^XMB(3.9,145987,2,1256,0)=" ; Reference to DUZ^XUP is supported by IA #7487"
^XMB(3.9,145987,2,1257,0)="""RTN"",""SDES2GETDEVICES"",6,0)"
^XMB(3.9,145987,2,1258,0)=" ;"
^XMB(3.9,145987,2,1259,0)="""RTN"",""SDES2GETDEVICES"",7,0)"
^XMB(3.9,145987,2,1260,0)=" ; External References"
^XMB(3.9,145987,2,1261,0)="""RTN"",""SDES2GETDEVICES"",8,0)"
^XMB(3.9,145987,2,1262,0)=" ; -------------------"
^XMB(3.9,145987,2,1263,0)="""RTN"",""SDES2GETDEVICES"",9,0)"
^XMB(3.9,145987,2,1264,0)=" ; Reference to ^%ZIS(1 supported by IA #2963"
^XMB(3.9,145987,2,1265,0)="""RTN"",""SDES2GETDEVICES"",10,0)"
^XMB(3.9,145987,2,1266,0)=" ; Reference to ^%ZIS(2 supported by IA #2964"
^XMB(3.9,145987,2,1267,0)="""RTN"",""SDES2GETDEVICES"",11,0)"
^XMB(3.9,145987,2,1268,0)=" ;"
^XMB(3.9,145987,2,1269,0)="""RTN"",""SDES2GETDEVICES"",12,0)"
^XMB(3.9,145987,2,1270,0)=" ; RPC: SDES2 GET VISTA DEVICES"
^XMB(3.9,145987,2,1271,0)="""RTN"",""SDES2GETDEVICES"",13,0)"
^XMB(3.9,145987,2,1272,0)=" ;"
^XMB(3.9,145987,2,1273,0)="""RTN"",""SDES2GETDEVICES"",14,0)"
^XMB(3.9,145987,2,1274,0)=" ; SDINPUT(""LOOKUPSTRING"") = Search string to match device name (* not allowed)"
^XMB(3.9,145987,2,1275,0)="""RTN"",""SDES2GETDEVICES"",15,0)"
^XMB(3.9,145987,2,1276,0)=" ; length must be 15 characters or less"
^XMB(3.9,145987,2,1277,0)="""RTN"",""SDES2GETDEVICES"",16,0)"
^XMB(3.9,145987,2,1278,0)=" ;"
^XMB(3.9,145987,2,1279,0)="""RTN"",""SDES2GETDEVICES"",17,0)"
^XMB(3.9,145987,2,1280,0)=" ; This will return up to 80 devices."
^XMB(3.9,145987,2,1281,0)="""RTN"",""SDES2GETDEVICES"",18,0)"
^XMB(3.9,145987,2,1282,0)=" ;"
^XMB(3.9,145987,2,1283,0)="""RTN"",""SDES2GETDEVICES"",19,0)"
^XMB(3.9,145987,2,1284,0)=" Q"
^XMB(3.9,145987,2,1285,0)="""RTN"",""SDES2GETDEVICES"",20,0)"
^XMB(3.9,145987,2,1286,0)="DEVICES(JSON,SDCONTEXT,SDINPUT) ;"
^XMB(3.9,145987,2,1287,0)="""RTN"",""SDES2GETDEVICES"",21,0)"
^XMB(3.9,145987,2,1288,0)=" N ERRORS,DEVICES,DEVLIST,DEV,DEVDAT,LOOKUP,LOOKUPSHORT"
^XMB(3.9,145987,2,1289,0)="""RTN"",""SDES2GETDEVICES"",22,0)"
^XMB(3.9,145987,2,1290,0)=" ; Validation"
^XMB(3.9,145987,2,1291,0)="""RTN"",""SDES2GETDEVICES"",23,0)"
^XMB(3.9,145987,2,1292,0)=" D VALCONTEXT^SDES2VALCONTEXT(.ERRORS,.SDCONTEXT)"
^XMB(3.9,145987,2,1293,0)="""RTN"",""SDES2GETDEVICES"",24,0)"
^XMB(3.9,145987,2,1294,0)=" I $D(ERRORS) S RETURN(""Device"",1)="""" M RETURN=ERRORS D BUILDJSON^SDES2JSON(.JSON,.RETURN) Q"
^XMB(3.9,145987,2,1295,0)="""RTN"",""SDES2GETDEVICES"",25,0)"
^XMB(3.9,145987,2,1296,0)=" I $G(SDCONTEXT(""USER DUZ""))'="""" N DUZ D DUZ^XUP(SDCONTEXT(""USER DUZ""))"
^XMB(3.9,145987,2,1297,0)="""RTN"",""SDES2GETDEVICES"",26,0)"
^XMB(3.9,145987,2,1298,0)=" S LOOKUP=$G(SDINPUT(""LOOKUPSTRING""))"
^XMB(3.9,145987,2,1299,0)="""RTN"",""SDES2GETDEVICES"",27,0)"
^XMB(3.9,145987,2,1300,0)=" D VALLOOKUP(.ERRORS,LOOKUP)"
^XMB(3.9,145987,2,1301,0)="""RTN"",""SDES2GETDEVICES"",28,0)"
^XMB(3.9,145987,2,1302,0)=" S LOOKUPSHORT=$E(LOOKUP,1,$L(LOOKUP)-1)"
^XMB(3.9,145987,2,1303,0)="""RTN"",""SDES2GETDEVICES"",29,0)"
^XMB(3.9,145987,2,1304,0)=" I $D(ERRORS) S ERRORS(""Device"",1)="""" D BUILDJSON^SDESBUILDJSON(.JSON,.ERRORS) Q"
^XMB(3.9,145987,2,1305,0)="""RTN"",""SDES2GETDEVICES"",30,0)"
^XMB(3.9,145987,2,1306,0)=" ; Loop through device info"
^XMB(3.9,145987,2,1307,0)="""RTN"",""SDES2GETDEVICES"",31,0)"
^XMB(3.9,145987,2,1308,0)=" D DEVICE(.DEVICES,LOOKUPSHORT,1)"
^XMB(3.9,145987,2,1309,0)="""RTN"",""SDES2GETDEVICES"",32,0)"
^XMB(3.9,145987,2,1310,0)=" I '$D(DEVICES) S DEVLIST(""Device"",1)="""" D BUILDJSON^SDESBUILDJSON(.JSON,.DEVLIST) Q"
^XMB(3.9,145987,2,1311,0)="""RTN"",""SDES2GETDEVICES"",33,0)"
^XMB(3.9,145987,2,1312,0)=" ; Build output"
^XMB(3.9,145987,2,1313,0)="""RTN"",""SDES2GETDEVICES"",34,0)"
^XMB(3.9,145987,2,1314,0)=" D BLDOUTPUT(.DEVICES,.DEVLIST)"
^XMB(3.9,145987,2,1315,0)="""RTN"",""SDES2GETDEVICES"",35,0)"
^XMB(3.9,145987,2,1316,0)="  I '$D(DEVLIST) S DEVLIST(""Device"",1)="""" D BUILDJSON^SDESBUILDJSON(.JSON,.DEVLIST) Q"
^XMB(3.9,145987,2,1317,0)="""RTN"",""SDES2GETDEVICES"",36,0)"
^XMB(3.9,145987,2,1318,0)=" ; Build JSON output"
^XMB(3.9,145987,2,1319,0)="""RTN"",""SDES2GETDEVICES"",37,0)"
^XMB(3.9,145987,2,1320,0)=" D BUILDJSON^SDESBUILDJSON(.JSON,.DEVLIST)"
^XMB(3.9,145987,2,1321,0)="""RTN"",""SDES2GETDEVICES"",38,0)"
^XMB(3.9,145987,2,1322,0)=" Q"
^XMB(3.9,145987,2,1323,0)="""RTN"",""SDES2GETDEVICES"",39,0)"
^XMB(3.9,145987,2,1324,0)="VALLOOKUP(ERRORS,LOOKUP) ;"
^XMB(3.9,145987,2,1325,0)="""RTN"",""SDES2GETDEVICES"",40,0)"
^XMB(3.9,145987,2,1326,0)=" I LOOKUP[""*"" D ERRLOG^SDESJSON(.ERRORS,52,""Search string cannot contain an *"") Q"
^XMB(3.9,145987,2,1327,0)="""RTN"",""SDES2GETDEVICES"",41,0)"
^XMB(3.9,145987,2,1328,0)=" I LOOKUP="""" D ERRLOG^SDESJSON(.ERRORS,277) Q"
^XMB(3.9,145987,2,1329,0)="""RTN"",""SDES2GETDEVICES"",42,0)"
^XMB(3.9,145987,2,1330,0)=" I $L(LOOKUP)>15 D ERRLOG^SDESJSON(.ERRORS,278)"
^XMB(3.9,145987,2,1331,0)="""RTN"",""SDES2GETDEVICES"",43,0)"
^XMB(3.9,145987,2,1332,0)=" Q"
^XMB(3.9,145987,2,1333,0)="""RTN"",""SDES2GETDEVICES"",44,0)"
^XMB(3.9,145987,2,1334,0)="DEVICE(RETURN,SEARCHSTRING,DIRECTION,RIGHTMARGIN) ; Return a subset of entries from the Device file"
^XMB(3.9,145987,2,1335,0)="""RTN"",""SDES2GETDEVICES"",45,0)"
^XMB(3.9,145987,2,1336,0)=" ; Return up to 80 entries."
^XMB(3.9,145987,2,1337,0)="""RTN"",""SDES2GETDEVICES"",46,0)"
^XMB(3.9,145987,2,1338,0)=" ; RETURN(n)=Device IEN^Device Name^Display Name^Location^Right Margin^Page Length"
^XMB(3.9,145987,2,1339,0)="""RTN"",""SDES2GETDEVICES"",47,0)"
^XMB(3.9,145987,2,1340,0)=" ; SEARCHSTRING=text to $O from. Allow the Display Name to be used."
^XMB(3.9,145987,2,1341,0)="""RTN"",""SDES2GETDEVICES"",48,0)"
^XMB(3.9,145987,2,1342,0)=" ; Allow ""NAME*"" to get count limit from that starting point."
^XMB(3.9,145987,2,1343,0)="""RTN"",""SDES2GETDEVICES"",49,0)"
^XMB(3.9,145987,2,1344,0)=" ; DIRECTION=$O direction"
^XMB(3.9,145987,2,1345,0)="""RTN"",""SDES2GETDEVICES"",50,0)"
^XMB(3.9,145987,2,1346,0)=" ; [RIGHTMARGIN]=min RM value or min-max value (Default to 80)."
^XMB(3.9,145987,2,1347,0)="""RTN"",""SDES2GETDEVICES"",51,0)"
^XMB(3.9,145987,2,1348,0)=" N FOUNDCNT,DEVICEIEN,MAXCOUNT,SEARCH,DTYP,RML,RMH"
^XMB(3.9,145987,2,1349,0)="""RTN"",""SDES2GETDEVICES"",52,0)"
^XMB(3.9,145987,2,1350,0)=" S FOUNDCNT=0,MAXCOUNT=$G(MAXCOUNT,80),RIGHTMARGIN=$G(RIGHTMARGIN,80)"
^XMB(3.9,145987,2,1351,0)="""RTN"",""SDES2GETDEVICES"",53,0)"
^XMB(3.9,145987,2,1352,0)=" I '$G(DIRECTION) S DIRECTION=1"
^XMB(3.9,145987,2,1353,0)="""RTN"",""SDES2GETDEVICES"",54,0)"
^XMB(3.9,145987,2,1354,0)=" S RML=+RIGHTMARGIN,RMH=$S(RIGHTMARGIN[""-"":$P(RIGHTMARGIN,""-"",2),1:99999)"
^XMB(3.9,145987,2,1355,0)="""RTN"",""SDES2GETDEVICES"",55,0)"
^XMB(3.9,145987,2,1356,0)=" ;Allow the DisplayName to be used."
^XMB(3.9,145987,2,1357,0)="""RTN"",""SDES2GETDEVICES"",56,0)"
^XMB(3.9,145987,2,1358,0)=" I SEARCHSTRING["" <"" S SEARCHSTRING=$RE($P($RE(SEARCHSTRING),""< "",2))"
^XMB(3.9,145987,2,1359,0)="""RTN"",""SDES2GETDEVICES"",57,0)"
^XMB(3.9,145987,2,1360,0)=" S SEARCH=SEARCHSTRING I SEARCHSTRING[""*"" S SEARCHSTRING=$P(SEARCHSTRING,""*"",1),SEARCH="""""
^XMB(3.9,145987,2,1361,0)="""RTN"",""SDES2GETDEVICES"",58,0)"
^XMB(3.9,145987,2,1362,0)=" F  Q:FOUNDCNT'<MAXCOUNT  S SEARCHSTRING=$O(^%ZIS(1,""B"",SEARCHSTRING),DIRECTION) Q:(SEARCHSTRING="""")  D"
^XMB(3.9,145987,2,1363,0)="""RTN"",""SDES2GETDEVICES"",59,0)"
^XMB(3.9,145987,2,1364,0)=" . I $L(SEARCH),($E(SEARCHSTRING,1,$L(SEARCH))'=SEARCH) Q"
^XMB(3.9,145987,2,1365,0)="""RTN"",""SDES2GETDEVICES"",60,0)"
^XMB(3.9,145987,2,1366,0)=" . S DEVICEIEN=0"
^XMB(3.9,145987,2,1367,0)="""RTN"",""SDES2GETDEVICES"",61,0)"
^XMB(3.9,145987,2,1368,0)=" . F  S DEVICEIEN=$O(^%ZIS(1,""B"",SEARCHSTRING,DEVICEIEN)) Q:'DEVICEIEN  D"
^XMB(3.9,145987,2,1369,0)="""RTN"",""SDES2GETDEVICES"",62,0)"
^XMB(3.9,145987,2,1370,0)=" . . Q:'$D(^%ZIS(1,DEVICEIEN,0))"
^XMB(3.9,145987,2,1371,0)="""RTN"",""SDES2GETDEVICES"",63,0)"
^XMB(3.9,145987,2,1372,0)=" . . N OUTOFSERVDT,MARGINWIDTH,SECURITY,XTYPE,XSTYPE,XTIME"
^XMB(3.9,145987,2,1373,0)="""RTN"",""SDES2GETDEVICES"",64,0)"
^XMB(3.9,145987,2,1374,0)=" . . N DEVICENAME,DISPLAYNAME"
^XMB(3.9,145987,2,1375,0)="""RTN"",""SDES2GETDEVICES"",65,0)"
^XMB(3.9,145987,2,1376,0)=" . . N LOCKTIME,CURRTIME,ULIM,LLIM,SECSTRNG,EXT,SCODE"
^XMB(3.9,145987,2,1377,0)="""RTN"",""SDES2GETDEVICES"",66,0)"
^XMB(3.9,145987,2,1378,0)=" . . ; Device Info (filter)"
^XMB(3.9,145987,2,1379,0)="""RTN"",""SDES2GETDEVICES"",67,0)"
^XMB(3.9,145987,2,1380,0)=" . . S OUTOFSERVDT=$P($G(^%ZIS(1,DEVICEIEN,90)),U)"
^XMB(3.9,145987,2,1381,0)="""RTN"",""SDES2GETDEVICES"",68,0)"
^XMB(3.9,145987,2,1382,0)=" . . S MARGINWIDTH=$P($G(^%ZIS(1,DEVICEIEN,91)),U)"
^XMB(3.9,145987,2,1383,0)="""RTN"",""SDES2GETDEVICES"",69,0)"
^XMB(3.9,145987,2,1384,0)=" . . S SECURITY=$G(^%ZIS(1,DEVICEIEN,95))"
^XMB(3.9,145987,2,1385,0)="""RTN"",""SDES2GETDEVICES"",70,0)"
^XMB(3.9,145987,2,1386,0)=" . . S XSTYPE=$G(^%ZIS(1,DEVICEIEN,""SUBTYPE""))"
^XMB(3.9,145987,2,1387,0)="""RTN"",""SDES2GETDEVICES"",71,0)"
^XMB(3.9,145987,2,1388,0)=" . . S XTIME=$G(^%ZIS(1,DEVICEIEN,""TIME""))"
^XMB(3.9,145987,2,1389,0)="""RTN"",""SDES2GETDEVICES"",72,0)"
^XMB(3.9,145987,2,1390,0)=" . . S XTYPE=$G(^%ZIS(1,DEVICEIEN,""TYPE""))"
^XMB(3.9,145987,2,1391,0)="""RTN"",""SDES2GETDEVICES"",73,0)"
^XMB(3.9,145987,2,1392,0)=" . . ; Device Filters"
^XMB(3.9,145987,2,1393,0)="""RTN"",""SDES2GETDEVICES"",74,0)"
^XMB(3.9,145987,2,1394,0)=" . . I $E($G(^%ZIS(2,+XSTYPE,0)))'=""P"" Q  ;Printers only"
^XMB(3.9,145987,2,1395,0)="""RTN"",""SDES2GETDEVICES"",75,0)"
^XMB(3.9,145987,2,1396,0)=" . . S DTYP=$P(XTYPE,""^"") I DTYP'=""TRM"",DTYP'=""HG"",DTYP'=""HFS"",DTYP'=""CHAN"" Q  ;Device Types"
^XMB(3.9,145987,2,1397,0)="""RTN"",""SDES2GETDEVICES"",76,0)"
^XMB(3.9,145987,2,1398,0)=" . . Q:($P($G(^%ZIS(1,DEVICEIEN,0)),U,2)=""0"")!($P($G(^%ZIS(1,DEVICEIEN,0)),U,12)=2)  ;Queuing allowed"
^XMB(3.9,145987,2,1399,0)="""RTN"",""SDES2GETDEVICES"",77,0)"
^XMB(3.9,145987,2,1400,0)=" . . I OUTOFSERVDT,(OUTOFSERVDT'>DT) Q  ;Out of Service"
^XMB(3.9,145987,2,1401,0)="""RTN"",""SDES2GETDEVICES"",78,0)"
^XMB(3.9,145987,2,1402,0)=" . . ;Prohibited Times -CURRTIME is current time, LLIM is lower limit, ULIM is upper limit"
^XMB(3.9,145987,2,1403,0)="""RTN"",""SDES2GETDEVICES"",79,0)"
^XMB(3.9,145987,2,1404,0)=" . . S LOCKTIME=$P(XTIME,""^"")"
^XMB(3.9,145987,2,1405,0)="""RTN"",""SDES2GETDEVICES"",80,0)"
^XMB(3.9,145987,2,1406,0)=" . . I $L(LOCKTIME) S CURRTIME=$P($H,"","",2),CURRTIME=CURRTIME\60#60+(CURRTIME\3600*100),ULIM=$P(LOCKTIME,""-"",2),LLIM=+LOCKTIME I $S(ULIM'<LLIM:(CURRTIME'>ULIM&(CURRTIME'<LLIM)),1:(CURRTIME'<LLIM!(CURRTIME'>ULIM))) Q"
^XMB(3.9,145987,2,1407,0)="""RTN"",""SDES2GETDEVICES"",81,0)"
^XMB(3.9,145987,2,1408,0)=" . . S EXT=0"
^XMB(3.9,145987,2,1409,0)="""RTN"",""SDES2GETDEVICES"",82,0)"
^XMB(3.9,145987,2,1410,0)=" . . I SECURITY]"""" S SECSTRNG=$G(DUZ(0)) I SECSTRNG'=""@"" S EXT=1 F SCODE=1:1:$L(SECSTRNG) I SECURITY[$E(SECSTRNG,SCODE) S EXT=0 Q"
^XMB(3.9,145987,2,1411,0)="""RTN"",""SDES2GETDEVICES"",83,0)"
^XMB(3.9,145987,2,1412,0)=" . . Q:EXT  ;User Security check"
^XMB(3.9,145987,2,1413,0)="""RTN"",""SDES2GETDEVICES"",84,0)"
^XMB(3.9,145987,2,1414,0)=" . . ; Device data to return"
^XMB(3.9,145987,2,1415,0)="""RTN"",""SDES2GETDEVICES"",85,0)"
^XMB(3.9,145987,2,1416,0)=" . . I '+MARGINWIDTH S MARGINWIDTH=$G(^%ZIS(2,+XSTYPE,1),""80^#^60^"") ;Get default width & page length p542"
^XMB(3.9,145987,2,1417,0)="""RTN"",""SDES2GETDEVICES"",86,0)"
^XMB(3.9,145987,2,1418,0)=" . . I RML>0,(+MARGINWIDTH<RML)!(+MARGINWIDTH>RMH) Q"
^XMB(3.9,145987,2,1419,0)="""RTN"",""SDES2GETDEVICES"",87,0)"
^XMB(3.9,145987,2,1420,0)=" . . S DEVICENAME=$P($G(^%ZIS(1,DEVICEIEN,0)),U),DISPLAYNAME=DEVICENAME"
^XMB(3.9,145987,2,1421,0)="""RTN"",""SDES2GETDEVICES"",88,0)"
^XMB(3.9,145987,2,1422,0)=" . . S:DEVICENAME'=SEARCHSTRING DISPLAYNAME=SEARCHSTRING_"" <""_DEVICENAME_"">"""
^XMB(3.9,145987,2,1423,0)="""RTN"",""SDES2GETDEVICES"",89,0)"
^XMB(3.9,145987,2,1424,0)=" . . S FOUNDCNT=FOUNDCNT+1,RETURN(FOUNDCNT)=DEVICEIEN_U_DEVICENAME_U_DISPLAYNAME_U_$P($G(^%ZIS(1,DEVICEIEN,1)),U)_U_$P(MARGINWIDTH,U)_U_$P(MARGINWIDTH,U,3)"
^XMB(3.9,145987,2,1425,0)="""RTN"",""SDES2GETDEVICES"",90,0)"
^XMB(3.9,145987,2,1426,0)=" Q"
^XMB(3.9,145987,2,1427,0)="""RTN"",""SDES2GETDEVICES"",91,0)"
^XMB(3.9,145987,2,1428,0)="BLDOUTPUT(DEVICES,DEVLIST) ;"
^XMB(3.9,145987,2,1429,0)="""RTN"",""SDES2GETDEVICES"",92,0)"
^XMB(3.9,145987,2,1430,0)=" S DEV=0 F  S DEV=$O(DEVICES(DEV)) Q:'DEV  D"
^XMB(3.9,145987,2,1431,0)="""RTN"",""SDES2GETDEVICES"",93,0)"
^XMB(3.9,145987,2,1432,0)=" .S DEVDAT=$G(DEVICES(DEV))"
^XMB(3.9,145987,2,1433,0)="""RTN"",""SDES2GETDEVICES"",94,0)"
^XMB(3.9,145987,2,1434,0)=" .I ($P(DEVDAT,U,2)'[LOOKUP),($P(DEVDAT,U,3)'[LOOKUP) Q"
^XMB(3.9,145987,2,1435,0)="""RTN"",""SDES2GETDEVICES"",95,0)"
^XMB(3.9,145987,2,1436,0)=" .S DEVLIST(""Device"",DEV,""ID"")=$P(DEVDAT,U)"
^XMB(3.9,145987,2,1437,0)="""RTN"",""SDES2GETDEVICES"",96,0)"
^XMB(3.9,145987,2,1438,0)=" .S DEVLIST(""Device"",DEV,""Name"")=$P(DEVDAT,U,2)"
^XMB(3.9,145987,2,1439,0)="""RTN"",""SDES2GETDEVICES"",97,0)"
^XMB(3.9,145987,2,1440,0)=" .S DEVLIST(""Device"",DEV,""DisplayName"")=$P(DEVDAT,U,3)"
^XMB(3.9,145987,2,1441,0)="""RTN"",""SDES2GETDEVICES"",98,0)"
^XMB(3.9,145987,2,1442,0)=" .S DEVLIST(""Device"",DEV,""Location"")=$P(DEVDAT,U,4)"
^XMB(3.9,145987,2,1443,0)="""RTN"",""SDES2GETDEVICES"",99,0)"
^XMB(3.9,145987,2,1444,0)=" .S DEVLIST(""Device"",DEV,""RightMargin"")=$P(DEVDAT,U,5)"
^XMB(3.9,145987,2,1445,0)="""RTN"",""SDES2GETDEVICES"",100,0)"
^XMB(3.9,145987,2,1446,0)=" .S DEVLIST(""Device"",DEV,""PageLength"")=$P(DEVDAT,U,6)"
^XMB(3.9,145987,2,1447,0)="""RTN"",""SDES2GETDEVICES"",101,0)"
^XMB(3.9,145987,2,1448,0)=" Q"
