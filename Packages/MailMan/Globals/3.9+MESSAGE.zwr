^XMB(3.9,145986,2,3989,0)="""RTN"",""FBPCR"",245,0)"
^XMB(3.9,145986,2,3990,0)=" I $D(FBARR(6)) W ?39,""HEAD/NECK CANCER"",!"
^XMB(3.9,145986,2,3991,0)="""RTN"",""FBPCR"",246,0)"
