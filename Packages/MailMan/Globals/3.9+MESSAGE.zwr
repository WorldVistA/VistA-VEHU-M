^XMB(3.9,145946,2,5555,0)="""RTN"",""IBCNSU21"",137,0)"
^XMB(3.9,145946,2,5556,0)=" ;          ^TMP(""IBCNSU21A,$J,IIEN)- Updated Array of selected policies"
^XMB(3.9,145946,2,5557,0)="""RTN"",""IBCNSU21"",138,0)"
^XMB(3.9,145946,2,5558,0)=" ;          Selected Insurance Company is added to the worklist "
^XMB(3.9,145946,2,5559,0)="""RTN"",""IBCNSU21"",139,0)"
^XMB(3.9,145946,2,5560,0)=" ;          Error message displayed (potentially)"
^XMB(3.9,145946,2,5561,0)="""RTN"",""IBCNSU21"",140,0)"
^XMB(3.9,145946,2,5562,0)=" N DIR,DIROUT,DIRUT,DLINE,DTOUT,DUOUT,ERROR,IEN,IIENS,IX,LINE"
^XMB(3.9,145946,2,5563,0)="""RTN"",""IBCNSU21"",141,0)"
^XMB(3.9,145946,2,5564,0)=" S VALMBCK=""R"",ERROR=0"
^XMB(3.9,145946,2,5565,0)="""RTN"",""IBCNSU21"",142,0)"
^XMB(3.9,145946,2,5566,0)=" ; "
^XMB(3.9,145946,2,5567,0)="""RTN"",""IBCNSU21"",143,0)"
^XMB(3.9,145946,2,5568,0)=" ; First select the Policy(s) to be selected"
^XMB(3.9,145946,2,5569,0)="""RTN"",""IBCNSU21"",144,0)"
^XMB(3.9,145946,2,5570,0)=" S IIENS=$$SELPOL(1,.DLINE,1,""IBCNSU21IX"")"
^XMB(3.9,145946,2,5571,0)="""RTN"",""IBCNSU21"",145,0)"
^XMB(3.9,145946,2,5572,0)=" I IIENS="""" S VALMBCK=""R"" Q                 ; None Selected"
^XMB(3.9,145946,2,5573,0)="""RTN"",""IBCNSU21"",146,0)"
^XMB(3.9,145946,2,5574,0)=" F IX=1:1:$L(IIENS,"","") D"
^XMB(3.9,145946,2,5575,0)="""RTN"",""IBCNSU21"",147,0)"
^XMB(3.9,145946,2,5576,0)=" . S IIEN=$P(IIENS,"","",IX)"
^XMB(3.9,145946,2,5577,0)="""RTN"",""IBCNSU21"",148,0)"
^XMB(3.9,145946,2,5578,0)=" . S LINE=$P(DLINE,"","",IX)"
^XMB(3.9,145946,2,5579,0)="""RTN"",""IBCNSU21"",149,0)"
^XMB(3.9,145946,2,5580,0)=" . ;"
^XMB(3.9,145946,2,5581,0)="""RTN"",""IBCNSU21"",150,0)"
^XMB(3.9,145946,2,5582,0)=" . ; If currently selected, display an error message"
^XMB(3.9,145946,2,5583,0)="""RTN"",""IBCNSU21"",151,0)"
^XMB(3.9,145946,2,5584,0)=" . I $D(^TMP(""IBCNSU21A"",$J,IIEN)) D  Q"
^XMB(3.9,145946,2,5585,0)="""RTN"",""IBCNSU21"",152,0)"
^XMB(3.9,145946,2,5586,0)=" . . W !,*7,"">>>> # "",LINE,"" is currently selected."""
^XMB(3.9,145946,2,5587,0)="""RTN"",""IBCNSU21"",153,0)"
^XMB(3.9,145946,2,5588,0)=" . . S ERROR=1"
^XMB(3.9,145946,2,5589,0)="""RTN"",""IBCNSU21"",154,0)"
^XMB(3.9,145946,2,5590,0)=" . D MARK(1,IIEN,LINE,.NUMSEL)              ; Show the selection mark"
^XMB(3.9,145946,2,5591,0)="""RTN"",""IBCNSU21"",155,0)"
^XMB(3.9,145946,2,5592,0)=" D HDR                                      ; Update the header"
^XMB(3.9,145946,2,5593,0)="""RTN"",""IBCNSU21"",156,0)"
^XMB(3.9,145946,2,5594,0)=" D:ERROR PAUSE^VALM1"
^XMB(3.9,145946,2,5595,0)="""RTN"",""IBCNSU21"",157,0)"
^XMB(3.9,145946,2,5596,0)=" Q"
^XMB(3.9,145946,2,5597,0)="""RTN"",""IBCNSU21"",158,0)"
^XMB(3.9,145946,2,5598,0)=" ;"
^XMB(3.9,145946,2,5599,0)="""RTN"",""IBCNSU21"",159,0)"
^XMB(3.9,145946,2,5600,0)="UNSEL(SELECTED) ;EP"
^XMB(3.9,145946,2,5601,0)="""RTN"",""IBCNSU21"",160,0)"
^XMB(3.9,145946,2,5602,0)=" ; Protocol Action to deselect an already selected policy"
^XMB(3.9,145946,2,5603,0)="""RTN"",""IBCNSU21"",161,0)"
^XMB(3.9,145946,2,5604,0)=" ; Input:   SELECTED                - 1 - Called from IBCN POL DESELECT"
^XMB(3.9,145946,2,5605,0)="""RTN"",""IBCNSU21"",162,0)"
^XMB(3.9,145946,2,5606,0)=" ;                                    0 - Called from IBCN DESELECT"
^XMB(3.9,145946,2,5607,0)="""RTN"",""IBCNSU21"",163,0)"
^XMB(3.9,145946,2,5608,0)=" ;                                    Optional, defaults to 0"
^XMB(3.9,145946,2,5609,0)="""RTN"",""IBCNSU21"",164,0)"
