^XMB(3.9,145944,2,1333,0)="""RTN"",""IBJDF42"",150,0)"
^XMB(3.9,145944,2,1334,0)=" ;"
^XMB(3.9,145944,2,1335,0)="""RTN"",""IBJDF42"",151,0)"
^XMB(3.9,145944,2,1336,0)="WCTX ; - Write the comment text."
^XMB(3.9,145944,2,1337,0)="""RTN"",""IBJDF42"",152,0)"
^XMB(3.9,145944,2,1338,0)=" N LIN,WLIN,Z"
^XMB(3.9,145944,2,1339,0)="""RTN"",""IBJDF42"",153,0)"
^XMB(3.9,145944,2,1340,0)=" S LIN="""""
^XMB(3.9,145944,2,1341,0)="""RTN"",""IBJDF42"",154,0)"
^XMB(3.9,145944,2,1342,0)=" F  S LIN=$O(^UTILITY($J,""W"",1,LIN)) Q:LIN=""""  D  Q:IBQ"
^XMB(3.9,145944,2,1343,0)="""RTN"",""IBJDF42"",155,0)"
^XMB(3.9,145944,2,1344,0)=" . S WLIN=$G(^UTILITY($J,""W"",1,LIN,0)) Q:WLIN="""""
^XMB(3.9,145944,2,1345,0)="""RTN"",""IBJDF42"",156,0)"
^XMB(3.9,145944,2,1346,0)=" . W ?16,WLIN"
^XMB(3.9,145944,2,1347,0)="""RTN"",""IBJDF42"",157,0)"
^XMB(3.9,145944,2,1348,0)=" . I '$O(^UTILITY($J,""W"",1,LIN)) W ! Q"
^XMB(3.9,145944,2,1349,0)="""RTN"",""IBJDF42"",158,0)"
^XMB(3.9,145944,2,1350,0)=" . I $Y>(IOSL-4) D WCPB,WCD(IBIDX,1,1) Q"
^XMB(3.9,145944,2,1351,0)="""RTN"",""IBJDF42"",159,0)"
