^XMB(3.9,145944,2,225,0)="""QUES"",""XPO1"",""??"")"
^XMB(3.9,145944,2,226,0)="^D MENU^XPDH"
^XMB(3.9,145944,2,227,0)="""QUES"",""XPO1"",""A"")"
^XMB(3.9,145944,2,228,0)="Want KIDS to Rebuild Menu Trees Upon Completion of Install"
^XMB(3.9,145944,2,229,0)="""QUES"",""XPO1"",""B"")"
