^XMB(3.9,145958,2,1181,0)="""RTN"",""ORWDXA"",85,0)"
^XMB(3.9,145958,2,1182,0)=" Q"
^XMB(3.9,145958,2,1183,0)="""RTN"",""ORWDXA"",86,0)"
^XMB(3.9,145958,2,1184,0)="DC(REC,ORID,ORNP,ORL,REASON,DCORIG,ISNEWORD) ; Discontinue/Cancel/Delete order"
^XMB(3.9,145958,2,1185,0)="""RTN"",""ORWDXA"",87,0)"
^XMB(3.9,145958,2,1186,0)=" N NATURE,CREATE,PRINT,STATUS,ACTDA,SIGSTS"
