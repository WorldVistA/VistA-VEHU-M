^XMB(3.9,145946,2,705,0)="""RTN"",""IBCMDT"",31,0)"
^XMB(3.9,145946,2,706,0)=" ; IBMDTSPC(""IBCLM"") 0 = ignore Missing Coverage Limitation filter."
^XMB(3.9,145946,2,707,0)="""RTN"",""IBCMDT"",32,0)"
^XMB(3.9,145946,2,708,0)=" ;                   1 = include Missing Coverage Limitation filter."
^XMB(3.9,145946,2,709,0)="""RTN"",""IBCMDT"",33,0)"
