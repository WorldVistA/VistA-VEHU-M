^XMB(3.9,145981,2,625,0)="""RTN"",""IBECECX1"",193,0)"
^XMB(3.9,145981,2,626,0)="ERR2(IBERRMSG) ;Handle error responses for Clock Discrepancy issues"
^XMB(3.9,145981,2,627,0)="""RTN"",""IBECECX1"",194,0)"
^XMB(3.9,145981,2,628,0)=" ;"
^XMB(3.9,145981,2,629,0)="""RTN"",""IBECECX1"",195,0)"
^XMB(3.9,145981,2,630,0)=" N XMY,XMSUB,IBL,IB3513D,IBTEXT,IBX,XMDUZ,XMTEXT"
^XMB(3.9,145981,2,631,0)="""RTN"",""IBECECX1"",196,0)"
^XMB(3.9,145981,2,632,0)=" ;IB*2*769 VDIF call to MVI prior to query to ensure patient has Treating Facilities - VDIF will not return any errors for this"
^XMB(3.9,145981,2,633,0)="""RTN"",""IBECECX1"",197,0)"
^XMB(3.9,145981,2,634,0)=" ;MAIL MESSAGE GENERATION CODE ON HOLD FOR FUTURE REQUIREMENTS"
^XMB(3.9,145981,2,635,0)="""RTN"",""IBECECX1"",198,0)"
^XMB(3.9,145981,2,636,0)=" K ^TMP($J,""IBCPYAC"")"
^XMB(3.9,145981,2,637,0)="""RTN"",""IBECECX1"",199,0)"
^XMB(3.9,145981,2,638,0)=" S XMSUB=""COPAY PATIENT ACCUMULATOR ISSUE"""
^XMB(3.9,145981,2,639,0)="""RTN"",""IBECECX1"",200,0)"
^XMB(3.9,145981,2,640,0)=" S XMY(""G.IB PATIENT ACCUMULATOR"")="""""
^XMB(3.9,145981,2,641,0)="""RTN"",""IBECECX1"",201,0)"
^XMB(3.9,145981,2,642,0)=" S IBL=0"
^XMB(3.9,145981,2,643,0)="""RTN"",""IBECECX1"",202,0)"
^XMB(3.9,145981,2,644,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""BILLING CLOCK DISCREPANCY FOUND BETWEEN VA FACILITIES:"""
^XMB(3.9,145981,2,645,0)="""RTN"",""IBECECX1"",203,0)"
^XMB(3.9,145981,2,646,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,647,0)="""RTN"",""IBECECX1"",204,0)"
^XMB(3.9,145981,2,648,0)=" S IBTEXT=IBERRMSG D WRAP(0,80,.IBTEXT)"
^XMB(3.9,145981,2,649,0)="""RTN"",""IBECECX1"",205,0)"
^XMB(3.9,145981,2,650,0)=" S IBX=0 F  S IBX=$O(IBTEXT(IBX)) Q:'IBX  D"
^XMB(3.9,145981,2,651,0)="""RTN"",""IBECECX1"",206,0)"
^XMB(3.9,145981,2,652,0)=" .S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=IBTEXT(IBX)"
^XMB(3.9,145981,2,653,0)="""RTN"",""IBECECX1"",207,0)"
^XMB(3.9,145981,2,654,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,655,0)="""RTN"",""IBECECX1"",208,0)"
^XMB(3.9,145981,2,656,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""As a result, the billing clock will not be synced up enterprise wide."""
^XMB(3.9,145981,2,657,0)="""RTN"",""IBECECX1"",209,0)"
^XMB(3.9,145981,2,658,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""Resolution will require researching encounters at the sites listed below"""
^XMB(3.9,145981,2,659,0)="""RTN"",""IBECECX1"",210,0)"
^XMB(3.9,145981,2,660,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""to determine the correct clock values and manually update billing clocks."""
^XMB(3.9,145981,2,661,0)="""RTN"",""IBECECX1"",211,0)"
^XMB(3.9,145981,2,662,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,663,0)="""RTN"",""IBECECX1"",212,0)"
^XMB(3.9,145981,2,664,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""Billing clock and error details and other sites with clocks:"""
^XMB(3.9,145981,2,665,0)="""RTN"",""IBECECX1"",213,0)"
^XMB(3.9,145981,2,666,0)=" S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)="""""
^XMB(3.9,145981,2,667,0)="""RTN"",""IBECECX1"",214,0)"
^XMB(3.9,145981,2,668,0)=" I $D(IBID) S IBL=IBL+1,^TMP($J,""IBCPYAC"",IBL)=""HLO MESSAGE ID: ""_IBID"
^XMB(3.9,145981,2,669,0)="""RTN"",""IBECECX1"",215,0)"
