^XMB(3.9,145987,2,1482,0)=" ; RPC: SDES2 SET APPT CHECKOUT"
^XMB(3.9,145987,2,1483,0)="""RTN"",""SDES2SETCHECKOUT"",17,0)"
^XMB(3.9,145987,2,1484,0)=" ;"
^XMB(3.9,145987,2,1485,0)="""RTN"",""SDES2SETCHECKOUT"",18,0)"
^XMB(3.9,145987,2,1486,0)=" ; SDCONTEXT(""ACHERON AUDIT ID"") = 36 character unique ID number. Ex: 11d9dcc6-c6a2-4785-8031-8261576fca37"
^XMB(3.9,145987,2,1487,0)="""RTN"",""SDES2SETCHECKOUT"",19,0)"
^XMB(3.9,145987,2,1488,0)=" ; SDCONTEXT(""USER DUZ"") = The DUZ of the user taking action on the calling application."
^XMB(3.9,145987,2,1489,0)="""RTN"",""SDES2SETCHECKOUT"",20,0)"
^XMB(3.9,145987,2,1490,0)=" ; SDCONTEXT(""USER SECID"") = The name of the user taking action on the calling application."
^XMB(3.9,145987,2,1491,0)="""RTN"",""SDES2SETCHECKOUT"",21,0)"
^XMB(3.9,145987,2,1492,0)=" ; SDCONTEXT(""PATIENT DFN"") = The DFN of the Veteran/user taking action on the calling application."
^XMB(3.9,145987,2,1493,0)="""RTN"",""SDES2SETCHECKOUT"",22,0)"
^XMB(3.9,145987,2,1494,0)=" ; SDCONTEXT(""PATIENT ICN"") = The ICN of the Veteran/user taking action on the calling application."
^XMB(3.9,145987,2,1495,0)="""RTN"",""SDES2SETCHECKOUT"",23,0)"
^XMB(3.9,145987,2,1496,0)=" ;"
^XMB(3.9,145987,2,1497,0)="""RTN"",""SDES2SETCHECKOUT"",24,0)"
^XMB(3.9,145987,2,1498,0)=" ; PARAMS(""APPT IEN"") = IEN of SDEC APPOINTMENT (#409.84) file record to be Checked Out (required)"
^XMB(3.9,145987,2,1499,0)="""RTN"",""SDES2SETCHECKOUT"",25,0)"
^XMB(3.9,145987,2,1500,0)=" ; PARAMS(""CHECKOUT DATE"") = Checkout date/time in ISO format (required)"
^XMB(3.9,145987,2,1501,0)="""RTN"",""SDES2SETCHECKOUT"",26,0)"
^XMB(3.9,145987,2,1502,0)=" ;"
^XMB(3.9,145987,2,1503,0)="""RTN"",""SDES2SETCHECKOUT"",27,0)"
^XMB(3.9,145987,2,1504,0)="SETCHECKOUT(JSONRETURN,SDCONTEXT,PARAMS) ; Set Checkout Date/Time for Appointment"
^XMB(3.9,145987,2,1505,0)="""RTN"",""SDES2SETCHECKOUT"",28,0)"
^XMB(3.9,145987,2,1506,0)=" ;"
^XMB(3.9,145987,2,1507,0)="""RTN"",""SDES2SETCHECKOUT"",29,0)"
^XMB(3.9,145987,2,1508,0)=" N APPTDATA,APPTIENS,CLINICIEN,RESOURCE,SDASK,SDCOACT,SDDA,DFN,SDERRORS,SDLNE,SDQUIET,SDRETURN"
^XMB(3.9,145987,2,1509,0)="""RTN"",""SDES2SETCHECKOUT"",30,0)"
^XMB(3.9,145987,2,1510,0)=" ;"
^XMB(3.9,145987,2,1511,0)="""RTN"",""SDES2SETCHECKOUT"",31,0)"
^XMB(3.9,145987,2,1512,0)=" ; Validate SDCONTEXT"
^XMB(3.9,145987,2,1513,0)="""RTN"",""SDES2SETCHECKOUT"",32,0)"
^XMB(3.9,145987,2,1514,0)=" ;"
^XMB(3.9,145987,2,1515,0)="""RTN"",""SDES2SETCHECKOUT"",33,0)"
^XMB(3.9,145987,2,1516,0)=" D VALCONTEXT^SDES2VALCONTEXT(.SDERRORS,.SDCONTEXT)"
^XMB(3.9,145987,2,1517,0)="""RTN"",""SDES2SETCHECKOUT"",34,0)"
^XMB(3.9,145987,2,1518,0)=" I $D(SDERRORS) M SDRETURN=SDERRORS S SDRETURN(""Checkout"",1)="""" D BUILDJSON^SDES2JSON(.JSONRETURN,.SDRETURN) Q"
^XMB(3.9,145987,2,1519,0)="""RTN"",""SDES2SETCHECKOUT"",35,0)"
^XMB(3.9,145987,2,1520,0)=" I $G(SDCONTEXT(""USER DUZ""))'="""" N DUZ D DUZ^XUP(SDCONTEXT(""USER DUZ""))"
^XMB(3.9,145987,2,1521,0)="""RTN"",""SDES2SETCHECKOUT"",36,0)"
^XMB(3.9,145987,2,1522,0)=" ;"
^XMB(3.9,145987,2,1523,0)="""RTN"",""SDES2SETCHECKOUT"",37,0)"
^XMB(3.9,145987,2,1524,0)=" ; Validate APPT IEN"
