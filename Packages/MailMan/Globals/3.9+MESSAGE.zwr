^XMB(3.9,145986,2,924,0)=" ;;3.5;FEE BASIS;**55,61,116,108,164**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,925,0)="""RTN"",""FBAACCB1"",3,0)"
^XMB(3.9,145986,2,926,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145986,2,927,0)="""RTN"",""FBAACCB1"",4,0)"
^XMB(3.9,145986,2,928,0)="PHARM ;ENTRY FOR PHARMACY BATCH CALCULATE TOTAL DOLLARS AND LINE COUNT"
^XMB(3.9,145986,2,929,0)="""RTN"",""FBAACCB1"",5,0)"
^XMB(3.9,145986,2,930,0)=" ; HIPAA 5010 - count line items that have 0.00 amount paid"
^XMB(3.9,145986,2,931,0)="""RTN"",""FBAACCB1"",6,0)"
^XMB(3.9,145986,2,932,0)=" F A=0:0 S A=$O(^FBAA(162.1,""AE"",B,A)) Q:A'>0  F B2=0:0 S B2=$O(^FBAA(162.1,""AE"",B,A,B2)) Q:B2'>0  I $D(^FBAA(162.1,A,""RX"",B2,0)) S Z(0)=^(0) D MOREP"
^XMB(3.9,145986,2,933,0)="""RTN"",""FBAACCB1"",7,0)"
^XMB(3.9,145986,2,934,0)=" G FIN^FBAACCB"
^XMB(3.9,145986,2,935,0)="""RTN"",""FBAACCB1"",8,0)"
^XMB(3.9,145986,2,936,0)="MOREP S T=T+$P(Z(0),""^"",16),C=C+1 Q"
^XMB(3.9,145986,2,937,0)="""RTN"",""FBAACCB1"",9,0)"
^XMB(3.9,145986,2,938,0)=" ;"
^XMB(3.9,145986,2,939,0)="""RTN"",""FBAACCB1"",10,0)"
^XMB(3.9,145986,2,940,0)="TRAV ;ENTRY FOR TRAVEL BATCH CALCULATE TOTAL DOLLARS AND LINE COUNT"
^XMB(3.9,145986,2,941,0)="""RTN"",""FBAACCB1"",11,0)"
^XMB(3.9,145986,2,942,0)=" ; HIPAA 5010 - count line items that have 0.00 amount paid"
^XMB(3.9,145986,2,943,0)="""RTN"",""FBAACCB1"",12,0)"
^XMB(3.9,145986,2,944,0)=" F J=0:0 S J=$O(^FBAAC(""AD"",B,J)) Q:J'>0  F K=0:0 S K=$O(^FBAAC(""AD"",B,J,K)) Q:K'>0  I $D(^FBAAC(J,3,K,0)) S Z(0)=^(0) D MORET"
^XMB(3.9,145986,2,945,0)="""RTN"",""FBAACCB1"",13,0)"
^XMB(3.9,145986,2,946,0)=" G FIN^FBAACCB"
^XMB(3.9,145986,2,947,0)="""RTN"",""FBAACCB1"",14,0)"
^XMB(3.9,145986,2,948,0)=" ;"
^XMB(3.9,145986,2,949,0)="""RTN"",""FBAACCB1"",15,0)"
^XMB(3.9,145986,2,950,0)="MORET S T=T+$P(Z(0),""^"",3),C=C+1 Q"
^XMB(3.9,145986,2,951,0)="""RTN"",""FBAACCB1"",16,0)"
^XMB(3.9,145986,2,952,0)="LISTC S Q="""",$P(Q,""="",80)=""="",(FBAAOUT,FBLISTC)=0,IOP=$S($D(ION):ION,1:""HOME"") D ^%ZIS K IOP"
^XMB(3.9,145986,2,953,0)="""RTN"",""FBAACCB1"",17,0)"
^XMB(3.9,145986,2,954,0)="PRTC D HEDC"
^XMB(3.9,145986,2,955,0)="""RTN"",""FBAACCB1"",18,0)"
^XMB(3.9,145986,2,956,0)=" F I=0:0 S I=$O(^FBAAI(""AC"",B,I)) Q:I'>0!(FBAAOUT)  I $D(^FBAAI(I,0)) S Z(0)=^(0) D CMORE"
^XMB(3.9,145986,2,957,0)="""RTN"",""FBAACCB1"",19,0)"
^XMB(3.9,145986,2,958,0)=" Q"
^XMB(3.9,145986,2,959,0)="""RTN"",""FBAACCB1"",20,0)"
^XMB(3.9,145986,2,960,0)="CMORE N FBADJLR,FBFPPSC,FBFPPSL,FBX,FBY3,FBDX,FBPOA,FBADMTDX"
^XMB(3.9,145986,2,961,0)="""RTN"",""FBAACCB1"",21,0)"
^XMB(3.9,145986,2,962,0)=" S K=$P(Z(0),""^"",3),J=$P(Z(0),""^"",4) D ENV^FBAACCB0 S N=$$NAME^FBCHREQ2(J),S=$$SSN^FBAAUTL(J),FBIN=I,FBAC=$P(Z(0),""^"",8)+.0001,FBAP=$P(Z(0),""^"",9)+.0001,FBVP=$P(Z(0),""^"",14),ZS=$P(Z(0),""^"",13)"
^XMB(3.9,145986,2,963,0)="""RTN"",""FBAACCB1"",22,0)"
^XMB(3.9,145986,2,964,0)=" S FBAC=$P(FBAC,""."",1)_"".""_$E($P(FBAC,""."",2),1,2),FBAP=$P(FBAP,""."",1)_"".""_$E($P(FBAP,""."",2),1,2)"
^XMB(3.9,145986,2,965,0)="""RTN"",""FBAACCB1"",23,0)"
^XMB(3.9,145986,2,966,0)=" S FBSC=$P(Z(0),""^"",11),FBSC=$S(FBSC="""":"""",$D(^FBAA(161.27,FBSC,0)):$P(^(0),""^"",1),1:""""),FBFD=$P(Z(0),""^"",6),FBTD=$P(Z(0),""^"",7) S FBPDT=FBFD D CDAT S FBFD=FBPDT,FBPDT=FBTD D CDAT S FBTD=FBPDT"
^XMB(3.9,145986,2,967,0)="""RTN"",""FBAACCB1"",24,0)"
^XMB(3.9,145986,2,968,0)=" S FBY3=$G(^FBAAI(I,3))"
^XMB(3.9,145986,2,969,0)="""RTN"",""FBAACCB1"",25,0)"
^XMB(3.9,145986,2,970,0)=" S FBFPPSC=$P(FBY3,U)"
^XMB(3.9,145986,2,971,0)="""RTN"",""FBAACCB1"",26,0)"
^XMB(3.9,145986,2,972,0)=" S FBFPPSL=$P(FBY3,U,2)"
^XMB(3.9,145986,2,973,0)="""RTN"",""FBAACCB1"",27,0)"
^XMB(3.9,145986,2,974,0)=" S FBX=$$ADJLRA^FBCHFA(I_"","")"
^XMB(3.9,145986,2,975,0)="""RTN"",""FBAACCB1"",28,0)"
^XMB(3.9,145986,2,976,0)=" S FBADJLR=$P(FBX,U)"
^XMB(3.9,145986,2,977,0)="""RTN"",""FBAACCB1"",29,0)"
^XMB(3.9,145986,2,978,0)=" D FBCKI(I)"
^XMB(3.9,145986,2,979,0)="""RTN"",""FBAACCB1"",30,0)"
^XMB(3.9,145986,2,980,0)=" S B(1617)=$S(B="""":"""",$D(^FBAA(161.7,B,0)):$P(^(0),""^""),1:"""")"
^XMB(3.9,145986,2,981,0)="""RTN"",""FBAACCB1"",31,0)"
^XMB(3.9,145986,2,982,0)=" S FBIN(1)=$P(Z(0),""^"",2)"
^XMB(3.9,145986,2,983,0)="""RTN"",""FBAACCB1"",32,0)"
^XMB(3.9,145986,2,984,0)=" D WRITC"
^XMB(3.9,145986,2,985,0)="""RTN"",""FBAACCB1"",33,0)"
^XMB(3.9,145986,2,986,0)=" Q"
^XMB(3.9,145986,2,987,0)="""RTN"",""FBAACCB1"",34,0)"
^XMB(3.9,145986,2,988,0)="WRITC I $Y+7>IOSL D ASKH^FBAACCB0:$E(IOST,1,2)[""C-"" Q:FBAAOUT  W @IOF D HEDC"
^XMB(3.9,145986,2,989,0)="""RTN"",""FBAACCB1"",35,0)"
^XMB(3.9,145986,2,990,0)=" W !!,$S('$D(ZS):"""",ZS=""R"":""*"",1:"""")"
^XMB(3.9,145986,2,991,0)="""RTN"",""FBAACCB1"",36,0)"
^XMB(3.9,145986,2,992,0)=" W N,?35,S,?60,B(1617)"
^XMB(3.9,145986,2,993,0)="""RTN"",""FBAACCB1"",37,0)"
^XMB(3.9,145986,2,994,0)=" W !,?3,V,?45,VID,?58,FBIN,?70,$$DATX^FBAAUTL($E(FBIN(1),1,7))"
^XMB(3.9,145986,2,995,0)="""RTN"",""FBAACCB1"",38,0)"
^XMB(3.9,145986,2,996,0)=" I FBFPPSC]"""" W !,?4,""FPPS Claim ID: "",FBFPPSC,""   FPPS Line: "",FBFPPSL"
^XMB(3.9,145986,2,997,0)="""RTN"",""FBAACCB1"",39,0)"
^XMB(3.9,145986,2,998,0)=" W !,$S($D(QQ):QQ_"")"",1:""""),FBVP,$S(FBCAN]"""":""+"",1:""""),?4,FBFD,?13,FBTD,?22,$J(FBAC,6),?32,$J(FBAP,6),?45,$S(FBADJLR]"""":FBADJLR,1:FBSC)"
^XMB(3.9,145986,2,999,0)="""RTN"",""FBAACCB1"",40,0)"
^XMB(3.9,145986,2,1000,0)=" W:$P(Z(0),""^"",24) ?56,""Discharge "",$$ICD^FBCSV1(+$P(Z(0),""^"",24),$P(Z(0),""^"",6)) W ! ;CSV"
^XMB(3.9,145986,2,1001,0)="""RTN"",""FBAACCB1"",41,0)"
^XMB(3.9,145986,2,1002,0)=" ; write admitting diagnosis"
^XMB(3.9,145986,2,1003,0)="""RTN"",""FBAACCB1"",42,0)"
^XMB(3.9,145986,2,1004,0)=" N P7,P8"
^XMB(3.9,145986,2,1005,0)="""RTN"",""FBAACCB1"",43,0)"
^XMB(3.9,145986,2,1006,0)=" S P7=$G(^FBAAI(I,5))"
^XMB(3.9,145986,2,1007,0)="""RTN"",""FBAACCB1"",44,0)"
^XMB(3.9,145986,2,1008,0)=" S FBADMTDX=$P(P7,""^"",9)"
^XMB(3.9,145986,2,1009,0)="""RTN"",""FBAACCB1"",45,0)"
^XMB(3.9,145986,2,1010,0)=" S P8=$$ICD9^FBCSV1(FBADMTDX,$P($G(Z(0)),""^"",6))"
^XMB(3.9,145986,2,1011,0)="""RTN"",""FBAACCB1"",46,0)"
^XMB(3.9,145986,2,1012,0)=" I P8'="""" W !,?4,""Admit Dx: "",P8"
^XMB(3.9,145986,2,1013,0)="""RTN"",""FBAACCB1"",47,0)"
^XMB(3.9,145986,2,1014,0)=" ; set diagnosis code and present on admission code"
^XMB(3.9,145986,2,1015,0)="""RTN"",""FBAACCB1"",48,0)"
^XMB(3.9,145986,2,1016,0)=" N P1,P2"
^XMB(3.9,145986,2,1017,0)="""RTN"",""FBAACCB1"",49,0)"
^XMB(3.9,145986,2,1018,0)=" S P1=$G(^FBAAI(I,""DX""))"
^XMB(3.9,145986,2,1019,0)="""RTN"",""FBAACCB1"",50,0)"
^XMB(3.9,145986,2,1020,0)=" S P2=$G(^FBAAI(I,""POA""))"
^XMB(3.9,145986,2,1021,0)="""RTN"",""FBAACCB1"",51,0)"
^XMB(3.9,145986,2,1022,0)=" F FBK=1:1:25 D WRTDX"
^XMB(3.9,145986,2,1023,0)="""RTN"",""FBAACCB1"",52,0)"
^XMB(3.9,145986,2,1024,0)=" ; set procedure code"
^XMB(3.9,145986,2,1025,0)="""RTN"",""FBAACCB1"",53,0)"
^XMB(3.9,145986,2,1026,0)=" N P5"
^XMB(3.9,145986,2,1027,0)="""RTN"",""FBAACCB1"",54,0)"
^XMB(3.9,145986,2,1028,0)=" S P5=$G(^FBAAI(I,""PROC""))"
^XMB(3.9,145986,2,1029,0)="""RTN"",""FBAACCB1"",55,0)"
^XMB(3.9,145986,2,1030,0)=" F FBL=1:1:25 D WRTPC"
^XMB(3.9,145986,2,1031,0)="""RTN"",""FBAACCB1"",56,0)"
^XMB(3.9,145986,2,1032,0)=" ; write attachment IDs"
^XMB(3.9,145986,2,1033,0)="""RTN"",""FBAACCB1"",57,0)"
^XMB(3.9,145986,2,1034,0)=" I $D(^FBAAI(I,10)) D"
^XMB(3.9,145986,2,1035,0)="""RTN"",""FBAACCB1"",58,0)"
^XMB(3.9,145986,2,1036,0)=" . N AI,AID,AITI,WRTPC"
^XMB(3.9,145986,2,1037,0)="""RTN"",""FBAACCB1"",59,0)"
^XMB(3.9,145986,2,1038,0)=" . S AI=0 S WRTPC=""Attachment ID:"""
^XMB(3.9,145986,2,1039,0)="""RTN"",""FBAACCB1"",60,0)"
^XMB(3.9,145986,2,1040,0)=" . F  S AI=$O(^FBAAI(I,10,AI)) Q:'AI  D"
^XMB(3.9,145986,2,1041,0)="""RTN"",""FBAACCB1"",61,0)"
^XMB(3.9,145986,2,1042,0)=" . . S AID=$P($G(^FBAAI(I,10,AI,0)),""^"") I AI>1 S WRTPC=WRTPC_"","""
^XMB(3.9,145986,2,1043,0)="""RTN"",""FBAACCB1"",62,0)"
^XMB(3.9,145986,2,1044,0)=" . . S WRTPC=WRTPC_"" ""_AID"
^XMB(3.9,145986,2,1045,0)="""RTN"",""FBAACCB1"",63,0)"
^XMB(3.9,145986,2,1046,0)=" . . S AITI=$P($G(^FBAAI(I,10,AI,0)),""^"",2) I AITI D"
^XMB(3.9,145986,2,1047,0)="""RTN"",""FBAACCB1"",64,0)"
^XMB(3.9,145986,2,1048,0)=" . . . S WRTPC=WRTPC_"" (""_$P($G(^IBE(353.3,AITI,0)),""^"")"
^XMB(3.9,145986,2,1049,0)="""RTN"",""FBAACCB1"",65,0)"
^XMB(3.9,145986,2,1050,0)=" . . . S WRTPC=WRTPC_"" - """
^XMB(3.9,145986,2,1051,0)="""RTN"",""FBAACCB1"",66,0)"
^XMB(3.9,145986,2,1052,0)=" . . . S WRTPC=WRTPC_$P($G(^IBE(353.3,AITI,0)),""^"",2)_"")"""
^XMB(3.9,145986,2,1053,0)="""RTN"",""FBAACCB1"",67,0)"
^XMB(3.9,145986,2,1054,0)=" . . I $L(WRTPC)>IOM D WRTSTR(.WRTPC,IOM)"
^XMB(3.9,145986,2,1055,0)="""RTN"",""FBAACCB1"",68,0)"
^XMB(3.9,145986,2,1056,0)=" . I $L(WRTPC)>0 D WRTSTR(.WRTPC,IOM)"
^XMB(3.9,145986,2,1057,0)="""RTN"",""FBAACCB1"",69,0)"
^XMB(3.9,145986,2,1058,0)=" S A2=FBAP D PMNT^FBAACCB2 K A2"
^XMB(3.9,145986,2,1059,0)="""RTN"",""FBAACCB1"",70,0)"
^XMB(3.9,145986,2,1060,0)=" Q"
^XMB(3.9,145986,2,1061,0)="""RTN"",""FBAACCB1"",71,0)"
^XMB(3.9,145986,2,1062,0)="WRTSTR(STR,MX) ; Wordwrap string"
^XMB(3.9,145986,2,1063,0)="""RTN"",""FBAACCB1"",72,0)"
^XMB(3.9,145986,2,1064,0)=" N RM,I"
^XMB(3.9,145986,2,1065,0)="""RTN"",""FBAACCB1"",73,0)"
^XMB(3.9,145986,2,1066,0)="WRTSTR1 S RM=$S(STR?1""Attachment ID:"".E:MX-4,1:MX-7)"
^XMB(3.9,145986,2,1067,0)="""RTN"",""FBAACCB1"",74,0)"
^XMB(3.9,145986,2,1068,0)=" F I=1:1:$L(STR,"" "") Q:$L($P(STR,"" "",1,I))>RM"
^XMB(3.9,145986,2,1069,0)="""RTN"",""FBAACCB1"",75,0)"
^XMB(3.9,145986,2,1070,0)=" W !,?4 W:STR'?1""Attachment ID:"".E ?7"
^XMB(3.9,145986,2,1071,0)="""RTN"",""FBAACCB1"",76,0)"
^XMB(3.9,145986,2,1072,0)=" I $L($P(STR,"" "",1,I))>RM W $P(STR,"" "",1,I-1) S STR=$P(STR,"" "",I,999)"
^XMB(3.9,145986,2,1073,0)="""RTN"",""FBAACCB1"",77,0)"
^XMB(3.9,145986,2,1074,0)=" E  W $P(STR,"" "",1,I) S STR="""""
^XMB(3.9,145986,2,1075,0)="""RTN"",""FBAACCB1"",78,0)"
^XMB(3.9,145986,2,1076,0)=" I $L(STR)>(MX-3) G WRTSTR1"
^XMB(3.9,145986,2,1077,0)="""RTN"",""FBAACCB1"",79,0)"
^XMB(3.9,145986,2,1078,0)=" Q"
^XMB(3.9,145986,2,1079,0)="""RTN"",""FBAACCB1"",80,0)"
^XMB(3.9,145986,2,1080,0)="CDAT S FBPDT=$E(FBPDT,4,5)_""/""_$S($E(FBPDT,6,7)=""00"":$E(FBPDT,2,3),1:$E(FBPDT,6,7)_""/""_$E(FBPDT,2,3))"
^XMB(3.9,145986,2,1081,0)="""RTN"",""FBAACCB1"",81,0)"
^XMB(3.9,145986,2,1082,0)=" Q"
^XMB(3.9,145986,2,1083,0)="""RTN"",""FBAACCB1"",82,0)"
^XMB(3.9,145986,2,1084,0)="HEDC W ""Patient Name"",?20,""('*' Reimbursement to Veteran   '+' Cancellation Activity)"",!,?13,""('#' Voided Payment '&' Additional Payment)"",?60,""Batch Number"""
^XMB(3.9,145986,2,1085,0)="""RTN"",""FBAACCB1"",83,0)"
^XMB(3.9,145986,2,1086,0)=" W !,?3,""Vendor Name"",?45,""Vendor ID"",?57,""Invoice #"",?68,""Dt Inv Rec'd"",!,?3,""FR DATE"",?14,""TO DATE  CLAIMED   PAID"",?41,""ADJ CODE"",!,Q,!"
^XMB(3.9,145986,2,1087,0)="""RTN"",""FBAACCB1"",84,0)"
^XMB(3.9,145986,2,1088,0)=" Q"
^XMB(3.9,145986,2,1089,0)="""RTN"",""FBAACCB1"",85,0)"
^XMB(3.9,145986,2,1090,0)="CHNH ; FB*3.5*116"
^XMB(3.9,145986,2,1091,0)="""RTN"",""FBAACCB1"",86,0)"
^XMB(3.9,145986,2,1092,0)=" S (J,FZ(""CNT""))=0 F  S J=$O(^FBAAI(""AC"",B,J)) Q:J'>0  I $D(^FBAAI(J,0)) S Z(0)=^(0) D MORECH D:$P(FZ,U,15)'=""Y"" INVCNT"
^XMB(3.9,145986,2,1093,0)="""RTN"",""FBAACCB1"",87,0)"
^XMB(3.9,145986,2,1094,0)=" S:$G(FZ(""CNT"")) $P(FZ,U,10)=FZ(""CNT"") K FZ(""CNT"")  ; CNH batch"
^XMB(3.9,145986,2,1095,0)="""RTN"",""FBAACCB1"",88,0)"
^XMB(3.9,145986,2,1096,0)=" G FIN^FBAACCB"
^XMB(3.9,145986,2,1097,0)="""RTN"",""FBAACCB1"",89,0)"
^XMB(3.9,145986,2,1098,0)=" ;"
^XMB(3.9,145986,2,1099,0)="""RTN"",""FBAACCB1"",90,0)"
^XMB(3.9,145986,2,1100,0)="MORECH ; HIPAA 5010 - count line items that have 0.00 amount paid"
^XMB(3.9,145986,2,1101,0)="""RTN"",""FBAACCB1"",91,0)"
^XMB(3.9,145986,2,1102,0)=" S T=T+$P(Z(0),""^"",9),C=C+1"
^XMB(3.9,145986,2,1103,0)="""RTN"",""FBAACCB1"",92,0)"
^XMB(3.9,145986,2,1104,0)=" ; FB*3.5*116 - build array of invoices"
^XMB(3.9,145986,2,1105,0)="""RTN"",""FBAACCB1"",93,0)"
^XMB(3.9,145986,2,1106,0)=" ;do not build array for CH batches not exempt from the pricer"
^XMB(3.9,145986,2,1107,0)="""RTN"",""FBAACCB1"",94,0)"
^XMB(3.9,145986,2,1108,0)=" Q:($P(FZ,""^"",18)'=""Y"")&($P(FZ,""^"",15)=""Y"") "
