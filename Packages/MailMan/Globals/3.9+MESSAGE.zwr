^XMB(3.9,145989,2,1386,0)=" S STATEIEN=$$GET1^DIQ(58.42,BATCHIEN,1,""I"")"
^XMB(3.9,145989,2,1387,0)="""RTN"",""PSOSPML2"",89,0)"
^XMB(3.9,145989,2,1388,0)=" S PSOASVER=$$GET1^DIQ(58.41,STATEIEN,1,""I"")"
^XMB(3.9,145989,2,1389,0)="""RTN"",""PSOSPML2"",90,0)"
^XMB(3.9,145989,2,1390,0)=" S PSOTXRTS=+$$GET1^DIQ(58.41,STATEIEN,12,""I"")"
^XMB(3.9,145989,2,1391,0)="""RTN"",""PSOSPML2"",91,0)"
^XMB(3.9,145989,2,1392,0)=" ;"
^XMB(3.9,145989,2,1393,0)="""RTN"",""PSOSPML2"",92,0)"
^XMB(3.9,145989,2,1394,0)=" S QUIT=0,RUNMODE=""F"""
^XMB(3.9,145989,2,1395,0)="""RTN"",""PSOSPML2"",93,0)"
^XMB(3.9,145989,2,1396,0)=" I MODE=""EXPORT"",($$GET1^DIQ(58.42,BATCHIEN,2,""I"")'=""VD""!PSOTXRTS) D  I QUIT Q"
^XMB(3.9,145989,2,1397,0)="""RTN"",""PSOSPML2"",94,0)"
^XMB(3.9,145989,2,1398,0)=" . W ! K DIRUT,DUOUT,DIR"
^XMB(3.9,145989,2,1399,0)="""RTN"",""PSOSPML2"",95,0)"
^XMB(3.9,145989,2,1400,0)=" . S DIR(0)=""SA^B:Background;F:Foreground;D:Debug Mode (Foreground)"""
^XMB(3.9,145989,2,1401,0)="""RTN"",""PSOSPML2"",96,0)"
^XMB(3.9,145989,2,1402,0)=" . S DIR(""A"",1)=""Indicate whether the transmission should be queued to run on the Background"""
^XMB(3.9,145989,2,1403,0)="""RTN"",""PSOSPML2"",97,0)"
^XMB(3.9,145989,2,1404,0)=" . S DIR(""A"",2)=""via TaskMan, on the Foreground (Terminal Screen) or in Debug Mode (Foreground)"""
^XMB(3.9,145989,2,1405,0)="""RTN"",""PSOSPML2"",98,0)"
^XMB(3.9,145989,2,1406,0)=" . S DIR(""A"",3)=""which shows the sFTP (secure File Transfer) connection steps."""
^XMB(3.9,145989,2,1407,0)="""RTN"",""PSOSPML2"",99,0)"
^XMB(3.9,145989,2,1408,0)=" . S DIR(""A"",3)="""""
^XMB(3.9,145989,2,1409,0)="""RTN"",""PSOSPML2"",100,0)"
^XMB(3.9,145989,2,1410,0)=" . S DIR(""A"",4)=""      Select one of the following:"""
^XMB(3.9,145989,2,1411,0)="""RTN"",""PSOSPML2"",101,0)"
^XMB(3.9,145989,2,1412,0)=" . S DIR(""A"",5)="""""
^XMB(3.9,145989,2,1413,0)="""RTN"",""PSOSPML2"",102,0)"
^XMB(3.9,145989,2,1414,0)=" . S DIR(""A"",6)=""          B         Background"""
^XMB(3.9,145989,2,1415,0)="""RTN"",""PSOSPML2"",103,0)"
^XMB(3.9,145989,2,1416,0)=" . S DIR(""A"",7)=""          F         Foreground"""
^XMB(3.9,145989,2,1417,0)="""RTN"",""PSOSPML2"",104,0)"
^XMB(3.9,145989,2,1418,0)=" . S DIR(""A"",8)=""          D         Debug Mode (Foreground)"""
^XMB(3.9,145989,2,1419,0)="""RTN"",""PSOSPML2"",105,0)"
^XMB(3.9,145989,2,1420,0)=" . S DIR(""A"",9)="""""
^XMB(3.9,145989,2,1421,0)="""RTN"",""PSOSPML2"",106,0)"
^XMB(3.9,145989,2,1422,0)=" . S DIR(""A"")=""Running Mode: "",DIR(""B"")=""F"",DIR(""??"")=""^D RMHELP^PSOSPML2"""
^XMB(3.9,145989,2,1423,0)="""RTN"",""PSOSPML2"",107,0)"
^XMB(3.9,145989,2,1424,0)=" . D ^DIR I $D(DTOUT)!$D(DIRUT) S QUIT=1 Q"
^XMB(3.9,145989,2,1425,0)="""RTN"",""PSOSPML2"",108,0)"
^XMB(3.9,145989,2,1426,0)=" . S RUNMODE=Y"
^XMB(3.9,145989,2,1427,0)="""RTN"",""PSOSPML2"",109,0)"
^XMB(3.9,145989,2,1428,0)=" . W ! K DIRUT,DUOUT,DIR"
^XMB(3.9,145989,2,1429,0)="""RTN"",""PSOSPML2"",110,0)"
^XMB(3.9,145989,2,1430,0)=" . S DIR(""A"",1)=""The Batch will be transmitted to the state of ""_$$GET1^DIQ(58.42,BATCHIEN,1)_""."""
^XMB(3.9,145989,2,1431,0)="""RTN"",""PSOSPML2"",111,0)"
^XMB(3.9,145989,2,1432,0)=" . S DIR(""A"",2)="""",DIR(""A"")=""Confirm"",DIR(0)=""Y"",DIR(""B"")=""N"""
^XMB(3.9,145989,2,1433,0)="""RTN"",""PSOSPML2"",112,0)"
^XMB(3.9,145989,2,1434,0)=" . D ^DIR I $G(DTOUT)!$G(DUOUT)!'Y S QUIT=1 Q"
^XMB(3.9,145989,2,1435,0)="""RTN"",""PSOSPML2"",113,0)"
^XMB(3.9,145989,2,1436,0)=" . I RUNMODE'=""B"" W ?40,""Please wait..."""
^XMB(3.9,145989,2,1437,0)="""RTN"",""PSOSPML2"",114,0)"
^XMB(3.9,145989,2,1438,0)=" . I RUNMODE=""D"",($$GET1^DIQ(58.42,BATCHIEN,2,""I"")'=""RX"") D DBUG(BATCHIEN) I QUIT=1 Q"
^XMB(3.9,145989,2,1439,0)="""RTN"",""PSOSPML2"",115,0)"
^XMB(3.9,145989,2,1440,0)=" ;"
^XMB(3.9,145989,2,1441,0)="""RTN"",""PSOSPML2"",116,0)"
^XMB(3.9,145989,2,1442,0)=" I (MODE=""VIEW"")!(($$GET1^DIQ(58.42,BATCHIEN,2,""I"")=""VD"")&'PSOTXRTS) D  D ^%ZIS K %ZIS Q:POP  U IO"
^XMB(3.9,145989,2,1443,0)="""RTN"",""PSOSPML2"",117,0)"
^XMB(3.9,145989,2,1444,0)=" . D EXMSG($S(MODE=""VIEW"":0,1:1)) W ! K %ZIS,IOP,POP,ZTSK S %ZIS=""QM"""
^XMB(3.9,145989,2,1445,0)="""RTN"",""PSOSPML2"",118,0)"
^XMB(3.9,145989,2,1446,0)=" ;"
^XMB(3.9,145989,2,1447,0)="""RTN"",""PSOSPML2"",119,0)"
^XMB(3.9,145989,2,1448,0)=" ; If export batch type is VOID ONLY, and TRANSMIT RTS is OFF, just display for capture"
^XMB(3.9,145989,2,1449,0)="""RTN"",""PSOSPML2"",120,0)"
^XMB(3.9,145989,2,1450,0)=" I (MODE=""VIEW"")!(($$GET1^DIQ(58.42,BATCHIEN,2,""I"")=""VD"")&'PSOTXRTS) D"
^XMB(3.9,145989,2,1451,0)="""RTN"",""PSOSPML2"",121,0)"
^XMB(3.9,145989,2,1452,0)=" . W ! D EXPORT^PSOSPMUT(BATCHIEN,""VIEW"")"
^XMB(3.9,145989,2,1453,0)="""RTN"",""PSOSPML2"",122,0)"
^XMB(3.9,145989,2,1454,0)=" . D ^%ZISC"
^XMB(3.9,145989,2,1455,0)="""RTN"",""PSOSPML2"",123,0)"
^XMB(3.9,145989,2,1456,0)=" E  D"
^XMB(3.9,145989,2,1457,0)="""RTN"",""PSOSPML2"",124,0)"
^XMB(3.9,145989,2,1458,0)=" . I RUNMODE=""B"" D  Q"
^XMB(3.9,145989,2,1459,0)="""RTN"",""PSOSPML2"",125,0)"
^XMB(3.9,145989,2,1460,0)=" . . N ZTRTN,ZTIO,ZTDESC,ZTDTH,ZTSK"
^XMB(3.9,145989,2,1461,0)="""RTN"",""PSOSPML2"",126,0)"
^XMB(3.9,145989,2,1462,0)=" . . S ZTRTN=""EXPORT^PSOSPMUT(""_BATCHIEN_"",""""EXPORT"""",1,1)"",ZTIO="""""
^XMB(3.9,145989,2,1463,0)="""RTN"",""PSOSPML2"",127,0)"
^XMB(3.9,145989,2,1464,0)=" . . S ZTDESC=""State Prescription Monitoring Program (SPMP) Transmission"""
^XMB(3.9,145989,2,1465,0)="""RTN"",""PSOSPML2"",128,0)"
^XMB(3.9,145989,2,1466,0)=" . . S ZTDTH=$$NOW^XLFDT()"
^XMB(3.9,145989,2,1467,0)="""RTN"",""PSOSPML2"",129,0)"
^XMB(3.9,145989,2,1468,0)=" . . D ^%ZTLOAD W:$D(ZTSK) !!,""Export Background Job Queued to Run."",$C(7),! K ZTSK"
^XMB(3.9,145989,2,1469,0)="""RTN"",""PSOSPML2"",130,0)"
^XMB(3.9,145989,2,1470,0)=" . D EXPORT^PSOSPMUT(BATCHIEN,""EXPORT"",0,$S(RUNMODE=""D"":1,1:0),$G(FLUSH))"
^XMB(3.9,145989,2,1471,0)="""RTN"",""PSOSPML2"",131,0)"
^XMB(3.9,145989,2,1472,0)=" ;"
^XMB(3.9,145989,2,1473,0)="""RTN"",""PSOSPML2"",132,0)"
^XMB(3.9,145989,2,1474,0)=" ; If exporting manually (web upload), update export fields (assumes user will upload file)"
^XMB(3.9,145989,2,1475,0)="""RTN"",""PSOSPML2"",133,0)"
^XMB(3.9,145989,2,1476,0)=" I MODE=""EXPORT"",$$GET1^DIQ(58.42,BATCHIEN,2,""I"")=""VD"",'PSOTXRTS D"
^XMB(3.9,145989,2,1477,0)="""RTN"",""PSOSPML2"",134,0)"
^XMB(3.9,145989,2,1478,0)=" . D ^%ZISC N DIE,DA,DR S DIE=""^PS(58.42,"",DA=BATCHIEN"
^XMB(3.9,145989,2,1479,0)="""RTN"",""PSOSPML2"",135,0)"
^XMB(3.9,145989,2,1480,0)=" . S DR=""6///<Manual Web Upload>;7////""_DUZ_"";9///""_$$NOW^XLFDT()"
^XMB(3.9,145989,2,1481,0)="""RTN"",""PSOSPML2"",136,0)"
^XMB(3.9,145989,2,1482,0)=" . D ^DIE"
^XMB(3.9,145989,2,1483,0)="""RTN"",""PSOSPML2"",137,0)"
^XMB(3.9,145989,2,1484,0)=" ;"
^XMB(3.9,145989,2,1485,0)="""RTN"",""PSOSPML2"",138,0)"
^XMB(3.9,145989,2,1486,0)=" K DIR S DIR(""A"")=""Press Return to continue"",DIR(0)=""E"" D ^DIR"
^XMB(3.9,145989,2,1487,0)="""RTN"",""PSOSPML2"",139,0)"
^XMB(3.9,145989,2,1488,0)=" D HDR"
^XMB(3.9,145989,2,1489,0)="""RTN"",""PSOSPML2"",140,0)"
^XMB(3.9,145989,2,1490,0)=" Q"
^XMB(3.9,145989,2,1491,0)="""RTN"",""PSOSPML2"",141,0)"
^XMB(3.9,145989,2,1492,0)=" ;"
^XMB(3.9,145989,2,1493,0)="""RTN"",""PSOSPML2"",142,0)"
^XMB(3.9,145989,2,1494,0)="EXIT ;"
^XMB(3.9,145989,2,1495,0)="""RTN"",""PSOSPML2"",143,0)"
^XMB(3.9,145989,2,1496,0)=" K ^TMP(""PSOSPML2"",$J)"
^XMB(3.9,145989,2,1497,0)="""RTN"",""PSOSPML2"",144,0)"
^XMB(3.9,145989,2,1498,0)=" Q"
^XMB(3.9,145989,2,1499,0)="""RTN"",""PSOSPML2"",145,0)"
^XMB(3.9,145989,2,1500,0)=" ;"
^XMB(3.9,145989,2,1501,0)="""RTN"",""PSOSPML2"",146,0)"
^XMB(3.9,145989,2,1502,0)="HELP ; Listman HELP entry-point"
^XMB(3.9,145989,2,1503,0)="""RTN"",""PSOSPML2"",147,0)"
^XMB(3.9,145989,2,1504,0)=" Q"
^XMB(3.9,145989,2,1505,0)="""RTN"",""PSOSPML2"",148,0)"
^XMB(3.9,145989,2,1506,0)=" ;"
^XMB(3.9,145989,2,1507,0)="""RTN"",""PSOSPML2"",149,0)"
^XMB(3.9,145989,2,1508,0)="EXMSG(RTSONLY) ;"
^XMB(3.9,145989,2,1509,0)="""RTN"",""PSOSPML2"",150,0)"
^XMB(3.9,145989,2,1510,0)=" W !!?5,""Before continuing, set up your terminal to capture the ASAP"""
^XMB(3.9,145989,2,1511,0)="""RTN"",""PSOSPML2"",151,0)"
^XMB(3.9,145989,2,1512,0)=" W !?5,""formatted data. On some terminals, this can be done by clicking"""
^XMB(3.9,145989,2,1513,0)="""RTN"",""PSOSPML2"",152,0)"
^XMB(3.9,145989,2,1514,0)=" W !?5,""on the 'File' menu above, then click on 'Logging...' and check"""
^XMB(3.9,145989,2,1515,0)="""RTN"",""PSOSPML2"",153,0)"
^XMB(3.9,145989,2,1516,0)=" W !?5,""'Logging on' and 'Disk'."""
^XMB(3.9,145989,2,1517,0)="""RTN"",""PSOSPML2"",154,0)"
^XMB(3.9,145989,2,1518,0)=" W !!?5,""Note: To avoid undesired wrapping of the data saved to the"""
^XMB(3.9,145989,2,1519,0)="""RTN"",""PSOSPML2"",155,0)"
^XMB(3.9,145989,2,1520,0)=" W !?5,""      file, please enter '0;256;9999' at the 'DEVICE:' prompt."""
^XMB(3.9,145989,2,1521,0)="""RTN"",""PSOSPML2"",156,0)"
^XMB(3.9,145989,2,1522,0)=" I '$G(RTSONLY) Q"
^XMB(3.9,145989,2,1523,0)="""RTN"",""PSOSPML2"",157,0)"
^XMB(3.9,145989,2,1524,0)=" W !!?5,""*********************** IMPORTANT ******************************"""
^XMB(3.9,145989,2,1525,0)="""RTN"",""PSOSPML2"",158,0)"
^XMB(3.9,145989,2,1526,0)=" W !?5,""When you upload this file to the state website, make sure to"""
^XMB(3.9,145989,2,1527,0)="""RTN"",""PSOSPML2"",159,0)"
^XMB(3.9,145989,2,1528,0)=" W !?5,""select the correct import option, usually called """"Back Records"""
^XMB(3.9,145989,2,1529,0)="""RTN"",""PSOSPML2"",160,0)"
^XMB(3.9,145989,2,1530,0)=" W !?5,""Out of the System"""", to avoid reporting duplicate records for the"""
^XMB(3.9,145989,2,1531,0)="""RTN"",""PSOSPML2"",161,0)"
^XMB(3.9,145989,2,1532,0)=" W !?5,""patients."""
^XMB(3.9,145989,2,1533,0)="""RTN"",""PSOSPML2"",162,0)"
^XMB(3.9,145989,2,1534,0)=" W !?5,""*****************************************************************"""
^XMB(3.9,145989,2,1535,0)="""RTN"",""PSOSPML2"",163,0)"
^XMB(3.9,145989,2,1536,0)=" Q"
^XMB(3.9,145989,2,1537,0)="""RTN"",""PSOSPML2"",164,0)"
^XMB(3.9,145989,2,1538,0)=" ;"
^XMB(3.9,145989,2,1539,0)="""RTN"",""PSOSPML2"",165,0)"
^XMB(3.9,145989,2,1540,0)="RMHELP ; Running Mode Help Text"
^XMB(3.9,145989,2,1541,0)="""RTN"",""PSOSPML2"",166,0)"
^XMB(3.9,145989,2,1542,0)=" W !!?5,""Choose one of the following transmission modes:"""
^XMB(3.9,145989,2,1543,0)="""RTN"",""PSOSPML2"",167,0)"
^XMB(3.9,145989,2,1544,0)=" W !!?5,""Background: Transmission runs in the background via Taskman. This option"""
^XMB(3.9,145989,2,1545,0)="""RTN"",""PSOSPML2"",168,0)"
^XMB(3.9,145989,2,1546,0)=" W !?5,""            will help you simulate the same transmission mode used by the"""
^XMB(3.9,145989,2,1547,0)="""RTN"",""PSOSPML2"",169,0)"
^XMB(3.9,145989,2,1548,0)=" W !?5,""            Scheduled Nightly Transmissions."""
^XMB(3.9,145989,2,1549,0)="""RTN"",""PSOSPML2"",170,0)"
^XMB(3.9,145989,2,1550,0)=" W !!?5,""Foreground: Transmission runs and displays the steps to your terminal"""
^XMB(3.9,145989,2,1551,0)="""RTN"",""PSOSPML2"",171,0)"
^XMB(3.9,145989,2,1552,0)=" W !?5,""            screen."""
^XMB(3.9,145989,2,1553,0)="""RTN"",""PSOSPML2"",172,0)"
^XMB(3.9,145989,2,1554,0)=" W !!?5,""Debug Mode: This is similar to the Foreground mode. The difference is"""
^XMB(3.9,145989,2,1555,0)="""RTN"",""PSOSPML2"",173,0)"
^XMB(3.9,145989,2,1556,0)=" W !?5,""            that the sFTP command used to transfer the file will be run"""
^XMB(3.9,145989,2,1557,0)="""RTN"",""PSOSPML2"",174,0)"
^XMB(3.9,145989,2,1558,0)=" W !?5,""            in 'debug mode'. This option is useful when troubleshooting"""
^XMB(3.9,145989,2,1559,0)="""RTN"",""PSOSPML2"",175,0)"
^XMB(3.9,145989,2,1560,0)=" W !?5,""            transmission problems."""
^XMB(3.9,145989,2,1561,0)="""RTN"",""PSOSPML2"",176,0)"
^XMB(3.9,145989,2,1562,0)=" Q"
^XMB(3.9,145989,2,1563,0)="""RTN"",""PSOSPML2"",177,0)"
^XMB(3.9,145989,2,1564,0)=" ;"
^XMB(3.9,145989,2,1565,0)="""RTN"",""PSOSPML2"",178,0)"
^XMB(3.9,145989,2,1566,0)="DBUG(BATCH) ; flush and debug reason prompt"
^XMB(3.9,145989,2,1567,0)="""RTN"",""PSOSPML2"",179,0)"
^XMB(3.9,145989,2,1568,0)=" I '$D(^XUSEC(""PSO SPMP ADMIN"",DUZ)) S FLUSH=0 Q"
^XMB(3.9,145989,2,1569,0)="""RTN"",""PSOSPML2"",180,0)"
^XMB(3.9,145989,2,1570,0)=" S FLUSH=0"
^XMB(3.9,145989,2,1571,0)="""RTN"",""PSOSPML2"",181,0)"
^XMB(3.9,145989,2,1572,0)=" K DIRUT,DUOUT,DIR"
^XMB(3.9,145989,2,1573,0)="""RTN"",""PSOSPML2"",182,0)"
^XMB(3.9,145989,2,1574,0)=" W ! S DIR(""A"")=""Do you want to flush the known hosts key"",DIR(0)=""Y"",DIR(""B"")=""N"""
^XMB(3.9,145989,2,1575,0)="""RTN"",""PSOSPML2"",183,0)"
^XMB(3.9,145989,2,1576,0)=" D ^DIR I $G(DTOUT)!$G(DUOUT) S QUIT=1 Q"
^XMB(3.9,145989,2,1577,0)="""RTN"",""PSOSPML2"",184,0)"
^XMB(3.9,145989,2,1578,0)=" S FLUSH=$S(Y:1,1:0) I 'FLUSH S NEWR=""<blank>"" D F102 Q"
^XMB(3.9,145989,2,1579,0)="""RTN"",""PSOSPML2"",185,0)"
^XMB(3.9,145989,2,1580,0)=" W ! K DIRUT,DUOUT,DIR"
^XMB(3.9,145989,2,1581,0)="""RTN"",""PSOSPML2"",186,0)"
^XMB(3.9,145989,2,1582,0)=" N DIR,DIC,DA,X,Y,DLAYGO,DO,DD"
^XMB(3.9,145989,2,1583,0)="""RTN"",""PSOSPML2"",187,0)"
^XMB(3.9,145989,2,1584,0)="RD S DIR(""A"")=""Reason for Debug"",DIR(0)=""58.42102,.01"" D ^DIR K DIR I $D(DTOUT)!$D(DUOUT) S QUIT=1 Q"
^XMB(3.9,145989,2,1585,0)="""RTN"",""PSOSPML2"",188,0)"
^XMB(3.9,145989,2,1586,0)=" I Y="""" W !,$C(7),""This is a required response. Enter '^' to exit"" G RD"
^XMB(3.9,145989,2,1587,0)="""RTN"",""PSOSPML2"",189,0)"
^XMB(3.9,145989,2,1588,0)=" S NEWR=Y"
^XMB(3.9,145989,2,1589,0)="""RTN"",""PSOSPML2"",190,0)"
^XMB(3.9,145989,2,1590,0)=" W !"
^XMB(3.9,145989,2,1591,0)="""RTN"",""PSOSPML2"",191,0)"
^XMB(3.9,145989,2,1592,0)="F102 ; add new entry in the DEBUG REASON field #102"
^XMB(3.9,145989,2,1593,0)="""RTN"",""PSOSPML2"",192,0)"
^XMB(3.9,145989,2,1594,0)=" S DLAYGO=58.42102,DIC(0)=""L"",X=NEWR,DA(1)=BATCHIEN,DIC=""^PS(58.42,""_BATCHIEN_"",""""DR"""","",DIC(""DR"")=""1////""_DUZ_"";3///""_$$NOW^XLFDT()"
^XMB(3.9,145989,2,1595,0)="""RTN"",""PSOSPML2"",193,0)"
^XMB(3.9,145989,2,1596,0)=" D FILE^DICN K DIC,DLAYGO"
^XMB(3.9,145989,2,1597,0)="""RTN"",""PSOSPML2"",194,0)"
^XMB(3.9,145989,2,1598,0)=" W !"
^XMB(3.9,145989,2,1599,0)="""RTN"",""PSOSPML2"",195,0)"
^XMB(3.9,145989,2,1600,0)=" Q"
^XMB(3.9,145989,2,1601,0)="""RTN"",""PSOSPML3"")"
^XMB(3.9,145989,2,1602,0)="0^3^B69444134"
^XMB(3.9,145989,2,1603,0)="""RTN"",""PSOSPML3"",1,0)"
^XMB(3.9,145989,2,1604,0)="PSOSPML3 ;BIRM/MFR - ASAP Definitions Listman Driver ;09/01/12"
^XMB(3.9,145989,2,1605,0)="""RTN"",""PSOSPML3"",2,0)"
^XMB(3.9,145989,2,1606,0)=" ;;7.0;OUTPATIENT PHARMACY;**408,451,625,772**;DEC 1997;Build 0"
^XMB(3.9,145989,2,1607,0)="""RTN"",""PSOSPML3"",3,0)"
^XMB(3.9,145989,2,1608,0)=" ;"
^XMB(3.9,145989,2,1609,0)="""RTN"",""PSOSPML3"",4,0)"
^XMB(3.9,145989,2,1610,0)=" N ASAPVER,VERLST,DIR,DIRUT,DTOUT,X,Y,DIC,VALM,VALMBG,VALMCNT,VALMHDR,VALMBCK,VALMSG,PSOLSTLN"
^XMB(3.9,145989,2,1611,0)="""RTN"",""PSOSPML3"",5,0)"
^XMB(3.9,145989,2,1612,0)=" ;"
^XMB(3.9,145989,2,1613,0)="""RTN"",""PSOSPML3"",6,0)"
^XMB(3.9,145989,2,1614,0)="VER ; ASAP Version Prompt"
^XMB(3.9,145989,2,1615,0)="""RTN"",""PSOSPML3"",7,0)"
^XMB(3.9,145989,2,1616,0)=" W ! S ASAPVER=$$ASAPVER^PSOSPMU2(""A"",""B"",1) I ASAPVER[""^""!(ASAPVER="""") G EXIT    ;adding ""B"" for Zero Report"
^XMB(3.9,145989,2,1617,0)="""RTN"",""PSOSPML3"",8,0)"
^XMB(3.9,145989,2,1618,0)=" ;"
^XMB(3.9,145989,2,1619,0)="""RTN"",""PSOSPML3"",9,0)"
^XMB(3.9,145989,2,1620,0)=" D EN(ASAPVER,0)"
^XMB(3.9,145989,2,1621,0)="""RTN"",""PSOSPML3"",10,0)"
^XMB(3.9,145989,2,1622,0)=" ;"
^XMB(3.9,145989,2,1623,0)="""RTN"",""PSOSPML3"",11,0)"
^XMB(3.9,145989,2,1624,0)=" G VER"
^XMB(3.9,145989,2,1625,0)="""RTN"",""PSOSPML3"",12,0)"
^XMB(3.9,145989,2,1626,0)=" ;"
^XMB(3.9,145989,2,1627,0)="""RTN"",""PSOSPML3"",13,0)"
^XMB(3.9,145989,2,1628,0)="EN(PSOASVER,PSOSHOW) ; Entry point"
^XMB(3.9,145989,2,1629,0)="""RTN"",""PSOSPML3"",14,0)"
^XMB(3.9,145989,2,1630,0)=" ;Input: (r) PSOASVER - ASAP Version (""3.0"", ""4.0"", etc.)"
^XMB(3.9,145989,2,1631,0)="""RTN"",""PSOSPML3"",15,0)"
^XMB(3.9,145989,2,1632,0)=" ;       (o) PSOSHOW  - 0: Segments Only"
^XMB(3.9,145989,2,1633,0)="""RTN"",""PSOSPML3"",16,0)"
^XMB(3.9,145989,2,1634,0)=" ;                      1: Segments & Data Elements (ID and Name Only)"
^XMB(3.9,145989,2,1635,0)="""RTN"",""PSOSPML3"",17,0)"
^XMB(3.9,145989,2,1636,0)=" ;                      2: Segments & Data Elements (All Details)"
^XMB(3.9,145989,2,1637,0)="""RTN"",""PSOSPML3"",18,0)"
^XMB(3.9,145989,2,1638,0)=" N ASAP"
^XMB(3.9,145989,2,1639,0)="""RTN"",""PSOSPML3"",19,0)"
^XMB(3.9,145989,2,1640,0)=" S PSOSHOW=+$G(PSOSHOW)"
^XMB(3.9,145989,2,1641,0)="""RTN"",""PSOSPML3"",20,0)"
^XMB(3.9,145989,2,1642,0)=" D EN^VALM(""PSO SPMP VIEW ASAP DEFINITION"")"
^XMB(3.9,145989,2,1643,0)="""RTN"",""PSOSPML3"",21,0)"
^XMB(3.9,145989,2,1644,0)=" D FULL^VALM1"
^XMB(3.9,145989,2,1645,0)="""RTN"",""PSOSPML3"",22,0)"
^XMB(3.9,145989,2,1646,0)=" Q"
^XMB(3.9,145989,2,1647,0)="""RTN"",""PSOSPML3"",23,0)"
^XMB(3.9,145989,2,1648,0)=" ;"
^XMB(3.9,145989,2,1649,0)="""RTN"",""PSOSPML3"",24,0)"
^XMB(3.9,145989,2,1650,0)="HDR ; - Builds the Header section"
^XMB(3.9,145989,2,1651,0)="""RTN"",""PSOSPML3"",25,0)"
^XMB(3.9,145989,2,1652,0)=" N STDIEN,VERIEN,HDR,ELMDELIM,SEGTERM,EOSCHR,STDVDLMS,ALLVDLMS,CLONE,HDRLINE,HDR   ; PSO*7*772 CLONE"
^XMB(3.9,145989,2,1653,0)="""RTN"",""PSOSPML3"",26,0)"
^XMB(3.9,145989,2,1654,0)=" S STDVDLMS=$$VERDATA^PSOSPMU0(PSOASVER,""S"")"
^XMB(3.9,145989,2,1655,0)="""RTN"",""PSOSPML3"",27,0)"
^XMB(3.9,145989,2,1656,0)=" S ALLVDLMS=$$VERDATA^PSOSPMU0(PSOASVER,""B"")"
^XMB(3.9,145989,2,1657,0)="""RTN"",""PSOSPML3"",28,0)"
^XMB(3.9,145989,2,1658,0)=" S STDIEN=$O(^PS(58.4,""B"",""STANDARD ASAP DEFINITION"",0))"
^XMB(3.9,145989,2,1659,0)="""RTN"",""PSOSPML3"",29,0)"
^XMB(3.9,145989,2,1660,0)=" S VERIEN=$O(^PS(58.4,STDIEN,""VER"",""B"",PSOASVER,0))"
^XMB(3.9,145989,2,1661,0)="""RTN"",""PSOSPML3"",30,0)"
^XMB(3.9,145989,2,1662,0)=" S CLONE=$P(STDVDLMS,""^"",6),HDRLINE=1     ; PSO*7*772 - Cloned ASAP Version"
^XMB(3.9,145989,2,1663,0)="""RTN"",""PSOSPML3"",31,0)"
^XMB(3.9,145989,2,1664,0)=" S VALM(""TITLE"")="" ASAP ""_$S('VERIEN!$L(CLONE):""Custom"",1:""Standard"")_"" Ver ""_PSOASVER_$S('VERIEN!$L(CLONE):""*"",1:"""")   ; PSO*7*772 Cloned ASAP Version"
^XMB(3.9,145989,2,1665,0)="""RTN"",""PSOSPML3"",32,0)"
^XMB(3.9,145989,2,1666,0)=" S ELMDELIM=$S(PSOASVER=""1995"":""N/A"",1:$P(ALLVDLMS,""^"",2))"
^XMB(3.9,145989,2,1667,0)="""RTN"",""PSOSPML3"",33,0)"
^XMB(3.9,145989,2,1668,0)=" S HDR(HDRLINE)=""Copied From ASAP Version: ""_$S($L(CLONE):CLONE,1:""N/A"") D INSTR^VALM1(HDR(HDRLINE),2,HDRLINE+1) S HDRLINE=HDRLINE+1    ; PSO*7*772 Cloned ASAP Version"
^XMB(3.9,145989,2,1669,0)="""RTN"",""PSOSPML3"",34,0)"
^XMB(3.9,145989,2,1670,0)=" S HDR(HDRLINE)=""Element Delimiter""_$S(($P(STDVDLMS,""^"",2)'=""""&($P(STDVDLMS,""^"",2)'=$P(ALLVDLMS,""^"",2))):""*"",1:"""")_"":""_IOINHI_$S(ELMDELIM="""":""<NULL>"",1:"" ""_ELMDELIM)_IOINORM"
^XMB(3.9,145989,2,1671,0)="""RTN"",""PSOSPML3"",35,0)"
^XMB(3.9,145989,2,1672,0)=" S SEGTERM=$S(PSOASVER=""1995"":""N/A"",1:$P(ALLVDLMS,""^"",3))"
^XMB(3.9,145989,2,1673,0)="""RTN"",""PSOSPML3"",36,0)"
^XMB(3.9,145989,2,1674,0)=" S HDR(HDRLINE)=HDR(HDRLINE)_""  Segment Terminator""_$S(($P(STDVDLMS,""^"",3)'=""""&($P(STDVDLMS,""^"",3)'=$P(ALLVDLMS,""^"",3))):""*"",1:"""")_"":""_IOINHI_$S(SEGTERM="""":""<NULL>"",1:"" ""_SEGTERM)_IOINORM    ; PSO*7*772 - Denote delimiter customization"
^XMB(3.9,145989,2,1675,0)="""RTN"",""PSOSPML3"",37,0)"
^XMB(3.9,145989,2,1676,0)=" S EOSCHR=$S(PSOASVER=""1995"":""$C(10,13)"",1:$P(ALLVDLMS,""^"",4))"
^XMB(3.9,145989,2,1677,0)="""RTN"",""PSOSPML3"",38,0)"
^XMB(3.9,145989,2,1678,0)=" S HDR(HDRLINE)=HDR(HDRLINE)_""  End Of Line ESC""_$S(($P(STDVDLMS,""^"",4)'=""""&($P(STDVDLMS,""^"",4)'=$P(ALLVDLMS,""^"",4))):""*"",1:"""")_"":""_IOINHI_$S(EOSCHR="""":""<NULL>"",1:"" ""_EOSCHR)_IOINORM"
^XMB(3.9,145989,2,1679,0)="""RTN"",""PSOSPML3"",39,0)"
^XMB(3.9,145989,2,1680,0)=" D INSTR^VALM1(HDR(HDRLINE),2,HDRLINE+1)"
^XMB(3.9,145989,2,1681,0)="""RTN"",""PSOSPML3"",40,0)"
^XMB(3.9,145989,2,1682,0)=" Q"
^XMB(3.9,145989,2,1683,0)="""RTN"",""PSOSPML3"",41,0)"
^XMB(3.9,145989,2,1684,0)=" ;"
^XMB(3.9,145989,2,1685,0)="""RTN"",""PSOSPML3"",42,0)"
^XMB(3.9,145989,2,1686,0)="INIT ; Builds the Body section"
^XMB(3.9,145989,2,1687,0)="""RTN"",""PSOSPML3"",43,0)"
^XMB(3.9,145989,2,1688,0)=" N ASAP,LINE,I"
^XMB(3.9,145989,2,1689,0)="""RTN"",""PSOSPML3"",44,0)"
^XMB(3.9,145989,2,1690,0)=" ;"
^XMB(3.9,145989,2,1691,0)="""RTN"",""PSOSPML3"",45,0)"
^XMB(3.9,145989,2,1692,0)=" K ^TMP(""PSOSPML3"",$J) S VALMCNT=0,LINE=0"
^XMB(3.9,145989,2,1693,0)="""RTN"",""PSOSPML3"",46,0)"
^XMB(3.9,145989,2,1694,0)=" F I=1:1:1000 D RESTORE^VALM10(I)"
^XMB(3.9,145989,2,1695,0)="""RTN"",""PSOSPML3"",47,0)"
^XMB(3.9,145989,2,1696,0)=" I PSOASVER=""1995"" D"
^XMB(3.9,145989,2,1697,0)="""RTN"",""PSOSPML3"",48,0)"
^XMB(3.9,145989,2,1698,0)=" . D SETSEG95^PSOSPML4(""PSOSPML3"","""") S VALMCNT=LINE"
^XMB(3.9,145989,2,1699,0)="""RTN"",""PSOSPML3"",49,0)"
^XMB(3.9,145989,2,1700,0)=" I PSOASVER'=""1995"" D"
^XMB(3.9,145989,2,1701,0)="""RTN"",""PSOSPML3"",50,0)"
^XMB(3.9,145989,2,1702,0)=" . D LOADASAP^PSOSPMU0(PSOASVER,""B"",.ASAP)"
^XMB(3.9,145989,2,1703,0)="""RTN"",""PSOSPML3"",51,0)"
^XMB(3.9,145989,2,1704,0)=" . D SETSEG(""ASAP"",0) S VALMCNT=LINE"
^XMB(3.9,145989,2,1705,0)="""RTN"",""PSOSPML3"",52,0)"
^XMB(3.9,145989,2,1706,0)=" . S VALMSG=""Enter ?? for more actions|* Custom Segment/Element"""
^XMB(3.9,145989,2,1707,0)="""RTN"",""PSOSPML3"",53,0)"
^XMB(3.9,145989,2,1708,0)=" Q"
^XMB(3.9,145989,2,1709,0)="""RTN"",""PSOSPML3"",54,0)"
^XMB(3.9,145989,2,1710,0)=" ;"
^XMB(3.9,145989,2,1711,0)="""RTN"",""PSOSPML3"",55,0)"
^XMB(3.9,145989,2,1712,0)=" ; Note: Recursivity used because of the 'Tree' nature of the ASAP definition"
^XMB(3.9,145989,2,1713,0)="""RTN"",""PSOSPML3"",56,0)"
^XMB(3.9,145989,2,1714,0)="SETSEG(ARRNAM,LEVEL) ; Set list content with the Segment info"
^XMB(3.9,145989,2,1715,0)="""RTN"",""PSOSPML3"",57,0)"
^XMB(3.9,145989,2,1716,0)=" ;Input: ARRNAM - Name of the Array containing the ASAP definition"
^XMB(3.9,145989,2,1717,0)="""RTN"",""PSOSPML3"",58,0)"
^XMB(3.9,145989,2,1718,0)=" ;       LEVEL  - Level of the Segment"
^XMB(3.9,145989,2,1719,0)="""RTN"",""PSOSPML3"",59,0)"
^XMB(3.9,145989,2,1720,0)=" N ARRAY,COLUMN,TYPE,DETLN,SEGID,JUST,I,J,ELMCNT,LSTELM,ELMNAM,MVALUE,SEGLN,LEVNAM,DESCNT,VALIDX"
^XMB(3.9,145989,2,1721,0)="""RTN"",""PSOSPML3"",60,0)"
^XMB(3.9,145989,2,1722,0)=" ;"
^XMB(3.9,145989,2,1723,0)="""RTN"",""PSOSPML3"",61,0)"
^XMB(3.9,145989,2,1724,0)=" S PSOSHOW=+$G(PSOSHOW)"
^XMB(3.9,145989,2,1725,0)="""RTN"",""PSOSPML3"",62,0)"
^XMB(3.9,145989,2,1726,0)=" S ARRAY=$Q(@ARRNAM) I '+$P(ARRAY,""("",2) Q"
^XMB(3.9,145989,2,1727,0)="""RTN"",""PSOSPML3"",63,0)"
^XMB(3.9,145989,2,1728,0)=" S SEGID=$P(@ARRAY,""^""),COLUMN=(($L(ARRAY,"","")-1)*4)"
^XMB(3.9,145989,2,1729,0)="""RTN"",""PSOSPML3"",64,0)"
^XMB(3.9,145989,2,1730,0)=" S JUST="""" S:PSOSHOW'=2 JUST=$J("""",COLUMN)"
^XMB(3.9,145989,2,1731,0)="""RTN"",""PSOSPML3"",65,0)"
^XMB(3.9,145989,2,1732,0)=" I LEVEL'=$P(ASAP(SEGID),""^"",6) D"
^XMB(3.9,145989,2,1733,0)="""RTN"",""PSOSPML3"",66,0)"
^XMB(3.9,145989,2,1734,0)=" . S LEVEL=$P(ASAP(SEGID),""^"",6)"
^XMB(3.9,145989,2,1735,0)="""RTN"",""PSOSPML3"",67,0)"
^XMB(3.9,145989,2,1736,0)=" . S LEVNAM=$P(""MAIN HEADER^PHARMACY HEADER^PATIENT DETAIL^PRESCRIPTION DETAIL^PHARMACY TRAILER^MAIN TRAILER"",""^"",LEVEL)"
^XMB(3.9,145989,2,1737,0)="""RTN"",""PSOSPML3"",68,0)"
^XMB(3.9,145989,2,1738,0)=" . D SETLN^PSOSPMU1(""PSOSPML3"",JUST_LEVNAM,0,0,0)"
^XMB(3.9,145989,2,1739,0)="""RTN"",""PSOSPML3"",69,0)"
^XMB(3.9,145989,2,1740,0)=" . D CNTRL^VALM10(LINE,$L(JUST)+1,$L(LEVNAM),IORVON,IORVOFF_IOINORM)"
^XMB(3.9,145989,2,1741,0)="""RTN"",""PSOSPML3"",70,0)"
^XMB(3.9,145989,2,1742,0)=" S SEGLN=JUST_$P(ASAP(SEGID),""^"")_$S($$CUSSEG^PSOSPMU3(PSOASVER,SEGID):""*"",1:"""")_"" - ""_$P(ASAP(SEGID),""^"",2)_$S($P(ASAP(SEGID),""^"",4)=""N"":"" (Not Used)"",1:"""")"
^XMB(3.9,145989,2,1743,0)="""RTN"",""PSOSPML3"",71,0)"
^XMB(3.9,145989,2,1744,0)=" D SETLN^PSOSPMU1(""PSOSPML3"",SEGLN,0,$S(PSOSHOW'=0:1,1:0),$S($P(ASAP(SEGID),""^"",4)=""N"":0,1:1))"
^XMB(3.9,145989,2,1745,0)="""RTN"",""PSOSPML3"",72,0)"
^XMB(3.9,145989,2,1746,0)=" S LSTELM=+$O(ASAP(SEGID,""""),-1)"
^XMB(3.9,145989,2,1747,0)="""RTN"",""PSOSPML3"",73,0)"
^XMB(3.9,145989,2,1748,0)=" I PSOSHOW'=0 D"
^XMB(3.9,145989,2,1749,0)="""RTN"",""PSOSPML3"",74,0)"
^XMB(3.9,145989,2,1750,0)=" . F ELMCNT=1:1:LSTELM D"
^XMB(3.9,145989,2,1751,0)="""RTN"",""PSOSPML3"",75,0)"
^XMB(3.9,145989,2,1752,0)=" . . S:PSOSHOW=1 JUST=$J("""",COLUMN+$L(SEGID)+1)"
^XMB(3.9,145989,2,1753,0)="""RTN"",""PSOSPML3"",76,0)"
^XMB(3.9,145989,2,1754,0)=" . . S ELMNAM=JUST_$P(ASAP(SEGID,ELMCNT),""^"")_$S($G(ASAP(SEGID,ELMCNT,""CUS"")):""*"",1:"""")_"" - ""_$P(ASAP(SEGID,ELMCNT),""^"",2)"
^XMB(3.9,145989,2,1755,0)="""RTN"",""PSOSPML3"",77,0)"
^XMB(3.9,145989,2,1756,0)=" . . S ELMNAM=ELMNAM_$S((PSOSHOW=1)&($P(ASAP(SEGID,ELMCNT),""^"",6)=""N""):"" (Not Used)"",1:"""")"
^XMB(3.9,145989,2,1757,0)="""RTN"",""PSOSPML3"",78,0)"
^XMB(3.9,145989,2,1758,0)=" . . D SETLN^PSOSPMU1(""PSOSPML3"",ELMNAM,0,0,$S((PSOSHOW=1)&($P(ASAP(SEGID,ELMCNT),""^"",6)=""N""):0,1:1))"
^XMB(3.9,145989,2,1759,0)="""RTN"",""PSOSPML3"",79,0)"
^XMB(3.9,145989,2,1760,0)=" . . I PSOSHOW=1 Q"
^XMB(3.9,145989,2,1761,0)="""RTN"",""PSOSPML3"",80,0)"
^XMB(3.9,145989,2,1762,0)=" . . S DETLN=JUST_""Requirement: ""_$S($P(ASAP(SEGID,ELMCNT),""^"",6)=""R"":""Required"",$P(ASAP(SEGID,ELMCNT),""^"",6)=""O"":""Optional"",$P(ASAP(SEGID,ELMCNT),""^"",6)=""N"":""Not Used"",1:"""")"
^XMB(3.9,145989,2,1763,0)="""RTN"",""PSOSPML3"",81,0)"
^XMB(3.9,145989,2,1764,0)=" . . S TYPE=$P(ASAP(SEGID,ELMCNT),""^"",3)"
^XMB(3.9,145989,2,1765,0)="""RTN"",""PSOSPML3"",82,0)"
^XMB(3.9,145989,2,1766,0)=" . . S $E(DETLN,33)=""Format: ""_$S(TYPE=""AN"":""Alphanumeric"",TYPE=""N"":""Numeric"",TYPE=""D"":""Decimal"",TYPE=""DT"":""Date (YYYYMMDD)"",TYPE=""TM"":""Time (HHMMSS or HHMM)"",1:"""")"
^XMB(3.9,145989,2,1767,0)="""RTN"",""PSOSPML3"",83,0)"
^XMB(3.9,145989,2,1768,0)=" . . S $E(DETLN,62)=""Maximum Length: ""_$P(ASAP(SEGID,ELMCNT),""^"",4)"
^XMB(3.9,145989,2,1769,0)="""RTN"",""PSOSPML3"",84,0)"
^XMB(3.9,145989,2,1770,0)=" . . D SETLN^PSOSPMU1(""PSOSPML3"",DETLN)"
^XMB(3.9,145989,2,1771,0)="""RTN"",""PSOSPML3"",85,0)"
^XMB(3.9,145989,2,1772,0)=" . . ; Highlighting fields Requirement, Format and Length"
^XMB(3.9,145989,2,1773,0)="""RTN"",""PSOSPML3"",86,0)"
^XMB(3.9,145989,2,1774,0)=" . . D CNTRL^VALM10(LINE,13,10,IOINHI,IOINORM)"
^XMB(3.9,145989,2,1775,0)="""RTN"",""PSOSPML3"",87,0)"
^XMB(3.9,145989,2,1776,0)=" . . D CNTRL^VALM10(LINE,41,20,IOINHI,IOINORM)"
^XMB(3.9,145989,2,1777,0)="""RTN"",""PSOSPML3"",88,0)"
^XMB(3.9,145989,2,1778,0)=" . . D CNTRL^VALM10(LINE,77,5,IOINHI,IOINORM)"
^XMB(3.9,145989,2,1779,0)="""RTN"",""PSOSPML3"",89,0)"
^XMB(3.9,145989,2,1780,0)=" . . F DESCNT=1:1 Q:'$D(ASAP(SEGID,ELMCNT,""DES"",DESCNT))  D"
^XMB(3.9,145989,2,1781,0)="""RTN"",""PSOSPML3"",90,0)"
^XMB(3.9,145989,2,1782,0)=" . . . D SETLN^PSOSPMU1(""PSOSPML3"",JUST_ASAP(SEGID,ELMCNT,""DES"",DESCNT))"
^XMB(3.9,145989,2,1783,0)="""RTN"",""PSOSPML3"",91,0)"
^XMB(3.9,145989,2,1784,0)=" . . ; Field M Expression Value"
^XMB(3.9,145989,2,1785,0)="""RTN"",""PSOSPML3"",92,0)"
^XMB(3.9,145989,2,1786,0)=" . . S DETLN=""Value: "",MVALUE="""""
^XMB(3.9,145989,2,1787,0)="""RTN"",""PSOSPML3"",93,0)"
^XMB(3.9,145989,2,1788,0)=" . . F VALIDX=1:1 Q:'$D(ASAP(SEGID,ELMCNT,""VAL"",VALIDX))  D"
^XMB(3.9,145989,2,1789,0)="""RTN"",""PSOSPML3"",94,0)"
^XMB(3.9,145989,2,1790,0)=" . . . S MVALUE=MVALUE_ASAP(SEGID,ELMCNT,""VAL"",VALIDX)"
^XMB(3.9,145989,2,1791,0)="""RTN"",""PSOSPML3"",95,0)"
^XMB(3.9,145989,2,1792,0)=" . . F  Q:MVALUE=""""  D"
^XMB(3.9,145989,2,1793,0)="""RTN"",""PSOSPML3"",96,0)"
^XMB(3.9,145989,2,1794,0)=" . . . S $E(DETLN,8)=$E(MVALUE,1,72)"
^XMB(3.9,145989,2,1795,0)="""RTN"",""PSOSPML3"",97,0)"
^XMB(3.9,145989,2,1796,0)=" . . . D SETLN^PSOSPMU1(""PSOSPML3"",DETLN)"
^XMB(3.9,145989,2,1797,0)="""RTN"",""PSOSPML3"",98,0)"
^XMB(3.9,145989,2,1798,0)=" . . . D CNTRL^VALM10(LINE,8,72,IOINHI,IOINORM)"
^XMB(3.9,145989,2,1799,0)="""RTN"",""PSOSPML3"",99,0)"
^XMB(3.9,145989,2,1800,0)=" . . . S DETLN="""",MVALUE=$E(MVALUE,73,999)"
^XMB(3.9,145989,2,1801,0)="""RTN"",""PSOSPML3"",100,0)"
^XMB(3.9,145989,2,1802,0)=" . . D SETLN^PSOSPMU1(""PSOSPML3"","" "")"
^XMB(3.9,145989,2,1803,0)="""RTN"",""PSOSPML3"",101,0)"
^XMB(3.9,145989,2,1804,0)=" D SETSEG(ARRAY,LEVEL)"
