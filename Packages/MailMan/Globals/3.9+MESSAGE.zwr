^XMB(3.9,145980,2,5392,0)=" D VALFIELD^SDES2VALUTIL(.VAL,.ERRORS,409.84,.23,$G(APPOINTMENT(""PATIENT STATUS"")))"
^XMB(3.9,145980,2,5393,0)="""RTN"",""SDES2CREATEAPPT2"",253,0)"
^XMB(3.9,145980,2,5394,0)=" S APPOINTMENT(""PATIENT STATUS"")=$G(VAL(409.84,.23,""I""))"
^XMB(3.9,145980,2,5395,0)="""RTN"",""SDES2CREATEAPPT2"",254,0)"
^XMB(3.9,145980,2,5396,0)=" ;"
^XMB(3.9,145980,2,5397,0)="""RTN"",""SDES2CREATEAPPT2"",255,0)"
^XMB(3.9,145980,2,5398,0)=" D VALFIELD^SDES2VALUTIL(.VAL,.ERRORS,409.84,.13,$G(APPOINTMENT(""WALKIN"")),,,,178)"
^XMB(3.9,145980,2,5399,0)="""RTN"",""SDES2CREATEAPPT2"",256,0)"
^XMB(3.9,145980,2,5400,0)=" S APPOINTMENT(""WALKIN"")=$G(VAL(409.84,.13,""I""))"
^XMB(3.9,145980,2,5401,0)="""RTN"",""SDES2CREATEAPPT2"",257,0)"
^XMB(3.9,145980,2,5402,0)=" ;"
^XMB(3.9,145980,2,5403,0)="""RTN"",""SDES2CREATEAPPT2"",258,0)"
^XMB(3.9,145980,2,5404,0)=" ; Appointment already exists for patient at this date and time"
^XMB(3.9,145980,2,5405,0)="""RTN"",""SDES2CREATEAPPT2"",259,0)"
^XMB(3.9,145980,2,5406,0)=" I '$G(BLOCKANDMOVE) D"
^XMB(3.9,145980,2,5407,0)="""RTN"",""SDES2CREATEAPPT2"",260,0)"
^XMB(3.9,145980,2,5408,0)=" . S DUPDATE=$$GET1^DIQ(2.98,$G(APPOINTMENT(""START DATE TIME""))_"",""_$G(APPOINTMENT(""DFN"")),.001,""I"")"
^XMB(3.9,145980,2,5409,0)="""RTN"",""SDES2CREATEAPPT2"",261,0)"
^XMB(3.9,145980,2,5410,0)=" . S DUPSTAT="",""_$$GET1^DIQ(2.98,$G(APPOINTMENT(""START DATE TIME""))_"",""_$G(APPOINTMENT(""DFN"")),3,""I"")_"","""
^XMB(3.9,145980,2,5411,0)="""RTN"",""SDES2CREATEAPPT2"",262,0)"
^XMB(3.9,145980,2,5412,0)=" . I DUPDATE'="""",("",C,PC,""'[DUPSTAT) D ERRLOG^SDESJSON(.ERRORS,176,""Due to system limitations an appointment cannot be made at the same time in different time zones. Please add at least 1 minute to the appointment start time and try again"")"
^XMB(3.9,145980,2,5413,0)="""RTN"",""SDES2CREATEAPPT2"",263,0)"
^XMB(3.9,145980,2,5414,0)=" ;"
^XMB(3.9,145980,2,5415,0)="""RTN"",""SDES2CREATEAPPT2"",264,0)"
^XMB(3.9,145980,2,5416,0)=" I '$G(BLOCKANDMOVE) D"
^XMB(3.9,145980,2,5417,0)="""RTN"",""SDES2CREATEAPPT2"",265,0)"
^XMB(3.9,145980,2,5418,0)=" .D REQUESTTYPE^SDES2APPTUTIL(.ERRORS,.APPOINTMENT,$P($G(APPOINTMENT(""REQUEST TYPE"")),""|""),$P($G(APPOINTMENT(""REQUEST TYPE"")),""|"",2),$G(APPOINTMENT(""DFN"")))"
^XMB(3.9,145980,2,5419,0)="""RTN"",""SDES2CREATEAPPT2"",266,0)"
^XMB(3.9,145980,2,5420,0)=" D GETAPPTTYPE^SDES2APPTUTIL(.ERRORS,.APPOINTMENT,$G(APPOINTMENT(""APPOINTMENT TYPE"")),$G(APPOINTMENT(""APPOINTMENT TYPE NAME"")))"
^XMB(3.9,145980,2,5421,0)="""RTN"",""SDES2CREATEAPPT2"",267,0)"
^XMB(3.9,145980,2,5422,0)=" D GETPID^SDES2APPTUTIL(.APPOINTMENT,$G(APPOINTMENT(""PATIENT INDICATED DATE"")),$P($G(APPOINTMENT(""REQUEST TYPE"")),""|""),$P($G(APPOINTMENT(""REQUEST TYPE"")),""|"",2))"
^XMB(3.9,145980,2,5423,0)="""RTN"",""SDES2CREATEAPPT2"",268,0)"
^XMB(3.9,145980,2,5424,0)=" I $D(ERRORS) Q"
^XMB(3.9,145980,2,5425,0)="""RTN"",""SDES2CREATEAPPT2"",269,0)"
^XMB(3.9,145980,2,5426,0)=" ;"
^XMB(3.9,145980,2,5427,0)="""RTN"",""SDES2CREATEAPPT2"",270,0)"
^XMB(3.9,145980,2,5428,0)=" ;"
^XMB(3.9,145980,2,5429,0)="""RTN"",""SDES2CREATEAPPT2"",271,0)"
^XMB(3.9,145980,2,5430,0)=" D GETPROVIDER^SDES2APPTUTIL(.APPOINTMENT,$G(APPOINTMENT(""CLINIC IEN"")),$G(APPOINTMENT(""PROVIDER IEN"")),$P($G(APPOINTMENT(""REQUEST TYPE"")),""|""),$P($G(APPOINTMENT(""REQUEST TYPE"")),""|"",2))"
^XMB(3.9,145980,2,5431,0)="""RTN"",""SDES2CREATEAPPT2"",272,0)"
^XMB(3.9,145980,2,5432,0)=" D GETRESOURCE^SDES2APPTUTIL(.ERRORS,.APPOINTMENT,$G(APPOINTMENT(""CLINIC IEN"")))"
^XMB(3.9,145980,2,5433,0)="""RTN"",""SDES2CREATEAPPT2"",273,0)"
^XMB(3.9,145980,2,5434,0)=" I $$ORDERCHECKLOCK^SDES2APPTUTIL(.ERRORS,$G(APPOINTMENT(""REQUEST TYPE"")),$G(APPOINTMENT(""DFN"")))"
^XMB(3.9,145980,2,5435,0)="""RTN"",""SDES2CREATEAPPT2"",274,0)"
^XMB(3.9,145980,2,5436,0)=" I $$INACTIVE^SDESUTIL($G(APPOINTMENT(""CLINIC IEN""))) D ERRLOG^SDESJSON(.ERRORS,19)"
^XMB(3.9,145980,2,5437,0)="""RTN"",""SDES2CREATEAPPT2"",275,0)"
^XMB(3.9,145980,2,5438,0)=" I $$APPTIN44EXISTS^SDES2APPTUTIL($G(APPOINTMENT(""DFN"")),$G(APPOINTMENT(""CLINIC IEN"")),$G(APPOINTMENT(""START DATE TIME""))) D ERRLOG^SDESJSON(.ERRORS,175)"
^XMB(3.9,145980,2,5439,0)="""RTN"",""SDES2CREATEAPPT2"",276,0)"
^XMB(3.9,145980,2,5440,0)=" I '$G(BLOCKANDMOVE) D"
^XMB(3.9,145980,2,5441,0)="""RTN"",""SDES2CREATEAPPT2"",277,0)"
^XMB(3.9,145980,2,5442,0)=" .I $$APPTINDIFFTZ^SDES2APPTUTIL($G(APPOINTMENT(""DFN"")),$G(APPOINTMENT(""START DATE TIME"")),$G(APPOINTMENT(""CLINIC IEN""))) D ERRLOG^SDES2JSON(.ERRORS,570)"
^XMB(3.9,145980,2,5443,0)="""RTN"",""SDES2CREATEAPPT2"",278,0)"
^XMB(3.9,145980,2,5444,0)=" ;"
^XMB(3.9,145980,2,5445,0)="""RTN"",""SDES2CREATEAPPT2"",279,0)"
^XMB(3.9,145980,2,5446,0)=" ;"
^XMB(3.9,145980,2,5447,0)="""RTN"",""SDES2CREATEAPPT2"",280,0)"
^XMB(3.9,145980,2,5448,0)=" S CLINICDT=$P($$ISOTFM^SDAMUTDT($$FMTISO^SDAMUTDT($$NOW^XLFDT()),$G(APPOINTMENT(""CLINIC IEN""))),""."")"
^XMB(3.9,145980,2,5449,0)="""RTN"",""SDES2CREATEAPPT2"",281,0)"
^XMB(3.9,145980,2,5450,0)=" I $G(APPOINTMENT(""WALKIN""))=""y"",$P($G(APPOINTMENT(""START DATE TIME"")),""."")<CLINICDT!($P($G(APPOINTMENT(""START DATE TIME"")),""."")>CLINICDT) D ERRLOG^SDESJSON(.ERRORS,166)"
^XMB(3.9,145980,2,5451,0)="""RTN"",""SDES2CREATEAPPT2"",282,0)"
^XMB(3.9,145980,2,5452,0)=" I $$FMDIFF^XLFDT($G(APPOINTMENT(""END DATE TIME"")),$G(APPOINTMENT(""START DATE TIME"")),2)/60'=$G(APPOINTMENT(""APPOINTMENT LENGTH"")) D ERRLOG^SDESJSON(.ERRORS,116)"
