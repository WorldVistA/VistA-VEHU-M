^XMB(3.9,145986,2,586,0)="^D MENU^XPDH"
^XMB(3.9,145986,2,587,0)="""QUES"",""XPO1"",""A"")"
^XMB(3.9,145986,2,588,0)="Want KIDS to Rebuild Menu Trees Upon Completion of Install"
