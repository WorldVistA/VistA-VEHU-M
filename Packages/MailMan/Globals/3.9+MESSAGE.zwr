^XMB(3.9,145984,2,2068,0)=" . . S ERRSEQ=$$ERRSEQ^PSOERXU1(EIEN) Q:'ERRSEQ"
^XMB(3.9,145984,2,2069,0)="""RTN"",""PSOERXI1"",186,0)"
^XMB(3.9,145984,2,2070,0)=" . . D FILERR^PSOERXU1(CURREC,ERRSEQ,""PA"",""E"",ERRTXT)"
^XMB(3.9,145984,2,2071,0)="""RTN"",""PSOERXI1"",187,0)"
^XMB(3.9,145984,2,2072,0)=" ;"
^XMB(3.9,145984,2,2073,0)="""RTN"",""PSOERXI1"",188,0)"
^XMB(3.9,145984,2,2074,0)=" S RES=""1^Erx Received."""
^XMB(3.9,145984,2,2075,0)="""RTN"",""PSOERXI1"",189,0)"
^XMB(3.9,145984,2,2076,0)=" ;"
^XMB(3.9,145984,2,2077,0)="""RTN"",""PSOERXI1"",190,0)"
^XMB(3.9,145984,2,2078,0)=" ;Create an Addendum for eRx Change Response Progress Note"
^XMB(3.9,145984,2,2079,0)="""RTN"",""PSOERXI1"",191,0)"
^XMB(3.9,145984,2,2080,0)=" I $G(EIEN)'="""",$$GET1^DIQ(52.49,EIEN,.08,""I"")=""CX"" D CREATEADD(ERXHID,EIEN)"
^XMB(3.9,145984,2,2081,0)="""RTN"",""PSOERXI1"",192,0)"
^XMB(3.9,145984,2,2082,0)=" Q"
^XMB(3.9,145984,2,2083,0)="""RTN"",""PSOERXI1"",193,0)"
^XMB(3.9,145984,2,2084,0)=" ;"
^XMB(3.9,145984,2,2085,0)="""RTN"",""PSOERXI1"",194,0)"
^XMB(3.9,145984,2,2086,0)="CREATEADD(ERXHID,EIEN) ;Create CPRS Progress Notes Addendum for this eRx Change Response"
^XMB(3.9,145984,2,2087,0)="""RTN"",""PSOERXI1"",195,0)"
^XMB(3.9,145984,2,2088,0)=" ;Input: ERXHID - eRx processing hub id^CANCEL/CHANGE REQUEST DENIED BY HUB (1=YES)^relates to hub ID"
^XMB(3.9,145984,2,2089,0)="""RTN"",""PSOERXI1"",196,0)"
^XMB(3.9,145984,2,2090,0)=" ;       EIEN   - The eRx Change Response IEN, Pointer to ERX HOLDING QUEUE file (#52.49)"
^XMB(3.9,145984,2,2091,0)="""RTN"",""PSOERXI1"",197,0)"
^XMB(3.9,145984,2,2092,0)=" ;Output: Create an Addendum and attach it to the parent eRx Change Request"
^XMB(3.9,145984,2,2093,0)="""RTN"",""PSOERXI1"",198,0)"
^XMB(3.9,145984,2,2094,0)=" ;"
^XMB(3.9,145984,2,2095,0)="""RTN"",""PSOERXI1"",199,0)"
^XMB(3.9,145984,2,2096,0)=" I ($G(ERXHID)="""")!($G(EIEN)="""") Q"
^XMB(3.9,145984,2,2097,0)="""RTN"",""PSOERXI1"",200,0)"
^XMB(3.9,145984,2,2098,0)=" N CNT,CRERXIEN,ORGERXIEN,ERXDRUG,CRMEDS,CNT,CXTARGET,ERXDRUG,PSOTIUIEN,TIUDADD,ERXTIUX"
