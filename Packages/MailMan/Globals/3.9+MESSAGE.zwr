^XMB(3.9,145986,2,3871,0)="""RTN"",""FBPCR"",186,0)"
^XMB(3.9,145986,2,3872,0)=" Q"
^XMB(3.9,145986,2,3873,0)="""RTN"",""FBPCR"",187,0)"
^XMB(3.9,145986,2,3874,0)=" ;"
^XMB(3.9,145986,2,3875,0)="""RTN"",""FBPCR"",188,0)"
^XMB(3.9,145986,2,3876,0)="HDRUNK ;Warning message if patient's insurance status is unknown"
^XMB(3.9,145986,2,3877,0)="""RTN"",""FBPCR"",189,0)"
^XMB(3.9,145986,2,3878,0)=" D PAGE Q:FBOUT"
^XMB(3.9,145986,2,3879,0)="""RTN"",""FBPCR"",190,0)"
^XMB(3.9,145986,2,3880,0)=" W !?(IOM-30/2),""POTENTIAL COST RECOVERY REPORT"""
^XMB(3.9,145986,2,3881,0)="""RTN"",""FBPCR"",191,0)"
^XMB(3.9,145986,2,3882,0)=" ;W !?(IOM-(11+$L($G(FBPSFNAM))+$L($G(FBPSFNUM)))/2),""Division: "",$G(FBPSFNUM),"" "",$G(FBPSFNAM) ;FB*3.5*163"
^XMB(3.9,145986,2,3883,0)="""RTN"",""FBPCR"",192,0)"
^XMB(3.9,145986,2,3884,0)=" W !?(IOM-(19+$L($G(FBPSFNAM))+$L($G(FBPSFNUM)))/2),""Division/Station: "",$G(FBPSFNUM),"" "",$G(FBPSFNAM) ;FB*3.5*163"
^XMB(3.9,145986,2,3885,0)="""RTN"",""FBPCR"",193,0)"
^XMB(3.9,145986,2,3886,0)=" W !?(IOM-19/2),$$DATX^FBAAUTL(FBBDATE),"" - "",$$DATX^FBAAUTL(FBEDATE)"
^XMB(3.9,145986,2,3887,0)="""RTN"",""FBPCR"",194,0)"
^XMB(3.9,145986,2,3888,0)=" W !?71,""Page: "",FBPG"
^XMB(3.9,145986,2,3889,0)="""RTN"",""FBPCR"",195,0)"
^XMB(3.9,145986,2,3890,0)=" W !,""------------------------------ !!! WARNING !!! --------------------------------"""
^XMB(3.9,145986,2,3891,0)="""RTN"",""FBPCR"",196,0)"
^XMB(3.9,145986,2,3892,0)=" W !,""This report is incomplete due to problems with obtaining insurance information"""
^XMB(3.9,145986,2,3893,0)="""RTN"",""FBPCR"",197,0)"
^XMB(3.9,145986,2,3894,0)=" W !,""for those patients listed in a separate section in the end of the report. You"""
^XMB(3.9,145986,2,3895,0)="""RTN"",""FBPCR"",198,0)"
^XMB(3.9,145986,2,3896,0)=" W !,""may want to rerun the report again to get more accurate results."""
^XMB(3.9,145986,2,3897,0)="""RTN"",""FBPCR"",199,0)"
^XMB(3.9,145986,2,3898,0)=" W !,FBDASH"
^XMB(3.9,145986,2,3899,0)="""RTN"",""FBPCR"",200,0)"
^XMB(3.9,145986,2,3900,0)=" I FBINCUNK=1 D"
^XMB(3.9,145986,2,3901,0)="""RTN"",""FBPCR"",201,0)"
^XMB(3.9,145986,2,3902,0)=" . W !,""Note: You have chosen to include patients with unknown insurance status in"""
^XMB(3.9,145986,2,3903,0)="""RTN"",""FBPCR"",202,0)"
^XMB(3.9,145986,2,3904,0)=" . W !,""this report. Please be aware that these patients will be treated as if they"""
^XMB(3.9,145986,2,3905,0)="""RTN"",""FBPCR"",203,0)"
^XMB(3.9,145986,2,3906,0)=" . W !,""have billable insurance and their treatment details will be marked accordingly."""
^XMB(3.9,145986,2,3907,0)="""RTN"",""FBPCR"",204,0)"
^XMB(3.9,145986,2,3908,0)=" . W !,""The names of these patients will be accompanied with the following message"""
^XMB(3.9,145986,2,3909,0)="""RTN"",""FBPCR"",205,0)"
^XMB(3.9,145986,2,3910,0)=" . W !,""to order to identify them:"""
^XMB(3.9,145986,2,3911,0)="""RTN"",""FBPCR"",206,0)"
^XMB(3.9,145986,2,3912,0)=" . W !,"">> Warning: accurate insurance information for the patient is unavailable"""
^XMB(3.9,145986,2,3913,0)="""RTN"",""FBPCR"",207,0)"
^XMB(3.9,145986,2,3914,0)=" . W !,FBDASH"
^XMB(3.9,145986,2,3915,0)="""RTN"",""FBPCR"",208,0)"
^XMB(3.9,145986,2,3916,0)=" Q"
^XMB(3.9,145986,2,3917,0)="""RTN"",""FBPCR"",209,0)"
^XMB(3.9,145986,2,3918,0)=" ;"
^XMB(3.9,145986,2,3919,0)="""RTN"",""FBPCR"",210,0)"
^XMB(3.9,145986,2,3920,0)="PATDEMO ; Patient Demographics FB*3.5*163"
^XMB(3.9,145986,2,3921,0)="""RTN"",""FBPCR"",211,0)"
^XMB(3.9,145986,2,3922,0)=" N VAEL,FBCP,FBMT"
^XMB(3.9,145986,2,3923,0)="""RTN"",""FBPCR"",212,0)"
^XMB(3.9,145986,2,3924,0)=" D ELIG^VADPT"
^XMB(3.9,145986,2,3925,0)="""RTN"",""FBPCR"",213,0)"
^XMB(3.9,145986,2,3926,0)=" S FBMT=$P($G(VAEL(9)),U,2)"
^XMB(3.9,145986,2,3927,0)="""RTN"",""FBPCR"",214,0)"
^XMB(3.9,145986,2,3928,0)=" W !,?10,""Outpatient Copayment Status: "",FBMT"
^XMB(3.9,145986,2,3929,0)="""RTN"",""FBPCR"",215,0)"
^XMB(3.9,145986,2,3930,0)=" D DISP^IBARXEU(DFN,DT,1,"""")"
^XMB(3.9,145986,2,3931,0)="""RTN"",""FBPCR"",216,0)"
^XMB(3.9,145986,2,3932,0)=" D GETSC"
^XMB(3.9,145986,2,3933,0)="""RTN"",""FBPCR"",217,0)"
^XMB(3.9,145986,2,3934,0)=" D GETSTA"
^XMB(3.9,145986,2,3935,0)="""RTN"",""FBPCR"",218,0)"
^XMB(3.9,145986,2,3936,0)=" Q"
^XMB(3.9,145986,2,3937,0)="""RTN"",""FBPCR"",219,0)"
^XMB(3.9,145986,2,3938,0)=" ;"
^XMB(3.9,145986,2,3939,0)="""RTN"",""FBPCR"",220,0)"
^XMB(3.9,145986,2,3940,0)="GETSC    ; Get Service Connected FB*3.5*163"
^XMB(3.9,145986,2,3941,0)="""RTN"",""FBPCR"",221,0)"
^XMB(3.9,145986,2,3942,0)=" N FBD,FBI,FBX,FBY,FBSC"
^XMB(3.9,145986,2,3943,0)="""RTN"",""FBPCR"",222,0)"
^XMB(3.9,145986,2,3944,0)=" W !,?20,""Service Connected: """
^XMB(3.9,145986,2,3945,0)="""RTN"",""FBPCR"",223,0)"
^XMB(3.9,145986,2,3946,0)=" I VAEL(3)=0 W ""NO"" Q"
^XMB(3.9,145986,2,3947,0)="""RTN"",""FBPCR"",224,0)"
^XMB(3.9,145986,2,3948,0)=" I $P(VAEL(3),U,2)="""" W ""NO"" Q"
^XMB(3.9,145986,2,3949,0)="""RTN"",""FBPCR"",225,0)"
^XMB(3.9,145986,2,3950,0)=" W $P(VAEL(3),U,2)_""%"""
^XMB(3.9,145986,2,3951,0)="""RTN"",""FBPCR"",226,0)"
^XMB(3.9,145986,2,3952,0)=" I '$O(^DPT(DFN,.372,0)) Q"
^XMB(3.9,145986,2,3953,0)="""RTN"",""FBPCR"",227,0)"
^XMB(3.9,145986,2,3954,0)=" S FBI=0 F  S FBI=$O(^DPT(DFN,.372,FBI)) Q:'FBI  D"
^XMB(3.9,145986,2,3955,0)="""RTN"",""FBPCR"",228,0)"
^XMB(3.9,145986,2,3956,0)=" . S FBX=$G(^DPT(DFN,.372,FBI,0)),FBY=$G(^DIC(31,+FBX,0))"
^XMB(3.9,145986,2,3957,0)="""RTN"",""FBPCR"",229,0)"
^XMB(3.9,145986,2,3958,0)=" . S FBD=$S($P(FBY,U,4)="""":$P(FBY,U,1),1:$P(FBY,U,4))_"" (""_$P(FBX,U,2)_""%-""_$S(+$P(FBX,U,3):""SC"",1:""NSC"")_"")"""
^XMB(3.9,145986,2,3959,0)="""RTN"",""FBPCR"",230,0)"
^XMB(3.9,145986,2,3960,0)=" . W !?39,FBD"
^XMB(3.9,145986,2,3961,0)="""RTN"",""FBPCR"",231,0)"
^XMB(3.9,145986,2,3962,0)=" Q"
^XMB(3.9,145986,2,3963,0)="""RTN"",""FBPCR"",232,0)"
^XMB(3.9,145986,2,3964,0)=" ;"
^XMB(3.9,145986,2,3965,0)="""RTN"",""FBPCR"",233,0)"
^XMB(3.9,145986,2,3966,0)="GETSTA ; Get Special Authority Eligibility FB*3.5*163"
^XMB(3.9,145986,2,3967,0)="""RTN"",""FBPCR"",234,0)"
^XMB(3.9,145986,2,3968,0)=" N FBY,FBADT,FBARR"
^XMB(3.9,145986,2,3969,0)="""RTN"",""FBPCR"",235,0)"
