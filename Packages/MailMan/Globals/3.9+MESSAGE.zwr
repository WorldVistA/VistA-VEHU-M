^XMB(3.9,145976,2,394,0)=" ;"
^XMB(3.9,145976,2,395,0)="""RTN"",""MAGGTU4D"",73,0)"
^XMB(3.9,145976,2,396,0)=" ; .MAGBUF       Reference to a local array that the warning text"
^XMB(3.9,145976,2,397,0)="""RTN"",""MAGGTU4D"",74,0)"
^XMB(3.9,145976,2,398,0)=" ;               is returned to. It is appended to the RPC result"
