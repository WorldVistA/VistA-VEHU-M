^XMB(3.9,145980,2,3909,0)="""RTN"",""SDES2CANCELAPPT2"",111,0)"
^XMB(3.9,145980,2,3910,0)=" ; update linked appointment request records"
^XMB(3.9,145980,2,3911,0)="""RTN"",""SDES2CANCELAPPT2"",112,0)"
^XMB(3.9,145980,2,3912,0)=" D UPDATEREQUEST(REQUESTIEN,APPTIEN,CLINICIEN,DFN,CANBYCLINORPAT,$G(NOTE),APPTSTARTTIME,RESOURCE,MRTC,PARENTREQUEST,PARENTSTATUS,$G(NEWPID),.SDERRORS,REQUESTTYPE)"
