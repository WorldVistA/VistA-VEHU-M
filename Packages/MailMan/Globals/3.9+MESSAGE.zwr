^XMB(3.9,145957,2,656,0)="VALMSG(GMRCORC,GMRCCRNR,GMRCMSG) ;check to make sure placer and filler # match current entr"
^XMB(3.9,145957,2,657,0)="""RTN"",""GMRCIMSG"",183,0)"
^XMB(3.9,145957,2,658,0)=" ; Input: "
