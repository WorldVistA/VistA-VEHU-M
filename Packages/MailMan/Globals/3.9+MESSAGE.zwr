^XMB(3.9,145946,2,6313,0)="""RTN"",""IBCOPP"",129,0)"
^XMB(3.9,145946,2,6314,0)=" ;                1 - Only select Active Insurance Companies"
^XMB(3.9,145946,2,6315,0)="""RTN"",""IBCOPP"",130,0)"
^XMB(3.9,145946,2,6316,0)=" ;                2 - Select both Active and Inactive Insurance Companies"
^XMB(3.9,145946,2,6317,0)="""RTN"",""IBCOPP"",131,0)"
^XMB(3.9,145946,2,6318,0)=" ;        IBAIPA  0 - Only select Inactive Insurance Company Plans"
^XMB(3.9,145946,2,6319,0)="""RTN"",""IBCOPP"",132,0)"
^XMB(3.9,145946,2,6320,0)=" ;                1 - Only select Active Insurance Company Plans"
^XMB(3.9,145946,2,6321,0)="""RTN"",""IBCOPP"",133,0)"
^XMB(3.9,145946,2,6322,0)=" ;                2 - Select both Active and Inactive Insurance Company Plans"
^XMB(3.9,145946,2,6323,0)="""RTN"",""IBCOPP"",134,0)"
^XMB(3.9,145946,2,6324,0)=" ;        IBAPL - 0 - Whether some or all ins. co's., user selects plans (may be"
^XMB(3.9,145946,2,6325,0)="""RTN"",""IBCOPP"",135,0)"
^XMB(3.9,145946,2,6326,0)=" ;                    all for certain companies, some for other companies)"
^XMB(3.9,145946,2,6327,0)="""RTN"",""IBCOPP"",136,0)"
^XMB(3.9,145946,2,6328,0)=" ;                1 - Whether some or all ins. co's., run report for all plans"
^XMB(3.9,145946,2,6329,0)="""RTN"",""IBCOPP"",137,0)"
^XMB(3.9,145946,2,6330,0)=" ;                    associated with those co's."
^XMB(3.9,145946,2,6331,0)="""RTN"",""IBCOPP"",138,0)"
^XMB(3.9,145946,2,6332,0)=" S (IBCT,IBQUIT)=0"
^XMB(3.9,145946,2,6333,0)="""RTN"",""IBCOPP"",139,0)"
^XMB(3.9,145946,2,6334,0)=" I IBAPL D STARTQ Q"
^XMB(3.9,145946,2,6335,0)="""RTN"",""IBCOPP"",140,0)"
^XMB(3.9,145946,2,6336,0)=" ;"
^XMB(3.9,145946,2,6337,0)="""RTN"",""IBCOPP"",141,0)"
^XMB(3.9,145946,2,6338,0)=" ; Gather all Insurance Companies if required"
^XMB(3.9,145946,2,6339,0)="""RTN"",""IBCOPP"",142,0)"
^XMB(3.9,145946,2,6340,0)=" I IBAI D"
^XMB(3.9,145946,2,6341,0)="""RTN"",""IBCOPP"",143,0)"
^XMB(3.9,145946,2,6342,0)=" . N INACT"
^XMB(3.9,145946,2,6343,0)="""RTN"",""IBCOPP"",144,0)"
^XMB(3.9,145946,2,6344,0)=" . S A=0"
^XMB(3.9,145946,2,6345,0)="""RTN"",""IBCOPP"",145,0)"
^XMB(3.9,145946,2,6346,0)=" . F  S A=$O(^IBA(355.3,""B"",A)) Q:'A  D"
^XMB(3.9,145946,2,6347,0)="""RTN"",""IBCOPP"",146,0)"
^XMB(3.9,145946,2,6348,0)=" . . Q:$G(^DIC(36,A,0))="""""
^XMB(3.9,145946,2,6349,0)="""RTN"",""IBCOPP"",147,0)"
^XMB(3.9,145946,2,6350,0)=" . . S INACT=+$$GET1^DIQ(36,A_"","",.05,""I"")  ; Is the Insurance Company Inactive?"
^XMB(3.9,145946,2,6351,0)="""RTN"",""IBCOPP"",148,0)"
^XMB(3.9,145946,2,6352,0)=" . . I INACT,IBAIA=1 Q                      ; IB*2.0*549 Only include Active Ins. Cos."
^XMB(3.9,145946,2,6353,0)="""RTN"",""IBCOPP"",149,0)"
^XMB(3.9,145946,2,6354,0)=" . . I 'INACT,IBAIA=0 Q                     ; IB*2.0*549 Only include Inactive Ins. Cos."
^XMB(3.9,145946,2,6355,0)="""RTN"",""IBCOPP"",150,0)"
^XMB(3.9,145946,2,6356,0)=" . . S ^TMP(""IBINC"",$J,$E($P($G(^DIC(36,A,0)),""^""),1,25),A)="""""
^XMB(3.9,145946,2,6357,0)="""RTN"",""IBCOPP"",151,0)"
^XMB(3.9,145946,2,6358,0)=" ;"
^XMB(3.9,145946,2,6359,0)="""RTN"",""IBCOPP"",152,0)"
^XMB(3.9,145946,2,6360,0)=" ; Gather plans for selected Insurance Companies"
^XMB(3.9,145946,2,6361,0)="""RTN"",""IBCOPP"",153,0)"
^XMB(3.9,145946,2,6362,0)=" S IBIC="""""
^XMB(3.9,145946,2,6363,0)="""RTN"",""IBCOPP"",154,0)"
^XMB(3.9,145946,2,6364,0)=" F  S IBIC=$O(^TMP(""IBINC"",$J,IBIC)) Q:IBIC=""""!IBQUIT  D"
^XMB(3.9,145946,2,6365,0)="""RTN"",""IBCOPP"",155,0)"
^XMB(3.9,145946,2,6366,0)=" . S IBCNS="""""
^XMB(3.9,145946,2,6367,0)="""RTN"",""IBCOPP"",156,0)"
^XMB(3.9,145946,2,6368,0)=" . F  S IBCNS=$O(^TMP(""IBINC"",$J,IBIC,IBCNS)) Q:IBCNS=""""!(IBQUIT)  D"
^XMB(3.9,145946,2,6369,0)="""RTN"",""IBCOPP"",157,0)"
^XMB(3.9,145946,2,6370,0)=" . . S IBCT=IBCT+1"
^XMB(3.9,145946,2,6371,0)="""RTN"",""IBCOPP"",158,0)"
^XMB(3.9,145946,2,6372,0)=" . . W !!,""Insurance Company # ""_IBCT_"": ""_IBIC"
^XMB(3.9,145946,2,6373,0)="""RTN"",""IBCOPP"",159,0)"
^XMB(3.9,145946,2,6374,0)=" . . D OK^IBCNSM3"
^XMB(3.9,145946,2,6375,0)="""RTN"",""IBCOPP"",160,0)"
^XMB(3.9,145946,2,6376,0)=" . . Q:IBQUIT"
^XMB(3.9,145946,2,6377,0)="""RTN"",""IBCOPP"",161,0)"
^XMB(3.9,145946,2,6378,0)=" . . I 'IBOK K ^TMP(""IBINC"",$J,IBIC,IBCNS) S IBAI=0 Q"
^XMB(3.9,145946,2,6379,0)="""RTN"",""IBCOPP"",162,0)"
^XMB(3.9,145946,2,6380,0)=" . . W ""   ...building a list of plans..."""
^XMB(3.9,145946,2,6381,0)="""RTN"",""IBCOPP"",163,0)"
^XMB(3.9,145946,2,6382,0)=" . . K IBSEL,^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,6383,0)="""RTN"",""IBCOPP"",164,0)"
^XMB(3.9,145946,2,6384,0)=" . . ;"
^XMB(3.9,145946,2,6385,0)="""RTN"",""IBCOPP"",165,0)"
^XMB(3.9,145946,2,6386,0)=" . . ; IB*2.0*549 - Add Active/Inactive/Both Plan filter"
^XMB(3.9,145946,2,6387,0)="""RTN"",""IBCOPP"",166,0)"
^XMB(3.9,145946,2,6388,0)=" . . S XX=$S(IBAIPA=0:2,IBAIPA=1:0,IBAIPA=2:1)"
^XMB(3.9,145946,2,6389,0)="""RTN"",""IBCOPP"",167,0)"
^XMB(3.9,145946,2,6390,0)=" . . D LKP^IBCNSU2(IBCNS,1,1,.IBSEL,0,XX)"
^XMB(3.9,145946,2,6391,0)="""RTN"",""IBCOPP"",168,0)"
^XMB(3.9,145946,2,6392,0)=" . . Q:IBQUIT"
^XMB(3.9,145946,2,6393,0)="""RTN"",""IBCOPP"",169,0)"
^XMB(3.9,145946,2,6394,0)=" . . I '$O(^TMP($J,""IBSEL"",0)) D  Q"
^XMB(3.9,145946,2,6395,0)="""RTN"",""IBCOPP"",170,0)"
^XMB(3.9,145946,2,6396,0)=" . . . K ^TMP(""IBINC"",$J,IBIC,IBCNS)"
^XMB(3.9,145946,2,6397,0)="""RTN"",""IBCOPP"",171,0)"
^XMB(3.9,145946,2,6398,0)=" . . . S IBAI=0"
^XMB(3.9,145946,2,6399,0)="""RTN"",""IBCOPP"",172,0)"
^XMB(3.9,145946,2,6400,0)=" . . ;"
^XMB(3.9,145946,2,6401,0)="""RTN"",""IBCOPP"",173,0)"
^XMB(3.9,145946,2,6402,0)=" . . ; Set plans into an array"
^XMB(3.9,145946,2,6403,0)="""RTN"",""IBCOPP"",174,0)"
^XMB(3.9,145946,2,6404,0)=" . . S IBPN=0"
^XMB(3.9,145946,2,6405,0)="""RTN"",""IBCOPP"",175,0)"
^XMB(3.9,145946,2,6406,0)=" . . F  S IBPN=$O(^TMP($J,""IBSEL"",IBPN)) Q:'IBPN  D"
^XMB(3.9,145946,2,6407,0)="""RTN"",""IBCOPP"",176,0)"
^XMB(3.9,145946,2,6408,0)=" . . . S ^TMP(""IBINC"",$J,IBIC,IBCNS,IBPN)="""""
^XMB(3.9,145946,2,6409,0)="""RTN"",""IBCOPP"",177,0)"
^XMB(3.9,145946,2,6410,0)=" ;"
^XMB(3.9,145946,2,6411,0)="""RTN"",""IBCOPP"",178,0)"
^XMB(3.9,145946,2,6412,0)="STARTQ ;"
^XMB(3.9,145946,2,6413,0)="""RTN"",""IBCOPP"",179,0)"
^XMB(3.9,145946,2,6414,0)=" K IBAO,IBCT,IBIC,IBJJ,IBLCT,IBCNS,IBOK,IBPN,IBSEL,^TMP($J,""IBSEL"")"
^XMB(3.9,145946,2,6415,0)="""RTN"",""IBCOPP"",180,0)"
^XMB(3.9,145946,2,6416,0)=" Q "
^XMB(3.9,145946,2,6417,0)="""VER"")"
^XMB(3.9,145946,2,6418,0)="8.0^22.2"
^XMB(3.9,145946,2,6419,0)="$END KID IB*2.0*827b"
