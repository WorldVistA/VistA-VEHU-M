^XMB(3.9,145986,2,3451,0)="""RTN"",""FBPAY671"",110,0)"
^XMB(3.9,145986,2,3452,0)="WRTDX ; inputs"
^XMB(3.9,145986,2,3453,0)="""RTN"",""FBPAY671"",111,0)"
^XMB(3.9,145986,2,3454,0)=" ; FBDATA contains node from ^TMP "
