^XMB(3.9,145989,2,567,0)="""RTN"",""PSOASAP0"",141,0)"
^XMB(3.9,145989,2,568,0)="PAT13() ;Patient Address Information - Line 2"
^XMB(3.9,145989,2,569,0)="""RTN"",""PSOASAP0"",142,0)"
^XMB(3.9,145989,2,570,0)=" ; ASAP 4.2: Length = 35 characters (All others: 30 characters)"
^XMB(3.9,145989,2,571,0)="""RTN"",""PSOASAP0"",143,0)"
^XMB(3.9,145989,2,572,0)=" I PSOASVER=""4.2"" Q $G(VAPA(2))"
^XMB(3.9,145989,2,573,0)="""RTN"",""PSOASAP0"",144,0)"
^XMB(3.9,145989,2,574,0)=" N ADDRESS"
^XMB(3.9,145989,2,575,0)="""RTN"",""PSOASAP0"",145,0)"
^XMB(3.9,145989,2,576,0)=" S ADDRESS=$$TRIM^XLFSTR($G(VAPA(1)))_$S($$TRIM^XLFSTR($G(VAPA(2)))'="""":"" ""_VAPA(2),1:"""")_$S($$TRIM^XLFSTR($G(VAPA(3)))'="""":"" ""_VAPA(3),1:"""")"
^XMB(3.9,145989,2,577,0)="""RTN"",""PSOASAP0"",146,0)"
^XMB(3.9,145989,2,578,0)=" I $E(ADDRESS,1,30)'["" "" Q $E(ADDRESS,31,999)"
^XMB(3.9,145989,2,579,0)="""RTN"",""PSOASAP0"",147,0)"
^XMB(3.9,145989,2,580,0)=" Q $$ADDRESS(ADDRESS,2)"
^XMB(3.9,145989,2,581,0)="""RTN"",""PSOASAP0"",148,0)"
^XMB(3.9,145989,2,582,0)=" ;"
^XMB(3.9,145989,2,583,0)="""RTN"",""PSOASAP0"",149,0)"
^XMB(3.9,145989,2,584,0)="PAT15() ;Patient State Address"
^XMB(3.9,145989,2,585,0)="""RTN"",""PSOASAP0"",150,0)"
^XMB(3.9,145989,2,586,0)=" ; US State Abbreviation"
^XMB(3.9,145989,2,587,0)="""RTN"",""PSOASAP0"",151,0)"
^XMB(3.9,145989,2,588,0)=" I $$PAT22()="""" Q $$GET1^DIQ(5,+$G(VAPA(5)),1)"
^XMB(3.9,145989,2,589,0)="""RTN"",""PSOASAP0"",152,0)"
^XMB(3.9,145989,2,590,0)=" ; International State/Province"
^XMB(3.9,145989,2,591,0)="""RTN"",""PSOASAP0"",153,0)"
^XMB(3.9,145989,2,592,0)=" Q $P($G(VAPA(23)),""^"")"
^XMB(3.9,145989,2,593,0)="""RTN"",""PSOASAP0"",154,0)"
^XMB(3.9,145989,2,594,0)=" ;"
^XMB(3.9,145989,2,595,0)="""RTN"",""PSOASAP0"",155,0)"
^XMB(3.9,145989,2,596,0)="PAT17() ;Patient Phone Number"
^XMB(3.9,145989,2,597,0)="""RTN"",""PSOASAP0"",156,0)"
^XMB(3.9,145989,2,598,0)=" N PAT17"
^XMB(3.9,145989,2,599,0)="""RTN"",""PSOASAP0"",157,0)"
^XMB(3.9,145989,2,600,0)=" ;PHONE NUMBER [RESIDENCE] (Home)"
^XMB(3.9,145989,2,601,0)="""RTN"",""PSOASAP0"",158,0)"
^XMB(3.9,145989,2,602,0)=" S PAT17=$$PHONE($P($G(VAPA(8)),""^"",1)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,603,0)="""RTN"",""PSOASAP0"",159,0)"
^XMB(3.9,145989,2,604,0)=" ;PHONE NUMBER [CELLULAR] (Cell)"
^XMB(3.9,145989,2,605,0)="""RTN"",""PSOASAP0"",160,0)"
^XMB(3.9,145989,2,606,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.134)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,607,0)="""RTN"",""PSOASAP0"",161,0)"
^XMB(3.9,145989,2,608,0)=" ;PHONE NUMBER [WORK] (Work)"
^XMB(3.9,145989,2,609,0)="""RTN"",""PSOASAP0"",162,0)"
^XMB(3.9,145989,2,610,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.132)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,611,0)="""RTN"",""PSOASAP0"",163,0)"
^XMB(3.9,145989,2,612,0)=" ;K-WORK PHONE NUMBER (Next Of Kin)"
^XMB(3.9,145989,2,613,0)="""RTN"",""PSOASAP0"",164,0)"
^XMB(3.9,145989,2,614,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.21011)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,615,0)="""RTN"",""PSOASAP0"",165,0)"
^XMB(3.9,145989,2,616,0)=" ;K2-WORK PHONE NUMBER (Secondary Next Of Kin)"
^XMB(3.9,145989,2,617,0)="""RTN"",""PSOASAP0"",166,0)"
^XMB(3.9,145989,2,618,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.211011)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,619,0)="""RTN"",""PSOASAP0"",167,0)"
^XMB(3.9,145989,2,620,0)=" ;E-WORK PHONE NUMBER (Work Emergency)"
^XMB(3.9,145989,2,621,0)="""RTN"",""PSOASAP0"",168,0)"
^XMB(3.9,145989,2,622,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.33011)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,623,0)="""RTN"",""PSOASAP0"",169,0)"
^XMB(3.9,145989,2,624,0)=" ;E2-WORK PHONE NUMBER (Secondary Work Emergency)"
^XMB(3.9,145989,2,625,0)="""RTN"",""PSOASAP0"",170,0)"
^XMB(3.9,145989,2,626,0)=" S PAT17=$$PHONE($$GET1^DIQ(2,PATIEN,.331011)) I PAT17 Q PAT17"
^XMB(3.9,145989,2,627,0)="""RTN"",""PSOASAP0"",171,0)"
^XMB(3.9,145989,2,628,0)=" ;Last resort: Pharmacy Phone #"
^XMB(3.9,145989,2,629,0)="""RTN"",""PSOASAP0"",172,0)"
^XMB(3.9,145989,2,630,0)=" Q $$PHA10()"
^XMB(3.9,145989,2,631,0)="""RTN"",""PSOASAP0"",173,0)"
^XMB(3.9,145989,2,632,0)=" ;"
^XMB(3.9,145989,2,633,0)="""RTN"",""PSOASAP0"",174,0)"
^XMB(3.9,145989,2,634,0)="PAT18() ;ASAP 3.0 : Email Address (Not Used)"
^XMB(3.9,145989,2,635,0)="""RTN"",""PSOASAP0"",175,0)"
^XMB(3.9,145989,2,636,0)=" ;       ASAP 4.0+: Patient DOB"
