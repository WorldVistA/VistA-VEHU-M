^XMB(3.9,145989,2,782,0)=" S DSP05=$S((RECTYPE=""V"")&($G(RTSDATA(""RELDTTM""))'=""""):$G(RTSDATA(""RELDTTM"")),$$RXRLDT^PSOBPSUT(RXIEN,FILLNUM):$$RXRLDT^PSOBPSUT(RXIEN,FILLNUM),1:DT)\1"
