^XMB(3.9,145986,2,614,0)=19
^XMB(3.9,145986,2,615,0)="""RTN"",""FBAACCB"")"
^XMB(3.9,145986,2,616,0)="0^11^B39441611"
^XMB(3.9,145986,2,617,0)="""RTN"",""FBAACCB"",1,0)"
^XMB(3.9,145986,2,618,0)="FBAACCB ;AISC/GRR - CLERK CLOSE BATCH ;7/9/14  16:16"
^XMB(3.9,145986,2,619,0)="""RTN"",""FBAACCB"",2,0)"
^XMB(3.9,145986,2,620,0)=" ;;3.5;FEE BASIS;**4,61,77,116,154,164**;JAN 30, 1995;Build 0"
^XMB(3.9,145986,2,621,0)="""RTN"",""FBAACCB"",3,0)"
^XMB(3.9,145986,2,622,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145986,2,623,0)="""RTN"",""FBAACCB"",4,0)"
^XMB(3.9,145986,2,624,0)=" K QQ D DT^DICRW"
^XMB(3.9,145986,2,625,0)="""RTN"",""FBAACCB"",5,0)"
^XMB(3.9,145986,2,626,0)="BT W !! S DIC=""^FBAA(161.7,"",DIC(0)=""AEQ"",DIC(""S"")=$S($D(^XUSEC(""FBAA LEVEL 2"",DUZ)):""I $G(^(""""ST""""))=""""O"""""",1:""I $P(^(0),U,5)=DUZ&($G(^(""""ST""""))=""""O"""")"") D ^DIC K DIC(""S"")"
^XMB(3.9,145986,2,627,0)="""RTN"",""FBAACCB"",6,0)"
^XMB(3.9,145986,2,628,0)=" G Q^FBAACCB0:X=""^""!(X=""""),BT:Y<0 S B=+Y,FZ=^FBAA(161.7,B,0),FBTYPE=$P(FZ,""^"",3)"
^XMB(3.9,145986,2,629,0)="""RTN"",""FBAACCB"",7,0)"
^XMB(3.9,145986,2,630,0)=" I FBTYPE=""B3"",'$D(^FBAAC(""AC"",B)) W !!,*7,""No payments in Batch yet!"",! G BT"
^XMB(3.9,145986,2,631,0)="""RTN"",""FBAACCB"",8,0)"
^XMB(3.9,145986,2,632,0)=" I FBTYPE=""B2"",'$D(^FBAAC(""AD"",B)) W !!,*7,""No Payments in Batch yet!"",! G BT"
^XMB(3.9,145986,2,633,0)="""RTN"",""FBAACCB"",9,0)"
^XMB(3.9,145986,2,634,0)=" I FBTYPE=""B5"",'$D(^FBAA(162.1,""AE"",B)) W !!,*7,""No Payments in Batch yet!"",! G BT"
^XMB(3.9,145986,2,635,0)="""RTN"",""FBAACCB"",10,0)"
^XMB(3.9,145986,2,636,0)=" I FBTYPE=""B9"",'$D(^FBAAI(""AC"",B)) W !!,*7,""No Payments in Batch yet!"",! G BT"
^XMB(3.9,145986,2,637,0)="""RTN"",""FBAACCB"",11,0)"
^XMB(3.9,145986,2,638,0)="RDD S DIR(0)=""Y"",DIR(""A"")=""Want to review batch"",DIR(""B"")=""NO"",DIR(""?"")=""If you want a detail list of each payment line, answer """"Yes"""" otherwise press Return key"" D ^DIR K DIR"
^XMB(3.9,145986,2,639,0)="""RTN"",""FBAACCB"",12,0)"
^XMB(3.9,145986,2,640,0)=" G BT:$D(DIRUT) W:Y @IOF D:Y LIST:FBTYPE=""B3"",LISTP:FBTYPE=""B5"",LISTT^FBAACCB0:FBTYPE=""B2"",LISTC^FBAACCB1:FBTYPE=""B9"""
^XMB(3.9,145986,2,641,0)="""RTN"",""FBAACCB"",13,0)"
^XMB(3.9,145986,2,642,0)="RDD1 S DIR(0)=""Y"",DIR(""A"")=""Do you still want to close Batch"",DIR(""B"")=""YES"" D ^DIR K DIR G BT:'Y!$D(DIRUT)"
^XMB(3.9,145986,2,643,0)="""RTN"",""FBAACCB"",14,0)"
^XMB(3.9,145986,2,644,0)=" N FBARY,FBOLD,FBINVT"
^XMB(3.9,145986,2,645,0)="""RTN"",""FBAACCB"",15,0)"
^XMB(3.9,145986,2,646,0)=" ;"
^XMB(3.9,145986,2,647,0)="""RTN"",""FBAACCB"",16,0)"
^XMB(3.9,145986,2,648,0)=" S C=0,T=0 G PHARM^FBAACCB1:FBTYPE=""B5"",TRAV^FBAACCB1:FBTYPE=""B2"",CHNH^FBAACCB1:FBTYPE=""B9"""
^XMB(3.9,145986,2,649,0)="""RTN"",""FBAACCB"",17,0)"
^XMB(3.9,145986,2,650,0)=" F J=0:0 S J=$O(^FBAAC(""AC"",B,J)) Q:J'>0  F K=0:0 S K=$O(^FBAAC(""AC"",B,J,K)) Q:K'>0  F L=0:0 S L=$O(^FBAAC(""AC"",B,J,K,L)) Q:L'>0  F M=0:0 S M=$O(^FBAAC(""AC"",B,J,K,L,M)) Q:M'>0  D GOT"
^XMB(3.9,145986,2,651,0)="""RTN"",""FBAACCB"",18,0)"
^XMB(3.9,145986,2,652,0)="FIN ; FB*3.5*116 - check and handle $0 invoices"
^XMB(3.9,145986,2,653,0)="""RTN"",""FBAACCB"",19,0)"
^XMB(3.9,145986,2,654,0)=" D CHECK(.FBARY)"
^XMB(3.9,145986,2,655,0)="""RTN"",""FBAACCB"",20,0)"
^XMB(3.9,145986,2,656,0)=" I $D(FBARY) D  G BT"
^XMB(3.9,145986,2,657,0)="""RTN"",""FBAACCB"",21,0)"
^XMB(3.9,145986,2,658,0)=" . ;D EN^DDIOL(.FBARY)"
^XMB(3.9,145986,2,659,0)="""RTN"",""FBAACCB"",22,0)"
^XMB(3.9,145986,2,660,0)=" . W *7,!!?2,""Batch cannot be closed. Listed invoices are zero dollar """
^XMB(3.9,145986,2,661,0)="""RTN"",""FBAACCB"",23,0)"
^XMB(3.9,145986,2,662,0)=" . W *7,!?2,""and must be corrected or removed from the batch."""
^XMB(3.9,145986,2,663,0)="""RTN"",""FBAACCB"",24,0)"
^XMB(3.9,145986,2,664,0)=" ; end of changes"
^XMB(3.9,145986,2,665,0)="""RTN"",""FBAACCB"",25,0)"
^XMB(3.9,145986,2,666,0)=" ;"
^XMB(3.9,145986,2,667,0)="""RTN"",""FBAACCB"",26,0)"
^XMB(3.9,145986,2,668,0)=" S $P(FZ,""^"",9)=T,$P(FZ,""^"",11)=C"
^XMB(3.9,145986,2,669,0)="""RTN"",""FBAACCB"",27,0)"
^XMB(3.9,145986,2,670,0)=" S $P(FZ,""^"",13)=DT,^FBAA(161.7,B,0)=FZ,^FBAA(161.7,B,""ST"")=""C"",^FBAA(161.7,""AC"",""C"",B)="""",DA=B,DR=""0;ST"" K ^FBAA(161.7,""AC"",""O"",B),^FBAA(161.7,""AB"",""O"",$P(^FBAA(161.7,B,0),""^"",5),B) W !! D EN^DIQ W !!,""Batch Closed"" G BT"
^XMB(3.9,145986,2,671,0)="""RTN"",""FBAACCB"",28,0)"
^XMB(3.9,145986,2,672,0)=" ;"
^XMB(3.9,145986,2,673,0)="""RTN"",""FBAACCB"",29,0)"
^XMB(3.9,145986,2,674,0)="GOT S Y(0)=$G(^FBAAC(J,1,K,1,L,1,M,0)),FBIN=$P(Y(0),""^"",16)"
^XMB(3.9,145986,2,675,0)="""RTN"",""FBAACCB"",30,0)"
^XMB(3.9,145986,2,676,0)=" ; HIPAA 5010 - count line items that have 0.00 amount paid"
^XMB(3.9,145986,2,677,0)="""RTN"",""FBAACCB"",31,0)"
^XMB(3.9,145986,2,678,0)=" S T=T+$P(Y(0),""^"",3),C=C+1"
^XMB(3.9,145986,2,679,0)="""RTN"",""FBAACCB"",32,0)"
^XMB(3.9,145986,2,680,0)=" ; FB*3.5*116 -collect amount paid for each invoice in batch"
^XMB(3.9,145986,2,681,0)="""RTN"",""FBAACCB"",33,0)"
^XMB(3.9,145986,2,682,0)=" S FBARY(FBIN)=$G(FBARY(FBIN))+$P(Y(0),""^"",3)"
^XMB(3.9,145986,2,683,0)="""RTN"",""FBAACCB"",34,0)"
^XMB(3.9,145986,2,684,0)=" Q"
^XMB(3.9,145986,2,685,0)="""RTN"",""FBAACCB"",35,0)"
^XMB(3.9,145986,2,686,0)=" ;"
^XMB(3.9,145986,2,687,0)="""RTN"",""FBAACCB"",36,0)"
^XMB(3.9,145986,2,688,0)="CHECK(FBINV) ; order thru array and save zero dollar invoices; report any zero dollar invoices"
^XMB(3.9,145986,2,689,0)="""RTN"",""FBAACCB"",37,0)"
^XMB(3.9,145986,2,690,0)=" ; FBINV = array of invoices"
^XMB(3.9,145986,2,691,0)="""RTN"",""FBAACCB"",38,0)"
^XMB(3.9,145986,2,692,0)=" N FBAAIN"
^XMB(3.9,145986,2,693,0)="""RTN"",""FBAACCB"",39,0)"
^XMB(3.9,145986,2,694,0)=" S FBAAIN=0 F  S FBAAIN=$O(FBINV(FBAAIN)) Q:'FBAAIN  D"
^XMB(3.9,145986,2,695,0)="""RTN"",""FBAACCB"",40,0)"
^XMB(3.9,145986,2,696,0)=" . I FBINV(FBAAIN)'>0 W !!,""Invoice #: ""_FBAAIN_"" totals $0.00"""
^XMB(3.9,145986,2,697,0)="""RTN"",""FBAACCB"",41,0)"
^XMB(3.9,145986,2,698,0)=" . E  K FBINV(FBAAIN) ; remove array elements that represent non-zero dollar invoices"
^XMB(3.9,145986,2,699,0)="""RTN"",""FBAACCB"",42,0)"
^XMB(3.9,145986,2,700,0)=" Q"
^XMB(3.9,145986,2,701,0)="""RTN"",""FBAACCB"",43,0)"
^XMB(3.9,145986,2,702,0)=" ;"
^XMB(3.9,145986,2,703,0)="""RTN"",""FBAACCB"",44,0)"
^XMB(3.9,145986,2,704,0)="LIST S Q="""",$P(Q,""="",80)=""="""
^XMB(3.9,145986,2,705,0)="""RTN"",""FBAACCB"",45,0)"
^XMB(3.9,145986,2,706,0)=" S IOP=$S($D(ION):ION,1:""HOME"") D ^%ZIS K IOP"
^XMB(3.9,145986,2,707,0)="""RTN"",""FBAACCB"",46,0)"
^XMB(3.9,145986,2,708,0)="ENM D HED S (FBIN,FBINOLD)="""",(FBAAOUT,FBINTOT)=0 F XY=0:0 S FBIN=$O(^FBAAC(""AJ"",B,FBIN)) Q:FBIN=""""!($G(FBAAOUT))  D INTOT^FBAACCB0 F J=0:0 S J=$O(^FBAAC(""AJ"",B,FBIN,J)) Q:J'>0!($G(FBAAOUT))  D GMORE^FBAACCB0"
^XMB(3.9,145986,2,709,0)="""RTN"",""FBAACCB"",47,0)"
^XMB(3.9,145986,2,710,0)=" I '$G(FBAAOUT) S FBIN=0 D INTOT^FBAACCB0"
^XMB(3.9,145986,2,711,0)="""RTN"",""FBAACCB"",48,0)"
^XMB(3.9,145986,2,712,0)=" Q"
^XMB(3.9,145986,2,713,0)="""RTN"",""FBAACCB"",49,0)"
^XMB(3.9,145986,2,714,0)="SET ;"
^XMB(3.9,145986,2,715,0)="""RTN"",""FBAACCB"",50,0)"
^XMB(3.9,145986,2,716,0)=" N FBADJLA,FBADJLR,FBFPPSC,FBFPPSL,FBX,FBY3,TAMT"
^XMB(3.9,145986,2,717,0)="""RTN"",""FBAACCB"",51,0)"
^XMB(3.9,145986,2,718,0)=" S N=$S($D(^DPT(J,0)):$P(^DPT(J,0),""^"",1),1:""""),S=$S(N]"""":$P(^DPT(J,0),""^"",9),1:""""),V=$S($D(^FBAAV(K,0)):$P(^FBAAV(K,0),""^"",1),1:""""),VID=$S(V]"""":$P(^(0),""^"",2),1:"""")"
^XMB(3.9,145986,2,719,0)="""RTN"",""FBAACCB"",52,0)"
^XMB(3.9,145986,2,720,0)=" S D=+$G(^FBAAC(J,1,K,1,L,0)) Q:'D"
^XMB(3.9,145986,2,721,0)="""RTN"",""FBAACCB"",53,0)"
^XMB(3.9,145986,2,722,0)=" S Y=$G(^FBAAC(J,1,K,1,L,1,M,0)) Q:Y']"""""
^XMB(3.9,145986,2,723,0)="""RTN"",""FBAACCB"",54,0)"
^XMB(3.9,145986,2,724,0)=" S FBY3=$G(^FBAAC(J,1,K,1,L,1,M,3))"
^XMB(3.9,145986,2,725,0)="""RTN"",""FBAACCB"",55,0)"
^XMB(3.9,145986,2,726,0)=" S FBFPPSC=$P(FBY3,U)"
^XMB(3.9,145986,2,727,0)="""RTN"",""FBAACCB"",56,0)"
^XMB(3.9,145986,2,728,0)=" S FBFPPSL=$P(FBY3,U,2)"
^XMB(3.9,145986,2,729,0)="""RTN"",""FBAACCB"",57,0)"
^XMB(3.9,145986,2,730,0)=" S FBX=$$ADJLRA^FBAAFA(M_"",""_L_"",""_K_"",""_J_"","")"
^XMB(3.9,145986,2,731,0)="""RTN"",""FBAACCB"",58,0)"
^XMB(3.9,145986,2,732,0)=" S FBADJLR=$P(FBX,U)"
^XMB(3.9,145986,2,733,0)="""RTN"",""FBAACCB"",59,0)"
^XMB(3.9,145986,2,734,0)=" S FBADJLA=$P(FBX,U,2)"
^XMB(3.9,145986,2,735,0)="""RTN"",""FBAACCB"",60,0)"
^XMB(3.9,145986,2,736,0)=" S T=$P(Y,""^"",5),FBIN=$P(Y,""^"",16),ZS=$P(Y,""^"",20)"
^XMB(3.9,145986,2,737,0)="""RTN"",""FBAACCB"",61,0)"
^XMB(3.9,145986,2,738,0)=" S TAMT=$FN($P(Y,""^"",4),"""",2)"
^XMB(3.9,145986,2,739,0)="""RTN"",""FBAACCB"",62,0)"
^XMB(3.9,145986,2,740,0)=" S FBVP=$S($P(Y,""^"",21)=""VP"":""#"",1:"""")"
^XMB(3.9,145986,2,741,0)="""RTN"",""FBAACCB"",63,0)"
^XMB(3.9,145986,2,742,0)=" S FBAACPT=$$CPT^FBAAUTL4($P(Y,U))"
^XMB(3.9,145986,2,743,0)="""RTN"",""FBAACCB"",64,0)"
^XMB(3.9,145986,2,744,0)=" S CPTDESC=$$CPT^FBAAUTL4($P(Y,U),1,D)"
^XMB(3.9,145986,2,745,0)="""RTN"",""FBAACCB"",65,0)"
^XMB(3.9,145986,2,746,0)=" S FBVCHDT=$P(Y,""^"",6),FBIN(1)=$P(Y,""^"",15) D FBCKO^FBAACCB2(J,K,L,M)"
^XMB(3.9,145986,2,747,0)="""RTN"",""FBAACCB"",66,0)"
^XMB(3.9,145986,2,748,0)=" S FBMODLE=$$MODL^FBAAUTL4(""^FBAAC(""_J_"",1,""_K_"",1,""_L_"",1,""_M_"",""""M"""")"",""E"")"
^XMB(3.9,145986,2,749,0)="""RTN"",""FBAACCB"",67,0)"
^XMB(3.9,145986,2,750,0)="GO S A1=$P(Y,""^"",2)+.0001,A2=$P(Y,""^"",3)+.0001,A1=$P(A1,""."",1)_"".""_$E($P(A1,""."",2),1,2),A2=$P(A2,""."",1)_"".""_$E($P(A2,""."",2),1,2),FBINTOT=FBINTOT+A2"
^XMB(3.9,145986,2,751,0)="""RTN"",""FBAACCB"",68,0)"
