^XMB(3.9,145946,2,2715,0)="""RTN"",""IBCNEDE3"",96,0)"
^XMB(3.9,145946,2,2716,0)="CHK(X,PIEN,PINS,Z) ; Check patient policy - logic from CHK^IBCNS1"
