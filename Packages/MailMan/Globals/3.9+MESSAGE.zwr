^XMB(3.9,145984,2,1144,0)=" I (RULE=1060)!((RULE=1056)&(CHGMESRI=""U"")!(CHGMESRI=""D"")) D"
^XMB(3.9,145984,2,1145,0)="""RTN"",""PSOERX1D"",74,0)"
^XMB(3.9,145984,2,1146,0)=" .S IENS=$O(^PS(52.49,PSOIEN,316,0))"
