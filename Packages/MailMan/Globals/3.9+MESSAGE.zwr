^XMB(3.9,145989,2,1970,0)=" N DIR,DIRUT,X,PSOQUIT,RXIEN,SCREEN,STATEIEN,PSOTTCNT,PSOTPCNT,DFN,VALM,VALMCNT,VALMHDR,VALMBCK,VALMSG,PSOLSTLN"
^XMB(3.9,145989,2,1971,0)="""RTN"",""PSOSPML4"",5,0)"
^XMB(3.9,145989,2,1972,0)=" ;"
^XMB(3.9,145989,2,1973,0)="""RTN"",""PSOSPML4"",6,0)"
^XMB(3.9,145989,2,1974,0)="RX ; - Prescription prompt"
^XMB(3.9,145989,2,1975,0)="""RTN"",""PSOSPML4"",7,0)"
^XMB(3.9,145989,2,1976,0)=" K DIR S DIR(0)=""FAO^1:30"",DIR(""A"")="" PRESCRIPTION: "",(DIR(""?""),DIR(""??""))=""^D HLP^PSORXVW1"""
^XMB(3.9,145989,2,1977,0)="""RTN"",""PSOSPML4"",8,0)"
^XMB(3.9,145989,2,1978,0)=" W ! D ^DIR I X=""""!$D(DIRUT) G EXIT"
^XMB(3.9,145989,2,1979,0)="""RTN"",""PSOSPML4"",9,0)"
^XMB(3.9,145989,2,1980,0)=" S X=$$UP^XLFSTR(X),PSOQUIT=0"
^XMB(3.9,145989,2,1981,0)="""RTN"",""PSOSPML4"",10,0)"
^XMB(3.9,145989,2,1982,0)=" I $E(X,1,2)'=""E."" S RXIEN=+$$RXLKP(X) I RXIEN<0 G RX"
^XMB(3.9,145989,2,1983,0)="""RTN"",""PSOSPML4"",11,0)"
^XMB(3.9,145989,2,1984,0)=" I $E(X,1,2)=""E."" D  I PSOQUIT G RX"
^XMB(3.9,145989,2,1985,0)="""RTN"",""PSOSPML4"",12,0)"
^XMB(3.9,145989,2,1986,0)=" . I $L(X)'=9 W !?5,""The ECME# must be 7 digits long!"",$C(7) S PSOQUIT=1 Q"
^XMB(3.9,145989,2,1987,0)="""RTN"",""PSOSPML4"",13,0)"
^XMB(3.9,145989,2,1988,0)=" . S RXIEN=+$$RXNUM^PSOBPSU2($E(X,3,9)) I RXIEN<0 W "" ??"" S PSOQUIT=1"
^XMB(3.9,145989,2,1989,0)="""RTN"",""PSOSPML4"",14,0)"
^XMB(3.9,145989,2,1990,0)=" ;"
^XMB(3.9,145989,2,1991,0)="""RTN"",""PSOSPML4"",15,0)"
^XMB(3.9,145989,2,1992,0)=" S FILLNUM=$$RXFILL^PSOSPMU2(RXIEN) I FILLNUM=""^"" G EXIT"
^XMB(3.9,145989,2,1993,0)="""RTN"",""PSOSPML4"",16,0)"
^XMB(3.9,145989,2,1994,0)=" ;"
^XMB(3.9,145989,2,1995,0)="""RTN"",""PSOSPML4"",17,0)"
^XMB(3.9,145989,2,1996,0)=" S SCREEN=$$SCREEN^PSOSPMUT(RXIEN,FILLNUM)"
^XMB(3.9,145989,2,1997,0)="""RTN"",""PSOSPML4"",18,0)"
^XMB(3.9,145989,2,1998,0)=" I +SCREEN D  G RX:$P(SCREEN,""^"",3)=""E"""
^XMB(3.9,145989,2,1999,0)="""RTN"",""PSOSPML4"",19,0)"
^XMB(3.9,145989,2,2000,0)=" . W !!?1,$S($P(SCREEN,""^"",3)=""E"":""ERROR"",1:""WARNING""),"": "",$P(SCREEN,""^"",2),$C(7) D PAUSE^PSOSPMU1"
^XMB(3.9,145989,2,2001,0)="""RTN"",""PSOSPML4"",20,0)"
^XMB(3.9,145989,2,2002,0)=" ;"
^XMB(3.9,145989,2,2003,0)="""RTN"",""PSOSPML4"",21,0)"
^XMB(3.9,145989,2,2004,0)=" ; The legislation allowing VA to report was published on 02/11/2013"
^XMB(3.9,145989,2,2005,0)="""RTN"",""PSOSPML4"",22,0)"
^XMB(3.9,145989,2,2006,0)=" I $$RXRLDT^PSOBPSUT(RXIEN,FILLNUM),$$RXRLDT^PSOBPSUT(RXIEN,FILLNUM)<3130211 D  G RX"
^XMB(3.9,145989,2,2007,0)="""RTN"",""PSOSPML4"",23,0)"
^XMB(3.9,145989,2,2008,0)=" . W !!?1,""Only prescription fills dispensed on or after Feb 11, 2013 can be exported."",$C(7)"
^XMB(3.9,145989,2,2009,0)="""RTN"",""PSOSPML4"",24,0)"
^XMB(3.9,145989,2,2010,0)=" ;"
^XMB(3.9,145989,2,2011,0)="""RTN"",""PSOSPML4"",25,0)"
^XMB(3.9,145989,2,2012,0)=" D EN(RXIEN,FILLNUM,""N"")"
^XMB(3.9,145989,2,2013,0)="""RTN"",""PSOSPML4"",26,0)"
^XMB(3.9,145989,2,2014,0)=" ;"
^XMB(3.9,145989,2,2015,0)="""RTN"",""PSOSPML4"",27,0)"
^XMB(3.9,145989,2,2016,0)=" G RX"
^XMB(3.9,145989,2,2017,0)="""RTN"",""PSOSPML4"",28,0)"
^XMB(3.9,145989,2,2018,0)=" ;"
^XMB(3.9,145989,2,2019,0)="""RTN"",""PSOSPML4"",29,0)"
^XMB(3.9,145989,2,2020,0)="EN(RXIEN,FILLNUM,RECTYPE) ; Entry point"
^XMB(3.9,145989,2,2021,0)="""RTN"",""PSOSPML4"",30,0)"
^XMB(3.9,145989,2,2022,0)=" N ASAP,SITEIEN,PATIEN,FILLIEN,DRUGIEN,PREIEN,RPHIEN,RSTREC,RTSDATA,PSONAME,TRXTYPE,RTSREC"
^XMB(3.9,145989,2,2023,0)="""RTN"",""PSOSPML4"",31,0)"
^XMB(3.9,145989,2,2024,0)=" N BATCHIEN"
^XMB(3.9,145989,2,2025,0)="""RTN"",""PSOSPML4"",32,0)"
^XMB(3.9,145989,2,2026,0)=" S BATCHIEN="""""
^XMB(3.9,145989,2,2027,0)="""RTN"",""PSOSPML4"",33,0)"
^XMB(3.9,145989,2,2028,0)=" ;"
^XMB(3.9,145989,2,2029,0)="""RTN"",""PSOSPML4"",34,0)"
^XMB(3.9,145989,2,2030,0)=" S:$G(FILLNUM)="""" FILLNUM=0"
^XMB(3.9,145989,2,2031,0)="""RTN"",""PSOSPML4"",35,0)"
^XMB(3.9,145989,2,2032,0)=" S:$G(STATEIEN)="""" STATEIEN=$$RXSTATE^PSOBPSUT(RXIEN,0)      ;P662"
^XMB(3.9,145989,2,2033,0)="""RTN"",""PSOSPML4"",36,0)"
^XMB(3.9,145989,2,2034,0)=" S PSOASVER=$$GET1^DIQ(58.41,STATEIEN,1,""I"") S:PSOASVER="""" PSOASVER=""4.2"""
^XMB(3.9,145989,2,2035,0)="""RTN"",""PSOSPML4"",37,0)"
^XMB(3.9,145989,2,2036,0)=" S SITEIEN=$$RXSITE^PSOBPSUT(RXIEN,0)"
^XMB(3.9,145989,2,2037,0)="""RTN"",""PSOSPML4"",38,0)"
^XMB(3.9,145989,2,2038,0)=" S (PATIEN,DFN)=$$GET1^DIQ(52,RXIEN,2,""I"")"
^XMB(3.9,145989,2,2039,0)="""RTN"",""PSOSPML4"",39,0)"
^XMB(3.9,145989,2,2040,0)=" D DEM^VADPT,ADD^VADPT,SETNAME^PSOSPMUT(DFN)"
^XMB(3.9,145989,2,2041,0)="""RTN"",""PSOSPML4"",40,0)"
^XMB(3.9,145989,2,2042,0)=" S DRUGIEN=$$GET1^DIQ(52,RXIEN,6,""I"")"
^XMB(3.9,145989,2,2043,0)="""RTN"",""PSOSPML4"",41,0)"
^XMB(3.9,145989,2,2044,0)=" S FILLIEN=$S(FILLNUM[""P"":+$P(FILLNUM,""P"",2),1:+FILLNUM)"
^XMB(3.9,145989,2,2045,0)="""RTN"",""PSOSPML4"",42,0)"
^XMB(3.9,145989,2,2046,0)=" S TRXTYPE=""S"""
^XMB(3.9,145989,2,2047,0)="""RTN"",""PSOSPML4"",43,0)"
^XMB(3.9,145989,2,2048,0)=" K RTSDATA S RTSREC=0 I RECTYPE=""V"" S RTSREC=1 D LOADRTS^PSOSPMU1(RXIEN,FILLNUM,.RTSDATA)"
^XMB(3.9,145989,2,2049,0)="""RTN"",""PSOSPML4"",44,0)"
^XMB(3.9,145989,2,2050,0)=" S PREIEN=$$PREIEN^PSOSPMUT(RECTYPE,RXIEN,FILLNUM)"
^XMB(3.9,145989,2,2051,0)="""RTN"",""PSOSPML4"",45,0)"
^XMB(3.9,145989,2,2052,0)=" S RPHIEN=$$RPHIEN^PSOSPMUT(RECTYPE,RXIEN,FILLNUM)"
^XMB(3.9,145989,2,2053,0)="""RTN"",""PSOSPML4"",46,0)"
^XMB(3.9,145989,2,2054,0)=" D EN^VALM(""PSO SPMP VIEW/EXPORT RX"")"
^XMB(3.9,145989,2,2055,0)="""RTN"",""PSOSPML4"",47,0)"
^XMB(3.9,145989,2,2056,0)=" D FULL^VALM1"
^XMB(3.9,145989,2,2057,0)="""RTN"",""PSOSPML4"",48,0)"
^XMB(3.9,145989,2,2058,0)=" Q"
^XMB(3.9,145989,2,2059,0)="""RTN"",""PSOSPML4"",49,0)"
^XMB(3.9,145989,2,2060,0)=" ;"
^XMB(3.9,145989,2,2061,0)="""RTN"",""PSOSPML4"",50,0)"
^XMB(3.9,145989,2,2062,0)="HDR ; - Builds the Header section"
^XMB(3.9,145989,2,2063,0)="""RTN"",""PSOSPML4"",51,0)"
^XMB(3.9,145989,2,2064,0)=" N LINE1,LINE2,X"
^XMB(3.9,145989,2,2065,0)="""RTN"",""PSOSPML4"",52,0)"
^XMB(3.9,145989,2,2066,0)=" K VALMHDR S VALMHDR(1)=""Rx: ""_$$GET1^DIQ(52,RXIEN,.01)_"" - ""_$$GET1^DIQ(52,RXIEN,6)"
^XMB(3.9,145989,2,2067,0)="""RTN"",""PSOSPML4"",53,0)"
^XMB(3.9,145989,2,2068,0)=" S VALMHDR(1)=VALMHDR(1)_""   (Fill: ""_$S(FILLNUM[""P"":""Partial ""_$E(FILLNUM,2,9),'FILLNUM:""Original"",1:""Refill ""_FILLNUM)_"")"""
^XMB(3.9,145989,2,2069,0)="""RTN"",""PSOSPML4"",54,0)"
^XMB(3.9,145989,2,2070,0)=" S VALMHDR(2)=""Patient: ""_$$GET1^DIQ(52,RXIEN,2)_""            ASAP Version: ""_PSOASVER"
^XMB(3.9,145989,2,2071,0)="""RTN"",""PSOSPML4"",55,0)"
^XMB(3.9,145989,2,2072,0)=" Q"
^XMB(3.9,145989,2,2073,0)="""RTN"",""PSOSPML4"",56,0)"
^XMB(3.9,145989,2,2074,0)=" ;"
^XMB(3.9,145989,2,2075,0)="""RTN"",""PSOSPML4"",57,0)"
^XMB(3.9,145989,2,2076,0)="INIT ; Builds the Body section "
^XMB(3.9,145989,2,2077,0)="""RTN"",""PSOSPML4"",58,0)"
^XMB(3.9,145989,2,2078,0)=" N ASAP,LINE"
^XMB(3.9,145989,2,2079,0)="""RTN"",""PSOSPML4"",59,0)"
^XMB(3.9,145989,2,2080,0)=" ;"
^XMB(3.9,145989,2,2081,0)="""RTN"",""PSOSPML4"",60,0)"
^XMB(3.9,145989,2,2082,0)=" D CLEAN^VALM10 K ^TMP(""PSOSPML4"",$J) S VALMCNT=0,LINE=0"
^XMB(3.9,145989,2,2083,0)="""RTN"",""PSOSPML4"",61,0)"
^XMB(3.9,145989,2,2084,0)=" I PSOASVER=""1995"" D"
^XMB(3.9,145989,2,2085,0)="""RTN"",""PSOSPML4"",62,0)"
^XMB(3.9,145989,2,2086,0)=" . D SETSEG95(""PSOSPML4"",$$ASAP95^PSOASAP0(RXIEN,+FILLNUM)) S VALMCNT=LINE"
^XMB(3.9,145989,2,2087,0)="""RTN"",""PSOSPML4"",63,0)"
^XMB(3.9,145989,2,2088,0)=" I PSOASVER'=""1995"" D"
^XMB(3.9,145989,2,2089,0)="""RTN"",""PSOSPML4"",64,0)"
^XMB(3.9,145989,2,2090,0)=" . S (PSOTTCNT,PSOTPCNT)=0"
^XMB(3.9,145989,2,2091,0)="""RTN"",""PSOSPML4"",65,0)"
^XMB(3.9,145989,2,2092,0)=" . D LOADASAP^PSOSPMU0(PSOASVER,""B"",.ASAP)"
^XMB(3.9,145989,2,2093,0)="""RTN"",""PSOSPML4"",66,0)"
^XMB(3.9,145989,2,2094,0)=" . D SETSEG(""ASAP"") S VALMCNT=LINE"
^XMB(3.9,145989,2,2095,0)="""RTN"",""PSOSPML4"",67,0)"
^XMB(3.9,145989,2,2096,0)=" . S VALMSG=""Enter ?? for more actions|* Custom Segment/Element"""
^XMB(3.9,145989,2,2097,0)="""RTN"",""PSOSPML4"",68,0)"
^XMB(3.9,145989,2,2098,0)=" Q"
^XMB(3.9,145989,2,2099,0)="""RTN"",""PSOSPML4"",69,0)"
^XMB(3.9,145989,2,2100,0)=" ;"
^XMB(3.9,145989,2,2101,0)="""RTN"",""PSOSPML4"",70,0)"
^XMB(3.9,145989,2,2102,0)="SETSEG(ARRNAM) ; Sets list body with ASAP (non-1995) info (Uses Recurisivity - Call itself)"
^XMB(3.9,145989,2,2103,0)="""RTN"",""PSOSPML4"",71,0)"
^XMB(3.9,145989,2,2104,0)=" ;Input: ARRNAM - Name of the Array containing the ASAP Definition ('ASAP')"
^XMB(3.9,145989,2,2105,0)="""RTN"",""PSOSPML4"",72,0)"
^XMB(3.9,145989,2,2106,0)=" ;"
^XMB(3.9,145989,2,2107,0)="""RTN"",""PSOSPML4"",73,0)"
^XMB(3.9,145989,2,2108,0)=" N ARRAY,SEGID,DETLN,VALUE,RXLN,COLUMN,I,TMPARR,SEGTXT,LSTELM"
^XMB(3.9,145989,2,2109,0)="""RTN"",""PSOSPML4"",74,0)"
^XMB(3.9,145989,2,2110,0)=" S ARRAY=$Q(@ARRNAM) I '+$P(ARRAY,""("",2) Q"
^XMB(3.9,145989,2,2111,0)="""RTN"",""PSOSPML4"",75,0)"
^XMB(3.9,145989,2,2112,0)=" S SEGID=@ARRAY,COLUMN=(($L(ARRAY,"","")-1)*4)"
^XMB(3.9,145989,2,2113,0)="""RTN"",""PSOSPML4"",76,0)"
^XMB(3.9,145989,2,2114,0)=" ; Segment Not Used by ASAP Version"
^XMB(3.9,145989,2,2115,0)="""RTN"",""PSOSPML4"",77,0)"
^XMB(3.9,145989,2,2116,0)=" I $P(ASAP(SEGID),""^"",4)=""N"" D SETSEG(ARRAY) Q"
^XMB(3.9,145989,2,2117,0)="""RTN"",""PSOSPML4"",78,0)"
^XMB(3.9,145989,2,2118,0)=" D SETLN^PSOSPMU1(""PSOSPML4"",$P(ASAP(SEGID),""^"")_$S($$CUSSEG^PSOSPMU3(PSOASVER,SEGID):""*"",1:"""")_"" ""_$P(ASAP(SEGID),""^"",2),0,1)"
^XMB(3.9,145989,2,2119,0)="""RTN"",""PSOSPML4"",79,0)"
^XMB(3.9,145989,2,2120,0)=" D SEGCOUNT^PSOSPMUT($P(ASAP(SEGID),""^"",6))"
^XMB(3.9,145989,2,2121,0)="""RTN"",""PSOSPML4"",80,0)"
^XMB(3.9,145989,2,2122,0)=" K TMPARR S SEGTXT=SEGID"
^XMB(3.9,145989,2,2123,0)="""RTN"",""PSOSPML4"",81,0)"
^XMB(3.9,145989,2,2124,0)=" S LSTELM=+$O(ASAP(SEGID,""""),-1)"
^XMB(3.9,145989,2,2125,0)="""RTN"",""PSOSPML4"",82,0)"
^XMB(3.9,145989,2,2126,0)=" N $ETRAP,$ESTACK S $ETRAP=""D ERROR^PSOSPML4"""
^XMB(3.9,145989,2,2127,0)="""RTN"",""PSOSPML4"",83,0)"
^XMB(3.9,145989,2,2128,0)=" F I=1:1:LSTELM D"
^XMB(3.9,145989,2,2129,0)="""RTN"",""PSOSPML4"",84,0)"
^XMB(3.9,145989,2,2130,0)=" . S VALUE="""" I $P(ASAP(SEGID,I),""^"",6)'=""N"" X ""S VALUE=""_ASAP(SEGID,I,""VAL"",1)"
^XMB(3.9,145989,2,2131,0)="""RTN"",""PSOSPML4"",85,0)"
^XMB(3.9,145989,2,2132,0)=" . S VALUE=$E(VALUE,1,$P(ASAP(SEGID,I),""^"",4))"
^XMB(3.9,145989,2,2133,0)="""RTN"",""PSOSPML4"",86,0)"
^XMB(3.9,145989,2,2134,0)=" . S SEGTXT=SEGTXT_$P(ASAP,""^"",2)_VALUE"
^XMB(3.9,145989,2,2135,0)="""RTN"",""PSOSPML4"",87,0)"
^XMB(3.9,145989,2,2136,0)=" . S RXLN=$S($G(VALUE)'="""":VALUE,1:$P(ASAP,""^"",2))"
^XMB(3.9,145989,2,2137,0)="""RTN"",""PSOSPML4"",88,0)"
^XMB(3.9,145989,2,2138,0)=" . S $E(RXLN,40)=$P(ASAP(SEGID,I),""^"")_$S($G(ASAP(SEGID,I,""CUS"")):""* "",1:"" "")_$P(ASAP(SEGID,I),""^"",2)_$S($P(ASAP(SEGID,I),""^"",6)=""N"":"" (Not Used)"",1:"""")"
^XMB(3.9,145989,2,2139,0)="""RTN"",""PSOSPML4"",89,0)"
^XMB(3.9,145989,2,2140,0)=" . S TMPARR(I)=RXLN I $G(ASAP(SEGID,I,""CUS"")) S TMPARR(I,""HIGH"")=1"
^XMB(3.9,145989,2,2141,0)="""RTN"",""PSOSPML4"",90,0)"
^XMB(3.9,145989,2,2142,0)=" S SEGTXT=SEGTXT_$S(PSOASVER=""3.0"":$$TH13^PSOASAP0(),1:$$TH09^PSOASAP0())"
^XMB(3.9,145989,2,2143,0)="""RTN"",""PSOSPML4"",91,0)"
^XMB(3.9,145989,2,2144,0)=" ;"
^XMB(3.9,145989,2,2145,0)="""RTN"",""PSOSPML4"",92,0)"
^XMB(3.9,145989,2,2146,0)=" F I=1:1 Q:SEGTXT=""""  D SETLN^PSOSPMU1(""PSOSPML4"",$E(SEGTXT,1,80)) S SEGTXT=$E(SEGTXT,81,999)"
^XMB(3.9,145989,2,2147,0)="""RTN"",""PSOSPML4"",93,0)"
^XMB(3.9,145989,2,2148,0)=" F I=1:1 Q:'$D(TMPARR(I))  D SETLN^PSOSPMU1(""PSOSPML4"",TMPARR(I),,,+$G(TMPARR(I,""HIGH"")))"
^XMB(3.9,145989,2,2149,0)="""RTN"",""PSOSPML4"",94,0)"
^XMB(3.9,145989,2,2150,0)=" ;"
^XMB(3.9,145989,2,2151,0)="""RTN"",""PSOSPML4"",95,0)"
^XMB(3.9,145989,2,2152,0)=" D SETSEG(ARRAY)"
^XMB(3.9,145989,2,2153,0)="""RTN"",""PSOSPML4"",96,0)"
^XMB(3.9,145989,2,2154,0)=" Q"
^XMB(3.9,145989,2,2155,0)="""RTN"",""PSOSPML4"",97,0)"
^XMB(3.9,145989,2,2156,0)=" ;"
^XMB(3.9,145989,2,2157,0)="""RTN"",""PSOSPML4"",98,0)"
^XMB(3.9,145989,2,2158,0)="ERROR ; Error Trap Handling to catch errors on user-entered M expression"
^XMB(3.9,145989,2,2159,0)="""RTN"",""PSOSPML4"",99,0)"
^XMB(3.9,145989,2,2160,0)=" D SETLN^PSOSPMU1(""PSOSPML4"",$E($$EC^%ZOSV,1,80))"
