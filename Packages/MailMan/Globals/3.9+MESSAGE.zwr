^XMB(3.9,145958,2,1598,0)=" ;ORID=ORDER NUMBER"
^XMB(3.9,145958,2,1599,0)="""RTN"",""ORWDXA"",294,0)"
^XMB(3.9,145958,2,1600,0)=" ;RETURNS 1 IF THERE IS AN UPCARET IN THE ORDER'S COMMENTS"
