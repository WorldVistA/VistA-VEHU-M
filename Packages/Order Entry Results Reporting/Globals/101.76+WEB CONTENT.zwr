^ORW(101.76,7,1,1,0)=" // Function to handle form submission"
^ORW(101.76,7,1,2,0)=" function handleFormSubmit(event) {"
^ORW(101.76,7,1,3,0)="   event.preventDefault(); // Prevent the default form submission"
^ORW(101.76,7,1,4,0)="   let form = event.target;"
^ORW(101.76,7,1,5,0)="   let formData = new FormData(form);"
^ORW(101.76,7,1,6,0)=" "
^ORW(101.76,7,1,7,0)="   // Convert form data to a JSON object"
^ORW(101.76,7,1,8,0)="   let formObj = {};"
^ORW(101.76,7,1,9,0)="   formObj['id'] = form.id;"
^ORW(101.76,7,1,10,0)="   if (form.CloseQuery) {"
^ORW(101.76,7,1,11,0)="     formObj['CloseQuery'] = true;"
^ORW(101.76,7,1,12,0)="     form.CloseQuery = false;"
^ORW(101.76,7,1,13,0)="   }"
^ORW(101.76,7,1,14,0)="   formData.forEach(function(value, key) {"
^ORW(101.76,7,1,15,0)="     formObj[key] = value;"
^ORW(101.76,7,1,16,0)="   });"
^ORW(101.76,7,1,17,0)=" "
^ORW(101.76,7,1,18,0)="   // Add the messageType property"
^ORW(101.76,7,1,19,0)="   formObj['delphiMessage']['type'] = 'submit';"
^ORW(101.76,7,1,20,0)=" "
^ORW(101.76,7,1,21,0)="   // Send the message to Delphi"
^ORW(101.76,7,1,22,0)="   window.chrome.webview.postMessage(JSON.stringify(formObj));"
^ORW(101.76,7,1,23,0)=" }"
^ORW(101.76,7,1,24,0)=" // Event listener for the form's submit event"
^ORW(101.76,7,1,25,0)=" document.addEventListener('DOMContentLoaded', function() {"
^ORW(101.76,7,1,26,0)="   let allForms = document.forms;"
^ORW(101.76,7,1,27,0)="   for (let i = 0; i < allForms.length; i++) {"
^ORW(101.76,7,1,28,0)="     let form = allForms[i];"
^ORW(101.76,7,1,29,0)="     form.addEventListener('submit', handleFormSubmit);"
^ORW(101.76,7,1,30,0)="   }"
^ORW(101.76,7,1,31,0)=" });"
^ORW(101.76,8,0)="Submit Save^2^1"
^ORW(101.76,8,1,0)="^^10^10^3241206^"
^ORW(101.76,8,1,1,0)="    let allForms = document.forms;"
^ORW(101.76,8,1,2,0)="    for (let i = 0; i < allForms.length; i++) {"
^ORW(101.76,8,1,3,0)="        let form = allForms[i];"
^ORW(101.76,8,1,4,0)="        form.CloseQuery = false;"
^ORW(101.76,8,1,5,0)="        if (document.createEvent) {"
^ORW(101.76,8,1,6,0)="            var event = document.createEvent('HTMLEvents');"
^ORW(101.76,8,1,7,0)="            event.initEvent('submit', true, true);"
^ORW(101.76,8,1,8,0)="            form.dispatchEvent(event);"
^ORW(101.76,8,1,9,0)="        }"
^ORW(101.76,8,1,10,0)="    };"
^ORW(101.76,9,0)="Submit Query^2^1"
^ORW(101.76,9,1,0)="^^10^10^3241206^"
^ORW(101.76,9,1,1,0)="    let allForms = document.forms;"
^ORW(101.76,9,1,2,0)="    for (let i = 0; i < allForms.length; i++) {"
^ORW(101.76,9,1,3,0)="        let form = allForms[i];"
^ORW(101.76,9,1,4,0)="        form.CloseQuery = true;"
^ORW(101.76,9,1,5,0)="        if (document.createEvent) {"
^ORW(101.76,9,1,6,0)="            var event = document.createEvent('HTMLEvents');"
^ORW(101.76,9,1,7,0)="            event.initEvent('submit', true, true);"
^ORW(101.76,9,1,8,0)="            form.dispatchEvent(event);"
^ORW(101.76,9,1,9,0)="        }"
^ORW(101.76,9,1,10,0)="    };"
