^PS(58.4,1,"VER",10,"SEG",5,"DAT",13,"DES",1,0)="Freeform text for additional address information, if required by the PDMP "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",13,"DES",2,0)="and is available in pharmacy system."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",13,"VAL",0)="^58.410111^1^1^3250207^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",13,"VAL",1,0)="$$PAT13^PSOASAP()"
