^PS(58.4,1,"VER",11,"SEG",8,"DAT",7,"VAL",1,0)="$$TH07^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,0)="TH08^Routing Number/BIN^N^6^8^O"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"DES",1,0)="This field can be used for real-time transmissions that go through a "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"DES",2,0)="intermediary or network switch to indicate, if necessary, the specific "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"DES",3,0)="state that the transactions should be routed to."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",8,"VAL",1,0)="$$TH08^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,0)="TH09^Segment Terminator Character^AN^1^9^R"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",0)="^^5^5^3250415^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",1,0)="This terminates the TH segment and sets the actual value of the data "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",2,0)="segment terminator for the entire transaction."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",3,0)="Note: The ASAP 4.2a Standard document uses the ""~"" in all examples. See"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",4,0)="the ""Data Element Separators and Segment Terminators"" in the standard's"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"DES",5,0)="introduction for more information."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",9,"VAL",0)="^58.410111^1^1^3250415^^^^"
