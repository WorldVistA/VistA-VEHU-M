^PS(58.4,1,"VER",14,"SEG",5,0)="DSP^Dispensing Record^PAT^R^1^4"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",0)="^58.400111I^34^34"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",1,0)="DSP04^Refills Authorized^N^4^4^R"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",1,"DES",0)="^58.4001111^1^1^3241230^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",1,"DES",1,0)="The number of refills authorized by the prescriber."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",1,"VAL",0)="^58.410111^1^1^3241230^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",1,"VAL",1,0)="$$DSP04^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,0)="DSP06^Fill Number^N^4^6^R"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,"DES",0)="^^2^2^3250220^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,"DES",1,0)="Number of the fill of the prescription. 0 indicates original dispensing,"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,"DES",2,0)="01-99 is the refill number."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,"VAL",0)="^58.410111^1^1^3250220^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",2,"VAL",1,0)="$$DSP06^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,0)="DSP07^Product ID Qualifier^N^2^7^R"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",0)="^^10^10^3250220^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",1,0)="Used to identify the type of product ID contained in DSP08."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",2,0)="01 NDC"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",3,0)="02 UPC"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",4,0)="03 HRI"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",5,0)="04 UPN"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",6,0)="05 DIN"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",7,0)="06 Compound (Used to indicate it is a compound. The CDI"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",8,0)="segment then becomes a required segment. Also, see"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",9,0)="instructions for DSP08.)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"DES",10,0)="07 Cannabis"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"VAL",0)="^58.410111^1^1^3250220^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",3,"VAL",1,0)="$$DSP07^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,0)="DSP08^Product ID^AN^15^8^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",0)="^58.4001111^12^12^3250303^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",1,0)="Full product identification as indicated in DSP07, including zeros without"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",2,0)="punctuation."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",3,0)="If DSP07 = 01, then DSP08 should contain the 11-digit NDC code without"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",4,0)="hyphens."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",5,0)="If the product is a compound, use 99999 as the first five characters of"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",6,0)="the product code. The remaining six characters are assigned by the"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",7,0)="pharmacy. The CDI then becomes a required segment. "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",8,0)="Note: If a controlled substance is part of a kit, the NDC of the kit"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",9,0)="should be reported if it is a legitimate manufacturer's NDC. If not, the"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",10,0)="NDC of the controlled substance within the kit should be reported. Also,"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",11,0)="if multiple controlled substances are in the kit, use the CDI segment to"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"DES",12,0)="report it as a compound."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"VAL",0)="^58.410111^1^1^3250303^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",4,"VAL",1,0)="$$DSP08^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,0)="DSP12^Transmission Form of Rx Origin Code^N^2^12^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",0)="^^12^12^3250313^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",1,0)="Code indicating how the pharmacy received the prescription, if required "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",2,0)="by the PDMP."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",3,0)="01 Written Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",4,0)="02 Telephone Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",5,0)="03 Telephone Emergency Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",6,0)="04 Fax Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",7,0)="05 Electronic Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",8,0)="06 Transferred/Forwarded Rx"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",9,0)="07 Order (Administered at Prescriber Location)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",10,0)="08 Dispensed from a Prescriber Location"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",11,0)="09 Standing Order/Protocol"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"DES",12,0)="99 Other"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"VAL",0)="^58.410111^1^1^3250313^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",5,"VAL",1,0)="$$DSP12^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,0)="DSP15^Pharmacist State License Number^AN^20^15^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,"DES",0)="^58.4001111^2^2^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,"DES",1,0)="Assigned to the pharmacist by the State Licensing Board. This data "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,"DES",2,0)="element can be used to identify the pharmacist dispensing the medication."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,"VAL",0)="^58.410111^1^1^3250314^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",6,"VAL",1,0)="$$DSP15^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,0)="DSP17^Date Sold^DT^8^17^N"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",0)="^58.4001111^7^7^3250313^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",1,0)="This field is used to determine the date the prescription was dispensed"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",2,0)="(sold to, picked up by, or otherwise left the pharmacy), not the date it"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",3,0)="was prepared. This date could be captured from the point-of-sale (POS)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",4,0)="system, if the pharmacy has a POS system, and there is a bidirectional"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",5,0)="flow with the pharmacy management system in order to capture and report"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",6,0)="this date. Or it could be captured and reported from a will-call"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"DES",7,0)="management system, integrated with the pharmacy management system."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"VAL",0)="^58.410111^1^1^3250313^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",7,"VAL",1,0)="$$DSP17^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,0)="DSP18^RxNorm Product Qualifier^AN^20^18^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",0)="^^8^8^3250324^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",1,0)="01 Semantic Clinical Drug (SCD)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",2,0)="02 Semantic Branded Drug (SBD)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",3,0)="03 Generic Package (GPCK)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",4,0)="04 Branded Package (BPCK)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",5,0)="RxNorm code that is populated in the DRU-010-09 field in the SCRIPT "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",6,0)="transaction."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",7,0)="Note: DSP18 and DSP19 are placeholder fields pending RxNorm becoming an"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"DES",8,0)="industry standard. These fields should not be required until such time."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"VAL",0)="^58.410111^1^1^3250324^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",8,"VAL",1,0)="$$DSP18^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,0)="DSP19^RxNorm Code^AN^15^19^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,"DES",0)="^58.4001111^2^2^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,"DES",1,0)="Used for electronic prescriptions to capture the prescribed drug product"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,"DES",2,0)="identification, if required by the PDMP."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,"VAL",0)="^58.410111^1^1^3250314^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",9,"VAL",1,0)="$$DSP19^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,0)="DSP20^Electronic Prescription Reference Number^AN^35^20^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,"DES",0)="^58.4001111^2^2^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,"DES",1,0)="This field should be populated with the appropriate field in the SCRIPT "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,"DES",2,0)="transaction."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,"VAL",0)="^58.410111^1^1^3250314^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",10,"VAL",1,0)="$$DSP20^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,0)="DSP21^Electronic Prescription Order Number^AN^35^21^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",0)="^58.4001111^8^8^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",1,0)="This field will be populated with appropriate field in the SCRIPT "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",2,0)="standard."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",3,0)="Note: DSP20 and DSP21 should be reported as a pair to the PDMP and the "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",4,0)="PDMP will decide which one, if not both, it decides tocapture. By "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",5,0)="requiring the reporting of both, this avoids specification variations "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",6,0)="that would require custom programming to accommodate a PDMP. Also, the "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",7,0)="information reported by the pharmacy management system will depend on the "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"DES",8,0)="information received at the pharmacy with an electronic prescription."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"VAL",0)="^58.410111^1^1^3250314^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",11,"VAL",1,0)="$$DSP21^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",12,0)="DSP22^Quantity Prescribed^D^11^22^N"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",12,"DES",0)="^^1^1^3250501^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",12,"DES",1,0)="This field can clarify the value reported in DSP13 Partial Fill Indicator."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",12,"VAL",0)="^58.410111^1^1^3250501^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",12,"VAL",1,0)="$$DSP22^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,0)="DSP23^Rx SIG^AN^200^23^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"DES",0)="^58.4001111^3^3^3250329^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"DES",1,0)="This field would capture the actual directions printed on the prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"DES",2,0)="vial label. If the directions exceed 200 characters, truncation would be"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"DES",3,0)="allowed."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"VAL",0)="^58.410111^1^1^3250329^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",13,"VAL",1,0)="$$DSP23^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,0)="DSP24^Opioid Treatment Type^N^2^24^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",0)="^^21^21^3250128^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",1,0)="This field is used to explain the reason for an opioid prescription."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",2,0)="If the prescription is not for an opioid, then this field would not be"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",3,0)="used."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",4,0)="01 Not Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",5,0)="02 Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",6,0)="03 Pain Associated with Active and Aftercare Cancer Treatment"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",7,0)="04 Palliative Care in Conjunction with a Serious Illness"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",8,0)="05 End-of-Life and Hospice Care"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",9,0)="06 A Pregnant Individual with a Pre-existing Prescription for"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",10,0)="Opioids"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",11,0)="07 Acute Pain for an Individual with an Existing Opioid Prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",12,0)="for Chronic Pain"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",13,0)="08 Individuals Pursuing an Active Taper of Opioid Medications"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",14,0)="09 Patient is Participating in a Pain Management Contract"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",15,0)="10 Acute Opioid Therapy"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",16,0)="11 Chronic Opioid Therapy"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",17,0)="99 Other (trading partner agreed upon reason or not"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",18,0)="indicated)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",19,0)="The definitions of Codes 03 to 11 can only be reported if required"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",20,0)="by the state to be provided by the prescriber on the prescription"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"DES",21,0)="order."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"VAL",0)="^58.410111^1^1^3250128^^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",14,"VAL",1,0)="$$DSP24^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,0)="DSP25^Diagnosis Code^AN^7^25^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"DES",0)="^58.4001111^3^3^3250128^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"DES",1,0)="This field is used to report the ICD-10 code. If required by a PDMP, this"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"DES",2,0)="field would be populated only when the ICD-10 code is included with the"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"DES",3,0)="prescription. Exclude the decimal point."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"VAL",0)="^58.410111^1^1^3250128^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",15,"VAL",1,0)="$$DSP25^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,0)="DSP26^Time Written^TM^7^26^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"DES",0)="^^4^4^3250128^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"DES",1,0)="Time expressed in 24-hour clock time HMMSS or HHMM). Time range: 000000"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"DES",2,0)="through 235959. The time zone should be reported in Coordinated Universal"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"DES",3,0)="Time (UTC) as HHMMSSZ (e.g., 235959Z). Do not include colons or"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"DES",4,0)="non-numeric characters other than Z for Zulu time."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"VAL",0)="^58.410111^1^1^3250128^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",16,"VAL",1,0)="$$DSP26^PSOASAP1()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,0)="DSP27^Time Filled^TM^7^27^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",0)="^^5^5^3250128^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",1,0)="The time the prescription record was prepared. Time expressed in 24-hour"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",2,0)="clock time HMMSS or HHMM). Time range: 000000 through 235959. The time"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",3,0)="zone should be reported in Coordinated Universal Time (UTC) as HHMMSSZ"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",4,0)="(e.g., 235959Z). Do not include colons or non-numeric characters other"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"DES",5,0)="than Z for Zulu time."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"VAL",0)="^58.410111^1^1^3250128^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",17,"VAL",1,0)="$$DSP27^PSOASAP1()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,0)="DSP28^Time Sold^TM^7^28^N"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",0)="^58.4001111^6^6^3250313^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",1,0)="The time the prescription record was sold to, picked up by, or otherwise"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",2,0)="left the pharmacy for the patient. Time expressed in 24-hour clock time"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",3,0)="HMMSS or HHMM). Time range: 000000 through 235959. The time zone should be"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",4,0)="reported in Coordinated Universal Time (UTC) as HHMMSSZ (e.g., 235959Z)."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",5,0)="Do not include colons or non-numeric characters other than Z for Zulu"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"DES",6,0)="time."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"VAL",0)="^58.410111^1^1^3250313^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",18,"VAL",1,0)="$$DSP28^PSOASAP1()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,0)="DSP29^Total Quantity Remaining on Prescription^D^11^29^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"DES",0)="^58.4001111^4^4^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"DES",1,0)="Identifies the unit of measure for the total quantity remaining for the "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"DES",2,0)="prescription after the current dispense in metric decimal format. "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"DES",3,0)="Example: 2.5. Note: For compounding show the first quantity in CDI04."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"DES",4,0)="ASAP version 5.0 Standard Appendix B has specific instructions."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"VAL",0)="^58.410111^1^1^3250314^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",19,"VAL",1,0)="$$DSP29^PSOASAP1()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,0)="DSP30^Total Quantity Remaining Drug Dosage Units Code^N^2^30^O"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",0)="^58.4001111^6^6^3250314^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",1,0)="Identifies the unit of measure for the quantity remaining in DSP29. ASAP "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",2,0)="version 5.0 Standard has specific instructions."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",3,0)="01 Each (used to report solid dosage units or indivisible package)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",4,0)="02 Milliliters (ml) (for liters adjust to the decimal milliliter "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",5,0)="equivalent)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"DES",6,0)="03 Grams (gm) (for milligrams adjust to the decimal gram equivalent)"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"VAL",0)="^58.410111^1^1^3250314^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",20,"VAL",1,0)="$$DSP30^PSOASAP1()"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,0)="DSP31^Discount Card^N^2^31^O"
