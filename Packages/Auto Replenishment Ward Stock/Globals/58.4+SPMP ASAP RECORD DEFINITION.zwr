^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,0)="PRE01^National Provider Identifier (NPI)^AN^10^1^O"
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"DES",0)="^^4^4^3250316^"
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"DES",1,0)="Identifier assigned to the prescriber by CMS."
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"DES",2,0)="Note: If the prescriber does not have a DEA number, and prescribed a "
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"DES",3,0)="noncontrolled substance that is a reportable drug to the PDMP, this field "
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"DES",4,0)="should be used as the identifier."
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",7,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,0)="PRE02^DEA Number^AN^9^2^R"
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,"DES",1,0)="Identifying number assigned to a prescriber or an institution by the Drug "
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,"DES",2,0)="Enforcement Administration (DEA). Required when the prescription is for a "
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,"DES",3,0)="DEA-defined controlled substance."
^PS(58.4,1,"VER",13,"SEG",7,"DAT",2,"VAL",0)="^58.410111^1^1^3250316^^"
