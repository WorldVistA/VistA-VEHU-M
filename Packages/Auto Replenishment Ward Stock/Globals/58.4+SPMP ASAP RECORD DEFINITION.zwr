^PS(58.4,1,"VER",13,"SEG",5,"DAT",7,"DES",1,0)="Patient's last name."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",7,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",7,"VAL",1,0)="""REPORT"""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",8,0)="PAT08^First Name^AN^50^8^R"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",8,"DES",0)="^58.4001111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",8,"DES",1,0)="Patient's first name."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",8,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",8,"VAL",1,0)="""ZERO"""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,0)="PAT09^Middle Name^AN^30^9^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,"DES",0)="^58.4001111^2^2^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,"DES",1,0)="Patient's middle name or initial if available. Used if available in "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,"DES",2,0)="pharmacy system and required by the PDMP."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,"VAL",0)="^58.410111^1^1^3250316^^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",9,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,0)="PAT10^Name Prefix^AN^10^10^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,"DES",0)="^^2^2^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,"DES",1,0)="Patient's name prefix such as Mr. or Dr. Used if available in pharmacy "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,"DES",2,0)="system and required by the PDMP."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",10,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,0)="PAT11^Name Suffix^AN^10^11^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,"DES",0)="^^2^2^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,"DES",1,0)="Patient's name suffix such as Jr. or the III. Used if available in "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,"DES",2,0)="pharmacy system and if required by the PDMP."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",11,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,0)="PAT12^Address Information - 1^AN^55^12^R"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",0)="^^7^7^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",1,0)="Field size has been increased to 55 bytes from 35 bytes. However, in "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",2,0)="order to accommodate pharmacy management systems storing 35 bytes or less "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",3,0)="for the patient address, no programming change is necessary if that is "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",4,0)="the maximum length"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",5,0)="of the field in the pharmacy management system. If the address stored in "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",6,0)="the system is a P.O. box number, defer to the specifications of the PDMP "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"DES",7,0)="as to whether this should be reported in PAT12 or PAT13."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",12,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",13,0)="PAT13^Address Information - 2^AN^55^13^O"
