^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,0)="PAT07^Last Name^AN^50^7^R"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",0)="^^10^10^3250313^"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",1,0)="Patient's last name."
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",2,0)="Recommended way to report:"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",3,0)="Report the patient's complete legal last name ONLY as listed on a "
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",4,0)="government-issued identification"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",5,0)="Do NOT report extraneous information or notes in this field"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",6,0)="Do NOT enter Prefix or Suffix in Last Name field"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",7,0)="Do NOT report special characters (e.g., parentheses, asterisk) other than "
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",8,0)="a hyphen or apostrophe."
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",9,0)="If for a veterinary patient, enter information of PERSON responsible for "
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"DES",10,0)="the care of the animal or who arranges for the animal's veterinary care"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"VAL",0)="^58.410111^1^1^3250313^^^^"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",7,"VAL",1,0)="""REPORT"""
