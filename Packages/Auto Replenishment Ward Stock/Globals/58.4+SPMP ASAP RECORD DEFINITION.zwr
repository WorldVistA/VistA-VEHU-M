^PS(58.4,1,"VER",10,"SEG",1,"DAT",9,"DES",1,0)="Last name or initials of the pharmacist dispensing the medication, if "
^PS(58.4,1,"VER",10,"SEG",1,"DAT",9,"DES",2,0)="required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",1,"DAT",9,"VAL",0)="^58.410111^1^1^3250312^"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",9,"VAL",1,0)="$$AIR09^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",10,0)="AIR10^First Name of Pharmacist^AN^50^10^O"
