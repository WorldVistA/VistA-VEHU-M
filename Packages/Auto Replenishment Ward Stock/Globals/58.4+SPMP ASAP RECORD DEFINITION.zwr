^PS(58.4,1,"VER",13,"SEG",5,"DAT",15,"DES",2,0)="Note: Field has been sized to handle international patients not residing "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",15,"DES",3,0)="in the U.S."
