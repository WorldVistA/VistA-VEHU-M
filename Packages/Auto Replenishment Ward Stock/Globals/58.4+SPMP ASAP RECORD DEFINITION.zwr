^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,0)="DSP01^Reporting Status^N^2^1^R"
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",0)="^58.4001111^10^10^3201012^"
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",1,0)="Required when reporting a change or cancellation of a previously "
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",2,0)="transmitted prescription record. 00 indicates a new prescription "
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",3,0)="dispensing transaction. 01 would be used when information on the"
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",4,0)="original prescription, including patient information, has been changed. "
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",5,0)="02 would be used when the prescription was not picked up and returned to "
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",6,0)="stock."
^PS(58.4,1,"VER",8,"SEG",3,"DAT",1,"DES",7,0)="  00 New Record (Not available for ASAP 4.0)"
