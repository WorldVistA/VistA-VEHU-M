^PS(58.4,1,"VER",13,"SEG",8,"DAT",1,0)="TH01^Version / Release Number^AN^4^1^R"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",1,"DES",0)="^58.4001111^3^3^3250407^^^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",1,"DES",1,0)="Used to identify the transaction Version/Release."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",1,"DES",2,0)="Format = x.x 4.2B "
