^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"DES",1,0)="Sender assigned code uniquely identifying a transaction. This number must"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"DES",2,0)="be used in TT01. "
^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"DES",3,0)="Recommendation: Use a Globally Unique Identifier (GUID) or other"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"DES",4,0)="nonrepeating alphanumeric combination to populate this field."
^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"VAL",0)="^58.410111^1^1^3250319^^^^"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",3,"VAL",1,0)="$$TH02^PSOASAP()"
