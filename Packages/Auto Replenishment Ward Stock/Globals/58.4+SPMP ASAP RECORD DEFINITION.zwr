^PS(58.4,1,"VER",11,"SEG",8,"DAT",1,"VAL",1,0)="""4.2A"""
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,0)="TH02^Transaction Control Number^AN^40^2^R"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"DES",0)="^^4^4^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"DES",1,0)="Sender assigned code uniquely identifying a transaction.  This number "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"DES",2,0)="must be used in TT01."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"DES",3,0)="Recommendation: Use a Globally Unique Identifier (GUID) or other "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"DES",4,0)="nonrepeating alphanumeric combination to populate this field."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"VAL",0)="^58.410111^1^1^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",2,"VAL",1,0)="$$TH02^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,0)="TH03^Transaction Type^N^2^3^O"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",0)="^^9^9^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",1,0)="Identifies the purpose of initiating the transaction."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",2,0)="01 Send/Request Transaction"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",3,0)="02 Acknowledgment (Used in Response only.)"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",4,0)="03 Error Receiving (Used in Response only.)"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",5,0)="04 Void (Used to void a specific Rx in a real-time transmission, or an "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",6,0)="entire batch file that has been transmitted."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",7,0)="When 04 is used the appropriate transaction control number in TH02 for "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",8,0)="the specific prescription or batch file must be included. When 04 is used "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"DES",9,0)="only the TH Header Segment and the Transaction Trailer Segment are used.)"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"VAL",0)="^58.410111^1^1^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",3,"VAL",1,0)="$$TH03^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,0)="TH04^Response ID^AN^40^4^O"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,"DES",1,0)="Contains the Transaction Control Number of a transaction that initiated "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,"DES",2,0)="the transaction. Required in response transaction only."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",4,"VAL",1,0)="$$TH04^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",5,0)="TH05^Creation Date^DT^8^5^R"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",5,"DES",0)="^^1^1^3201007"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",5,"DES",1,0)="Date the transaction was created. Format: CCYYMMDD."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",5,"VAL",0)="^^1^1^3201007"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",5,"VAL",1,0)="$$TH05^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,0)="TH06^Creation Time^TM^6^6^R"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,"DES",0)="^^2^2^3250325^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,"DES",1,0)="Time the transaction was created. Format: HHMMSS or HHMM. Do not use "
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,"DES",2,0)="colons or other nonnumeric characters."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,"VAL",0)="^58.410111^1^1^3250325^"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",6,"VAL",1,0)="$$TH06^PSOASAP()"
