^PS(58.4,1,"VER",1,"SEG",1,"DAT",3,"DES",5,0)="  04 Void (Used to void an Rx in real-time transmission or a batch)"
^PS(58.4,1,"VER",1,"SEG",1,"DAT",3,"VAL",0)="^^1^1^3151115^"
^PS(58.4,1,"VER",1,"SEG",1,"DAT",3,"VAL",1,0)="$$TH03^PSOASAP()"
