^PS(58.4,1,"VER",13,"SEG",1,"DAT",2,"DES",1,0)="Number assigned to state issued serialized prescription blank. Required "
^PS(58.4,1,"VER",13,"SEG",1,"DAT",2,"DES",2,0)="if state issues serialized prescription pads for prescribers to use."
^PS(58.4,1,"VER",13,"SEG",1,"DAT",2,"VAL",0)="^58.410111^1^1^3250221^^"
