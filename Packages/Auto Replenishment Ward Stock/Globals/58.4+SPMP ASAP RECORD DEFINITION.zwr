^PS(58.4,1,"VER",10,"SEG",1,"DAT",5,"DES",6,0)="only the unadorned customer ID and no additional information be entered "
^PS(58.4,1,"VER",10,"SEG",1,"DAT",5,"DES",7,0)="into this field."
