^PS(58.4,1,"VER",10,"SEG",1,"DAT",10,"DES",1,0)="First name of the pharmacist dispensing the medication, if required by "
^PS(58.4,1,"VER",10,"SEG",1,"DAT",10,"DES",2,0)="the PDMP."
