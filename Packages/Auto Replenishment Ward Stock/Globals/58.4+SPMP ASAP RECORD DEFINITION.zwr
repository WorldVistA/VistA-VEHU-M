^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,0)="PAT06^Additional ID^AN^20^6^O"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"DES",0)="^^3^3^3250207^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"DES",1,0)="Identification that might be required by the PDMP to further identify the"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"DES",2,0)="individual. An example might be in that PAT03 driver's license is required"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"DES",3,0)="and in PAT06 Social Security number is also required."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",6,"VAL",1,0)="$$PAT06^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,0)="PAT09^Middle Name^AN^30^9^O"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,"DES",0)="^^2^2^3250207^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,"DES",1,0)="Patient's middle name or initial if available. Used if available in "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,"DES",2,0)="pharmacy system and required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",9,"VAL",1,0)="$$PAT09^PSOASAP()"
