^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"DES",3,0)="classification payment code is 01 (Private Pay) or 04 (Commercial"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"DES",4,0)="Insurance) used in DSP16. "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"DES",5,0)="01 Yes"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"DES",6,0)="02 No"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"VAL",0)="^^1^1^3241227^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",21,"VAL",1,0)="$$DSP31^PSOASAP1()"
