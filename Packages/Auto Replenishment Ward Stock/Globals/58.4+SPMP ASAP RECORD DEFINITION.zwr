^PS(58.4,1,"VER",11,"SEG",4,0)="IS^Information Source^TH^R^1^1"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",0)="^58.400111I^3^3"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,0)="IS01^Unique Information Source ID^AN^10^1^R"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"DES",0)="^^3^3^3250407^"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"DES",1,0)="Reference number or identification number as defined by the business "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"DES",2,0)="partners. (Example: Phone number. However, if a phone number is used to "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"DES",3,0)="populate this field, do not include hyphens)."
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"VAL",0)="^58.410111^1^1^3250407^"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",1,"VAL",1,0)="$$IS01^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",2,0)="IS02^Information Source Entity Name^AN^60^2^R"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",2,"DES",0)="^^1^1^3201007"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",2,"DES",1,0)="Entity name of the Information Source."
^PS(58.4,1,"VER",11,"SEG",4,"DAT",2,"VAL",0)="^^1^1^3201007"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",2,"VAL",1,0)="$$IS02^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,0)="IS03^Message^AN^60^3^O"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",0)="^58.4001111^13^13^3250415^^^"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",1,0)="Freeform text message. Use of this field is defined by the PDMP. "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",2,0)="Many PDMPs may designate this field to hold the submission period date "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",3,0)="range of the file transmitted. When used to indicate the date range, it "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",4,0)="must be the first data text in the field and must be inserted with using "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",5,0)="the following layout (where ""#"" and ""-"" are those literal characters): "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",6,0)="#CCYYMMDD#-#CCYYMMDD#"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",7,0)="For example, a pharmacy may be submitting records for the reporting "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",8,0)="period of March 1, 2012 through March 7, 2012 but only filled reportable "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",9,0)="prescriptions on March 3, and March 5. The full submission period date "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",10,0)="range would be reported in IS03 as #20120301#-#20120307# "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",11,0)="It is up to the PDMP to further define how to enter the submission date "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",12,0)="range for exceptional cases, such as for late submission records."
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"DES",13,0)="Note: IS03 can also be used to show the date range for Zero Reports   "
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"VAL",0)="^58.410111^1^1^3250325^^^^"
^PS(58.4,1,"VER",11,"SEG",4,"DAT",3,"VAL",1,0)="$$IS03^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",4,"DAT","B","IS01",1)=""
^PS(58.4,1,"VER",11,"SEG",4,"DAT","B","IS02",2)=""
^PS(58.4,1,"VER",11,"SEG",4,"DAT","B","IS03",3)=""
^PS(58.4,1,"VER",11,"SEG",5,0)="PAT^Patient Information^PHA^R^1^3"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",0)="^58.400111I^19^19"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,0)="PAT01^ID Qualifier of Patient Identifier^AN^2^1^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"DES",0)="^58.4001111^3^3^3250325^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT03."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"DES",2,0)="Used if the PDMP requires such identification."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"DES",3,0)="ASAP version 4.2a Standard Appendix A lists jurisdictions."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"VAL",0)="^58.410111^1^1^3250325^^^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,0)="PAT02^ID Qualifier^N^2^2^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",0)="^58.4001111^11^11^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",1,0)="Code to identify the type of ID in PAT03. If PAT02 is used, PAT03 is "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",2,0)="required."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",3,0)="  01 Military ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",4,0)="  02 State Issued ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",5,0)="  03 Unique System ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",6,0)="  04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",7,0)="  05 Passport ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",8,0)="  06 Driver's License ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",9,0)="  07 Social Security Number"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",10,0)="  08 Tribal ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"DES",11,0)="  99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"VAL",0)="^^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",2,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,0)="PAT03^ID of Patient^AN^20^3^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,"DES",0)="^58.4001111^2^2^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,"DES",1,0)="Identification number for the patient as indicated in PAT02. An example "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,"DES",2,0)="would be the driver's license number."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,"VAL",0)="^^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",3,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,0)="PAT04^ID Qualifier of Additional Patient Identifier^AN^2^4^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT06. Used if "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"DES",2,0)="the PDMP requires such identification. ASAP version 4.2a Standard "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"DES",3,0)="Appendix A lists jurisdictions."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"VAL",0)="^58.410111^1^1^3250317^^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",4,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,0)="PAT05^Additional Patient ID Qualifier^N^2^5^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",0)="^58.4001111^11^11^3250325^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",1,0)="Code to identify the type of ID in PAT06 if the PDMP requires a second "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",2,0)="identifier. If PAT05 is used, PAT06 is required."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",3,0)="01 Military ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",4,0)="02 State Issued ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",5,0)="03 Unique System ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",6,0)="04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",7,0)="05 Passport ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",8,0)="06 Driver's License ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",9,0)="07 Social Security Number"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",10,0)="08 Tribal ID"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"DES",11,0)="99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"VAL",0)="^58.410111^1^1^3250325^^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",5,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,0)="PAT06^Additional ID^AN^20^6^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"DES",1,0)="Identification that might be required by the PDMP to further identify the "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"DES",2,0)="individual. An example might be in that PAT03 driver's license is "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"DES",3,0)="required and in PAT06 Social Security number is also required."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",6,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",7,0)="PAT07^Last Name^AN^50^7^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",7,"DES",0)="^58.4001111^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",7,"DES",1,0)="Patient's last name."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",7,"VAL",0)="^^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",7,"VAL",1,0)="""REPORT"""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",8,0)="PAT08^First Name^AN^50^8^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",8,"DES",0)="^58.4001111^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",8,"DES",1,0)="Patient's first name."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",8,"VAL",0)="^^1^1^3201009^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",8,"VAL",1,0)="""ZERO"""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,0)="PAT09^Middle Name^AN^30^9^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,"DES",1,0)="Patient's middle name or initial if available. Used if available in "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,"DES",2,0)="pharmacy system and required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",9,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,0)="PAT10^Name Prefix^AN^10^10^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,"DES",1,0)="Patient's name prefix such as Mr. or Dr. Used if available in pharmacy "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,"DES",2,0)="system and required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",10,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,0)="PAT11^Name Suffix^AN^10^11^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,"DES",1,0)="Patient's name suffix such as Jr. or the III. Used if available in "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,"DES",2,0)="pharmacy system and if required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",11,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,0)="PAT12^Address Information - 1^AN^35^12^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",0)="^^7^7^3250325^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",1,0)="Field size has been increased to 35 bytes from 30 bytes in 4.1. However, "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",2,0)="in order to accommodate pharmacy management systems storing 30 bytes or "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",3,0)="less for the patient address, no programming change is necessary if that "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",4,0)="is the maximum length of the field in the pharmacy management system. If"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",5,0)="the address stored in the system is a P.O. box number, defer to the"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",6,0)="specifications of the PDMP as to whether this should be reported in PAT12"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"DES",7,0)="or PAT13."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"VAL",0)="^58.410111^1^1^3250325^^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",12,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,0)="PAT13^Address Information - 2^AN^35^13^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,"DES",1,0)="Freeform text for additional address information, if required by the PDMP "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,"DES",2,0)="and is available in pharmacy system."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",13,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",14,0)="PAT14^City Address^AN^20^14^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",14,"DES",0)="^^1^1^3250325^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",14,"DES",1,0)="Freeform text for city name."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",14,"VAL",0)="^58.410111^1^1^3250325^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",14,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,0)="PAT15^State Address^AN^10^15^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"DES",1,0)="U.S. Postal Service state code if required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"DES",2,0)="Note: Field has been sized to handle international patients not residing "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"DES",3,0)="in the U.S."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",15,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,0)="PAT16^ZIP Code Address^AN^9^16^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,"DES",0)="^58.4001111^2^2^3250415^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,"DES",1,0)="U.S. Postal Service ZIP code. Postal code will be reported for non-U.S. "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,"DES",2,0)="addresses."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,"VAL",0)="^58.410111^1^1^3250325^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",16,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,0)="PAT17^Phone Number^AN^10^17^O"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"DES",1,0)="Complete phone number including area code when a state PDMP requires and "
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"DES",2,0)="is available in the pharmacy system."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"DES",3,0)="Note: Do not include hyphens in the number."
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",17,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",5,"DAT",18,0)="PAT18^Date of Birth^DT^8^18^R"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",18,"DES",0)="^58.4001111^1^1^3250325^^"
^PS(58.4,1,"VER",11,"SEG",5,"DAT",18,"DES",1,0)="Date patient was born. Format: CCYYMMDD."
