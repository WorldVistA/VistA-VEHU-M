^PS(58.4,1,"VER",10,"SEG",1,"DAT",10,"VAL",1,0)="$$AIR10^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,0)="AIR11^Dropping Off/Picking Up Identifier Qualifier^N^2^11^O"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",0)="^58.4001111^11^11^3250314^^^"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",1,0)="Additional qualifier for the ID contained in AIR05."
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",2,0)="  01 Person Dropping Off"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",3,0)="  02 Person Picking Up"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",4,0)="  98 Unknown/Not Applicable (An example of Unknown: Where the"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",5,0)="pharmacist does not know which person it is. Or there is no ID to collect"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",6,0)="at drop-off, such as when a prescription is phoned in. An example of Not"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",7,0)="Applicable: When the prescription is delivered.) "
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",8,0)="Note: Both 01 and 02 cannot be required by a PDMP. Usage of this field"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",9,0)="depends on whether a PDMP has interest in knowing whether the information"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",10,0)="supplied in fields AIR04-AIR08 is for the person dropping off or picking"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"DES",11,0)="up the prescription."
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"VAL",0)="^58.410111^1^1^3250314^^^^"
^PS(58.4,1,"VER",10,"SEG",1,"DAT",11,"VAL",1,0)="$$AIR11^PSOASAP()"
