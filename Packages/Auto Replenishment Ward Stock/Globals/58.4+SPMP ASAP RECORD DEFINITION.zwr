^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,0)="AIR01^State Issuing Rx Serial Number^AN^2^1^O"
^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,"DES",1,0)="U.S.P.S. state code of state that issued serialized prescription blank. "
^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,"DES",2,0)="This is required if AIR02 is used. "
^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,"DES",3,0)="ASAP version 4.2b Standard Appendix A lists jurisdictions."
