^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",0)="^^10^10^3250319^"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",1,0)="Identifies the purpose of initiating the transaction."
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",2,0)=" "
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",3,0)="01 Send/Request Transaction"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",4,0)="02 Acknowledgment (Used in Response only.)"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",5,0)="03 Error Receiving (Used in Response only.)"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",6,0)="04 Void (Used to void a specific Rx in a real-time transmission, or an"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",7,0)="entire batch file that has been transmitted. When 04 is used the"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",8,0)="appropriate transaction control number in TH02 for the specific"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",4,"DES",9,0)="prescription or batch file must be included. When 04 is used only the TH"
