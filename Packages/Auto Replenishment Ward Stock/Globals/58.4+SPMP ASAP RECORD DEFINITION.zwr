^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"DES",0)="^58.4001111^3^3^3250408^^^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"DES",1,0)="This field can be used for real-time transmissions that go through an "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"DES",2,0)="intermediary or network switch to indicate, if necessary, the specific "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"DES",3,0)="state that the transactions should be routed to."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"VAL",0)="^^1^1^3250408^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",8,"VAL",1,0)="$$TH08^PSOASAP()"
