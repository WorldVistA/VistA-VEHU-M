^PS(58.4,1,"VER",13,"SEG",1,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",1,"DAT",2,0)="AIR02^State Issued Rx Serial Number^AN^20^2^O"
