^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"DES",1,0)="Used when the patient's address is a foreign country. This is a freeform "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"DES",2,0)="text field. ASAP does not provide a list of countries for this field. "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"DES",3,0)="PDMPs may permit some of the other address fields to not be used if this "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"DES",4,0)="field is populated."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",22,"VAL",1,0)="$$PAT22^PSOASAP()"
