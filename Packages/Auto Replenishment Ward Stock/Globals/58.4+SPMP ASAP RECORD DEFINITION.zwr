^PS(58.4,1,"VER",13,"SEG",8,"DAT",1,"VAL",1,0)="""4.2B"""
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,0)="TH02^Transaction Control Number^AN^40^2^R"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"DES",0)="^^4^4^3250408^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"DES",1,0)="Sender assigned code uniquely identifying a transaction. This number must "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"DES",2,0)="be used in TT01."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"DES",3,0)="Recommendation: Use a Globally Unique Identifier (GUID) or other "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"DES",4,0)="nonrepeating alphanumeric combination to populate this field."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"VAL",0)="^58.410111^1^1^3250408^^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",2,"VAL",1,0)="$$TH02^PSOASAP()"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,0)="TH03^Transaction Type^N^2^3^O"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",0)="^^9^9^3250316^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",1,0)="Identifies the purpose of initiating the transaction."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",2,0)="01 Send/Request Transaction"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",3,0)="02 Acknowledgment (Used in Response only.)"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",4,0)="03 Error Receiving (Used in Response only.)"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",5,0)="04 Void (Used to void a specific Rx in a real-time transmission, or an "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",6,0)="entire batch file that has been transmitted."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",7,0)="When 04 is used the appropriate transaction control number in TH02 for "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",8,0)="the specific prescription or batch file must be included. When 04 is used "
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"DES",9,0)="only the TH Header Segment and the Transaction Trailer Segment are used.)"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"VAL",0)="^58.410111^1^1^3250316^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",3,"VAL",1,0)="$$TH03^PSOASAP()"
