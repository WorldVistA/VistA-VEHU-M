^PS(58.4,1,"VER",10,"SEG",5,"DAT",17,"DES",0)="^^3^3^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",17,"DES",1,0)="Complete phone number including area code when a state PDMP requires and"
