^PS(58.4,1,"VER",10,"SEG",5,"DAT",15,0)="PAT15^State Address^AN^10^15^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",15,"DES",0)="^^3^3^3250415^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",15,"DES",1,0)="U.S. Postal Service state code if required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",15,"DES",2,0)="Note: Field has been sized to handle international patients not residing"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",15,"DES",3,0)="in the U.S."
