^PS(58.4,1,"VER",13,"SEG",4,0)="IS^Information Source^TH^R^1^1"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",0)="^58.400111I^3^3"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,0)="IS01^Unique Information Source ID^AN^10^1^R"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"DES",1,0)="Reference number or identification number as defined by the business "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"DES",2,0)="partners. (Example: Phone number. However, if a phone number is used to "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"DES",3,0)="populate this field, do not include hyphens.)"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"VAL",0)="^58.410111^1^1^3250316^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",1,"VAL",1,0)="$$IS01^PSOASAP()"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",2,0)="IS02^Information Source Entity Name^AN^60^2^R"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",2,"DES",0)="^58.4001111^1^1^3250316^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",2,"DES",1,0)="Entity name of the Information Source."
^PS(58.4,1,"VER",13,"SEG",4,"DAT",2,"VAL",0)="^58.410111^1^1^3250316^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",2,"VAL",1,0)="$$IS02^PSOASAP()"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,0)="IS03^Message^AN^60^3^O"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",0)="^58.4001111^14^14^3250415^^^^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",1,0)="Freeform text message. Use of this field is defined by the PDMP. Many "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",2,0)="PDMPs may designate this field to hold the submission period date range "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",3,0)="of the file transmitted. When used to indicate the date range, it must be "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",4,0)="the first data text in the field and must be inserted with using the "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",5,0)="following layout (where ""#"" and ""-"" are those literal characters): "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",6,0)="#CCYYMMDD#-#CCYYMMDD#"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",7,0)="For example, a pharmacy may be submitting records for the reporting "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",8,0)="period of December 5, 2019 through December 11, 2019 but only filled "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",9,0)="reportable prescriptions on December 5 and December 7. The full "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",10,0)="submission period date range would be reported in IS03 as "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",11,0)="#20191205#-#20191211#"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",12,0)="It is up to the PDMP to further define how to enter the submission date "
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",13,0)="range for exceptional cases, such as for late submission records."
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"DES",14,0)="Note: IS03 can also be used to show the date range for Zero Reports."
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"VAL",0)="^58.410111^1^1^3250407^^^^"
^PS(58.4,1,"VER",13,"SEG",4,"DAT",3,"VAL",1,0)="$$IS03^PSOASAP()"
^PS(58.4,1,"VER",13,"SEG",4,"DAT","B","IS01",1)=""
^PS(58.4,1,"VER",13,"SEG",4,"DAT","B","IS02",2)=""
^PS(58.4,1,"VER",13,"SEG",4,"DAT","B","IS03",3)=""
^PS(58.4,1,"VER",13,"SEG",5,0)="PAT^Patient Information^PHA^R^1^3"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",0)="^58.400111I^23^23"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,0)="PAT01^ID Qualifier of Patient Identifier^AN^2^1^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT03."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"DES",2,0)="Used if the PDMP requires such identification."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"DES",3,0)="ASAP version 4.2b Standard Appendix A lists jurisdictions."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"VAL",0)="^58.410111^1^1^3250316^^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,0)="PAT02^ID Qualifier^N^2^2^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",0)="^^13^13^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",1,0)="Code to identify the type of ID in PAT03. If PAT02 is used, PAT03 is "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",2,0)="required."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",3,0)="01 Military ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",4,0)="02 State Issued ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",5,0)="03 Unique System ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",6,0)="04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",7,0)="05 Passport ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",8,0)="06 Driver's License ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",9,0)="07 Social Security Number"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",10,0)="08 Tribal ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",11,0)="09 Vendor Specific (such as Appriss Health, Experian, LexisNexis)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",12,0)="10 Veterinary Patient Microchip Number"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"DES",13,0)="99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",2,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,0)="PAT03^ID of Patient^AN^20^3^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"DES",1,0)="Identification number for the patient as indicated in PAT02.  An example "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"DES",2,0)="would be the driver's license number.  Note: This field can only be "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"DES",3,0)="populated with code 10 when provided on the prescription."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",3,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,0)="PAT04^ID Qualifier of Additional Patient Identifier^AN^2^4^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT06. Used if "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"DES",2,0)="the PDMP requires such identification.  ASAP version 4.2b Standard "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"DES",3,0)="Appendix A lists jurisdictions."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",4,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,0)="PAT05^Additional Patient ID Qualifier^N^2^5^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",0)="^^13^13^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",1,0)="Code to identify the type of ID in PAT06 if the PDMP requires a second "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",2,0)="identifier. If PAT05 is used, PAT06 is required."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",3,0)="01 Military ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",4,0)="02 State Issued ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",5,0)="03 Unique System ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",6,0)="04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",7,0)="05 Passport ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",8,0)="06 Driver's License ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",9,0)="07 Social Security Number"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",10,0)="08 Tribal ID"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",11,0)="09 Vendor Specific (such as Appriss Health, Experian, LexisNexis)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",12,0)="10 Veterinary Patient Microchip Number"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"DES",13,0)="99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",5,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,0)="PAT06^Additional ID^AN^20^6^O"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"DES",1,0)="Identification that might be required by the PDMP to further identify the "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"DES",2,0)="individual. An example might be in that PAT03 driver's license is "
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"DES",3,0)="required and in PAT06 Social Security number is also required."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",6,"VAL",1,0)=""""""
