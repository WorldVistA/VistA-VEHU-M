^PS(58.4,1,"VER",12,"SEG",5,"DAT",23,"DES",1,0)="Used if required by the PDMP for prescriptions written by a veterinarian "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",23,"DES",2,0)="and the pharmacist has access to this information at the time of "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",23,"DES",3,0)="preparing the prescription."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",23,"VAL",0)="^58.410111^1^1^3250304^^"
