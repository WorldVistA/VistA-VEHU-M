^PS(58.4,1,"VER",12,"SEG",7,0)="PRE^Prescriber Information^DSP^R^1^4"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",0)="^58.400111I^10^10"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,0)="PRE01^National Provider Identifier (NPI)^AN^10^1^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"DES",0)="^^4^4^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"DES",1,0)="Identifier assigned to the prescriber by CMS."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"DES",2,0)="Note: If the prescriber does not have a DEA number, and prescribed a "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"DES",3,0)="noncontrolled substance that is a reportable drug to the PDMP, this field "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"DES",4,0)="should be used as the identifier."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",1,"VAL",1,0)="$$PRE01^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,0)="PRE02^DEA Number^AN^9^2^R"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"DES",0)="^^3^3^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"DES",1,0)="Identifying number assigned to a prescriber or an institution by the Drug "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"DES",2,0)="Enforcement Administration (DEA).  Required when the prescription is for "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"DES",3,0)="a DEA-defined controlled substance."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",2,"VAL",1,0)="$$PRE02^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,0)="PRE03^DEA Number Suffix^AN^7^3^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,"DES",0)="^^2^2^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,"DES",1,0)="Identifying number assigned to a prescriber by an institution when the "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,"DES",2,0)="institution's DEA number is used, if required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",3,"VAL",1,0)="$$PRE03^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,0)="PRE04^Prescriber License Number^AN^20^4^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"DES",0)="^58.4001111^3^3^3250319^^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"DES",1,0)="Identification assigned to the prescriber by the State Licensing Board of "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"DES",2,0)="a state or jurisdiction. This field can be used for veterinarian "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"DES",3,0)="prescriptions. Used if required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"VAL",0)="^58.410111^1^1^3250319^^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",4,"VAL",1,0)="$$PRE04^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",5,0)="PRE05^Last Name^AN^50^5^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",5,"DES",0)="^^1^1^3250324^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",5,"DES",1,0)="Prescriber's last name. Used if required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",5,"VAL",0)="^58.410111^1^1^3250324^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",5,"VAL",1,0)="$$PRE05^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",6,0)="PRE06^First Name^AN^50^6^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",6,"DES",0)="^^1^1^3250324^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",6,"DES",1,0)="Prescriber's first name. Used if required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",6,"VAL",0)="^58.410111^1^1^3250324^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",6,"VAL",1,0)="$$PRE06^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,0)="PRE07^Middle Name^AN^30^7^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,"DES",0)="^^2^2^3250207"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,"DES",1,0)="Prescriber's middle name or initial. Used if required and is available in "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,"DES",2,0)="the pharmacy system."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,"VAL",0)="^^1^1^3250207"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",7,"VAL",1,0)="$$PRE07^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",8,0)="PRE08^Phone Number^AN^10^8^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",8,"DES",0)="^58.4001111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",8,"DES",1,0)="The prescriber's primary phone number."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",8,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",8,"VAL",1,0)="$$PRE08^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,0)="PRE09^XDEA Number^AN^9^9^N"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,"DES",0)="^^2^2^3250315^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,"DES",1,0)="This field gives a PDMP the option of requiring the XDEA Number (NADEAN) "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,"DES",2,0)="in the PRE Segment when the prescription is for opioid dependency."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,"VAL",0)="^58.410111^1^1^3250315^^^^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",9,"VAL",1,0)="$$PRE09^PSOASAP0()"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,0)="PRE10^Jurisdiction or State Issuing Prescriber License Number^AN^2^10^O"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,"DES",0)="^58.4001111^2^2^3250305^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,"DES",1,0)="This field can be used to further identify the information in PRE04 "
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,"DES",2,0)="depending PDMP's need for this information."
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,"VAL",0)="^^1^1^3250305^"
^PS(58.4,1,"VER",12,"SEG",7,"DAT",10,"VAL",1,0)="$$PRE10^PSOASAP()"
