^PS(58.4,1,"VER",14,"SEG",2,"DAT",2,"VAL",0)="^58.410111^1^1^3250310^^^^"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",2,"VAL",1,0)="$$IS04^PSOASAP()"
