^PS(58.4,1,"VER",15,"SEG",7,"DAT",3,0)="PAT03^ID of Patient^AN^20^3^O"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",3,"DES",0)="^^3^3^3250220^"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",3,"DES",1,0)="Identification number for the patient as indicated in PAT02. An example "
