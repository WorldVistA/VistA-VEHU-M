^PS(58.4,1,"VER",14,"SEG",1,"DAT",8,"DES",4,0)="Separators and Segment Terminators"" in the standard's  introduction for "
^PS(58.4,1,"VER",14,"SEG",1,"DAT",8,"DES",5,0)="more information."
^PS(58.4,1,"VER",14,"SEG",1,"DAT",8,"VAL",0)="^58.410111^1^1^3250319^^^^"
