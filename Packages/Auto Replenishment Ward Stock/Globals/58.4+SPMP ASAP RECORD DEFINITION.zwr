^PS(58.4,1,"VER",14,"SEG",2,"DAT",0)="^58.400111I^4^4"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,0)="IS01^Unique Information Source ID^N^10^1^R"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"DES",0)="^^3^3^3250221^"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"DES",1,0)="Reference number or identification number as defined by the business "
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"DES",2,0)="partners. (Example: Phone number. However, if a phone number is used to "
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"DES",3,0)="populate this field, do not include hyphens.)"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"VAL",0)="^58.410111^1^1^3250221^^^^"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",1,"VAL",1,0)="$$IS01^PSOASAP()"
