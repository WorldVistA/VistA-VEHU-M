^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP15",15)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP16",16)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP17",17)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP18",18)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP19",19)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP20",20)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP21",21)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP22",22)=""
^PS(58.4,1,"VER",13,"SEG",3,"DAT","B","DSP23",23)=""
