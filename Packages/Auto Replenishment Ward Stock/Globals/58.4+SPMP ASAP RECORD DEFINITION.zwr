^PS(58.4,1,"VER",14,"SEG",2,"DAT",3,"VAL",1,0)="$$IS05^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,0)="IS03^Message^AN^60^3^O"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",0)="^^14^14^3260123"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",1,0)="Freetext message. Use of this field is defined by the PDMP. PDMPs may"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",2,0)="designate this field to hold the submission period date range of the file"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",3,0)="transmitted. When used to indicate the date range, it must be the first"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",4,0)="data text in the field and must be inserted using the following layout"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",5,0)="(where ""#"" and ""-"" are those literal characters):"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",6,0)="#CCYYMMDD#-#CCYYMMDD#"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",7,0)="For example, a pharmacy may be submitting records for the reporting period"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",8,0)="of February 5, 2023 through February 11, 2023 but only filled reportable"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",9,0)="prescriptions on February 5 and February 7. The full submission period"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",10,0)="date range would be reported in IS03 as #20230205#-#20230211# "
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",11,0)="It is up to the PDMP to further define how to enter the submission date"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",12,0)="range for exceptional cases, such as for late submission records."
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",13,0)="Note: IS03 can also be used to show the date range for Zero"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"DES",14,0)="Reports."
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"VAL",0)="^58.410111^1^1^3250221^^"
^PS(58.4,1,"VER",14,"SEG",2,"DAT",4,"VAL",1,0)="$$IS03^PSOASAP()"
