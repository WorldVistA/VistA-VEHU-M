^PS(58.4,1,"VER",15,"SEG",7,"DAT",1,0)="PAT01^ID Qualifier of Patient Identifier^AN^2^1^O"
^PS(58.4,1,"VER",15,"SEG",7,"DAT",1,"DES",0)="^^4^4^3250313^"
