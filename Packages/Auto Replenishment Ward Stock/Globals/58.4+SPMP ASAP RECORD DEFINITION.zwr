^PS(58.4,1,"VER",12,"SEG",1,"DAT",2,"DES",0)="^^2^2^3250207"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",2,"DES",1,0)="Number assigned to state issued serialized prescription blank. Required "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",2,"DES",2,0)="if state issues serialized prescription pads for prescribers to use."
^PS(58.4,1,"VER",12,"SEG",1,"DAT",2,"VAL",0)="^^1^1^3250207"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",2,"VAL",1,0)="$$AIR02^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,0)="AIR03^ID Issuing Jurisdiction^AN^2^3^O"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"DES",0)="^^3^3^3250315^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"DES",1,0)="Code identifying the jurisdiction that issues the ID contained in AIR05. "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"DES",2,0)="Used if required by the PDMP. "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"DES",3,0)="ASAP version 4.2b Standard Appendix A lists jurisdictions."
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",3,"VAL",1,0)="$$AIR03^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,0)="AIR04^ID Qualifier of Person Dropping Off or Picking Up Rx^N^2^4^O"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",0)="^^12^12^3250407^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",1,0)="Code indicating the type of ID in AIR05 if required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",2,0)="01 Military ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",3,0)="02 State Issued ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",4,0)="03 Unique System ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",5,0)="04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",6,0)="05 Passport ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",7,0)="06 Driver's License ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",8,0)="07 Social Security Number"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",9,0)="08 Tribal ID"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",10,0)="09 Vendor Specific (such as Appriss Health, Experian, LexisNexis)"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",11,0)="10 Veterinary Patient Microchip Number"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"DES",12,0)="99 Other (trading partner agreed upon ID such as cardholder ID)"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"VAL",0)="^58.410111^1^1^3250407^^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",4,"VAL",1,0)="$$AIR04^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,0)="AIR05^ID of Person Dropping Off or Picking Up Rx^AN^20^5^O"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",0)="^^7^7^3250315^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",1,0)="ID number of the person dropping off or picking up the prescription, if "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",2,0)="required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",3,0)="Note: Because historically there has been a noticeable amount of "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",4,0)="extraneous information entered in this field, which has interfered with "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",5,0)="data analysis, it's important that every effort be made to ensure that "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",6,0)="only the unadorned customer ID and no additional information be entered "
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"DES",7,0)="into this field."
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",1,"DAT",5,"VAL",1,0)="$$AIR05^PSOASAP()"
