^PS(58.4,1,"VER",14,"SEG",5,"DAT",28,"DES",1,0)="This field is used when the quantity in DSP09 is less than the metric"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",28,"DES",2,0)="quantity per dispensing authorized by the prescriber. This dispensing"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",28,"DES",3,0)="activity is often referred to as a split filling."
