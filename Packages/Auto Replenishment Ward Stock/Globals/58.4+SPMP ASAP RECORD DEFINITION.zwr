^PS(58.4,1,"VER",14,"SEG",4,"DAT",23,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT06. Used if the"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",23,"DES",2,0)="PDMP requires such identification."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",23,"DES",3,0)="ASAP version 5.0 Standard Appendix A lists jurisdictions. "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",23,"VAL",0)="^58.410111^1^1^3250311^^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",23,"VAL",1,0)="$$PAT04^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,0)="PAT06^Additional ID^AN^20^6^O"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"DES",0)="^^3^3^3250220^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"DES",1,0)="Identification that might be required by the PDMP to further identify the"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"DES",2,0)="individual. An example might be in that PAT03 driver's license is required"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"DES",3,0)="and in PAT06 Social Security number is also required."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"VAL",0)="^58.410111^1^1^3250220^^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",24,"VAL",1,0)="$$PAT06^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,0)="PAT09^Middle Name^AN^30^9^O"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,"DES",0)="^58.4001111^2^2^3250306^^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,"DES",1,0)="Patient's middle name or initial if available. Used if available in "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,"DES",2,0)="pharmacy system and required by the PDMP."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,"VAL",0)="^58.410111^1^1^3250306^^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",25,"VAL",1,0)="$$PAT09^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,0)="PAT20^Species Code^N^2^20^O"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"DES",0)="^^4^4^3250311^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"DES",1,0)="Used if required by the PDMP to differentiate a prescription for an "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"DES",2,0)="individual from one prescribed for an animal."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"DES",3,0)="01 Human"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"DES",4,0)="02 Veterinary Patient"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"VAL",0)="^58.410111^1^1^3250311^^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",26,"VAL",1,0)="$$PAT20^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,0)="PAT07^Last Name^AN^50^7^R"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",0)="^58.4001111^10^10^3250311^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",1,0)="Patient's last name."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",2,0)="Recommended way to report:"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",3,0)="Report the patient's complete legal last name ONLY as listed on a"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",4,0)="government-issued identification."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",5,0)="Do NOT report extraneous information or notes in this field "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",6,0)="Do NOT enter Prefix or Suffix in Last Name field"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",7,0)="Do NOT report special characters (e.g., parentheses, asterisk) other than"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",8,0)="a hyphen or apostrophe."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",9,0)="If for a veterinary patient, enter information of PERSON responsible for"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"DES",10,0)="the care of the animal or who arranges for the animal's veterinary care."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"VAL",0)="^58.410111^1^1^3250311^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",27,"VAL",1,0)="$$PAT07^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,0)="PAT08^First Name^AN^50^8^R"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",0)="^^10^10^3250324^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",1,0)="Patient's first name."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",2,0)="Recommended way to report:"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",3,0)="Report the patient's complete legal first name ONLY as listed on a"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",4,0)="government-issued identification."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",5,0)="Do NOT report extraneous information or notes in this field"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",6,0)="Do NOT enter Prefix or Suffix in First Name field"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",7,0)="Do NOT report special characters (e.g., parentheses, asterisk) other than"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",8,0)="a hyphen or apostrophe."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",9,0)="If for a veterinary patient, enter information of PERSON responsible for"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"DES",10,0)="the care of the animal or who arranges for the animal's veterinary care."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"VAL",0)="^58.410111^1^1^3250324^^^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",28,"VAL",1,0)="$$PAT08^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,0)="PAT03^ID of Patient^AN^20^3^O"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"DES",0)="^58.4001111^3^3^3250311^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"DES",1,0)="Identification number for the patient as indicated in PAT02.  An example "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"DES",2,0)="would be the driver's license number.  Note: This field can only be "
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"DES",3,0)="populated with code 10 when provided on the prescription."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"VAL",0)="^^1^1^3250311^"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",29,"VAL",1,0)="$$PAT03^PSOASAP()"
