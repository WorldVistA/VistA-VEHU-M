^PS(58.4,1,"VER",11,"SEG",8,"DAT",7,"DES",1,0)="Code specifying the type of transaction."
^PS(58.4,1,"VER",11,"SEG",8,"DAT",7,"DES",2,0)="  P Production"
^PS(58.4,1,"VER",11,"SEG",8,"DAT",7,"DES",3,0)="  T Test"
