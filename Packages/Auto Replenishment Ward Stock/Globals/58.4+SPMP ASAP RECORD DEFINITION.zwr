^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"DES",1,0)="Time expressed in 24-hour clock time (HHMMSS or HHMM). Time range: 000000"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"DES",2,0)="through 235959.  The time zone should be reported in Coordinated Universal"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"DES",3,0)="Time (UTC) as HHMMSSZ (e.g., 235959Z). Do not include colons or"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"DES",4,0)="non-numeric characters other than Z for Zulu time."
^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"VAL",0)="^58.410111^1^1^3250319^^^^"
^PS(58.4,1,"VER",14,"SEG",1,"DAT",1,"VAL",1,0)="$$TH06^PSOASAP()"
