^PS(58.4,1,"VER",12,"SEG",2,"DAT","B","CDI04",4)=""
^PS(58.4,1,"VER",12,"SEG",2,"DAT","B","CDI05",5)=""
^PS(58.4,1,"VER",12,"SEG",3,0)="DSP^Dispensing Record^PAT^R^1^4"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",0)="^58.400111I^27^22"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,0)="DSP01^Reporting Status^N^2^1^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",0)="^58.4001111^12^12^3250408^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",1,0)="00 New Record"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",2,0)="01 Revise"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",3,0)="02 Void"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",4,0)="DSP01 requires one of the codes below. An empty or blank field no longer "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",5,0)="indicates a new prescription dispensing transaction. A PDMP may elect to "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",6,0)="require a subset of the codes below, specifically 00 and 02, but not 01."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",7,0)="00 This code indicates a new prescription dispensing transaction."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",8,0)="01 This code indicates that one or more data element values in a "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",9,0)="previously submitted transaction are being revised. "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",10,0)="02 This code is a message to the PDMP to remove the original prescription "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",11,0)="transaction from its database (or to mark the record as invalid and to be "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"DES",12,0)="ignored). "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"VAL",0)="^58.410111^1^1^3250408^^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",1,"VAL",1,0)="$$DSP01^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",5,0)="DSP05^Date Filled^DT^8^5^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",5,"DES",0)="^^1^1^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",5,"DES",1,0)="Date prescription was prepared. Format: CCYYMMDD."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",5,"VAL",0)="^58.410111^1^1^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",5,"VAL",1,0)="$$DSP05^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,0)="DSP06^Fill Number^N^2^6^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,"DES",0)="^58.4001111^2^2^3250319^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,"DES",1,0)="Number of the fill of the prescription."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,"DES",2,0)="0 indicates original dispensing, 01-99 is the refill number."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,"VAL",0)="^58.410111^1^1^3250319^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",6,"VAL",1,0)="$$DSP06^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,0)="DSP07^Product ID Qualifier^N^2^7^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",0)="^^8^8^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",1,0)="Used to identify the type of product ID contained in DSP08."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",2,0)="01 NDC"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",3,0)="02 UPC"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",4,0)="03 HRI"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",5,0)="04 UPN"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",6,0)="05 DIN"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",7,0)="06 Compound (Used to indicate it is a compound. The CDI segment then"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"DES",8,0)="becomes a required segment. Also, see instructions for DSP08.)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"VAL",0)="^58.410111^1^1^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",7,"VAL",1,0)="$$DSP07^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",10,0)="DSP10^Days Supply^N^3^10^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",10,"DES",0)="^^1^1^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",10,"DES",1,0)="The calculated or estimated number of days the medication will cover."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",10,"VAL",0)="^58.410111^1^1^3250208^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",10,"VAL",1,0)="$$DSP10^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,0)="DSP11^Drug Dosage Units Code^N^2^11^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",0)="^^7^7^3250407^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",1,0)="Identifies the unit of measure for the quantity dispensed in DSP09, if "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",2,0)="required by the PDMP.  Appendix B in ASAP version 4.2b Standard contains "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",3,0)="specific instructions."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",4,0)="  01 Each (used to report solid dosage or indivisible package)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",5,0)="  02 Milliliters (ml) (for liters adjust to the decimal milliliter"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",6,0)="     equivalent)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"DES",7,0)="  03 Grams (gm) (for milligrams adjust to the decimal gram equivalent)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"VAL",0)="^58.410111^1^1^3250407^^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",11,"VAL",1,0)="$$DSP11^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,0)="DSP12^Transmission Form of Rx Origin Code^N^2^12^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",0)="^^9^9^3250210^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",1,0)="Code indicating how the pharmacy received the prescription, if required "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",2,0)="by the PDMP."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",3,0)="  01 Written Prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",4,0)="  02 Telephone Prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",5,0)="  03 Telephone Emergency Prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",6,0)="  04 Fax Prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",7,0)="  05 Electronic Prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",8,0)="  06 Transferred/Forwarded Rx"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"DES",9,0)="  99 Other"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"VAL",0)="^58.410111^1^1^3250210^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",12,"VAL",1,0)="$$DSP12^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,0)="DSP13^Partial Fill Indicator^N^2^13^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",0)="^^7^7^3250210^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",1,0)="This field is used when the quantity in DSP09 is less than the metric "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",2,0)="quantity per dispensing authorized by the prescriber. This dispensing "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",3,0)="activity is often referred to as a split filling. "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",4,0)="00 Not a Partial Fill"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",5,0)="01 First Partial Fill"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",6,0)="Note: For additional fills per prescription, increment by 1. So the "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"DES",7,0)="second partial fill would be reported as 02, up to a maximum of 99"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"VAL",0)="^58.410111^1^1^3250210^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",13,"VAL",1,0)="$$DSP13^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,0)="DSP14^Pharmacist National Provider Identifier (NPI)^AN^10^14^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,"DES",0)="^58.4001111^2^2^3250320^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,"DES",1,0)="Identifier assigned to the pharmacist by CMS. This number can be used to "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,"DES",2,0)="identify the pharmacist dispensing the medication."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,"VAL",0)="^58.410111^1^1^3250320^^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",14,"VAL",1,0)="$$DSP14^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,0)="DSP15^Pharmacist State License Number^AN^10^15^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,"DES",0)="^^2^2^3250210^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,"DES",1,0)="Assigned to the pharmacist by the State Licensing Board. This data "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,"DES",2,0)="element can be used to identify the pharmacist dispensing the medication."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,"VAL",0)="^58.410111^1^1^3250210^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",15,"VAL",1,0)="$$DSP15^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,0)="DSP16^Classification Code for Payment Type^N^2^16^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",0)="^^10^10^3250407^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",1,0)="Code identifying the type of payment, i.e. how it was paid for, if "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",2,0)="required by the PDMP."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",3,0)="  01 Private Pay (Cash, Charge, Credit Card)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",4,0)="  02 Medicaid"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",5,0)="  03 Medicare"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",6,0)="  04 Commercial Insurance"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",7,0)="  05 Military Installations and VA"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",8,0)="  06 Workers' Compensation"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",9,0)="  07 Indian Nations"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"DES",10,0)="  99 Other"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"VAL",0)="^58.410111^1^1^3250407^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",16,"VAL",1,0)="$$DSP16^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,0)="DSP17^Date Sold^DT^8^17^N"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",0)="^^7^7^3250320^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",1,0)="This field is used to determine the date the prescription was dispensed "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",2,0)="(sold to, picked up by, or otherwise left the pharmacy), not the date it "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",3,0)="was prepared. This date could be captured from the point-of-sale (POS) "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",4,0)="system, if the pharmacy has a POS system, and there is a bidirectional "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",5,0)="flow with the pharmacy management system in order to capture and report "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",6,0)="this date. Or it could be captured and reported from a will-call "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"DES",7,0)="management system, integrated with the pharmacy management system."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"VAL",0)="^58.410111^1^1^3250320^^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",17,"VAL",1,0)="$$DSP17^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,0)="DSP18^RxNorm Product Qualifier^N^2^18^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",0)="^^8^8^3250407^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",1,0)="  01 Semantic Clinical Drug (SCD)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",2,0)="  02 Semantic Branded Drug (SBD)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",3,0)="  03 Generic Package (GPCK)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",4,0)="  04 Branded Package (BPCK)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",5,0)="RxNorm code that is populated in the DRU-010-09 field in the SCRIPT"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",6,0)="transaction."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",7,0)="Note: DSP18 and DSP19 are placeholder fields pending RxNorm becoming an"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"DES",8,0)="industry standard. These fields should not be required until such time."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"VAL",0)="^58.410111^1^1^3250407^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",18,"VAL",1,0)="$$DSP18^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,0)="DSP19^RxNorm Code^AN^15^19^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,"DES",0)="^^2^2^3250315^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,"DES",1,0)="Used for electronic prescriptions to capture the prescribed drug product"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,"DES",2,0)="identification."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,"VAL",0)="^58.410111^1^1^3250315^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",19,"VAL",1,0)="$$DSP19^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,0)="DSP20^Electronic Prescription Reference Number^AN^35^20^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,"DES",0)="^58.4001111^2^2^3250304^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,"DES",1,0)="This field should be populated with the Initiator Reference Number from"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,"DES",2,0)="field UIB-030-01 in the SCRIPT transaction."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,"VAL",0)="^58.410111^1^1^3250304^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",20,"VAL",1,0)="$$DSP20^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,0)="DSP21^Electronic Prescription Order Number^AN^35^21^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",0)="^^9^9^3250315^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",1,0)="This field will be populated with the Initiator Control Reference from"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",2,0)="field UIH-030-01 in the SCRIPT standard."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",3,0)=" "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",4,0)="Note: DSP20 and DSP21 should be reported as a pair to the PDMP and the "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",5,0)="PDMP will decide which one, if not both, it decides to capture. By "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",6,0)="requiring the reporting of both, this avoids specification variations "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",7,0)="that would require custom programming to accommodate a PDMP. Also, the "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",8,0)="information reported by the pharmacy management system will depend on the "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"DES",9,0)="information received at the pharmacy with an electronic prescription."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",21,"VAL",1,0)="$$DSP21^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,0)="DSP22^Quantity Prescribed^N^15^22^N"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,"DES",0)="^^2^2^3250501^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,"DES",1,0)="This field has been added in order to add clarity to the value reported in"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,"DES",2,0)="DSP13 Partial Fill Indicator. (Revised 08/17/2020)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,"VAL",0)="^58.410111^1^1^3250501^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",22,"VAL",1,0)="$$DSP22^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,0)="DSP23^Rx SIG^AN^200^23^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"DES",0)="^^3^3^3250212^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"DES",1,0)="This field would capture the actual directions printed on the prescription"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"DES",2,0)="vial label. If the directions exceed 200 characters, truncation would be"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"DES",3,0)="allowed."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"VAL",0)="^^1^1^3250212^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",23,"VAL",1,0)="$$DSP23^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,0)="DSP24^Treatment Type^N^2^24^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",0)="^^17^17^3250315^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",1,0)="This field is used to explain the reason for an opioid prescription. If "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",2,0)="the prescription is not for an opioid, then this field would not be used."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",3,0)="01 = Not Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",4,0)="02 = Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",5,0)="03 = Pain Associated with Active and Aftercare Cancer Treatment"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",6,0)="04 = Palliative Care in Conjunction with a Serious Illness"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",7,0)="05 = End-of-Life and Hospice Care"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",8,0)="06 = A Pregnant Individual with a Pre-existing Prescription for Opioids"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",9,0)="07 = Acute Pain for an Individual with an Existing Opioid Prescription "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",10,0)="for Chronic Pain"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",11,0)="08 = Individuals Pursuing an Active Taper of Opioid Medications"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",12,0)="09 = Patient is Participating in a Pain Management Contract"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",13,0)="10 = Acute Opioid Therapy"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",14,0)="11 = Chronic Opioid Therapy"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",15,0)="99 = Other (trading partner agreed upon reason or not indiciated)"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",16,0)="The definitions of Codes 03 to 11 can only be reported if mandated by the "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"DES",17,0)="state to be provided by the prescriber on the prescription order."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"VAL",0)="^58.410111^1^1^3250315^^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",24,"VAL",1,0)="$$DSP24^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,0)="DSP25^Diagnosis Code^AN^7^25^O"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"DES",0)="^^3^3^3250315^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"DES",1,0)="This field is used to report the ICD-10 code.  If required by a PDMP, "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"DES",2,0)="this field would be populated only when the ICD-10 code is included with "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"DES",3,0)="the prescription.  Exclude the decimal point."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"VAL",0)="^58.410111^1^1^3250315^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",25,"VAL",1,0)="$$DSP25^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,0)="DSP08^Product ID^AN^15^8^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",0)="^^10^10^3250303^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",1,0)="Full product identification as indicated in DSP07, including leading zeros"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",2,0)="without punctuation."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",3,0)="If the product is a compound, use 99999 as the first five characters of"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",4,0)="the product code. The remaining six characters are assigned by the"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",5,0)="pharmacy. The CDI then becomes a required segment."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",6,0)="Note: If a controlled substance is part of a kit, the NDC of the kit"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",7,0)="should be reported as long as it is a legitimate manufacturer's NDC. If"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",8,0)="not, the NDC of the controlled substance within the kit should be"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",9,0)="reported. Also, if multiple controlled substances are in the kit, use the"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"DES",10,0)="CDI segment to report it as a compound."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"VAL",0)="^^1^1^3250303^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",26,"VAL",1,0)="$$DSP08^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,0)="DSP09^Quantity Dispensed^D^11^9^R"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"DES",0)="^58.4001111^3^3^3250321^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"DES",1,0)="Number of metric units dispensed in metric decimal format."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"DES",2,0)="Example: 2.5. Note: For compounds show the first quantity in CDI04. "
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"DES",3,0)="Appendix B in ASAP version 4.2b Standard contains specific instructions."
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"VAL",0)="^58.410111^1^1^3250321^^"
^PS(58.4,1,"VER",12,"SEG",3,"DAT",27,"VAL",1,0)="$$DSP09^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP01",1)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP05",5)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP06",6)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP07",7)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP08",26)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP09",27)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP10",10)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP11",11)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP12",12)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP13",13)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP14",14)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP15",15)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP16",16)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP17",17)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP18",18)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP19",19)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP20",20)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP21",21)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP22",22)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP23",23)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP24",24)=""
^PS(58.4,1,"VER",12,"SEG",3,"DAT","B","DSP25",25)=""
^PS(58.4,1,"VER",12,"SEG",4,0)="IS^Information Source^TH^R^1^1"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",0)="^58.400111I^3^2"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,0)="IS01^Unique Information Source ID^AN^10^1^R"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"DES",0)="^^3^3^3250207^"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"DES",1,0)="Reference number or identification number as defined by the business "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"DES",2,0)="partners. (Example: Phone number. However, if a phone number is used to "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"DES",3,0)="populate this field, do not include hyphens)."
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",1,"VAL",1,0)="$$IS01^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,0)="IS03^Message^AN^60^3^O"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",0)="^58.4001111^14^14^3250415^^"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",1,0)="Freeform text message. Use of this field is defined by the PDMP. Many "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",2,0)="PDMPs may designate this field to hold the submission period date range "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",3,0)="of the file transmitted. When used to indicate the date range, it must be "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",4,0)="the first data text in the field and must be inserted with using the "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",5,0)="following layout (where ""#"" and ""-"" are those literal characters): "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",6,0)="#CCYYMMDD#-#CCYYMMDD#"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",7,0)="For example, a pharmacy may be submitting records for the reporting "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",8,0)="period of December 5, 2019 through December 11, 2019 but only filled "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",9,0)="reportable prescriptions on December 5 and December 7. The full "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",10,0)="submission period date range would be reported in IS03 as "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",11,0)="#20191205#-#20191211#"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",12,0)="It is up to the PDMP to further define how to enter the submission date "
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",13,0)="range for exceptional cases, such as for late submission records."
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"DES",14,0)="Note: IS03 can also be used to show the date range for Zero Reports."
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"VAL",0)="^58.410111^1^1^3250325^^^^"
^PS(58.4,1,"VER",12,"SEG",4,"DAT",3,"VAL",1,0)="$$IS03^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",4,"DAT","B","IS01",1)=""
^PS(58.4,1,"VER",12,"SEG",4,"DAT","B","IS03",3)=""
^PS(58.4,1,"VER",12,"SEG",5,0)="PAT^Patient Information^PHA^R^1^3"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",0)="^58.400111I^25^20"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,0)="PAT01^ID Qualifier of Patient Identifier^AN^2^1^O"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"DES",0)="^^3^3^3250314^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT03."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"DES",2,0)="Used if the PDMP requires such identification."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"DES",3,0)="ASAP version 4.2b Standard Appendix A lists jurisdictions."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"VAL",0)="^58.410111^1^1^3250314^^^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",1,"VAL",1,0)="$$PAT01^PSOASAP()"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,0)="PAT02^ID Qualifier^N^2^2^O"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",0)="^^13^13^3250321^"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",1,0)="Code to identify the type of ID in PAT03. If PAT02 is used, PAT03 is "
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",2,0)="required."
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",3,0)="01 Military ID"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",4,0)="02 State Issued ID"
^PS(58.4,1,"VER",12,"SEG",5,"DAT",2,"DES",5,0)="03 Unique System ID"
