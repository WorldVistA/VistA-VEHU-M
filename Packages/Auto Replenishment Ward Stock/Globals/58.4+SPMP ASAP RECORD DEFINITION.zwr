^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",1,0)="If the pharmacy management system stores 35 bytes or less for the address,"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",2,0)="no programming change is necessary. If the address stored in the system is"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",3,0)="a P.O. box number, defer to the specifications of the PDMP as to whether"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",4,0)="this should be reported in PAT12 or PAT13."
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",5,0)="Recommendation: Information should be reported according to United States"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",6,0)="Postal Service Publication 28-Postal Addressing Standards or the most"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",7,0)="recently published version of the ONC Project US@ Technical Specifications"
^PS(58.4,1,"VER",14,"SEG",4,"DAT",3,"DES",8,0)="for Patient Addresses."
