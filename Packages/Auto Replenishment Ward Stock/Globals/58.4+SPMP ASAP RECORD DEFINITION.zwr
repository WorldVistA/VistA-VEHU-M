^PS(58.4,1,"VER",13,"SEG",5,"DAT",14,"DES",1,0)="Freeform text for city name."
^PS(58.4,1,"VER",13,"SEG",5,"DAT",14,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",5,"DAT",14,"VAL",1,0)=""""""
