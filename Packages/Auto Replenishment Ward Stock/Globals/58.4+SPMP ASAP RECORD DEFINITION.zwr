^PS(58.4,1,"VER",13,"SEG",8,"DAT",4,"DES",1,0)="Contains the Transaction Control Number of a transaction that initiated"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",4,"DES",2,0)="the transaction. Required in response transaction only."
^PS(58.4,1,"VER",13,"SEG",8,"DAT",4,"VAL",0)="^^1^1^3250408^"
^PS(58.4,1,"VER",13,"SEG",8,"DAT",4,"VAL",1,0)="$$TH04^PSOASAP()"
