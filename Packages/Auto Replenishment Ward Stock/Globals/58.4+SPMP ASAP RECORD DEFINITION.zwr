^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"DES",7,0)="  05 Military Installations and VA"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"DES",8,0)="  06 Workers' Compensation"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"DES",9,0)="  07 Indian Nations"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"DES",10,0)="  99 Other"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"VAL",0)="^58.410111^1^1^3250315^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",16,"VAL",1,0)="$$DSP16^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,0)="DSP17^Date Sold^DT^8^17^N"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",0)="^58.4001111^8^8^3250317^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",1,0)="This field is used to determine the date the prescription was dispensed "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",2,0)="(sold to, picked up by, or otherwise left the pharmacy), not the date it "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",3,0)="was prepared. "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",4,0)="This date could be captured from the point-of-sale (POS) system, if the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",5,0)="pharmacy has a POS system, and there is a bidirectional flow with the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",6,0)="pharmacy management system in order to capture and report this date. Or "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",7,0)="it could be captured and reported from a will-call management system, "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"DES",8,0)="integrated with the pharmacy management system."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"VAL",0)="^58.410111^1^1^3250317^^^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",17,"VAL",1,0)="$$DSP17^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,0)="DSP18^RxNorm Product Qualifier^N^2^18^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",0)="^^9^9^3250407^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",1,0)="  01 Semantic Clinical Drug (SCD)"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",2,0)="  02 Semantic Branded Drug (SBD)"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",3,0)="  03 Generic Package (GPCK)"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",4,0)="  04 Branded Package (BPCK)"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",5,0)="RxNorm code that is populated in the DRU-010-09 field in the SCRIPT"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",6,0)="transaction."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",7,0)="Note: DSP18 and DSP19 are placeholder fields pending"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",8,0)="RxNorm becoming an industry standard. These fields should"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"DES",9,0)="not be required until such time."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"VAL",0)="^58.410111^1^1^3250407^^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",18,"VAL",1,0)="$$DSP18^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,0)="DSP19^RxNorm Code^AN^15^19^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,"DES",0)="^58.4001111^2^2^3250317^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,"DES",1,0)="Used for electronic prescriptions to capture the prescribed drug product"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,"DES",2,0)="identification, if required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",19,"VAL",1,0)="$$DSP19^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,0)="DSP20^Electronic Prescription Reference Number^AN^35^20^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,"DES",0)="^58.4001111^2^2^3250317^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,"DES",1,0)="This field should be populated with the Initiator Reference Number from"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,"DES",2,0)="field UIB-030-01 in the SCRIPT transaction."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",20,"VAL",1,0)="$$DSP20^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,0)="DSP21^Electronic Prescription Order Number^AN^35^21^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",0)="^^9^9^3250617^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",1,0)="This field will be populated with the Initiator Control Reference from "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",2,0)="field UIH-030-01 in the SCRIPT standard."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",3,0)=" "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",4,0)="Note: DSP20 and DSP21 should be reported as a pair to the PDMP and the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",5,0)="PDMP will decide which one, if not both, it decides to capture. By "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",6,0)="requiring the reporting of both, this avoids specification variations "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",7,0)="that would require custom programming to accommodate a PDMP. Also, the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",8,0)="information reported by the pharmacy management system will depend on the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"DES",9,0)="information received at the pharmacy with an electronic prescription."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"VAL",0)="^58.410111^1^1^3250617^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",21,"VAL",1,0)="$$DSP21^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,0)="DSP22^Quantity Prescribed^N^100^22^N"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,"DES",0)="^58.4001111^2^2^3250501^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,"DES",1,0)="This field has been added in order to add clarity to the value reported in"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,"DES",2,0)="DSP13 Partial Fill Indicator."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,"VAL",0)="^^1^1^3250501^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",22,"VAL",1,0)="$$DSP22^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,0)="DSP23^Rx SIG^AN^200^23^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"DES",0)="^^3^3^3250212^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"DES",1,0)="This field would capture the actual directions printed on the prescription"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"DES",2,0)="vial label. If the directions exceed 200 characters, truncation would be"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"DES",3,0)="allowed."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"VAL",0)="^^1^1^3250212^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",23,"VAL",1,0)="$$DSP23^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,0)="DSP24^Treatment Type^N^2^24^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",0)="^^17^17^3250617^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",1,0)="While this field can be used to indicate that the prescription was for "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",2,0)="opioid dependency treatment when Code 02 is used, it can also be used to "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",3,0)="provide other reasons for the opioid prescription through use of the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",4,0)="additional codes."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",5,0)="01 = Not Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",6,0)="02 = Used for Opioid Dependency Treatment"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",7,0)="03 = Pain Associated with Active and Aftercare Cancer Treatment"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",8,0)="04 = Palliative Care in Conjunction with a Serious Illness"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",9,0)="05 = End-of-Life and Hospice Care"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",10,0)="06 = A Pregnant Individual with a Pre-existing Prescription for Opioids"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",11,0)="07 = Acute Pain for an Individual with an Existing Opioid Prescription "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",12,0)="for Chronic Pain"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",13,0)="08 = Individuals Pursuing an Active Taper of Opioid Medications"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",14,0)="09 = Patient is Participating in a Pain Management Contract"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",15,0)="99 = Other (trading partner agreed upon reason)"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",16,0)="*Codes 03 through 99 added 6/28/2017. Note: These new codes can only be "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"DES",17,0)="reported if provided by the prescriber with the prescription."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"VAL",0)="^58.410111^1^1^3250617^^^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",24,"VAL",1,0)="$$DSP24^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,0)="DSP25^Diagnosis Code^AN^7^25^O"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"DES",0)="^^3^3^3250212^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"DES",1,0)="This field is used to report the ICD-10 code.  If required by a PDMP, "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"DES",2,0)="this field would be populated only when the ICD-10 code is included with "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"DES",3,0)="the prescription."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"VAL",0)="^^1^1^3250212^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",25,"VAL",1,0)="$$DSP25^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,0)="DSP08^Product ID^AN^15^8^R"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",0)="^58.4001111^9^9^3250317^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",1,0)="Full product identification as indicated in DSP07, including zeros "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",2,0)="without punctuation. If the product is a compound, use 99999 as the first "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",3,0)="five characters of the product code. The remaining characters are "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",4,0)="assigned by the pharmacy. The CDI then becomes a required segment.  Note: "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",5,0)="If a controlled substance is part of a kit, the NDC of the kit should be "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",6,0)="reported if it is a legitimate manufacturer's NDC. If not,the NDC of the "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",7,0)="controlled substance within the kit should be reported. Also, if multiple "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",8,0)="controlled substances are in the kit, use the CDI segment to report it as "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"DES",9,0)="a compound."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"VAL",0)="^58.410111^1^1^3250317^^^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",26,"VAL",1,0)="$$DSP08^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,0)="DSP09^Quantity Dispensed^D^11^9^R"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"DES",0)="^58.4001111^3^3^3250407^^^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"DES",1,0)="Number of metric units dispensed in metric decimal format.Example: 2.5. "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"DES",2,0)="Note: For compounds show the first quantity in CDI04. Appendix B in ASAP "
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"DES",3,0)="version 4.2a Standard contains specific instructions."
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"VAL",0)="^58.410111^1^1^3250407^^"
^PS(58.4,1,"VER",10,"SEG",3,"DAT",27,"VAL",1,0)="$$DSP09^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP01",1)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP05",5)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP06",6)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP07",7)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP08",26)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP09",27)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP10",10)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP11",11)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP12",12)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP13",13)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP14",14)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP15",15)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP16",16)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP17",17)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP18",18)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP19",19)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP20",20)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP21",21)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP22",22)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP23",23)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP24",24)=""
^PS(58.4,1,"VER",10,"SEG",3,"DAT","B","DSP25",25)=""
^PS(58.4,1,"VER",10,"SEG",4,0)="IS^Information Source^TH^R^1^1"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",0)="^58.400111I^3^2"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,0)="IS01^Unique Information Source ID^AN^10^1^R"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"DES",0)="^58.4001111^3^3^3250304^^"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"DES",1,0)="Reference number or identification number as defined by the business "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"DES",2,0)="partners. (Example: Phone number. However, if a phone number is used to "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"DES",3,0)="populate this field, do not include hyphens)."
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",1,"VAL",1,0)="$$IS01^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,0)="IS03^Message^AN^60^3^O"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",0)="^^13^13^3250415^"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",1,0)="Freeform text message. Use of this field is defined by the PDMP. "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",2,0)="Many PDMPs may designate this field to hold the submission period date "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",3,0)="range of the file transmitted. When used to indicate the date range, it "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",4,0)="must be the first data text in the field and must be inserted with using "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",5,0)="the following layout (where ""#"" and ""-"" are those literal "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",6,0)="characters): #CCYYMMDD#-#CCYYMMDD#"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",7,0)="For example, a pharmacy may be submitting records for the reporting "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",8,0)="period of March 1, 2012 through March 7, 2012 but only filled reportable "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",9,0)="prescriptions on March 3, and March 5. The full submission period date "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",10,0)="range would be reported in IS03 as #20120301#-#20120307# "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",11,0)="It is up to the PDMP to further define how to enter the submission date "
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",12,0)="range for exceptional cases, such as for late submission records."
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"DES",13,0)="Note: IS03 can also be used to show the date range for Zero Reports."
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"VAL",0)="^58.410111^1^1^3250320^^^"
^PS(58.4,1,"VER",10,"SEG",4,"DAT",3,"VAL",1,0)="$$IS03^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",4,"DAT","B","IS01",1)=""
^PS(58.4,1,"VER",10,"SEG",4,"DAT","B","IS03",3)=""
^PS(58.4,1,"VER",10,"SEG",5,0)="PAT^Patient Information^PHA^R^1^3"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",0)="^58.400111I^24^19"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,0)="PAT01^ID Qualifier of Patient Identifier^AN^2^1^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"DES",0)="^58.4001111^3^3^3250317^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT03."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"DES",2,0)="Used if the PDMP requires such identification."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"DES",3,0)="ASAP version 4.2a Standard Appendix A lists jurisdictions."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"VAL",0)="^58.410111^1^1^3250317^^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",1,"VAL",1,0)="$$PAT01^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,0)="PAT02^ID Qualifier^N^2^2^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",0)="^^11^11^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",1,0)="Code to identify the type of ID in PAT03. If PAT02 is used, PAT03 is "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",2,0)="required."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",3,0)="  01 Military ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",4,0)="  02 State Issued ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",5,0)="  03 Unique System ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",6,0)="  04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",7,0)="  05 Passport ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",8,0)="  06 Driver's License ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",9,0)="  07 Social Security Number"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",10,0)="  08 Tribal ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"DES",11,0)="  99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",2,"VAL",1,0)="$$PAT02^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,0)="PAT04^ID Qualifier of Additional Patient Identifier^AN^2^4^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"DES",0)="^58.4001111^3^3^3250317^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"DES",1,0)="Code identifying the jurisdiction that issues the ID in PAT06. Used if "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"DES",2,0)="the PDMP requires such identification. ASAP version 4.2a Standard "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"DES",3,0)="Appendix A lists jurisdictions."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"VAL",0)="^58.410111^1^1^3250317^^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",4,"VAL",1,0)="$$PAT04^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,0)="PAT05^Additional Patient ID Qualifier^N^2^5^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",0)="^58.4001111^11^11^3250317^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",1,0)="Code to identify the type of ID in PAT06 if the PDMP requires a second"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",2,0)="identifier. If PAT05 is used, PAT06 is required. "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",3,0)="01 Military ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",4,0)="02 State Issued ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",5,0)="03 Unique System ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",6,0)="04 Permanent Resident Card (Green Card)"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",7,0)="05 Passport ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",8,0)="06 Driver's License ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",9,0)="07 Social Security Number"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",10,0)="08 Tribal ID"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"DES",11,0)="99 Other (Trading partner agreed upon ID, such as cardholder ID.)"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"VAL",0)="^58.410111^1^1^3250317^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",5,"VAL",1,0)="$$PAT05^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,0)="PAT06^Additional ID^AN^20^6^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"DES",0)="^^3^3^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"DES",1,0)="Identification that might be required by the PDMP to further identify the"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"DES",2,0)="individual. An example might be in that PAT03 driver's license is required"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"DES",3,0)="and in PAT06 Social Security number is also required."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",6,"VAL",1,0)="$$PAT06^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,0)="PAT09^Middle Name^AN^30^9^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,"DES",0)="^58.4001111^2^2^3250306^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,"DES",1,0)="Patient's middle name or initial if available. Used if available in "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,"DES",2,0)="pharmacy system and required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,"VAL",0)="^58.410111^1^1^3250306^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",9,"VAL",1,0)="$$PAT09^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,0)="PAT10^Name Prefix^AN^10^10^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,"DES",0)="^58.4001111^2^2^3250321^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,"DES",1,0)="Patient's name prefix such as Mr. or Dr. Used if available in pharmacy "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,"DES",2,0)="system and required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,"VAL",0)="^58.410111^1^1^3250321^^^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",10,"VAL",1,0)="$$PAT10^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,0)="PAT11^Name Suffix^AN^10^11^O"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,"DES",0)="^^2^2^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,"DES",1,0)="Patient's name suffix such as Jr. or the III. Used if available in "
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,"DES",2,0)="pharmacy system and if required by the PDMP."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",11,"VAL",1,0)="$$PAT11^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,0)="PAT12^Address Information - 1^AN^35^12^R"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",0)="^^7^7^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",1,0)="Field size has been increased to 35 bytes from 30 bytes in 4.1."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",2,0)="However, in order to accommodate pharmacy management systems storing 30"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",3,0)="bytes or less for the patient address, no programming change is necessary"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",4,0)="if that is the maximum length of the field in the pharmacy management"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",5,0)="system. If the address stored in the system is a P.O. box number, defer to"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",6,0)="the specifications of the PDMP as to whether this should be reported in"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"DES",7,0)="PAT12 or PAT13."
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",12,"VAL",1,0)="$$PAT12^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",5,"DAT",13,0)="PAT13^Address Information - 2^AN^35^13^O"
