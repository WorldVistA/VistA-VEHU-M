^PS(58.4,1,"VER",13,"SEG",2,0)="CDI^Compound Drug Ingredient Detail^DSP^O^2^4"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",0)="^58.400111I^4^4"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,0)="CDI01^Compound Drug Ingredient Sequence Number^N^2^1^R"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,"DES",0)="^^2^2^3250316^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,"DES",1,0)="The first reportable ingredient is 1. Each additional reportable "
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,"DES",2,0)="ingredient is incremented by 1."
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,0)="CDI02^Product ID Qualifier^N^2^2^R"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",0)="^^7^7^3250326^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",1,0)="Code to identify the type of product ID contained in CDI03."
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",2,0)="01 NDC"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",3,0)="02 UPC"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",4,0)="03 HRI"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",5,0)="04 UPN"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",6,0)="05 DIN"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"DES",7,0)="06 Compound (This code is not used in this segment.)"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"VAL",0)="^58.410111^1^1^3250326^^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",2,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,0)="CDI03^Product ID^AN^15^3^R"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,"DES",0)="^58.4001111^2^2^3201012^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,"DES",1,0)="Full product identification as indicated in CDI02, including leading "
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,"DES",2,0)="zeros without punctuation."
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",3,"VAL",1,0)=""""""
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,0)="CDI04^Component Ingredient Quantity^D^11^4^R"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"DES",0)="^^3^3^3250316^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"DES",1,0)="Metric decimal quantity of the ingredient identified in CDI03."
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"DES",2,0)="Example: 2.5.  Appendix B in ASAP version 4.2b Standard contains specific "
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"DES",3,0)="instructions."
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"VAL",0)="^58.410111^1^1^3250316^^"
^PS(58.4,1,"VER",13,"SEG",2,"DAT",4,"VAL",1,0)=""""""
