^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,0)="CDI01^Compound Drug Ingredient Sequence Number^N^2^1^R"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,"DES",0)="^^2^2^3250317^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,"DES",1,0)="The first reportable ingredient is 1. Each additional reportable "
^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,"DES",2,0)="ingredient is incremented by 1."
^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,0)="CDI02^Product ID Qualifier^N^2^2^R"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",0)="^58.4001111^7^7^3201012^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",1,0)="Code to identify the type of product ID contained in CDI03."
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",2,0)="  01 NDC"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",3,0)="  02 UPC"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",4,0)="  03 HRI"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",5,0)="  04 UPN"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",6,0)="  05 DIN"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"DES",7,0)="  06 CPD (This code is not used in this segment.)"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",2,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,0)="CDI03^Product ID^AN^15^3^R"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,"DES",0)="^58.4001111^2^2^3201012^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,"DES",1,0)="Full product identification as indicated in CDI02, including leading "
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,"DES",2,0)="zeros without punctuation."
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",3,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,0)="CDI04^Component Ingredient Quantity^D^11^4^R"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"DES",1,0)="Metric decimal quantity of the ingredient identified in CDI03."
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"DES",2,0)="Example: 2.5. Appendix B in ASAP version 4.2a Standard contains specific "
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"DES",3,0)="instructions."
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",2,"DAT",4,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",2,"DAT","B","CDI01",1)=""
^PS(58.4,1,"VER",11,"SEG",2,"DAT","B","CDI02",2)=""
^PS(58.4,1,"VER",11,"SEG",2,"DAT","B","CDI03",3)=""
^PS(58.4,1,"VER",11,"SEG",2,"DAT","B","CDI04",4)=""
^PS(58.4,1,"VER",11,"SEG",3,0)="DSP^Dispensing Record^PAT^R^1^4"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",0)="^58.400111I^17^17"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,0)="DSP01^Reporting Status^N^2^1^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",0)="^^12^12^3250408^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",1,0)="00 New Record"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",2,0)="01 Revise"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",3,0)="02 Void"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",4,0)="DSP01 requires one of the codes below. An empty or blank field no longer "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",5,0)="indicates a new prescription dispensing transaction. A PDMP may elect to "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",6,0)="require a subset of the codes below, specifically 00 and 02, but not 01."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",7,0)="00 This code indicates a new prescription dispensing transaction."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",8,0)="01 This code indicates that one or more data element values in a "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",9,0)="previously submitted transaction are being revised."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",10,0)="02 This code is a message to the PDMP to remove the original prescription "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",11,0)="transaction from its database (or to mark the record as invalid and to be "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"DES",12,0)="ignored)."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"VAL",0)="^58.410111^1^1^3250408^^^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",1,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",2,0)="DSP02^Prescription Number^AN^25^2^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",2,"DES",0)="^58.4001111^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",2,"DES",1,0)="Serial number assigned to the prescription by the pharmacy."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",2,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",2,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",3,0)="DSP03^Date Written^DT^8^3^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",3,"DES",0)="^58.4001111^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",3,"DES",1,0)="Date the prescription was written (authorized). Format: CCYYMMDD."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",3,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",3,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",4,0)="DSP04^Refills Authorized^N^2^4^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",4,"DES",0)="^58.4001111^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",4,"DES",1,0)="The number of refills authorized by the prescriber."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",4,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",4,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",5,0)="DSP05^Date Filled^DT^8^5^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",5,"DES",0)="^58.4001111^1^1^3250407^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",5,"DES",1,0)="Date prescription was prepared. Format: CCYYMMDD."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",5,"VAL",0)="^58.410111^1^1^3250407^^^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",5,"VAL",1,0)="$$DSP05^PSOASAP()"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,0)="DSP06^Refill Number^N^2^6^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,"DES",0)="^^2^2^3250326^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,"DES",1,0)="Number of the fill of the prescription."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,"DES",2,0)="0 indicates original dispensing, 01-99 is the refill number."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,"VAL",0)="^58.410111^1^1^3250326^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",6,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,0)="DSP07^Product ID Qualifier^N^2^7^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",0)="^^8^8^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",1,0)="Used to identify the type of product ID contained in DSP08."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",2,0)="01 NDC"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",3,0)="02 UPC"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",4,0)="03 HRI"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",5,0)="04 UPN"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",6,0)="05 DIN"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",7,0)="06 Compound (Used to indicate it is a compound. The CDI segment then "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"DES",8,0)="becomes a required segment. Also, see instructions for DSP08.)"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",7,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,0)="DSP08^Product ID^AN^15^8^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",0)="^^9^9^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",1,0)="Full product identification as indicated in DSP07, including zeros "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",2,0)="without punctuation. If the product is a compound, use 99999 as the first "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",3,0)="five characters of the product code. The remaining characters are "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",4,0)="assigned by the pharmacy. The CDI then becomes a required segment.  Note: "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",5,0)="If a controlled substance is part of a kit, the NDC of the kit should be "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",6,0)="reported if it is a legitimate manufacturer's NDC. If not,the NDC of the "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",7,0)="controlled substance within the kit should be reported. Also, if multiple "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",8,0)="controlled substances are in the kit, use the CDI segment to report it as "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"DES",9,0)="a compound."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",8,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,0)="DSP09^Quantity Dispensed^D^11^9^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"DES",0)="^^3^3^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"DES",1,0)="Number of metric units dispensed in metric decimal format."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"DES",2,0)="Example: 2.5. Note: For compounds show the first quantity in CDI04. "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"DES",3,0)="Appendix B in ASAP version 4.2a Standard contains specific instructions."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",9,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",10,0)="DSP10^Days Supply^N^3^10^R"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",10,"DES",0)="^^1^1^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",10,"DES",1,0)="The calculated or estimated number of days the medication will cover."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",10,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",10,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,0)="DSP11^Drug Dosage Units Code^N^2^11^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",0)="^^7^7^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",1,0)="Identifies the unit of measure for the quantity dispensed in DSP09, if "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",2,0)="required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",3,0)="Appendix B in ASAP version 4.2a Standard contains specific instructions."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",4,0)="01 Each (used to report solid dosage or indivisible package)"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",5,0)="02 Milliliters (ml) (for liters adjust to the decimal milliliter "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",6,0)="equivalent)"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"DES",7,0)="03 Grams (gm) (for milligrams adjust to the decimal gram equivalent)"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",11,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,0)="DSP12^Transmission Form of Rx Origin Code^N^2^12^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",0)="^^9^9^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",1,0)="Code indicating how the pharmacy received the prescription, if required "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",2,0)="by the PDMP."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",3,0)="01 Written Prescription"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",4,0)="02 Telephone Prescription"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",5,0)="03 Telephone Emergency Prescription"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",6,0)="04 Fax Prescription"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",7,0)="05 Electronic Prescription"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",8,0)="06 Transferred/Forwarded Rx"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"DES",9,0)="99 Other"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",12,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,0)="DSP13^Partial Fill Indicator^N^2^13^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",0)="^^7^7^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",1,0)="This field is used when the quantity in DSP09 is less than the metric "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",2,0)="quantity per dispensing authorized by the prescriber. This dispensing "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",3,0)="activity is often referred to as a split filling. "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",4,0)="00 Not a Partial Fill"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",5,0)="01 First Partial Fill"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",6,0)="Note: For additional fills per prescription, increment by 1. So the "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"DES",7,0)="second partial fill would be reported as 02, up to a maximum of 99"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"VAL",0)="^58.410111^1^1^3250317^^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",13,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,0)="DSP14^Pharmacist National Provider Identifier (NPI)^AN^10^14^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"DES",0)="^58.4001111^3^3^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"DES",1,0)="Identifier assigned to the pharmacist by CMS if the pharmacist applies "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"DES",2,0)="for a number. This number can be used to identify the pharmacist "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"DES",3,0)="dispensing the medication."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"VAL",0)="^^1^1^3201012^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",14,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,0)="DSP15^Pharmacist State License Number^AN^10^15^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,"DES",0)="^^2^2^3250326^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,"DES",1,0)="Assigned to the pharmacist by the State Licensing Board. This data "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,"DES",2,0)="element can be used to identify the pharmacist dispensing the medication."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,"VAL",0)="^58.410111^1^1^3250326^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",15,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,0)="DSP16^Classification Code for Payment Type^N^2^16^O"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",0)="^^10^10^3250326^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",1,0)="Code identifying the type of payment, i.e. how it was paid for, if "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",2,0)="required by the PDMP."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",3,0)="01 Private Pay (Cash, Charge, Credit Card)"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",4,0)="02 Medicaid"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",5,0)="03 Medicare"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",6,0)="04 Commercial Insurance"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",7,0)="05 Military Installations and VA"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",8,0)="06 Workers' Compensation"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",9,0)="07 Indian Nations"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"DES",10,0)="99 Other"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"VAL",0)="^58.410111^1^1^3250326^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",16,"VAL",1,0)=""""""
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,0)="DSP17^Date Sold^DT^8^17^N"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",0)="^^8^8^3250317^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",1,0)="This field is used to determine the date the prescription was dispensed "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",2,0)="(sold to, picked up by, or otherwise left the pharmacy), not the date it "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",3,0)="was prepared. "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",4,0)="This date could be captured from the point-of-sale (POS) system, if the "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",5,0)="pharmacy has a POS system, and there is a bidirectional flow with the "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",6,0)="pharmacy management system in order to capture and report this date. Or "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",7,0)="it could be captured and reported from a will-call management system, "
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"DES",8,0)="integrated with the pharmacy management system."
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"VAL",0)="^58.410111^1^1^3250317^^"
^PS(58.4,1,"VER",11,"SEG",3,"DAT",17,"VAL",1,0)=""""""
