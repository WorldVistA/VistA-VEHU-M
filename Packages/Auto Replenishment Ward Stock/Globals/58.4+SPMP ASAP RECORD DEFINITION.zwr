^PS(58.4,1,"VER",14,"SEG",7,"DAT",2,"VAL",1,0)="$$CDI01^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,0)="CDI03^Product ID^AN^15^3^R"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",0)="^^7^7^3250312^"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",1,0)="Full product identification as indicated in CDI02, including leading "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",2,0)="zeros without punctuation."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",3,0)="If DSP07 = 01, then DSP08 should contain the 11-digit NDC code without "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",4,0)="hyphens."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",5,0)="If the product is a compound, use 99999 as the first five characters of "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",6,0)="the product code. The remaining six characters are assigned by the "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"DES",7,0)="pharmacy. The CDI then becomes a required segment."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"VAL",0)="^^1^1^3250312^"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",3,"VAL",1,0)="$$CDI03^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,0)="CDI04^Component Ingredient Quantity^D^11^4^R"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"DES",0)="^^3^3^3250312^"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"DES",1,0)="Metric decimal quantity of the ingredient identified in CDI03."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"DES",2,0)="Example: 2.5. Appendix B in ASAP version 5.0 Standard contains specific "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"DES",3,0)="instructions."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"VAL",0)="^^1^1^3250312^"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",4,"VAL",1,0)="$$CDI04^PSOASAP()"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,0)="CDI05^Compound Drug Dosage Units Code^N^2^5^O"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",0)="^^7^7^3250312^"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",1,0)="Identifies the unit of measure for the quantity dispensed in CDI04, if "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",2,0)="required by the prescription-monitoring program."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",3,0)="Appendix B in ASAP version 5.0 Standard contains specific instructions."
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",4,0)="01 Each (used to report solid dosage units or indivisible package)"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",5,0)="02 Milliliters (ml) (for liters adjust to the decimal milliliter "
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",6,0)="   equivalent)"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"DES",7,0)="03 Grams (gm) (for milligrams adjust to the decimal gram equivalent)"
^PS(58.4,1,"VER",14,"SEG",7,"DAT",5,"VAL",0)="^^1^1^3250312^"
