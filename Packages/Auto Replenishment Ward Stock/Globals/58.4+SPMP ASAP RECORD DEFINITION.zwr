^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",1,0)="00 New Record"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",2,0)="01 Revise"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",3,0)="02 Void"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",4,0)="DSP01 requires one of the codes below. An empty or blank field no longer "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",5,0)="indicates a new prescription dispensing transaction. A PDMP may elect to "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",6,0)="require a subset of the codes below, specifically 00 and 02, but not 01."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",7,0)="00 This code indicates a new prescription dispensing transaction. "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",8,0)="01 This code indicates that one or more data element values in a "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",9,0)="previously submitted transaction are being revised."
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",10,0)="02 This code is a message to the PDMP to remove the original prescription "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",11,0)="transaction from its database (or to mark the record as invalid and to be "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"DES",12,0)="ignored). "
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"VAL",0)="^58.410111^1^1^3250408^^^"
^PS(58.4,1,"VER",14,"SEG",5,"DAT",32,"VAL",1,0)="$$DSP01^PSOASAP()"
