^PS(58.4,1,"VER",10,"SEG",8,0)="TH^Transaction Header^^R^1^1"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",0)="^58.400111I^10^7"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,0)="TH01^Version / Release Number^AN^4^1^R"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,"DES",0)="^58.4001111^2^2^3250213^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,"DES",1,0)="Code uniquely identifying the transaction. Format = x.x  "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,"DES",2,0)="4.2A ASAP Version 4 Release 2A"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,"VAL",0)="^58.410111^1^1^3250213^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",1,"VAL",1,0)="$$TH01^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,0)="TH02^Transaction Control Number^AN^40^2^R"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"DES",0)="^58.4001111^4^4^3250225^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"DES",1,0)="Sender assigned code uniquely identifying a transaction. This number must "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"DES",2,0)="be used in TT01."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"DES",3,0)="Recommendation: Use a Globally Unique Identifier (GUID) or other "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"DES",4,0)="nonrepeating alphanumeric combination to populate this field."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"VAL",0)="^58.410111^1^1^3250225^^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",2,"VAL",1,0)="$$TH02^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,0)="TH03^Transaction Type^N^2^3^O"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",0)="^^10^10^3250207^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",1,0)="Identifies the purpose of initiating the transaction."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",2,0)="01 Send/Request Transaction"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",3,0)="02 Acknowledgment (Used in Response only.)"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",4,0)="03 Error Receiving (Used in Response only.)"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",5,0)="04 Void (Used to void a specific Rx in a real-time transmission, or an "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",6,0)="entire batch file that has been transmitted. "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",7,0)="When 04 is used the appropriate transaction control number in TH02 for "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",8,0)="the specific prescription or batch file must be included. "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",9,0)="When 04 is used only the TH Header Segment and the Transaction Trailer "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"DES",10,0)="Segment are used.)"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",3,"VAL",1,0)="$$TH03^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,0)="TH06^Creation Time^TM^6^6^R"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,"DES",0)="^^2^2^3250207^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,"DES",1,0)="Time the transaction was created. Format: HHMMSS or HHMM."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,"DES",2,0)="Do not use colons or other nonnumeric characters."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,"VAL",0)="^58.410111^1^1^3250207^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",6,"VAL",1,0)="$$TH06^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,0)="TH08^Routing Number/BIN^N^6^8^O"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"DES",0)="^58.4001111^3^3^3250226^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"DES",1,0)="This field can be used for real-time transmissions that go through a "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"DES",2,0)="intermediary or network switch to indicate, if necessary, the specific "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"DES",3,0)="state that the transactions should be routed to."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"VAL",0)="^58.410111^1^1^3250226^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",8,"VAL",1,0)="$$TH08^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,0)="TH09^Segment Terminator Character^AN^1^9^R"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",0)="^58.4001111^5^5^3250318^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",1,0)="This terminates the TH segment and sets the actual value of the data "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",2,0)="segment terminator for the entire transaction."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",3,0)="Note: The ASAP 4.2a Standard document uses the ""~"" in all examples. See "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",4,0)="the ""Data Element Separators and Segment Terminators"" in the standard's "
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"DES",5,0)="introduction for more information."
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"VAL",0)="^58.410111^1^1^3250318^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",9,"VAL",1,0)="$$TH09^PSOASAP()"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",10,0)="TH04^Response ID^AN^40^4^O"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",10,"DES",0)="^58.4001111^2^2^3250317^^^"
^PS(58.4,1,"VER",10,"SEG",8,"DAT",10,"DES",1,0)="Contains the Transaction Control Number of a transaction that initiated "
