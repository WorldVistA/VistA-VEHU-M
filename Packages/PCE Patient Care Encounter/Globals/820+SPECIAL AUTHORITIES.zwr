OSEHRA ZGO Export: SPECIAL AUTHORITIES
ZWR
^PXIND(820,0)="SPECIAL AUTHORITIES^820^13^11"
^PXIND(820,1,0)="SERVICE CONNECTED^SC^Service &Connected Condition^5^SC"
^PXIND(820,1,3,0)="^820.08^4^4^3250424^^^^"
^PXIND(820,1,3,1,0)="Service-Connected (SC):"
^PXIND(820,1,3,2,0)="Veterans are eligible for medical care for treatment of service-connected"
^PXIND(820,1,3,3,0)="(SC) conditions without incurring copayment charges or claims against"
^PXIND(820,1,3,4,0)="their insurance.  See 'Help' for additional information."
^PXIND(820,2,0)="AGENT ORANGE^AO^Agent &Orange Exposure^15^AO"
^PXIND(820,2,3,0)="^820.08^9^9^3250417^^^^"
^PXIND(820,2,3,1,0)="Agent Orange (AO):"
^PXIND(820,2,3,2,0)="Herbicide used in Vietnam.  Veterans who were present within the borders"
^PXIND(820,2,3,3,0)="of the Republic of Vietnam from January 1962 through May 1975 are presumed"
^PXIND(820,2,3,4,0)="to have been exposed to Agent Orange and are eligible to receive care of"
^PXIND(820,2,3,5,0)="conditions possibly for AO exposure without incurring copayment charges or"
^PXIND(820,2,3,6,0)="claims against their insurance. Some conditions associated with AO"
^PXIND(820,2,3,7,0)="exposure: diabetes (type 2), chloracne, porphyria cutanea tarda,"
^PXIND(820,2,3,8,0)="peripheral neuropathy and some cancers.  See 'Help' for additional"
^PXIND(820,2,3,9,0)="information."
^PXIND(820,3,0)="IONIZING RADIATION EXPOSURE^IR^Ionizing &Radiation Exposure^20^IR"
^PXIND(820,3,3,0)="^820.08^7^7^3250417^^"
^PXIND(820,3,3,1,0)="Ionizing Radiation (IR):"
^PXIND(820,3,3,2,0)="Veterans exposed to ionizing radiation (IR) as a POW or while on active"
^PXIND(820,3,3,3,0)="duty in Hiroshima and/or Nagasaki, Japan, or who served at a nuclear"
^PXIND(820,3,3,4,0)="device atmospheric testing site are eligible to receive care of any"
^PXIND(820,3,3,5,0)="malignant condition and certain other non-malignant conditions for IR"
^PXIND(820,3,3,6,0)="exposure without incurring copayment charges or claims against their"
^PXIND(820,3,3,7,0)="insurance.  See 'Help' for additional information."
^PXIND(820,4,0)="SW ASIA CONDITIONS^EC^Southwest &Asia Conditions^25^SWAC"
^PXIND(820,4,3,0)="^^7^7^3240715^"
^PXIND(820,4,3,1,0)="Southwest Asia Conditions (SWAC):"
^PXIND(820,4,3,2,0)="Veterans who served in Southwest Asia during the Gulf War are eligible to"
^PXIND(820,4,3,3,0)="receive treatment for conditions relating to this service, including"
^PXIND(820,4,3,4,0)="exposure to depleted uranium, pesticides, anti- nerve gas pill,"
^PXIND(820,4,3,5,0)="pyridostigmine bromide, infectious diseases, chemical and biological"
^PXIND(820,4,3,6,0)="warfare agents, etc. without incurring copayment charges or claims against"
^PXIND(820,4,3,7,0)="their insurance.  See 'Help' for additional information."
^PXIND(820,5,0)="PROJ 112/SHAD^SHAD^Shipboard &Hazard and Defense^30^SHD"
^PXIND(820,5,3,0)="^820.08^7^7^3240715^^"
^PXIND(820,5,3,1,0)="Shipboard Hazard and Defense (SHD):"
^PXIND(820,5,3,2,0)="Veterans with conditions recognized by VA as associated with Project 112/"
^PXIND(820,5,3,3,0)="SHAD, shipboard and land-based biological and chemical testing conducted"
^PXIND(820,5,3,4,0)="by the United States (U.S.) military between 1962 and 1973 are eligible"
^PXIND(820,5,3,5,0)="for enrollment in priority group 6, unless eligible for enrollment in a"
^PXIND(820,5,3,6,0)="higher priority. In addition, veterans receive care at no charge for care"
^PXIND(820,5,3,7,0)="and medications provided for treatment of conditions related to exposure."
^PXIND(820,6,0)="MILITARY SEXUAL TRAUMA^MST^&MST^35^MST"
^PXIND(820,6,3,0)="^820.08^5^5^3250815^^^^"
^PXIND(820,6,3,1,0)="Military Sexual Trauma (MST):"
^PXIND(820,6,3,2,0)="Veterans who experienced sexual trauma while serving on active duty in the"
^PXIND(820,6,3,3,0)="military are eligible to receive treatment and counseling services for the"
^PXIND(820,6,3,4,0)="sexual trauma without incurring copayment charges or claims against their"
^PXIND(820,6,3,5,0)="insurance.  See 'Help' for additional information."
^PXIND(820,7,0)="HEAD AND/OR NECK CANCER^HNC^Head and/or &Neck Cancer^40^HNC"
^PXIND(820,7,3,0)="^^6^6^3240715^"
^PXIND(820,7,3,1,0)="Head and Neck Cancer (HNC):"
^PXIND(820,7,3,2,0)="Veterans with cancer of the head or neck and a history of receipt of"
^PXIND(820,7,3,3,0)="Nasopharyngeal (NP) radium therapy while in the military are eligible to"
^PXIND(820,7,3,4,0)="receive treatment for the head or neck cancer without incurring copayment"
^PXIND(820,7,3,5,0)="charges or claims against their insurance. See 'Help' for additional"
^PXIND(820,7,3,6,0)="information."
^PXIND(820,8,0)="COMBAT VETERAN^CV^Combat &Vet (Combat Related)^10^CV^^1"
^PXIND(820,8,3,0)="^820.08^9^9^3241211^^^^"
^PXIND(820,8,3,1,0)="Combat Veteran (CV):"
^PXIND(820,8,3,2,0)="To receive CV exemption the veteran must have served in combat operations"
^PXIND(820,8,3,3,0)="after the Gulf War or in combat against a hostile force after November 11,"
^PXIND(820,8,3,4,0)="1998.  In addition, the condition for which the veteran is treated must be"
^PXIND(820,8,3,5,0)="related to that combat, the veteran must have registered as a combat"
^PXIND(820,8,3,6,0)="veteran, and be within two years of separation from active military"
^PXIND(820,8,3,7,0)="service.  Finally, the condition must not be already considered to be"
^PXIND(820,8,3,8,0)="service related or that exemption should apply.  See 'Help' for additional"
^PXIND(820,8,3,9,0)="information."
^PXIND(820,9,0)="COMPACT ACT^ASC^Acute Suicidal Crisis^45^ASC^^^1"
^PXIND(820,9,3,0)="^^1^1^3250805^"
^PXIND(820,9,3,1,0)="Acute Suicidal Episode (COMPACT Act)"
^PXIND(820,10,0)="CAMP LEJEUNE^CL^Camp &Lejeune^50^CL^^^1"
^PXIND(820,13,0)="TOXIC EXPOSURE RISK ACTIVITY^TERA^Exposure to Toxins and Other Hazards^55^TOX^^^1"
^PXIND(820,"B","AGENT ORANGE",2)=""
